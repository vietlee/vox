<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In — VOX</title>
  <%= csrf_meta_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    html, body { margin: 0; padding: 0; background: #0F172A; font-family: 'Inter', sans-serif; }
    * { box-sizing: border-box; }
    input:focus { border-color: #6366f1 !important; box-shadow: 0 0 0 3px rgba(99,102,241,0.2) !important; outline: none; }
    .auth-card-wrap { width: 480px; margin: 0 auto; }
    @media (max-width: 768px) { .auth-card-wrap { width: 100%; } }
  </style>
</head>
<body>

  <!-- Language switcher fixed top-right -->
  <div style="position:fixed; top:16px; right:16px; z-index:999; display:flex; gap:4px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:10px; padding:4px;">
    <%= link_to request.path + "?locale=vi", style: "display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; #{I18n.locale == :vi ? 'background:#4f46e5; color:#fff;' : 'color:#64748b;'}" do %>🇻🇳 VI<% end %>
    <%= link_to request.path + "?locale=en", style: "display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; #{I18n.locale == :en ? 'background:#4f46e5; color:#fff;' : 'color:#64748b;'}" do %>🇬🇧 EN<% end %>
  </div>

  <!-- Centered wrapper -->
  <div style="padding: 72px 0 48px; margin: 0 auto; width: 100%">
    <div class="auth-card-wrap">

      <!-- Logo -->
      <div style="text-align:center; margin-bottom:28px;">
        <div style="display:inline-flex; align-items:center; gap:12px; filter:drop-shadow(0 8px 28px rgba(26,107,255,0.4)); margin-bottom:8px;">
          <img src="/icon.svg" width="52" height="52" alt="VOX" style="display:block;">
          <div style="font-family:system-ui,-apple-system,'Helvetica Neue',Arial,sans-serif; font-size:42px; font-weight:800; letter-spacing:10px; color:#2D1B8B; line-height:1; padding-left:4px;">VOX</div>
        </div>
        <p style="font-size:13px; color:#64748b; margin-top:0;">
          <%= I18n.locale == :vi ? "Đăng nhập vào workspace của bạn" : "Sign in to your workspace" %>
        </p>
      </div>

      <!-- Card -->
      <div style="background:#1E293B; border-radius:20px; border:1px solid rgba(255,255,255,0.07); padding:28px; box-shadow:0 24px 60px rgba(0,0,0,0.5);">

        <% if flash[:alert] %>
          <div style="margin-bottom:18px; display:flex; align-items:flex-start; gap:10px; padding:14px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:12px; font-size:13px; color:#f87171; line-height:1.5;">
            <span>⚠</span><span><%= flash[:alert] %></span>
          </div>
        <% end %>

        <%= form_with model: resource, as: resource_name, url: session_path(resource_name), local: true, data: { turbo: false } do |f| %>

          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Email</label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: t("devise.placeholder_email", default: "you@example.com"),
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
          </div>

          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">
              <%= I18n.locale == :vi ? "Mật khẩu" : "Password" %>
            </label>
            <%= f.password_field :password, autocomplete: "current-password",
              placeholder: "••••••••",
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
            <div style="text-align:right; margin-top:8px;">
              <%= link_to new_user_password_path(locale: I18n.locale), style: "font-size:12px; color:#818cf8; text-decoration:none; font-weight:600;" do %>
                <%= I18n.locale == :vi ? "Quên mật khẩu?" : "Forgot password?" %>
              <% end %>
            </div>
          </div>

          <div style="display:flex; align-items:center; gap:10px; margin-bottom:20px;">
            <%= f.check_box :remember_me, id: "remember_me", style: "width:16px; height:16px; accent-color:#6366f1; cursor:pointer;" %>
            <label for="remember_me" style="font-size:13px; color:#64748b; cursor:pointer;">
              <%= I18n.locale == :vi ? "Ghi nhớ đăng nhập" : "Remember me" %>
            </label>
          </div>

          <%= f.submit (I18n.locale == :vi ? "Đăng nhập →" : "Sign In →"),
            style: "display:block; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:8px; cursor:pointer; font-family:'Inter',sans-serif;" %>

        <% end %>

        <!-- Divider -->
        <div style="display:flex; align-items:center; gap:12px; margin:20px 0;">
          <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
          <span style="font-size:11px; color:#475569; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">
            <%= I18n.locale == :vi ? "Hoặc đăng nhập với" : "Or continue with" %>
          </span>
          <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
        </div>

        <!-- SSO Buttons -->
        <div style="display:flex; flex-direction:column; gap:10px;">
          <%= button_to user_google_oauth2_omniauth_authorize_path(locale: I18n.locale), method: :post,
            data: { turbo: false },
            style: "display:flex; align-items:center; justify-content:center; gap:10px; padding:13px 16px; background:#fff; border:none; border-radius:10px; font-size:14px; font-weight:600; color:#1e293b; cursor:pointer; width:100%; font-family:'Inter',sans-serif;" do %>
            <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.95 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg>
            <%= I18n.locale == :vi ? "Đăng nhập với Google" : "Continue with Google" %>
          <% end %>

          <%= button_to user_entra_id_omniauth_authorize_path(locale: I18n.locale), method: :post,
            data: { turbo: false },
            style: "display:flex; align-items:center; justify-content:center; gap:10px; padding:13px 16px; background:#2f3136; border:1px solid rgba(255,255,255,0.1); border-radius:10px; font-size:14px; font-weight:600; color:#f1f5f9; cursor:pointer; width:100%; font-family:'Inter',sans-serif;" do %>
            <svg width="18" height="18" viewBox="0 0 23 23"><path fill="#f3f3f3" d="M0 0h23v23H0z"/><path fill="#f35325" d="M1 1h10v10H1z"/><path fill="#81bc06" d="M12 1h10v10H12z"/><path fill="#05a6f0" d="M1 12h10v10H1z"/><path fill="#ffba08" d="M12 12h10v10H12z"/></svg>
            <%= I18n.locale == :vi ? "Đăng nhập với Microsoft" : "Continue with Microsoft" %>
          <% end %>
        </div>

      </div>

      <p style="text-align:center; font-size:13px; color:#475569; margin-top:18px;">
        <%= I18n.locale == :vi ? "Chưa có tài khoản?" : "Don't have an account?" %>
        <%= link_to (I18n.locale == :vi ? "Đăng ký miễn phí" : "Sign up free"), new_user_registration_path, style: "color:#818cf8; font-weight:600; text-decoration:none;" %>
      </p>

    </div>
  </div>

</body>
</html>
