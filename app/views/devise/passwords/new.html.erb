<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= I18n.locale == :vi ? "Đặt lại mật khẩu" : "Reset Password" %> — VOX</title>
  <%= csrf_meta_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    html, body { margin: 0; padding: 0; background: #0F172A; font-family: 'Inter', sans-serif; }
    * { box-sizing: border-box; }
    input:focus { border-color: #6366f1 !important; box-shadow: 0 0 0 3px rgba(99,102,241,0.2) !important; outline: none; }
    .auth-card-wrap { width: 480px; margin: 0 auto; }
    @media (max-width: 520px) { .auth-card-wrap { width: 100%; } }
  </style>
</head>
<body>

  <!-- Language switcher -->
  <div style="position:fixed; top:16px; right:16px; z-index:999; display:flex; gap:4px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:10px; padding:4px;">
    <%= link_to request.path + "?locale=vi", style: "display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; #{I18n.locale == :vi ? 'background:#4f46e5; color:#fff;' : 'color:#64748b;'}" do %>🇻🇳 VI<% end %>
    <%= link_to request.path + "?locale=en", style: "display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; #{I18n.locale == :en ? 'background:#4f46e5; color:#fff;' : 'color:#64748b;'}" do %>🇬🇧 EN<% end %>
  </div>

  <!-- Centered wrapper -->
  <div style="padding: 72px 16px 48px;margin: 0 auto;">
    <div class="auth-card-wrap">

      <!-- Logo -->
      <div style="text-align:center; margin-bottom:28px;">
        <div style="display:inline-block; filter:drop-shadow(0 8px 28px rgba(26,107,255,0.5));">
          <svg width="72" height="72" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
            <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
            <polygon points="325,84 318,98 338,84" fill="white"/>
            <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
            <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
            <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
            <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
          </svg>
        </div>
        <div style="font-family:system-ui,-apple-system,'Helvetica Neue',Arial,sans-serif; font-size:38px; font-weight:800; letter-spacing:10px; color:#1A6BFF; line-height:1; padding-left:10px;">VOX</div>
      </div>

      <!-- Card -->
      <div style="background:#1E293B; border-radius:20px; border:1px solid rgba(255,255,255,0.07); box-shadow:0 24px 60px rgba(0,0,0,0.5); overflow:hidden;">

        <!-- Header -->
        <div style="padding:28px 28px 24px; border-bottom:1px solid rgba(255,255,255,0.05);">
          <div style="width:46px; height:46px; background:rgba(245,158,11,0.12); border:1px solid rgba(245,158,11,0.25); border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:22px; margin-bottom:16px;">🔑</div>
          <h1 style="font-size:20px; font-weight:800; color:#f1f5f9; margin:0 0 8px;">
            <%= I18n.locale == :vi ? "Quên mật khẩu?" : "Forgot your password?" %>
          </h1>
          <p style="font-size:13px; color:#64748b; margin:0; line-height:1.6;">
            <%= I18n.locale == :vi ? "Nhập email tài khoản, chúng tôi sẽ gửi liên kết đặt lại mật khẩu ngay." : "Enter your email and we'll send you a reset link right away." %>
          </p>
        </div>

        <!-- Form -->
        <div style="padding:24px 28px;">

          <%# ── SUCCESS STATE ── %>
          <div id="sent-state" style="display:<%= @email_sent ? 'block' : 'none' %>; text-align:center; padding:8px 0 16px;">
            <div style="width:56px; height:56px; background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.25); border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:26px; margin:0 auto 16px;">📬</div>
            <div style="font-size:15px; font-weight:700; color:#f1f5f9; margin-bottom:8px;">
              <%= I18n.locale == :vi ? "Đã gửi email!" : "Email sent!" %>
            </div>
            <p style="font-size:13px; color:#94a3b8; line-height:1.8; margin:0 0 20px;">
              <% if I18n.locale == :vi %>
                Chúng tôi đã gửi liên kết đặt lại mật khẩu tới<br>
                <span style="color:#a5b4fc; font-weight:600;"><%= @submitted_email %></span><br>
                Hãy kiểm tra hộp thư (kể cả thư mục Spam).
              <% else %>
                We sent a password reset link to<br>
                <span style="color:#a5b4fc; font-weight:600;"><%= @submitted_email %></span><br>
                Please check your inbox (and Spam folder).
              <% end %>
            </p>
            <div>
              <span style="font-size:12px; color:#475569;">
                <%= I18n.locale == :vi ? "Không nhận được email?" : "Didn't receive it?" %>
              </span>
              <button type="button"
                onclick="document.getElementById('sent-state').style.display='none'; document.getElementById('form-state').style.display='block';"
                style="background:none; border:none; color:#818cf8; font-size:12px; font-weight:600; cursor:pointer; padding:0 0 0 4px; font-family:'Inter',sans-serif; text-decoration:underline;">
                <%= I18n.locale == :vi ? "Gửi lại" : "Resend" %>
              </button>
            </div>
          </div>

          <%# ── FORM STATE ── %>
          <div id="form-state" style="display:<%= @email_sent ? 'none' : 'block' %>;">
            <% if resource.errors.any? %>
              <div style="margin-bottom:16px; display:flex; align-items:flex-start; gap:10px; padding:14px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:12px; font-size:13px; color:#f87171; line-height:1.5;">
                <span>⚠</span>
                <div>
                  <% resource.errors.full_messages.each do |msg| %>
                    <div>• <%= msg %></div>
                  <% end %>
                </div>
              </div>
            <% end %>

            <%= form_with model: resource, as: resource_name, url: password_path(resource_name), method: :post, local: true, data: { turbo: false } do |f| %>
              <div style="margin-bottom:16px;">
                <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Email</label>
                <%= f.email_field :email, autofocus: true, autocomplete: "email",
                  placeholder: (I18n.locale == :vi ? "ban@congty.com" : "you@company.com"),
                  style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
              </div>
              <button type="submit" id="submit-btn"
                style="display:block; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:8px; cursor:pointer; font-family:'Inter',sans-serif; transition:opacity 0.2s;">
                <span id="submit-text"><%= I18n.locale == :vi ? "Gửi liên kết đặt lại →" : "Send Reset Link →" %></span>
                <span id="submit-loading" style="display:none;">
                  <svg style="display:inline;vertical-align:middle;margin-right:6px;" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83">
                      <animateTransform attributeName="transform" type="rotate" from="0 12 12" to="360 12 12" dur="0.8s" repeatCount="indefinite"/>
                    </path>
                  </svg>
                  <%= I18n.locale == :vi ? "Đang gửi..." : "Sending..." %>
                </span>
              </button>
            <% end %>

            <script>
              document.querySelector('form').addEventListener('submit', function() {
                var btn = document.getElementById('submit-btn');
                document.getElementById('submit-text').style.display = 'none';
                document.getElementById('submit-loading').style.display = 'inline';
                btn.disabled = true;
                btn.style.opacity = '0.75';
              });
            </script>
          </div>

        </div>

        <!-- Back -->
        <div style="padding:0 28px 24px;">
          <%= link_to new_user_session_path(locale: I18n.locale),
            style: "display:flex; align-items:center; justify-content:center; gap:8px; padding:13px; font-size:13px; color:#64748b; text-decoration:none; border:1.5px solid rgba(255,255,255,0.07); border-radius:12px;" do %>
            ← <%= I18n.locale == :vi ? "Quay lại đăng nhập" : "Back to sign in" %>
          <% end %>
        </div>
      </div>

      <p style="text-align:center; font-size:11px; color:#334155; margin-top:18px;">© <%= Date.current.year %> VOX Platform</p>
    </div>
  </div>

</body>
</html>
