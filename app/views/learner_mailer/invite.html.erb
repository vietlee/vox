<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bạn được mời tham gia VOX Learn</title>
</head>
<body style="margin:0;padding:0;background-color:#f0f4f8;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">

<!-- Wrapper -->
<table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color:#f0f4f8;">
  <tr>
    <td align="center" valign="top" style="padding:32px 12px;">

      <!-- Card -->
      <table border="0" cellpadding="0" cellspacing="0" width="520" style="width:100%;max-width:520px;background-color:#ffffff;">

        <!-- Header -->
        <tr>
          <td align="center" valign="top" bgcolor="#1e3a5f" style="background-color:#1e3a5f;padding:32px 24px 28px;">
            <p style="margin:0 0 12px 0;color:#93b8d8;font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:bold;letter-spacing:2px;text-transform:uppercase;">VOX LEARN</p>
            <h1 style="margin:0;color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:26px;font-weight:800;line-height:1.3;">Bạn được mời<br/>tham gia học tập!</h1>
          </td>
        </tr>

        <!-- Accent bar -->
        <tr>
          <td bgcolor="#4a7fa8" style="background-color:#4a7fa8;height:4px;font-size:4px;line-height:4px;">&nbsp;</td>
        </tr>

        <!-- Body -->
        <tr>
          <td valign="top" style="padding:28px 24px 8px 24px;">

            <!-- Greeting -->
            <p style="margin:0 0 6px 0;font-family:Arial,Helvetica,sans-serif;font-size:16px;color:#1e293b;">
              Xin chào <strong style="color:#1e3a5f;"><%= @learner.name %></strong>,
            </p>
            <p style="margin:0 0 24px 0;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#64748b;line-height:1.7;">
              <strong style="color:#1e3a5f;"><%= @assigned_by.name %></strong> đã mời bạn tham gia
              <strong style="color:#1e3a5f;">VOX Learn</strong> — nền tảng học tập thông minh với
              Quiz, Flashcard, Lộ trình học và AI Tutor.
            </p>

            <!-- Feature pills 2x2 grid -->
            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:28px;">
              <tr>
                <td width="50%" style="padding:0 4px 6px 0;">
                  <table border="0" cellpadding="0" cellspacing="0" width="100%">
                    <tr>
                      <td bgcolor="#f0f4f8" style="background-color:#f0f4f8;border:1px solid #d1dce8;border-radius:20px;padding:6px 14px;text-align:center;">
                        <span style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:bold;color:#1e3a5f;">🎓 Quiz</span>
                      </td>
                    </tr>
                  </table>
                </td>
                <td width="50%" style="padding:0 0 6px 4px;">
                  <table border="0" cellpadding="0" cellspacing="0" width="100%">
                    <tr>
                      <td bgcolor="#f0f4f8" style="background-color:#f0f4f8;border:1px solid #d1dce8;border-radius:20px;padding:6px 14px;text-align:center;">
                        <span style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:bold;color:#1e3a5f;">🃏 Flashcard</span>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
              <tr>
                <td width="50%" style="padding:0 4px 0 0;">
                  <table border="0" cellpadding="0" cellspacing="0" width="100%">
                    <tr>
                      <td bgcolor="#f0f4f8" style="background-color:#f0f4f8;border:1px solid #d1dce8;border-radius:20px;padding:6px 14px;text-align:center;">
                        <span style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:bold;color:#1e3a5f;">🗺️ Lộ trình</span>
                      </td>
                    </tr>
                  </table>
                </td>
                <td width="50%" style="padding:0 0 0 4px;">
                  <table border="0" cellpadding="0" cellspacing="0" width="100%">
                    <tr>
                      <td bgcolor="#f0f4f8" style="background-color:#f0f4f8;border:1px solid #d1dce8;border-radius:20px;padding:6px 14px;text-align:center;">
                        <span style="font-family:Arial,Helvetica,sans-serif;font-size:13px;font-weight:bold;color:#1e3a5f;">🤖 AI Tutor</span>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>

          </td>
        </tr>

        <!-- CTA Button row -->
        <tr>
          <td align="center" valign="top" style="padding:0 24px 28px 24px;">
            <table border="0" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td align="center" bgcolor="#1e3a5f" style="background-color:#1e3a5f;border-radius:12px;padding:0;">
                  <a href="<%= @invite_url %>"
                     style="display:block;padding:16px 24px;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;color:#ffffff;text-decoration:none;text-align:center;">
                    Thiết lập tài khoản →
                  </a>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Info note -->
        <tr>
          <td valign="top" style="padding:0 24px 28px 24px;">
            <table border="0" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td bgcolor="#f8fafc" style="background-color:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:14px 16px;text-align:center;">
                  <p style="margin:0 0 6px 0;font-family:Arial,Helvetica,sans-serif;font-size:12px;color:#94a3b8;">
                    ⏳ Link có hiệu lực trong <strong style="color:#64748b;">7 ngày</strong>.<br/>Nếu gặp vấn đề, copy link bên dưới:
                  </p>
                  <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#94a3b8;word-break:break-all;"><%= @invite_url %></p>
                </td>
              </tr>
            </table>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td align="center" bgcolor="#f8fafc" style="background-color:#f8fafc;border-top:1px solid #e2e8f0;padding:14px 24px;">
            <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:11px;color:#94a3b8;">© 2026 VOX · Nền tảng học tập thông minh</p>
          </td>
        </tr>

      </table>
      <!-- /Card -->

    </td>
  </tr>
</table>

</body>
</html>
