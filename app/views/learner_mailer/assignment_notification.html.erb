<!DOCTYPE html>
<html>
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    @media only screen and (max-width:600px) {
      .em-wrap  { width: 100% !important; max-width: 100% !important; margin: 0 !important; border-radius: 0 !important; }
      .em-hd    { padding: 26px 16px !important; }
      .em-hd h1 { font-size: 19px !important; }
      .em-body  { padding: 24px 16px !important; }
      .em-ft    { padding: 14px 16px !important; }
      .em-btn   { display: block !important; padding: 15px !important; font-size: 15px !important; }
    }
  </style>
</head>
<body style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;background:#eef3f9;padding:0;margin:0;">

<div class="em-wrap" style="max-width:540px;margin:32px auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 2px 16px rgba(30,58,95,0.10);">

  <!-- Header -->
  <div class="em-hd" style="background:#1e3a5f;padding:28px 32px;text-align:center;">
    <div style="margin-bottom:12px;">
      <span style="color:rgba(255,255,255,0.85);font-size:12px;font-weight:700;letter-spacing:1px;text-transform:uppercase;">VOX Learn</span>
    </div>
    <h1 style="color:#ffffff;font-size:22px;font-weight:800;margin:0;line-height:1.3;">Bạn có <strong><%= @type_label %></strong> mới!</h1>
  </div>

  <div style="height:4px;background:linear-gradient(90deg,#1e3a5f,#4a80a8,#1e3a5f);"></div>

  <!-- Body -->
  <div class="em-body" style="padding:28px 32px;">
    <p style="font-size:16px;color:#1e293b;margin:0 0 8px;">Xin chào <strong style="color:#1e3a5f;"><%= @learner.name %></strong>,</p>
    <p style="font-size:14px;color:#64748b;line-height:1.7;margin:0 0 24px;">
      Bạn vừa được giao một <strong style="color:#1e3a5f;"><%= @type_label %></strong> trên VOX Learn:
    </p>

    <!-- Resource card -->
    <div style="background:#eef3f9;border:1px solid #d9e5f1;border-radius:12px;padding:16px 20px;margin-bottom:28px;">
      <p style="font-size:11px;font-weight:700;color:#4a80a8;text-transform:uppercase;letter-spacing:.6px;margin:0 0 6px;"><%= @type_label %></p>
      <p style="font-size:16px;font-weight:800;color:#1e3a5f;margin:0;"><%= @resource_title %></p>
    </div>

    <!-- CTA -->
    <div style="text-align:center;margin-bottom:24px;">
      <a href="<%= @access_url %>" class="em-btn"
         style="display:inline-block;background:#1e3a5f;color:#ffffff;text-decoration:none;padding:14px 32px;border-radius:12px;font-weight:700;font-size:15px;">
        Bắt đầu ngay →
      </a>
    </div>

    <!-- Fallback link -->
    <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:12px 16px;">
      <p style="font-size:12px;color:#94a3b8;margin:0;text-align:center;">Nếu không thể click nút, copy link bên dưới:</p>
      <p style="font-size:11px;color:#94a3b8;text-align:center;word-break:break-all;margin:4px 0 0;"><%= @access_url %></p>
    </div>
  </div>

  <!-- Footer -->
  <div class="em-ft" style="background:#f8fafc;border-top:1px solid #e2e8f0;padding:14px 32px;text-align:center;">
    <p style="font-size:11px;color:#94a3b8;margin:0;">© <%= Date.current.year %> VOX · Nền tảng học tập thông minh</p>
  </div>
</div>

</body>
</html>
