<% content_for :title, @outline.title %>

<style>
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin:0; padding:0; background:#0f172a; font-family:Inter,sans-serif; height:100%; }

  #pub-root {
    display:flex; flex-direction:column;
    min-height:100vh;
    padding:12px 16px 24px;
  }

  #pub-header {
    display:flex; align-items:center; justify-content:space-between;
    margin-bottom:10px;
  }
  .pub-title { color:#fff; font-weight:600; font-size:15px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:70%; }
  .pub-btn-fs {
    background:#1e293b; color:#94a3b8; border:1px solid #334155;
    border-radius:8px; padding:6px 14px; cursor:pointer;
    font-size:13px; font-family:Inter,sans-serif; white-space:nowrap;
  }
  .pub-btn-fs:hover { background:#334155; color:#fff; }

  #slide-outer {
    flex:1;
    display:flex; align-items:center; justify-content:center;
  }
  #slide-wrap {
    position:relative;
    width:100%;
    background:#1e293b;
    border-radius:10px;
    overflow:hidden;
    box-shadow:0 8px 40px rgba(0,0,0,.5);
  }
  #slide-stage {
    width:1280px;
    height:720px;
    position:absolute;
    top:0; left:0;
    overflow:hidden;
    background:#fff;
    pointer-events:none;
  }
  #slide-wrap:-webkit-full-screen,
  #slide-wrap:fullscreen {
    width:100% !important; height:100% !important;
    border-radius:0; overflow:hidden; background:#000;
  }

  .pub-dots { display:flex; gap:6px; align-items:center; flex-wrap:wrap; justify-content:center; margin-top:10px; }
  .pub-dot { width:8px; height:8px; border-radius:50%; background:#334155; cursor:pointer; transition:background .15s, transform .15s; }
  .pub-dot.active { background:#6366f1; transform:scale(1.3); }

  .pub-nav { display:flex; align-items:center; justify-content:center; gap:16px; margin-top:12px; }
  .pub-nav button {
    background:#1e293b; color:#fff; border:1px solid #334155;
    border-radius:8px; padding:9px 28px; cursor:pointer;
    font-size:14px; font-family:Inter,sans-serif; transition:background .15s;
  }
  .pub-nav button:hover { background:#334155; }
  .pub-nav button:disabled { opacity:.3; cursor:default; }
  #slide-counter { color:#94a3b8; font-size:14px; min-width:80px; text-align:center; }
</style>

<div id="pub-root">
  <div id="pub-header">
    <div class="pub-title"><%= @outline.title %></div>
    <div style="display:flex;gap:8px;align-items:center;">
      <span style="color:#475569;font-size:12px;">VOX Slides · view only</span>
      <button class="pub-btn-fs" onclick="enterFullscreen()">⛶ Toàn màn hình</button>
    </div>
  </div>

  <div id="slide-outer" style="display:flex;justify-content:center;align-items:flex-start;padding-top:4px;">
    <div id="slide-wrap">
      <div id="slide-stage"></div>
    </div>
  </div>

  <div class="pub-dots" id="pub-dots"></div>

  <div class="pub-nav">
    <button id="btn-prev" onclick="prevSlide()">← Trước</button>
    <span id="slide-counter"></span>
    <button id="btn-next" onclick="nextSlide()">Sau →</button>
  </div>
</div>

<script>
  var deck        = <%= raw @outline.slide_json.presence || '{"slides":[],"theme":{}}' %>;
  var slides      = deck.slides || [];
  var total       = slides.length;
  var current     = 0;
  var editorMode  = false;
  var SW = 10.0, SH = 5.625;
  var PX = function(inch) { return Math.round(inch * 128); };
  var PT = function(pt)   { return Math.round(pt * 128 / 72); };

  /* ── Theme helpers ── */
  function _hexLuminance(hex) {
    hex = hex.replace('#','');
    if (hex.length===3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
    var r=parseInt(hex.substr(0,2),16)/255, g=parseInt(hex.substr(2,2),16)/255, b=parseInt(hex.substr(4,2),16)/255;
    var toL=function(c){return c<=0.03928?c/12.92:Math.pow((c+0.055)/1.055,2.4);};
    return 0.2126*toL(r)+0.7152*toL(g)+0.0722*toL(b);
  }
  function _darken(hex, amt) {
    hex = hex.replace('#','');
    if (hex.length===3) hex = hex[0]+hex[0]+hex[1]+hex[1]+hex[2]+hex[2];
    var r=Math.max(0,parseInt(hex.substr(0,2),16)-amt);
    var g=Math.max(0,parseInt(hex.substr(2,2),16)-amt);
    var b=Math.max(0,parseInt(hex.substr(4,2),16)-amt);
    return '#'+[r,g,b].map(function(v){return v.toString(16).padStart(2,'0');}).join('');
  }
  function applyThemeAccent() {
    var accent = (deck.theme && deck.theme.accent) || '#6366f1';
    if (_hexLuminance(accent) > 0.55) accent = '#6366f1';
    var accentDk = _darken(accent, 20);
    document.documentElement.style.setProperty('--vox-accent', accent);
    document.documentElement.style.setProperty('--vox-accent-dk', accentDk);
  }
  function _accent()   { return getComputedStyle(document.documentElement).getPropertyValue('--vox-accent').trim()  || '#6366f1'; }
  function _accentDk() { return getComputedStyle(document.documentElement).getPropertyValue('--vox-accent-dk').trim()|| '#4f46e5'; }

  /* ── Render engine ── */
  <%= render 'admin/content_outlines/slide_render_engine' %>

  function renderSlide(idx) {
    var s = slides[idx];
    if (!s) return '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#94A3B8;">Không có slide</div>';
    var bg = s.background || { type:'solid', color:'#ffffff' };
    var bgCss = bg.type === 'gradient' ? 'background:' + bg.value + ';' : 'background:' + (bg.color||'#fff') + ';';
    var els = (s.elements || []).sort(function(a,b){ return (a.z||2)-(b.z||2); });
    var content = els.map(function(e){ return renderEl(e, idx); }).join('');
    return '<div style="position:absolute;inset:0;' + bgCss + '">' + content + '</div>';
  }

  /* ── Navigation ── */
  function updateUI() {
    var ctr = document.getElementById('slide-counter');
    if (ctr) ctr.textContent = (current+1) + ' / ' + total;
    var prev = document.getElementById('btn-prev');
    var next = document.getElementById('btn-next');
    if (prev) prev.disabled = current === 0;
    if (next) next.disabled = current === total - 1;
    document.querySelectorAll('.pub-dot').forEach(function(d, i) {
      d.classList.toggle('active', i === current);
    });
  }

  function goToSlide(idx) {
    current = Math.max(0, Math.min(idx, total - 1));
    var stage = document.getElementById('slide-stage');
    if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
    updateUI();
    rescaleCanvas();
    window.history.replaceState(null, '', location.pathname + '#s' + current);
  }
  function nextSlide() { goToSlide(current + 1); }
  function prevSlide() { goToSlide(current - 1); }

  /* ── Dots ── */
  function buildDots() {
    var c = document.getElementById('pub-dots');
    if (!c) return;
    c.innerHTML = '';
    slides.forEach(function(_, i) {
      var d = document.createElement('div');
      d.className = 'pub-dot' + (i === 0 ? ' active' : '');
      d.onclick = (function(idx){ return function(){ goToSlide(idx); }; })(i);
      c.appendChild(d);
    });
  }

  /* ── Rescale (normal mode) ── */
  function rescaleCanvas() {
    if (_inFullscreen) return;
    var wrap  = document.getElementById('slide-wrap');
    var stage = document.getElementById('slide-stage');
    if (!wrap || !stage) return;
    var availW = window.innerWidth  - 32;
    var availH = window.innerHeight - 130;
    var scale  = Math.min(availW / 1280, availH / 720);
    var scaledW = Math.round(1280 * scale);
    var scaledH = Math.round(720  * scale);
    wrap.style.width  = scaledW + 'px';
    wrap.style.height = scaledH + 'px';
    stage.style.transform       = 'scale(' + scale + ')';
    stage.style.transformOrigin = 'top left';
  }

  /* ── Fullscreen (mirrors admin behavior) ── */
  var _inFullscreen = false;
  function enterFullscreen() {
    var el = document.getElementById('slide-wrap');
    if (el.requestFullscreen)       el.requestFullscreen();
    else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
  }
  function rescaleFullscreen() {
    var wrap  = document.getElementById('slide-wrap');
    var stage = document.getElementById('slide-stage');
    if (!wrap || !stage) return;
    var fw = window.screen.width, fh = window.screen.height;
    var scale   = Math.min(fw / 1280, fh / 720);
    var scaledW = Math.round(1280 * scale);
    var scaledH = Math.round(720  * scale);
    wrap.style.width  = fw + 'px';
    wrap.style.height = fh + 'px';
    stage.style.transformOrigin = 'top left';
    stage.style.transform = 'scale(' + scale + ')';
    stage.style.left = Math.floor((fw - scaledW) / 2) + 'px';
    stage.style.top  = Math.floor((fh - scaledH) / 2) + 'px';
  }
  function onFullscreenEnter() {
    _inFullscreen = true;
    requestAnimationFrame(function() { requestAnimationFrame(rescaleFullscreen); });
  }
  function onFullscreenExit() {
    _inFullscreen = false;
    var wrap = document.getElementById('slide-wrap');
    var stage = document.getElementById('slide-stage');
    if (stage) { stage.style.left = '0'; stage.style.top = '0'; }
    requestAnimationFrame(rescaleCanvas);
  }
  document.addEventListener('fullscreenchange', function() {
    if (document.fullscreenElement) onFullscreenEnter(); else onFullscreenExit();
  });
  document.addEventListener('webkitfullscreenchange', function() {
    if (document.webkitFullscreenElement) onFullscreenEnter(); else onFullscreenExit();
  });

  /* ── Keyboard ── */
  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown' || e.key === ' ') { e.preventDefault(); nextSlide(); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')                    { e.preventDefault(); prevSlide(); }
    if (e.key === 'f' || e.key === 'F') enterFullscreen();
  });

  /* ── Init ── */
  window.addEventListener('load', function() {
    applyThemeAccent();
    buildDots();
    rescaleCanvas();
    var hash = location.hash.match(/#s(\d+)/);
    goToSlide(hash ? parseInt(hash[1]) : 0);
  });
  window.addEventListener('resize', rescaleCanvas);
</script>
