<% locale = (@workspace.language.presence || 'vi').to_sym %>

<p style="margin:0 0 6px;font-size:22px;font-weight:800;color:#0f172a;">
  ✏️ <%= I18n.t("survey_mailer.edit_link.heading", locale: locale) %>
</p>
<p style="margin:0 0 24px;font-size:15px;color:#64748b;">
  <%= I18n.t("survey_mailer.edit_link.intro",
        survey: "<strong style='color:#0f172a;'>#{@survey.title}</strong>",
        locale: locale).html_safe %>
</p>

<!-- Survey info card -->
<table cellpadding="0" cellspacing="0" width="100%"
       style="background:#f8faff;border:1.5px solid #e0e7ff;border-radius:12px;margin-bottom:28px;">
  <tr>
    <td style="padding:20px 24px;">
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td style="font-size:13px;color:#64748b;padding-bottom:10px;width:40%;">
            <%= I18n.t("survey_mailer.edit_link.survey_label", locale: locale) %>
          </td>
          <td style="font-size:13px;font-weight:600;color:#1e293b;padding-bottom:10px;">
            <%= @survey.title %>
          </td>
        </tr>
        <tr>
          <td style="font-size:13px;color:#64748b;">
            <%= I18n.t("survey_mailer.edit_link.email_label", locale: locale) %>
          </td>
          <td style="font-size:13px;font-weight:600;color:#1e293b;">
            <%= @response.respondent_email %>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- CTA button -->
<table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
  <tr>
    <td align="center">
      <a href="<%= @edit_url %>"
         style="display:inline-block;padding:14px 36px;background:linear-gradient(135deg,#6366f1,#a855f7);color:#ffffff;font-size:15px;font-weight:700;text-decoration:none;border-radius:12px;letter-spacing:0.01em;">
        ✏️ <%= I18n.t("survey_mailer.edit_link.cta", locale: locale) %>
      </a>
    </td>
  </tr>
</table>

<p style="font-size:12px;color:#94a3b8;margin:0 0 4px;">
  <%= I18n.t("survey_mailer.edit_link.link_note", locale: locale) %>
</p>
<p style="font-size:11px;color:#cbd5e1;word-break:break-all;margin:0;">
  <%= @edit_url %>
</p>
