<% content_for :title, @summary.title.presence || t("document_summary.no_title") %>

<% if @summary.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url:      ai_status_document_summary_path(@summary, format: :json),
        message:       "AI đang tóm tắt tài liệu...",
        vtask_id:      "doc-#{@summary.id}",
        vtask_icon:    "📄",
        vtask_label:   "Tóm tắt tài liệu",
        vtask_title:   @summary.title.presence || @summary.source_filename.presence || "Tài liệu",
        vtask_redirect: document_summary_path(@summary) %>
<% end %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate">
      <%= @summary.title.presence || @summary.source_filename.presence || "Tài liệu không có tiêu đề" %>
    </h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "pdf" => "📕 PDF", "audio" => "🎧 Audio", "text" => "📝 Văn bản" }[@summary.source_type] || "Tài liệu" %></span>
      <span>· <%= @summary.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <%= link_to ai_tutor_page_path(context_type: "document_summary", context_id: @summary.id),
      class: "flex items-center gap-1.5 px-3 py-2 bg-violet-600 hover:bg-violet-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    <%= t("document_summary.ask_ai_btn") %>
  <% end %>
</div>

<% if @summary.pending? %>
  <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
    <div class="flex items-center justify-center mb-4">
      <div class="w-12 h-12 border-4 border-indigo-500 border-t-transparent rounded-full animate-spin"></div>
    </div>
    <h3 class="text-[15px] font-bold text-slate-700 mb-1">AI đang đọc và tóm tắt...</h3>
    <p class="text-[13px] text-slate-400">Đừng tắt trang này.</p>
    <meta http-equiv="refresh" content="4">
  </div>
<% elsif @summary.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">⚠️</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2"><%= t("document_summary.failed_title") %></h3>
    <p class="text-[13px] text-red-600 mb-4"><%= t("document_summary.failed_desc") %></p>
    <%= link_to t("document_summary.failed_retry"), new_document_summary_path, class: "px-5 py-2.5 bg-red-600 text-white text-[13px] font-bold rounded-xl" %>
  </div>
<% else %>
  <!-- ── Shortcut actions ──────────────────────────────────────────────── -->
  <% doc_title = @summary.title.presence || @summary.source_filename.presence || t("document_summary.no_title") %>
  <% doc_text  = @summary.source_text.presence || @summary.summary.to_s %>
  <div class="bg-white border border-slate-200 rounded-2xl shadow-sm p-4 mb-5">
    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-3"><%= t("document_summary.next_action_label") %></div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2">

      <!-- AI Tutor -->
      <%= link_to ai_tutor_page_path(context_type: "document_summary", context_id: @summary.id),
          class: "group flex flex-col items-center gap-2 bg-slate-50 hover:bg-[#1e3a5f] border border-slate-200 hover:border-[#1e3a5f] rounded-xl px-3 py-4 text-center transition-all" do %>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background:#ede9fe">
          <%= render "admin/shared/ai_bot_icon" %>
        </div>
        <div>
          <div class="text-[12px] font-bold text-slate-800 group-hover:text-white">AI Tutor</div>
          <div class="text-[10px] text-slate-400 group-hover:text-slate-300 mt-0.5"><%= t("document_summary.action_ai_tutor_sub") %></div>
        </div>
      <% end %>

      <!-- Flashcard -->
      <%= link_to new_flashcard_deck_path(title: doc_title, source_text: doc_text.truncate(8000)),
          class: "group flex flex-col items-center gap-2 bg-slate-50 hover:bg-[#1e3a5f] border border-slate-200 hover:border-[#1e3a5f] rounded-xl px-3 py-4 text-center transition-all" do %>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl" style="background:#e0e7ff">🃏</div>
        <div>
          <div class="text-[12px] font-bold text-slate-800 group-hover:text-white"><%= t("document_summary.action_flashcard") %></div>
          <div class="text-[10px] text-slate-400 group-hover:text-slate-300 mt-0.5"><%= t("document_summary.action_flashcard_sub") %></div>
        </div>
      <% end %>

      <!-- Quiz -->
      <%= link_to new_quiz_set_path(title: doc_title, source_text: doc_text.truncate(12000)),
          class: "group flex flex-col items-center gap-2 bg-slate-50 hover:bg-[#1e3a5f] border border-slate-200 hover:border-[#1e3a5f] rounded-xl px-3 py-4 text-center transition-all" do %>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl" style="background:#fef9c3">📝</div>
        <div>
          <div class="text-[12px] font-bold text-slate-800 group-hover:text-white"><%= t("document_summary.action_quiz") %></div>
          <div class="text-[10px] text-slate-400 group-hover:text-slate-300 mt-0.5"><%= t("document_summary.action_quiz_sub") %></div>
        </div>
      <% end %>

      <!-- Slide AI -->
      <%
        slide_prompt = "Tạo bộ slide thuyết trình từ tài liệu \"#{doc_title}\".\n\nNội dung tóm tắt:\n#{@summary.summary.to_s.truncate(1500)}"
        slide_subject = @summary.respond_to?(:subject) ? @summary.subject.to_s : ""
      %>
      <%= link_to new_content_outline_path(suggested_prompt: slide_prompt, title: doc_title, subject: slide_subject),
          class: "group flex flex-col items-center gap-2 bg-slate-50 hover:bg-[#1e3a5f] border border-slate-200 hover:border-[#1e3a5f] rounded-xl px-3 py-4 text-center transition-all" do %>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl" style="background:#e0f2fe">🖥️</div>
        <div>
          <div class="text-[12px] font-bold text-slate-800 group-hover:text-white"><%= t("document_summary.action_slide") %></div>
          <div class="text-[10px] text-slate-400 group-hover:text-slate-300 mt-0.5"><%= t("document_summary.action_slide_sub") %></div>
        </div>
      <% end %>

      <!-- TTS -->
      <%= link_to tts_path(text: doc_text.truncate(4500)),
          class: "group flex flex-col items-center gap-2 bg-slate-50 hover:bg-[#1e3a5f] border border-slate-200 hover:border-[#1e3a5f] rounded-xl px-3 py-4 text-center transition-all" do %>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl" style="background:#d1fae5">🎙️</div>
        <div>
          <div class="text-[12px] font-bold text-slate-800 group-hover:text-white"><%= t("document_summary.action_tts") %></div>
          <div class="text-[10px] text-slate-400 group-hover:text-slate-300 mt-0.5">Text-to-speech</div>
        </div>
      <% end %>

    </div>
  </div>

  <div class="space-y-4">
    <!-- Source content -->
    <% type_label = { "pdf"=>"PDF","docx"=>"Word","doc"=>"Word","txt"=>"Text","csv"=>"CSV","xlsx"=>"Excel","xls"=>"Excel","pptx"=>"PowerPoint","image"=>"Ảnh","text"=>"Văn bản nhập" }[@summary.source_type] || @summary.source_type %>
    <div class="bg-slate-50 border border-slate-200 rounded-2xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-[11px] font-bold text-slate-500 uppercase tracking-widest"><%= t("document_summary.source_label", type: type_label) %></span>
      </div>
      <% if @summary.source_file.attached? %>
        <div class="flex items-center gap-3">
          <div class="w-9 h-9 bg-white border border-slate-200 rounded-lg flex items-center justify-center text-[18px] shrink-0">
            <%= { "pdf"=>"📕","docx"=>"📘","doc"=>"📘","txt"=>"📄","csv"=>"📊","xlsx"=>"📊","xls"=>"📊","pptx"=>"📑","image"=>"🖼️" }[@summary.source_type] || "📎" %>
          </div>
          <div class="min-w-0">
            <div class="text-[13px] font-semibold text-slate-800 truncate"><%= @summary.source_filename %></div>
            <div class="text-[11px] text-slate-400"><%= number_to_human_size(@summary.source_file.blob.byte_size) %></div>
          </div>
          <%= link_to rails_blob_path(@summary.source_file, disposition: "attachment"),
              class: "ml-auto shrink-0 px-3 py-1.5 text-[12px] font-semibold text-indigo-600 hover:text-indigo-800 bg-white border border-indigo-200 hover:border-indigo-400 rounded-lg transition-colors",
              target: "_blank" do %>
            ↓ <%= t("document_summary.btn_download") %>
          <% end %>
        </div>
      <% elsif @summary.source_text.present? %>
        <div id="src-text-wrap" class="relative">
          <div id="src-text-inner" class="text-[13px] text-slate-600 leading-relaxed whitespace-pre-wrap line-clamp-4 overflow-hidden" style="max-height:5.5rem"><%= @summary.source_text %></div>
          <% if @summary.source_text.length > 300 %>
            <button onclick="document.getElementById('src-text-inner').style.maxHeight='none';document.getElementById('src-text-inner').classList.remove('line-clamp-4');this.style.display='none'"
                    class="mt-1 text-[12px] text-indigo-500 hover:text-indigo-700 font-semibold bg-transparent border-0 cursor-pointer px-0">
              Xem thêm ↓
            </button>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Summary -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
      <div class="flex items-center gap-2 mb-3">
        <div class="w-6 h-6 bg-indigo-100 rounded-lg flex items-center justify-center text-[12px]">📌</div>
        <h3 class="text-[13px] font-bold text-slate-700"><%= t("document_summary.summary_label") %></h3>
      </div>
      <p class="text-[14px] text-slate-800 leading-relaxed"><%= @summary.summary %></p>
    </div>

    <!-- Key points -->
    <% if @summary.key_points.present? %>
      <% points = JSON.parse(@summary.key_points) rescue [] %>
      <% if points.any? %>
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-6 h-6 bg-emerald-100 rounded-lg flex items-center justify-center text-[12px]">🔑</div>
            <h3 class="text-[13px] font-bold text-slate-700"><%= t("document_summary.key_points_label", count: points.size) %></h3>
          </div>
          <ul class="space-y-2.5">
            <% points.each_with_index do |pt, i| %>
              <li class="flex items-start gap-3">
                <span class="w-5 h-5 bg-indigo-100 text-indigo-600 text-[10px] font-bold rounded-full flex items-center justify-center shrink-0 mt-0.5"><%= i+1 %></span>
                <span class="text-[13px] text-slate-700 leading-relaxed"><%= pt %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
