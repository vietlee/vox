<% content_for :title, @summary.title.presence || "Tài liệu" %>
<div class="p-6 max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%= link_to "← Danh sách", document_summaries_path, class: "text-[13px] text-slate-500 hover:text-slate-700" %>
      <h1 class="text-[20px] font-extrabold text-slate-900 mt-1"><%= @summary.title.presence || "Tài liệu không có tên" %></h1>
      <div class="text-[12px] text-slate-500 mt-0.5"><%= @summary.source_type&.upcase %> · <%= @summary.created_at.strftime("%d/%m/%Y %H:%M") %></div>
    </div>
    <%= link_to ai_tutor_page_path(context_type: "document_summary", context_id: @summary.id), class: "px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-[13px] font-bold rounded-lg" do %>
      🤖 Hỏi AI về tài liệu này
    <% end %>
  </div>

  <% if @summary.pending? %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-center">
      <div class="text-3xl mb-2">⏳</div>
      <p class="text-[14px] text-amber-800 font-semibold">AI đang xử lý tài liệu...</p>
      <meta http-equiv="refresh" content="3">
    </div>
  <% elsif @summary.failed? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 text-center">
      <p class="text-red-700 text-[14px] font-semibold">Không thể xử lý tài liệu này. Vui lòng thử lại.</p>
    </div>
  <% else %>
    <div class="grid gap-4">
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
        <h3 class="text-[13px] font-bold text-slate-700 mb-3">📌 Tóm tắt</h3>
        <p class="text-[14px] text-slate-800 leading-relaxed"><%= @summary.summary %></p>
      </div>
      <% if @summary.key_points.present? %>
        <% points = JSON.parse(@summary.key_points) rescue [] %>
        <% if points.any? %>
          <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
            <h3 class="text-[13px] font-bold text-slate-700 mb-3">🔑 Điểm chính</h3>
            <ul class="space-y-2">
              <% points.each do |pt| %>
                <li class="flex items-start gap-2 text-[13px] text-slate-700">
                  <span class="text-indigo-500 mt-0.5 shrink-0">▸</span>
                  <%= pt %>
                </li>
              <% end %>
            </ul>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
