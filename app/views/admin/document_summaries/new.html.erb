<% content_for :title, t("document_summary.new_title") %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">📄 <%= t("document_summary.new_title") %></h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <div id="ds-error" class="hidden mb-4 bg-red-50 border border-red-200 text-red-700 text-[13px] rounded-xl px-4 py-3"></div>

  <div class="space-y-4">
    <div>
      <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Tiêu đề (tuỳ chọn)</label>
      <input type="text" id="ds-title" name="title" placeholder="Tên tài liệu..."
             class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none">
    </div>

    <div>
      <label class="block text-[12px] font-bold text-slate-700 mb-2 uppercase tracking-wide">Loại tài liệu</label>
      <div class="flex gap-2 mb-3">
        <button type="button" id="tab-file" onclick="switchTab('file')"
                class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12px] font-bold border-2 border-indigo-500 bg-indigo-50 text-indigo-700 cursor-pointer transition-colors">
          📁 Upload file
        </button>
        <button type="button" id="tab-text" onclick="switchTab('text')"
                class="flex items-center gap-1.5 px-4 py-2 rounded-xl text-[12px] font-bold border-2 border-slate-200 text-slate-600 cursor-pointer hover:border-slate-300 transition-colors">
          📝 Văn bản
        </button>
      </div>

      <div id="panel-text" class="hidden">
        <div id="ds-quill-wrap" style="border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#fff;">
          <div id="ds-quill-editor" style="min-height:200px;font-size:14px;"></div>
        </div>
      </div>

      <div id="panel-file">
        <label id="file-drop-zone"
               class="flex flex-col items-center justify-center border-2 border-dashed border-slate-300 rounded-xl p-8 cursor-pointer hover:border-indigo-400 hover:bg-indigo-50 transition-colors">
          <div class="w-12 h-12 bg-slate-100 rounded-xl flex items-center justify-center mb-3 text-2xl">📁</div>
          <div class="text-[13px] font-semibold text-slate-700">Chọn hoặc kéo file vào đây</div>
          <div class="flex flex-wrap justify-center gap-1 mt-2">
            <% [["PDF","#ef4444"],["Word","#2563eb"],["Excel","#16a34a"],["PPT","#ea580c"],["Ảnh","#1e3a5f"],["TXT","#64748b"]].each do |label, color| %>
              <span style="background:<%= color %>15;color:<%= color %>;border:1px solid <%= color %>30;"
                    class="text-[10px] font-bold px-2 py-0.5 rounded-full"><%= label %></span>
            <% end %>
          </div>
          <input type="file" id="ds-file" class="hidden"
                 accept=".txt,.csv,.pdf,.doc,.docx,.xlsx,.xls,.pptx,.png,.jpg,.jpeg,.webp,.gif,.bmp"
                 onchange="onFileSelected(this)">
        </label>
        <div id="file-name" class="hidden mt-2 flex items-center gap-2 px-3 py-2 bg-slate-50 rounded-xl border border-slate-200 text-[13px] text-slate-700">
          <svg class="w-4 h-4 text-slate-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <span id="file-name-text"></span>
        </div>
      </div>
    </div>

    <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 flex items-center gap-2 text-[13px] text-amber-700">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      Sử dụng <strong class="mx-1">2 AI Credits</strong> để tóm tắt tài liệu
    </div>

    <div class="flex gap-2 pt-1">
      <button type="button" id="ds-submit-btn" onclick="runDsSummarize()"
              class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors border-0">
        ✨ Tóm tắt ngay
      </button>
      <%= link_to "Hủy", document_summaries_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
    </div>
  </div>
</div>

<!-- Loading overlay -->
<div id="ds-overlay"
     style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center;
            background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center;
              box-shadow:0 20px 60px rgba(0,0,0,0.22); max-width:320px; width:90%; position:relative;">
    <button id="ds-minimize-btn" onclick="dsMinimize()" title="Thu nhỏ — tiếp tục làm việc khác"
            style="position:absolute;top:12px;right:12px;display:flex;align-items:center;gap:5px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:5px 11px;font-size:11px;font-weight:700;cursor:pointer;color:#1e3a5f;"
            onmouseenter="this.style.background='#e8f0f8';this.style.borderColor='#b3cbe3'" onmouseleave="this.style.background='#fff';this.style.borderColor='#e2e8f0'">
      <svg width="12" height="3" viewBox="0 0 12 3" fill="none"><rect y="0.5" width="12" height="2" rx="1" fill="#1e3a5f"/></svg>
      Thu nhỏ
    </button>
    <div id="ds-ring-container"></div>
    <p style="font-size:11px; color:#94A3B8; margin:12px 0 0;">Nhấn <strong style="color:#1e3a5f">Thu nhỏ</strong> để tiếp tục làm việc.</p>
  </div>
</div>

<style>
@keyframes vox-pulse {
  0%,100% { transform:scale(1); opacity:1; }
  50%      { transform:scale(0.88); opacity:0.75; }
}
#ds-quill-wrap .ql-toolbar {
  border: none;
  border-bottom: 1px solid #e2e8f0;
  background: #f8fafc;
  padding: 6px 10px;
}
#ds-quill-wrap .ql-container {
  border: none;
  font-size: 14px;
  font-family: inherit;
}
#ds-quill-wrap .ql-editor { min-height: 200px; }
#ds-quill-wrap .ql-editor.ql-blank::before { color: #94a3b8; font-style: normal; }
</style>

<script>
var DS_PHASES = ["Đang đọc tài liệu...", "Đang phân tích nội dung...", "Đang trích xuất ý chính...", "Đang tổng hợp kết quả..."];
var _dsRingCtrl = null;
var _dsActiveTab = 'file';
var _dsQuill = null;

(function initDsQuill() {
  function tryInit() {
    if (typeof Quill === 'undefined') { setTimeout(tryInit, 80); return; }
    _dsQuill = new Quill('#ds-quill-editor', {
      theme: 'snow',
      placeholder: 'Dán nội dung văn bản vào đây (tối đa ~15.000 ký tự)...',
      modules: { toolbar: [['bold','italic','underline'],[{list:'ordered'},{list:'bullet'}],['clean']] }
    });
  }
  tryInit();
})();

function makeDsProgressRing() {
  var phases = DS_PHASES;
  var totalPhases = phases.length;
  var phase = 0, pct = 0, timer = null;
  document.getElementById('ds-ring-container').innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
      '<span id="ds-ring-pct" style="font-size:13px;font-weight:800;color:#1e3a5f;letter-spacing:-0.3px;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#d9e5f1" stroke-width="6"/>',
          '<circle id="ds-ring-arc" cx="44" cy="44" r="38" stroke="#1e3a5f" stroke-width="6" stroke-linecap="round" stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
          '<img src="/icon-mark.svg" width="40" height="40" alt="VOX" style="display:block;">',
        '</div>',
      '</div>',
      '<p id="ds-ring-phase" style="font-size:12px;font-weight:600;color:#1e3a5f;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');

  var ring  = document.getElementById('ds-ring-arc');
  var pctEl = document.getElementById('ds-ring-pct');
  var phEl  = document.getElementById('ds-ring-phase');
  var milestones = phases.map(function(_, i) { return Math.round(((i + 1) / totalPhases) * 85); });

  function setProgress(p) {
    ring.style.strokeDashoffset = 238.8 * (1 - p / 100);
    pctEl.textContent = Math.round(p) + '%';
  }

  timer = setInterval(function() {
    var target = milestones[phase] || 85;
    pct = Math.min(pct + 1, target);
    setProgress(pct);
    if (pct >= (milestones[phase] || 85) && phase < totalPhases - 1) {
      phase++;
      phEl.textContent = phases[phase];
    }
    if (pct >= 85 && phase >= totalPhases - 1) {
      clearInterval(timer);
      timer = setInterval(function() {
        if (pct >= 98) { clearInterval(timer); return; }
        pct = Math.min(pct + 0.4, 98);
        setProgress(pct);
      }, 3000);
    }
  }, 300);

  return { finish: function() { clearInterval(timer); ring.style.strokeDashoffset = '0'; pctEl.textContent = '100%'; } };
}

async function runDsSummarize() {
  var formData = new FormData();
  formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);
  formData.append('title', document.getElementById('ds-title').value.trim());
  formData.append('source_type', _dsActiveTab === 'file' ? 'pdf' : 'text');

  if (_dsActiveTab === 'file') {
    var file = document.getElementById('ds-file').files[0];
    if (!file) { showDsError('Vui lòng chọn file.'); return; }
    formData.append('source_file', file);
  } else {
    var text = (_dsQuill ? _dsQuill.getText().trim() : '');
    if (!text) { showDsError('Vui lòng nhập nội dung văn bản.'); return; }
    formData.append('source_text', text);
  }

  document.getElementById('ds-submit-btn').disabled = true;
  document.getElementById('ds-error').classList.add('hidden');
  document.getElementById('ds-overlay').style.display = 'flex';
  _dsRingCtrl = makeDsProgressRing();

  try {
    var res = await fetch('<%= document_summaries_path %>', {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    });
    var data = await res.json();
    if (data.error) {
      document.getElementById('ds-overlay').style.display = 'none';
      document.getElementById('ds-submit-btn').disabled = false;
      if (handleAiError(data, res)) return;
      showDsError(data.error);
      return;
    }
    if (data.pending) {
      window._dsPollUrl = data.poll_url;
      window._dsShowUrl = data.show_url;
      pollDsStatus(data.poll_url, data.show_url);
    } else if (data.redirect) {
      if (_dsRingCtrl) _dsRingCtrl.finish();
      window.location.href = data.redirect;
    }
  } catch(e) {
    document.getElementById('ds-overlay').style.display = 'none';
    document.getElementById('ds-submit-btn').disabled = false;
    showDsError('Có lỗi mạng. Vui lòng thử lại.');
  }
}

function dsMinimize() {
  var overlay = document.getElementById('ds-overlay');
  if (overlay) overlay.style.display = 'none';
  if (window.VoxTaskManager && window._dsPollUrl) {
    VoxTaskManager.add({
      id:          'doc-summary-new',
      icon:        '📄',
      label:       'Tóm tắt tài liệu',
      title:       document.getElementById('ds-title').value.trim() || 'Tài liệu',
      poll_url:    window._dsPollUrl,
      redirect_url: window._dsShowUrl || ''
    });
  }
}

async function pollDsStatus(pollUrl, showUrl) {
  var overlay = document.getElementById('ds-overlay');
  if (overlay && overlay.style.display === 'none') return; // minimized — VoxTaskManager takes over
  try {
    var res = await fetch(pollUrl, { headers: { 'Accept': 'application/json' } });
    var data = await res.json();
    if (data.pending) {
      setTimeout(function() { pollDsStatus(pollUrl, showUrl); }, 3000);
    } else if (data.success) {
      if (_dsRingCtrl) _dsRingCtrl.finish();
      window.location.href = data.redirect || showUrl;
    } else {
      document.getElementById('ds-overlay').style.display = 'none';
      document.getElementById('ds-submit-btn').disabled = false;
      if (handleAiError(data, res)) return;
      showDsError(data.error || 'AI gặp lỗi. Vui lòng thử lại.');
    }
  } catch(e) {
    setTimeout(function() { pollDsStatus(pollUrl, showUrl); }, 3000);
  }
}

function showDsError(msg) {
  var el = document.getElementById('ds-error');
  el.textContent = msg;
  el.classList.remove('hidden');
}

function switchTab(type) {
  _dsActiveTab = type;
  var tabs   = { text: document.getElementById('tab-text'), file: document.getElementById('tab-file') };
  var panels = { text: document.getElementById('panel-text'), file: document.getElementById('panel-file') };
  Object.keys(tabs).forEach(function(k) {
    var active = k === type;
    tabs[k].classList.toggle('border-indigo-500', active);
    tabs[k].classList.toggle('bg-indigo-50', active);
    tabs[k].classList.toggle('text-indigo-700', active);
    tabs[k].classList.toggle('border-slate-200', !active);
    tabs[k].classList.toggle('text-slate-600', !active);
    panels[k].classList.toggle('hidden', k !== type);
  });
}

function onFileSelected(input) {
  var file = input.files[0];
  if (!file) return;
  var name = file.name;
  var ext  = name.split('.').pop().toLowerCase();
  var icons = { pdf:'📄', doc:'📝', docx:'📝', xlsx:'📊', xls:'📊', pptx:'📑', txt:'📃', csv:'📃',
                png:'🖼️', jpg:'🖼️', jpeg:'🖼️', gif:'🖼️', webp:'🖼️', bmp:'🖼️' };
  var icon = icons[ext] || '📁';
  document.getElementById('file-name').classList.remove('hidden');
  document.getElementById('file-name-text').textContent = icon + ' ' + name;
}

document.addEventListener('turbo:before-cache', function() {
  document.getElementById('ds-overlay').style.display = 'none';
  document.getElementById('ds-submit-btn').disabled = false;
});
</script>
