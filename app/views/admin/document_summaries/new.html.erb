<% content_for :title, "Tóm tắt tài liệu mới" %>
<div class="p-6 max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Danh sách", document_summaries_path, class: "text-[13px] text-slate-500 hover:text-slate-700" %>
    <h1 class="text-[20px] font-extrabold text-slate-900 mt-2">📄 Tóm tắt tài liệu bằng AI</h1>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
    <%= form_with url: document_summaries_path, method: :post, multipart: true do %>
      <div class="space-y-5">
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Tiêu đề (tuỳ chọn)</label>
          <input type="text" name="title" placeholder="Tên tài liệu..." class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none">
        </div>

        <!-- Source type tabs -->
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Loại tài liệu</label>
          <div class="flex gap-2 mb-3">
            <button type="button" onclick="showType('text')" class="type-btn active px-4 py-2 rounded-lg text-[12px] font-bold border-2 border-indigo-500 bg-indigo-50 text-indigo-700 cursor-pointer">📝 Văn bản</button>
            <button type="button" onclick="showType('pdf')" class="type-btn px-4 py-2 rounded-lg text-[12px] font-bold border-2 border-slate-200 text-slate-600 cursor-pointer hover:border-slate-300">📕 PDF</button>
          </div>

          <div id="type-text">
            <textarea name="source_text" placeholder="Dán nội dung văn bản vào đây (tối đa ~15.000 ký tự)..." rows="8" class="w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[13px] resize-none focus:border-indigo-500 outline-none"></textarea>
            <input type="hidden" name="source_type" id="source_type_field" value="text">
          </div>
          <div id="type-pdf" class="hidden">
            <label class="flex flex-col items-center justify-center border-2 border-dashed border-slate-300 rounded-xl p-8 cursor-pointer hover:border-indigo-400 hover:bg-indigo-50 transition-colors">
              <div class="text-3xl mb-2">📁</div>
              <div class="text-[13px] font-semibold text-slate-700">Chọn file văn bản</div>
              <div class="text-[11px] text-slate-400 mt-1">TXT, PDF (dạng text)</div>
              <input type="file" name="source_file" class="hidden" accept=".txt,.pdf,.doc,.docx" onchange="document.getElementById('source_type_field').value='pdf'; document.querySelector('.file-name').textContent = this.files[0]?.name || ''">
            </label>
            <div class="file-name text-[12px] text-slate-500 mt-2 text-center"></div>
          </div>
        </div>

        <div class="flex items-center gap-2 text-[12px] text-amber-700 bg-amber-50 px-4 py-2.5 rounded-lg">
          ⚡ Sử dụng <strong>2 AI Credits</strong> để tóm tắt
        </div>
        <button type="submit" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-[14px] font-bold rounded-xl cursor-pointer border-0">
          ✨ Tóm tắt ngay
        </button>
      </div>
    <% end %>
  </div>
</div>
<script>
function showType(type) {
  document.querySelectorAll('.type-btn').forEach(b => { b.classList.remove('border-indigo-500','bg-indigo-50','text-indigo-700'); b.classList.add('border-slate-200','text-slate-600'); });
  event.target.classList.add('border-indigo-500','bg-indigo-50','text-indigo-700');
  document.getElementById('type-text').classList.toggle('hidden', type !== 'text');
  document.getElementById('type-pdf').classList.toggle('hidden', type !== 'pdf');
  document.getElementById('source_type_field').value = type;
}
</script>
