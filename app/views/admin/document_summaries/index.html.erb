<% content_for :title, t("document_summary.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <%= render "admin/shared/back_btn" %>
      <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[28px] bg-slate-100 shrink-0">📄</div>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight"><%= t("document_summary.title") %></h1>
        <p class="text-[13px] font-medium text-slate-600 mt-0.5"><%= t("document_summary.subtitle") %></p>
      </div>
    </div>
    <%= link_to new_document_summary_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-[13px] font-bold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <%= t("document_summary.new") %>
    <% end %>
  </div>
</div>

<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
        <input type="text" placeholder="Tìm kiếm tài liệu..."
          class="w-full pl-8 pr-3 py-1.5 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white"
          oninput="filterRows(this,'ds-row','ds-no-results')">
      </div>
      <span class="text-[11px] text-slate-400 ml-auto"><%= @summaries.size %> tài liệu</span>
    </div>

    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @summaries.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Tên tài liệu</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Loại</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Trạng thái</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Tạo lúc</th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <tr id="ds-no-results" class="hidden">
              <td colspan="5" class="px-4 py-10 text-center text-[13px] text-slate-400">Không tìm thấy kết quả</td>
            </tr>
            <% @summaries.each do |doc| %>
              <% type_icon = {"pdf"=>"📕","audio"=>"🎧","text"=>"📝"}[doc.source_type] || "📄" %>
              <% type_label = {"pdf"=>"PDF / File","audio"=>"Âm thanh","text"=>"Văn bản"}[doc.source_type] || "Tài liệu" %>
              <tr class="ds-row border-b border-slate-200 hover:bg-white/70 transition-colors"
                  data-title="<%= (doc.title.presence || '').downcase %>">
                <td class="px-4 py-3">
                  <%= link_to doc.title.presence || "Không có tiêu đề", document_summary_path(doc),
                      class: "text-[13px] font-semibold text-slate-800 hover:text-indigo-600 transition-colors" %>
                </td>
                <td class="px-4 py-3 text-[12px] text-slate-500"><%= type_icon %> <%= type_label %></td>
                <td class="px-4 py-3">
                  <% if doc.done? %>
                    <span class="text-[11px] font-bold text-emerald-600">Hoàn thành</span>
                  <% elsif doc.pending? %>
                    <span class="text-[11px] font-semibold text-amber-500">Đang xử lý...</span>
                  <% else %>
                    <span class="text-[11px] font-semibold text-red-500">Thất bại</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-[12px] text-slate-400"><%= doc.created_at.strftime("%d/%m %H:%M") %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1 justify-end">
                    <%= link_to document_summary_path(doc),
                        class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-slate-200 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-slate-500 hover:text-white text-[12px] font-semibold rounded-lg transition-colors" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                      Xem
                    <% end %>
                    <button type="button" onclick="confirmDelete('<%= document_summary_path(doc) %>', '<%= j(doc.title.presence || "tài liệu này") %>')"
                            class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-red-100 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-red-400 hover:text-white text-[12px] font-semibold rounded-lg transition-colors cursor-pointer">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      Xóa
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="py-20 text-center">
          <div class="text-5xl mb-4">📄</div>
          <h3 class="text-[15px] font-bold text-slate-700 mb-2"><%= t("document_summary.empty_title") %></h3>
          <p class="text-[13px] text-slate-400 mb-5"><%= t("document_summary.empty_desc") %></p>
          <%= link_to t("document_summary.create_first"), new_document_summary_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div id="ds-delete-modal" style="display:none; position:fixed; inset:0; z-index:60; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.5);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.18); width:100%; max-width:380px; padding:28px 24px;">
    <div style="width:48px; height:48px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg style="width:24px;height:24px;" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 style="font-size:16px; font-weight:800; color:#1E293B; text-align:center; margin:0 0 8px;"><%= t("document_summary.confirm_delete_title") %></h3>
    <p id="ds-delete-desc" style="font-size:13px; color:#64748B; text-align:center; margin:0 0 20px;"></p>
    <div style="display:flex; gap:8px;">
      <button id="ds-delete-btn" onclick="executeDelete()"
              style="flex:1; padding:11px; background:#EF4444; color:#fff; font-weight:700; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Xóa</button>
      <button onclick="document.getElementById('ds-delete-modal').style.display='none'"
              style="flex:1; padding:11px; background:#F1F5F9; color:#475569; font-weight:600; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Hủy</button>
    </div>
  </div>
</div>

<script>
let _dsDeletePath = null;
function confirmDelete(path, title) {
  _dsDeletePath = path;
  document.getElementById('ds-delete-desc').textContent = 'Bạn sắp xóa "' + title + '". Hành động này không thể hoàn tác.';
  document.getElementById('ds-delete-modal').style.display = 'flex';
}
function executeDelete() {
  if (!_dsDeletePath) return;
  const btn = document.getElementById('ds-delete-btn'); btn.disabled = true; btn.textContent = '...';
  const f = document.createElement('form'); f.method = 'POST'; f.action = _dsDeletePath;
  const m = document.createElement('input'); m.type='hidden'; m.name='_method'; m.value='delete';
  const c = document.createElement('input'); c.type='hidden'; c.name='authenticity_token'; c.value=document.querySelector('meta[name="csrf-token"]').content;
  f.appendChild(m); f.appendChild(c); document.body.appendChild(f); f.submit();
}
function filterRows(input, rowClass, noResultId) {
  var q = input.value.toLowerCase();
  var rows = document.querySelectorAll('.' + rowClass);
  var found = 0;
  rows.forEach(function(r) { var show = !q || (r.dataset.title||'').includes(q); r.style.display = show ? '' : 'none'; if(show) found++; });
  document.getElementById(noResultId).classList.toggle('hidden', found > 0 || !q);
}
</script>
