<% content_for :title, t("surveys.share.title") %>
<div class="max-w-[600px]">
  <div class="flex items-center gap-3 mb-5">
    <%= render "admin/shared/back_btn" %>
    <h1 class="text-[19px] font-extrabold text-slate-900">🔗 <%= t("surveys.share.title") %></h1>
  </div>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 space-y-5">

    <% _full_url  = request.base_url + participate_survey_path(@survey.slug) %>
    <% _short_url = short_url_for(_full_url, workspace: current_workspace) rescue _full_url %>
    <div>
      <label class="block text-[12px] font-semibold text-slate-500 mb-1.5"><%= t("surveys.share.link_label") %></label>
      <div class="flex gap-2 mb-2">
        <input id="survey-link" readonly value="<%= _short_url %>"
          class="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-[12px] bg-slate-50 font-mono">
        <button onclick="voxCopy(document.getElementById('survey-link').value, this)" class="vox-copy-btn">
          <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          <span>Sao chép</span>
        </button>
      </div>
      <p class="text-[11px] text-slate-400">Full link: <span class="font-mono"><%= _full_url %></span></p>
    </div>

    <div class="text-center">
      <p class="text-[12px] font-semibold text-slate-500 mb-3"><%= t("surveys.share.qr_code") %></p>
      <% if @survey.qr_code %>
        <div class="inline-block bg-white border border-slate-200 rounded-xl p-4 shadow-sm">
          <img src="<%= qr_image_path(@survey.qr_code.token) %>"
               alt="QR Code"
               class="w-44 h-44 block"
               id="qr-img"
               crossorigin="anonymous">
        </div>
        <p class="text-[11px] text-slate-400 mt-2 mb-3"><%= t("surveys.qr_scans", count: @survey.qr_code.scan_count) %></p>
        <div class="flex justify-center gap-2 flex-wrap">
          <button onclick="copyQrImage(document.getElementById('qr-img'), this)"
            class="vox-copy-btn">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            <span>Copy QR</span>
          </button>
          <button onclick="downloadQrPng()"
            class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 text-slate-700 text-[12px] font-semibold rounded-lg hover:bg-slate-200">
            <%= t("surveys.share.download_png") %>
          </button>
        </div>
      <% else %>
        <div class="w-44 h-44 mx-auto bg-slate-100 rounded-xl flex items-center justify-center text-slate-400 text-[12px]">
          <%= t("surveys.share.no_qr") %>
        </div>
      <% end %>
    </div>

    <div>
      <label class="block text-[12px] font-semibold text-slate-500 mb-1.5"><%= t("surveys.share.embed_code") %></label>
      <textarea readonly rows="3" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[11px] bg-slate-50 font-mono resize-none"><iframe src="<%= request.base_url + participate_survey_path(@survey.slug) %>" width="100%" height="600" frameborder="0"></iframe></textarea>
    </div>

  </div>
</div>

<% if @survey.qr_code %>
<script>
function downloadQrPng() {
  const img = document.getElementById('qr-img');
  const canvas = document.createElement('canvas');
  canvas.width = 512; canvas.height = 512;
  const ctx = canvas.getContext('2d');
  const svgImg = new Image();
  svgImg.onload = function() {
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, 512, 512);
    ctx.drawImage(svgImg, 0, 0, 512, 512);
    const a = document.createElement('a');
    a.download = 'qrcode-<%= @survey.slug %>.png';
    a.href = canvas.toDataURL('image/png');
    a.click();
  };
  svgImg.crossOrigin = 'anonymous';
  svgImg.src = img.src;
}
</script>
<% end %>
