<% content_for :title, t("surveys.new") %>
<div class="max-w-[600px]">
  <div class="flex items-center gap-3 mb-5">
    <%= render "admin/shared/back_btn" %>
    <h1 class="text-[19px] font-extrabold text-slate-900">📋 <%= t("surveys.new") %></h1>
  </div>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with model: @survey, url: surveys_path, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("surveys.form.title_label") %> *</label>
          <%= f.text_field :title, required: true, placeholder: t("surveys.form.title_label"),
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("surveys.form.description_label") %></label>
          <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none resize-none" %>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("surveys.form.identity_mode_label") %></label>
            <%= f.select :identity_mode,
                  Survey.identity_modes.keys.map { |k| [t("surveys.form.identity_modes.#{k}"), k] }, {},
                  class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none",
                  onchange: "onIdentityChange(this.value)" %>
          </div>
        </div>

        <!-- SSO provider picker — shown only when identity_mode = login_required -->
        <div id="sso-providers-wrap" style="display:none;" class="px-4 py-3 rounded-xl border border-indigo-100 bg-indigo-50/60">
          <label class="block text-[11px] font-semibold text-slate-500 mb-2">
            <%= I18n.locale == :vi ? "Cho phép đăng nhập với" : "Allow sign in with" %>
          </label>
          <div class="flex gap-4">
            <% [["google", "🔵 Google"], ["microsoft", "🟦 Microsoft"], ["both", I18n.locale == :vi ? "✅ Cả hai" : "✅ Both"]].each do |val, lbl| %>
              <label class="flex items-center gap-1.5 text-[12px] font-semibold text-slate-600 cursor-pointer">
                <%= f.radio_button :login_providers, val, checked: val == "both", class: "accent-indigo-600" %>
                <%= lbl %>
              </label>
            <% end %>
          </div>
        </div>

        <div class="flex gap-2 pt-4 border-t border-slate-100">
          <%= f.submit t("surveys.form.create_btn"), class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to t("surveys.form.cancel"), surveys_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
function onIdentityChange(val) {
  document.getElementById('sso-providers-wrap').style.display = val === 'login_required' ? '' : 'none';
}
onIdentityChange(document.querySelector('select[name="survey[identity_mode]"]')?.value || 'anonymous');
</script>
