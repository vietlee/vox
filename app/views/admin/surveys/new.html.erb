<% content_for :title, "New Survey" %>
<div class="max-w-[600px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5">📋 New Survey</h1>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with model: @survey, url: surveys_path, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Survey Title *</label>
          <%= f.text_field :title, required: true, placeholder: "e.g., Q1 Employee Satisfaction Survey",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Description</label>
          <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none resize-none" %>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Identity Mode</label>
            <%= f.select :identity_mode, Survey.identity_modes.keys.map { |k| [k.humanize, k] }, {},
              class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
        </div>
        <div class="flex gap-2 pt-4 border-t border-slate-100">
          <%= f.submit "Create & Add Questions →", class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to "Cancel", surveys_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
