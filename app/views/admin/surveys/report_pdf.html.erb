<%
  out       = report.output
  meta      = out["_meta"] || {}
  sentiment = out.dig("key_metrics") || {}
  sections  = out["sections"] || []
  recs      = out["recommendations"] || []
  ai_data   = survey.ai_analysis_results.where(result_type: "executive_summary").order(created_at: :desc).first&.output || {}
  themes    = ai_data["top_themes"] || ai_data["themes"] || []

  # Sentiment data
  pos_pct = (ai_data.dig("sentiment","positive") || sentiment["sentiment_positive"] || "0%").to_s.gsub('%','').to_f
  neg_pct = (ai_data.dig("sentiment","negative") || sentiment["sentiment_negative"] || "0%").to_s.gsub('%','').to_f
  neu_pct = [100 - pos_pct - neg_pct, 0].max.round(1)

  # SVG pie helper (simple donut)
  def donut_arc(cx, cy, r, start_deg, end_deg, color)
    start_rad = (start_deg - 90) * Math::PI / 180
    end_rad   = (end_deg - 90)   * Math::PI / 180
    x1 = (cx + r * Math.cos(start_rad)).round(2)
    y1 = (cy + r * Math.sin(start_rad)).round(2)
    x2 = (cx + r * Math.cos(end_rad)).round(2)
    y2 = (cy + r * Math.sin(end_rad)).round(2)
    large = (end_deg - start_deg) > 180 ? 1 : 0
    "<path d='M#{cx},#{cy} L#{x1},#{y1} A#{r},#{r} 0 #{large},1 #{x2},#{y2} Z' fill='#{color}'/>"
  end
%>

<!-- ── Cover page ─────────────────────────────────────────────────── -->
<div class="cover">
  <div class="cover-accent"></div>
  <div class="cover h1" style="font-size:28px;font-weight:900;color:#1e1b4b;line-height:1.25;margin-bottom:12px;">
    <%= out["title"] || survey.title %>
  </div>
  <% if out["subtitle"].present? %>
    <div class="subtitle"><%= out["subtitle"] %></div>
  <% end %>
  <div class="meta-row">
    <div class="meta-item">
      <strong><%= report.response_count || survey.responses.completed.count %></strong>
      <%= t("surveys.results.total_responses") %>
    </div>
    <div class="meta-item">
      <strong><%= report.created_at.strftime("%d/%m/%Y") %></strong>
      <%= t("surveys.results.report_date", default: "Ngày tạo báo cáo") %>
    </div>
    <div class="meta-item">
      <strong><%= (meta["language"] || "vi") == "vi" ? "Tiếng Việt" : "English" %></strong>
      <%= t("surveys.results.report_language", default: "Ngôn ngữ") %>
    </div>
    <div class="meta-item">
      <strong><%= survey.workspace.name %></strong>
      <%= t("surveys.results.organization", default: "Tổ chức") %>
    </div>
  </div>
</div>

<!-- ── Content pages ────────────────────────────────────────────── -->
<div class="content page-break">

  <!-- Key metrics row -->
  <% if sentiment.any? %>
    <div class="metrics-row">
      <% if sentiment["sentiment_positive"].present? %>
        <div class="metric-card" style="border-top:3px solid #10b981;">
          <div class="metric-val" style="color:#065f46;"><%= sentiment["sentiment_positive"] %></div>
          <div class="metric-label">Tích cực</div>
        </div>
      <% end %>
      <% if sentiment["sentiment_negative"].present? %>
        <div class="metric-card" style="border-top:3px solid #ef4444;">
          <div class="metric-val" style="color:#991b1b;"><%= sentiment["sentiment_negative"] %></div>
          <div class="metric-label">Tiêu cực</div>
        </div>
      <% end %>
      <div class="metric-card" style="border-top:3px solid #6366f1;">
        <div class="metric-val"><%= report.response_count || survey.responses.completed.count %></div>
        <div class="metric-label"><%= t("surveys.results.total_responses") %></div>
      </div>
      <% if sentiment["top_concern"].present? %>
        <div class="metric-card" style="flex:2; border-top:3px solid #f59e0b;">
          <div class="metric-val" style="font-size:12px;color:#92400e;"><%= sentiment["top_concern"] %></div>
          <div class="metric-label">Vấn đề ưu tiên</div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Charts row: sentiment pie + themes bar -->
  <% if pos_pct + neg_pct > 0 || themes.any? %>
    <div class="charts-row">
      <!-- Sentiment donut chart -->
      <% if pos_pct + neg_pct > 0 %>
        <div class="chart-box" style="max-width:200px;">
          <div class="chart-title">Cảm xúc tổng thể</div>
          <%
            segments = [
              [pos_pct, "#10b981", "Tích cực"],
              [neu_pct, "#94a3b8", "Trung lập"],
              [neg_pct, "#ef4444", "Tiêu cực"]
            ].select { |pct,_,_| pct > 0 }
            angle = 0
            cx, cy, r = 70, 70, 55
            inner_r = 30
          %>
          <svg width="140" height="140" viewBox="0 0 140 140">
            <% segments.each do |pct, color, label| %>
              <% sweep = pct * 3.6 %>
              <% start_rad = (angle - 90) * Math::PI / 180 %>
              <% end_rad   = (angle + sweep - 90) * Math::PI / 180 %>
              <% x1 = (cx + r * Math.cos(start_rad)).round(2) %>
              <% y1 = (cy + r * Math.sin(start_rad)).round(2) %>
              <% x2 = (cx + r * Math.cos(end_rad)).round(2) %>
              <% y2 = (cy + r * Math.sin(end_rad)).round(2) %>
              <% large = sweep > 180 ? 1 : 0 %>
              <path d="M<%= cx %>,<%= cy %> L<%= x1 %>,<%= y1 %> A<%= r %>,<%= r %> 0 <%= large %>,1 <%= x2 %>,<%= y2 %> Z" fill="<%= color %>"/>
              <% angle += sweep %>
            <% end %>
            <circle cx="<%= cx %>" cy="<%= cy %>" r="<%= inner_r %>" fill="white"/>
            <text x="<%= cx %>" y="<%= cy - 4 %>" text-anchor="middle" font-size="14" font-weight="800" fill="#1e1b4b"><%= pos_pct.round %>%</text>
            <text x="<%= cx %>" y="<%= cy + 12 %>" text-anchor="middle" font-size="8" fill="#64748b">tích cực</text>
          </svg>
          <!-- Legend -->
          <% segments.each do |pct, color, label| %>
            <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:#374151;margin-top:3px;">
              <span style="width:8px;height:8px;border-radius:2px;background:<%= color %>;flex-shrink:0;"></span>
              <%= label %>: <%= pct.round(1) %>%
            </div>
          <% end %>
        </div>
      <% end %>

      <!-- Themes bar chart -->
      <% if themes.any? %>
        <div class="chart-box" style="flex:2;">
          <div class="chart-title">Chủ đề nổi bật</div>
          <% themes.first(6).each do |t| %>
            <% theme_name = t["theme"] || t["name"] || "" %>
            <% pct = (t["percentage"] || 0).to_f %>
            <% bar_color = t["sentiment"] == "positive" ? "#10b981" : t["sentiment"] == "negative" ? "#ef4444" : "#6366f1" %>
            <div style="margin-bottom:8px;">
              <div style="display:flex;justify-content:space-between;font-size:10px;color:#374151;margin-bottom:3px;">
                <span><%= theme_name.truncate(45) %></span>
                <span style="font-weight:700;color:<%= bar_color %>;"><%= pct.round(1) %>%</span>
              </div>
              <div style="height:6px;background:#e2e8f0;border-radius:3px;overflow:hidden;">
                <div style="height:100%;width:<%= [pct,100].min %>%;background:<%= bar_color %>;border-radius:3px;"></div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Executive Summary -->
  <div class="section-label"><%= t("surveys.results.ai_executive_summary") %></div>
  <div class="exec-summary">
    <% (out["executive_summary"] || "").split("\\n\\n").each do |para| %>
      <p><%= para.gsub("\\n", " ") %></p>
    <% end %>
  </div>

  <!-- Sections -->
  <% sections.each_with_index do |s, i| %>
    <h2><%= s["heading"] %></h2>
    <% (s["content"] || "").split("\\n\\n").each do |para| %>
      <p><%= para.gsub("\\n", " ") %></p>
    <% end %>
    <% if s["key_finding"].present? %>
      <div class="key-finding"><%= s["key_finding"] %></div>
    <% end %>
  <% end %>

  <!-- Recommendations -->
  <% if recs.any? %>
    <div class="page-break" style="page-break-before:auto;">
      <h2><%= t("surveys.results.ai_recommendations") %></h2>
      <% recs.each_with_index do |rec, i| %>
        <% text     = rec.is_a?(Hash) ? rec["action"] : rec.to_s %>
        <% rationale= rec.is_a?(Hash) ? rec["rationale"] : nil %>
        <% impact   = rec.is_a?(Hash) ? rec["expected_impact"] : nil %>
        <% pri      = rec.is_a?(Hash) ? rec["priority"].to_s : "" %>
        <% badge_label = pri == "high" ? "CAO" : pri == "medium" ? "TB" : pri == "low" ? "THẤP" : "" %>
        <div class="rec">
          <% if badge_label.present? %>
            <span class="rec-badge <%= pri %>"><%= badge_label %></span>
          <% end %>
          <div class="rec-body">
            <div class="rec-action"><%= i + 1 %>. <%= text %></div>
            <% if rationale.present? %>
              <div class="rec-rationale"><%= rationale %></div>
            <% end %>
            <% if impact.present? %>
              <div class="rec-impact">→ <%= impact %></div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Conclusion -->
  <% if out["conclusion"].present? %>
    <h2><%= t("surveys.results.ai_conclusion") %></h2>
    <div class="conclusion">
      <% out["conclusion"].split("\\n\\n").each do |para| %>
        <p><%= para.gsub("\\n", " ") %></p>
      <% end %>
    </div>
  <% end %>

  <div class="footer">
    <span><%= survey.workspace.name %> · <%= t("surveys.results.report_generated", time: report.created_at.strftime("%d/%m/%Y %H:%M")) %></span>
    <span><%= t("surveys.results.powered_by", default: "Powered by VOX AI") %></span>
  </div>
</div>
