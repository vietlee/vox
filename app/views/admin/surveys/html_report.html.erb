            <div class="bar-track"><div class="bar-fill" style="width:<%= o[:pct].clamp(0,100) %>%;background:<%= palette[oi % palette.size] %>"><%= o[:pct] > 10 ? "#{o[:pct]}%" : '' %></div></div>
            <span class="bar-count"><%= o[:count] %></span>
          </div>
