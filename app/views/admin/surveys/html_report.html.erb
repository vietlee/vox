            Trung bình: <strong style="color:#4361ee;font-size:15px"><%= stats[:avg] %>%</strong>
            <% if stats[:min] && stats[:max] %>
              &nbsp;·&nbsp; Min: <strong><%= stats[:min] %>%</strong> / Max: <strong><%= stats[:max] %>%</strong>
            <% end %>
          </div>
          <% end %>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
        <% end %>

      <%# ═══ NPS BAR (0-10 distribution with red/cyan/green colors) ═══ %>
      <% elsif chart_type == "nps_bar" %>
        <% dist = stats[:distribution] || [] %>
        <% if dist.any? %>
          <canvas id="ch_<%= cid %>"></canvas>
          <script>
          (function(){
            var labels = <%= raw dist.map{|d| d[:label]}.to_json %>;
            var counts = <%= raw dist.map{|d| d[:count]}.to_json %>;
            var npsColors = labels.map(function(v){
              var n = parseInt(v);
              return n >= 9 ? '#10b981' : n >= 7 ? '#06b6d4' : '#ef4444';
            });
            mkChart('ch_<%= cid %>', {
              type: 'bar',
              data: {
                labels: labels,
                datasets: [{ data: counts, backgroundColor: npsColors, borderRadius: 4 }]
              },
              options: { responsive:true, plugins:{ legend:{display:false}, datalabels: barDL },
                scales:{ y:{beginAtZero:true,ticks:{precision:0}}, x:{ticks:{font:{size:11}}} },
                layout: barLayout },
              plugins:[ChartDataLabels]
            });
          })();
          </script>
          <% detractors = (dist.select{|d| d[:label].to_i <= 6}.sum{|d| d[:count]}) %>
          <% passives   = (dist.select{|d| [7,8].include?(d[:label].to_i)}.sum{|d| d[:count]}) %>
          <% promoters  = (dist.select{|d| d[:label].to_i >= 9}.sum{|d| d[:count]}) %>
          <% total_nps  = stats[:total].to_i %>
          <% if total_nps > 0 %>
          <% nps_score  = ((promoters - detractors).to_f / total_nps * 100).round %>
          <% det_pct = (detractors.to_f / total_nps * 100).round %>
          <% pas_pct = (passives.to_f   / total_nps * 100).round %>
          <% pro_pct = (promoters.to_f  / total_nps * 100).round %>
