<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Báo cáo: <%= @survey.title %></title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif; background: #f0f2f5; color: #1a1a2e; font-size: 14px; }

.header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: white; padding: 36px 48px; }
.header h1 { font-size: 22px; font-weight: 700; margin-bottom: 6px; line-height: 1.35; }
.header p  { opacity: 0.6; font-size: 13px; }

.container { max-width: 1200px; margin: 0 auto; padding: 28px 24px 100px; }

/* KPI */
.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(155px,1fr)); gap: 14px; margin-bottom: 4px; }
.kpi { background: white; border-radius: 12px; padding: 18px 14px; text-align: center; box-shadow: 0 2px 8px rgba(0,0,0,.07); border-top: 4px solid; }
.kpi-value { font-size: 34px; font-weight: 800; line-height: 1; margin-bottom: 5px; }
.kpi-label { font-size: 11px; color: #666; font-weight: 500; text-transform: uppercase; letter-spacing: .5px; }

/* Section wrapper — sortable unit */
.report-section { position: relative; margin-top: 28px; }
.report-section.hidden-section { display: none; }

/* Section header row */
.section-header { display: flex; align-items: center; gap: 8px; margin-bottom: 14px; }
.section-title { font-size: 16px; font-weight: 700; color: #1a1a2e; display: flex; align-items: center; gap: 10px; flex: 1; }
.section-title::before { content:''; display:block; width:4px; height:20px; background:#4361ee; border-radius:2px; flex-shrink:0; }

/* Edit mode controls */
.section-controls { display: none; align-items: center; gap: 4px; }
.edit-mode .section-controls { display: flex; }
.btn-drag { cursor: grab; background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 6px; padding: 4px 8px; font-size: 14px; color: #94a3b8; line-height: 1; }
.btn-drag:active { cursor: grabbing; }
.btn-hide { background: #fef2f2; border: 1px solid #fecaca; border-radius: 6px; padding: 4px 10px; font-size: 11px; font-weight: 600; color: #ef4444; cursor: pointer; white-space: nowrap; }
.btn-hide:hover { background: #fee2e2; }

/* Sortable ghost */
.edit-mode .report-section { border: 2px dashed transparent; border-radius: 10px; padding: 4px; transition: border-color .15s; }
.edit-mode .report-section:hover { border-color: #c7d2fe; }
.sortable-ghost { opacity: .4; background: #e0e7ff; border-radius: 10px; }
.sortable-chosen { box-shadow: 0 8px 24px rgba(67,97,238,.2); }

/* Hidden section restore bar */
.restore-bar { display: none; flex-wrap: wrap; gap: 6px; padding: 10px 14px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; margin-top: 12px; }
.restore-bar.has-hidden { display: flex; }
.restore-bar span { font-size: 11px; color: #94a3b8; font-weight: 600; align-self: center; margin-right: 4px; }
.btn-restore { background: white; border: 1px solid #c7d2fe; border-radius: 20px; padding: 3px 10px; font-size: 11px; font-weight: 600; color: #4361ee; cursor: pointer; }
.btn-restore:hover { background: #eef2ff; }

/* Layout */
.grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
.grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 20px; margin-bottom: 20px; }
@media(max-width:900px){ .grid-2,.grid-3{ grid-template-columns:1fr; } }

/* Cards */
.card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,.07); }
.card h3 { font-size: 13px; font-weight: 700; margin-bottom: 16px; color: #1a1a2e; border-bottom: 2px solid #f0f2f5; padding-bottom: 10px; }
canvas { max-height: 260px; }

/* Bar items */
.bar-item { display: flex; align-items: center; margin-bottom: 9px; font-size: 12px; }
.bar-label { flex-shrink: 0; color: #444; line-height: 1.3; padding-right: 8px; }
.bar-label.w160 { width: 160px; }
.bar-label.w200 { width: 200px; }
.bar-label.w220 { width: 220px; }
.bar-track { flex: 1; background: #e8eaf0; border-radius: 4px; height: 18px; overflow: hidden; margin-right: 8px; }
.bar-fill  { height: 100%; border-radius: 4px; display: flex; align-items: center; justify-content: flex-end; padding-right: 6px; color: white; font-size: 11px; font-weight: 700; min-width: 18px; }
.bar-count { width: 26px; text-align: right; color: #888; font-weight: 600; font-size: 12px; }

/* Rating rows */
.rating-row { display: flex; align-items: center; margin-bottom: 11px; }
.rating-label { width: 220px; font-size: 12px; color: #555; line-height: 1.3; flex-shrink: 0; }
.rating-bar { flex: 1; background: #e8eaf0; height: 22px; border-radius: 6px; overflow: hidden; margin-right: 10px; }
.rating-fill { height: 100%; border-radius: 6px; display: flex; align-items: center; justify-content: flex-end; padding-right: 8px; color: white; font-weight: 700; font-size: 11px; }
.rating-score { width: 36px; font-size: 14px; font-weight: 800; color: #1a1a2e; text-align: right; }

/* Insight / Quote */
.insight-box { background: #f8f9ff; border-left: 4px solid #4361ee; border-radius: 0 8px 8px 0; padding: 12px 14px; margin-bottom: 10px; font-size: 12px; line-height: 1.65; }
.insight-box strong { color: #4361ee; }
.quote-card { background: #fffbf0; border: 1px solid #ffe082; border-radius: 10px; padding: 12px 14px; margin-bottom: 9px; font-size: 12px; line-height: 1.65; color: #555; }
.quote-card .author { font-weight: 700; color: #e65100; font-size: 11px; margin-bottom: 3px; }

/* Action bar */
.action-bar { position: fixed; bottom: 24px; right: 24px; display: flex; gap: 8px; z-index: 200; }
.action-bar button { display: flex; align-items: center; gap: 6px; border: none; border-radius: 50px; padding: 10px 20px; font-size: 13px; font-weight: 600; cursor: pointer; box-shadow: 0 4px 14px rgba(0,0,0,.15); transition: all .15s; }
.action-bar button:hover { opacity: .88; }
.btn-print  { background: #fff; color: #374151; }
.btn-pdf    { background: #4361ee; color: #fff; }
.btn-edit   { background: #0f172a; color: #fff; }
.btn-edit.active { background: #10b981; }

footer { text-align: center; padding: 20px; color: #bbb; font-size: 11px; }

/* Print */
@media print {
  .action-bar, .section-controls, .restore-bar { display: none !important; }
  body { background: white; }
  .header { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  .kpi { -webkit-print-color-adjust: exact; print-color-adjust: exact; break-inside: avoid; }
  .card { box-shadow: none !important; border: 1px solid #e0e0e0; break-inside: avoid; }
  .report-section { break-inside: avoid; }
  .grid-2, .grid-3 { break-inside: avoid; }
}
</style>
</head>
<body>

<%# ─── ACTION BAR ───────────────────────────────────────────────── %>
<div class="action-bar" id="actionBar">
  <button class="btn-print" onclick="window.print()">🖨 In</button>
  <button class="btn-pdf"   onclick="window.print()">⬇ Tải PDF</button>
  <button class="btn-edit"  id="btnEdit" onclick="toggleEdit()">✏️ Chỉnh layout</button>
</div>

<%# ─── RESTORE BAR (hidden sections) ──────────────────────────── %>
<div style="max-width:1200px;margin:0 auto;padding:0 24px">
  <div class="restore-bar" id="restoreBar">
    <span>Đã ẩn:</span>
  </div>
</div>

<%# ─── HEADER ─────────────────────────────────────────────────── %>
<div class="header">
  <h1>📊 <%= @survey.title %></h1>
  <p>Báo cáo phân tích
    · <%= @total_responses %> phản hồi
    <% if @survey_date_range %> · <%= @survey_date_range %><% end %>
  </p>
</div>

<div class="container">

<%
  palette = %w[#4361ee #7c3aed #06b6d4 #10b981 #f59e0b #ef4444 #ec4899 #8b5cf6 #0ea5e9 #14b8a6]
  all_buckets = ["<40%", "40–49%", "50–59%", "60–69%", "70–79%", "80–89%", "≥90%"]
%>

<%# ─── KPI (always visible, not draggable) ──────────────────── %>
<%
  kpi_list = [
    { val: @kpis[:total].to_s,          label: "Người tham gia",     color: "#4361ee" },
    (@kpis[:savings_task]  ? { val: @kpis[:savings_task],  label: "Tiết kiệm / task",   color: "#06b6d4" } : nil),
    (@kpis[:savings_daily] ? { val: @kpis[:savings_daily], label: "Tiết kiệm / ngày",    color: "#10b981" } : nil),
    (@kpis[:nps_avg]       ? { val: @kpis[:nps_avg],       label: "Điểm giới thiệu TB",  color: "#f59e0b" } : nil),
    (@kpis[:daily_pct]     ? { val: @kpis[:daily_pct],     label: "Dùng AI hàng ngày",   color: "#8b5cf6" } : nil),
  ].compact
%>
<div class="kpi-grid" style="margin-top:24px">
  <% kpi_list.each do |k| %>
    <div class="kpi" style="border-color:<%= k[:color] %>">
      <div class="kpi-value" style="color:<%= k[:color] %>"><%= k[:val] %></div>
      <div class="kpi-label"><%= k[:label] %></div>
    </div>
  <% end %>
</div>

<%# ─── SORTABLE SECTIONS WRAPPER ────────────────────────────── %>
<div id="sortableContainer">

<%# ── S1: Thành phần ──────────────────────────────────────────── %>
<% if @dept_data.any? || @tool_counts.any? %>
<div class="report-section" data-id="s-demo">
  <div class="section-header">
    <div class="section-controls">
      <span class="btn-drag" title="Kéo để di chuyển">⠿</span>
      <button class="btn-hide" onclick="hideSection('s-demo', 'Thành phần')">Ẩn</button>
    </div>
    <div class="section-title">Thành phần người tham gia</div>
  </div>
  <div class="grid-2">
    <% if @dept_data.any? %>
      <div class="card">
        <h3>Phân bổ theo bộ phận</h3>
        <canvas id="deptChart"></canvas>
      </div>
    <% end %>
    <% if @tool_counts.any? %>
      <div class="card">
        <h3>Công cụ AI được sử dụng (top <%= @tool_counts.size %>)</h3>
        <% max_tc = @tool_counts.first[:count].to_f %>
        <% @tool_counts.each_with_index do |t, i| %>
          <div class="bar-item">
            <div class="bar-label w160"><%= t[:label] %></div>
            <div class="bar-track"><div class="bar-fill" style="width:<%= [(t[:count].to_f/max_tc*100).round,4].max %>%;background:<%= palette[i%palette.size] %>"><%= t[:count] %></div></div>
            <div class="bar-count"><%= t[:count] %></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── S2: Tiết kiệm thời gian ─────────────────────────────────── %>
<% has_savings = @task_savings_dist.any? || @daily_savings_dist.any? || (@dept_savings.any? && @dept_savings.any? { |d| d[:savings_task] || d[:savings_daily] }) %>
<% if has_savings %>
<div class="report-section" data-id="s-savings">
  <div class="section-header">
    <div class="section-controls">
      <span class="btn-drag">⠿</span>
      <button class="btn-hide" onclick="hideSection('s-savings', 'Tiết kiệm TG')">Ẩn</button>
    </div>
    <div class="section-title">Mức độ tiết kiệm thời gian</div>
  </div>
  <% if @task_savings_dist.any? || @daily_savings_dist.any? %>
    <div class="grid-2">
      <% if @task_savings_dist.any? %>
        <div class="card"><h3>Phân bổ % tiết kiệm mỗi task điển hình</h3><canvas id="taskSavingsChart"></canvas></div>
      <% end %>
      <% if @daily_savings_dist.any? %>
        <div class="card"><h3>Phân bổ % tiết kiệm mỗi ngày làm việc</h3><canvas id="dailySavingsChart"></canvas></div>
      <% end %>
    </div>
  <% end %>
  <% if @dept_savings.any? && @dept_savings.any? { |d| d[:savings_task] || d[:savings_daily] } %>
    <div class="card" style="margin-bottom:20px"><h3>Tiết kiệm thời gian theo bộ phận</h3><canvas id="deptSavingsChart" style="max-height:200px"></canvas></div>
  <% end %>
</div>
<% end %>

<%# ── S3: Cách sử dụng AI ─────────────────────────────────────── %>
<% if @stage_counts.any? || @task_type_counts.any? %>
<div class="report-section" data-id="s-usage">
  <div class="section-header">
    <div class="section-controls">
      <span class="btn-drag">⠿</span>
      <button class="btn-hide" onclick="hideSection('s-usage', 'Cách dùng AI')">Ẩn</button>
    </div>
    <div class="section-title">Cách sử dụng AI</div>
  </div>
  <div class="grid-2">
    <% if @stage_counts.any? %>
      <div class="card"><h3>Giai đoạn AI hữu ích nhất</h3><canvas id="stageChart"></canvas></div>
    <% end %>
    <% if @task_type_counts.any? %>
      <div class="card">
        <h3>Loại công việc dùng AI</h3>
        <% max_tt = @task_type_counts.first[:count].to_f %>
        <% @task_type_counts.each_with_index do |t, i| %>
          <div class="bar-item">
            <div class="bar-label w200"><%= t[:label].to_s.truncate(38) %></div>
            <div class="bar-track"><div class="bar-fill" style="width:<%= [(t[:count].to_f/max_tt*100).round,4].max %>%;background:<%= palette[i%palette.size] %>"><%= t[:count] %></div></div>
            <div class="bar-count"><%= t[:count] %></div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── S4: Đánh giá ────────────────────────────────────────────── %>
<% all_rating_data = (@rating_stats + [@nps_stats&.merge(title: "Sẵn sàng giới thiệu (NPS)")]).compact %>
<% if all_rating_data.any? %>
<div class="report-section" data-id="s-ratings">
  <div class="section-header">
    <div class="section-controls">
      <span class="btn-drag">⠿</span>
      <button class="btn-hide" onclick="hideSection('s-ratings', 'Đánh giá')">Ẩn</button>
    </div>
    <div class="section-title">Đánh giá chất lượng & trải nghiệm</div>
  </div>
  <div class="grid-3">
    <div class="card">
      <h3>Điểm trung bình các chỉ số</h3>
      <% r_gradients = ["linear-gradient(90deg,#4361ee,#7c3aed)","linear-gradient(90deg,#06b6d4,#4361ee)","linear-gradient(90deg,#10b981,#06b6d4)","linear-gradient(90deg,#f59e0b,#10b981)","linear-gradient(90deg,#8b5cf6,#ec4899)"] %>
      <% all_rating_data.each_with_index do |rs, ri| %>
        <% max_scale = (rs[:max] || 10).to_f %>
        <% pct = [(rs[:mean].to_f/max_scale*100).round, 3].max %>
        <div class="rating-row">
          <div class="rating-label"><%= rs[:title].to_s.truncate(45) %></div>
          <div class="rating-bar"><div class="rating-fill" style="width:<%= pct %>%;background:<%= r_gradients[ri % r_gradients.size] %>"><%= rs[:mean] %></div></div>
          <div class="rating-score"><%= rs[:mean] %></div>
        </div>
      <% end %>
    </div>
    <% if (first_r = @rating_stats.first) %>
      <div class="card"><h3>Phân phối: <%= first_r[:title].to_s.truncate(50) %></h3><canvas id="ratingDistChart"></canvas></div>
    <% end %>
    <% if @nps_stats %>
      <div class="card"><h3>Phân phối NPS (0–10)</h3><canvas id="npsChart"></canvas></div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── S5: Khó khăn ────────────────────────────────────────────── %>
<% if @challenge_counts.any? || @notable_quotes.any? %>
<div class="report-section" data-id="s-challenges">
  <div class="section-header">
    <div class="section-controls">
      <span class="btn-drag">⠿</span>
      <button class="btn-hide" onclick="hideSection('s-challenges', 'Khó khăn')">Ẩn</button>
    </div>
    <div class="section-title">Khó khăn & ý kiến người dùng</div>
  </div>
  <div class="grid-2">
    <% if @challenge_counts.any? %>
      <div class="card"><h3>Tỷ lệ các khó khăn gặp phải</h3><canvas id="challengeChart"></canvas></div>
    <% end %>
    <% if @notable_quotes.any? %>
      <div class="card">
        <h3>Nhận xét đáng chú ý</h3>
        <% @notable_quotes.first(4).each do |q| %>
          <div class="quote-card">
            <div class="author"><%= q[:name].present? && q[:name] != "Ẩn danh" ? q[:name] : "Người dùng" %><% if q[:dept].present? %> · <%= q[:dept] %><% end %></div>
            "<%= q[:text] %>"
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── S6: Đề xuất ─────────────────────────────────────────────── %>
<% has_s6 = @request_themes.any? || (@ai_analysis.present? && (@ai_analysis.output["highlights"].present? || @ai_analysis.output["recommendations"].present?)) %>
<% if has_s6 %>
<div class="report-section" data-id="s-recs">
  <div class="section-header">
    <div class="section-controls">
      <span class="btn-drag">⠿</span>
      <button class="btn-hide" onclick="hideSection('s-recs', 'Đề xuất')">Ẩn</button>
    </div>
    <div class="section-title">Đề xuất & khuyến nghị</div>
  </div>
  <div class="grid-2">
    <% if @request_themes.any? %>
      <div class="card">
        <h3>Nhóm đề xuất từ nhân viên</h3>
        <% max_rt = @request_themes.first[:count].to_f %>
        <% rt_colors = %w[#4361ee #7c3aed #06b6d4 #10b981 #f59e0b] %>
        <% @request_themes.each_with_index do |t, i| %>
          <div class="bar-item">
            <div class="bar-label w220"><%= t[:label] %></div>
            <div class="bar-track"><div class="bar-fill" style="width:<%= [(t[:count].to_f/max_rt*100).round,4].max %>%;background:<%= rt_colors[i%rt_colors.size] %>"><%= t[:count] %></div></div>
            <div class="bar-count"><%= t[:count] %></div>
          </div>
        <% end %>
      </div>
    <% end %>
    <% if @ai_analysis.present? %>
      <% ai = @ai_analysis.output %>
      <% ai_h = ai["highlights"] || []; ai_r = ai["recommendations"] || [] %>
      <% if ai_h.any? || ai_r.any? %>
        <div class="card">
          <h3>Insights & Khuyến nghị (AI)</h3>
          <% ai_h.first(3).each do |h| %><div class="insight-box"><strong>✦</strong> <%= h %></div><% end %>
          <% ai_r.first(3).each do |rec| %>
            <% if rec.is_a?(Hash) %>
              <div class="insight-box"><strong>→ <%= rec["action"] %></strong><br><span style="color:#666;font-size:11px"><%= rec["rationale"] %></span></div>
            <% else %>
              <div class="insight-box"><strong>→</strong> <%= rec %></div>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
<% end %>

</div><!-- /#sortableContainer -->
</div><!-- /.container -->

<footer>Báo cáo tự động · VOX · <%= @total_responses %> phản hồi · <%= @survey.title %></footer>

<%# ─── CHARTS JS ─────────────────────────────────────────────── %>
<script>
Chart.register(ChartDataLabels);
const C = ['#4361ee','#7c3aed','#06b6d4','#10b981','#f59e0b','#ef4444','#ec4899','#8b5cf6','#0ea5e9','#14b8a6'];
const barDL  = { anchor:'end', align:'end', offset:2, clip:false, font:{size:11,weight:'700'}, color:'#444', formatter:(v)=>v>0?v:'' };
const hbarDL = { anchor:'end', align:'end', offset:4, clip:false, font:{size:11,weight:'700'}, color:'#444', formatter:(v)=>v>0?v:'' };
const pieDL  = { display:(ctx)=>ctx.dataset.data[ctx.dataIndex]>0, color:'#fff', font:{size:12,weight:'700'}, formatter:(v)=>v };
const barLayout = { padding:{ top:20 } };

<% if @dept_data.any? %>
new Chart(document.getElementById('deptChart'),{type:'doughnut',data:{labels:<%= raw @dept_data.map{|d|d[:label]}.to_json %>,datasets:[{data:<%= raw @dept_data.map{|d|d[:count]}.to_json %>,backgroundColor:C,borderWidth:2,borderColor:'#fff'}]},options:{cutout:'50%',plugins:{legend:{position:'right',labels:{boxWidth:14,font:{size:12}}},datalabels:pieDL}}});
<% end %>

<% if @task_savings_dist.any? %>
<% bucket_map_t=@task_savings_dist.each_with_object({}){|b,h|h[b[:label]]=b[:count]}; t_labels=all_buckets.dup; t_data=all_buckets.map{|l|bucket_map_t[l]||0} %>
new Chart(document.getElementById('taskSavingsChart'),{type:'bar',data:{labels:<%= raw t_labels.to_json %>,datasets:[{data:<%= raw t_data.to_json %>,backgroundColor:C[0]+'99',borderColor:C[0],borderWidth:2,borderRadius:6}]},options:{layout:barLayout,plugins:{legend:{display:false},datalabels:barDL},scales:{y:{beginAtZero:true,ticks:{stepSize:1,precision:0}}}}});
<% end %>

<% if @daily_savings_dist.any? %>
<% bucket_map_d=@daily_savings_dist.each_with_object({}){|b,h|h[b[:label]]=b[:count]}; d_data=all_buckets.map{|l|bucket_map_d[l]||0} %>
