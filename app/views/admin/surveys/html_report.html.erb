let rd = null;
let rafId = null;
let latestE = null;

document.addEventListener('mousedown', e => {
  const handle = e.target.closest('[data-dir]');
  if (!handle) return;
  const cw = handle.closest('.cw');
  if (!cw?.classList.contains('cw-resize-mode')) return; // only resize-mode cards
  e.preventDefault();
  e.stopPropagation();

  const grid = cw.parentElement;
  const dir = handle.dataset.dir;
  const defaultSpan = grid.classList.contains('grid-3') ? 4 : 6;
  const startSpan = parseInt(cw.style.gridColumn?.match(/span (\d+)/)?.[1] || defaultSpan);
  const startH = cw.querySelector('.card')?.offsetHeight || 240;
  const gridRect = grid.getBoundingClientRect();

  handle.classList.add('dragging');
  cw.classList.add('is-resizing');
  rd = { cw, handle, dir, gridRect, startH,
         startSpan, startY: e.clientY, _span: startSpan, _h: startH };

  document.body.style.userSelect = 'none';
  document.body.style.cursor = dir === 'e' ? 'ew-resize' : dir === 's' ? 'ns-resize' : 'nwse-resize';
  tip.classList.add('visible');
});

document.addEventListener('mousemove', e => {
  if (!rd) return;
  latestE = e;
  if (!rafId) rafId = requestAnimationFrame(applyResize);
}, { passive: true });

function applyResize() {
  rafId = null;
  if (!rd || !latestE) return;
  const e = latestE;
  const { cw, dir, gridRect, startH, startY, startSpan } = rd;
  const card = cw.querySelector('.card');
  const MAXCOLS = 12;

  if (dir === 'e' || dir === 'se') {
    // Snap based on absolute cursor position within grid
    const colW = gridRect.width / MAXCOLS;
    const offsetInGrid = e.clientX - gridRect.left;
    const newSpan = Math.max(1, Math.min(MAXCOLS, Math.round(offsetInGrid / colW)));
    if (newSpan !== rd._span) {
      cw.style.gridColumn = `span ${newSpan}`;
      rd._span = newSpan;
    }
  }
  if (dir === 's' || dir === 'se') {
    const newH = Math.max(180, startH + (e.clientY - startY));
    if (card && Math.abs(newH - (rd._h||0)) > 2) {
      card.style.minHeight = newH + 'px';
      card.style.height = '';
      rd._h = newH;
      showResizeBorder(card);
      const h3H = card?.querySelector('h3')?.offsetHeight || 50;
      const cvH = Math.max(80, newH - h3H - 60);
      rd.cw.querySelectorAll('.chart-wrap').forEach(wrap => {
        wrap.style.height = cvH + 'px';
        const cv = wrap.querySelector('canvas');
        const ch = cv && chartReg[cv.id]; if (ch) { try { ch.resize(); } catch(_) {} }
      });
    }
  }

  const parts = [];
  if (dir !== 's') parts.push(`${rd._span}/12`);
  if (dir !== 'e') parts.push(`${Math.round(rd._h||startH)}px`);
  tip.textContent = parts.join(' · ');
  tip.style.left = e.clientX + 'px';
  tip.style.top  = e.clientY + 'px';
}

document.addEventListener('mouseup', () => {
  if (!rd) return;
  const resizedCw = rd.cw;
  rd.handle.classList.remove('dragging');
  rd.cw.classList.remove('is-resizing');
  document.body.style.cursor = '';
  document.body.style.userSelect = '';
  tip.classList.remove('visible');
  rd = null; latestE = null; rafId = null;
  saveLayout();
  resizedCw.querySelectorAll('.chart-wrap canvas').forEach(cv => {
    const ch = chartReg[cv.id]; if (ch) { try { ch.resize(); } catch(e) {} }
  });
});

// ── Delete card ──
function askDelete(cid, label) {
  deactivateAllCards();
