          <div class="quote-card"><div style="font-size:12px;line-height:1.7;color:#374151"><%= q_text %></div></div>
          <% end %>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
