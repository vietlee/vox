            end
            # Map value_question_ids to short titles
            val_qids = Array(card["value_question_ids"]).map(&:to_i)
            ct_datasets = ct_data[:datasets].each_with_index.map do |ds, i|
              short = short_title_map[val_qids[i]] || ds[:label]
