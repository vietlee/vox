<script>
Chart.register(ChartDataLabels);
const C=['#4361ee','#7c3aed','#06b6d4','#10b981','#f59e0b','#ef4444','#ec4899','#8b5cf6','#0ea5e9','#14b8a6'];
const barDL  ={anchor:'end',align:'end',offset:2,clip:false,font:{size:11,weight:'700'},color:'#444',formatter:v=>v>0?v:''};
const hbarDL ={anchor:'end',align:'end',offset:4,clip:false,font:{size:11,weight:'700'},color:'#444',formatter:v=>v>0?v:''};
const pieDL  ={display:ctx=>ctx.dataset.data[ctx.dataIndex]>0,color:'#fff',font:{size:12,weight:'700'},formatter:v=>v};
const barLayout={padding:{top:20}};
const chartReg={}; // chartId → Chart instance

function mkChart(id,cfg){
  const ch=new Chart(document.getElementById(id),cfg);
  chartReg[id]=ch;
  return ch;
}

<%# ── Charts ── %>
<% if @dept_data.any? %>
mkChart('deptChart',{type:'doughnut',data:{labels:<%= raw @dept_data.map{|d|d[:label]}.to_json %>,datasets:[{data:<%= raw @dept_data.map{|d|d[:count]}.to_json %>,backgroundColor:C,borderWidth:2,borderColor:'#fff'}]},options:{cutout:'50%',plugins:{legend:{position:'right',labels:{boxWidth:14,font:{size:12}}},datalabels:pieDL}}});
<% end %>

<% if @task_savings_dist.any? %>
<% bmt=@task_savings_dist.each_with_object({}){|b,h|h[b[:label]]=b[:count]}; td=all_buckets.map{|l|bmt[l]||0} %>
mkChart('taskSavingsChart',{type:'bar',data:{labels:<%= raw all_buckets.to_json %>,datasets:[{data:<%= raw td.to_json %>,backgroundColor:C[0]+'99',borderColor:C[0],borderWidth:2,borderRadius:6}]},options:{layout:barLayout,plugins:{legend:{display:false},datalabels:barDL},scales:{y:{beginAtZero:true,ticks:{stepSize:1,precision:0}}}}});
<% end %>

<% if @daily_savings_dist.any? %>
<% bmd=@daily_savings_dist.each_with_object({}){|b,h|h[b[:label]]=b[:count]}; dd=all_buckets.map{|l|bmd[l]||0} %>
mkChart('dailySavingsChart',{type:'bar',data:{labels:<%= raw all_buckets.to_json %>,datasets:[{data:<%= raw dd.to_json %>,backgroundColor:C[2]+'99',borderColor:C[2],borderWidth:2,borderRadius:6}]},options:{layout:barLayout,plugins:{legend:{display:false},datalabels:barDL},scales:{y:{beginAtZero:true,ticks:{stepSize:1,precision:0}}}}});
