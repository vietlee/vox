<script>
// ══════════════════════════════════════════════════════════
// Layout editor
// ══════════════════════════════════════════════════════════
const SURVEY_ID = '<%= @survey.id %>';
const REPORT_LANG = '<%= @report_lang || "vi" %>';
const SK = 'report_layout_' + SURVEY_ID + '_' + REPORT_LANG;
const IS_PUBLIC = <%= @public_view ? 'true' : 'false' %>;

// ── KPI drag-resize ──────────────────────────────────────────────────────
const KPI_SIZE_SK = 'report_kpi_sizes_' + SURVEY_ID + '_' + REPORT_LANG;
let kpiDrag = null;
const KPI_MAXCOLS = 12;
function _kpiGridCols() { return KPI_MAXCOLS; }
function loadKpiSizes() {
  try {
    const saved = JSON.parse(localStorage.getItem(KPI_SIZE_SK) || '{}');
    Object.entries(saved).forEach(([idx, v]) => {
      const block = document.getElementById('kpi-block-' + idx);
      if (!block) return;
      const span = typeof v === 'object' ? v.span : v;
      const h    = typeof v === 'object' ? v.h : null;
      if (span) block.style.gridColumn = 'span ' + span;
      if (h) block.style.minHeight = h + 'px';
    });
  } catch(e) {}
}
(function initKpiDrag() {
  document.addEventListener('mousedown', e => {
    if (IS_PUBLIC) return;
    const handle = e.target.closest('.kpi-rh,.kpi-lh,.kpi-rb,.kpi-rt');
    if (!handle) return;
    const block = handle.parentElement;
    const kpiGrid = document.querySelector('.kpi-grid');
    if (!block || !kpiGrid) return;
    e.preventDefault();
    handle.classList.add('dragging');
    const dir = handle.dataset.dir;
    if (dir === 'r' || dir === 'l') {
      const numCols = _kpiGridCols();
      const colW = kpiGrid.getBoundingClientRect().width / numCols;
      const curSpan = parseInt(block.style.gridColumn?.replace('span ', '')) || 1;
      kpiDrag = { handle, block, dir, startX: e.clientX, startSpan: curSpan, colW, numCols };
    } else {
      const blockRect = block.getBoundingClientRect();
      kpiDrag = { handle, block, dir, startY: e.clientY, startH: blockRect.height, blockTop: blockRect.top };
    }
  });
  document.addEventListener('mousemove', e => {
    if (!kpiDrag) return;
    const { dir } = kpiDrag;
    if (dir === 'r' || dir === 'l') {
      const dx = e.clientX - kpiDrag.startX;
      // right: drag right = wider; left: drag left = wider
      const sign = dir === 'r' ? 1 : -1;
      const newSpan = Math.max(1, Math.min(kpiDrag.numCols, Math.round((kpiDrag.startSpan * kpiDrag.colW + sign * dx) / kpiDrag.colW)));
      kpiDrag.block.style.gridColumn = newSpan > 1 ? 'span ' + newSpan : '';
      kpiDrag.pendingSpan = newSpan;
    } else {
      // Use absolute position from block top so shrinking works even when minHeight constrains
      const newH = dir === 'b'
        ? Math.max(80, e.clientY - kpiDrag.blockTop)
        : Math.max(80, kpiDrag.startH - (e.clientY - kpiDrag.startY));
      kpiDrag.block.style.height = newH + 'px';
      kpiDrag.block.style.minHeight = newH + 'px';
      kpiDrag.pendingH = newH;
    }
  });
  document.addEventListener('mouseup', () => {
    if (!kpiDrag) return;
    kpiDrag.handle.classList.remove('dragging');
    const idx = kpiDrag.handle.dataset.kpiIdx;
    const isH = kpiDrag.dir === 'r' || kpiDrag.dir === 'l';
    if (!isH && kpiDrag.block.style.height) {
      kpiDrag.block.style.minHeight = kpiDrag.block.style.height;
      kpiDrag.block.style.height = '';
    }
    try {
      const saved = JSON.parse(localStorage.getItem(KPI_SIZE_SK) || '{}');
      if (!saved[idx] || typeof saved[idx] !== 'object') saved[idx] = {};
      if (isH) {
        const span = kpiDrag.pendingSpan != null ? kpiDrag.pendingSpan : kpiDrag.startSpan;
        if (span >= 1) saved[idx].span = span; else delete saved[idx].span;
      } else {
        const h = kpiDrag.pendingH != null ? Math.round(kpiDrag.pendingH) : Math.round(kpiDrag.startH);
        if (h > 80) saved[idx].h = h; else delete saved[idx].h;
      }
      if (!Object.keys(saved[idx]).length) delete saved[idx];
      localStorage.setItem(KPI_SIZE_SK, JSON.stringify(saved));
    } catch(e) {}
    kpiDrag = null;
    saveLayout();
  });
})();

// ── KPI label inline editing ──────────────────────────────────────────────
const KPI_SK = 'report_kpi_labels_' + SURVEY_ID + '_' + REPORT_LANG;
function saveKpiLabel(el) {
  const idx  = el.dataset.kpiIdx;
  const text = el.innerText.trim();
  if (!text) { el.innerText = el.dataset.kpiDefault; return; }
  try {
    const saved = JSON.parse(localStorage.getItem(KPI_SK) || '{}');
    saved[idx] = text;
    localStorage.setItem(KPI_SK, JSON.stringify(saved));
  } catch(e) {}
}
function loadKpiLabels() {
  try {
    const saved = JSON.parse(localStorage.getItem(KPI_SK) || '{}');
    document.querySelectorAll('.kpi-editable[data-kpi-idx]').forEach(el => {
      const v = saved[el.dataset.kpiIdx];
      if (v) el.innerText = v;
    });
  } catch(e) {}
}
document.addEventListener('DOMContentLoaded', () => { loadKpiLabels(); loadKpiSizes(); });

// ── Floating edit icon for [data-editable] elements ──────────────────────
(function(){
  if (IS_PUBLIC) return;
  const icon = document.createElement('button');
  icon.className = 'float-edit-icon';
  icon.title = 'Sửa nội dung';
  icon.innerHTML = '<svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z"/></svg>';
  document.body.appendChild(icon);
  let target = null, hideTimer = null;
  function showIcon(el) {
    clearTimeout(hideTimer);
    target = el;
    const r = el.getBoundingClientRect();
    icon.style.left = (r.right + 6) + 'px';
    icon.style.top  = (r.top + r.height / 2 - 18) + 'px';
    icon.style.display = 'flex';
  }
  function scheduleHide() {
    hideTimer = setTimeout(() => { icon.style.display = 'none'; target = null; }, 120);
  }
  document.addEventListener('mouseover', e => {
    const el = e.target.closest('[data-editable]');
    if (el) showIcon(el);
  });
  document.addEventListener('mouseout', e => {
    if (e.target.closest('[data-editable]') && !e.relatedTarget?.closest('[data-editable]') && e.relatedTarget !== icon) scheduleHide();
  });
  icon.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  icon.addEventListener('mouseleave', () => scheduleHide());
  icon.addEventListener('click', e => {
    e.stopPropagation();
    if (!target) return;
    const cw = target.closest('.cw');
    if (cw) {
      cw.classList.remove('cw-resize-mode','cw-move-mode');
      cw.classList.add('cw-text-mode');
      cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'true');
      cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
      const textBtn = cw.querySelector('.ct-mode-btn[data-mode="text"]');
      if (textBtn) textBtn.classList.add('active');
    }
    target.focus();
    icon.style.display = 'none';
  });
})();

// ── Structure version check: clear stale localStorage if structure changed ──
(function(){
  const STRUCT_VER = '<%= Digest::MD5.hexdigest(@report_structure.to_json)[0,8] rescue "0" %>';
  const VER_KEY = SK + '_structver';
  const savedVer = localStorage.getItem(VER_KEY);
  if (savedVer && savedVer !== STRUCT_VER) {
    // Structure regenerated → wipe old layout so stale section IDs don't pollute restore bar
    localStorage.removeItem(SK);
    localStorage.removeItem(SK + '_sub_edited');
  }
  localStorage.setItem(VER_KEY, STRUCT_VER);
})();
<% _layout_key = "report_layout_#{@survey.id}_#{@report_lang || 'vi'}" %>
<% if @survey.settings[_layout_key].present? %>
// Inject server-saved layout into localStorage (admin + public)
(function(){
  try {
    const serverLayout = <%= raw @survey.settings[_layout_key].to_json %>;
    // Only use server layout if it was saved with current LAYOUT_VERSION
    if (serverLayout && serverLayout._v >= LAYOUT_VERSION) {
      localStorage.setItem(SK, JSON.stringify(serverLayout));
    } else {
      // Server layout is stale — clear localStorage so loadLayout starts fresh
      localStorage.removeItem(SK);
    }
  } catch(e) {}
})();
<% end %>
let editMode = false;
let pendingDeleteCid = null;
let currentChartModal = null; // { chartId, cardTitle }

// ── Section-level edit mode (drag/hide sections) ──
function toggleEdit() {
  editMode = !editMode;
  document.body.classList.toggle('edit-mode', editMode);
  const btn = document.getElementById('btnEdit');
  btn.classList.toggle('active', editMode);
  btn.textContent = editMode ? '✅ Xong' : '⠿ Sắp xếp sections';
  // Close any active card when toggling
  deactivateAllCards();
}

// ── Per-card gear activation ──
let activeCw = null;

function activateCard(cw) {
  if (activeCw === cw) return;
  deactivateAllCards();
  activeCw = cw;
  cw.classList.add('cw-active');
}

function deactivateAllCards() {
  document.querySelectorAll('.cw-active').forEach(c => {
    c.classList.remove('cw-active','cw-text-mode','cw-resize-mode','cw-move-mode');
    c.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'false');
    c.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  });
  activeCw = null;
}

// ── Mode toggle per card ──
// mode: 'text' | 'resize' | 'move'
function setCwMode(btn, mode) {
  if (!btn) return; // guard: called with null (old ERB remnant)
  const cw = btn.closest('.cw');
  if (!cw) return;
  const modeClass = 'cw-' + mode + '-mode';
  const wasActive = btn.classList.contains('active');

  // Clear all modes on this card
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'false');

  if (!wasActive) {
    cw.classList.add(modeClass);
    btn.classList.add('active');
    // Show correct mode bar label
    cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
    const lbl = cw.querySelector('.lbl-' + (mode==='resize'?'resize':mode==='move'?'move':'text'));
    if (lbl) lbl.style.display = '';
    if (mode === 'text') {
      cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'true');
    }
    if (mode === 'resize') {
      const grid = cw.parentElement;
      const defaultSpan = grid?.classList.contains('grid-3') ? 4 : 6;
      const cur = parseInt(cw.style.gridColumn?.match(/span (\d+)/)?.[1] || defaultSpan);
      const lbl = cw.querySelector('.span-label');
      if (lbl) lbl.textContent = cur + '/12';
    }
  }
  // Close dropdown after selecting a mode
  cw.classList.remove('cw-active');
  activeCw = null;
}

function adjustSpan(btn, delta) {
  const cw = btn.closest('.cw');
  if (!cw) return;
  const grid = cw.parentElement;
  const MAXCOLS = 12;
  const defaultSpan = grid?.classList.contains('grid-3') ? 4 : 6;
  const cur = parseInt(cw.style.gridColumn?.match(/span (\d+)/)?.[1] || defaultSpan);
  const siblings = [...(grid?.querySelectorAll(':scope > .cw') || [])].filter(el => el !== cw && !el.classList.contains('hidden-section'));
  const minSib = siblings.length > 0 ? 2 : 0;
  const newSpan = Math.max(2, Math.min(MAXCOLS - minSib, cur + delta));
  cw.style.gridColumn = `span ${newSpan}`;
  if (siblings.length === 1) siblings[0].style.gridColumn = `span ${MAXCOLS - newSpan}`;
  // Update label
  const lbl = btn.closest('.span-controls')?.querySelector('.span-label');
  if (lbl) lbl.textContent = newSpan + '/12';
  cw.querySelectorAll('.chart-wrap canvas').forEach(cv => { const ch = chartReg[cv.id]; if (ch) { try { ch.resize(); } catch(_){} } });
  saveLayout();
}

function cancelMode(e, btn) {
  e.stopPropagation();
  e.preventDefault();
  const cw = btn.closest('.cw');
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'false');
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
  saveLayout();
}

