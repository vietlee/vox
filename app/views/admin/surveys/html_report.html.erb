              <div style="display:flex;align-items:center;gap:6px">
                <span style="width:10px;height:10px;border-radius:50%;background:#06b6d4;flex-shrink:0;display:inline-block"></span>
                <div>
                  <div style="font-size:13px;font-weight:700;color:#06b6d4"><%= passives %> người <span style="font-weight:400;color:#94a3b8">(<%= pas_pct %>%)</span></div>
