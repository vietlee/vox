const SECTION_I18N_MAP = {
  's-demo': { vi: 'Thành phần người tham gia', en: 'Participant breakdown' },
  's-savings': { vi: 'Mức độ tiết kiệm thời gian', en: 'Time savings' },
  's-usage': { vi: 'Cách sử dụng AI', en: 'How AI is used' },
  's-ratings': { vi: 'Đánh giá chất lượng & trải nghiệm', en: 'Quality & experience ratings' },
  's-challenges': { vi: 'Khó khăn & ý kiến người dùng', en: 'Challenges & feedback' },
  's-recs': { vi: 'Đề xuất & khuyến nghị', en: 'Suggestions & recommendations' },
};

let currentLang = '<%= @report_lang || I18n.locale %>';

function t(key) { return (TRANSLATIONS[currentLang] || TRANSLATIONS['vi'])[key] || key; }

function applyTranslations() {
  // data-i18n elements in action bar
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    el.textContent = t(key);
  });
  // Restore bar label
  const hiddenSpan = document.querySelector('#restoreBar > span');
  if (hiddenSpan) hiddenSpan.textContent = t('hidden_label');
  // Share modal static text
  const st = document.querySelector('.share-box h3'); if (st) st.textContent = t('share_title');
  const sd = document.querySelector('.share-box > p'); if (sd) sd.textContent = t('share_desc');
  const sl = document.querySelector('.share-link-input');
  if (sl && sl.value === 'Đang tạo link...' || sl?.value === 'Generating link...') sl.value = t('generating_link');
  document.querySelectorAll('.share-btn .icon + span, .share-btn').forEach(btn => {
    const icon = btn.querySelector?.('.icon');
    if (!icon) return;
    const txt = btn.childNodes[btn.childNodes.length - 1];
    // identify by icon
    const ic = icon.textContent;
    if (ic === '📋') { if (txt.nodeType === 3) txt.textContent = t('copy_link'); }
    else if (ic === '🖼') { if (txt.nodeType === 3) txt.textContent = t('copy_qr'); }
    else if (ic === '⬇️') { if (txt.nodeType === 3) txt.textContent = t('download_qr'); }
  });
  document.querySelector('.share-revoke') && (document.querySelector('.share-revoke').textContent = t('revoke_link'));
  document.querySelector('.share-close') && (document.querySelector('.share-close').textContent = t('close'));
  // PDF loading
  const pdfSpan = document.querySelector('#pdf-loading span'); if (pdfSpan) pdfSpan.textContent = t('pdf_loading');
  // Section titles via SECTION_I18N_MAP
  Object.entries(SECTION_I18N_MAP).forEach(([sid, labels]) => {
    const sec = document.querySelector(`[data-id="${sid}"]`);
    if (!sec) return;
    const titleEl = sec.querySelector('.section-title');
    if (titleEl) titleEl.textContent = labels[currentLang] || labels['vi'];
  });
  // Lang button active state
  document.getElementById('langVI')?.classList.toggle('active', currentLang === 'vi');
  document.getElementById('langEN')?.classList.toggle('active', currentLang === 'en');
  // Header subtitle "Báo cáo phân tích · N phản hồi" — only if not custom-edited
  const subEl = document.getElementById('hdrSubText');
  if (subEl && !localStorage.getItem(SK + '_sub_edited')) {
    const totalRes = <%= @total_responses %>;
    const dateRange = '<%= @survey_date_range.to_s %>';
    let sub = t('analysis_report') + ' · ' + totalRes + ' ' + t('responses');
    if (dateRange) sub += ' · ' + dateRange;
    subEl.textContent = sub;
  }
}

function setLang(lang) {
  if (lang === REPORT_LANG) return;
  // Data is server-rendered per language — reload with correct lang param
  const url = new URL(window.location.href);
  url.searchParams.set('lang', lang);
  window.location.href = url.toString();
}

// Init — apply translations using REPORT_LANG (server-authoritative)
(function(){
  currentLang = REPORT_LANG;
  applyTranslations();
})();

loadLayout();
</script>
