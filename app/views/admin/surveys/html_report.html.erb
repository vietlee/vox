             style="width:72px;height:72px;border-radius:18px;box-shadow:0 4px 20px rgba(67,97,238,.3);animation:vox-pulse 1.6s ease-in-out infinite"
             onerror="this.style.display='none';document.getElementById('rb-icon-fallback').style.display='flex'">
        <div id="rb-icon-fallback"
             style="display:none;width:72px;height:72px;border-radius:18px;background:linear-gradient(135deg,#4361ee,#7c3aed);align-items:center;justify-content:center;font-size:28px;font-weight:900;color:white;letter-spacing:-1px;box-shadow:0 4px 20px rgba(67,97,238,.3);animation:vox-pulse 1.6s ease-in-out infinite">
          V
        </div>
        <!-- Orbiting dot -->
        <div style="position:absolute;inset:-6px;border-radius:50%;border:2px dashed #c7d2fe;animation:rb-orbit 3s linear infinite"></div>
      </div>

      <div style="font-size:11px;font-weight:700;color:#4361ee;letter-spacing:1.2px;text-transform:uppercase;margin-bottom:8px">✦ AI đang phân tích</div>
      <h2 style="font-size:20px;font-weight:800;color:#1a1a2e;margin-bottom:8px">Đang tạo cấu trúc báo cáo</h2>
      <p style="font-size:13px;color:#64748b;line-height:1.6;margin-bottom:20px">AI đọc câu hỏi, phân tích dữ liệu và thiết kế layout phù hợp.</p>

      <!-- Progress bar + % -->
      <div style="margin-bottom:20px">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
          <span id="rb-status-text" style="font-size:12px;color:#64748b">Đang khởi động...</span>
          <span id="rb-pct" style="font-size:13px;font-weight:700;color:#4361ee">0%</span>
        </div>
        <div style="height:6px;background:#e0e7ff;border-radius:99px;overflow:hidden">
          <div id="rb-bar" style="height:100%;width:0%;background:linear-gradient(90deg,#4361ee,#7c3aed);border-radius:99px;transition:width .6s ease"></div>
        </div>
      </div>

      <!-- Steps -->
      <div style="background:#f8fafc;border-radius:12px;padding:14px 18px;text-align:left">
        ${[
          ['rb-s1','Đọc danh sách câu hỏi','done'],
          ['rb-s2','Phân tích dữ liệu thực tế','done'],
          ['rb-s3','AI rút gọn nhãn & thiết kế layout','active'],
          ['rb-s4','Tạo báo cáo hoàn chỉnh',''],
        ].map(([id,label,cls])=>`
          <div id="${id}" style="display:flex;align-items:center;gap:10px;padding:5px 0;font-size:12px;
            color:${cls==='done'?'#10b981':cls==='active'?'#4361ee':'#94a3b8'};
            font-weight:${cls==='active'?'700':'500'};border-bottom:1px solid #f1f5f9">
            <span style="width:8px;height:8px;border-radius:50%;flex-shrink:0;
              background:${cls==='done'?'#10b981':cls==='active'?'#4361ee':'#e2e8f0'};
              ${cls==='active'?'animation:pulse-dot 1s infinite':''}"></span>
            ${label}
          </div>`).join('')}
      </div>
    </div>`;
  document.body.appendChild(el);

  // Animate progress
  const steps = [
    { id:'rb-s1', pct:15, text:'Đọc danh sách câu hỏi...', delay:0 },
    { id:'rb-s2', pct:40, text:'Phân tích dữ liệu thực tế...', delay:800 },
    { id:'rb-s3', pct:75, text:'AI rút gọn nhãn & thiết kế layout...', delay:2500 },
    { id:'rb-s4', pct:95, text:'Đang hoàn thiện báo cáo...', delay:6000 },
  ];
  steps.forEach(({ id, pct, text, delay }) => {
    setTimeout(() => {
      // Mark previous done
      const prev = document.getElementById(id);
      if (prev) {
        // done style for previous steps, active for current
        steps.forEach(s => {
          const el2 = document.getElementById(s.id);
          if (!el2) return;
          const dot = el2.querySelector('span');
          if (s.id === id) {
            el2.style.color = '#4361ee'; el2.style.fontWeight = '700';
            dot.style.background = '#4361ee'; dot.style.animation = 'pulse-dot 1s infinite';
          } else if (steps.indexOf(s) < steps.findIndex(x=>x.id===id)) {
            el2.style.color = '#10b981'; el2.style.fontWeight = '500';
            dot.style.background = '#10b981'; dot.style.animation = '';
          }
        });
      }
      const bar = document.getElementById('rb-bar');
      const pctEl = document.getElementById('rb-pct');
      const txt = document.getElementById('rb-status-text');
      if (bar) bar.style.width = pct + '%';
      if (pctEl) pctEl.textContent = pct + '%';
      if (txt) txt.textContent = text;
    }, delay);
  });
}

function hideRebuildOverlay() {
  const el = document.getElementById('rebuild-overlay');
  if (el) el.style.display = 'none';
}

function pollUntilReady(attempts) {
  attempts = attempts || 0;
  if (attempts > 60) { // max 60s
    hideRebuildOverlay();
    alert('Quá thời gian chờ. Vui lòng reload trang.');
    return;
  }
  // Step 4 active after 8s
  if (attempts === 8) {
    const s4 = document.getElementById('rb-step-4');
    if (s4) { s4.style.color='#4361ee'; s4.style.fontWeight='700'; s4.querySelector('span').style.background='#4361ee'; }
  }
  fetch('<%= html_report_survey_path(@survey) %>?check_structure=1', { cache: 'no-store' })
    .then(r => r.json())
    .then(data => {
      if (data.ready) {
        // 100% done
        const bar = document.getElementById('rb-bar');
        const pct = document.getElementById('rb-pct');
        const txt = document.getElementById('rb-status-text');
        const s4  = document.getElementById('rb-s4');
        if (bar) bar.style.width = '100%';
        if (pct) pct.textContent = '100%';
        if (txt) txt.textContent = 'Hoàn thành! Đang tải báo cáo...';
        if (s4)  { s4.style.color='#10b981'; s4.style.fontWeight='500'; s4.querySelector('span').style.background='#10b981'; s4.querySelector('span').style.animation=''; }
        localStorage.removeItem(SK + '_structver');
        setTimeout(() => { window.location.reload(); }, 700);
      } else {
        setTimeout(() => pollUntilReady(attempts + 1), 1000);
      }
    })
    .catch(() => setTimeout(() => pollUntilReady(attempts + 1), 2000));
}

function voxConfirm({ title, message, okText = 'Xác nhận', okColor = '#ef4444', onOk }) {
  let overlay = document.getElementById('vox-confirm-overlay');
  if (!overlay) {
    overlay = document.createElement('div');
    overlay.id = 'vox-confirm-overlay';
    overlay.style.cssText = 'position:fixed;inset:0;z-index:9990;background:rgba(0,0,0,.45);display:flex;align-items:center;justify-content:center;backdrop-filter:blur(3px)';
    overlay.innerHTML = `<div style="background:white;border-radius:16px;padding:28px;max-width:400px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.2);">
      <div id="vc-title" style="font-size:16px;font-weight:800;color:#1a1a2e;margin-bottom:10px"></div>
      <p id="vc-msg" style="font-size:13px;color:#475569;line-height:1.7;margin-bottom:22px;white-space:pre-line"></p>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button id="vc-cancel" style="padding:9px 20px;border:1px solid #e2e8f0;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;background:white;color:#64748b">Huỷ</button>
        <button id="vc-ok" style="padding:9px 20px;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;color:white"></button>
      </div></div>`;
    document.body.appendChild(overlay);
  }
  document.getElementById('vc-title').textContent = title || '';
  document.getElementById('vc-msg').textContent = message;
  document.getElementById('vc-ok').textContent = okText;
  document.getElementById('vc-ok').style.background = okColor;
  const close = () => { overlay.style.display = 'none'; };
  document.getElementById('vc-cancel').onclick = close;
  document.getElementById('vc-ok').onclick = () => { close(); onOk(); };
  overlay.onclick = (e) => { if (e.target === overlay) close(); };
  overlay.style.display = 'flex';
}

