            <%# ── Progress bar ── %>
            <div style="display:flex;height:10px;border-radius:6px;overflow:hidden;gap:2px">
              <div style="width:<%= det_pct %>%;background:#ef4444;min-width:<%= detractors>0 ? 2 : 0 %>px"></div>
              <div style="width:<%= pas_pct %>%;background:#06b6d4;min-width:<%= passives>0 ? 2 : 0 %>px"></div>
              <div style="width:<%= pro_pct %>%;background:#10b981;min-width:<%= promoters>0 ? 2 : 0 %>px"></div>
            </div>
            <%# ── Labels ── %>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-top:10px;gap:8px">
