// ── Rebuild structure ──────────────────────────────────────────
function rebuildStructure() {
  voxConfirm({
    title: '✦ Tạo lại báo cáo',
    message: 'AI sẽ đọc toàn bộ câu hỏi, dữ liệu và tạo cấu trúc báo cáo mới.\nNhãn, tiêu đề sẽ được AI rút gọn thông minh.',
    okText: 'Tạo lại ngay',
    okColor: '#4361ee',
    onOk: () => {
      // Show full-page generating overlay
      showRebuildOverlay();
      localStorage.removeItem(SK);
      localStorage.removeItem(SK + '_sub_edited');
