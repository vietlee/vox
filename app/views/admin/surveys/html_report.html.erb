<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<% if @pdf_preview %>
<meta name="viewport" content="width=1200">
<% else %>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<% end %>
<title>Báo cáo: <%= @survey.title %></title>
<link rel="icon" type="image/svg+xml" href="/icon.svg">
<link rel="icon" type="image/png" href="/icon.png">
<%= csrf_meta_tags %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
// ── Chart helpers — must be defined BEFORE any chart <script> blocks ──
// White background plugin: draw white before every chart render so PDF/print canvas is opaque
const whiteBackgroundPlugin = {
  id: 'whiteBackground',
  beforeDraw(chart) {
    const ctx = chart.canvas.getContext('2d');
    ctx.save();
    ctx.globalCompositeOperation = 'source-over';
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, chart.canvas.width, chart.canvas.height);
    ctx.restore();
  }
};
Chart.register(ChartDataLabels, whiteBackgroundPlugin);
const C=['#4361ee','#7c3aed','#06b6d4','#10b981','#f59e0b','#ef4444','#ec4899','#8b5cf6','#0ea5e9','#14b8a6'];
const barDL  ={anchor:'end',align:'end',offset:2,clip:false,font:{size:11,weight:'700'},color:'#444',formatter:v=>v>0?v:''};
const hbarDL ={anchor:'end',align:'end',offset:4,clip:false,font:{size:11,weight:'700'},color:'#374151',formatter:v=>v>0?v:''};
const pieDL  ={display:ctx=>ctx.dataset.data[ctx.dataIndex]>0,color:'#fff',font:{size:12,weight:'700'},formatter:v=>v};
const barLayout={padding:{top:20}};
const chartReg={};
const _pdfMode = new URLSearchParams(location.search).get('pdf') === '1';
// Disable animation in PDF mode so Grover captures fully-rendered charts
if (_pdfMode) { Chart.defaults.animation = false; Chart.defaults.animations = {}; }
function mkChart(id,cfg){
  const el=document.getElementById(id);
  if(!el){console.warn('mkChart: canvas not found:',id);return null;}
  if(chartReg[id]){chartReg[id].destroy();}
  // Wrap canvas in fixed-height div (canonical Chart.js way to prevent ResizeObserver loop)
  let wrap = el.parentElement?.classList.contains('chart-wrap') ? el.parentElement : null;
  if(!wrap){
    wrap = document.createElement('div');
    wrap.className = 'chart-wrap';
    el.parentNode.insertBefore(wrap, el);
    wrap.appendChild(el);
  }
  const isHBar = cfg.type==='bar' && cfg.options?.indexAxis==='y';
  const isPie = cfg.type==='doughnut'||cfg.type==='pie';
  const itemCount = cfg.data?.labels?.length||0;
  const autoH = isHBar ? Math.max(160, itemCount*38+60) : isPie ? Math.max(260, itemCount*24+80) : 240;
  if(!wrap.style.height) wrap.style.height = autoH+'px';
  if (_pdfMode) { cfg.options = Object.assign({}, cfg.options||{}, {animation:false}); }
  cfg.options = Object.assign({}, cfg.options||{}, {responsive:true, maintainAspectRatio:false});
  const ch=new Chart(el,cfg);
  chartReg[id]=ch;
  return ch;
}
// Signal to Grover when all charts are done (used by waitForFunction)
window._chartsReady = false;
window._markChartsReady = function() {
  // Wait 3 rAFs to ensure all canvas pixels are flushed
  requestAnimationFrame(() => requestAnimationFrame(() => requestAnimationFrame(() => {
    window._chartsReady = true;
  })));
};
</script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,sans-serif;background:#f0f2f5;color:#1a1a2e;font-size:14px;transition:padding-right .3s cubic-bezier(.4,0,.2,1)}
body.pdf-preview-open{padding-right:540px}

/* ── Header ── */
.header{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);color:white;padding:36px 48px;position:relative}
.header h1{font-size:22px;font-weight:700;margin-bottom:6px;line-height:1.35}
.header p{opacity:.6;font-size:13px}
/* Editable header fields */
.hdr-editable{position:relative;display:inline-block;max-width:100%;cursor:pointer;border-radius:6px;transition:background .15s}
.hdr-editable.editing{display:block}
.hdr-editable:hover{background:rgba(255,255,255,.08)}
.hdr-editable:hover .hdr-edit-icon{opacity:1}
.hdr-edit-icon{position:absolute;top:50%;right:-32px;transform:translateY(-50%);opacity:.7;display:inline-flex;align-items:center;justify-content:center;transition:opacity .15s;cursor:pointer;padding:4px;line-height:0}
.hdr-edit-icon:hover{opacity:1}
.hdr-input{display:none;background:transparent!important;border:none!important;border-bottom:2px solid rgba(255,255,255,.55)!important;border-radius:0!important;color:white;outline:none!important;box-shadow:none!important;-webkit-appearance:none;font-family:inherit;width:100%;max-width:min(760px,calc(100vw - 140px));box-sizing:border-box}
.hdr-editable.editing{background:transparent!important}
.hdr-input.title-input{font-size:22px;font-weight:700;line-height:1.35;padding:4px 10px}
.hdr-input.sub-input{font-size:13px;padding:3px 8px;opacity:.9}
.hdr-editable.editing .hdr-text{display:none}
.hdr-editable.editing .hdr-edit-icon{display:none}
.hdr-editable.editing .hdr-input{display:block}
@media print{.hdr-edit-icon{display:none!important}}
.container{max-width:1200px;margin:0 auto;padding:28px 24px 120px}

/* ── KPI ── */
.kpi-grid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px;margin-bottom:4px}
.kpi{grid-column:span 2}
.kpi{background:white;border-radius:12px;padding:18px 14px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.07);border-top:4px solid;position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center}
.kpi-value{font-size:34px;font-weight:800;line-height:1;margin-bottom:5px}
.kpi-label{font-size:11px;color:#666;font-weight:500;text-transform:uppercase;letter-spacing:.5px}
/* KPI toolbar (edit) */
.kpi-toolbar{position:absolute;top:8px;right:8px;display:flex;gap:4px;opacity:0;transition:opacity .2s;z-index:60}
.kpi:hover .kpi-toolbar{opacity:1}
.kpi-drag-handle{cursor:grab;color:#818cf8;line-height:0;padding:5px;background:#eef2ff;border-radius:7px;border:none;box-shadow:0 1px 4px rgba(99,102,241,.15);font-size:14px;user-select:none}
.kpi-drag-handle:hover{background:#e0e7ff}
/* Section title editable */
.section-title-edit{outline:none;border:none;border-bottom:2px solid transparent;background:transparent;cursor:default;border-radius:3px;padding:1px 4px;min-width:40px;flex:1;font-size:inherit;font-weight:inherit;color:inherit;font-family:inherit;width:100%}
.section-title-edit:hover{background:#f0f4ff;cursor:text;border-bottom-color:#c7d2fe}
.section-title-edit:focus{border-bottom:2px dashed #4361ee;background:#eef2ff;outline:none;cursor:text}
.section-edit-btn{opacity:0;border:none;background:transparent;cursor:pointer;font-size:13px;padding:2px 6px;border-radius:5px;color:#94a3b8;transition:opacity .15s,background .15s;line-height:1;flex-shrink:0}
.section-header:hover .section-edit-btn{opacity:1}
.section-edit-btn:hover{background:#eef2ff;color:#4361ee}
.kpi-tool-btn{cursor:pointer;color:#818cf8;line-height:0;padding:5px;background:#eef2ff;border-radius:7px;border:none;box-shadow:0 1px 4px rgba(99,102,241,.15);transition:background .15s,transform .15s}
.kpi-tool-btn:hover{background:#e0e7ff;color:#4361ee;transform:scale(1.08)}
/* KPI drag-resize handles (4 directions) */
.kpi-rh,.kpi-lh{position:absolute;top:0;width:12px;height:100%;cursor:ew-resize;z-index:50;opacity:0;transition:opacity .2s;display:flex;align-items:center;justify-content:center}
.kpi-rh{right:0}.kpi-lh{left:0}
.kpi-rb,.kpi-rt{position:absolute;left:0;width:100%;height:10px;cursor:ns-resize;z-index:50;opacity:0;transition:opacity .2s;display:flex;align-items:center;justify-content:center}
.kpi-rb{bottom:0}.kpi-rt{top:0;pointer-events:none}.kpi:hover .kpi-rt{pointer-events:auto}
.kpi:hover .kpi-rh,.kpi:hover .kpi-lh,.kpi:hover .kpi-rb,.kpi:hover .kpi-rt{opacity:1}
.kpi-rh::after,.kpi-lh::after{content:'';display:block;width:4px;height:30px;background:#6366f1;border-radius:2px;opacity:.5;transition:opacity .15s,width .15s}
.kpi-rh:hover::after,.kpi-lh:hover::after,.kpi-rh.dragging::after,.kpi-lh.dragging::after{opacity:1;width:6px}
.kpi-rb::after,.kpi-rt::after{content:'';display:block;width:30px;height:4px;background:#6366f1;border-radius:2px;opacity:.5;transition:opacity .15s,height .15s}
.kpi-rb:hover::after,.kpi-rt:hover::after,.kpi-rb.dragging::after,.kpi-rt.dragging::after{opacity:1;height:6px}
.kpi-rh.dragging,.kpi-lh.dragging,.kpi-rb.dragging,.kpi-rt.dragging{background:rgba(99,102,241,.12)}
/* KPI inline editing */
.kpi-edit-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center;gap:4px;width:100%}
.kpi-editable{cursor:text;border-radius:4px;transition:background .15s;padding:2px 4px;min-width:20px}
.kpi-editable:hover{background:rgba(67,97,238,.07)}
.kpi-editable:focus{outline:1px solid rgba(67,97,238,.3);background:#f5f7ff}
/* Floating edit icon for section card text */
.float-edit-icon{position:fixed;display:none;align-items:center;justify-content:center;width:auto;height:auto;background:#eef2ff;color:#818cf8;border:none;border-radius:7px;cursor:pointer;z-index:500;box-shadow:0 1px 4px rgba(99,102,241,.15);padding:5px;line-height:0;pointer-events:auto;transition:background .15s,transform .15s}
.float-edit-icon:hover{background:#e0e7ff;color:#4361ee;transform:scale(1.08)}
@media print{.kpi-toolbar,.kpi-rh,.float-edit-icon{display:none!important}.kpi-edit-wrap{display:block}}

/* ── Sections ── */
.report-section{position:relative;margin-top:28px}
.report-section.hidden-section{display:none}
.section-header{display:flex;align-items:center;gap:8px;margin-bottom:14px}
.section-title{font-size:16px;font-weight:700;color:#1a1a2e;display:flex;align-items:center;gap:10px;flex:1}
.section-title::before{content:'';display:block;width:4px;height:20px;background:#4361ee;border-radius:2px;flex-shrink:0}
.section-controls{display:none;align-items:center;gap:4px}
.edit-mode .section-controls{display:flex}
.btn-sec-drag{cursor:grab;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:6px;padding:4px 8px;font-size:14px;color:#94a3b8;line-height:1;user-select:none}
.btn-sec-hide{background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:4px 10px;font-size:11px;font-weight:600;color:#ef4444;cursor:pointer}
.sortable-ghost{opacity:.3;background:#e0e7ff;border-radius:10px}
.sortable-chosen{box-shadow:0 8px 24px rgba(67,97,238,.25)}

/* ── Grids (12-col base) ── */
.grid-2,.grid-3{display:grid;grid-template-columns:repeat(12,1fr);gap:20px;margin-bottom:20px}
.grid-2>.cw{grid-column:span 6}
.grid-3>.cw{grid-column:span 4}
<% if @public_view %>@media(max-width:900px){.grid-2,.grid-3{grid-template-columns:1fr}.grid-2>.cw,.grid-3>.cw{grid-column:span 1}}<% end %>

/* ── Card wrapper ── */
.cw{position:relative;display:flex;flex-direction:column;align-self:start}
.cw>.card{flex:1}
.cw.hidden-section{display:none}
.kpi.hidden-section{display:none}
.cw.cd-source{opacity:.25;pointer-events:none}

/* ── Custom drag ghost ── */
.cd-ghost{position:fixed;z-index:1000;pointer-events:none;opacity:.85;border-radius:12px;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden;background:white}

/* ── Drop zones ── */
.cd-zone{border:2px dashed #93c5fd;border-radius:12px;background:rgba(239,246,255,.7);min-height:80px;transition:background .15s,border-color .15s,transform .15s;box-sizing:border-box}
.cd-zone-over{border-color:#4361ee;background:#dbeafe;transform:scale(1.02);box-shadow:0 0 0 3px rgba(67,97,238,.15)}

/* ── Placeholder while dragging ── */
.cd-placeholder{border:2px dashed #e2e8f0;border-radius:12px;background:#fafafa;min-height:80px}

/* ── Gear icon (always visible, per card) ── */
.h3-spacer{flex:1}
.cw-gear{flex-shrink:0;margin-left:8px;width:32px;height:32px;border-radius:50%;border:none;background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;color:#6366f1;transition:background .15s;box-shadow:none;padding:0;line-height:1}
.cw-gear:hover{background:rgba(99,102,241,.1)}
.cw-active .cw-gear,.cw-resize-mode .cw-gear,.cw-text-mode .cw-gear,.cw-move-mode .cw-gear{background:#4361ee;color:white;box-shadow:none}

/* Card controls — floating dropdown below gear */
.card-toolbar{display:none;flex-direction:column;gap:3px;position:absolute;top:56px;right:14px;z-index:50;background:white;border:1px solid #e2e8f0;border-radius:12px;padding:6px;box-shadow:0 8px 24px rgba(0,0,0,.13);min-width:185px}
.cw-active .card-toolbar{display:flex}
.ct-mode-btn{display:flex;align-items:center;gap:8px;background:transparent;border:none;border-radius:7px;padding:8px 10px;font-size:12px;font-weight:500;cursor:pointer;color:#374151;text-align:left;width:100%;transition:background .1s}
.ct-mode-btn:hover{background:#f1f5f9}
.ct-mode-btn .icon{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.ct-mode-btn.active{background:#eef2ff;color:#4361ee;font-weight:600}
.ct-mode-btn.active .icon{color:#4361ee}
.ct-mode-btn.danger{color:#ef4444}
.ct-mode-btn.danger:hover{background:#fef2f2}
/* divider */
.ct-divider{height:1px;background:#f0f2f5;margin:3px 0}
/* Active card: subtle ring only */
.cw-active .card{box-shadow:0 0 0 2px #c7d2fe,0 2px 8px rgba(0,0,0,.07)}
/* Resize mode: dashed outline */
.cw-resize-mode .card{box-shadow:0 2px 8px rgba(0,0,0,.07);outline:2px dashed #a5b4fc;outline-offset:-2px}
/* ── Mode bar: inline in card header, same row as h3 ── */
.cw-mode-bar{display:none;align-items:center;gap:8px;white-space:nowrap;flex-shrink:0}
.cw-mode-bar .mode-label{display:flex;align-items:center;gap:5px;border-radius:20px;padding:5px 12px;font-size:12px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.12)}
.cw-mode-bar .btn-done{background:white;border:1px solid #e2e8f0;border-radius:20px;padding:5px 13px;font-size:12px;font-weight:700;cursor:pointer;line-height:1.4;box-shadow:0 2px 8px rgba(0,0,0,.1);color:#374151}
.cw-mode-bar .btn-done:hover{background:#f9fafb;border-color:#6366f1;color:#4361ee}
.span-controls{display:none;align-items:center;gap:4px;background:#f1f5f9;border-radius:20px;padding:3px 8px}
.cw-resize-mode .span-controls{display:flex}
.span-btn{width:26px;height:26px;border-radius:50%;border:none;background:#6366f1;color:white;font-size:15px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;padding:0}
.span-btn:hover{background:#4361ee}
.span-label{font-size:11px;font-weight:700;color:#374151;min-width:32px;text-align:center}
/* text mode */
.cw-text-mode  .cw-mode-bar{display:flex}
.cw-text-mode  .mode-label{background:#4361ee;color:white}
/* resize mode */
.cw-resize-mode .cw-mode-bar{display:flex}
.cw-resize-mode .mode-label{background:#059669;color:white}
/* move mode */
.cw-move-mode  .cw-mode-bar{display:flex}
.cw-move-mode  .mode-label{background:#6366f1;color:white;cursor:grab}
.cw-move-mode  .mode-label:active{cursor:grabbing}
/* Resize mode: show handles */
.cw-resize-mode .rh-right{display:flex}
.cw-resize-mode .rh-bottom{display:flex}
.cw-resize-mode .rh-corner{display:flex}
.cw-resize-mode.is-resizing .card{outline-color:#6366f1!important}

/* ── Resize handles — only when .cw-resize-mode ── */
.rh-right{display:none;position:absolute;top:0;right:0;width:16px;height:100%;cursor:ew-resize;z-index:200;align-items:center;justify-content:center;background:rgba(99,102,241,.08);border-radius:0 8px 8px 0;}
.rh-right-bar{width:4px;height:32px;background:#6366f1;border-radius:3px;opacity:.8}
.rh-right:hover{background:rgba(99,102,241,.18)}
.rh-right:hover .rh-right-bar,.rh-right.dragging .rh-right-bar{opacity:1;width:5px}
.rh-bottom{display:none;position:absolute;bottom:0;left:0;width:100%;height:14px;cursor:ns-resize;z-index:200;align-items:center;justify-content:center;background:rgba(99,102,241,.08);border-radius:0 0 8px 8px;}
.rh-bottom-bar{height:4px;width:32px;background:#6366f1;border-radius:3px;opacity:.8}
.rh-bottom:hover{background:rgba(99,102,241,.18)}
.rh-bottom:hover .rh-bottom-bar,.rh-bottom.dragging .rh-bottom-bar{opacity:1;height:5px}
.rh-corner{display:none;position:absolute;bottom:0;right:0;width:32px;height:32px;cursor:nwse-resize;z-index:201;align-items:flex-end;justify-content:flex-end;padding:7px;background:rgba(99,102,241,.12);border-radius:0 0 8px 0;}
.rh-corner::after{content:'';display:block;width:13px;height:13px;border-right:3px solid #6366f1;border-bottom:3px solid #6366f1;border-radius:0 0 4px 0;opacity:.9}
.rh-corner:hover{background:rgba(99,102,241,.25)}
.rh-corner:hover::after,.rh-corner.dragging::after{opacity:1}
/* tooltip */
.resize-tip{display:none;position:fixed;background:#1a1a2e;color:#fff;font-size:11px;font-weight:700;padding:4px 9px;border-radius:6px;white-space:nowrap;pointer-events:none;z-index:999;transform:translate(12px,-50%)}
.resize-tip.visible{display:block}
/* align guide lines */
.align-guide{position:fixed;left:0;width:100%;height:0;border-top:2px dashed #a5b4fc;pointer-events:none;z-index:998;display:none}
.align-guide.visible{display:block}

/* ── AI Insights ── */
.insights-col{background:white;border-radius:12px;padding:20px 22px;box-shadow:0 2px 8px rgba(0,0,0,.07);align-self:start}
.insights-col-header{font-size:13px;font-weight:700;color:#1a1a2e;margin-bottom:14px;padding-bottom:10px;border-bottom:2px solid #f0f2f5}
.insight-item{border-radius:0 8px 8px 0;padding:10px 14px;margin-bottom:10px;font-size:12px;line-height:1.65}
.insight-stat{background:#f0f4ff;border-left:4px solid #4361ee;color:#374151}
.insight-plus{color:#4361ee;font-weight:700}
.insight-rec{border-left:4px solid #7c3aed;background:#faf5ff}
.insight-rec-title{font-size:12px;font-weight:700;color:#7c3aed;margin-bottom:5px;line-height:1.4}
.insight-rec-detail{font-size:11px;color:#6b7280;line-height:1.6}


/* ── Card ── */
.card{background:white;border-radius:12px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,.07)}
.card h3{font-size:13px;font-weight:700;margin-bottom:16px;color:#1a1a2e;border-bottom:2px solid #f0f2f5;padding-bottom:10px;display:flex;align-items:center;gap:10px}
canvas{height:250px;min-height:80px;max-height:none}
.chart-wrap{position:relative;width:100%;background:white;overflow:hidden}
.chart-wrap canvas{position:absolute;top:0;left:0;width:100%!important;height:100%!important}

/* Editable text — only in text mode */
.cw-text-mode [data-editable]{outline:none;border-bottom:2px dashed #a5b4fc;cursor:text;min-width:20px;border-radius:3px;padding:1px 4px;background:#f8f9ff;transition:background .1s}
.cw-text-mode [data-editable]:focus{background:#eef2ff;border-bottom-color:#4361ee;outline:none}
.cw-text-mode [data-editable]:empty::before{content:'(trống)';color:#aaa;font-style:italic}

/* Bar items */
.bar-list{display:flex;flex-direction:column;justify-content:space-between}
.bar-item{display:flex;align-items:center;margin-bottom:9px;font-size:12px}
.bar-label{flex-shrink:0;color:#444;line-height:1.3;padding-right:8px;word-break:break-word;white-space:normal}
.bar-label.w160{width:160px}.bar-label.w200{width:200px}.bar-label.w220{width:220px}
.bar-track{flex:1;background:#e8eaf0;border-radius:4px;height:18px;overflow:hidden;margin-right:8px}
.bar-fill{height:100%;border-radius:4px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;color:white;font-size:11px;font-weight:700;min-width:18px}
.bar-pct-out{font-size:11px;font-weight:700;white-space:nowrap;width:44px;text-align:right;flex-shrink:0}
.bar-count{width:26px;text-align:right;color:#888;font-weight:600;font-size:12px;margin-left:8px}
.bar-header{margin-bottom:4px!important}.bar-header .bar-pct-out,.bar-header .bar-count{font-size:10px;text-transform:uppercase;letter-spacing:.05em}

/* Rating rows */
.rating-row{display:flex;align-items:center;margin-bottom:11px}
.rating-label{width:220px;font-size:12px;color:#555;line-height:1.3;flex-shrink:0}
.rating-bar{flex:1;background:#e8eaf0;height:22px;border-radius:6px;overflow:hidden;margin-right:10px}
.rating-fill{height:100%;border-radius:6px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;color:white;font-weight:700;font-size:11px}
.rating-score{width:36px;font-size:14px;font-weight:800;color:#1a1a2e;text-align:right}

/* Insight / Quote */
.insight-box{background:#f8f9ff;border-left:4px solid #4361ee;border-radius:0 8px 8px 0;padding:12px 14px;margin-bottom:10px;font-size:12px;line-height:1.65}
.insight-box strong{color:#4361ee}
.quote-card{background:#fffbf0;border:1px solid #ffe082;border-radius:10px;padding:12px 14px;margin-bottom:9px;font-size:12px;line-height:1.65;color:#555}
.quote-card .author{font-weight:700;color:#e65100;font-size:11px;margin-bottom:3px}

/* ── Restore bar ── */
.restore-bar{display:none;flex-wrap:wrap;gap:6px;padding:10px 14px;background:#fef3c7;border:1px solid #fcd34d;border-radius:10px;margin:8px 0;align-items:center}
.restore-bar.has-hidden{display:flex}
.restore-bar>.restore-label{font-size:11px;color:#92400e;font-weight:700;align-self:center}
.btn-restore{background:white;border:1px solid #fcd34d;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;color:#92400e;cursor:pointer}
.btn-restore:hover{background:#fffbeb}
.btn-restore-all{background:#f59e0b;border:none;border-radius:20px;padding:3px 12px;font-size:11px;font-weight:700;color:white;cursor:pointer;margin-left:4px}
.btn-restore-all:hover{background:#d97706}

/* ── Action bar ── */
.action-bar{position:fixed;bottom:24px;right:24px;display:flex;gap:8px;z-index:1500}
.action-bar button{display:flex;align-items:center;gap:6px;border:none;border-radius:50px;padding:10px 20px;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,.15);transition:all .15s}
.action-bar button:hover{opacity:.88}
.btn-share{background:linear-gradient(135deg,#4361ee,#7c3aed);color:#fff}
.btn-print{background:#fff;color:#374151}
.btn-pdf{background:#374151;color:#fff}
.btn-edit{background:#4361ee;color:#fff}
/* ── PDF Preview side tab + Drawer ── */
.pdf-preview-tab{position:fixed;top:50%;right:0;transform:translateY(-50%);z-index:1400;display:flex;flex-direction:column;align-items:center;background:#0f766e;color:white;border-radius:10px 0 0 10px;padding:14px 8px;gap:6px;cursor:pointer;box-shadow:-4px 0 16px rgba(0,0,0,.25);transition:background .15s,right .3s cubic-bezier(.4,0,.2,1);user-select:none;border:none}
.pdf-preview-tab:hover{background:#0d9488}
.pdf-preview-tab.open{right:540px}
.pdf-preview-tab-icon{font-size:18px;line-height:1}
.pdf-preview-tab-text{writing-mode:vertical-rl;text-orientation:mixed;transform:rotate(180deg);font-size:11px;font-weight:700;letter-spacing:.08em;white-space:nowrap}
.pdf-preview-tab-badge{font-size:9px;font-weight:700;background:rgba(255,255,255,.25);border-radius:20px;padding:2px 5px;letter-spacing:.05em}
.pdf-drawer{position:fixed;top:0;right:-560px;width:540px;height:100vh;background:#1e293b;z-index:1399;transition:right .3s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;box-shadow:-8px 0 40px rgba(0,0,0,.5)}
.pdf-drawer.open{right:0}
.pdf-drawer-hdr{padding:13px 16px;background:#0f172a;display:flex;align-items:center;justify-content:space-between;color:#f1f5f9;font-weight:600;font-size:13px;flex-shrink:0;border-bottom:1px solid #334155}
.pdf-drawer-hdr-left{display:flex;align-items:center;gap:8px}
.pdf-drawer-badge{background:#0d9488;color:white;font-size:10px;font-weight:700;padding:2px 7px;border-radius:20px;letter-spacing:.05em}
.pdf-drawer-close{background:#334155;border:none;color:#94a3b8;cursor:pointer;border-radius:6px;padding:5px 10px;font-size:13px;line-height:1;transition:all .15s}
.pdf-drawer-close:hover{color:white;background:#475569}
.pdf-drawer-toolbar{padding:8px 16px;background:#1e293b;display:flex;align-items:center;gap:8px;border-bottom:1px solid #334155;flex-shrink:0}
.pdf-drawer-hint{font-size:11px;color:#64748b;flex:1}
.pdf-drawer-body{flex:1;overflow:hidden;background:#525659;padding:0;display:flex;flex-direction:column}
.pdf-frame-wrap{background:#374151;border-radius:2px;overflow:hidden;flex-shrink:0;position:relative}
#pdfPreviewFrame{width:1200px;border:none;display:block;transform-origin:0 0}
.pdf-preview-refreshing{position:absolute;inset:0;background:rgba(55,65,81,.6);display:flex;align-items:center;justify-content:center;color:white;font-size:12px;font-weight:600;opacity:0;transition:opacity .2s;pointer-events:none}
.pdf-preview-refreshing.show{opacity:1}
.pdf-size-btn{background:#1e3a5f;color:#93c5fd;border:1px solid #2563eb;border-radius:5px;padding:3px 9px;font-size:11px;font-weight:700;cursor:pointer;transition:all .15s}
.pdf-size-btn:hover{background:#1d4ed8;color:white}
.pdf-size-btn.active{background:#2563eb;color:white}
#pdfFullscreenOverlay{display:none}
#pdfFullscreenOverlay.show{display:flex}
.pdf-page-wrap{background:white;box-shadow:0 4px 24px rgba(0,0,0,.5);flex-shrink:0;overflow:hidden;position:relative}
.pdf-page-iframe{border:none;display:block;transform-origin:0 0}
.page-break-sep{position:absolute;left:0;right:0;background:#374151;z-index:20;pointer-events:none;display:flex;align-items:center;justify-content:center}
.page-break-sep-lbl{color:#9ca3af;font-size:10px;font-weight:600;white-space:nowrap;letter-spacing:.5px}
/* Share modal */
#shareModal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:10000;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
#shareModal.open{display:flex}
.share-box{background:white;border-radius:20px;padding:28px 28px 24px;max-width:420px;width:90%;box-shadow:0 24px 60px rgba(0,0,0,.2)}
.share-box h3{font-size:17px;font-weight:700;color:#1e293b;margin-bottom:4px}
.share-box p{font-size:13px;color:#64748b;margin-bottom:20px}
.share-qr{display:flex;justify-content:center;margin-bottom:20px}
.share-qr canvas{border-radius:12px;box-shadow:0 4px 16px rgba(0,0,0,.1)}
.share-link-row{display:flex;gap:8px;margin-bottom:16px}
.share-link-input{flex:1;border:1px solid #e2e8f0;border-radius:10px;padding:9px 12px;font-size:12px;color:#374151;background:#f8fafc;outline:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.share-actions{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:16px}
.share-btn{border:1px solid #e2e8f0;background:white;border-radius:10px;padding:10px 8px;font-size:12px;font-weight:600;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:5px;color:#374151;transition:all .15s}
.share-btn:hover{background:#f1f5f9;border-color:#cbd5e1}
.share-btn .icon{font-size:20px}
.share-footer{display:flex;justify-content:space-between;align-items:center}
.share-revoke{font-size:12px;color:#ef4444;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:7px 14px;cursor:pointer;font-weight:600;display:flex;align-items:center;gap:5px;transition:all .15s}
.share-revoke:hover{background:#fee2e2;border-color:#fca5a5}
/* Copy tick */
.share-btn.copied{background:#f0fdf4;border-color:#86efac;color:#16a34a}
.share-btn.copied .icon{display:none}
.share-btn.copied .copy-tick{display:block}
.copy-tick{display:none;font-size:20px}
.share-close{background:#4361ee;color:white;border:none;border-radius:10px;padding:9px 20px;font-size:13px;font-weight:600;cursor:pointer}
.btn-edit.active{background:#10b981}
.btn-rebuild{background:rgba(124,58,237,.12);color:#7c3aed;border:1px solid rgba(124,58,237,.25)!important}
.btn-rebuild:hover{background:rgba(124,58,237,.2)!important}
/* Lang switcher — in header top-right */
.header-lang-switcher{position:absolute;top:20px;right:24px;display:flex;background:rgba(255,255,255,.12);border-radius:50px;padding:2px;gap:2px;border:1px solid rgba(255,255,255,.18);z-index:10}
.lang-btn{background:transparent;border:none;border-radius:50px;padding:5px 14px;font-size:12px;font-weight:700;cursor:pointer;color:rgba(255,255,255,.65);transition:all .15s;line-height:1}
.lang-btn.active{background:white;color:#374151;box-shadow:0 2px 6px rgba(0,0,0,.15)}
.lang-btn:not(.active):hover{color:white;background:rgba(255,255,255,.15)}
@media print{.header-lang-switcher{display:none!important}}
/* PDF loading overlay */
#pdf-loading{display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:16px;color:white;font-size:15px;font-weight:600;backdrop-filter:blur(3px)}
#pdf-loading.show{display:flex}
.pdf-spinner{width:44px;height:44px;border:4px solid rgba(255,255,255,.3);border-top-color:white;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse-dot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
@keyframes vox-pulse{0%,100%{opacity:1;transform:scale(1);box-shadow:0 4px 20px rgba(67,97,238,.3)}50%{opacity:.75;transform:scale(.93);box-shadow:0 2px 10px rgba(67,97,238,.15)}}
@keyframes rb-orbit{to{transform:rotate(360deg)}}

/* ── Confirm modal ── */
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:500;align-items:center;justify-content:center}
.modal-overlay.open{display:flex}
.modal-box{background:white;border-radius:16px;padding:28px 24px;max-width:480px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.modal-box h4{font-size:16px;font-weight:700;margin-bottom:8px;color:#1a1a2e}
.modal-box p{font-size:13px;color:#666;margin-bottom:20px;line-height:1.6}
.modal-actions{display:flex;gap:10px;justify-content:flex-end}
.modal-actions button{padding:8px 20px;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;border:none}
.btn-cancel{background:#f1f5f9;color:#374151}
.btn-confirm-del{background:#ef4444;color:white}

/* ── Chart edit modal ── */
.chart-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;align-items:center;justify-content:center;padding:20px}
.chart-modal-overlay.open{display:flex}
.chart-modal{background:white;border-radius:16px;width:100%;max-width:600px;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.25)}
.chart-modal-header{padding:20px 24px 16px;border-bottom:1px solid #f0f2f5;display:flex;align-items:center;justify-content:space-between}
.chart-modal-header h4{font-size:15px;font-weight:700;color:#1a1a2e}
.chart-modal-close{background:none;border:none;font-size:20px;cursor:pointer;color:#94a3b8;line-height:1;padding:0 4px}
.chart-modal-body{padding:20px 24px;overflow-y:auto;flex:1}
.data-table{width:100%;border-collapse:collapse;font-size:13px}
.data-table th{text-align:left;padding:6px 8px;font-size:11px;font-weight:700;text-transform:uppercase;color:#94a3b8;border-bottom:2px solid #f0f2f5}
.data-table td{padding:6px 8px;border-bottom:1px solid #f9fafb}
.data-table input{width:100%;border:1px solid #e2e8f0;border-radius:6px;padding:5px 8px;font-size:13px;color:#1a1a2e}
.data-table input:focus{outline:none;border-color:#6366f1;background:#fafafe}
.data-table .del-row{background:none;border:none;color:#ef4444;cursor:pointer;font-size:16px;padding:0 4px}
.chart-modal-footer{padding:16px 24px;border-top:1px solid #f0f2f5;display:flex;gap:8px;justify-content:space-between}
.btn-add-row{background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:7px 14px;font-size:12px;font-weight:600;cursor:pointer;color:#374151}
.btn-add-row:hover{background:#f1f5f9}
.btn-apply{background:#4361ee;color:white;border:none;border-radius:8px;padding:8px 20px;font-size:13px;font-weight:600;cursor:pointer}
.btn-apply:hover{background:#3451d1}

footer{text-align:center;padding:20px;color:#bbb;font-size:11px;break-before:avoid;page-break-before:avoid}

/* ── PDF mode (Grover ?pdf=1) ── */
<% if params[:pdf] == "1" %>
body.pdf-mode .action-bar,body.pdf-mode .header-lang-switcher,
body.pdf-mode .cw-gear,body.pdf-mode .card-toolbar,
body.pdf-mode .cw-mode-bar,body.pdf-mode .restore-bar,body.pdf-mode .section-controls,
body.pdf-mode .rh-right,body.pdf-mode .rh-bottom,body.pdf-mode .rh-corner,
body.pdf-mode #shareModal,body.pdf-mode #pdf-loading,
body.pdf-mode .pdf-preview-tab,body.pdf-mode .pdf-drawer,body.pdf-mode #pdfFullscreenOverlay{display:none!important}
body.pdf-mode{background:white!important}
body.pdf-mode .card{box-shadow:none!important;border:1px solid #e2e8f0!important}
body.pdf-mode *{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility}
<% end %>
/* ── Public view mode ── */
<% if @public_view %>
.cw-gear,.card-toolbar,.cw-mode-bar,.restore-bar,.section-controls,
.rh-right,.rh-bottom,.rh-corner,.btn-sec-drag,.btn-sec-hide,
#shareModal,#deleteModal,#chartModal,.hdr-edit-icon,
.hdr-editable{pointer-events:none;cursor:default}
.cw-gear,.card-toolbar,.cw-mode-bar,.restore-bar,.section-controls,
.rh-right,.rh-bottom,.rh-corner,.btn-sec-drag,.btn-sec-hide,.section-edit-btn,
#shareModal,#deleteModal,#chartModal,.hdr-edit-icon{display:none!important}
.hdr-editable{cursor:default!important}
<% end %>

/* ── Print / PDF ── */
@media print{
  @page{size:A4 landscape;margin:10mm 12mm}

  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}

  /* Hide all UI chrome */
  .action-bar,.section-controls,.card-toolbar,.restore-bar,
  .cw-gear,.cw-mode-bar,.rh-right,.rh-bottom,.rh-corner,
  .modal-overlay,.btn-sec-drag,.section-edit-btn,#pdf-loading,footer,
  .hdr-edit-icon,#shareModal,#vox-confirm-overlay,
  .pdf-preview-tab,.pdf-drawer,#pdfFullscreenOverlay{display:none!important}

  html,body{height:auto!important;overflow:visible!important;background:white!important;font-size:12px}
  /* Remove any trailing padding/margin that creates blank last page */
  body>*:last-child{margin-bottom:0!important;padding-bottom:0!important}
  .container{padding-bottom:0!important;max-width:100%!important}
  .report-body{max-width:100%!important;padding:0!important}

  /* Header */
  .header{border-radius:0!important;margin-bottom:8mm}

  /* KPI: keep on one line, override grid positioning */
  .kpi-grid{display:flex!important;flex-wrap:nowrap!important;gap:8px!important;break-inside:avoid;page-break-inside:avoid}
  .kpi{flex:1!important;min-width:0!important;grid-column:unset!important;break-inside:avoid;page-break-inside:avoid}

  /* Sections: ALLOW breaking inside (prevents forced blank pages from oversized sections) */
  .report-section{break-inside:auto;page-break-inside:auto;margin-bottom:6mm}
  .section-header{break-after:avoid;page-break-after:avoid}

  /* Grids: allow breaking across pages */
  .grid-2,.grid-3{break-inside:auto;page-break-inside:auto;display:grid!important}
  .cw.hidden-section{display:none!important}
  /* Cards & canvases: never split mid-element */
  .cw{break-inside:avoid;page-break-inside:avoid}
  .card{box-shadow:none!important;border:1px solid #e2e8f0!important;break-inside:avoid;page-break-inside:avoid;border-radius:8px!important;background:white!important}
  canvas{break-inside:avoid;page-break-inside:avoid;max-width:100%!important;background:white!important}
.insights-col{box-shadow:none!important;border:1px solid #e2e8f0!important;break-inside:avoid;page-break-inside:avoid}
  .insight-item{break-inside:avoid;page-break-inside:avoid}
  #ai-insights-section{break-before:auto;page-break-before:auto}
  .section-title-edit{border-bottom-color:transparent!important;background:transparent!important;pointer-events:none}
}
<% if @pdf_preview %>
/* PDF Preview: exact copy of @media print to simulate Grover emulate_media:print */
*{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
.action-bar,.section-controls,.card-toolbar,.restore-bar,
.cw-gear,.cw-mode-bar,.rh-right,.rh-bottom,.rh-corner,
.modal-overlay,.btn-sec-drag,.section-edit-btn,#pdf-loading,footer,
.hdr-edit-icon,#shareModal,#vox-confirm-overlay,
.header-lang-switcher,
.pdf-preview-tab,.pdf-drawer,#pdfFullscreenOverlay{display:none!important}
html,body{height:auto!important;overflow:visible!important;background:white!important;font-size:12px}
body>*:last-child{margin-bottom:0!important;padding-bottom:0!important}
.container{padding-bottom:0!important;max-width:100%!important}
.report-body{max-width:100%!important;padding:0!important}
.header{border-radius:0!important;margin-bottom:8mm}
.kpi-grid{display:flex!important;flex-wrap:nowrap!important;gap:8px!important}
.kpi{flex:1!important;min-width:0!important;grid-column:unset!important}
.report-section{break-inside:auto;page-break-inside:auto;margin-bottom:6mm}
.section-header{break-after:avoid;page-break-after:avoid}
.grid-2,.grid-3{break-inside:auto;page-break-inside:auto;display:grid!important}
.cw.hidden-section{display:none!important}
.card{box-shadow:none!important;border:1px solid #e2e8f0!important;border-radius:8px!important;background:white!important}
.insights-col{box-shadow:none!important;border:1px solid #e2e8f0!important;background:white!important}
canvas{background:white!important}
.section-title-edit{border-bottom-color:transparent!important;background:transparent!important;pointer-events:none}
<% end %>
</style>
</head>
<body<% if @pdf_preview %> class="pdf-mode pdf-preview-body"<% end %>>

<%# ── Delete confirm modal ── %>
<div class="modal-overlay" id="deleteModal">
  <div class="modal-box">
    <h4>Xoá block này?</h4>
    <p>Block sẽ bị ẩn khỏi báo cáo. Bạn có thể khôi phục từ thanh phía trên.</p>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeDeleteModal()">Huỷ</button>
      <button class="btn-confirm-del" onclick="confirmDelete()">Xoá</button>
    </div>
  </div>
</div>

<%# ── Chart edit modal ── %>
<div class="chart-modal-overlay" id="chartModal">
  <div class="chart-modal">
    <div class="chart-modal-header">
      <h4 id="chartModalTitle">Chỉnh sửa dữ liệu</h4>
      <button class="chart-modal-close" onclick="closeChartModal()">×</button>
    </div>
    <div class="chart-modal-body">
      <table class="data-table" id="chartDataTable">
        <thead><tr><th>Nhãn</th><th id="chartModalDataHeader">Giá trị</th><th></th></tr></thead>
        <tbody id="chartDataBody"></tbody>
      </table>
    </div>
    <div class="chart-modal-footer">
      <button class="btn-add-row" onclick="addDataRow()">+ Thêm hàng</button>
      <button class="btn-apply" onclick="applyChartEdit()">Cập nhật</button>
    </div>
  </div>
</div>

<%# ── Action bar ── %>
<div class="action-bar" id="actionBar">
  <% unless @public_view %>
    <button class="btn-share" onclick="openShareModal()">🔗 <span data-i18n="share">Chia sẻ</span></button>
  <% end %>
  <button class="btn-print" onclick="window.print()">🖨 <span data-i18n="print">In</span></button>
  <button class="btn-pdf" onclick="downloadPdf()">⬇ <span data-i18n="download_pdf">Tải PDF</span></button>
  <% unless @public_view %>
    <button class="btn-edit" id="btnEdit" onclick="toggleEdit()">⠿ <span data-i18n="arrange">Sắp xếp sections</span></button>
    <button class="btn-rebuild" onclick="rebuildStructure()" title="Yêu cầu AI tạo lại cấu trúc báo cáo">✦ <span data-i18n="rebuild">Tạo lại</span></button>
  <% end %>
</div>

<% unless @pdf_preview %>
<button class="pdf-preview-tab" id="pdfPreviewTab" onclick="togglePdfPreview()" title="Xem trước PDF">
  <span class="pdf-preview-tab-icon">👁</span>
  <span class="pdf-preview-tab-text">XEM TRƯỚC PDF</span>
</button>
<div class="pdf-drawer" id="pdfDrawer">
  <div class="pdf-drawer-hdr">
    <div class="pdf-drawer-hdr-left">
      <span>👁 Xem trước PDF thực tế</span>
    </div>
    <button class="pdf-drawer-close" onclick="togglePdfPreview()">✕ Đóng</button>
  </div>
  <div class="pdf-drawer-toolbar">
    <span class="pdf-drawer-hint" id="pdfPreviewHint">Xem trước layout — đường đỏ = điểm cắt trang A4</span>
    <button id="pdfRefreshBtn" onclick="generatePdfPreview()" class="pdf-size-btn" style="background:#4361ee;color:white;border-color:#4361ee">🔄 Làm mới</button>
    <button onclick="downloadPdf()" style="background:#374151;color:white;border:none;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer">⬇ Tải PDF</button>
  </div>
  <div class="pdf-drawer-body" style="padding:0;background:#525659">
    <div id="pdfPreviewLoading" style="display:none;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;color:white">
      <div style="width:36px;height:36px;border:3px solid rgba(255,255,255,.2);border-top-color:white;border-radius:50%;animation:spin .8s linear infinite"></div>
      <span id="pdfPreviewLoadingText" style="font-size:13px;opacity:.8">Đang tạo PDF...</span>
    </div>
    <div id="pdfIframeWrap" style="display:none;flex:1;min-height:0;overflow:hidden;">
      <iframe id="pdfHtmlFrame" src="" style="width:100%;height:100%;border:none;display:block;"></iframe>
    </div>
    <div id="pdfPreviewEmpty" style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;gap:12px;color:rgba(255,255,255,.6)">
      <span style="font-size:32px">📄</span>
      <span style="font-size:13px">Nhấn "Làm mới" để xem trước PDF</span>
    </div>
  </div>
</div>
<% end %>

<%# ── Share modal ── %>
<div id="shareModal">
  <div class="share-box">
    <h3>🔗 Chia sẻ báo cáo</h3>
    <p>Ai có link này đều có thể xem báo cáo mà không cần đăng nhập</p>
    <div class="share-qr" id="shareQrWrap">
      <div id="shareQrDiv"></div>
    </div>
    <div class="share-link-row">
      <input class="share-link-input" id="shareLinkInput" readonly type="text" value="Đang tạo link...">
    </div>
    <div id="shareShortRow" style="display:none;font-size:11px;color:#64748b;margin-bottom:10px;padding:0 2px">
      Full link: <span id="shareFullUrl" style="font-family:monospace;word-break:break-all"></span>
    </div>
    <div class="share-actions">
      <button id="btn-copy-link" class="share-btn" onclick="copyShareLink(this)"><span class="icon">📋</span><span class="copy-tick">✅</span>Copy link</button>
      <button id="btn-copy-qr"   class="share-btn" onclick="copyQrImage(this)"><span class="icon">🖼</span><span class="copy-tick">✅</span>Copy QR</button>
      <button class="share-btn" onclick="downloadQr()"><span class="icon">⬇️</span>Tải QR</button>
    </div>
    <div class="share-footer">
      <button class="share-revoke" onclick="revokeShareLink()">🗑 Thu hồi link</button>
      <button class="share-close" onclick="closeShareModal()">Đóng</button>
    </div>
  </div>
</div>

<%# ── PDF loading overlay ── %>
<div id="pdf-loading">
  <div class="pdf-spinner"></div>
  <span>Đang tạo PDF, vui lòng chờ...</span>
</div>

<%# ── Header ── %>
<div class="header" style="position:relative">
  <div class="header-lang-switcher" id="headerLangSwitcher">
    <button class="lang-btn<%= ' active' if (@report_lang || 'vi') == 'vi' %>" id="langVI" onclick="setLang('vi')">🇻🇳 VI</button>
    <button class="lang-btn<%= ' active' if @report_lang == 'en' %>" id="langEN" onclick="setLang('en')">🇬🇧 EN</button>
  </div>
  <h1>
    <span class="hdr-editable" id="hdrTitleWrap" onclick="startHdrEdit('title')" title="Click để chỉnh sửa tiêu đề">
      <% _display_title = (@report_lang == "en" && @report_structure&.dig("survey_title_translated").present?) ? @report_structure["survey_title_translated"] : @survey.title %>
      <span class="hdr-text" id="hdrTitleText">📊 <%= _display_title %></span>
      <span class="hdr-edit-icon"><svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z" stroke="#a5b4fc" stroke-width="1.8" stroke-linejoin="round"/></svg></span>
      <input class="hdr-input title-input" id="hdrTitleInput" type="text" value="📊 <%= _display_title %>" onblur="endHdrEdit('title')" onkeydown="hdrKey(event,'title')">
    </span>
  </h1>
  <p>
    <span class="hdr-editable" id="hdrSubWrap" onclick="startHdrEdit('sub')" title="Click để chỉnh sửa mô tả">
      <% _sub_prefix = @report_lang == "en" ? "Analytics report" : "Báo cáo phân tích" %>
      <% _sub_responses = @report_lang == "en" ? "#{@total_responses} responses" : "#{@total_responses} phản hồi" %>
      <% _sub_text = "#{_sub_prefix} · #{_sub_responses}#{@survey_date_range.present? ? " · #{@survey_date_range}" : ""}" %>
      <span class="hdr-text" id="hdrSubText"><%= _sub_text %></span>
      <span class="hdr-edit-icon"><svg width="12" height="12" viewBox="0 0 20 20" fill="none"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z" stroke="#a5b4fc" stroke-width="1.6" stroke-linejoin="round"/></svg></span>
      <input class="hdr-input sub-input" id="hdrSubInput" type="text" value="<%= _sub_text %>" onblur="endHdrEdit('sub')" onkeydown="hdrKey(event,'sub')">
    </span>
  </p>
</div>

<div class="container">
<% palette = %w[#4361ee #7c3aed #06b6d4 #10b981 #f59e0b #ef4444 #ec4899 #8b5cf6 #0ea5e9 #14b8a6] %>

<%# ── Restore bar ── %>
<div class="restore-bar" id="restoreBar">
  <span class="restore-label">👁 Đang ẩn:</span>
  <button class="btn-restore-all" onclick="restoreAllHidden()" title="Hiện tất cả sections và cards đang ẩn">Hiện tất cả</button>
</div>

<%# ── KPI grid — driven by report_structure kpis ── %>
<% if @kpi_values.any? %>
<div class="kpi-grid" style="margin-top:24px">
  <% @kpi_values.each_with_index do |k, ki| %>
    <div class="kpi" id="kpi-block-<%= ki %>" style="border-color:<%= k[:color] %>">
      <div class="kpi-rh" data-kpi-idx="<%= ki %>" data-dir="r"></div>
      <div class="kpi-lh" data-kpi-idx="<%= ki %>" data-dir="l"></div>
      <div class="kpi-rb" data-kpi-idx="<%= ki %>" data-dir="b"></div>
      <div class="kpi-rt" data-kpi-idx="<%= ki %>" data-dir="t"></div>
      <div class="kpi-toolbar">
        <span class="kpi-drag-handle" title="Kéo để di chuyển">⠿</span>
        <button class="kpi-tool-btn" onclick="document.getElementById('kpi-lbl-<%= ki %>').focus()" title="Sửa nhãn">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z"/></svg>
        </button>
        <button class="kpi-tool-btn" onclick="hideKpi('<%= ki %>')" title="Ẩn block">
          <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 11.94A10 10 0 0 1 2.06 11.94M1 1l18 18"/><path d="M9.9 4.07A7 7 0 0 1 17 11M6.53 6.53A7 7 0 0 0 3 11"/></svg>
        </button>
      </div>
      <div class="kpi-value" style="color:<%= k[:color] %>"><%= k[:value] %></div>
      <div class="kpi-edit-wrap">
        <span contenteditable="true"
              spellcheck="false"
              id="kpi-lbl-<%= ki %>"
              data-kpi-idx="<%= ki %>"
              data-kpi-default="<%= j k[:label] %>"
              class="kpi-label kpi-editable"
              onblur="saveKpiLabel(this)"
              onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}"
        ><%= k[:label] %></span>
      </div>
    </div>
  <% end %>
</div>
<% end %>

<%# ── Sortable sections — DYNAMIC from report_structure ── %>
<div id="sortableContainer">
<% if @report_structure && @report_structure["sections"].present? %>
<%
  sections_data = @report_structure["sections"]
  card_idx = 0
%>
<% sections_data.each do |section| %>
<% sid = section["id"] || "s#{sections_data.index(section)+1}" %>
<% sec_title = section["title"].to_s %>
<div class="report-section" data-id="<%= sid %>">
  <div class="section-header">
    <div class="section-controls">
      <span class="btn-sec-drag">⠿</span>
      <button class="btn-sec-hide" onclick="hideSection('<%= sid %>','<%= j sec_title %>')">Ẩn section</button>
    </div>
    <div class="section-title"><% unless @public_view %><input type="text" class="section-title-edit" data-sec-id="<%= sid %>" value="<%= j sec_title %>" onchange="saveLayout()" onblur="saveLayout()" onkeydown="if(event.key==='Enter')this.blur()" spellcheck="false"><% else %><span><%= sec_title %></span><% end %></div>
    <% unless @public_view %><button class="section-edit-btn" onmousedown="event.preventDefault();event.stopPropagation();focusSectionTitle(this)" title="Sửa tên section">✏️</button><% end %>
  </div>
  <div class="<%= section['layout'] || 'grid-2' %>" id="grid-<%= sid %>">
  <% (section["cards"] || []).each do |card| %>
  <%
    chart_type = card["chart_type"].to_s
    _stats_check = @question_stats[card["question_id"]&.to_i]
    # AI-generated themes → force horizontal_bar for readability
    if _stats_check&.dig(:processing) == "ai_themes"
      chart_type = "horizontal_bar"
    elsif %w[bar horizontal_bar distribution_bar doughnut pie].include?(chart_type)
      # Override to hbar with top-12 if too many options (unreadable chart)
      _opts_check = _stats_check&.dig(:options) || []
      chart_type = "horizontal_bar" if _opts_check.size > 12
    end
    is_cross_tab = chart_type == "cross_tab_grouped_bar"
    qid  = is_cross_tab ? nil : card["question_id"]&.to_i
    stats = is_cross_tab ? nil : @question_stats[qid]
    next unless stats || is_cross_tab
    # Skip blocks with no meaningful data
    if stats && !is_cross_tab
      has_data = stats[:options]&.any?{|o| o[:count].to_i > 0} || stats[:distribution]&.any? || stats[:avg]
      next unless has_data
    end

    # For cross-tab, look up pre-computed data
    ct_data = nil
    if is_cross_tab
      grp_qid  = card["group_by_question_id"]&.to_i
      val_qids = Array(card["value_question_ids"]).map(&:to_i)
      ct_key   = "ct_#{grp_qid}_#{val_qids.join('_')}"
      ct_data  = @cross_tab_data[ct_key]
      next unless ct_data
    end

    span     = card["span"] || 6
    cid      = is_cross_tab ? "card-ct-#{grp_qid.to_i}-#{card_idx}" : "card-#{qid}"
    card_title = card["title"].presence || stats&.dig(:title).to_s
    card_idx += 1
    ci = card_idx - 1
  %>
  <div class="cw" data-cid="<%= cid %>" style="grid-column:span <%= span %>">
    <div class="card-toolbar">
      <button class="ct-mode-btn" onclick="setCwMode(this,'text')"><span class="icon">✏️</span>Sửa nội dung</button>
      <button class="ct-mode-btn" onclick="setCwMode(this,'resize')"><span class="icon">⤢</span>Thay đổi kích thước</button>
      <button class="ct-mode-btn" onclick="setCwMode(this,'move')"><span class="icon">⠿</span>Di chuyển</button>
      <div class="ct-divider"></div>
      <button class="ct-mode-btn danger" onclick="hideCard('<%= cid %>')"><span class="icon">👁</span>Ẩn block này</button>
    </div>
    <%# cw-mode-bar, resize handles, snap-guide injected by JS below %>
    <div class="card">
      <h3><span data-editable contenteditable="false"><%= card_title.to_s.truncate(100) %></span><span class="h3-spacer"></span><button class="cw-gear" onclick="toggleCardMenu(this)">⚙</button></h3>

      <%# ═══ DOUGHNUT ═══ %>
      <% if chart_type == "doughnut" || chart_type == "pie" %>
        <% opts = stats[:options] || [] %>
        <% if opts.any? %>
          <canvas id="ch_<%= cid %>"></canvas>
          <script>
          (function(){
            var ctx = document.getElementById('ch_<%= cid %>');
            if(!ctx) return;
            mkChart('ch_<%= cid %>', {
              type: 'doughnut',
              data: {
                labels: <%= raw opts.map{|o| o[:label]}.to_json %>,
                datasets: [{ data: <%= raw opts.map{|o| o[:count]}.to_json %>, backgroundColor: C.slice(0, <%= opts.size %>), borderWidth:2, borderColor:'#fff' }]
              },
              options: { responsive:true, maintainAspectRatio:true,
                plugins: { legend:{position:'right',labels:{font:{size:11},padding:10}},
                  datalabels:{ color:'#fff',font:{weight:'bold',size:10},
                    formatter:(v,ctx2)=>{ var s=ctx2.chart.data.datasets[0].data.reduce((a,b)=>a+b,0); return s>0?Math.round(v/s*100)+'%':''; },
                    display: ctx2=>{ var s=ctx2.chart.data.datasets[0].data.reduce((a,b)=>a+b,0); return s>0&&ctx2.dataset.data[ctx2.dataIndex]/s>0.04; }
                  }
                }
              },
              plugins:[ChartDataLabels]
            });
          })();
          </script>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
        <% end %>

      <%# ═══ VERTICAL BAR (choice questions / tool bar) ═══ %>
      <% elsif chart_type == "bar" %>
        <% opts = (stats[:options] || []).sort_by{|o| -o[:count]} %>
        <% if opts.any? %>
          <canvas id="ch_<%= cid %>"></canvas>
          <script>
          (function(){
            mkChart('ch_<%= cid %>', {
              type: 'bar',
              data: {
                labels: <%= raw opts.map{|o| o[:label]}.to_json %>,
                datasets: [{ data: <%= raw opts.map{|o| o[:count]}.to_json %>,
                  backgroundColor: <%= raw opts.map.with_index{|_,i| palette[i % palette.size]}.to_json %>,
                  borderRadius: 4 }]
              },
              options: { responsive:true, plugins:{ legend:{display:false}, datalabels: barDL },
                scales:{ y:{beginAtZero:true,ticks:{precision:0}}, x:{ticks:{maxRotation:30,font:{size:10}}} },
                layout: barLayout },
              plugins:[ChartDataLabels]
            });
          })();
          </script>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
        <% end %>

      <%# ═══ HORIZONTAL BAR (challenges / multiple-choice) ═══ %>
      <% elsif chart_type == "horizontal_bar" %>
        <% opts = (stats[:options] || []).sort_by{|o| -o[:count]}.first(12) %>
        <% if opts.any? %>
          <div class="bar-list">
          <div class="bar-item bar-header">
            <span class="bar-label w200"></span>
            <div class="bar-track" style="background:transparent"></div>
            <span class="bar-pct-out" style="color:#9ca3af;font-weight:500" data-i18n="bar_pct">%</span>
            <span class="bar-count" style="color:#9ca3af;font-weight:500" data-i18n="bar_count">SL</span>
          </div>
          <% opts.each_with_index do |o, oi| %>
          <div class="bar-item">
            <span class="bar-label w200" title="<%= o[:label] %>"><%= o[:label] %></span>
            <div class="bar-track"><div class="bar-fill" style="width:<%= o[:pct].clamp(0,100) %>%;background:<%= palette[oi % palette.size] %>"></div></div>
            <span class="bar-pct-out" style="color:<%= palette[oi % palette.size] %>"><%= o[:pct] %>%</span>
            <span class="bar-count"><%= o[:count] %></span>
          </div>
          <% end %>
          </div>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
        <% end %>

      <%# ═══ DISTRIBUTION BAR (parse_percent questions: % savings histogram) ═══ %>
      <% elsif chart_type == "distribution_bar" %>
        <% dist = stats[:distribution] || [] %>
        <% if dist.any? %>
          <canvas id="ch_<%= cid %>"></canvas>
          <script>
          (function(){
            mkChart('ch_<%= cid %>', {
              type: 'bar',
              data: {
                labels: <%= raw dist.map{|d| d[:label]}.to_json %>,
                datasets: [{ data: <%= raw dist.map{|d| d[:count]}.to_json %>,
                  backgroundColor: '#4361ee', borderRadius: 4,
                  hoverBackgroundColor: '#3451d1' }]
              },
              options: { responsive:true, plugins:{ legend:{display:false}, datalabels: barDL },
                scales:{ y:{beginAtZero:true,ticks:{precision:0}}, x:{ticks:{font:{size:10}}} },
                layout: barLayout },
              plugins:[ChartDataLabels]
            });
          })();
          </script>
          <% if stats[:avg] %>
          <div style="margin-top:10px;font-size:12px;color:#6b7280;text-align:center">
            Trung bình: <strong style="color:#4361ee;font-size:15px"><%= stats[:avg] %>%</strong>
            <% if stats[:min] && stats[:max] %>
              &nbsp;·&nbsp; Min: <strong><%= stats[:min] %>%</strong> / Max: <strong><%= stats[:max] %>%</strong>
            <% end %>
          </div>
          <% end %>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
        <% end %>

      <%# ═══ NPS BAR (0-10 distribution with red/cyan/green colors) ═══ %>
      <% elsif chart_type == "nps_bar" %>
        <% dist = stats[:distribution] || [] %>
        <% if dist.any? %>
          <canvas id="ch_<%= cid %>"></canvas>
          <script>
          (function(){
            var labels = <%= raw dist.map{|d| d[:label]}.to_json %>;
            var counts = <%= raw dist.map{|d| d[:count]}.to_json %>;
            var npsColors = labels.map(function(v){
              var n = parseInt(v);
              return n >= 9 ? '#10b981' : n >= 7 ? '#06b6d4' : '#ef4444';
            });
            mkChart('ch_<%= cid %>', {
              type: 'bar',
              data: {
                labels: labels,
                datasets: [{ data: counts, backgroundColor: npsColors, borderRadius: 4 }]
              },
              options: { responsive:true, plugins:{ legend:{display:false}, datalabels: barDL },
                scales:{ y:{beginAtZero:true,ticks:{precision:0}}, x:{ticks:{font:{size:11}}} },
                layout: barLayout },
              plugins:[ChartDataLabels]
            });
          })();
          </script>
          <% detractors = (dist.select{|d| d[:label].to_i <= 6}.sum{|d| d[:count]}) %>
          <% passives   = (dist.select{|d| [7,8].include?(d[:label].to_i)}.sum{|d| d[:count]}) %>
          <% promoters  = (dist.select{|d| d[:label].to_i >= 9}.sum{|d| d[:count]}) %>
          <% total_nps  = stats[:total].to_i %>
          <% if total_nps > 0 %>
          <% nps_score  = ((promoters - detractors).to_f / total_nps * 100).round %>
          <% det_pct = (detractors.to_f / total_nps * 100).round %>
          <% pas_pct = (passives.to_f   / total_nps * 100).round %>
          <% pro_pct = (promoters.to_f  / total_nps * 100).round %>
          <div style="margin-top:14px">
            <%# ── Progress bar ── %>
            <div style="display:flex;height:10px;border-radius:6px;overflow:hidden;gap:2px">
              <div style="width:<%= det_pct %>%;background:#ef4444;min-width:<%= detractors>0 ? 2 : 0 %>px"></div>
              <div style="width:<%= pas_pct %>%;background:#06b6d4;min-width:<%= passives>0 ? 2 : 0 %>px"></div>
              <div style="width:<%= pro_pct %>%;background:#10b981;min-width:<%= promoters>0 ? 2 : 0 %>px"></div>
            </div>
            <%# ── Labels ── %>
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-top:10px;gap:8px">
              <div style="display:flex;align-items:center;gap:6px">
                <span style="width:10px;height:10px;border-radius:50%;background:#ef4444;flex-shrink:0;display:inline-block"></span>
                <div>
                  <div style="font-size:13px;font-weight:700;color:#ef4444"><%= detractors %> người <span style="font-weight:400;color:#94a3b8">(<%= det_pct %>%)</span></div>
                  <div style="font-size:10px;color:#94a3b8">Không hài lòng (0–6)</div>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:6px">
                <span style="width:10px;height:10px;border-radius:50%;background:#06b6d4;flex-shrink:0;display:inline-block"></span>
                <div>
                  <div style="font-size:13px;font-weight:700;color:#06b6d4"><%= passives %> người <span style="font-weight:400;color:#94a3b8">(<%= pas_pct %>%)</span></div>
                  <div style="font-size:10px;color:#94a3b8">Trung lập (7–8)</div>
                </div>
              </div>
              <div style="display:flex;align-items:center;gap:6px">
                <span style="width:10px;height:10px;border-radius:50%;background:#10b981;flex-shrink:0;display:inline-block"></span>
                <div>
                  <div style="font-size:13px;font-weight:700;color:#10b981"><%= promoters %> người <span style="font-weight:400;color:#94a3b8">(<%= pro_pct %>%)</span></div>
                  <div style="font-size:10px;color:#94a3b8">Hài lòng cao (9–10)</div>
                </div>
              </div>
              <div style="text-align:right;border-left:2px solid #e5e7eb;padding-left:12px">
                <div style="font-size:22px;font-weight:800;color:<%= nps_score >= 50 ? '#10b981' : nps_score >= 0 ? '#f59e0b' : '#ef4444' %>"><%= nps_score > 0 ? '+' : '' %><%= nps_score %></div>
                <div style="font-size:10px;color:#94a3b8;font-weight:600">Điểm hài lòng</div>
              </div>
            </div>
          </div>
          <% end %>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
        <% end %>

      <%# ═══ RATING BAR (rating/linear_scale) ═══ %>
      <% elsif chart_type == "rating_bar" %>
        <% vals = stats[:values] || [] %>
        <% dist = stats[:distribution] || [] %>
        <% max_s = stats[:max_scale] || 5 %>
        <% if vals.any? %>
          <% dist.each do |d| %>
          <div class="rating-row">
            <div class="rating-label"><%= d[:label] %></div>
            <div class="rating-bar"><div class="rating-fill" style="width:<%= d[:pct].clamp(0,100) %>%;background:<%= palette[(d[:label].to_i - 1) % palette.size] %>"><%= d[:count] > 0 ? d[:count] : '' %></div></div>
            <div class="rating-score"><%= d[:pct] %>%</div>
          </div>
          <% end %>
          <div style="margin-top:10px;font-size:12px;color:#6b7280">Trung bình: <strong style="color:#4361ee"><%= stats[:avg] %></strong> / <%= max_s %></div>
        <% else %>
          <p style="color:#9ca3af;text-align:center;padding:24px 0;font-size:13px">Chưa có dữ liệu</p>
        <% end %>

      <%# ═══ CROSS-TAB GROUPED BAR (dept × savings etc.) ═══ %>
      <% elsif chart_type == "cross_tab_grouped_bar" %>
        <% if ct_data && ct_data[:labels].any? %>
          <%
            ct_labels  = ct_data[:labels]
            ct_n       = ct_labels.size
            # Build qid → short title map from structure cards
            short_title_map = {}
            @report_structure&.dig("sections")&.each do |sec|
              sec["cards"]&.each do |c|
                qid = c["question_id"]&.to_i
                short_title_map[qid] = c["title"] if qid && c["title"].present?
              end
            end
            # Map value_question_ids to short titles
            val_qids = Array(card["value_question_ids"]).map(&:to_i)
            ct_datasets = ct_data[:datasets].each_with_index.map do |ds, i|
              short = short_title_map[val_qids[i]] || ds[:label]
              { label: short, data: Array(ds[:data]).first(ct_n),
