// ── Floating edit icon for [data-editable] elements ──────────────────────
(function(){
  if (IS_PUBLIC) return;
  const icon = document.createElement('button');
  icon.className = 'float-edit-icon';
  icon.title = 'Sửa nội dung';
  icon.innerHTML = '<svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z"/></svg>';
  document.body.appendChild(icon);
  let target = null, hideTimer = null;
  function showIcon(el) {
    clearTimeout(hideTimer);
    target = el;
    const r = el.getBoundingClientRect();
    icon.style.left = (r.right + 6) + 'px';
    icon.style.top  = (r.top + r.height / 2 - 18) + 'px';
    icon.style.display = 'flex';
  }
  function scheduleHide() {
    hideTimer = setTimeout(() => { icon.style.display = 'none'; target = null; }, 120);
  }
  document.addEventListener('mouseover', e => {
    const el = e.target.closest('[data-editable]');
    if (el) showIcon(el);
  });
  document.addEventListener('mouseout', e => {
    if (e.target.closest('[data-editable]') && !e.relatedTarget?.closest('[data-editable]') && e.relatedTarget !== icon) scheduleHide();
  });
  icon.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  icon.addEventListener('mouseleave', () => scheduleHide());
  icon.addEventListener('click', e => {
    e.stopPropagation();
    if (!target) return;
    const cw = target.closest('.cw');
    if (cw) {
      cw.classList.remove('cw-resize-mode','cw-move-mode');
      cw.classList.add('cw-text-mode');
