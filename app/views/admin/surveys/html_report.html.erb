// ── Layout editor ───────────────────────────────────────────────
const STORAGE_KEY = 'report_layout_<%= @survey.id %>';
let editMode = false;

function loadLayout() {
  try {
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    const container = document.getElementById('sortableContainer');

    // Restore order
    if (saved.order && saved.order.length) {
      saved.order.forEach(id => {
        const el = container.querySelector(`[data-id="${id}"]`);
        if (el) container.appendChild(el);
      });
    }

    // Restore hidden
    if (saved.hidden && saved.hidden.length) {
      saved.hidden.forEach(({ id, label }) => {
        const el = container.querySelector(`[data-id="${id}"]`);
        if (el) {
          el.classList.add('hidden-section');
          addRestoreChip(id, label);
        }
      });
    }
    updateRestoreBar();
  } catch(e) {}
}

function saveLayout() {
  const container = document.getElementById('sortableContainer');
  const sections = [...container.querySelectorAll('.report-section')];
  const order = sections.map(el => el.dataset.id);
  const hidden = sections
    .filter(el => el.classList.contains('hidden-section'))
    .map(el => ({ id: el.dataset.id, label: el.querySelector('.btn-hide')?.getAttribute('data-label') || el.dataset.id }));
  localStorage.setItem(STORAGE_KEY, JSON.stringify({ order, hidden }));
}

function toggleEdit() {
  editMode = !editMode;
  document.body.classList.toggle('edit-mode', editMode);
  const btn = document.getElementById('btnEdit');
  btn.classList.toggle('active', editMode);
  btn.textContent = editMode ? '✅ Xong' : '✏️ Chỉnh layout';
}

function hideSection(id, label) {
  const el = document.querySelector(`[data-id="${id}"]`);
  if (!el) return;
  el.classList.add('hidden-section');
  el.querySelector('.btn-hide').setAttribute('data-label', label);
  addRestoreChip(id, label);
  updateRestoreBar();
  saveLayout();
}

function addRestoreChip(id, label) {
  const bar = document.getElementById('restoreBar');
  if (bar.querySelector(`[data-restore="${id}"]`)) return;
  const btn = document.createElement('button');
  btn.className = 'btn-restore';
  btn.setAttribute('data-restore', id);
  btn.textContent = `👁 ${label}`;
  btn.onclick = () => {
    document.querySelector(`[data-id="${id}"]`)?.classList.remove('hidden-section');
    btn.remove();
    updateRestoreBar();
    saveLayout();
  };
  bar.appendChild(btn);
}

function updateRestoreBar() {
  const bar = document.getElementById('restoreBar');
  bar.classList.toggle('has-hidden', bar.querySelectorAll('.btn-restore').length > 0);
}

// Init Sortable
const sortable = new Sortable(document.getElementById('sortableContainer'), {
  animation: 150,
  handle: '.btn-drag',
  ghostClass: 'sortable-ghost',
  chosenClass: 'sortable-chosen',
  onEnd: saveLayout
});

loadLayout();
</script>
</body>
</html>
