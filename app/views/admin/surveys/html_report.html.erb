// ── PDF download via Grover (server-side, with current layout) ──
async function downloadPdf() {
  deactivateAllCards();
  const overlay = document.getElementById('pdf-loading');
  overlay.classList.add('show');
  try {
    // Read current layout from localStorage so Grover renders same as browser
    const layoutJson = localStorage.getItem(SK) || '{}';

    const resp = await fetch('<%= raw pdf_report_survey_path(@survey, lang: @report_lang) %>', {
      method:  'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
      },
      body: JSON.stringify({ layout: layoutJson })
    });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const blob = await resp.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = resp.headers.get('Content-Disposition')
                   ?.match(/filename="?([^";\n]+)"?/)?.[1] || 'bao-cao.pdf';
    document.body.appendChild(a);
    a.click();
    setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 1000);
  } catch(err) {
    alert('Không thể tạo PDF: ' + err.message);
  } finally {
    overlay.classList.remove('show');
  }
}

