// Layout editor
// ══════════════════════════════════════════════════════════
const SURVEY_ID = '<%= @survey.id %>';
const SK = 'report_layout_' + SURVEY_ID;
let editMode = false;
let pendingDeleteCid = null;
let currentChartModal = null; // { chartId, cardTitle }

// ── Section-level edit mode (drag/hide sections) ──
function toggleEdit() {
  editMode = !editMode;
  document.body.classList.toggle('edit-mode', editMode);
  const btn = document.getElementById('btnEdit');
  btn.classList.toggle('active', editMode);
  btn.textContent = editMode ? '✅ Xong' : '⠿ Sắp xếp sections';
  // Close any active card when toggling
  deactivateAllCards();
}

// ── Per-card gear activation ──
let activeCw = null;

function activateCard(cw) {
  if (activeCw === cw) return;
  deactivateAllCards();
  activeCw = cw;
  cw.classList.add('cw-active');
}

function deactivateAllCards() {
  document.querySelectorAll('.cw-active').forEach(c => {
    c.classList.remove('cw-active','cw-text-mode','cw-resize-mode','cw-move-mode');
    c.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'false');
    c.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  });
  activeCw = null;
}

// ── Mode toggle per card ──
// mode: 'text' | 'resize' | 'move'
function setCwMode(btn, mode) {
  const cw = btn.closest('.cw');
  const modeClass = 'cw-' + mode + '-mode';
  const wasActive = btn.classList.contains('active');

  // Clear all modes on this card
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'false');

  if (!wasActive) {
    cw.classList.add(modeClass);
    btn.classList.add('active');
    // Show correct mode bar label
    cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
    const lbl = cw.querySelector('.lbl-' + (mode==='resize'?'resize':mode==='move'?'move':'text'));
    if (lbl) lbl.style.display = '';
    if (mode === 'text') {
      cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'true');
    }
  }
  // Close dropdown after selecting a mode
  cw.classList.remove('cw-active');
  activeCw = null;
}

function cancelMode(e, btn) {
  e.stopPropagation();
  e.preventDefault();
  const cw = btn.closest('.cw');
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'false');
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
  saveLayout();
}

// Click outside any .cw → deactivate
document.addEventListener('mousedown', e => {
  if (rd) return; // ignore during resize
  if (e.target.closest('.cw-gear')) return; // handled by gear click
  if (e.target.closest('[data-dir]')) return; // resize handle
  if (e.target.closest('#deleteModal,#chartModal')) return; // modals
  if (!e.target.closest('.cw-active')) deactivateAllCards();
});

// ── Print / PDF ──
function printPdf() {
  deactivateAllCards();
  window.print();
}

// ── Inject gear icons + resize handles into each .cw ──
document.querySelectorAll('.cw').forEach(cw => {
  // Gear button
  const gear = document.createElement('button');
  gear.className = 'cw-gear';
  gear.textContent = '⚙';
  gear.title = 'Tuỳ chỉnh block';
  gear.addEventListener('click', e => {
    e.stopPropagation();
    const hasMode = cw.classList.contains('cw-resize-mode') || cw.classList.contains('cw-text-mode') || cw.classList.contains('cw-move-mode');
    if (cw.classList.contains('cw-active')) {
      deactivateAllCards();
    } else if (hasMode) {
      // Already in a mode — show dropdown again to let user switch
      deactivateAllCards();
      activateCard(cw);
    } else {
      activateCard(cw);
    }
  });
  cw.appendChild(gear);
});

// ── Drag Resize ──
const tip = document.createElement('div');
tip.className = 'resize-tip';
document.body.appendChild(tip);

// Inject move banner (before card) + resize handles (after card) into all .cw
document.querySelectorAll('.cw').forEach(cw => {
  // Mode bar goes FIRST in .cw (above the card, in normal flow)
  cw.insertAdjacentHTML('afterbegin',
    '<div class="cw-mode-bar ct-drag">' +
      '<span class="mode-label">' +
        '<span class="lbl-text" style="display:none">✏️ Đang sửa nội dung</span>' +
        '<span class="lbl-resize" style="display:none">⤡ Đang thay đổi kích thước</span>' +
        '<span class="lbl-move" style="display:none">⠿ Kéo để di chuyển</span>' +
      '</span>' +
      '<button class="btn-done" onclick="cancelMode(event,this)">✓ Xong</button>' +
    '</div>'
  );
  // Resize handles + snap guide go after card (absolute positioned)
  cw.insertAdjacentHTML('beforeend',
    '<div class="rh-right"  data-dir="e"><div class="rh-right-bar"></div></div>' +
    '<div class="rh-bottom" data-dir="s"><div class="rh-bottom-bar"></div></div>' +
    '<div class="rh-corner" data-dir="se"></div>' +
    '<div class="snap-guide"></div>'
  );
});

let rd = null;
let rafId = null;
let latestE = null;

document.addEventListener('mousedown', e => {
  const handle = e.target.closest('[data-dir]');
  if (!handle) return;
  const cw = handle.closest('.cw');
  if (!cw?.classList.contains('cw-resize-mode')) return; // only resize-mode cards
  e.preventDefault();
  e.stopPropagation();

  const grid = cw.parentElement;
  const dir = handle.dataset.dir;
  const defaultSpan = grid.classList.contains('grid-3') ? 4 : 6;
  const startSpan = parseInt(cw.style.gridColumn?.match(/span (\d+)/)?.[1] || defaultSpan);
  const startH = cw.querySelector('.card')?.offsetHeight || 240;
  const gridRect = grid.getBoundingClientRect();

  handle.classList.add('dragging');
  cw.classList.add('is-resizing');
  rd = { cw, handle, dir, gridRect, startH,
         startSpan, startY: e.clientY, _span: startSpan, _h: startH };

  document.body.style.userSelect = 'none';
  document.body.style.cursor = dir === 'e' ? 'ew-resize' : dir === 's' ? 'ns-resize' : 'nwse-resize';
  tip.classList.add('visible');
});

document.addEventListener('mousemove', e => {
  if (!rd) return;
  latestE = e;
  if (!rafId) rafId = requestAnimationFrame(applyResize);
}, { passive: true });

function applyResize() {
  rafId = null;
  if (!rd || !latestE) return;
  const e = latestE;
  const { cw, dir, gridRect, startH, startY, startSpan } = rd;
  const card = cw.querySelector('.card');
  const MAXCOLS = 12;

  if (dir === 'e' || dir === 'se') {
    // Snap based on absolute cursor position within grid
    const colW = gridRect.width / MAXCOLS;
    const offsetInGrid = e.clientX - gridRect.left;
    const newSpan = Math.max(1, Math.min(MAXCOLS, Math.round(offsetInGrid / colW)));
    if (newSpan !== rd._span) {
      cw.style.gridColumn = `span ${newSpan}`;
      rd._span = newSpan;
    }
  }
  if (dir === 's' || dir === 'se') {
    const newH = Math.max(120, startH + (e.clientY - startY));
    if (card && Math.abs(newH - (rd._h||0)) > 2) {
      card.style.minHeight = newH + 'px';
      card.style.height = newH + 'px';
      rd._h = newH;
    }
  }

  const parts = [];
  if (dir !== 's') parts.push(`${rd._span}/12`);
  if (dir !== 'e') parts.push(`${Math.round(rd._h||startH)}px`);
  tip.textContent = parts.join(' · ');
  tip.style.left = e.clientX + 'px';
  tip.style.top  = e.clientY + 'px';
}

document.addEventListener('mouseup', () => {
  if (!rd) return;
  rd.handle.classList.remove('dragging');
  rd.cw.classList.remove('is-resizing');
  document.body.style.cursor = '';
  document.body.style.userSelect = '';
  tip.classList.remove('visible');
  rd = null; latestE = null; rafId = null;
  saveLayout();
});

// ── Delete card ──
function askDelete(cid, label) {
  pendingDeleteCid = cid;
  document.getElementById('deleteModal').classList.add('open');
}
function closeDeleteModal() {
  document.getElementById('deleteModal').classList.remove('open');
  pendingDeleteCid = null;
}
function confirmDelete() {
  if (!pendingDeleteCid) return;
  const el = document.querySelector(`[data-cid="${pendingDeleteCid}"]`);
  const label = el?.querySelector('h3')?.textContent?.trim() || pendingDeleteCid;
  if (el) el.classList.add('hidden-section');
  addRestoreChip(pendingDeleteCid, label, 'card');
  closeDeleteModal();
  saveLayout();
}

// ── Hide/show section ──
function hideSection(sid, label) {
  const el = document.querySelector(`[data-id="${sid}"]`);
  if (el) el.classList.add('hidden-section');
  addRestoreChip(sid, label, 'section');
  saveLayout();
}
function addRestoreChip(id, label, type) {
  const bar = document.getElementById('restoreBar');
  if (bar.querySelector(`[data-restore="${id}"]`)) return;
  const btn = document.createElement('button');
  btn.className = 'btn-restore';
  btn.setAttribute('data-restore', id);
  btn.textContent = '👁 ' + label;
  btn.onclick = () => {
    const sel = type === 'card' ? `[data-cid="${id}"]` : `[data-id="${id}"]`;
    document.querySelector(sel)?.classList.remove('hidden-section');
    btn.remove();
    updateRestoreBar();
    saveLayout();
  };
  bar.appendChild(btn);
  updateRestoreBar();
}
function updateRestoreBar() {
  const bar = document.getElementById('restoreBar');
  bar.classList.toggle('has-hidden', bar.querySelectorAll('.btn-restore').length > 0);
}

// ── Chart edit modal ──
function openChartModal(cardId, title, chartId) {
  const chart = chartReg[chartId];
  if (!chart) return;
  currentChartModal = { cardId, chartId };
  document.getElementById('chartModalTitle').textContent = '✎ ' + title;

  const ds = chart.data.datasets;
  const isMulti = ds.length > 1;
  const header = document.getElementById('chartModalDataHeader');
  header.textContent = isMulti ? ds.map(d => d.label || 'Dataset').join(' / ') : 'Giá trị';

  const tbody = document.getElementById('chartDataBody');
  tbody.innerHTML = '';
  chart.data.labels.forEach((lbl, i) => {
    const tr = document.createElement('tr');
    const vals = ds.map(d => d.data[i] ?? '').join('\t');
    tr.innerHTML = `
      <td><input value="${lbl}" placeholder="Nhãn" data-col="label" data-i="${i}"></td>
      ${ds.map((d,di) => `<td><input type="number" value="${d.data[i]??''}" placeholder="0" data-col="val" data-di="${di}" data-i="${i}"></td>`).join('')}
      <td><button class="del-row" onclick="this.closest('tr').remove()">×</button></td>`;
    tbody.appendChild(tr);
  });
  document.getElementById('chartModal').classList.add('open');
}
function closeChartModal() {
  document.getElementById('chartModal').classList.remove('open');
  currentChartModal = null;
}
function addDataRow() {
  const tbody = document.getElementById('chartDataBody');
  const chart = chartReg[currentChartModal?.chartId];
  if (!chart) return;
  const nds = chart.data.datasets.length;
  const tr = document.createElement('tr');
  tr.innerHTML = `
    <td><input value="" placeholder="Nhãn" data-col="label"></td>
    ${Array(nds).fill(0).map((_,di)=>`<td><input type="number" value="" placeholder="0" data-col="val" data-di="${di}"></td>`).join('')}
    <td><button class="del-row" onclick="this.closest('tr').remove()">×</button></td>`;
  tbody.appendChild(tr);
}
function applyChartEdit() {
  if (!currentChartModal) return;
  const chart = chartReg[currentChartModal.chartId];
  if (!chart) return;
  const rows = document.querySelectorAll('#chartDataBody tr');
  const newLabels = [];
  const newData = chart.data.datasets.map(() => []);
  rows.forEach(row => {
    const lblInput = row.querySelector('[data-col="label"]');
    if (!lblInput) return;
    newLabels.push(lblInput.value);
    row.querySelectorAll('[data-col="val"]').forEach(inp => {
      const di = parseInt(inp.dataset.di || 0);
      newData[di].push(parseFloat(inp.value) || 0);
    });
  });
  chart.data.labels = newLabels;
  chart.data.datasets.forEach((ds, di) => { ds.data = newData[di]; });
  chart.update();
  closeChartModal();
  saveLayout();
}

// ── Persist layout ──
function saveLayout() {
  const container = document.getElementById('sortableContainer');
  const sections = [...container.querySelectorAll('.report-section')];
  const layout = {
    sectionOrder: sections.map(el => el.dataset.id),
    hiddenSections: sections.filter(el => el.classList.contains('hidden-section')).map(el => ({
      id: el.dataset.id,
      label: el.querySelector('.btn-sec-hide')?.textContent?.replace('Ẩn section','').trim() || el.dataset.id
    })),
    hiddenCards: [],
    cardSpans: {},
    cardHeights: {},
    cardOrder: {},   // gridId → [cid, cid, ...]
    chartData: {},
    textEdits: {}
  };
  // Card order per grid
  document.querySelectorAll('[id^="grid-"]').forEach(grid => {
    layout.cardOrder[grid.id] = [...grid.querySelectorAll('.cw')].map(c => c.dataset.cid);
  });
  // Cards
  document.querySelectorAll('.cw').forEach(cw => {
    const cid = cw.dataset.cid;
    if (cw.classList.contains('hidden-section')) layout.hiddenCards.push(cid);
    if (cw.style.gridColumn) layout.cardSpans[cid] = cw.style.gridColumn;
    const card = cw.querySelector('.card');
    if (card?.style.minHeight) layout.cardHeights[cid] = card.style.minHeight;
  });
  // Text edits
  document.querySelectorAll('[data-editable]').forEach(el => {
    const cid = el.closest('.cw')?.dataset.cid || el.closest('.report-section')?.dataset.id;
    if (cid && el.textContent) layout.textEdits[cid + '_' + (el.className||'h3')] = el.textContent;
  });
  // Chart data
  Object.entries(chartReg).forEach(([id, ch]) => {
    layout.chartData[id] = { labels: ch.data.labels, datasets: ch.data.datasets.map(d => ({ label: d.label, data: [...d.data] })) };
  });
  localStorage.setItem(SK, JSON.stringify(layout));
}

function loadLayout() {
  let saved;
  try { saved = JSON.parse(localStorage.getItem(SK) || 'null'); } catch(e) {}
  if (!saved) return;
  const container = document.getElementById('sortableContainer');

  // Restore section order
  if (saved.sectionOrder) {
    saved.sectionOrder.forEach(id => {
      const el = container.querySelector(`[data-id="${id}"]`);
      if (el) container.appendChild(el);
    });
  }
  // Restore hidden sections
  (saved.hiddenSections || []).forEach(({ id, label }) => {
    const el = container.querySelector(`[data-id="${id}"]`);
    if (el) { el.classList.add('hidden-section'); addRestoreChip(id, label, 'section'); }
  });
  // Restore hidden cards
  (saved.hiddenCards || []).forEach(cid => {
    const el = document.querySelector(`[data-cid="${cid}"]`);
    if (el) {
      el.classList.add('hidden-section');
      const label = el.querySelector('h3')?.textContent?.trim() || cid;
      addRestoreChip(cid, label, 'card');
    }
  });
  // Restore card order per grid
  if (saved.cardOrder) {
    Object.entries(saved.cardOrder).forEach(([gridId, cids]) => {
      const grid = document.getElementById(gridId);
      if (!grid) return;
      cids.forEach(cid => {
        const el = document.querySelector(`[data-cid="${cid}"]`);
        if (el) grid.appendChild(el);
      });
    });
  }
  // Restore card spans
  if (saved.cardSpans) {
    Object.entries(saved.cardSpans).forEach(([cid, col]) => {
      const el = document.querySelector(`[data-cid="${cid}"]`);
      if (el) el.style.gridColumn = col;
    });
  }
  // Restore card heights
  if (saved.cardHeights) {
    Object.entries(saved.cardHeights).forEach(([cid, h]) => {
      const card = document.querySelector(`[data-cid="${cid}"] .card`);
      if (card) { card.style.minHeight = h; card.style.height = h; }
    });
  }
  // Restore chart data
  if (saved.chartData) {
    Object.entries(saved.chartData).forEach(([cid, data]) => {
      const ch = chartReg[cid];
      if (!ch) return;
      ch.data.labels = data.labels;
      data.datasets.forEach((ds, i) => { if (ch.data.datasets[i]) ch.data.datasets[i].data = ds.data; });
      ch.update('none');
    });
  }
  updateRestoreBar();
}

// ── Sortable: sections ──
new Sortable(document.getElementById('sortableContainer'), {
  animation: 150,
  handle: '.btn-sec-drag',
  ghostClass: 'sortable-ghost',
  chosenClass: 'sortable-chosen',
  onEnd: saveLayout
});

// ── Custom card drag (CSS-Grid aware) ──
let cdrag = null; // current drag state

function startCardDrag(e, cw) {
  if (e.target.closest('.btn-done')) return;
  e.preventDefault();
  e.stopPropagation();

  const rect = cw.getBoundingClientRect();

  // Ghost: clone card, fixed position, follows mouse
  const ghost = document.createElement('div');
  ghost.className = 'cd-ghost';
  ghost.style.cssText = `width:${rect.width}px;height:${rect.height}px;left:${rect.left}px;top:${rect.top}px`;
  ghost.innerHTML = cw.querySelector('.card')?.outerHTML || '';
  document.body.appendChild(ghost);

  // Placeholder in place of card
  const ph = document.createElement('div');
  ph.className = 'cd-placeholder';
  ph.style.gridColumn = cw.style.gridColumn || '';
  cw.parentElement.insertBefore(ph, cw);
  cw.classList.add('cd-source');

  // Show drop zones across all grids
  injectDropZones(cw);

  cdrag = {
    cw, ghost, ph,
    offX: e.clientX - rect.left,
    offY: e.clientY - rect.top,
    activeZone: null
  };
}

function injectDropZones(dragCw) {
  const span = dragCw.style.gridColumn || '';
  document.querySelectorAll('[id^="grid-"]').forEach(grid => {
    const cards = [...grid.querySelectorAll(':scope > .cw:not(.cd-source)')];
    // Insert zone before each card and at the end
    const positions = [...cards.map(c => ({ before: c })), { before: null, grid }];
    positions.forEach(({ before, grid: g }) => {
      const zone = document.createElement('div');
      zone.className = 'cd-zone';
      zone.style.gridColumn = span;
      zone.dataset.grid = grid.id;
      if (before) {
        grid.insertBefore(zone, before);
      } else {
        grid.appendChild(zone);
      }
    });
  });
}

document.addEventListener('mousemove', e => {
  if (!cdrag) return;
  // Move ghost
  cdrag.ghost.style.left = (e.clientX - cdrag.offX) + 'px';
  cdrag.ghost.style.top  = (e.clientY - cdrag.offY) + 'px';

  // Find nearest drop zone
  let nearest = null, nearDist = Infinity;
  document.querySelectorAll('.cd-zone').forEach(zone => {
    const r = zone.getBoundingClientRect();
    const cx = r.left + r.width / 2;
    const cy = r.top + r.height / 2;
    const dist = Math.hypot(e.clientX - cx, e.clientY - cy);
    if (dist < nearDist) { nearDist = dist; nearest = zone; }
  });

  if (cdrag.activeZone !== nearest) {
    cdrag.activeZone?.classList.remove('cd-zone-over');
    nearest?.classList.add('cd-zone-over');
    cdrag.activeZone = nearest;
  }
}, { passive: true });

document.addEventListener('mouseup', e => {
  if (!cdrag) return;
  const { cw, ghost, ph, activeZone } = cdrag;

  ghost.remove();
  cw.classList.remove('cd-source');

  if (activeZone) {
    const targetGrid = document.getElementById(activeZone.dataset.grid);
    targetGrid.insertBefore(cw, activeZone);
  } else {
    // No zone found: restore to placeholder position
    ph.parentElement.insertBefore(cw, ph);
  }

  ph.remove();
  document.querySelectorAll('.cd-zone').forEach(z => z.remove());
  cdrag = null;
  saveLayout();
});

// Attach drag start to mode bars
document.addEventListener('mousedown', e => {
  const bar = e.target.closest('.cw-mode-bar');
  if (!bar) return;
  const cw = bar.closest('.cw');
  if (!cw?.classList.contains('cw-move-mode')) return;
  startCardDrag(e, cw);
});

loadLayout();
</script>
</body>
</html>
