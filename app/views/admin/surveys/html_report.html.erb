                <div style="font-size:22px;font-weight:800;color:<%= nps_score >= 50 ? '#10b981' : nps_score >= 0 ? '#f59e0b' : '#ef4444' %>"><%= nps_score > 0 ? '+' : '' %><%= nps_score %></div>
