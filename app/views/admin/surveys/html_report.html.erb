const SECTION_I18N_MAP = {
  's-demo': { vi: 'Thành phần người tham gia', en: 'Participant breakdown' },
  's-savings': { vi: 'Mức độ tiết kiệm thời gian', en: 'Time savings' },
  's-usage': { vi: 'Cách sử dụng AI', en: 'How AI is used' },
  's-ratings': { vi: 'Đánh giá chất lượng & trải nghiệm', en: 'Quality & experience ratings' },
  's-challenges': { vi: 'Khó khăn & ý kiến người dùng', en: 'Challenges & feedback' },
  's-recs': { vi: 'Đề xuất & khuyến nghị', en: 'Suggestions & recommendations' },
};

let currentLang = '<%= @report_lang || I18n.locale %>';

function t(key) { return (TRANSLATIONS[currentLang] || TRANSLATIONS['vi'])[key] || key; }

function applyTranslations() {
  // data-i18n elements in action bar
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    el.textContent = t(key);
  });
  // Restore bar label
  const hiddenSpan = document.querySelector('#restoreBar > span');
  if (hiddenSpan) hiddenSpan.textContent = t('hidden_label');
  // Share modal static text
  const st = document.querySelector('.share-box h3'); if (st) st.textContent = t('share_title');
  const sd = document.querySelector('.share-box > p'); if (sd) sd.textContent = t('share_desc');
  const sl = document.querySelector('.share-link-input');
  if (sl && sl.value === 'Đang tạo link...' || sl?.value === 'Generating link...') sl.value = t('generating_link');
  document.querySelectorAll('.share-btn .icon + span, .share-btn').forEach(btn => {
    const icon = btn.querySelector?.('.icon');
    if (!icon) return;
    const txt = btn.childNodes[btn.childNodes.length - 1];
    // identify by icon
    const ic = icon.textContent;
    if (ic === '📋') { if (txt.nodeType === 3) txt.textContent = t('copy_link'); }
    else if (ic === '🖼') { if (txt.nodeType === 3) txt.textContent = t('copy_qr'); }
    else if (ic === '⬇️') { if (txt.nodeType === 3) txt.textContent = t('download_qr'); }
  });
  document.querySelector('.share-revoke') && (document.querySelector('.share-revoke').textContent = t('revoke_link'));
  document.querySelector('.share-close') && (document.querySelector('.share-close').textContent = t('close'));
  // PDF loading
  const pdfSpan = document.querySelector('#pdf-loading span'); if (pdfSpan) pdfSpan.textContent = t('pdf_loading');
  // Section titles via SECTION_I18N_MAP
  Object.entries(SECTION_I18N_MAP).forEach(([sid, labels]) => {
    const sec = document.querySelector(`[data-id="${sid}"]`);
    if (!sec) return;
    const titleEl = sec.querySelector('.section-title');
    if (titleEl) titleEl.textContent = labels[currentLang] || labels['vi'];
  });
  // Lang button active state
  document.getElementById('langVI')?.classList.toggle('active', currentLang === 'vi');
  document.getElementById('langEN')?.classList.toggle('active', currentLang === 'en');
  // Header subtitle "Báo cáo phân tích · N phản hồi" — only if not custom-edited
  const subEl = document.getElementById('hdrSubText');
  if (subEl && !localStorage.getItem(SK + '_sub_edited')) {
    const totalRes = <%= @total_responses %>;
    const dateRange = '<%= @survey_date_range.to_s %>';
    let sub = t('analysis_report') + ' · ' + totalRes + ' ' + t('responses');
    if (dateRange) sub += ' · ' + dateRange;
    subEl.textContent = sub;
  }
}

function setLang(lang) {
  if (lang === REPORT_LANG) return;
  // Data is server-rendered per language — reload with correct lang param
  const url = new URL(window.location.href);
  url.searchParams.set('lang', lang);
  window.location.href = url.toString();
}

// Init — apply translations using REPORT_LANG (server-authoritative)
(function(){
  currentLang = REPORT_LANG;
  applyTranslations();
})();

loadLayout();

<% unless @pdf_preview %>
// ── PDF Preview drawer (actual PDF via blob) ──
let pdfPreviewOpen = false;
let _pdfBlobUrl = null;
let _pdfPreviewLoading = false;

function togglePdfPreview() {
  pdfPreviewOpen = !pdfPreviewOpen;
  const drawer = document.getElementById('pdfDrawer');
  const tab    = document.getElementById('pdfPreviewTab');
  if (!drawer) return;
  drawer.classList.toggle('open', pdfPreviewOpen);
  if (tab) tab.classList.toggle('open', pdfPreviewOpen);
  document.body.classList.toggle('pdf-preview-open', pdfPreviewOpen);
  if (pdfPreviewOpen) generatePdfPreview();
}

// A4 landscape 210mm, scale 0.86, margins: 194mm content → 194*3.78/0.86 = 853px
const PDF_PAGE_H = 853;
const PREVIEW_ZOOM = 0.45; // 540px drawer / 1200px viewport
// Measured from actual PDF: ~18mm top + ~18mm bottom margin per page = 36mm gap
// In CSS px at scale 0.86: 36*3.78/0.86 = 158px; at zoom 0.45 = 71px visual
const PAGE_GAP_PX = 71;

async function generatePdfPreview() {
  if (!pdfPreviewOpen || _pdfPreviewLoading) return;
  _pdfPreviewLoading = true;
  const loading    = document.getElementById('pdfPreviewLoading');
  const loadText   = document.getElementById('pdfPreviewLoadingText');
  const iframeWrap = document.getElementById('pdfIframeWrap');
  const iframe     = document.getElementById('pdfHtmlFrame');
  const empty      = document.getElementById('pdfPreviewEmpty');
  const hint       = document.getElementById('pdfPreviewHint');
  const btn        = document.getElementById('pdfRefreshBtn');

  if (loading)    loading.style.display = 'flex';
  if (iframeWrap) iframeWrap.style.display = 'none';
  if (empty)      empty.style.display = 'none';
  if (btn)        { btn.disabled = true; btn.textContent = '⏳ Đang tải...'; }

  try {
    // Step 1: save current layout to server so iframe picks it up
    if (loadText) loadText.textContent = 'Đang lưu layout...';
    if (typeof saveLayout === 'function') saveLayout();
    const layoutJson = localStorage.getItem(SK) || '{}';
    await fetch('<%= save_report_layout_survey_path(@survey) %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]')?.content || '' },
      body: layoutJson
    }).catch(() => {});

    // Step 2: fetch real PDF (Grover) with countdown
    if (loadText) loadText.textContent = 'Đang tạo PDF...';
    const fetchStart = Date.now();
    const _countdownT = setInterval(() => {
      const s = Math.round((Date.now() - fetchStart) / 1000);
      if (loadText) loadText.textContent = s < 3 ? 'Đang tạo PDF...' : `Đang render... (${s}s)`;
    }, 1000);
    const resp = await fetch('<%= @pdf_preview_url || preview_pdf_report_survey_path(@survey, lang: @report_lang) %>&t=' + Date.now());
    clearInterval(_countdownT);
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const blob = await resp.blob();
    const fetchMs = Date.now() - fetchStart;

    // Step 3: show PDF via blob URL in iframe (native browser PDF viewer, no toolbar)
    const prevUrl = iframe.dataset.blobUrl;
    if (prevUrl) URL.revokeObjectURL(prevUrl);
    const blobUrl = URL.createObjectURL(blob);
    iframe.dataset.blobUrl = blobUrl;
    await new Promise((resolve) => { iframe.onload = resolve; iframe.src = blobUrl + '#toolbar=0&navpanes=0'; setTimeout(resolve, 5000); });

    if (iframeWrap) iframeWrap.style.display = 'flex';
    const cached = fetchMs < 1500;
    if (hint) hint.textContent = cached
      ? `⚡ Từ cache (${fetchMs}ms) — PDF chính xác A4`
      : `✓ Hoàn tất (${(fetchMs/1000).toFixed(1)}s) — PDF chính xác A4`;

  } catch(err) {
    if (empty) {
      empty.style.display = 'flex';
      const spans = empty.querySelectorAll('span');
      if (spans[1]) spans[1].textContent = 'Lỗi: ' + err.message;
    }
  } finally {
    _pdfPreviewLoading = false;
    if (loading) loading.style.display = 'none';
    if (btn)     { btn.disabled = false; btn.textContent = '🔄 Làm mới'; }
  }
}

function schedulePreviewReload() {
  if (!pdfPreviewOpen || _pdfPreviewLoading) return;
  const hint = document.getElementById('pdfPreviewHint');
  if (hint) hint.textContent = '⏳ Đang cập nhật xem trước...';
  clearTimeout(schedulePreviewReload._t);
  schedulePreviewReload._t = setTimeout(generatePdfPreview, 1500);
}
