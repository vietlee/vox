let kpiMoveDrag = null;
document.addEventListener('mousedown', e => {
  const handle = e.target.closest('.kpi-drag-handle');
  if (!handle) return;
  const block = handle.closest('.kpi');
  const grid = block?.closest('.kpi-grid');
  if (!block || !grid) return;
  e.preventDefault(); e.stopPropagation();
  const inlineCol = block.style.gridColumn;
  let span = 2;
  if (inlineCol) { const m = inlineCol.match(/span\s+(\d+)/); if (m) span = parseInt(m[1]); }
  kpiMoveDrag = { block, grid, span };
  document.body.style.cursor = 'grabbing';
  document.body.style.userSelect = 'none';
  block.style.opacity = '0.7';
});
document.addEventListener('mousemove', e => {
  if (!kpiMoveDrag) return;
  const { block, grid, span } = kpiMoveDrag;
  const rect = grid.getBoundingClientRect();
  const colW = rect.width / 12;
  const offset = e.clientX - rect.left;
  const newStart = Math.max(1, Math.min(13 - span, Math.round(offset / colW) + 1));
  block.style.gridColumn = `${newStart} / span ${span}`;
});
document.addEventListener('mouseup', e => {
  if (!kpiMoveDrag) return;
  kpiMoveDrag.block.style.opacity = '';
  document.body.style.cursor = '';
  document.body.style.userSelect = '';
  kpiMoveDrag = null;
  saveLayout();
});
