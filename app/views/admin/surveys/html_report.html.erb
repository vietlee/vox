// ── Custom card drag (CSS-Grid aware, free placement) ──
let cdrag = null;

function getCardSpan(cw) {
  if (cw.style.gridColumn) {
    const m = cw.style.gridColumn.match(/span\s+(\d+)/);
    if (m) return parseInt(m[1]);
  }
  const cs = window.getComputedStyle(cw);
  const s = parseInt(cs.gridColumnStart), en = parseInt(cs.gridColumnEnd);
  if (!isNaN(s) && !isNaN(en) && en > s) return en - s;
  return cw.closest('.grid-3') ? 4 : 6;
}

function startCardDrag(e, cw) {
  if (e.target.closest('.btn-done')) return;
  e.preventDefault(); e.stopPropagation();

  const rect = cw.getBoundingClientRect();
  const spanNum = getCardSpan(cw);

  // Ghost
  const ghost = document.createElement('div');
  ghost.className = 'cd-ghost';
  ghost.style.cssText = `width:${rect.width}px;height:${rect.height}px;left:${rect.left}px;top:${rect.top}px`;
  ghost.innerHTML = cw.querySelector('.card')?.outerHTML || '';
  document.body.appendChild(ghost);

  // Placeholder
  const ph = document.createElement('div');
  ph.className = 'cd-placeholder';
  ph.style.gridColumn = cw.style.gridColumn || `span ${spanNum}`;
  cw.parentElement.insertBefore(ph, cw);
  cw.classList.add('cd-source');

  // Single dynamic preview zone (created on first mousemove)
  const preview = document.createElement('div');
  preview.className = 'cd-zone cd-zone-over';
  preview.style.gridColumn = `span ${spanNum}`;

  cdrag = {
    cw, ghost, ph, preview, spanNum,
    offX: rect.width / 2,
    offY: 24,
    lastGrid: null, lastBefore: null, lastCol: null
  };
}

document.addEventListener('mousemove', e => {
  if (!cdrag) return;

  // Move ghost
  cdrag.ghost.style.left = (e.clientX - cdrag.offX) + 'px';
  cdrag.ghost.style.top  = (e.clientY - cdrag.offY)  + 'px';

  // Find which grid the cursor is over (with 50px vertical tolerance)
  let targetGrid = null;
  document.querySelectorAll('[id^="grid-"]').forEach(grid => {
    const r = grid.getBoundingClientRect();
    if (e.clientX >= r.left && e.clientX <= r.right &&
        e.clientY >= r.top - 50 && e.clientY <= r.bottom + 50) {
      targetGrid = grid;
    }
  });

  if (!targetGrid) {
    cdrag.preview.remove();
    cdrag.lastGrid = null;
    return;
  }

  // Snap column start (1-based) based on cursor X in grid
  const gr = targetGrid.getBoundingClientRect();
  const colW = gr.width / 12;
  let colStart = Math.round((e.clientX - gr.left) / colW) - Math.floor(cdrag.spanNum / 2) + 1;
  colStart = Math.max(1, Math.min(13 - cdrag.spanNum, colStart));

  // Insertion point: find the first card whose vertical midpoint is below cursor
  const items = [...targetGrid.querySelectorAll(':scope > *:not(.cd-source):not(.cd-zone)')];
  let insertBefore = null;
  for (const item of items) {
    const cr = item.getBoundingClientRect();
    if (e.clientY < cr.top + cr.height * 0.55) { insertBefore = item; break; }
  }

  // Only re-insert preview if grid/position changed (avoid flicker)
  if (targetGrid !== cdrag.lastGrid || insertBefore !== cdrag.lastBefore || colStart !== cdrag.lastCol) {
    cdrag.preview.style.gridColumn = `${colStart} / span ${cdrag.spanNum}`;
    if (insertBefore) targetGrid.insertBefore(cdrag.preview, insertBefore);
    else              targetGrid.appendChild(cdrag.preview);
    cdrag.lastGrid = targetGrid;
    cdrag.lastBefore = insertBefore;
    cdrag.lastCol = colStart;
  }
}, { passive: true });

document.addEventListener('mouseup', e => {
  if (!cdrag) return;
  const { cw, ghost, ph, preview, lastGrid, lastCol, spanNum } = cdrag;

  ghost.remove();
  cw.classList.remove('cd-source');

  if (lastGrid && preview.parentElement) {
    // Set explicit column start so card lands exactly where preview was
    cw.style.gridColumn = `${lastCol} / span ${spanNum}`;
    lastGrid.insertBefore(cw, preview);
  } else {
    ph.parentElement.insertBefore(cw, ph);
  }

  preview.remove();
  ph.remove();
  cdrag = null;
  saveLayout();
});

// Attach drag start to mode bars
document.addEventListener('mousedown', e => {
  const bar = e.target.closest('.cw-mode-bar');
  if (!bar) return;
  const cw = bar.closest('.cw');
  if (!cw?.classList.contains('cw-move-mode')) return;
  startCardDrag(e, cw);
});

// ── Share modal ──
let shareUrl = null;

async function openShareModal() {
  document.getElementById('shareModal').classList.add('open');
  if (shareUrl) return; // already generated
  try {
    const resp = await fetch('<%= raw generate_report_token_survey_path(@survey, lang: @report_lang) %>', {
      method: 'POST',
      headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' }
    });
    const data = await resp.json();
    shareUrl = data.short_url || data.url;
    document.getElementById('shareLinkInput').value = shareUrl;
    if (data.short_url && data.url !== data.short_url) {
      document.getElementById('shareFullUrl').textContent = data.url;
      document.getElementById('shareShortRow').style.display = '';
    }
    // Render server-generated SVG QR (same style as vote QR)
    document.getElementById('shareQrDiv').innerHTML = data.qr_svg || '';
  } catch(e) {
    document.getElementById('shareLinkInput').value = 'Lỗi: ' + e.message;
  }
}

// Inline voxConfirm (layout:false pages don't load admin layout)
function voxConfirm(message, onOk) {
  let overlay = document.getElementById('vox-confirm-overlay');
  if (!overlay) {
    overlay = document.createElement('div');
    overlay.id = 'vox-confirm-overlay';
    overlay.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(15,23,42,.5);z-index:99999;align-items:center;justify-content:center;';
    overlay.innerHTML = `<div style="background:white;border-radius:16px;padding:28px 28px 20px;max-width:380px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.2);"><p id="vox-confirm-msg" style="font-size:14px;color:#1e293b;line-height:1.6;margin-bottom:20px;font-weight:500;"></p><div style="display:flex;gap:10px;justify-content:flex-end;"><button id="vox-confirm-cancel" style="padding:8px 18px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;background:white;color:#64748b;">Huỷ</button><button id="vox-confirm-ok" style="padding:8px 18px;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;background:#ef4444;color:white;">Xác nhận</button></div></div>`;
    document.body.appendChild(overlay);
  }
  document.getElementById('vox-confirm-msg').textContent = message;
  overlay.style.display = 'flex';
  const close = () => { overlay.style.display = 'none'; };
  document.getElementById('vox-confirm-cancel').onclick = close;
  overlay.onclick = (e) => { if (e.target === overlay) close(); };
  document.getElementById('vox-confirm-ok').onclick = () => { close(); onOk(); };
}

function svgToCanvas(callback) {
  const svg = document.querySelector('#shareQrDiv svg');
  if (!svg) return callback(null);
  const xml = new XMLSerializer().serializeToString(svg);
  const img = new Image();
  img.onload = () => {
    const c = document.createElement('canvas');
    c.width = 220; c.height = 220;
    c.getContext('2d').drawImage(img, 0, 0, 220, 220);
    callback(c);
  };
  img.src = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(xml)));
}

function closeShareModal() {
  document.getElementById('shareModal').classList.remove('open');
}

function showCopyTick(btn) {
  if (!btn) return;
  btn.classList.add('copied');
  setTimeout(() => btn.classList.remove('copied'), 2000);
}

function copyShareLink(btn) {
  navigator.clipboard.writeText(shareUrl).then(() => showCopyTick(btn || document.getElementById('btn-copy-link')));
}

async function copyQrImage(btn) {
  const b = btn || document.getElementById('btn-copy-qr');
  try {
    if (!document.querySelector('#shareQrDiv svg')) return;
    svgToCanvas(async canvas => {
      if (!canvas) return;
      canvas.toBlob(async blob => {
        await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
        showCopyTick(b);
      });
    });
  } catch(e) { showCopyTip('Trình duyệt không hỗ trợ copy ảnh'); }
}

function downloadQr() {
  if (!document.querySelector('#shareQrDiv svg')) return showCopyTip('QR chưa sẵn sàng');
  svgToCanvas(canvas => {
    if (!canvas) return showCopyTip('Không thể tạo ảnh QR');
    const a = document.createElement('a');
    a.download = 'qr-bao-cao.png';
    a.href = canvas.toDataURL('image/png');
    a.click();
  });
}

async function revokeShareLink() {
