<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Đang tạo báo cáo...</title>
<link rel="icon" type="image/svg+xml" href="/icon.svg">
<%= csrf_meta_tags %>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,sans-serif;background:#f0f2f5;min-height:100vh;display:flex;align-items:center;justify-content:center}
.card{background:white;border-radius:20px;padding:48px 40px;max-width:420px;width:90%;text-align:center;box-shadow:0 8px 32px rgba(0,0,0,.1)}
.spinner-wrap{width:72px;height:72px;margin:0 auto 24px;position:relative}
.spinner{width:72px;height:72px;border-radius:50%;border:4px solid #e0e7ff;border-top-color:#4361ee;animation:spin 1s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ai-badge{display:inline-flex;align-items:center;gap:6px;background:#f0f4ff;border:1px solid #c7d2fe;border-radius:20px;padding:4px 14px;font-size:12px;font-weight:600;color:#4361ee;margin-bottom:16px}
h2{font-size:20px;font-weight:700;color:#1a1a2e;margin-bottom:10px}
p{font-size:14px;color:#64748b;line-height:1.6;margin-bottom:24px}
.steps{text-align:left;background:#f8fafc;border-radius:12px;padding:16px 20px;margin-bottom:28px}
.step{display:flex;align-items:center;gap:10px;padding:7px 0;font-size:13px;color:#64748b;border-bottom:1px solid #f1f5f9}
.step:last-child{border-bottom:none}
.step .dot{width:8px;height:8px;border-radius:50%;background:#c7d2fe;flex-shrink:0;transition:background .3s}
.step.active .dot{background:#4361ee;box-shadow:0 0 0 3px rgba(67,97,238,.2)}
.step.done .dot{background:#10b981}
.step.active{color:#1a1a2e;font-weight:600}
.step.done{color:#10b981}
.btn-back{display:inline-flex;align-items:center;gap:6px;color:#94a3b8;font-size:13px;text-decoration:none;margin-top:8px}
.btn-back:hover{color:#4361ee}
.error-box{display:none;background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:14px 16px;margin-bottom:16px;font-size:13px;color:#dc2626}
</style>
</head>
<body>
<div class="card">
  <div class="ai-badge">✨ AI đang phân tích</div>
  <div class="spinner-wrap"><div class="spinner"></div></div>
  <h2>Đang tạo cấu trúc báo cáo</h2>
  <p>AI đang đọc nội dung khảo sát và thiết kế layout báo cáo phù hợp. Quá trình này mất khoảng 5–15 giây.</p>

  <div class="steps">
    <div class="step done" id="step1"><div class="dot"></div> Đọc danh sách câu hỏi</div>
    <div class="step active" id="step2"><div class="dot"></div> AI phân tích & gom nhóm</div>
    <div class="step" id="step3"><div class="dot"></div> Thiết kế layout sections</div>
    <div class="step" id="step4"><div class="dot"></div> Tạo báo cáo hoàn chỉnh</div>
  </div>

  <div class="error-box" id="errorBox">Có lỗi xảy ra. <a href="<%= html_report_survey_path(@survey) %>" style="color:#dc2626;font-weight:600">Thử lại</a></div>

  <a href="<%= results_survey_path(@survey) %>" class="btn-back">← Quay lại kết quả</a>
</div>

<script>
const CHECK_URL = '<%= html_report_survey_path(@survey, check_structure: 1) %>';
const REPORT_URL = '<%= html_report_survey_path(@survey) %>';
let attempt = 0;
const steps = [null, document.getElementById('step2'), document.getElementById('step3'), document.getElementById('step4')];

function advanceStep(n) {
  if (n > 0 && n <= steps.length - 1 && steps[n]) {
    steps[n].classList.remove('active');
    steps[n].classList.add('done');
    if (steps[n+1]) { steps[n+1].classList.add('active'); }
  }
}

function checkReady() {
  attempt++;
  if (attempt === 3) advanceStep(1);
  if (attempt === 6) advanceStep(2);

  fetch(CHECK_URL, { headers: { 'Accept': 'application/json' } })
    .then(r => r.json())
    .then(data => {
      if (data.ready) {
        advanceStep(3);
        setTimeout(() => { window.location = REPORT_URL; }, 600);
      } else if (attempt < 30) {
        setTimeout(checkReady, 2000);
      } else {
        document.getElementById('errorBox').style.display = 'block';
      }
    })
    .catch(() => {
      if (attempt < 30) setTimeout(checkReady, 3000);
    });
}

setTimeout(checkReady, 2000);
</script>
</body>
</html>
