<%
  data           = @ai_result.output || {}
  rpt_title      = data["report_title"].presence || data["title"].presence || @survey.title
  rpt_sub        = data["subtitle"].presence || ""
  exec_sum       = data["executive_summary"].to_s
  sections       = data["sections"] || []
  recs           = data["recommendations"] || []
  conclusion     = data["conclusion"].to_s
  meta           = data["_meta"] || {}
  focused_mode   = meta["focused"] == true
  palette = %w[#4361ee #7c3aed #06b6d4 #10b981 #f59e0b #ef4444 #ec4899 #8b5cf6 #0ea5e9 #14b8a6]
%>
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= rpt_title %></title>
<link rel="icon" type="image/svg+xml" href="/icon.svg">
<%= csrf_meta_tags %>
<script>
// Force 2× DPR for crisp canvas in PDF (must be before Chart.js loads)
try { Object.defineProperty(window,'devicePixelRatio',{get:()=>2,configurable:true}); } catch(e){}
</script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.2.0/dist/chartjs-plugin-datalabels.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
Chart.register(ChartDataLabels);
const C=['#4361ee','#7c3aed','#06b6d4','#10b981','#f59e0b','#ef4444','#ec4899','#8b5cf6','#0ea5e9','#14b8a6'];
const chartReg={};
function mkChart(id,cfg){
  const el=document.getElementById(id);
  if(!el){console.warn('mkChart: canvas not found:',id);return null;}
  if(chartReg[id]){chartReg[id].destroy();}
  const ch=new Chart(el,cfg);
  chartReg[id]=ch;
  return ch;
}
</script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Segoe UI',-apple-system,BlinkMacSystemFont,sans-serif;background:#f0f2f5;color:#1a1a2e;font-size:14px}

/* ── Header ── */
.header{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%);color:white;padding:36px 48px 32px;position:relative}
.header h1{font-size:22px;font-weight:700;margin-bottom:6px;line-height:1.35}
.header p{opacity:.65;font-size:13px}
.header-lang-switcher{position:absolute;top:20px;right:24px;display:flex;background:rgba(255,255,255,.12);border-radius:50px;padding:2px;gap:2px;border:1px solid rgba(255,255,255,.18)}
.lang-btn{background:transparent;border:none;border-radius:50px;padding:5px 14px;font-size:12px;font-weight:700;cursor:pointer;color:rgba(255,255,255,.65);transition:all .15s;line-height:1}
.lang-btn.active{background:white;color:#374151;box-shadow:0 2px 6px rgba(0,0,0,.15)}
.lang-btn:not(.active):hover{color:white;background:rgba(255,255,255,.15)}
/* Header editable */
.hdr-editable{position:relative;display:inline-block;max-width:100%;cursor:pointer;border-radius:6px;transition:background .15s}
.hdr-editable.editing{display:block}
.hdr-editable:hover{background:rgba(255,255,255,.08)}
.hdr-editable:hover .hdr-edit-icon{opacity:1}
.hdr-edit-icon{position:absolute;top:50%;right:-34px;transform:translateY(-50%);opacity:0;transition:opacity .15s;cursor:pointer;color:rgba(255,255,255,.85);padding:5px;background:rgba(255,255,255,.12);border-radius:8px;line-height:0}
.hdr-edit-icon:hover{background:rgba(255,255,255,.22)}
.hdr-input{display:none;background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.4);border-radius:6px;color:white;outline:none;font-family:inherit;width:100%;max-width:min(760px,calc(100vw - 140px));box-sizing:border-box}
.hdr-input.title-input{font-size:22px;font-weight:700;line-height:1.35;padding:4px 10px}
.hdr-input.sub-input{font-size:13px;padding:3px 8px;opacity:.9}
.hdr-editable.editing .hdr-text{display:none}
.hdr-editable.editing .hdr-edit-icon{display:none}
.hdr-editable.editing .hdr-input{display:block}
<% if @public_view %>.hdr-editable{pointer-events:none;cursor:default}.hdr-edit-icon{display:none!important}<% end %>
@media print{.hdr-edit-icon{display:none!important}}

.container{max-width:1200px;margin:0 auto;padding:28px 24px 120px}

/* ── KPI ── */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:4px}
.kpi{background:white;border-radius:12px;padding:18px 14px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.07);border-top:4px solid;position:relative}
.kpi-value{font-size:32px;font-weight:800;line-height:1;margin-bottom:5px}
.kpi-label{font-size:10px;color:#666;font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.kpi-edit-wrap{position:relative;display:inline-flex;align-items:center;justify-content:center;gap:4px;width:100%}
.kpi-editable{cursor:text;border-radius:4px;transition:background .15s;padding:2px 4px;min-width:20px}
.kpi-editable:hover{background:rgba(67,97,238,.07)}
.kpi-editable:focus{outline:1px solid rgba(67,97,238,.3);background:#f5f7ff}
.kpi-edit-icon{opacity:0;transition:opacity .2s,background .15s;cursor:pointer;color:#818cf8;flex-shrink:0;line-height:0;padding:6px;background:#eef2ff;border-radius:8px}
.kpi:hover .kpi-edit-icon{opacity:1}

/* ── Sections ── */
.report-section{position:relative;margin-top:28px}
.report-section.hidden-section{display:none}
.section-header{display:flex;align-items:center;gap:8px;margin-bottom:14px}
.section-title{font-size:16px;font-weight:700;color:#1a1a2e;display:flex;align-items:center;gap:10px;flex:1}
.section-title::before{content:'';display:block;width:4px;height:20px;background:#4361ee;border-radius:2px;flex-shrink:0}
.section-controls{display:none;align-items:center;gap:4px}
.edit-mode .section-controls{display:flex}
.btn-sec-drag{cursor:grab;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:6px;padding:4px 8px;font-size:14px;color:#94a3b8;line-height:1;user-select:none}
.btn-sec-hide{background:#fef2f2;border:1px solid #fecaca;border-radius:6px;padding:4px 10px;font-size:11px;font-weight:600;color:#ef4444;cursor:pointer}
.sortable-ghost{opacity:.3;background:#e0e7ff;border-radius:10px}
.sortable-chosen{box-shadow:0 8px 24px rgba(67,97,238,.25)}

/* ── Grids ── */
.grid-2{display:grid;grid-template-columns:repeat(12,1fr);gap:20px;margin-bottom:4px}
.grid-2>.cw{grid-column:span 6}
@media(max-width:900px){.grid-2{grid-template-columns:1fr}.grid-2>.cw{grid-column:span 1!important}}

/* ── Card wrapper ── */
.cw{position:relative}
.cw.hidden-section{display:none}

/* ── Gear icon ── */
.cw-gear{flex-shrink:0;margin-left:auto;width:32px;height:32px;border-radius:50%;border:none;background:transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;color:#6366f1;transition:background .15s;box-shadow:none;padding:0;line-height:1}
.cw-gear:hover{background:rgba(99,102,241,.1)}
.cw-active .cw-gear,.cw-resize-mode .cw-gear,.cw-text-mode .cw-gear,.cw-move-mode .cw-gear{background:#4361ee;color:white;box-shadow:none}

/* ── Card toolbar dropdown ── */
.card-toolbar{display:none;flex-direction:column;gap:3px;position:absolute;top:56px;right:14px;z-index:50;background:white;border:1px solid #e2e8f0;border-radius:12px;padding:6px;box-shadow:0 8px 24px rgba(0,0,0,.13);min-width:185px}
.cw-active .card-toolbar{display:flex}
.ct-mode-btn{display:flex;align-items:center;gap:8px;background:transparent;border:none;border-radius:7px;padding:8px 10px;font-size:12px;font-weight:500;cursor:pointer;color:#374151;text-align:left;width:100%;transition:background .1s}
.ct-mode-btn:hover{background:#f1f5f9}
.ct-mode-btn .icon{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.ct-mode-btn.active{background:#eef2ff;color:#4361ee;font-weight:600}
.ct-mode-btn.danger{color:#ef4444}
.ct-mode-btn.danger:hover{background:#fef2f2}
.ct-divider{height:1px;background:#f0f2f5;margin:3px 0}
.cw-active .card{box-shadow:0 0 0 2px #c7d2fe,0 2px 8px rgba(0,0,0,.07)}

/* ── Mode bar ── */
.cw-mode-bar{display:none;align-items:center;gap:8px;white-space:nowrap;margin-left:auto;flex-shrink:0}
.cw-mode-bar .mode-label{display:flex;align-items:center;gap:5px;border-radius:20px;padding:5px 12px;font-size:12px;font-weight:700;box-shadow:0 2px 8px rgba(0,0,0,.12)}
.cw-mode-bar .btn-done{background:white;border:1px solid #e2e8f0;border-radius:20px;padding:5px 13px;font-size:12px;font-weight:700;cursor:pointer;line-height:1.4;box-shadow:0 2px 8px rgba(0,0,0,.1);color:#374151}
.cw-mode-bar .btn-done:hover{background:#f9fafb;border-color:#6366f1;color:#4361ee}
.cw-text-mode   .cw-mode-bar{display:flex}
.cw-text-mode   .mode-label{background:#4361ee;color:white}
.cw-resize-mode .cw-mode-bar{display:flex}
.cw-resize-mode .mode-label{background:#059669;color:white}
.cw-move-mode   .cw-mode-bar{display:flex}
.cw-move-mode   .mode-label{background:#6366f1;color:white;cursor:grab}

/* ── Resize handles (exact copy from html_report) ── */
.cw-resize-mode .rh-right{display:flex}
.cw-resize-mode .rh-bottom{display:flex}
.cw-resize-mode .rh-corner{display:block}
.cw-resize-mode .card{outline:2px dashed #a5b4fc;outline-offset:-2px}
.rh-right{display:none;position:absolute;top:0;right:-10px;width:20px;height:100%;cursor:ew-resize;z-index:25;align-items:center;justify-content:center}
.rh-right-bar{width:4px;height:100%;max-height:100%;background:linear-gradient(180deg,transparent 0%,#6366f1 20%,#6366f1 80%,transparent 100%);border-radius:2px;opacity:.45;transition:opacity .1s,width .1s}
.rh-right:hover .rh-right-bar,.rh-right.dragging .rh-right-bar{opacity:1;width:6px}
.rh-bottom{display:none;position:absolute;bottom:-10px;left:0;width:100%;height:20px;cursor:ns-resize;z-index:25;align-items:center;justify-content:center}
.rh-bottom-bar{height:4px;width:100%;background:linear-gradient(90deg,transparent 0%,#6366f1 20%,#6366f1 80%,transparent 100%);border-radius:2px;opacity:.45;transition:opacity .1s,height .1s}
.rh-bottom:hover .rh-bottom-bar,.rh-bottom.dragging .rh-bottom-bar{opacity:1;height:6px}
.rh-corner{display:none;position:absolute;bottom:-2px;right:-2px;width:22px;height:22px;cursor:nwse-resize;z-index:26}
.rh-corner::after{content:'';position:absolute;bottom:5px;right:5px;width:10px;height:10px;border-right:3px solid #6366f1;border-bottom:3px solid #6366f1;border-radius:0 0 3px 0;opacity:.5;transition:opacity .1s}
.rh-corner:hover::after,.rh-corner.dragging::after{opacity:1}
.snap-guide{display:none;position:absolute;top:0;right:0;width:3px;height:100%;background:#6366f1;border-radius:2px;opacity:.7;pointer-events:none;z-index:30}
.cw.is-resizing .snap-guide{display:block}
.resize-tip{display:none;position:fixed;background:#1a1a2e;color:#fff;font-size:11px;font-weight:700;padding:4px 9px;border-radius:6px;white-space:nowrap;pointer-events:none;z-index:999;transform:translate(12px,-50%)}
.resize-tip.visible{display:block}

/* ── Card ── */
.card{background:white;border-radius:12px;padding:20px;box-shadow:0 2px 8px rgba(0,0,0,.07);height:100%}
.card h3{font-size:13px;font-weight:700;margin-bottom:14px;color:#1a1a2e;border-bottom:2px solid #f0f2f5;padding-bottom:10px;display:flex;align-items:center;gap:10px}
canvas{max-height:250px}
@media(max-width:900px){.cw{grid-column:span 12!important}}

/* Editable text — only in text mode */
.cw-text-mode [data-editable]{outline:none;border-bottom:2px dashed #a5b4fc;cursor:text;min-width:20px;border-radius:3px;padding:1px 4px;background:#f8f9ff}
.cw-text-mode [data-editable]:focus{background:#eef2ff;border-bottom-color:#4361ee;outline:none}

/* ── Insight box ── */
.insight-box{background:#f0f4ff;border-left:4px solid #4361ee;border-radius:0 8px 8px 0;padding:10px 14px;margin-top:14px;font-size:12px;line-height:1.65;color:#374151}
.insight-box strong{color:#4361ee}

/* ── Restore bar ── */
.restore-bar{display:none;flex-wrap:wrap;gap:6px;padding:10px 14px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin:8px 0}
.restore-bar.has-hidden{display:flex}
.restore-bar span{font-size:11px;color:#94a3b8;font-weight:600;align-self:center}
.btn-restore{background:white;border:1px solid #c7d2fe;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:600;color:#4361ee;cursor:pointer}
.btn-restore:hover{background:#eef2ff}

/* ── Bar items ── */
.bar-item{display:flex;align-items:center;margin-bottom:8px;font-size:12px}
.bar-label{flex-shrink:0;color:#444;padding-right:8px;width:190px;line-height:1.3;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.bar-track{flex:1;background:#e8eaf0;border-radius:4px;height:20px;overflow:hidden;margin-right:8px}
.bar-fill{height:100%;border-radius:4px;display:flex;align-items:center;justify-content:flex-end;padding-right:6px;color:white;font-size:11px;font-weight:700;min-width:18px;transition:width .4s}
.bar-count{width:28px;text-align:right;color:#888;font-weight:600;font-size:12px}

/* ── Rating ── */
.rating-row{display:flex;align-items:center;margin-bottom:10px}
.rating-label{width:200px;font-size:12px;color:#555;flex-shrink:0;line-height:1.3}
.rating-bar{flex:1;background:#e8eaf0;height:22px;border-radius:6px;overflow:hidden;margin-right:10px}
.rating-fill{height:100%;border-radius:6px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;color:white;font-weight:700;font-size:11px}
.rating-score{width:36px;font-size:14px;font-weight:800;color:#1a1a2e;text-align:right}

/* ── NPS ── */
.nps-pills{display:flex;gap:16px;justify-content:center;margin-top:12px;font-size:12px}
.nps-pill{text-align:center;min-width:70px}
.nps-pill .nv{font-size:20px;font-weight:800;line-height:1.1}
.nps-pill .nl{color:#94a3b8;font-size:10px;text-transform:uppercase}

/* ── Executive summary ── */
.exec-card{background:white;border-radius:12px;padding:22px 24px;box-shadow:0 2px 8px rgba(0,0,0,.07);margin-bottom:24px}
.exec-card h2{font-size:14px;font-weight:700;color:#4361ee;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.exec-card p{font-size:13px;line-height:1.75;color:#374151;margin-bottom:10px}
.exec-card p:last-child{margin-bottom:0}

/* ── Recommendations ── */
.rec-insight-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:20px}
@media(max-width:800px){.rec-insight-grid{grid-template-columns:1fr}}
.rec-panel,.insight-panel{background:white;border-radius:12px;padding:20px 22px;box-shadow:0 2px 8px rgba(0,0,0,.07)}
.panel-title{font-size:13px;font-weight:700;color:#1a1a2e;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #f0f2f5}
.rec-card{border-left:4px solid #e2e8f0;padding:12px 14px;border-radius:0 8px 8px 0;margin-bottom:12px;background:#fafafa}
.rec-card.high{border-left-color:#ef4444;background:#fff8f8}
.rec-card.medium{border-left-color:#f59e0b;background:#fffdf5}
.rec-card.low{border-left-color:#10b981;background:#f5fffb}
.rec-card:last-child{margin-bottom:0}
.rec-priority{display:inline-flex;align-items:center;gap:4px;border-radius:20px;padding:2px 10px;font-size:10px;font-weight:700;text-transform:uppercase;margin-bottom:7px}
.rec-priority.high{background:#fef2f2;color:#ef4444}
.rec-priority.medium{background:#fffbeb;color:#d97706}
.rec-priority.low{background:#f0fdf4;color:#16a34a}
.rec-action{font-size:12px;font-weight:700;color:#1a1a2e;margin-bottom:5px;line-height:1.4}
.rec-rationale{font-size:11px;color:#6b7280;line-height:1.6}
.rec-impact{font-size:11px;color:#4361ee;font-weight:600;margin-top:5px}
.insight-item{border-left:4px solid #4361ee;padding:10px 14px;margin-bottom:10px;background:#f8f9ff;border-radius:0 8px 8px 0}
.insight-item:last-child{margin-bottom:0}
.insight-item p{font-size:12px;line-height:1.65;color:#374151}

/* ── Conclusion ── */
.conclusion-box{background:linear-gradient(135deg,#f0f4ff,#e8eeff);border:1px solid #c7d2fe;border-radius:12px;padding:22px 24px;margin-bottom:20px}
.conclusion-box h2{font-size:14px;font-weight:700;color:#3730a3;margin-bottom:10px}
.conclusion-box p{font-size:13px;line-height:1.75;color:#374151}

/* ── User prompt watermark ── */
.prompt-box{background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:14px 18px;margin-bottom:20px}
.prompt-label{font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px}
.prompt-text{font-size:12px;color:#64748b;font-style:italic;line-height:1.6}

/* ── Action bar ── */
.action-bar{position:fixed;bottom:24px;right:24px;display:flex;gap:8px;z-index:300}
.action-bar button,.action-bar a{display:flex;align-items:center;gap:6px;border:none;border-radius:50px;padding:10px 20px;font-size:13px;font-weight:600;cursor:pointer;box-shadow:0 4px 14px rgba(0,0,0,.15);transition:all .15s;text-decoration:none}
.action-bar button:hover,.action-bar a:hover{opacity:.88}
.btn-back{background:#f1f5f9;color:#374151}
.btn-print{background:#fff;color:#374151}
.btn-pdf{background:#374151;color:#fff}
.btn-share{background:linear-gradient(135deg,#4361ee,#7c3aed);color:#fff}
.btn-arrange{background:#4361ee;color:#fff}
.btn-arrange.active{background:#10b981}

/* ── Share modal ── */
#shareModal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:10000;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
#shareModal.open{display:flex}
.share-box{background:white;border-radius:20px;padding:28px 28px 24px;max-width:420px;width:90%;box-shadow:0 24px 60px rgba(0,0,0,.2)}
.share-box h3{font-size:17px;font-weight:700;color:#1e293b;margin-bottom:4px}
.share-box p{font-size:13px;color:#64748b;margin-bottom:20px}
.share-qr{display:flex;justify-content:center;margin-bottom:20px}
.share-link-row{display:flex;gap:8px;margin-bottom:16px}
.share-link-input{flex:1;border:1px solid #e2e8f0;border-radius:10px;padding:9px 12px;font-size:12px;color:#374151;background:#f8fafc;outline:none;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.share-actions{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:16px}
.share-btn{border:1px solid #e2e8f0;background:white;border-radius:10px;padding:10px 8px;font-size:12px;font-weight:600;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:5px;color:#374151;transition:all .15s}
.share-btn:hover{background:#f1f5f9}
.share-btn .icon{font-size:20px}
.share-btn.copied{background:#f0fdf4;border-color:#86efac;color:#16a34a}
.share-btn.copied .icon{display:none}
.share-btn.copied .copy-tick{display:block}
.copy-tick{display:none;font-size:20px}
.share-footer{display:flex;justify-content:space-between;align-items:center}
.share-revoke{font-size:12px;color:#ef4444;background:#fef2f2;border:1px solid #fecaca;border-radius:8px;padding:7px 14px;cursor:pointer;font-weight:600}
.share-close{background:#4361ee;color:white;border:none;border-radius:10px;padding:9px 20px;font-size:13px;font-weight:600;cursor:pointer}

/* ── PDF loading ── */
#pdf-loading{display:none;position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:16px;color:white;font-size:15px;font-weight:600;backdrop-filter:blur(3px)}
#pdf-loading.show{display:flex}
.pdf-spinner{width:44px;height:44px;border:4px solid rgba(255,255,255,.3);border-top-color:white;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── Focused mode highlight ── */
.focused-banner{background:#f0f4ff;border-left:4px solid #4361ee;border-radius:0 10px 10px 0;padding:14px 18px;margin:20px 0 8px;font-size:13px;line-height:1.7;color:#374151}

<% if @public_view %>
.cw-gear,.card-toolbar,.cw-mode-bar,.restore-bar,.section-controls,
.rh-right,.rh-bottom,.rh-corner,.btn-sec-drag,.btn-sec-hide,
#shareModal,.btn-share,.btn-arrange,.btn-back{display:none!important}
<% end %>

@media print{
  .action-bar,.header-lang-switcher,#shareModal,#pdf-loading,
  .cw-gear,.card-toolbar,.cw-mode-bar,.restore-bar,.section-controls,
  .rh-right,.rh-bottom,.rh-corner{display:none!important}
  body{background:white}
  .header{-webkit-print-color-adjust:exact;print-color-adjust:exact}
  @page{size:A4 landscape;margin:10mm 12mm}
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  .card{box-shadow:none!important;border:1px solid #e2e8f0!important;break-inside:avoid}
  canvas{max-height:200px;break-inside:avoid}
  .cw{break-inside:avoid}
  .grid-2{break-inside:auto}
  .report-section{break-inside:auto;margin-bottom:6mm}
}
</style>
</head>
<body>

<%
  hdr_sub_default = rpt_sub.present? ? rpt_sub : "#{@survey.title} · #{@total_responses rescue @ai_result.response_count} phản hồi"
%>
<div class="header">
  <div class="header-lang-switcher">
    <button class="lang-btn active" id="langVI" onclick="setLang('vi')">🇻🇳 VI</button>
    <button class="lang-btn" id="langEN" onclick="setLang('en')">🇬🇧 EN</button>
  </div>
  <h1>
    <span class="hdr-editable" id="hdrTitleWrap" onclick="startHdrEdit('title')" title="Click để chỉnh sửa tiêu đề">
      <span class="hdr-text" id="hdrTitleText"><%= rpt_title %></span>
      <svg class="hdr-edit-icon" width="16" height="16" viewBox="0 0 20 20" fill="none"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
      <input class="hdr-input title-input" id="hdrTitleInput" type="text" value="<%= j rpt_title %>" onblur="endHdrEdit('title')" onkeydown="hdrKey(event,'title')">
    </span>
  </h1>
  <p>
    <span class="hdr-editable" id="hdrSubWrap" onclick="startHdrEdit('sub')" title="Click để chỉnh sửa mô tả">
      <span class="hdr-text" id="hdrSubText"><%= hdr_sub_default %></span>
      <svg class="hdr-edit-icon" width="13" height="13" viewBox="0 0 20 20" fill="none"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
      <input class="hdr-input sub-input" id="hdrSubInput" type="text" value="<%= j hdr_sub_default %>" onblur="endHdrEdit('sub')" onkeydown="hdrKey(event,'sub')">
    </span>
  </p>
  <% if meta["generated_at"].present? %>
  <p style="margin-top:4px;font-size:11px;opacity:.4">Tạo lúc: <%= Time.parse(meta["generated_at"]).in_time_zone.strftime("%H:%M %d/%m/%Y") rescue meta["generated_at"] %></p>
  <% end %>
</div>

<%# ── Helper lambda: render single chart card (wrapped in .cw) ── %>
<% render_chart = ->(c, idx) do
  cd      = c["data"] || {}
  xt      = c["cross_tab_data"]
  qtype   = cd["type"].to_s
  opts    = cd["options"] || []
  dist    = cd["distribution"] || []
  total   = cd["total"].to_i
  avg_v   = cd["avg"]
  max_v   = cd["max"].to_f
  sub     = cd["subtype"].to_s
  insight = c["insight"].to_s
  chid    = "ch_#{idx}"
  vtype   = c["chart_type"].to_s.presence || begin
    if xt.present? then "grouped_bar"
    elsif qtype == "nps" then "nps"
    elsif qtype == "rating" then "rating_dist"
    elsif qtype == "linear_scale" || sub == "pct" then "dist_bar"
    elsif %w[single_choice dropdown].include?(qtype) && opts.size <= 6 then "doughnut"
    elsif %w[single_choice dropdown multiple_choice].include?(qtype) then "hbar"
    else "dist_bar"
    end
  end
  is_full  = c["span"] == "full" || %w[grouped_bar dist_bar hbar quotes].include?(vtype) || opts.size > 6
  col_span = is_full ? 12 : 6
  card_title = (c["title"].presence || cd["question"].to_s).truncate(90)
%>
<div class="cw" data-cid="<%= chid %>" style="grid-column:span <%= col_span %>">
  <div class="card-toolbar">
    <button class="ct-mode-btn" onclick="setCwMode(this,'text')"><span class="icon">✏️</span>Sửa nội dung</button>
    <button class="ct-mode-btn" onclick="setCwMode(this,'resize')"><span class="icon">⤢</span>Thay đổi kích thước</button>
    <button class="ct-mode-btn" onclick="setCwMode(this,'move')"><span class="icon">⠿</span>Di chuyển</button>
    <div class="ct-divider"></div>
    <button class="ct-mode-btn danger" onclick="hideCard('<%= chid %>')"><span class="icon">👁</span>Ẩn block này</button>
  </div>
  <div class="card">
    <h3><span data-editable contenteditable="false"><%= card_title %></span><button class="cw-gear" onclick="toggleCardMenu(this)">⚙</button></h3>

    <% if vtype == "grouped_bar" && xt.present? && xt["groups"].present? %>
      <% xt_groups = xt["groups"]; xt_pct = xt["max"].to_i >= 50 %>
      <canvas id="<%= chid %>"></canvas>
      <script>(function(){
        var labels=<%= raw xt_groups.map{|g| g["label"].to_s}.to_json %>;
        var values=<%= raw xt_groups.map{|g|(g["avg"]||g["pct"]||0).to_f}.to_json %>;
        var pct=<%= raw xt_pct ? 'true':'false' %>;
        var clrs=<%= raw palette.cycle.first(xt_groups.size).to_json %>;
        mkChart('<%= chid %>',{type:'bar',data:{labels:labels,datasets:[{data:values,backgroundColor:clrs,borderRadius:5,borderSkipped:false}]},
          options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},
            datalabels:{anchor:'end',align:'right',offset:4,font:{size:12,weight:'700'},color:'#374151',formatter:function(v){return pct?v+'%':v;}}},
            scales:{x:{beginAtZero:true,ticks:{callback:function(v){return pct?v+'%':v;}},grid:{color:'#f3f4f6'}},y:{ticks:{font:{size:11}}}},
            layout:{padding:{right:44}}},plugins:[ChartDataLabels]});
      })();</script>
      <div style="margin-top:10px;display:flex;flex-wrap:wrap;gap:10px">
        <% xt_groups.each do |g| %><span style="font-size:11px;color:#94a3b8"><%= g["label"] %>: <strong style="color:#374151"><%= g["total"]||"?" %></strong> phản hồi</span><% end %>
      </div>

    <% elsif vtype == "doughnut" && opts.any? %>
      <canvas id="<%= chid %>"></canvas>
      <script>(function(){
        var l=<%= raw opts.map{|o|o["label"].to_s}.to_json %>;
        var d=<%= raw opts.map{|o|o["count"].to_i}.to_json %>;
        mkChart('<%= chid %>',{type:'doughnut',data:{labels:l,datasets:[{data:d,backgroundColor:C.slice(0,l.length),borderWidth:2,borderColor:'#fff'}]},
          options:{responsive:true,plugins:{legend:{position:'right',labels:{font:{size:11},padding:10}},
            datalabels:{color:'#fff',font:{weight:'bold',size:10},display:ctx=>{var s=ctx.chart.data.datasets[0].data.reduce((a,b)=>a+b,0);return s>0&&ctx.dataset.data[ctx.dataIndex]/s>0.04;},
              formatter:(v,ctx)=>{var s=ctx.chart.data.datasets[0].data.reduce((a,b)=>a+b,0);return s>0?Math.round(v/s*100)+'%':'';}}},plugins:[ChartDataLabels]});
      })();</script>

    <% elsif vtype == "hbar" && opts.any? %>
      <% opts.sort_by{|o|-o["count"].to_i}.each_with_index do |o,oi| %>
      <div class="bar-item">
        <span class="bar-label" title="<%= o['label'] %>"><%= o["label"].to_s.truncate(32) %></span>
        <div class="bar-track"><div class="bar-fill" style="width:<%= o['pct'].to_f.clamp(0,100) %>%;background:<%= palette[oi%palette.size] %>"><%= o["pct"].to_f>8 ? "#{o['pct'].round(1)}%" : "" %></div></div>
        <span class="bar-count"><%= o["count"] %></span>
      </div>
      <% end %>

    <% elsif vtype == "dist_bar" && dist.any? %>
      <canvas id="<%= chid %>"></canvas>
      <script>(function(){
        var l=<%= raw dist.map{|d|d["value"].to_s}.to_json %>;
        var d=<%= raw dist.map{|d|d["count"].to_i}.to_json %>;
        mkChart('<%= chid %>',{type:'bar',data:{labels:l,datasets:[{data:d,backgroundColor:'#4361ee',borderRadius:4}]},
          options:{responsive:true,plugins:{legend:{display:false},datalabels:{anchor:'end',align:'top',offset:2,font:{size:11,weight:'700'},color:'#444',formatter:v=>v>0?v:''}},
            scales:{y:{beginAtZero:true,ticks:{precision:0}},x:{ticks:{font:{size:10}}}},layout:{padding:{top:20}}},plugins:[ChartDataLabels]});
      })();</script>
      <% if avg_v %><div style="margin-top:10px;text-align:center;font-size:12px;color:#6b7280">Trung bình: <strong style="color:#4361ee;font-size:15px"><%= avg_v %><%= '%' if sub=='pct' %></strong></div><% end %>

    <% elsif vtype == "nps" && dist.any? %>
      <canvas id="<%= chid %>"></canvas>
      <script>(function(){
        var l=<%= raw dist.map{|d|d["value"].to_s}.to_json %>;
        var d=<%= raw dist.map{|d|d["count"].to_i}.to_json %>;
        var clrs=l.map(function(v){var n=parseInt(v);return n>=9?'#10b981':n>=7?'#06b6d4':'#ef4444';});
        mkChart('<%= chid %>',{type:'bar',data:{labels:l,datasets:[{data:d,backgroundColor:clrs,borderRadius:4}]},
          options:{responsive:true,plugins:{legend:{display:false},datalabels:{anchor:'end',align:'top',offset:2,font:{size:12,weight:'700'},color:'#444',formatter:v=>v>0?v:''}},
            scales:{y:{beginAtZero:true,ticks:{precision:0}},x:{ticks:{font:{size:11}}}},layout:{padding:{top:20}}},plugins:[ChartDataLabels]});
      })();</script>
      <% pro=dist.select{|d|d["value"].to_i>=9}.sum{|d|d["count"].to_i}
         pas=dist.select{|d|[7,8].include?(d["value"].to_i)}.sum{|d|d["count"].to_i}
         det=dist.select{|d|d["value"].to_i<=6}.sum{|d|d["count"].to_i}
         sc=total>0 ? ((pro-det).to_f/total*100).round(0) : 0 %>
      <div class="nps-pills">
        <div class="nps-pill"><div class="nv" style="color:#4361ee"><%= sc %>%</div><div class="nl">Điểm hài lòng</div></div>
        <div class="nps-pill"><div class="nv" style="color:#10b981"><%= pro %></div><div class="nl">Hài lòng cao</div></div>
        <div class="nps-pill"><div class="nv" style="color:#06b6d4"><%= pas %></div><div class="nl">Trung lập</div></div>
        <div class="nps-pill"><div class="nv" style="color:#ef4444"><%= det %></div><div class="nl">Không hài lòng</div></div>
        <% if avg_v %><div class="nps-pill"><div class="nv" style="color:#f59e0b"><%= avg_v %></div><div class="nl">Điểm TB</div></div><% end %>
      </div>

    <% elsif vtype == "rating_dist" && dist.any? %>
      <% max_s=max_v>0?max_v:5.0; dist.each_with_index do |d,di| %>
      <% cnt=d["count"].to_i; pct_v=total>0?(cnt.to_f/total*100).round(1):0 %>
      <div class="rating-row">
        <div class="rating-label"><%= d["value"] %></div>
        <div class="rating-bar"><div class="rating-fill" style="width:<%= pct_v.clamp(0,100) %>%;background:<%= palette[di%palette.size] %>"><%= cnt>0?cnt:'' %></div></div>
        <div class="rating-score"><%= pct_v %>%</div>
      </div>
      <% end %>
      <% if avg_v %><div style="margin-top:10px;font-size:12px;color:#6b7280">Trung bình: <strong style="color:#4361ee"><%= avg_v %></strong> / <%= max_s.to_i %></div><% end %>

    <% elsif vtype == "number" %>
      <div style="text-align:center;padding:24px 0">
        <div style="font-size:52px;font-weight:800;color:#4361ee;line-height:1"><%= avg_v || total %></div>
        <div style="font-size:11px;color:#94a3b8;font-weight:600;margin-top:8px;text-transform:uppercase"><%= total %> phản hồi</div>
      </div>

    <% elsif vtype == "quotes" %>
      <% texts = cd["texts"] || [] %>
      <% texts.first(6).each do |t| %>
      <div style="border-left:3px solid #e0e7ff;padding:8px 12px;margin-bottom:10px;font-size:12px;color:#374151;line-height:1.65;font-style:italic">"<%= t.to_s.truncate(200) %>"</div>
      <% end %>

    <% else %>
      <p style="color:#9ca3af;text-align:center;padding:32px 0;font-size:13px">Chưa có dữ liệu</p>
    <% end %>

    <% if insight.present? %><div class="insight-box">💡 <%= insight %></div><% end %>
  </div><%# /card %>
</div><%# /cw %>
<% end %>

<div class="container">

<%# ── Restore bar ── %>
<div class="restore-bar" id="restoreBar"><span>Đã ẩn:</span></div>

<%# ── Focused mode: insight banner ── %>
<% if focused_mode && data["focused_insight"].present? %>
<div class="focused-banner">📊 <%= data["focused_insight"] %></div>
<% end %>

<%# ── Full mode: KPI + exec summary ── %>
<% unless focused_mode %>
<div class="kpi-grid" style="margin-top:24px">
  <div class="kpi" style="border-color:#4361ee">
    <div class="kpi-value" style="color:#4361ee"><%= data["response_count"] || (responses.count rescue @ai_result.response_count) rescue "—" %></div>
    <div class="kpi-label">Người tham gia</div>
  </div>
</div>
<% if exec_sum.present? %>
<div class="exec-card" style="margin-top:20px">
  <h2>📋 Tóm tắt điều hành</h2>
  <% exec_sum.split(/\n\n+/).each do |para| %><% next if para.strip.empty? %><p><%= para.strip %></p><% end %>
</div>
<% end %>
<% end %>

<%# ── Sections + Charts ── %>
<div id="sortableContainer">
<% chart_idx = 0 %>
<% sections.each_with_index do |sec, sidx| %>
  <% charts = sec["charts"] || [] %>
  <% next if charts.empty? %>
  <% sid = "s_#{sidx}" %>
  <% sec_title = sec["title"].to_s %>

  <div class="report-section" data-id="<%= sid %>">
    <% if !focused_mode || sections.size > 1 %>
    <div class="section-header">
      <div class="section-controls">
        <span class="btn-sec-drag">⠿</span>
        <button class="btn-sec-hide" onclick="hideSection('<%= sid %>','<%= j sec_title %>')">Ẩn section</button>
      </div>
      <div class="section-title"><%= sec_title %></div>
    </div>
    <% end %>

    <div class="grid-2" id="grid-<%= sid %>">
      <% charts.each do |c| %>
        <% render_chart.call(c, chart_idx); chart_idx += 1 %>
      <% end %>
    </div>

    <% if sec["insight"].present? && !focused_mode %>
    <div class="insight-box" style="margin-bottom:20px;margin-top:4px">💡 <%= sec["insight"] %></div>
    <% end %>
  </div>
<% end %>
</div><%# /sortableContainer %>

<%# ── Recommendations ── %>
<% if recs.any? && !focused_mode %>
<div style="margin-top:28px;margin-bottom:16px;font-size:16px;font-weight:700;color:#1a1a2e;display:flex;align-items:center;gap:10px">
  <span style="display:block;width:4px;height:20px;background:#4361ee;border-radius:2px"></span>Đề xuất & Khuyến nghị
</div>
<div class="rec-insight-grid">
  <div class="rec-panel">
    <div class="panel-title">Khuyến nghị hành động</div>
    <% recs.sort_by{|r| {"high"=>0,"medium"=>1,"low"=>2}[r["priority"].to_s]||9}.each do |rec| %>
    <div class="rec-card <%= rec['priority'] %>">
      <div class="rec-priority <%= rec['priority'] %>"><%= rec["priority"]=="high" ? "🔴 Ưu tiên cao" : rec["priority"]=="medium" ? "🟡 Trung bình" : "🟢 Thấp" %></div>
      <div class="rec-action"><%= rec["action"] %></div>
      <% if rec["rationale"].present? %><div class="rec-rationale"><%= rec["rationale"] %></div><% end %>
      <% if rec["expected_impact"].present? %><div class="rec-impact">→ <%= rec["expected_impact"] %></div><% end %>
    </div>
    <% end %>
  </div>
  <div class="insight-panel">
    <div class="panel-title">Insights từ dữ liệu</div>
    <% sections.each do |sec| %>
      <% next unless sec["insight"].present? %>
      <div class="insight-item"><p><%= sec["insight"] %></p></div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── Conclusion ── %>
<% if conclusion.present? && !focused_mode %>
<div class="conclusion-box">
  <h2>Kết luận</h2>
  <% conclusion.split(/\n\n+/).each do |para| %><% next if para.strip.empty? %><p><%= para.strip %></p><% end %>
</div>
<% end %>

<%# ── Prompt watermark ── %>
<% if meta["user_context"].present? %>
<div class="prompt-box">
  <div class="prompt-label">Prompt của bạn</div>
  <div class="prompt-text">"<%= meta["user_context"] %>"</div>
</div>
<% end %>

</div><%# /container %>

<%# ── Share modal ── %>
<% unless @public_view %>
<div id="shareModal">
  <div class="share-box">
    <h3>🔗 Chia sẻ báo cáo AI</h3>
    <p>Ai có link này đều có thể xem báo cáo mà không cần đăng nhập</p>
    <div class="share-qr" id="shareQrWrap"><div id="shareQrDiv"></div></div>
    <div class="share-link-row">
      <input class="share-link-input" id="shareLinkInput" readonly type="text" value="Đang tạo link...">
    </div>
    <div class="share-actions">
      <button id="btn-copy-link" class="share-btn" onclick="copyShareLink(this)"><span class="icon">📋</span><span class="copy-tick">✅</span>Copy link</button>
      <button id="btn-copy-qr"   class="share-btn" onclick="copyQrImage(this)"><span class="icon">🖼</span><span class="copy-tick">✅</span>Copy QR</button>
      <button class="share-btn" onclick="downloadQr()"><span class="icon">⬇️</span>Tải QR</button>
    </div>
    <div class="share-footer">
      <button class="share-revoke" onclick="revokeShareLink()">🗑 Thu hồi link</button>
      <button class="share-close" onclick="closeShareModal()">Đóng</button>
    </div>
  </div>
</div>
<% end %>

<%# ── PDF loading overlay ── %>
<div id="pdf-loading">
  <div class="pdf-spinner"></div>
  <span>Đang tạo PDF, vui lòng chờ...</span>
</div>

<%# ── Action bar ── %>
<div class="action-bar" id="actionBar">
  <% unless @public_view %>
    <button class="btn-share" onclick="openShareModal()">🔗 Chia sẻ</button>
  <% end %>
  <button class="btn-print" onclick="window.print()">🖨️ In</button>
  <button class="btn-pdf" onclick="downloadPdf()">⬇ Tải PDF</button>
  <% unless @public_view %>
    <button class="btn-arrange" id="btnArrange" onclick="toggleArrangeMode()">⠿ Sắp xếp</button>
    <a href="<%= results_survey_path(@survey, tab: 'report') %>" class="btn-back" style="text-decoration:none">← Quay lại</a>
  <% end %>
</div>

<script>
// ── i18n ──
const T = {
  vi: { ai_badge:'✨ Báo cáo AI', back:'Quay lại', print:'In', download_pdf:'Tải PDF' },
  en: { ai_badge:'✨ AI Report',  back:'Back',      print:'Print', download_pdf:'Download PDF' }
};
let lang = '<%= I18n.locale %>';
function t(k) { return (T[lang]||T.vi)[k] || k; }
function setLang(l) {
  lang = l; localStorage.setItem('report_lang', l);
  document.getElementById('langVI')?.classList.toggle('active', lang==='vi');
  document.getElementById('langEN')?.classList.toggle('active', lang==='en');
}
(function(){ const s = localStorage.getItem('report_lang'); if (s && T[s]) lang = s;
  document.getElementById('langVI')?.classList.toggle('active', lang==='vi');
  document.getElementById('langEN')?.classList.toggle('active', lang==='en');
})();

// ── PDF download (fetch → blob → dismiss loading) ──
async function downloadPdf() {
  deactivateAllCards();
  const overlay = document.getElementById('pdf-loading');
  overlay.classList.add('show');
  try {
    const resp = await fetch('<%= export_report_survey_path(@survey, report_id: @ai_result.id, format_type: "pdf") %>', {
      method: 'GET',
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const blob = await resp.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = resp.headers.get('Content-Disposition')
                   ?.match(/filename="?([^";\n]+)"?/)?.[1] || 'ai-report.pdf';
    document.body.appendChild(a);
    a.click();
    setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 1000);
  } catch(err) {
    alert('Không thể tạo PDF: ' + (err.message || 'Lỗi không xác định'));
  } finally {
    overlay.classList.remove('show');
  }
}

// ── Arrange (edit) mode toggle ──
let arrangeMode = false;
function toggleArrangeMode() {
  arrangeMode = !arrangeMode;
  document.body.classList.toggle('edit-mode', arrangeMode);
  const btn = document.getElementById('btnArrange');
  if (btn) {
    btn.classList.toggle('active', arrangeMode);
    btn.textContent = arrangeMode ? '✓ Xong' : '⠿ Sắp xếp';
  }
}

// ── Card activation ──
let activeCw = null;
function activateCard(cw) {
  deactivateAllCards();
  cw.classList.add('cw-active');
  activeCw = cw;
}
function deactivateAllCards() {
  document.querySelectorAll('.cw-active').forEach(cw => cw.classList.remove('cw-active'));
  activeCw = null;
}

function toggleCardMenu(el) {
  const cw = el.closest('.cw');
  if (!cw) return;
  const hasMode = cw.classList.contains('cw-resize-mode') || cw.classList.contains('cw-text-mode') || cw.classList.contains('cw-move-mode');
  if (cw.classList.contains('cw-active')) {
    deactivateAllCards();
  } else if (hasMode) {
    deactivateAllCards(); activateCard(cw);
  } else {
    activateCard(cw);
  }
}

// ── Mode switching ──
function setCwMode(btn, mode) {
  if (!btn) return;
  const cw = btn.closest('.cw');
  if (!cw) return;
  const modeClass = 'cw-' + mode + '-mode';
  const wasActive = btn.classList.contains('active');
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('[data-editable]').forEach(el => { el.contentEditable = 'false'; });
  if (!wasActive) {
    cw.classList.add(modeClass);
    btn.classList.add('active');
    cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
    const lbl = cw.querySelector('.lbl-' + (mode==='resize'?'resize':mode==='move'?'move':'text'));
    if (lbl) lbl.style.display = '';
    if (mode === 'text') {
      cw.querySelectorAll('[data-editable]').forEach(el => { el.contentEditable = 'true'; });
    }
  }
  cw.classList.remove('cw-active');
  activeCw = null;
}

function cancelMode(e, btn) {
  e.stopPropagation(); e.preventDefault();
  const cw = btn.closest('.cw');
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('[data-editable]').forEach(el => { el.contentEditable = 'false'; });
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
}

// Click outside → close active card menu
document.addEventListener('mousedown', e => {
  if (rd) return; // ignore during resize drag
  if (e.target.closest('.cw-gear')) return;
  if (e.target.closest('[data-dir]')) return; // resize handle
  if (!e.target.closest('.cw-active')) deactivateAllCards();
});

// ── Hide card ──
function getCardTitle(el) {
  const h3 = el.querySelector('h3');
  if (!h3) return '';
  return [...h3.childNodes].filter(n => n.nodeType === 3).map(n => n.textContent).join('').trim()
      || h3.querySelector('[data-editable]')?.textContent?.trim() || '';
}
function hideCard(cid) {
  deactivateAllCards();
  const el = document.querySelector(`[data-cid="${cid}"]`);
  if (!el) return;
  const label = getCardTitle(el) || cid;
  el.classList.add('hidden-section');
  addRestoreChip(cid, label, 'card');
  autoHideEmptySections();
}

// ── Auto-hide empty sections ──
function autoHideEmptySections() {
  document.querySelectorAll('.report-section:not(.hidden-section)').forEach(sec => {
    const allCards = sec.querySelectorAll('.cw');
    if (allCards.length === 0) return;
    const allHidden = [...allCards].every(cw => cw.classList.contains('hidden-section'));
    if (allHidden) {
      const sid = sec.dataset.id;
      const secText = sec.querySelector('.section-title')?.textContent?.trim();
      const firstCard = sec.querySelector('[data-editable]')?.textContent?.trim();
      const label = secText || firstCard || 'Section';
      sec.classList.add('hidden-section');
      addRestoreChip(sid, label, 'section');
    }
  });
}

// ── Hide/show section ──
function hideSection(sid, label) {
  const el = document.querySelector(`[data-id="${sid}"]`);
  if (el) el.classList.add('hidden-section');
  addRestoreChip(sid, label, 'section');
}
function addRestoreChip(id, label, type) {
  const bar = document.getElementById('restoreBar');
  if (!bar || bar.querySelector(`[data-restore="${id}"]`)) return;
  const btn = document.createElement('button');
  btn.className = 'btn-restore';
  btn.setAttribute('data-restore', id);
  btn.textContent = '👁 ' + label;
  btn.onclick = () => {
    const sel = type === 'card' ? `[data-cid="${id}"]` : `[data-id="${id}"]`;
    const el = document.querySelector(sel);
    if (el) {
      el.classList.remove('hidden-section');
      if (type === 'card') {
        const sec = el.closest('.report-section');
        if (sec && sec.classList.contains('hidden-section')) {
          sec.classList.remove('hidden-section');
          const secChip = document.querySelector(`[data-restore="${sec.dataset.id}"]`);
          if (secChip) secChip.remove();
        }
      }
    }
    btn.remove();
    updateRestoreBar();
  };
  bar.appendChild(btn);
  updateRestoreBar();
}
function updateRestoreBar() {
  const bar = document.getElementById('restoreBar');
  if (bar) bar.classList.toggle('has-hidden', bar.querySelectorAll('.btn-restore').length > 0);
}

// ── Inject mode-bar + resize handles (same as html_report) ──
document.querySelectorAll('.cw').forEach(cw => {
  const h3 = cw.querySelector('.card h3');
  if (h3) {
    // Insert mode-bar BEFORE gear so order is: [title][mode-bar][gear]
    const gear = h3.querySelector('.cw-gear');
    const modeBarHtml =
      '<div class="cw-mode-bar">' +
        '<span class="mode-label">' +
          '<span class="lbl-text"  style="display:none">✏️ Đang sửa</span>' +
          '<span class="lbl-resize" style="display:none">⤡ Kích thước</span>' +
          '<span class="lbl-move"  style="display:none">⠿ Di chuyển</span>' +
        '</span>' +
        '<button class="btn-done" onclick="cancelMode(event,this)">✓ Xong</button>' +
      '</div>';
    if (gear) gear.insertAdjacentHTML('beforebegin', modeBarHtml);
    else h3.insertAdjacentHTML('beforeend', modeBarHtml);
  }
  cw.insertAdjacentHTML('beforeend',
    '<div class="rh-right"  data-dir="e"><div class="rh-right-bar"></div></div>' +
    '<div class="rh-bottom" data-dir="s"><div class="rh-bottom-bar"></div></div>' +
    '<div class="rh-corner" data-dir="se"></div>' +
    '<div class="snap-guide"></div>'
  );
});

// ── Resize drag (same as html_report) ──
const tip = document.createElement('div');
tip.className = 'resize-tip';
document.body.appendChild(tip);
let rd = null, rafId = null, latestE = null;

document.addEventListener('mousedown', e => {
  const handle = e.target.closest('[data-dir]');
  if (!handle) return;
  console.log('[resize] handle clicked, dir=', handle.dataset.dir, 'target=', e.target);
  const cw = handle.closest('.cw');
  console.log('[resize] cw classes=', cw?.className);
  if (!cw?.classList.contains('cw-resize-mode')) { console.log('[resize] BLOCKED: no cw-resize-mode'); return; }
  e.preventDefault(); e.stopPropagation();
  const grid = cw.parentElement;
  const dir = handle.dataset.dir;
  const startSpan = parseInt(cw.style.gridColumn?.match(/span (\d+)/)?.[1] || 6);
  const startH = cw.querySelector('.card')?.offsetHeight || 240;
  const gridRect = grid.getBoundingClientRect();
  handle.classList.add('dragging');
  cw.classList.add('is-resizing');
  rd = { cw, handle, dir, gridRect, startH, startSpan, startY: e.clientY, _span: startSpan, _h: startH };
  document.body.style.userSelect = 'none';
  document.body.style.cursor = dir === 'e' ? 'ew-resize' : dir === 's' ? 'ns-resize' : 'nwse-resize';
  tip.classList.add('visible');
});

document.addEventListener('mousemove', e => {
  if (!rd) return;
  latestE = e;
  if (!rafId) rafId = requestAnimationFrame(applyResize);
}, { passive: true });

function applyResize() {
  rafId = null;
  if (!rd || !latestE) return;
  const e = latestE;
  const { cw, dir, gridRect, startH, startY } = rd;
  const card = cw.querySelector('.card');
  const MAXCOLS = 12;
  if (dir === 'e' || dir === 'se') {
    const colW = gridRect.width / MAXCOLS;
    const newSpan = Math.max(1, Math.min(MAXCOLS, Math.round((e.clientX - gridRect.left) / colW)));
    if (newSpan !== rd._span) { cw.style.gridColumn = `span ${newSpan}`; rd._span = newSpan; }
  }
  if (dir === 's' || dir === 'se') {
    const newH = Math.max(120, startH + (e.clientY - startY));
    if (card && Math.abs(newH - (rd._h || 0)) > 2) { card.style.minHeight = newH + 'px'; card.style.height = newH + 'px'; rd._h = newH; }
  }
  const parts = [];
  if (dir !== 's') parts.push(`${rd._span}/12`);
  if (dir !== 'e') parts.push(`${Math.round(rd._h || startH)}px`);
  tip.textContent = parts.join(' · ');
  tip.style.left = e.clientX + 'px'; tip.style.top = e.clientY + 'px';
}

document.addEventListener('mouseup', () => {
  if (!rd) return;
  rd.handle.classList.remove('dragging');
  rd.cw.classList.remove('is-resizing');
  document.body.style.cursor = ''; document.body.style.userSelect = '';
  tip.classList.remove('visible');
  rd = null; latestE = null; rafId = null;
});

// ── SortableJS: sections drag ──
<% unless @public_view %>
if (typeof Sortable !== 'undefined') {
  Sortable.create(document.getElementById('sortableContainer'), {
    handle: '.btn-sec-drag',
    animation: 150,
    ghostClass: 'sortable-ghost',
    chosenClass: 'sortable-chosen',
  });
  // Card drag within each grid
  document.querySelectorAll('.grid-2').forEach(grid => {
    Sortable.create(grid, {
      handle: '.cw-move-mode .mode-label',
      group: 'cards',
      animation: 150,
      ghostClass: 'sortable-ghost',
      chosenClass: 'sortable-chosen',
      filter: '.cw:not(.cw-move-mode)',
    });
  });
}
<% end %>

// ── Share modal ──
async function openShareModal() {
  document.getElementById('shareModal').classList.add('open');
  document.getElementById('shareLinkInput').value = 'Đang tạo link...';
  document.getElementById('shareQrDiv').innerHTML = '<div style="width:180px;height:180px;margin:0 auto;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:12px;">Đang tạo QR...</div>';
  try {
    const resp = await fetch('<%= generate_ai_report_token_survey_path(@survey, report_id: @ai_result.id) %>', {
      method: 'POST', headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]')?.content || '' }
    });
    const data = await resp.json();
    document.getElementById('shareLinkInput').value = data.url || '';
    document.getElementById('shareQrDiv').innerHTML = data.qr_svg || '';
  } catch(e) { document.getElementById('shareLinkInput').value = 'Lỗi tạo link'; }
}
function closeShareModal() { document.getElementById('shareModal').classList.remove('open'); }
async function copyShareLink(btn) {
  const url = document.getElementById('shareLinkInput').value;
  if (!url || url.startsWith('Đang') || url.startsWith('Lỗi')) return;
  try { await navigator.clipboard.writeText(url); } catch(e) { const i = document.getElementById('shareLinkInput'); i.select(); document.execCommand('copy'); }
  if (btn) { btn.classList.add('copied'); setTimeout(() => btn.classList.remove('copied'), 2000); }
}
async function copyQrImage(btn) {
  const svg = document.querySelector('#shareQrDiv svg'); if (!svg) return;
  try {
    const canvas = document.createElement('canvas'); canvas.width=220; canvas.height=220;
    const ctx = canvas.getContext('2d'); const img = new Image();
    img.onload = async () => { ctx.drawImage(img,0,0,220,220); canvas.toBlob(async b => { await navigator.clipboard.write([new ClipboardItem({'image/png':b})]); if(btn){btn.classList.add('copied');setTimeout(()=>btn.classList.remove('copied'),2000);} }); };
    img.src = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svg.outerHTML)));
  } catch(e){}
}
function downloadQr() {
  const svg = document.querySelector('#shareQrDiv svg'); if (!svg) return;
  const a = document.createElement('a'); a.download='qr-ai-report.svg';
  a.href='data:image/svg+xml;base64,'+btoa(unescape(encodeURIComponent(svg.outerHTML))); a.click();
}
async function revokeShareLink() {
  if (!confirm('Thu hồi link chia sẻ? Người đang giữ link sẽ không xem được nữa.')) return;
  await fetch('<%= revoke_ai_report_token_survey_path(@survey) %>', {
    method:'DELETE', headers:{'X-CSRF-Token':document.querySelector('meta[name=csrf-token]')?.content||''}
  });
  document.getElementById('shareLinkInput').value = 'Link đã bị thu hồi';
  document.getElementById('shareQrDiv').innerHTML = '';
}
document.getElementById('shareModal')?.addEventListener('click', e => { if (e.target===document.getElementById('shareModal')) closeShareModal(); });

// ── Header edit ──
function startHdrEdit(which) {
  const wrap  = document.getElementById(which==='title' ? 'hdrTitleWrap' : 'hdrSubWrap');
  const input = document.getElementById(which==='title' ? 'hdrTitleInput' : 'hdrSubInput');
  if (!wrap || !input) return;
  wrap.classList.add('editing');
  input.style.width = '';
  input.focus(); input.select();
}
function endHdrEdit(which) {
  const wrap  = document.getElementById(which==='title' ? 'hdrTitleWrap' : 'hdrSubWrap');
  const text  = document.getElementById(which==='title' ? 'hdrTitleText' : 'hdrSubText');
  const input = document.getElementById(which==='title' ? 'hdrTitleInput' : 'hdrSubInput');
  if (!wrap || !text || !input) return;
  wrap.classList.remove('editing');
  const val = input.value.trim();
  if (val) text.textContent = val;
  else input.value = text.textContent;
}
function hdrKey(e, which) {
  if (e.key === 'Enter') { e.preventDefault(); endHdrEdit(which); }
  if (e.key === 'Escape') {
    const wrap  = document.getElementById(which==='title' ? 'hdrTitleWrap' : 'hdrSubWrap');
    const text  = document.getElementById(which==='title' ? 'hdrTitleText' : 'hdrSubText');
    const input = document.getElementById(which==='title' ? 'hdrTitleInput' : 'hdrSubInput');
    if (input && text) input.value = text.textContent;
    wrap?.classList.remove('editing');
  }
}
</script>
</body>
</html>
