</div>
<% end %>

<%# ── PDF loading overlay ── %>
<div id="pdf-loading">
  <div class="pdf-spinner"></div>
  <span>Đang tạo PDF, vui lòng chờ...</span>
</div>

<%# ── Action bar ── %>
<div class="action-bar" id="actionBar">
  <% unless @public_view %>
    <button class="btn-share" onclick="openShareModal()">🔗 Chia sẻ</button>
  <% end %>
  <button class="btn-print" onclick="window.print()">🖨️ In</button>
  <button class="btn-pdf" onclick="downloadPdf()">⬇ Tải PDF</button>
  <% unless @public_view %>
    <button class="btn-arrange" id="btnArrange" onclick="toggleArrangeMode()">⠿ Sắp xếp</button>
    <a href="<%= results_survey_path(@survey, tab: 'report') %>" class="btn-back" style="text-decoration:none">← Quay lại</a>
  <% end %>
</div>

<% unless @pdf_preview %>
<button class="pdf-preview-tab" id="pdfPreviewTab" onclick="togglePdfPreview()" title="Xem trước PDF">
  <span class="pdf-preview-tab-icon">👁</span>
  <span class="pdf-preview-tab-text">XEM TRƯỚC PDF</span>
  <span class="pdf-preview-tab-badge">LIVE</span>
</button>
<div class="pdf-drawer" id="pdfDrawer">
  <div class="pdf-drawer-hdr">
    <div class="pdf-drawer-hdr-left">
      <span>👁 Xem trước PDF</span>
      <span class="pdf-drawer-badge">LIVE</span>
    </div>
    <button class="pdf-drawer-close" onclick="togglePdfPreview()">✕ Đóng</button>
  </div>
  <div class="pdf-drawer-toolbar">
    <span class="pdf-drawer-hint">Preview tự cập nhật khi thay đổi</span>
    <button onclick="openPdfFullscreen('A4')" class="pdf-size-btn">A4</button>
    <button onclick="openPdfFullscreen('A3')" class="pdf-size-btn">A3</button>
    <button onclick="downloadPdf()" style="background:#374151;color:white;border:none;border-radius:6px;padding:5px 12px;font-size:12px;font-weight:600;cursor:pointer">⬇ Tải PDF</button>
  </div>
  <div class="pdf-drawer-body">
    <div class="pdf-frame-wrap" id="pdfFrameWrap">
      <iframe id="pdfPreviewFrame" src="about:blank" scrolling="no"></iframe>
      <div class="pdf-preview-refreshing" id="pdfRefreshing">Đang cập nhật...</div>
    </div>
  </div>
</div>

<div id="pdfFullscreenOverlay" style="position:fixed;inset:0;background:rgba(15,23,42,.92);z-index:3000;flex-direction:column">
  <div style="padding:10px 16px;background:#0f172a;display:flex;align-items:center;gap:10px;flex-shrink:0">
    <span style="color:white;font-weight:600;font-size:13px">👁 Xem trước PDF</span>
    <div style="display:flex;gap:4px;margin-left:8px">
      <button onclick="setPdfFullscreenSize('A4')" id="fsA4Btn" class="pdf-size-btn active">A4</button>
      <button onclick="setPdfFullscreenSize('A3')" id="fsA3Btn" class="pdf-size-btn">A3</button>
    </div>
    <span id="fsSizeInfo" style="color:#64748b;font-size:11px;margin-left:4px"></span>
    <div style="flex:1"></div>
    <button onclick="downloadPdf()" style="background:#374151;color:white;border:none;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer">⬇ Tải PDF</button>
    <button onclick="closePdfFullscreen()" style="background:#475569;color:white;border:none;border-radius:6px;padding:6px 12px;font-size:13px;font-weight:600;cursor:pointer">✕ Đóng</button>
  </div>
  <div id="pdfFsBody" style="flex:1;overflow:auto;padding:24px;display:flex;flex-direction:column;align-items:center;gap:16px"></div>
</div>
<% end %>

<script>
// ── i18n ──
const T = {
  vi: { ai_badge:'✨ Báo cáo AI', back:'Quay lại', print:'In', download_pdf:'Tải PDF' },
  en: { ai_badge:'✨ AI Report',  back:'Back',      print:'Print', download_pdf:'Download PDF' }
};
let lang = '<%= I18n.locale %>';
function t(k) { return (T[lang]||T.vi)[k] || k; }
function setLang(l) {
  lang = l; localStorage.setItem('report_lang', l);
  document.getElementById('langVI')?.classList.toggle('active', lang==='vi');
  document.getElementById('langEN')?.classList.toggle('active', lang==='en');
}
(function(){ const s = localStorage.getItem('report_lang'); if (s && T[s]) lang = s;
  document.getElementById('langVI')?.classList.toggle('active', lang==='vi');
  document.getElementById('langEN')?.classList.toggle('active', lang==='en');
})();

// ── PDF download (fetch → blob → dismiss loading) ──
async function downloadPdf() {
  deactivateAllCards();
  const overlay = document.getElementById('pdf-loading');
  overlay.classList.add('show');
  try {
    const resp = await fetch('<%= export_report_survey_path(@survey, report_id: @ai_result.id, format_type: "pdf") %>', {
      method: 'GET',
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    });
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const blob = await resp.blob();
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = resp.headers.get('Content-Disposition')
                   ?.match(/filename="?([^";\n]+)"?/)?.[1] || 'ai-report.pdf';
    document.body.appendChild(a);
    a.click();
    setTimeout(() => { URL.revokeObjectURL(url); a.remove(); }, 1000);
  } catch(err) {
    alert('Không thể tạo PDF: ' + (err.message || 'Lỗi không xác định'));
  } finally {
    overlay.classList.remove('show');
  }
}

// ── Arrange (edit) mode toggle ──
let arrangeMode = false;
function toggleArrangeMode() {
  arrangeMode = !arrangeMode;
  document.body.classList.toggle('edit-mode', arrangeMode);
  const btn = document.getElementById('btnArrange');
  if (btn) {
    btn.classList.toggle('active', arrangeMode);
    btn.textContent = arrangeMode ? '✓ Xong' : '⠿ Sắp xếp';
  }
}

// ── Card activation ──
let activeCw = null;
function activateCard(cw) {
  deactivateAllCards();
  cw.classList.add('cw-active');
  activeCw = cw;
}
function deactivateAllCards() {
  document.querySelectorAll('.cw-active').forEach(cw => cw.classList.remove('cw-active'));
  activeCw = null;
}

function toggleCardMenu(el) {
  const cw = el.closest('.cw');
  if (!cw) return;
  const hasMode = cw.classList.contains('cw-resize-mode') || cw.classList.contains('cw-text-mode') || cw.classList.contains('cw-move-mode');
  if (cw.classList.contains('cw-active')) {
    deactivateAllCards();
  } else if (hasMode) {
    deactivateAllCards(); activateCard(cw);
  } else {
    activateCard(cw);
  }
}

// ── Mode switching ──
function setCwMode(btn, mode) {
  if (!btn) return;
  const cw = btn.closest('.cw');
  if (!cw) return;
  const modeClass = 'cw-' + mode + '-mode';
  const wasActive = btn.classList.contains('active');
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('[data-editable]').forEach(el => { el.contentEditable = 'false'; });
  if (!wasActive) {
    cw.classList.add(modeClass);
    btn.classList.add('active');
    cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
    const lbl = cw.querySelector('.lbl-' + (mode==='resize'?'resize':mode==='move'?'move':'text'));
    if (lbl) lbl.style.display = '';
    if (mode === 'text') {
      cw.querySelectorAll('[data-editable]').forEach(el => { el.contentEditable = 'true'; });
    }
  }
  cw.classList.remove('cw-active');
  activeCw = null;
}

const LAYOUT_KEY = '<%= "ai_report_layout_#{@survey.id}_#{@ai_result.id}" %>';
<% server_layout = @survey.settings["ai_report_layout_#{@ai_result.id}"] %>
<% if server_layout.present? %>
// Inject server layout into localStorage for both admin and public
(function(){try{var d=<%= raw server_layout.to_json.gsub('</', '<\/') %>;localStorage.setItem(LAYOUT_KEY,JSON.stringify(d));}catch(e){}})();
<% end %>

function saveLayout() {
  try {
    const saved = JSON.parse(localStorage.getItem(LAYOUT_KEY) || '{}');
    saved.report_id = '<%= @ai_result.id %>';
    // Card spans and heights
    saved.cardSpans = {}; saved.cardHeights = {};
    document.querySelectorAll('.cw[data-cid]').forEach(cw => {
      const cid = cw.dataset.cid;
      if (cw.style.gridColumn) saved.cardSpans[cid] = cw.style.gridColumn;
      const card = cw.querySelector('.card');
      if (card?.style.minHeight) saved.cardHeights[cid] = card.style.minHeight;
    });
    localStorage.setItem(LAYOUT_KEY, JSON.stringify(saved));
    <% unless @public_view %>
    clearTimeout(saveLayout._t);
    saveLayout._t = setTimeout(() => {
      fetch('<%= save_ai_report_layout_survey_path(@survey, report_id: @ai_result.id) %>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
        body: JSON.stringify(saved)
      }).catch(() => {});
    }, 1500);
    schedulePreviewReload();
    <% end %>
  } catch(e) {}
}

function saveTextEdits() {
  const edits = {};
  document.querySelectorAll('[data-cid] [data-editable]').forEach(el => {
    const cid = el.closest('[data-cid]')?.dataset.cid;
    if (cid && el.textContent.trim()) edits[cid] = el.textContent.trim();
  });
  try {
    const saved = JSON.parse(localStorage.getItem(LAYOUT_KEY) || '{}');
    saved.textEdits = edits;
    saved.report_id = '<%= @ai_result.id %>';
    localStorage.setItem(LAYOUT_KEY, JSON.stringify(saved));
    // Sync to server so public link shows same data
    clearTimeout(saveTextEdits._t);
    saveTextEdits._t = setTimeout(() => {
      fetch('<%= save_ai_report_layout_survey_path(@survey, report_id: @ai_result.id) %>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
        body: JSON.stringify(saved)
      }).catch(() => {});
    }, 1500);
  } catch(e) {}
}

function loadTextEdits() {
  try {
    const saved = JSON.parse(localStorage.getItem(LAYOUT_KEY) || '{}');
    // Restore header
    if (saved.hdrTitle) {
      const t = document.getElementById('hdrTitleText');
      const i = document.getElementById('hdrTitleInput');
      if (t) t.textContent = saved.hdrTitle;
      if (i) i.value = saved.hdrTitle;
    }
    if (saved.hdrSub) {
      const t = document.getElementById('hdrSubText');
      const i = document.getElementById('hdrSubInput');
      if (t) t.textContent = saved.hdrSub;
      if (i) i.value = saved.hdrSub;
    }
    // Restore card spans & heights
    if (saved.cardSpans) {
      Object.entries(saved.cardSpans).forEach(([cid, col]) => {
        const el = document.querySelector(`[data-cid="${cid}"]`);
        if (el) el.style.gridColumn = col;
      });
    }
    if (saved.cardHeights) {
      Object.entries(saved.cardHeights).forEach(([cid, h]) => {
        const card = document.querySelector(`[data-cid="${cid}"] .card`);
        if (card) { card.style.minHeight = h; card.style.height = ''; }
      });
    }
    // Restore card titles
    if (saved.textEdits) {
      Object.entries(saved.textEdits).forEach(([cid, text]) => {
        const el = document.querySelector(`[data-cid="${cid}"] [data-editable]`);
        if (el && text) el.textContent = text;
      });
    }
    // Restore section titles
    if (saved.sectionTitles) {
      Object.entries(saved.sectionTitles).forEach(([sid, title]) => {
        const el = document.querySelector(`.section-title-edit[data-sec-id="${sid}"]`);
        if (el && title) el.value = title;
      });
    }
    // Restore hidden KPIs
    (saved.hiddenKpis || []).forEach(({ id, label }) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.classList.add('hidden-section');
      addRestoreChip(id, label, 'kpi');
    });
  } catch(e) {}
}

function cancelMode(e, btn) {
  e.stopPropagation(); e.preventDefault();
  const cw = btn.closest('.cw');
  const wasTextMode = cw.classList.contains('cw-text-mode');
  cw.classList.remove('cw-text-mode','cw-resize-mode','cw-move-mode');
  cw.querySelectorAll('[data-editable]').forEach(el => { el.contentEditable = 'false'; });
  cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
  cw.querySelectorAll('.lbl-text,.lbl-resize,.lbl-move').forEach(el => el.style.display='none');
  if (wasTextMode) saveTextEdits();
}

// Click outside → close active card menu
document.addEventListener('mousedown', e => {
  if (rd) return; // ignore during resize drag
  if (e.target.closest('.cw-gear')) return;
  if (e.target.closest('[data-dir]')) return; // resize handle
  if (!e.target.closest('.cw-active')) deactivateAllCards();
});

// ── Hide card ──
function getCardTitle(el) {
  const h3 = el.querySelector('h3');
  if (!h3) return '';
  return [...h3.childNodes].filter(n => n.nodeType === 3).map(n => n.textContent).join('').trim()
      || h3.querySelector('[data-editable]')?.textContent?.trim() || '';
}
function hideCard(cid) {
  deactivateAllCards();
  const el = document.querySelector(`[data-cid="${cid}"]`);
  if (!el) return;
  const label = getCardTitle(el) || cid;
  el.classList.add('hidden-section');
  addRestoreChip(cid, label, 'card');
  autoHideEmptySections();
}

// ── Auto-hide empty sections ──
function autoHideEmptySections() {
  document.querySelectorAll('.report-section:not(.hidden-section)').forEach(sec => {
    const allCards = sec.querySelectorAll('.cw');
    if (allCards.length === 0) return;
    const allHidden = [...allCards].every(cw => cw.classList.contains('hidden-section'));
    if (allHidden) {
      const sid = sec.dataset.id;
      const secText = sec.querySelector('.section-title')?.textContent?.trim();
      const firstCard = sec.querySelector('[data-editable]')?.textContent?.trim();
      const label = secText || firstCard || 'Section';
      sec.classList.add('hidden-section');
      addRestoreChip(sid, label, 'section');
    }
  });
}

// ── Hide/show section ──
function hideKpi(id) {
  const el = document.getElementById(id);
  if (!el) return;
  el.classList.add('hidden-section');
  const label = el.querySelector('.kpi-label')?.textContent?.trim() || id;
  addRestoreChip(id, label, 'kpi');
  saveKpiHidden();
}
function saveKpiHidden() {
  try {
    const saved = JSON.parse(localStorage.getItem(LAYOUT_KEY) || '{}');
    saved.hiddenKpis = [...document.querySelectorAll('.kpi[id^="kpi-block-"].hidden-section')].map(el => ({
      id: el.id, label: el.querySelector('.kpi-label')?.textContent?.trim() || el.id
    }));
    localStorage.setItem(LAYOUT_KEY, JSON.stringify(saved));
  } catch(e) {}
}
function hideSection(sid, label) {
  const el = document.querySelector(`[data-id="${sid}"]`);
  if (el) el.classList.add('hidden-section');
  addRestoreChip(sid, label, 'section');
}
function addRestoreChip(id, label, type) {
  const bar = document.getElementById('restoreBar');
  if (!bar || bar.querySelector(`[data-restore="${id}"]`)) return;
  const btn = document.createElement('button');
  btn.className = 'btn-restore';
  btn.setAttribute('data-restore', id);
  btn.textContent = '👁 ' + label;
  btn.onclick = () => {
    const sel = type === 'card' ? `[data-cid="${id}"]` : type === 'kpi' ? `#${id}` : `[data-id="${id}"]`;
    const el = document.querySelector(sel);
    if (el) {
      el.classList.remove('hidden-section');
      if (type === 'kpi') { saveKpiHidden(); }
      if (type === 'card') {
        const sec = el.closest('.report-section');
        if (sec && sec.classList.contains('hidden-section')) {
          sec.classList.remove('hidden-section');
          const secChip = document.querySelector(`[data-restore="${sec.dataset.id}"]`);
          if (secChip) secChip.remove();
        }
      }
    }
    btn.remove();
    updateRestoreBar();
  };
  bar.appendChild(btn);
  updateRestoreBar();
}
function updateRestoreBar() {
  const bar = document.getElementById('restoreBar');
  if (bar) bar.classList.toggle('has-hidden', bar.querySelectorAll('.btn-restore').length > 0);
}

