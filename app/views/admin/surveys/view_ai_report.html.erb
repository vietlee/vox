// ── Custom card drag (same as html_report, avoids SortableJS blocking resize) ──
let cdrag = null;

function getCardSpan(cw) {
  if (cw.style.gridColumn) {
    const m = cw.style.gridColumn.match(/span\s+(\d+)/);
    if (m) return parseInt(m[1]);
  }
  return 6;
}

function startCardDrag(e, cw) {
  if (e.target.closest('.btn-done')) return;
  e.preventDefault(); e.stopPropagation();
  const rect = cw.getBoundingClientRect();
  const spanNum = getCardSpan(cw);
  const ghost = document.createElement('div');
  ghost.className = 'cd-ghost';
  ghost.style.cssText = `width:${rect.width}px;height:${rect.height}px;left:${rect.left}px;top:${rect.top}px`;
  ghost.innerHTML = cw.querySelector('.card')?.outerHTML || '';
  document.body.appendChild(ghost);
  const ph = document.createElement('div');
  ph.className = 'cd-placeholder';
  ph.style.gridColumn = cw.style.gridColumn || `span ${spanNum}`;
  cw.parentElement.insertBefore(ph, cw);
  cw.classList.add('cd-source');
  const preview = document.createElement('div');
  preview.className = 'cd-zone cd-zone-over';
  preview.style.gridColumn = `span ${spanNum}`;
  cdrag = { cw, ghost, ph, preview, spanNum, offX: rect.width/2, offY: 24, lastGrid: null, lastBefore: null, lastCol: null };
}

document.addEventListener('mousemove', e => {
  if (!cdrag) return;
  cdrag.ghost.style.left = (e.clientX - cdrag.offX) + 'px';
  cdrag.ghost.style.top  = (e.clientY - cdrag.offY) + 'px';
  let targetGrid = null;
  document.querySelectorAll('.grid-2').forEach(grid => {
    const r = grid.getBoundingClientRect();
    if (e.clientX >= r.left && e.clientX <= r.right && e.clientY >= r.top - 50 && e.clientY <= r.bottom + 50) targetGrid = grid;
  });
  if (!targetGrid) { cdrag.preview.remove(); cdrag.lastGrid = null; return; }
  const gr = targetGrid.getBoundingClientRect();
  const colW = gr.width / 12;
  let colStart = Math.round((e.clientX - gr.left) / colW) - Math.floor(cdrag.spanNum / 2) + 1;
  colStart = Math.max(1, Math.min(13 - cdrag.spanNum, colStart));
  const items = [...targetGrid.querySelectorAll(':scope > *:not(.cd-source):not(.cd-zone)')];
  let insertBefore = null;
  for (const item of items) {
    const cr = item.getBoundingClientRect();
    if (e.clientY < cr.top + cr.height * 0.55) { insertBefore = item; break; }
  }
  if (targetGrid !== cdrag.lastGrid || insertBefore !== cdrag.lastBefore || colStart !== cdrag.lastCol) {
    cdrag.preview.style.gridColumn = `${colStart} / span ${cdrag.spanNum}`;
    if (insertBefore) targetGrid.insertBefore(cdrag.preview, insertBefore);
    else targetGrid.appendChild(cdrag.preview);
    cdrag.lastGrid = targetGrid; cdrag.lastBefore = insertBefore; cdrag.lastCol = colStart;
  }
}, { passive: true });

document.addEventListener('mousedown', e => {
  const bar = e.target.closest('.cw-mode-bar');
  if (!bar) return;
  const cw = bar.closest('.cw');
  if (!cw?.classList.contains('cw-move-mode')) return;
  startCardDrag(e, cw);
});

// ── Floating edit icon for [data-editable] elements ──────────────────────
(function(){
  const icon = document.createElement('button');
  icon.className = 'float-edit-icon';
  icon.title = 'Sửa nội dung';
  icon.innerHTML = '<svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.2 2.8a1.8 1.8 0 0 1 2.54 2.54L6.5 15.58l-3.5.96.96-3.5L14.2 2.8z"/></svg>';
  document.body.appendChild(icon);
  let target = null, hideTimer = null;
  function showIcon(el) {
    clearTimeout(hideTimer);
    target = el;
    const r = el.getBoundingClientRect();
    icon.style.left = (r.right + 6) + 'px';
    icon.style.top  = (r.top + r.height / 2 - 18) + 'px';
    icon.style.display = 'flex';
  }
  function scheduleHide() {
    hideTimer = setTimeout(() => { icon.style.display = 'none'; target = null; }, 120);
  }
  document.addEventListener('mouseover', e => {
    const el = e.target.closest('[data-editable]');
    if (el) showIcon(el);
  });
  document.addEventListener('mouseout', e => {
    if (e.target.closest('[data-editable]') && !e.relatedTarget?.closest('[data-editable]') && e.relatedTarget !== icon) scheduleHide();
  });
  icon.addEventListener('mouseenter', () => clearTimeout(hideTimer));
  icon.addEventListener('mouseleave', () => scheduleHide());
  icon.addEventListener('click', e => {
    e.stopPropagation();
    if (!target) return;
    const cw = target.closest('.cw');
    if (cw) {
      cw.classList.remove('cw-resize-mode','cw-move-mode');
      cw.classList.add('cw-text-mode');
      cw.querySelectorAll('[data-editable]').forEach(el => el.contentEditable = 'true');
      cw.querySelectorAll('.ct-mode-btn').forEach(b => b.classList.remove('active'));
      const textBtn = cw.querySelector('.ct-mode-btn[data-mode="text"]');
      if (textBtn) textBtn.classList.add('active');
    }
    target.focus();
    icon.style.display = 'none';
  });
})();
