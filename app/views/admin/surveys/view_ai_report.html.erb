const tip = document.createElement('div');
tip.className = 'resize-tip';
document.body.appendChild(tip);

const guidePool = [];
function getGuide() {
  let g = guidePool.find(g => !g.classList.contains('visible'));
  if (!g) { g = document.createElement('div'); g.className = 'align-guide'; document.body.appendChild(g); guidePool.push(g); }
  return g;
}
function showAlignGuides(activeCw) {
  hideAlignGuides();
  const grid = activeCw.parentElement;
  if (!grid) return;
  const gridRect = grid.getBoundingClientRect();
  [...grid.children].forEach(sibling => {
    if (sibling === activeCw || !sibling.classList.contains('cw')) return;
    const card = sibling.querySelector('.card');
    if (!card) return;
    const rect = card.getBoundingClientRect();
    const g = getGuide();
    g.style.position = 'absolute';
    g.style.left = gridRect.left + 'px';
    g.style.width = gridRect.width + 'px';
    g.style.top = (rect.bottom + window.scrollY) + 'px';
    g.classList.add('visible');
  });
}
function hideAlignGuides() { guidePool.forEach(g => g.classList.remove('visible')); }

document.querySelectorAll('.cw').forEach(cw => {
