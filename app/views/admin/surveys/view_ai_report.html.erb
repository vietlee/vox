// ── KPI drag-resize ───────────────────────────────────────────────────────
const KPI_SIZE_SK = 'ai_kpi_sizes_<%= @survey.id %>_<%= @ai_result.id %>';
let kpiDrag = null;
const KPI_MAXCOLS = 12;
function _kpiGridCols() { return KPI_MAXCOLS; }
(function loadKpiSizes(){
  try {
    const saved = JSON.parse(localStorage.getItem(KPI_SIZE_SK) || '{}');
    Object.entries(saved).forEach(([idx, v]) => {
      const block = document.getElementById('kpi-block-' + idx);
      if (!block) return;
      const span = typeof v === 'object' ? v.span : v;
      const h    = typeof v === 'object' ? v.h : null;
      if (span > 1) block.style.gridColumn = 'span ' + span; else block.style.gridColumn = '';
      if (h) block.style.minHeight = h + 'px';
    });
  } catch(e) {}
})();
(function initKpiDrag(){
  document.addEventListener('mousedown', e => {
    const handle = e.target.closest('.kpi-rh,.kpi-lh,.kpi-rb,.kpi-rt');
    if (!handle) return;
    const block = handle.parentElement;
    const kpiGrid = document.querySelector('.kpi-grid');
    if (!block || !kpiGrid) return;
    e.preventDefault();
    handle.classList.add('dragging');
    const dir = handle.dataset.dir;
    if (dir === 'r' || dir === 'l') {
      const numCols = _kpiGridCols();
      const colW = kpiGrid.getBoundingClientRect().width / numCols;
      const curSpan = parseInt(block.style.gridColumn?.replace('span ', '')) || 1;
      kpiDrag = { handle, block, dir, startX: e.clientX, startSpan: curSpan, colW, numCols };
    } else {
      kpiDrag = { handle, block, dir, startY: e.clientY, startH: block.getBoundingClientRect().height };
    }
  });
  document.addEventListener('mousemove', e => {
    if (!kpiDrag) return;
    const { dir } = kpiDrag;
    if (dir === 'r' || dir === 'l') {
      const dx = e.clientX - kpiDrag.startX;
      const sign = dir === 'r' ? 1 : -1;
      const newSpan = Math.max(1, Math.min(kpiDrag.numCols, Math.round((kpiDrag.startSpan * kpiDrag.colW + sign * dx) / kpiDrag.colW)));
      kpiDrag.block.style.gridColumn = newSpan > 1 ? 'span ' + newSpan : '';
      kpiDrag.pendingSpan = newSpan;
    } else {
      const dy = e.clientY - kpiDrag.startY;
      const sign = dir === 'b' ? 1 : -1;
      const newH = Math.max(80, kpiDrag.startH + sign * dy);
      kpiDrag.block.style.minHeight = newH + 'px';
      kpiDrag.pendingH = newH;
    }
  });
  document.addEventListener('mouseup', () => {
    if (!kpiDrag) return;
    kpiDrag.handle.classList.remove('dragging');
    const idx = kpiDrag.handle.dataset.kpiIdx;
    const isH = kpiDrag.dir === 'r' || kpiDrag.dir === 'l';
    try {
      const saved = JSON.parse(localStorage.getItem(KPI_SIZE_SK) || '{}');
      if (!saved[idx] || typeof saved[idx] !== 'object') saved[idx] = {};
      if (isH) {
        const span = kpiDrag.pendingSpan != null ? kpiDrag.pendingSpan : kpiDrag.startSpan;
        if (span >= 1) saved[idx].span = span; else delete saved[idx].span;
      } else {
        const h = kpiDrag.pendingH != null ? Math.round(kpiDrag.pendingH) : Math.round(kpiDrag.startH);
        if (h > 80) saved[idx].h = h; else delete saved[idx].h;
      }
      if (!Object.keys(saved[idx]).length) delete saved[idx];
      localStorage.setItem(KPI_SIZE_SK, JSON.stringify(saved));
    } catch(e) {}
    kpiDrag = null;
  });
})();

