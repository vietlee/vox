async function openShareModal() {
  document.getElementById('shareModal').classList.add('open');
  document.getElementById('shareLinkInput').value = 'Đang tạo link...';
  document.getElementById('shareQrDiv').innerHTML = '<div style="width:180px;height:180px;margin:0 auto;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:12px;">Đang tạo QR...</div>';
  try {
    const resp = await fetch('<%= generate_ai_report_token_survey_path(@survey, report_id: @ai_result.id) %>', {
      method: 'POST', headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]')?.content || '' }
    });
    const data = await resp.json();
    const _displayUrl = data.short_url || data.url || '';
    document.getElementById('shareLinkInput').value = _displayUrl;
    if (data.short_url && data.url !== data.short_url) {
      document.getElementById('shareFullUrl').textContent = data.url;
      document.getElementById('shareShortRow').style.display = '';
    }
    document.getElementById('shareQrDiv').innerHTML = data.qr_svg || '';
  } catch(e) { document.getElementById('shareLinkInput').value = 'Lỗi tạo link'; }
}
function closeShareModal() { document.getElementById('shareModal').classList.remove('open'); }
async function copyShareLink(btn) {
  const url = document.getElementById('shareLinkInput').value;
  if (!url || url.startsWith('Đang') || url.startsWith('Lỗi')) return;
  try { await navigator.clipboard.writeText(url); } catch(e) { const i = document.getElementById('shareLinkInput'); i.select(); document.execCommand('copy'); }
  if (btn) { btn.classList.add('copied'); setTimeout(() => btn.classList.remove('copied'), 2000); }
}
async function copyQrImage(btn) {
  const svg = document.querySelector('#shareQrDiv svg'); if (!svg) return;
  try {
    const canvas = document.createElement('canvas'); canvas.width=220; canvas.height=220;
    const ctx = canvas.getContext('2d'); const img = new Image();
    img.onload = async () => { ctx.drawImage(img,0,0,220,220); canvas.toBlob(async b => { await navigator.clipboard.write([new ClipboardItem({'image/png':b})]); if(btn){btn.classList.add('copied');setTimeout(()=>btn.classList.remove('copied'),2000);} }); };
    img.src = 'data:image/svg+xml;base64,' + btoa(unescape(encodeURIComponent(svg.outerHTML)));
  } catch(e){}
}
function downloadQr() {
  const svg = document.querySelector('#shareQrDiv svg'); if (!svg) return;
  const a = document.createElement('a'); a.download='qr-ai-report.svg';
  a.href='data:image/svg+xml;base64,'+btoa(unescape(encodeURIComponent(svg.outerHTML))); a.click();
}
async function revokeShareLink() {
  if (!confirm('Thu hồi link chia sẻ? Người đang giữ link sẽ không xem được nữa.')) return;
  await fetch('<%= revoke_ai_report_token_survey_path(@survey) %>', {
    method:'DELETE', headers:{'X-CSRF-Token':document.querySelector('meta[name=csrf-token]')?.content||''}
  });
  document.getElementById('shareLinkInput').value = 'Link đã bị thu hồi';
  document.getElementById('shareQrDiv').innerHTML = '';
}
document.getElementById('shareModal')?.addEventListener('click', e => { if (e.target===document.getElementById('shareModal')) closeShareModal(); });

// ── Header edit ──
function startHdrEdit(which) {
  const wrap  = document.getElementById(which==='title' ? 'hdrTitleWrap' : 'hdrSubWrap');
  const input = document.getElementById(which==='title' ? 'hdrTitleInput' : 'hdrSubInput');
  if (!wrap || !input) return;
  wrap.classList.add('editing');
  input.style.width = '';
  input.focus(); input.setSelectionRange(input.value.length, input.value.length);
}
function endHdrEdit(which) {
  const wrap  = document.getElementById(which==='title' ? 'hdrTitleWrap' : 'hdrSubWrap');
  const text  = document.getElementById(which==='title' ? 'hdrTitleText' : 'hdrSubText');
  const input = document.getElementById(which==='title' ? 'hdrTitleInput' : 'hdrSubInput');
  if (!wrap || !text || !input) return;
  wrap.classList.remove('editing');
  const val = input.value.trim();
  if (val) text.textContent = val;
  else input.value = text.textContent;
  // Save to localStorage + server
  try {
    const saved = JSON.parse(localStorage.getItem(LAYOUT_KEY) || '{}');
    if (which === 'title') saved.hdrTitle = text.textContent;
    else saved.hdrSub = text.textContent;
    saved.report_id = '<%= @ai_result.id %>';
    localStorage.setItem(LAYOUT_KEY, JSON.stringify(saved));
    clearTimeout(endHdrEdit._t);
    endHdrEdit._t = setTimeout(() => {
      fetch('<%= save_ai_report_layout_survey_path(@survey, report_id: @ai_result.id) %>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
        body: JSON.stringify(saved)
      }).catch(() => {});
    }, 1500);
  } catch(e) {}
}
function hdrKey(e, which) {
  if (e.key === 'Enter') { e.preventDefault(); endHdrEdit(which); }
  if (e.key === 'Escape') {
    const wrap  = document.getElementById(which==='title' ? 'hdrTitleWrap' : 'hdrSubWrap');
    const text  = document.getElementById(which==='title' ? 'hdrTitleText' : 'hdrSubText');
    const input = document.getElementById(which==='title' ? 'hdrTitleInput' : 'hdrSubInput');
    if (input && text) input.value = text.textContent;
    wrap?.classList.remove('editing');
  }
}

<% unless @pdf_preview %>
// ── PDF Preview drawer ──
let pdfPreviewOpen = false;
const PDF_PREVIEW_W = 1200;

function togglePdfPreview() {
  pdfPreviewOpen = !pdfPreviewOpen;
  const drawer = document.getElementById('pdfDrawer');
  const tab    = document.getElementById('pdfPreviewTab');
  if (!drawer) return;
  drawer.classList.toggle('open', pdfPreviewOpen);
  if (tab) tab.classList.toggle('open', pdfPreviewOpen);
  document.body.classList.toggle('pdf-preview-open', pdfPreviewOpen);
  if (pdfPreviewOpen) { updatePreviewScale(); loadPreviewFrame(); }
}

const PAGE_SIZES = {
  A4: { w: 297, h: 210, label: 'A4 (297×210mm)' },
  A3: { w: 420, h: 297, label: 'A3 (420×297mm)' }
};
let _fsSize = 'A4';

function openPdfFullscreen(size) {
  _fsSize = size || 'A4';
  document.getElementById('pdfFullscreenOverlay').classList.add('show');
  setPdfFullscreenSize(_fsSize);
}
function closePdfFullscreen() {
  document.getElementById('pdfFullscreenOverlay').classList.remove('show');
}
function setPdfFullscreenSize(size) {
  _fsSize = size;
  document.getElementById('fsA4Btn')?.classList.toggle('active', size === 'A4');
  document.getElementById('fsA3Btn')?.classList.toggle('active', size === 'A3');
  const { w, h, label } = PAGE_SIZES[size];
  const info = document.getElementById('fsSizeInfo');
  if (info) info.textContent = label;
  const body  = document.getElementById('pdfFsBody');
  const avail = body.clientWidth - 48;
  const pageW = Math.min(avail, 1100);
  const pageH = Math.round(pageW / (w / h));
  const scale = pageW / PDF_PREVIEW_W;
  body.innerHTML = '';
  const wrap = document.createElement('div');
  wrap.className = 'pdf-page-wrap';
  wrap.style.cssText = `width:${pageW}px;height:${pageH}px`;
  const frame = document.createElement('iframe');
  frame.className = 'pdf-page-iframe';
  frame.style.cssText = `width:${PDF_PREVIEW_W}px;height:${Math.round(pageH/scale)}px;transform:scale(${scale})`;
  wrap.appendChild(frame);
  body.appendChild(wrap);
  const layoutJson = localStorage.getItem(LAYOUT_KEY) || '{}';
  fetch('<%= save_ai_report_layout_survey_path(@survey, report_id: @ai_result.id) %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
    body: JSON.stringify(JSON.parse(layoutJson))
  }).catch(() => {}).finally(() => {
    const base = window.location.href.split('?')[0];
    const qp = new URLSearchParams(window.location.search);
    qp.set('pdf_preview','1'); qp.set('pdf','1'); qp.set('_ts', Date.now());
    frame.src = base + '?' + qp.toString();
    frame.onload = () => {
      setTimeout(() => {
        try {
          const totalH = frame.contentDocument?.body?.scrollHeight || 0;
          if (totalH > 100) { frame.style.height = totalH+'px'; wrap.style.height = Math.ceil(totalH*scale)+'px'; }
        } catch(e) {}
      }, 800);
    };
  });
}

function updatePreviewScale() {
  const wrap  = document.getElementById('pdfFrameWrap');
  const frame = document.getElementById('pdfPreviewFrame');
  if (!wrap || !frame) return;
  const scale = wrap.offsetWidth / PDF_PREVIEW_W;
  frame.style.transform = `scale(${scale})`;
  frame._previewScale = scale;
}

function loadPreviewFrame() {
  if (!pdfPreviewOpen) return;
  const frame    = document.getElementById('pdfPreviewFrame');
  const refresher = document.getElementById('pdfRefreshing');
  if (!frame) return;
  const layoutJson = localStorage.getItem(LAYOUT_KEY) || '{}';
  fetch('<%= save_ai_report_layout_survey_path(@survey, report_id: @ai_result.id) %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || '' },
    body: JSON.stringify(JSON.parse(layoutJson))
  }).catch(() => {}).finally(() => {
    if (refresher) refresher.classList.add('show');
    const base = window.location.href.split('?')[0];
    const qp = new URLSearchParams(window.location.search);
    qp.set('pdf_preview', '1'); qp.set('pdf', '1'); qp.set('_ts', Date.now());
    frame.src = base + '?' + qp.toString();
    frame.onload = () => {
      updatePreviewScale();
      if (refresher) refresher.classList.remove('show');
      setTimeout(() => {
        try {
          const h = frame.contentDocument?.body?.scrollHeight;
          if (h > 100) {
            frame.style.height = h + 'px';
            const wrap = document.getElementById('pdfFrameWrap');
            if (wrap) wrap.style.height = Math.ceil(h * (frame._previewScale||1)) + 'px';
          }
        } catch(e) {}
      }, 600);
    };
  });
}

function schedulePreviewReload() {
  if (!pdfPreviewOpen) return;
  clearTimeout(schedulePreviewReload._t);
  schedulePreviewReload._t = setTimeout(loadPreviewFrame, 800);
}

window.addEventListener('resize', updatePreviewScale);
<% end %>
</script>
</body>
</html>
