<% content_for :title, t("surveys.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<% sub = current_workspace.active_subscription %>

<!-- ── Page header (always visible) ─────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-start gap-3 justify-between mb-4">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight">📋 <%= t("surveys.title") %></h1>
        <p class="text-[12px] text-slate-500 mt-0.5"><%= @surveys.total_count rescue @surveys.count %> <%= t("surveys.subtitle") %></p>
      </div>
    </div>
    <div class="flex gap-2">
      <button onclick="document.getElementById('ai-builder-modal').classList.remove('hidden'); var p=document.getElementById('ai-prompt'); p.value=''; document.getElementById('ai-submit-btn').disabled=true;"
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-white border border-slate-200 hover:bg-violet-50 hover:text-violet-700 hover:border-violet-300 text-slate-700 transition-colors">
        <%= t("surveys.ai_create") %> ✨
      </button>
      <%= link_to new_survey_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-blue-500 hover:bg-blue-600 text-white transition-colors" do %>
        + <%= t("surveys.new") %>
      <% end %>
    </div>
  </div>
</div>

<!-- ── Card area (fills remaining height) ───────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <!-- Card header: search + filter (fixed) -->
    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        <input id="survey-search" type="text" placeholder="<%= t("surveys.search_placeholder") %>"
          class="w-full pl-8 pr-3 py-1.5 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white"
          oninput="filterSurveys()">
      </div>
      <select id="survey-status-filter" onchange="filterSurveys()"
        class="px-3 py-1.5 text-[12px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white text-slate-600 cursor-pointer">
        <option value=""><%= t("surveys.all_statuses") %></option>
        <option value="draft"><%= t("status.draft") %></option>
        <option value="active"><%= t("status.active") %></option>
        <option value="closed"><%= t("status.closed") %></option>
        <option value="archived"><%= t("status.archived") %></option>
      </select>
      <span class="text-[11px] text-slate-400 ml-auto"><%= @surveys.total_count rescue @surveys.count %> <%= t("surveys.subtitle") %></span>
    </div>

    <!-- Table (scrollable) -->
    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @surveys.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("surveys.col_survey") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("surveys.col_status") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("surveys.col_responses") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">
                <% next_sort = @sort == "desc" ? "asc" : "desc" %>
                <%= link_to surveys_path(sort: next_sort, status: params[:status]),
                    class: "inline-flex items-center gap-1 hover:text-indigo-600 transition-colors" do %>
                  <%= t("surveys.col_created") %>
                  <span class="text-[10px]"><%= @sort == "desc" ? "↓" : "↑" %></span>
                <% end %>
              </th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <tr id="no-results-row" class="hidden">
              <td colspan="5" class="px-4 py-10 text-center text-[13px] text-slate-400"><%= t("surveys.not_found") %></td>
            </tr>
            <% @surveys.each do |survey| %>
              <tr class="survey-row border-b border-slate-200 hover:bg-white/70 transition-colors" id="survey-row-<%= survey.id %>"
                  data-title="<%= survey.title.downcase %>"
                  data-status="<%= survey.status %>">
                <td class="px-4 py-3">
                  <% title_path = (survey.closed? || survey.archived?) ? results_survey_path(survey) : edit_survey_path(survey) %>
                  <%= link_to title_path, class: "group block" do %>
                    <div class="text-[13px] font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors"><%= survey.title %></div>
                    <div class="text-[11px] text-slate-400"><%= t("surveys.questions_count", count: survey.questions.count) %> · <%= survey.identity_mode.humanize %></div>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <span id="survey-badge-<%= survey.id %>" class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold <%= survey_status_class(survey.status) %>">
                    <%= t("status.#{survey.status}", default: survey.status.capitalize) %>
                  </span>
                </td>
                <td class="px-4 py-3 text-[13px] text-slate-700"><%= survey.response_count %></td>
                <td class="px-4 py-3 text-[12px] text-slate-500"><%= survey.created_at.strftime("%d/%m/%Y") %></td>
                <td class="px-4 py-3">
                  <div id="survey-actions-<%= survey.id %>" class="flex gap-1.5 justify-end flex-wrap"
                       data-publish-url="<%= publish_survey_path(survey) %>"
                       data-close-url="<%= close_survey_path(survey) %>"
                       data-reopen-url="<%= reopen_survey_path(survey) %>"
                       data-archive-url="<%= archive_survey_path(survey) %>"
                       data-delete-url="<%= survey_path(survey) %>"
                       data-edit-url="<%= edit_survey_path(survey) %>"
                       data-results-url="<%= results_survey_path(survey) %>"
                       data-clone-url="<%= clone_survey_path(survey) %>">
                    <%= render "admin/surveys/survey_actions", survey: survey %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="flex flex-col items-center justify-center py-20 text-slate-400">
          <div class="text-4xl mb-3">📋</div>
          <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("surveys.empty") %></h3>
          <p class="text-[13px] text-slate-400 mb-4"><%= t("surveys.empty_desc") %></p>
          <%= link_to t("surveys.new"), new_survey_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-semibold bg-blue-500 text-white hover:bg-blue-600 transition-colors" %>
        </div>
      <% end %>
    </div><!-- /scrollable -->

    <!-- Pagination (fixed at bottom) -->
    <% if @pagy && @pagy.pages > 1 %>
      <div class="flex-shrink-0 flex items-center justify-between px-4 py-2.5 border-t" style="border-color:rgba(99,102,241,0.12); background:rgba(99,102,241,0.04);">
        <p class="text-[11px] text-slate-500">
          <% from = (@pagy.page - 1) * @pagy.items + 1; to = [@pagy.page * @pagy.items, @pagy.count].min %>
          <%= t("surveys.showing_range", from: from, to: to, count: @pagy.count) %>
        </p>
        <div class="flex gap-1">
          <% if @pagy.page > 1 %>
            <%= link_to surveys_path(page: @pagy.page - 1, status: params[:status], q: params[:q]),
              class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %><%= t("surveys.prev") %><% end %>
          <% end %>
          <% if @pagy.page < @pagy.pages %>
            <%= link_to surveys_path(page: @pagy.page + 1, status: params[:status], q: params[:q]),
              class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %><%= t("surveys.next") %><% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div><!-- /card -->
</div><!-- /card area -->

<!-- Confirm Modal -->
<div id="confirm-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center bg-black/40 backdrop-blur-sm">
  <div class="bg-white rounded-2xl shadow-2xl w-[400px] max-w-full mx-4 p-6">
    <div id="confirm-icon" class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4"></div>
    <h3 id="confirm-title" class="text-[17px] font-bold text-slate-900 text-center mb-2"></h3>
    <p id="confirm-body" class="text-[13px] text-slate-500 text-center leading-relaxed mb-6"></p>
    <div class="flex gap-3">
      <button onclick="closeConfirm()"
        class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 border-0 cursor-pointer">
        <%= t("surveys.confirm_cancel") %>
      </button>
      <button id="confirm-btn" onclick="submitConfirm()"
        class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold text-white border-0 cursor-pointer">
        <%= t("surveys.confirm_action") %>
      </button>
    </div>
  </div>
  </div>
</div>

<!-- AI Survey Builder Modal -->
<div id="ai-builder-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center bg-black/50">
  <div class="bg-white rounded-xl shadow-2xl w-[520px] max-w-full mx-4 p-6">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-violet-500 to-indigo-500 flex items-center justify-center text-[18px]">✨</div>
      <div>
        <h2 class="text-[16px] font-bold text-slate-900">AI Survey Builder</h2>
        <p class="text-[12px] text-slate-500">5 AI credits</p>
      </div>
      <button onclick="document.getElementById('ai-builder-modal').classList.add('hidden')" class="ml-auto text-slate-400 hover:text-slate-600 text-xl">✕</button>
    </div>
    <div id="ai-builder-form">
      <label class="block text-[12px] font-semibold text-slate-700 mb-2"><%= t("surveys.ai_builder_label") %></label>
      <textarea id="ai-prompt" rows="4" placeholder="<%= j t("surveys.ai_builder_placeholder") %>"
        oninput="document.getElementById('ai-submit-btn').disabled = !this.value.trim()"
        class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 resize-none outline-none"></textarea>
      <div class="flex gap-2 mt-4">
        <button id="ai-submit-btn" onclick="generateAiSurvey()" disabled
          class="flex-1 py-2 text-white text-[13px] font-semibold rounded-lg transition-all disabled:opacity-40 disabled:cursor-not-allowed"
          style="background:#7c3aed;"
          onmouseenter="if(!this.disabled) this.style.background='#6d28d9'"
          onmouseleave="this.style.background='#7c3aed'">
          <%= t("surveys.ai_builder_create") %>
        </button>
        <button onclick="document.getElementById('ai-builder-modal').classList.add('hidden')" class="px-4 py-2 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg hover:bg-slate-200"><%= t("surveys.ai_builder_cancel") %></button>
      </div>
    </div>
    <div id="ai-builder-loading" class="hidden" style="text-align:center;padding:32px 16px;">
      <div style="display:inline-flex;flex-direction:column;align-items:center;gap:12px;">
        <span id="ai-progress-pct" style="font-size:13px;font-weight:800;color:#1A6BFF;letter-spacing:-0.3px;">0%</span>
        <div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">
          <svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">
            <circle cx="44" cy="44" r="38" stroke="#dbeafe" stroke-width="6"/>
            <circle id="ai-progress-ring" cx="44" cy="44" r="38" stroke="#1A6BFF" stroke-width="6"
              stroke-linecap="round" stroke-dasharray="238.8" stroke-dashoffset="238.8"
              style="transition:stroke-dashoffset 0.6s ease;"/>
          </svg>
          <div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">
            <svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
              <rect x="0" y="0" width="36" height="36" rx="9" fill="#1A6BFF"/>
              <polygon points="10,24 6,31 16,24" fill="white"/>
              <rect x="6" y="6" width="24" height="19" rx="5" fill="white"/>
              <rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/>
              <rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/>
              <rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/>
            </svg>
          </div>
        </div>
        <p id="ai-progress-label" style="font-size:13px;font-weight:600;color:#475569;margin:0;"></p>
        <p style="font-size:11px;color:#94a3b8;margin:0;"><%= t("surveys.ai_builder_loading") %></p>
      </div>
    </div>
  </div>
  </div>
</div>

<script>
(function() {
const CSRF = document.querySelector('meta[name=csrf-token]')?.content;

const I18N = {
  edit:         "<%= j t('surveys.edit') %>",
  results:      "<%= j t('surveys.results_btn') %>",
  clone:        "<%= j t('surveys.clone') %>",
  publish:      "<%= j t('surveys.publish') %>",
  close_action: "<%= j t('surveys.close_action') %>",
  reopen:       "<%= j t('surveys.reopen') %>",
  archive:      "<%= j t('surveys.archive') %>",
  delete:       "<%= j t('surveys.delete') %>",
  edit_disabled_title: "<%= j t('surveys.edit_disabled_title') %>",
  close_title:  "<%= j t('surveys.close_title') %>",
  close_body:   "<%= j t('surveys.close_body') %>",
  archive_title:"<%= j t('surveys.archive_title') %>",
  archive_body: "<%= j t('surveys.archive_body') %>",
  delete_title: "<%= j t('surveys.delete_title') %>",
  delete_body:  "<%= j t('surveys.delete_body') %>",
  status_draft:    "<%= j t('status.draft') %>",
  status_active:   "<%= j t('status.active') %>",
  status_closed:   "<%= j t('status.closed') %>",
  status_archived: "<%= j t('status.archived') %>"
};

function filterSurveys() {
  const q      = document.getElementById('survey-search').value.toLowerCase().trim();
  const status = document.getElementById('survey-status-filter').value;
  const rows   = document.querySelectorAll('tr.survey-row');
  let visible  = 0;
  rows.forEach(row => {
    const show = (!q || row.dataset.title.includes(q)) && (!status || row.dataset.status === status);
    row.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  document.getElementById('no-results-row')?.classList.toggle('hidden', visible > 0);
}

const STATUS_BADGE = {
  draft:    { cls: 'bg-slate-100 text-slate-600',    label: I18N.status_draft },
  active:   { cls: 'bg-emerald-50 text-emerald-700', label: I18N.status_active },
  closed:   { cls: 'bg-amber-50 text-amber-700',     label: I18N.status_closed },
  archived: { cls: 'bg-slate-100 text-slate-400',    label: I18N.status_archived }
};

function updateRowStatus(id, newStatus) {
  const row = document.getElementById('survey-row-' + id);
  if (!row) return;
  row.dataset.status = newStatus;
  const badge = document.getElementById('survey-badge-' + id);
  if (badge) {
    const cfg = STATUS_BADGE[newStatus] || {};
    badge.className = 'inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold ' + (cfg.cls || '');
    badge.textContent = cfg.label || newStatus;
  }
  const actionsDiv = document.getElementById('survey-actions-' + id);
  if (!actionsDiv) return;
  const u = actionsDiv.dataset;
  const btn = (label, onclick, cls) =>
    `<button onclick="${onclick}" class="px-2.5 py-1 text-[11px] rounded-md border-0 cursor-pointer ${cls}">${label}</button>`;
  const canEdit = newStatus !== 'closed' && newStatus !== 'archived';
  let html = canEdit
    ? `<a href="${u.editUrl}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200">${I18N.edit}</a>`
    : `<span class="px-2.5 py-1 text-[11px] bg-slate-50 rounded-md text-slate-300 cursor-not-allowed" title="${I18N.edit_disabled_title}">${I18N.edit}</span>`;
  html += `<a href="${u.resultsUrl}" class="px-2.5 py-1 text-[11px] bg-indigo-50 rounded-md text-indigo-700 hover:bg-indigo-100">${I18N.results}</a>`
        + btn(I18N.clone, `cloneSurvey(${id})`, 'bg-violet-50 text-violet-700 hover:bg-violet-100');
  if (newStatus === 'draft')
    html += btn(I18N.publish, `surveyAction('publish',${id})`, 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100');
  if (newStatus === 'active')
    html += btn(I18N.close_action, `showConfirm('close',${id})`, 'bg-amber-50 text-amber-700 hover:bg-amber-100');
  if (newStatus === 'closed')
    html += btn(I18N.reopen, `surveyAction('reopen',${id})`, 'bg-emerald-50 text-emerald-700 hover:bg-emerald-100');
  if (newStatus !== 'archived')
    html += btn(I18N.archive, `showConfirm('archive',${id})`, 'bg-slate-100 text-slate-500 hover:bg-slate-200');
  html += btn(I18N.delete, `showConfirm('delete',${id})`, 'bg-red-50 text-red-500 hover:bg-red-100');
  actionsDiv.innerHTML = html;
}

function submitPatchForm(url) {
  const form = document.createElement('form');
  form.method = 'post'; form.action = url;
  const m = document.createElement('input'); m.type='hidden'; m.name='_method'; m.value='patch';
  const t = document.createElement('input'); t.type='hidden'; t.name='authenticity_token'; t.value=CSRF;
  form.appendChild(m); form.appendChild(t); document.body.appendChild(form); form.submit();
}

async function surveyAction(type, id) {
  const actionsDiv = document.getElementById('survey-actions-' + id);
  if (!actionsDiv) return;
  const urlMap = { publish: actionsDiv.dataset.publishUrl, close: actionsDiv.dataset.closeUrl, reopen: actionsDiv.dataset.reopenUrl, archive: actionsDiv.dataset.archiveUrl };
  const url = urlMap[type];
  if (!url) return;
  if (type === 'close' || type === 'reopen') { submitPatchForm(url); return; }
  const res = await fetch(url, { method:'PATCH', headers:{'X-CSRF-Token':CSRF,'Accept':'application/json','Content-Type':'application/json'} });
  if (!res.ok) return;
  updateRowStatus(id, { publish: 'active', archive: 'archived' }[type]);
}

const CONFIRM_CONFIG = {
  close:   { icon: '🔒', iconBg: '#fef3c7', btnColor: '#d97706' },
  archive: { icon: '📦', iconBg: '#f1f5f9', btnColor: '#64748b' },
  delete:  { icon: '🗑️', iconBg: '#fee2e2', btnColor: '#ef4444' }
};
let _confirmState = {};
const CONFIRM_MESSAGES = {
  close:   { title: () => I18N.close_title,   body: () => I18N.close_body },
  archive: { title: () => I18N.archive_title, body: () => I18N.archive_body },
  delete:  { title: () => I18N.delete_title,  body: () => I18N.delete_body }
};

function showConfirm(type, id) {
  const cfg = CONFIRM_CONFIG[type] || {};
  const msg = CONFIRM_MESSAGES[type] || {};
  _confirmState = { type, id };
  document.getElementById('confirm-title').textContent = msg.title ? msg.title() : '';
  document.getElementById('confirm-body').textContent  = msg.body  ? msg.body()  : '';
  const icon = document.getElementById('confirm-icon');
  icon.style.background = cfg.iconBg || '#f1f5f9';
  icon.textContent = cfg.icon || '❓';
  document.getElementById('confirm-btn').style.background = cfg.btnColor || '#6366f1';
  document.getElementById('confirm-modal').classList.remove('hidden');
}

function closeConfirm() { document.getElementById('confirm-modal').classList.add('hidden'); _confirmState = {}; }

async function submitConfirm() {
  const { type, id } = _confirmState;
  if (!type || !id) return;
  closeConfirm();
  if (type === 'delete') {
    const actionsDiv = document.getElementById('survey-actions-' + id);
    const url = actionsDiv?.dataset.deleteUrl;
    if (!url) return;
    const res = await fetch(url, { method:'DELETE', headers:{'X-CSRF-Token':CSRF,'Accept':'application/json'} });
    if (res.ok) {
      const row = document.getElementById('survey-row-' + id);
      if (row) { row.style.transition='opacity 0.2s,transform 0.2s'; row.style.opacity='0'; row.style.transform='translateX(8px)'; setTimeout(() => row.remove(), 220); }
    }
  } else { await surveyAction(type, id); }
}

document.getElementById('confirm-modal')?.addEventListener('click', e => { if (e.target === e.currentTarget) closeConfirm(); });

// ── AI progress ring ──────────────────────────────────────────────────────────
const AI_STEPS = [
  { pct: 8,  label: "<%= j t('surveys.ai_progress.analyzing') %>" },
  { pct: 22, label: "<%= j t('surveys.ai_progress.designing') %>" },
  { pct: 40, label: "<%= j t('surveys.ai_progress.writing') %>" },
  { pct: 58, label: "<%= j t('surveys.ai_progress.refining') %>" },
  { pct: 74, label: "<%= j t('surveys.ai_progress.validating') %>" },
  { pct: 88, label: "<%= j t('surveys.ai_progress.finalizing') %>" }
];
const RING_CIRCUMFERENCE = 238.8;
let _progressTimer = null, _currentStep = 0;

function setProgress(pct, label) {
  const ring = document.getElementById('ai-progress-ring');
  const txt  = document.getElementById('ai-progress-pct');
  const lbl  = document.getElementById('ai-progress-label');
  if (!ring) return;
  ring.style.strokeDashoffset = RING_CIRCUMFERENCE * (1 - pct / 100);
  if (txt) txt.textContent = Math.round(pct) + '%';
  if (lbl && label !== undefined) lbl.textContent = label;
}

function startProgress() {
  _currentStep = 0; setProgress(0, AI_STEPS[0].label);
  _progressTimer = setInterval(() => {
    if (_currentStep >= AI_STEPS.length - 1) return;
    const step = AI_STEPS[++_currentStep];
    setProgress(step.pct, step.label);
  }, 2800);
}

function finishProgress(onDone) { clearInterval(_progressTimer); setProgress(100, "<%= j t('surveys.ai_progress.done') %>"); setTimeout(onDone, 600); }
function stopProgress() { clearInterval(_progressTimer); setProgress(0); }

async function generateAiSurvey() {
  const prompt = document.getElementById('ai-prompt').value;
  if (!prompt.trim()) return;
  document.getElementById('ai-builder-form').classList.add('hidden');
  document.getElementById('ai-builder-loading').classList.remove('hidden');
  var errEl = document.getElementById('ai-builder-error');
  if (errEl) errEl.classList.add('hidden');
  startProgress();

  let data, resp;
  try {
    resp = await fetch('<%= ai_generate_survey_path %>', {
      method:'POST',
      headers:{'Content-Type':'application/json','Accept':'application/json','X-CSRF-Token':document.querySelector('meta[name=csrf-token]').content},
      body: JSON.stringify({ prompt })
    });
    data = await resp.json();
  } catch(e) { stopProgress(); resetAiBuilder('<%= j t("surveys.ai_builder_error") %>'); return; }

  if (resp.status === 402 || data?.upgrade_required) {
    stopProgress();
    document.getElementById('ai-builder-modal')?.classList.add('hidden');
    if (window.showAiUpgradeModal) window.showAiUpgradeModal('<%= j t("surveys.ai_builder") %>', data?.insufficient_credits);
    else resetAiBuilder(data?.error || '<%= j t("ai.feature_not_available") %>');
    return;
  }
  if (!data.job_id) { stopProgress(); resetAiBuilder(data.error || '<%= j t("surveys.ai_builder_error") %>'); return; }

  pollJobStatus(data.job_id, (result) => {
    finishProgress(() => {
      const form = document.createElement('form');
      form.method = 'POST'; form.action = '<%= surveys_path %>';
      const addField = (name, value) => { const inp = document.createElement('input'); inp.type='hidden'; inp.name=name; inp.value=value??''; form.appendChild(inp); };
      addField('authenticity_token', document.querySelector('meta[name=csrf-token]').content);
      addField('survey[title]', result.title);
      addField('survey[description]', result.description);
      addField('survey[thank_you_message]', result.thank_you_message);
      addField('ai_generated', 'true');
      addField('ai_data', JSON.stringify(result));
      document.body.appendChild(form); form.submit();
      window.deductDisplayCredits?.(5);
    });
  });
}

function cloneSurvey(id) {
  const actionsDiv = document.getElementById('survey-actions-' + id);
  const url = actionsDiv?.dataset.cloneUrl;
  if (!url) return;
  const form = document.createElement('form'); form.method='post'; form.action=url;
  const t = document.createElement('input'); t.type='hidden'; t.name='authenticity_token'; t.value=CSRF;
  form.appendChild(t); document.body.appendChild(form); form.submit();
}

async function pollJobStatus(jobId, onDone) {
  try {
    const resp = await fetch(`<%= ai_job_status_path("__ID__") %>`.replace('__ID__', jobId));
    const data = await resp.json();
    if (data.status === 'done') onDone(data.output);
    else if (data.status === 'failed') { stopProgress(); resetAiBuilder('<%= j t("surveys.ai_builder_error") %>: ' + (data.error || '')); }
    else setTimeout(() => pollJobStatus(jobId, onDone), 2000);
  } catch(e) { stopProgress(); resetAiBuilder('<%= j t("surveys.ai_builder_error") %>'); }
}

function resetAiBuilder(msg) {
  stopProgress();
  document.getElementById('ai-builder-loading').classList.add('hidden');
  document.getElementById('ai-builder-form').classList.remove('hidden');
  if (msg) {
    var errEl = document.getElementById('ai-builder-error');
    if (!errEl) { errEl = document.createElement('div'); errEl.id='ai-builder-error'; errEl.className='mt-3 px-3 py-2 bg-red-50 border border-red-200 rounded-lg text-[12px] text-red-600'; document.getElementById('ai-builder-form').appendChild(errEl); }
    errEl.textContent = msg; errEl.classList.remove('hidden');
  }
}

Object.assign(window, { filterSurveys, surveyAction, showConfirm, closeConfirm, submitConfirm, cloneSurvey, generateAiSurvey, resetAiBuilder });
})();
</script>
