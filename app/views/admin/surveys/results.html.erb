  if (wrap) {
    wrap.style.borderColor = '#8b5cf6';
    setTimeout(() => { wrap.style.borderColor = ''; }, 2000);
    wrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  // Set language
  const langInputs = document.querySelectorAll('input[name="language"]');
  langInputs.forEach(inp => { inp.checked = (inp.value === lang); });
  const langSel = document.querySelector('select[name="language"]');
  if (langSel) langSel.value = lang;
  // Set format
  const fmtBtns = document.querySelectorAll('[data-format]');
  fmtBtns.forEach(btn => {
    const isActive = btn.dataset.format === fmt;
    btn.style.background = isActive ? 'linear-gradient(135deg,#7c3aed,#6366f1)' : '';
    btn.style.color = isActive ? 'white' : '';
  });
  updateReportBtn();
}

Object.assign(window, { switchTab, toggleRow, requestAiAnalysis, requestReport, updateReportBtn, toggleReport, checkReport, startPdfExport, openExportPicker, closeExportPicker, closeDeleteReportModal, showSurveyCloseConfirm, hideSurveyCloseConfirm, deleteReport, btnDownloadLoading, suggestReportPrompt, toggleReportPrompt, regenReport });
})();

function showSurveyCloseConfirm() {
  document.getElementById('survey-close-modal').classList.remove('hidden');
}
function hideSurveyCloseConfirm() {
  document.getElementById('survey-close-modal').classList.add('hidden');
}
</script>

