<script>
function openAnswersModal(questionId, title) {
  const tmpl = document.getElementById('answers-data-' + questionId);
  if (!tmpl) return;

  const items = tmpl.content.querySelectorAll('div');
  const count = items.length;

  document.getElementById('answers-modal-title').textContent = title;
  document.getElementById('answers-modal-count').textContent = count + ' phản hồi';

  const body = document.getElementById('answers-modal-body');
  body.innerHTML = '';
  items.forEach(function(el) { body.appendChild(el.cloneNode(true)); });

  document.getElementById('answers-modal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}

function closeAnswersModal() {
  document.getElementById('answers-modal').classList.add('hidden');
  document.body.style.overflow = '';
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeAnswersModal();
});
</script>

<script>
// ── Report context Quill editor ────────────────────────────────────────────
(function initReportContextEditor() {
  function tryInit() {
    if (typeof Quill === 'undefined') { setTimeout(tryInit, 100); return; }

    const wrap  = document.getElementById('report-context-wrap');
    const edEl  = document.getElementById('report-context-editor');
    const input = document.getElementById('report-context');
    if (!wrap || !edEl || !input || edEl._quill) return;

    const q = new Quill('#report-context-editor', {
      theme: 'snow',
      placeholder: 'Mô tả mục đích báo cáo, đối tượng nhận, trọng tâm phân tích...',
      modules: {
        toolbar: [
          ['bold', 'italic', 'underline'],
          [{ list: 'ordered' }, { list: 'bullet' }],
          ['clean']
        ]
      }
    });
    edEl._quill = q;

    const STORAGE_KEY = 'vox_report_ctx_<%= @survey.id %>';

    // Restore saved prompt on load
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved && saved.trim()) {
      q.setText(saved);
      input.value = saved.trim();
      updateReportBtn();
      // Show copy button if there's content
      const copyBtn = document.getElementById('copy-prompt-btn');
      if (copyBtn) copyBtn.style.display = 'flex';
    }

    // Sync plain text → hidden input + save to localStorage on every change
    q.on('text-change', () => {
      const txt = q.getText().trim();
      input.value = txt;
      if (txt) localStorage.setItem(STORAGE_KEY, txt);
      else localStorage.removeItem(STORAGE_KEY);
      updateReportBtn();
    });

    // Focus style on wrap
    q.on('selection-change', (range) => {
      wrap.style.borderColor = range ? '#8b5cf6' : '#e2e8f0';
      wrap.style.boxShadow   = range ? '0 0 0 3px rgba(139,92,246,0.1)' : '';
    });
  }
  tryInit();

  // Patch window.regenReport to also fill Quill editor
  const _origRegen = window.regenReport;
  window.regenReport = function(ctx, lang, fmt) {
    _origRegen && _origRegen(ctx, lang, fmt);
    const edEl = document.getElementById('report-context-editor');
    const q = edEl?._quill;
    if (q) {
      q.setText(ctx);
      // Trigger sync
      document.getElementById('report-context').value = ctx;
      updateReportBtn();
    }
  };

  // Helper: set text in both hidden input AND Quill, and persist to localStorage
  window.setReportContext = function(text) {
    const ta = document.getElementById('report-context');
    const edEl = document.getElementById('report-context-editor');
    const q = edEl?._quill;
    if (ta) ta.value = text;
    if (q)  q.setText(text);
    if (text && text.trim()) localStorage.setItem('vox_report_ctx_<%= @survey.id %>', text.trim());
    updateReportBtn();
  };
})();
</script>
