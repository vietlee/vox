<% content_for :title, t("surveys.results.page_title", title: @survey.title) %>

<%
  option_labels = @questions.flat_map(&:question_options).each_with_object({}) { |o, h| h[o.id.to_s] = o.label }
  response_answer_map = @individual_responses.each_with_object({}) do |r, h|
    h[r.id] = r.answers.index_by(&:question_id)
  end

  def fmt_answer(ans, option_labels)
    return "—" if ans.nil?
    if ans.uploaded_file.attached?
      "📎 #{ans.uploaded_file.filename}"
    elsif ans.text_value.present?
      ans.text_value.truncate(80)
    elsif ans.numeric_value.present?
      ans.numeric_value.to_i.to_s
    elsif ans.option_ids.present?
      ans.option_ids.map { |id| option_labels[id.to_s] || id }.join(", ").truncate(80)
    elsif ans.date_value.present?
      ans.date_value.to_s
    else
      "—"
    end
  end
%>

<div class="flex items-start justify-between mb-5">
  <div>
    <h1 class="text-[19px] font-extrabold text-slate-900"><%= @survey.title %></h1>
    <p class="text-[12px] text-slate-500 mt-0.5"><%= t("surveys.results.subtitle", count: @total_responses, rate: @survey.completion_rate) %></p>
  </div>
  <div class="flex gap-2">
    <button onclick="switchTab('ai')"
      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-violet-50 hover:text-violet-700 hover:border-violet-200 text-slate-700 transition-colors">
      <%= t("surveys.results.tab_ai") %>
      <% if @ai_analysis %>
        <span class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block"></span>
      <% end %>
    </button>
    <button onclick="switchTab('report')"
      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-blue-50 hover:text-blue-700 hover:border-blue-200 text-slate-700 transition-colors">
      📄 <%= t("surveys.results.tab_report").gsub(/\A📄\s*/, '') %>
    </button>
    <!-- Export AI report as PDF -->
    <a id="export-pdf-btn"
       href="<%= export_report_survey_path(@survey, format_type: "pdf") %>"
       onclick="return startPdfExport(event)"
       data-turbo="false"
       class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-slate-50 hover:border-slate-300 text-slate-700 transition-colors">
      📄 <%= t("surveys.results.export_report") %>
    </a>
  </div>
</div>

<!-- Tabs -->
<div class="flex gap-0 mb-5 border-b border-slate-200">
  <button id="tab-summary" onclick="switchTab('summary')"
    class="px-4 py-2.5 text-[13px] font-semibold text-indigo-600 border-b-2 border-indigo-600 -mb-px bg-transparent transition-colors">
    <%= t("surveys.results.tab_summary") %>
  </button>
  <button id="tab-individual" onclick="switchTab('individual')"
    class="px-4 py-2.5 text-[13px] font-semibold text-slate-400 border-b-2 border-transparent -mb-px bg-transparent hover:text-slate-600 transition-colors">
    <%= t("surveys.results.tab_individual", count: @total_responses) %>
  </button>
  <button id="tab-ai" onclick="switchTab('ai')"
    class="px-4 py-2.5 text-[13px] font-semibold text-slate-400 border-b-2 border-transparent -mb-px bg-transparent hover:text-slate-600 transition-colors flex items-center gap-1.5">
    <%= t("surveys.results.tab_ai") %>
    <% if @ai_analysis %>
      <span id="ai-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block"></span>
    <% else %>
      <span id="ai-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block hidden"></span>
    <% end %>
  </button>
  <% latest_report_check = @survey.ai_analysis_results.where(result_type: "executive_report").exists? %>
  <button id="tab-report" onclick="switchTab('report')"
    class="px-4 py-2.5 text-[13px] font-semibold text-slate-400 border-b-2 border-transparent -mb-px bg-transparent hover:text-slate-600 transition-colors flex items-center gap-1.5">
    <%= t("surveys.results.tab_report") %>
    <% if latest_report_check %>
      <span id="report-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block"></span>
    <% else %>
      <span id="report-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block hidden"></span>
    <% end %>
  </button>
</div>

<!-- Tab: Summary -->
<div id="panel-summary">

<!-- Quick stats bar -->
<div class="grid grid-cols-3 gap-3 mb-5">
  <div class="bg-white border border-slate-200 rounded-[10px] p-3 text-center shadow-sm">
    <div class="text-[22px] font-extrabold text-slate-900"><%= @total_responses %></div>
    <div class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.total_responses") %></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-[10px] p-3 text-center shadow-sm">
    <div class="text-[22px] font-extrabold text-slate-900"><%= @survey.completion_rate %>%</div>
    <div class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.completion_rate") %></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-[10px] p-3 text-center shadow-sm">
    <div class="text-[22px] font-extrabold text-slate-900"><%= @questions.count %></div>
    <div class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.question_count", default: "Câu hỏi") %></div>
  </div>
</div>

<div class="space-y-5">
    <% @questions.each do |question| %>
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
        <h3 class="text-[14px] font-semibold text-slate-900 mb-4"><%= question.title %></h3>
        <% q_answers = response_answer_map.values.map { |h| h[question.id] }.compact %>
        <p class="text-[12px] text-slate-500 mb-3"><%= t("surveys.results.response_count", count: q_answers.count) %></p>

        <% if question.choice_type? %>
          <% total = q_answers.count %>
          <% question.question_options.each do |opt| %>
            <% count = q_answers.count { |a| Array(a.option_ids).map(&:to_s).include?(opt.id.to_s) } %>
            <% pct = total > 0 ? (count.to_f / total * 100).round(1) : 0 %>
            <div class="mb-3">
              <div class="flex justify-between text-[12px] mb-1">
                <span class="text-slate-700"><%= opt.label %></span>
                <span class="text-slate-500"><%= count %> (<%= pct %>%)</span>
              </div>
              <div class="h-5 bg-slate-100 rounded">
                <div class="h-5 bg-gradient-to-r from-indigo-400 to-indigo-600 rounded text-[11px] font-semibold text-white px-2 flex items-center" style="width: <%= pct %>%">
                  <% if pct > 10 %><%= pct %>%<% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% elsif question.numeric_type? %>
          <% values = q_answers.map(&:numeric_value).compact %>
          <% if values.any? %>
            <div class="grid grid-cols-3 gap-4 text-center">
              <div class="bg-slate-50 rounded-lg p-3">
                <div class="text-[20px] font-bold text-slate-900"><%= (values.sum / values.size).round(1) %></div>
                <div class="text-[11px] text-slate-500"><%= t("surveys.results.average") %></div>
              </div>
              <div class="bg-slate-50 rounded-lg p-3">
                <div class="text-[20px] font-bold text-slate-900"><%= values.min %></div>
                <div class="text-[11px] text-slate-500"><%= t("surveys.results.min") %></div>
              </div>
              <div class="bg-slate-50 rounded-lg p-3">
                <div class="text-[20px] font-bold text-slate-900"><%= values.max %></div>
                <div class="text-[11px] text-slate-500"><%= t("surveys.results.max") %></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="space-y-1.5">
            <% q_answers.first(5).each do |ans| %>
              <% if ans.uploaded_file.attached? %>
                <div class="bg-slate-50 rounded-lg px-3 py-2 text-[13px] text-slate-700 flex items-center gap-2">
                  📎 <%= link_to ans.uploaded_file.filename.to_s, rails_blob_path(ans.uploaded_file, disposition: "attachment"), class: "text-indigo-600 hover:underline", target: "_blank" %>
                  <span class="text-slate-400 text-[11px]">(<%= number_to_human_size(ans.uploaded_file.byte_size) %>)</span>
                </div>
              <% elsif ans.text_value.present? %>
                <div class="bg-slate-50 rounded-lg px-3 py-2 text-[13px] text-slate-700">"<%= ans.text_value %>"</div>
              <% end %>
            <% end %>
            <% if q_answers.count > 5 %>
              <p class="text-[12px] text-slate-400 text-center"><%= t("surveys.results.more_responses", count: q_answers.count - 5) %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div><!-- /panel-summary -->

<!-- Tab: AI Insights -->
<div id="panel-ai" class="hidden">

  <!-- AI Analysis card -->
  <div class="bg-white rounded-[12px] border border-slate-200 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-5 py-3.5 border-b border-slate-100 bg-gradient-to-r from-violet-50 to-indigo-50">
      <div>
        <h3 class="text-[14px] font-bold text-slate-900"><%= t("surveys.results.ai_executive_summary") %> ✨</h3>
        <p class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.ai_requires") %></p>
      </div>
      <div class="flex items-center gap-2">
        <div class="relative">
          <select id="ai-lang"
            class="appearance-none pl-3 pr-7 py-1.5 text-[12px] font-semibold bg-white border border-slate-200 rounded-lg text-slate-600 focus:outline-none focus:border-indigo-400 cursor-pointer">
            <option value="vi" <%= current_workspace.language == "vi" ? "selected" : "" %>><%= t("surveys.results.report_lang_vi") %></option>
            <option value="en" <%= current_workspace.language == "en" ? "selected" : "" %>><%= t("surveys.results.report_lang_en") %></option>
          </select>
          <span class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 text-[10px]">▾</span>
        </div>
        <button id="analyze-btn" onclick="requestAiAnalysis()"
          class="px-4 py-2 bg-gradient-to-r from-indigo-500 to-violet-500 text-white text-[12px] font-semibold rounded-lg hover:from-indigo-600 hover:to-violet-600 flex items-center gap-1.5">
          <span id="analyze-spinner" class="hidden w-3 h-3 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
          ✨ <%= t("surveys.results.analyze_btn") %>
        </button>
      </div>
    </div>
    <div id="ai-panel" class="p-5">
      <% if @ai_analysis %>
        <%= render "admin/surveys/ai_analysis_card", analysis: @ai_analysis %>
      <% else %>
        <div class="text-center py-8 text-slate-400">
          <div class="text-3xl mb-2">✨</div>
          <p class="text-[13px]"><%= t("surveys.results.get_analysis") %></p>
        </div>
      <% end %>
    </div>
  </div>

</div><!-- /panel-ai -->

<!-- Tab: Create Report -->
<div id="panel-report" class="hidden">

  <!-- Executive Report card -->
  <div class="bg-white rounded-[12px] border border-slate-200 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-5 py-3.5 border-b border-slate-100 bg-gradient-to-r from-violet-50 to-indigo-50">
      <div>
        <h3 class="text-[14px] font-bold text-slate-900">📄 <%= t("surveys.results.executive_report") %></h3>
        <p class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.report_credits") %> · <%= t("surveys.results.report_desc") %></p>
      </div>
      <div class="flex items-center gap-2">
        <div class="relative">
          <select id="report-lang"
            class="appearance-none pl-3 pr-7 py-1.5 text-[12px] font-semibold bg-white border border-slate-200 rounded-lg text-slate-600 focus:outline-none focus:border-indigo-400 cursor-pointer">
            <option value="vi" <%= current_workspace.language == "vi" ? "selected" : "" %>><%= t("surveys.results.report_lang_vi") %></option>
            <option value="en" <%= current_workspace.language == "en" ? "selected" : "" %>><%= t("surveys.results.report_lang_en") %></option>
          </select>
          <span class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 text-[10px]">▾</span>
        </div>
        <button id="report-btn" onclick="requestReport()"
          class="px-4 py-2 bg-gradient-to-r from-indigo-500 to-violet-500 text-white text-[12px] font-semibold rounded-lg hover:from-indigo-600 hover:to-violet-600 flex items-center gap-1.5">
          <span id="report-spinner" class="hidden w-3 h-3 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
          ✨ <%= t("surveys.results.create_report") %>
        </button>
      </div>
    </div>
    <div class="p-5">
      <div id="report-status"></div>
      <% latest_report = @survey.ai_analysis_results.where(result_type: "executive_report").order(created_at: :desc).first %>
      <% if latest_report %>
        <div id="report-saved">
          <div class="flex items-center justify-between mb-3">
            <span class="text-[11px] text-slate-400"><%= t("surveys.results.report_generated", time: latest_report.created_at.strftime("%d/%m/%Y %H:%M")) %></span>
            <button onclick="toggleReport()" class="text-[11px] font-semibold text-indigo-600 hover:text-indigo-800 bg-transparent border-0 cursor-pointer px-0">
              <span id="report-toggle-label"><%= t("surveys.results.report_view_full") %></span>
            </button>
          </div>
          <p class="text-[13px] text-slate-700 leading-relaxed mb-3"><%= latest_report.output["executive_summary"]&.truncate(300) %></p>
          <div id="report-full" class="hidden space-y-4">
            <% (latest_report.output["sections"] || []).each do |s| %>
              <div class="border-l-2 border-indigo-200 pl-4">
                <div class="text-[13px] font-bold text-indigo-700 mb-1"><%= s["heading"] %></div>
                <p class="text-[13px] text-slate-700 leading-relaxed"><%= s["content"] %></p>
                <% if s["key_finding"].present? %>
                  <div class="mt-1.5 text-[12px] text-slate-500 italic">💡 <%= s["key_finding"] %></div>
                <% end %>
              </div>
            <% end %>
            <% recs = latest_report.output["recommendations"] || [] %>
            <% if recs.any? %>
              <div>
                <div class="text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-2"><%= t("surveys.results.ai_recommendations") %></div>
                <% recs.each do |rec| %>
                  <% pri = rec.is_a?(Hash) ? rec["priority"].to_s : "" %>
                  <% pri_color = pri == "high" ? "bg-red-50 text-red-600 border-red-200" : pri == "medium" ? "bg-amber-50 text-amber-600 border-amber-200" : "bg-slate-50 text-slate-500 border-slate-200" %>
                  <div class="flex gap-2 items-start mb-2">
                    <% if pri.present? %>
                      <span class="text-[9px] font-bold px-1.5 py-0.5 rounded border flex-shrink-0 mt-0.5 <%= pri_color %>"><%= t("surveys.results.priority_#{pri}", default: pri.upcase) %></span>
                    <% else %>
                      <span class="text-indigo-400 flex-shrink-0">→</span>
                    <% end %>
                    <span class="text-[13px] text-slate-700"><%= rec.is_a?(Hash) ? rec["action"] : rec %></span>
                  </div>
                <% end %>
              </div>
            <% end %>
            <% if latest_report.output["conclusion"].present? %>
              <div class="bg-slate-50 rounded-lg p-4 mt-2">
                <div class="text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1"><%= t("surveys.results.ai_conclusion") %></div>
                <p class="text-[13px] text-slate-700"><%= latest_report.output["conclusion"] %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="text-center py-8 text-slate-400">
          <div class="text-3xl mb-2">📄</div>
          <p class="text-[13px]"><%= t("surveys.results.report_desc") %></p>
        </div>
      <% end %>
    </div>
  </div>

</div><!-- /panel-report -->

<!-- Tab: Individual -->
<div id="panel-individual" class="hidden">
  <% identity_mode = @survey.identity_mode %>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm overflow-hidden">
    <% if @individual_responses.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-[12px] border-collapse" style="min-width: <%= [600, @questions.count * 140 + 260].max %>px">
          <thead>
            <tr class="bg-slate-50 border-b border-slate-200">
              <th class="text-left px-4 py-2.5 font-semibold text-slate-500 uppercase tracking-[0.4px] text-[11px] w-[200px]">
                <% if identity_mode == "login_required" %><%= t("surveys.results.col_user") %><% elsif identity_mode == "email_required" %><%= t("surveys.results.col_email") %><% else %><%= t("surveys.results.col_token") %><% end %>
              </th>
              <th class="text-left px-4 py-2.5 font-semibold text-slate-500 uppercase tracking-[0.4px] text-[11px] w-[120px]"><%= t("surveys.results.col_time") %></th>
              <% @questions.each do |q| %>
                <th class="text-left px-4 py-2.5 font-semibold text-slate-500 uppercase tracking-[0.4px] text-[11px]">
                  <%= q.title.truncate(30) %>
                </th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @individual_responses.each do |resp| %>
              <tr class="border-b border-slate-100 hover:bg-slate-50 cursor-pointer" onclick="toggleRow(<%= resp.id %>)">
                <td class="px-4 py-3 font-medium text-slate-800">
                  <% if resp.respondent_email.present? %>
                    <%= resp.respondent_email %>
                  <% else %>
                    <span class="text-slate-400 font-mono text-[11px]">···<%= resp.respondent_token&.last(6) %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-slate-500"><%= resp.completed_at&.strftime("%d/%m %H:%M") %></td>
                <% ans_map = response_answer_map[resp.id] || {} %>
                <% @questions.each do |q| %>
                  <td class="px-4 py-3 text-slate-700 max-w-[180px] truncate">
                    <%= fmt_answer(ans_map[q.id], option_labels) %>
                  </td>
                <% end %>
              </tr>
              <tr id="row-detail-<%= resp.id %>" class="hidden bg-indigo-50/40">
                <td colspan="<%= @questions.count + 2 %>" class="px-5 py-4">
                  <div class="grid grid-cols-1 gap-2">
                    <% @questions.each do |q| %>
                      <% ans = ans_map[q.id] %>
                      <% next if ans.nil? %>
                      <div class="flex gap-3">
                        <span class="text-[12px] font-semibold text-slate-500 min-w-[180px] flex-shrink-0"><%= q.title.truncate(40) %></span>
                        <span class="text-[13px] text-slate-800">
                          <% if ans.uploaded_file.attached? %>
                            📎 <%= link_to ans.uploaded_file.filename.to_s, rails_blob_path(ans.uploaded_file, disposition: "attachment"), class: "text-indigo-600 hover:underline", target: "_blank" %>
                            <span class="text-slate-400 text-[11px]">(<%= number_to_human_size(ans.uploaded_file.byte_size) %>)</span>
                          <% else %>
                            <%= fmt_answer(ans, option_labels) %>
                          <% end %>
                        </span>
                      </div>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12 text-[13px] text-slate-400"><%= t("surveys.results.no_responses") %></div>
    <% end %>
  </div>
</div>

<script>
(function() {
const CSRF       = document.querySelector('meta[name=csrf-token]').content;
const STATUS_URL = "<%= ai_job_status_path("__ID__") %>";
const ANALYZE_URL= "<%= ai_analyze_survey_path(@survey) %>";
const REPORT_URL = "<%= ai_report_survey_path(@survey) %>";
const HAS_REPORT    = <%= @survey.ai_analysis_results.where(result_type: "executive_report").exists? ? 'true' : 'false' %>;
const HAS_ANALYSIS  = <%= @ai_analysis.present? ? 'true' : 'false' %>;
const NO_REPORT_MSG    = "<%= j t('surveys.results.export_report_missing') %>";
const NO_ANALYSIS_MSG  = "<%= j t('surveys.results.report_needs_analysis') %>";

const I18N = {
  analysis_phases: [
    "<%= j t('surveys.results.analysis_phases.reading') %>",
    "<%= j t('surveys.results.analysis_phases.processing') %>",
    "<%= j t('surveys.results.analysis_phases.finding') %>",
    "<%= j t('surveys.results.analysis_phases.generating') %>",
    "<%= j t('surveys.results.analysis_phases.finishing') %>"
  ],
  report_phases: [
    "<%= j t('surveys.results.report_phases.preparing') %>",
    "<%= j t('surveys.results.report_phases.writing') %>",
    "<%= j t('surveys.results.report_phases.sections') %>",
    "<%= j t('surveys.results.report_phases.recommendations') %>",
    "<%= j t('surveys.results.report_phases.polishing') %>",
    "<%= j t('surveys.results.report_phases.finalizing') %>"
  ],
  report_failed:    "<%= j t('surveys.results.report_failed') %>",
  analysis_failed:  "<%= j t('surveys.results.analysis_failed') %>",
  error_retry:      "<%= j t('surveys.results.error_retry') %>",
  report_view_full: "<%= j t('surveys.results.report_view_full') %>",
  report_collapse:  "<%= j t('surveys.results.report_collapse') %>"
};

// ── Progress ring helper ──────────────────────────────────────────────────────
function makeProgressRing(containerId, phases, intervalMs) {
  const totalPhases = phases.length;
  let   phase = 0, pct = 0, timer = null;

  const html = `
    <div class="flex flex-col items-center justify-center py-6 gap-3">
      <svg width="72" height="72" viewBox="0 0 72 72">
        <circle cx="36" cy="36" r="30" fill="none" stroke="#ede9fe" stroke-width="5"/>
        <circle id="${containerId}-ring" cx="36" cy="36" r="30" fill="none"
          stroke="url(#rg-${containerId})" stroke-width="5" stroke-linecap="round"
          stroke-dasharray="188.5" stroke-dashoffset="188.5"
          transform="rotate(-90 36 36)" style="transition:stroke-dashoffset 0.6s ease;"/>
        <defs>
          <linearGradient id="rg-${containerId}" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#6366f1"/>
            <stop offset="100%" stop-color="#a855f7"/>
          </linearGradient>
        </defs>
        <text x="36" y="40" text-anchor="middle" font-size="13" font-weight="700" fill="#6366f1" id="${containerId}-pct">0%</text>
      </svg>
      <p class="text-[12px] text-violet-600 font-medium text-center" id="${containerId}-phase">${phases[0]}</p>
    </div>`;

  document.getElementById(containerId).innerHTML = html;

  const milestones = phases.map((_, i) => Math.round(((i + 1) / totalPhases) * 90));

  timer = setInterval(() => {
    if (pct >= 90) { clearInterval(timer); return; }
    pct = Math.min(pct + 1, milestones[phase] || 90);
    const offset = 188.5 * (1 - pct / 100);
    const ring = document.getElementById(`${containerId}-ring`);
    const pctEl = document.getElementById(`${containerId}-pct`);
    const phEl  = document.getElementById(`${containerId}-phase`);
    if (ring)  ring.style.strokeDashoffset = offset;
    if (pctEl) pctEl.textContent = pct + '%';
    if (phEl && pct >= milestones[phase] && phase < totalPhases - 1) {
      phase++;
      phEl.textContent = phases[phase];
    }
  }, intervalMs);

  return {
    finish: () => {
      clearInterval(timer);
      const ring = document.getElementById(`${containerId}-ring`);
      const pctEl = document.getElementById(`${containerId}-pct`);
      if (ring)  ring.style.strokeDashoffset = '0';
      if (pctEl) pctEl.textContent = '100%';
    }
  };
}

// ── Tab switching ─────────────────────────────────────────────────────────────
const VALID_TABS = ['summary', 'individual', 'ai', 'report'];

function switchTab(tab) {
  VALID_TABS.forEach(t => {
    document.getElementById('panel-' + t)?.classList.toggle('hidden', t !== tab);
    const btn = document.getElementById('tab-' + t);
    if (!btn) return;
    if (t === tab) {
      btn.classList.add('text-indigo-600', 'border-indigo-600');
      btn.classList.remove('text-slate-400', 'border-transparent', 'hover:text-slate-600');
    } else {
      btn.classList.remove('text-indigo-600', 'border-indigo-600');
      btn.classList.add('text-slate-400', 'border-transparent', 'hover:text-slate-600');
    }
  });
  // Persist active tab in URL hash so language switcher reloads restore it
  history.replaceState(null, '', location.pathname + location.search + '#' + tab);
}

// Restore tab from URL hash on load
(function() {
  const hash = location.hash.replace('#', '');
  if (VALID_TABS.includes(hash)) switchTab(hash);

  // Update language switcher links to carry the current hash through reloads
  document.querySelectorAll('a[href*="?locale="]').forEach(function(link) {
    link.addEventListener('click', function() {
      this.href = this.href.split('#')[0] + location.hash;
    });
  });
})();

function toggleRow(id) {
  const row = document.getElementById('row-detail-' + id);
  if (row) row.classList.toggle('hidden');
}

function toggleReport() {
  const full   = document.getElementById('report-full');
  const label  = document.getElementById('report-toggle-label');
  if (!full) return;
  const hidden = full.classList.toggle('hidden');
  label.textContent = hidden ? I18N.report_view_full : I18N.report_collapse;
}

// ── AI Analysis ───────────────────────────────────────────────────────────────
async function requestAiAnalysis() {
  const lang    = document.getElementById('ai-lang')?.value || 'vi';
  const panel   = document.getElementById('ai-panel');
  const btn     = document.getElementById('analyze-btn');
  const spinner = document.getElementById('analyze-spinner');

  switchTab('ai');

  if (btn) btn.disabled = true;
  if (spinner) spinner.classList.remove('hidden');

  panel.innerHTML = `<div id="analysis-progress"></div>`;
  const progress = makeProgressRing('analysis-progress', I18N.analysis_phases, 300);

  const resetBtn = () => { if (btn) btn.disabled = false; if (spinner) spinner.classList.add('hidden'); };

  try {
    const resp = await fetch(ANALYZE_URL, {
      method: 'POST',
      headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json', 'Content-Type': 'application/json' },
      body: JSON.stringify({ language: lang })
    });
    const data = await resp.json();
    if (window.handleAiUpgrade(resp, data, '<%= j t("surveys.results.tab_ai") %>')) {
      progress.finish();
      panel.innerHTML = '';
      resetBtn();
      return;
    }
    if (!resp.ok) {
      resetBtn();
      panel.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-[10px] p-4 text-[13px] text-red-600">❌ ${data.error || I18N.error_retry}</div>`;
      return;
    }
    pollAnalysis(data.job_id, progress, panel, resetBtn);
  } catch(e) {
    resetBtn();
    panel.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-[10px] p-4 text-[13px] text-red-600">❌ ${I18N.error_retry}</div>`;
  }
}

async function pollAnalysis(jobId, progress, panel, resetBtn) {
  const resp = await fetch(STATUS_URL.replace('__ID__', jobId));
  const data = await resp.json();
  if (data.status === 'done') {
    progress.finish();
    setTimeout(() => {
      window.deductDisplayCredits?.(5);
      const dot = document.getElementById('ai-tab-dot');
      if (dot) dot.classList.remove('hidden');
      location.reload();
    }, 500);
  } else if (data.status === 'failed') {
    if (resetBtn) resetBtn();
    panel.innerHTML = `<div class="bg-red-50 border border-red-200 rounded-[10px] p-4 text-[13px] text-red-600">❌ ${I18N.analysis_failed}</div>`;
  } else {
    setTimeout(() => pollAnalysis(jobId, progress, panel, resetBtn), 2500);
  }
}

// ── Executive Report ──────────────────────────────────────────────────────────
function resetReportUI(statusEl, btn, spinner, msg) {
  statusEl.innerHTML = msg ? `<div class="flex items-center gap-2 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-[13px] text-amber-700 mb-4"><span>⚠️</span><span>${msg}</span></div>` : '';
  if (btn) btn.disabled = false;
  if (spinner) spinner.classList.add('hidden');
}

async function requestReport() {
  const lang     = document.getElementById('report-lang')?.value || 'vi';
  const statusEl = document.getElementById('report-status');
  const btn      = document.getElementById('report-btn');
  const spinner  = document.getElementById('report-spinner');

  // Must have AI analysis first
  if (!HAS_ANALYSIS) {
    statusEl.innerHTML = `<div class="flex items-center gap-2 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-[13px] text-amber-700 mb-4">
      <span>⚠️</span>
      <span>${NO_ANALYSIS_MSG} <button onclick="switchTab('ai')" class="underline font-semibold ml-1 bg-transparent border-0 cursor-pointer text-amber-700">${'<%= j t("surveys.results.tab_ai") %>'} →</button></span>
    </div>`;
    return;
  }

  statusEl.innerHTML = `<div class="border border-violet-100 rounded-lg bg-violet-50 mb-4" id="report-progress"></div>`;
  if (btn) { btn.disabled = true; }
  if (spinner) spinner.classList.remove('hidden');
  const progress = makeProgressRing('report-progress', I18N.report_phases, 600);

  try {
    const resp = await fetch(REPORT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF, 'Accept': 'application/json' },
      body: JSON.stringify({ language: lang })
    });
    const data = await resp.json();
    if (window.handleAiUpgrade(resp, data, '<%= j t("surveys.results.create_report") %>')) {
      // Clear progress area — upgrade modal will guide user
      progress.finish();
      resetReportUI(statusEl, btn, spinner, null);
      return;
    }
    if (!resp.ok) {
      progress.finish();
      resetReportUI(statusEl, btn, spinner, data.error || I18N.error_retry);
      return;
    }
    pollReport(data.job_id, progress, statusEl, btn, spinner);
  } catch(e) {
    resetReportUI(statusEl, btn, spinner, I18N.error_retry);
  }
}

async function pollReport(jobId, progress, statusEl, btn, spinner) {
  const resp = await fetch(STATUS_URL.replace('__ID__', jobId));
  const data = await resp.json();
  if (data.status === 'done') {
    progress.finish();
    setTimeout(() => {
      window.deductDisplayCredits?.(15);
      const dot = document.getElementById('report-tab-dot');
      if (dot) dot.classList.remove('hidden');
      location.reload();
    }, 500);
  } else if (data.status === 'failed') {
    statusEl.innerHTML = `<div class="text-[12px] text-red-600 py-2">❌ ${I18N.report_failed}</div>`;
    if (btn) { btn.disabled = false; }
    if (spinner) spinner.classList.add('hidden');
  } else {
    setTimeout(() => pollReport(jobId, progress, statusEl, btn, spinner), 3000);
  }
}

// ── Export report (PDF only) ──────────────────────────────────────────────────
function checkReport(e, fmt) {
  if (!HAS_REPORT) {
    e.preventDefault();
    switchTab('report');
    let toast = document.getElementById('no-report-toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'no-report-toast';
      toast.className = 'mb-4 flex items-center gap-2 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-[13px] text-amber-700';
      toast.innerHTML = '<span>⚠️</span><span>' + NO_REPORT_MSG + '</span>';
      const panel = document.getElementById('panel-report');
      panel?.insertBefore(toast, panel.firstChild);
    }
    toast.classList.remove('hidden');
    setTimeout(() => toast?.classList.add('hidden'), 5000);
    return false;
  }
  return true;
}

// ── PDF Export with loading popup ─────────────────────────────────────────────
function setPdfProgress(pct) {
  const bar = document.getElementById('pdf-progress-bar');
  const lbl = document.getElementById('pdf-progress-pct');
  if (bar) bar.style.width = pct + '%';
  if (lbl) lbl.textContent = pct + '%';
}

function closePdfModal() {
  const m = document.getElementById('pdf-loading-modal');
  if (m) m.style.display = 'none';
  // Reset href token for next export
  const btn = document.getElementById('export-pdf-btn');
  if (btn) {
    const base = btn.href.split('?')[0];
    btn.href = base + '?format_type=pdf';
  }
}

function startPdfExport(e) {
  if (!HAS_REPORT) {
    e.preventDefault();
    switchTab('report');
    let toast = document.getElementById('no-report-toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = 'no-report-toast';
      toast.className = 'mb-4 flex items-center gap-2 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-[13px] text-amber-700';
      toast.innerHTML = '<span>⚠️</span><span>' + NO_REPORT_MSG + '</span>';
      document.getElementById('panel-report')?.insertBefore(toast, document.getElementById('panel-report').firstChild);
    }
    toast.classList.remove('hidden');
    setTimeout(() => toast?.classList.add('hidden'), 5000);
    return false;
  }

  // Attach unique token to URL
  const token = 'pdf_' + Date.now();
  const btn   = document.getElementById('export-pdf-btn');
  btn.href    = btn.href.split('?')[0] + '?format_type=pdf&download_token=' + token;

  // Build modal if not exists
  if (!document.getElementById('pdf-loading-modal')) {
    const m = document.createElement('div');
    m.id = 'pdf-loading-modal';
    m.className = 'fixed inset-0 z-[70] flex items-center justify-center';
    m.innerHTML = `
      <div class="absolute inset-0 bg-black/40"></div>
      <div class="relative bg-white rounded-2xl shadow-xl p-8 w-[340px] text-center">
        <div class="text-[36px] mb-4">📄</div>
        <h3 id="pdf-modal-title" class="text-[16px] font-extrabold text-slate-900 mb-1"></h3>
        <p  id="pdf-modal-desc"  class="text-[12px] text-slate-400 mb-5"></p>
        <div class="h-2 bg-slate-100 rounded-full overflow-hidden mb-3">
          <div id="pdf-progress-bar" class="h-full bg-gradient-to-r from-indigo-500 to-violet-500 rounded-full" style="width:0%;transition:width 0.4s ease"></div>
        </div>
        <div id="pdf-progress-pct" class="text-[13px] font-bold text-indigo-600">0%</div>
      </div>`;
    document.body.appendChild(m);
  }

  // Reset and show
  document.getElementById('pdf-modal-title').textContent = 'Đang tạo PDF...';
  document.getElementById('pdf-modal-desc').textContent  = 'Vui lòng chờ, quá trình này mất khoảng 10–20 giây';
  setPdfProgress(0);
  document.getElementById('pdf-loading-modal').style.display = 'flex';

  // Smooth progress animation up to 88%
  let currentPct = 0;
  const allIntervals = [];
  const phases = [
    { target: 20, ms: 1500 },
    { target: 50, ms: 3000 },
    { target: 75, ms: 4000 },
    { target: 88, ms: 5000 },
  ];
  let pi = 0;
  function runPhase() {
    if (pi >= phases.length) return;
    const { target, ms } = phases[pi++];
    const steps  = 20;
    const stepMs = ms / steps;
    const step   = (target - currentPct) / steps;
    const iv = setInterval(() => {
      currentPct = Math.min(currentPct + step, target);
      setPdfProgress(Math.round(currentPct));
      if (Math.round(currentPct) >= target) { clearInterval(iv); runPhase(); }
    }, stepMs);
    allIntervals.push(iv);
  }
  runPhase();

  // Poll cookie every 500ms
  const poller = setInterval(() => {
    const found = document.cookie.split(';').some(c => c.trim().startsWith('fileDownloadToken=' + token));
    if (!found) return;
    // Stop all animations
    allIntervals.forEach(clearInterval);
    clearInterval(poller);
    // Clear cookie
    document.cookie = 'fileDownloadToken=; Max-Age=0; path=/';
    // Complete
    setPdfProgress(100);
    document.getElementById('pdf-modal-title').textContent = '✅ Hoàn thành!';
    document.getElementById('pdf-modal-desc').textContent  = 'File PDF đã được tải xuống.';
    setTimeout(closePdfModal, 1500);
  }, 500);

  // Fallback: close after 90s
  setTimeout(() => { clearInterval(poller); allIntervals.forEach(clearInterval); closePdfModal(); }, 90000);

  return true;
}

Object.assign(window, { switchTab, toggleRow, requestAiAnalysis, requestReport, toggleReport, checkReport, startPdfExport });
})();
</script>
