async function suggestReportPrompt() {
  const btn = document.getElementById('suggest-prompt-btn');
  const icon = document.getElementById('suggest-icon');
  const label = document.getElementById('suggest-label');
  const overlay = document.getElementById('suggest-loading-overlay');
  const wrap = document.getElementById('report-context-wrap');
  const ring = document.getElementById('suggest-ring');
  const subText = document.getElementById('suggest-loading-sub');
  if (btn.disabled) return;

  // Show overlay, hide editor
  btn.disabled = true;
  btn.style.opacity = '0.75';
  btn.style.cursor = 'not-allowed';
  icon.textContent = '✨';
  label.textContent = 'Đang phân tích...';
  if (overlay) overlay.style.display = 'flex';
  if (wrap) wrap.style.display = 'none';

  // Animate progress ring: creep from 0→85% over ~12s
  let ringPct = 0;
  const phases = ['AI đang đọc dữ liệu khảo sát...', 'Phân tích xu hướng và trọng tâm...', 'Đang tạo gợi ý prompt...'];
  let phaseIdx = 0;
  const ringTimer = setInterval(() => {
    ringPct = Math.min(ringPct + 1.2, 85);
    if (ring) ring.style.strokeDashoffset = (150.8 * (1 - ringPct / 100)).toFixed(1);
    const milestone = (phaseIdx + 1) / phases.length * 85;
    if (ringPct >= milestone && phaseIdx < phases.length - 1) {
      phaseIdx++;
      if (subText) subText.textContent = phases[phaseIdx];
    }
  }, 200);

  // Get selected language
  const langEl = document.querySelector('input[name="language"]:checked') ||
                 document.querySelector('select[name="language"]');
  const language = langEl ? langEl.value : 'vi';

  try {
    const res = await fetch('<%= ai_suggest_prompt_survey_path(@survey) %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
      body: JSON.stringify({ language })
    });
    const data = await res.json();
    // Finish ring to 100%
    clearInterval(ringTimer);
    if (ring) ring.style.strokeDashoffset = '0';

    if (data.suggestion) {
      if (window.setReportContext) window.setReportContext(data.suggestion);
      // Show copy button
      const copyBtn = document.getElementById('copy-prompt-btn');
      if (copyBtn) { copyBtn.style.display = 'flex'; }

      // Show truncation warning if content was cut off
      const truncWarn = document.getElementById('suggest-truncation-warn');
      if (truncWarn) truncWarn.style.display = data.truncated ? 'flex' : 'none';

      icon.textContent = data.truncated ? '⚠️' : '✅';
      label.textContent = data.truncated ? 'Prompt bị cắt!' : 'Đã gợi ý!';
      btn.style.background = data.truncated
        ? 'linear-gradient(135deg,#d97706,#f59e0b)'
        : 'linear-gradient(135deg,#059669,#10b981)';
      if (wrap) { wrap.style.borderColor = data.truncated ? '#f59e0b' : '#8b5cf6'; }
      setTimeout(() => {
        icon.textContent = '✨'; label.textContent = 'AI gợi ý prompt';
        btn.style.background = 'linear-gradient(135deg,#7c3aed,#6366f1)';
        if (wrap) wrap.style.borderColor = '';
      }, data.truncated ? 5000 : 2500);
    } else {
      icon.textContent = '⚠️';
      label.textContent = data.error || 'Lỗi';
      btn.style.background = 'linear-gradient(135deg,#dc2626,#ef4444)';
      setTimeout(() => {
        icon.textContent = '✨'; label.textContent = 'AI gợi ý prompt';
        btn.style.background = 'linear-gradient(135deg,#7c3aed,#6366f1)';
      }, 3000);
    }
  } catch(e) {
    clearInterval(ringTimer);
    icon.textContent = '⚠️';
    label.textContent = 'Lỗi kết nối';
    btn.style.background = 'linear-gradient(135deg,#dc2626,#ef4444)';
    setTimeout(() => {
      icon.textContent = '✨'; label.textContent = 'AI gợi ý prompt';
      btn.style.background = 'linear-gradient(135deg,#7c3aed,#6366f1)';
    }, 3000);
  } finally {
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
    // Hide overlay, show editor
    if (overlay) overlay.style.display = 'none';
    if (wrap) wrap.style.display = '';
  }
}

