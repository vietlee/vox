<% content_for :title, t("surveys.results.page_title", title: @survey.title) %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<%
  option_labels = @questions.flat_map(&:question_options).each_with_object({}) { |o, h| h[o.id.to_s] = o.label }
  response_answer_map = @individual_responses.each_with_object({}) do |r, h|
    h[r.id] = r.answers.index_by(&:question_id)
  end

  def fmt_answer(ans, option_labels)
    return "—" if ans.nil?
    if ans.uploaded_file.attached?
      "📎 #{ans.uploaded_file.filename}"
    elsif ans.text_value.present?
      ans.text_value.truncate(80)
    elsif ans.numeric_value.present?
      ans.numeric_value.to_i.to_s
    elsif ans.option_ids.present?
      ans.option_ids.map { |id| option_labels[id.to_s] || id }.join(", ").truncate(80)
    elsif ans.date_value.present?
      ans.date_value.to_s
    else
      "—"
    end
  end
%>

<!-- ── Page header (fixed) ──────────────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
<div class="flex items-start justify-between mb-3">
  <div class="flex items-start gap-3">
    <a href="<%= survey_path(@survey) %>"
       class="mt-1 flex-shrink-0 w-7 h-7 rounded-lg flex items-center justify-center bg-white border border-slate-200 text-slate-500 hover:bg-slate-50 hover:text-slate-700 transition-colors"
       title="<%= t("common.back") %>">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
      </svg>
    </a>
    <div>
      <h1 class="text-[19px] font-extrabold text-slate-900"><%= @survey.title %></h1>
      <p class="text-[12px] text-slate-500 mt-0.5"><%= t("surveys.results.subtitle", count: @total_responses, rate: @survey.completion_rate) %></p>
    </div>
  </div>
  <div class="flex gap-2">
  
    <% if @survey.active? %>
      <button onclick="showSurveyCloseConfirm()"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-red-50 hover:text-red-600 hover:border-red-200 text-slate-700 transition-colors">
        ⏹ <%= t("surveys.close_action") %>
      </button>
      <form id="survey-close-form" action="<%= close_survey_path(@survey) %>" method="post" class="hidden">
        <%= hidden_field_tag :_method, :patch %>
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      </form>
    <% elsif @survey.closed? %>
      <%= button_to reopen_survey_path(@survey), method: :patch,
          class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-emerald-200 hover:bg-emerald-50 hover:text-emerald-700 text-emerald-600 transition-colors" do %>
        ▶ <%= t("surveys.reopen") %>
      <% end %>
    <% end %>
    <button onclick="switchTab('ai')"
      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-violet-50 hover:text-violet-700 hover:border-violet-200 text-slate-700 transition-colors">
      <%= t("surveys.results.tab_ai") %>
      <% if @ai_analysis %>
        <span class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block"></span>
      <% end %>
    </button>
    
    <button onclick="switchTab('report')"
      class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-blue-50 hover:text-blue-700 hover:border-blue-200 text-slate-700 transition-colors">
      📄 <%= t("surveys.results.tab_report").gsub(/\A📄\s*/, '') %>
    </button>
    <!-- Export AI report -->
    <button onclick="openExportPicker()"
       class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-slate-50 hover:border-slate-300 text-slate-700 transition-colors">
      📄 <%= t("surveys.results.export_report") %>
    </button>
    <!-- Export CSV -->
    <a href="<%= export_survey_path(@survey) %>"
       data-turbo="false"
       onclick="btnDownloadLoading(this)"
       class="inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-emerald-50 hover:text-emerald-700 hover:border-emerald-200 text-slate-700 transition-colors">
      ⬇ CSV
    </a>
    
  </div>
</div>

<!-- Tabs -->
<div class="flex gap-0 border-b border-slate-200">
  <button id="tab-summary" onclick="switchTab('summary')"
    class="px-4 py-2.5 text-[13px] font-semibold text-indigo-600 border-b-2 border-slate-600 -mb-px bg-transparent transition-colors">
    <%= t("surveys.results.tab_summary") %>
  </button>
  <button id="tab-individual" onclick="switchTab('individual')"
    class="px-4 py-2.5 text-[13px] font-semibold text-slate-400 border-b-2 border-transparent -mb-px bg-transparent hover:text-slate-600 transition-colors">
    <%= t("surveys.results.tab_individual", count: @total_responses) %>
  </button>
  <button id="tab-ai" onclick="switchTab('ai')"
    class="px-4 py-2.5 text-[13px] font-semibold text-slate-400 border-b-2 border-transparent -mb-px bg-transparent hover:text-slate-600 transition-colors flex items-center gap-1.5">
    <%= t("surveys.results.tab_ai") %>
    <% if @ai_analysis %>
      <span id="ai-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block"></span>
    <% else %>
      <span id="ai-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block hidden"></span>
    <% end %>
  </button>
  <% latest_report_check = @survey.ai_analysis_results.where(result_type: "executive_report").exists? %>
  <button id="tab-report" onclick="switchTab('report')"
    class="px-4 py-2.5 text-[13px] font-semibold text-slate-400 border-b-2 border-transparent -mb-px bg-transparent hover:text-slate-600 transition-colors flex items-center gap-1.5">
    <%= t("surveys.results.tab_report") %>
    <% if latest_report_check %>
      <span id="report-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block"></span>
    <% else %>
      <span id="report-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block hidden"></span>
    <% end %>
  </button>
</div>
</div><!-- /page header -->

<!-- ── Scrollable tab content ────────────────────────────────────────────────── -->
<div id="tab-content-wrap" class="flex-1 min-h-0 overflow-y-auto px-6 pt-4 pb-6">

<!-- Tab: Summary -->
<div id="panel-summary">

<!-- Quick stats bar -->
<div class="grid grid-cols-3 gap-3 mb-5">
  <div class="bg-white border border-slate-200 rounded-[10px] p-3 text-center shadow-sm">
    <div class="text-[22px] font-extrabold text-slate-900"><%= @total_responses %></div>
    <div class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.total_responses") %></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-[10px] p-3 text-center shadow-sm">
    <div class="text-[22px] font-extrabold text-slate-900"><%= @survey.avg_completion_time || t("surveys.results.avg_completion_time_na") %></div>
    <div class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.avg_completion_time") %></div>
  </div>
  <div class="bg-white border border-slate-200 rounded-[10px] p-3 text-center shadow-sm">
    <div class="text-[22px] font-extrabold text-slate-900"><%= @questions.count %></div>
    <div class="text-[11px] text-slate-500 mt-0.5"><%= t("surveys.results.question_count", default: "Câu hỏi") %></div>
  </div>
</div>

<div class="space-y-5">
    <% @questions.each do |question| %>
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
        <h3 class="text-[14px] font-semibold text-slate-900 mb-4"><%= question.title %></h3>
        <% q_answers = response_answer_map.values.map { |h| h[question.id] }.compact %>
        <p class="text-[12px] text-slate-500 mb-3"><%= t("surveys.results.response_count", count: q_answers.count) %></p>

        <% if question.choice_type? %>
          <% total = q_answers.count %>
          <% question.question_options.each do |opt| %>
            <% count = q_answers.count { |a| Array(a.option_ids).map(&:to_s).include?(opt.id.to_s) } %>
            <% pct = total > 0 ? (count.to_f / total * 100).round(1) : 0 %>
            <div class="mb-3">
              <div class="flex justify-between text-[12px] mb-1">
                <span class="text-slate-700"><%= opt.label %></span>
                <span class="text-slate-500"><%= count %> (<%= pct %>%)</span>
              </div>
              <div class="h-5 bg-slate-100 rounded">
                <div class="h-5 bg-gradient-to-r from-indigo-400 to-indigo-600 rounded text-[11px] font-semibold text-white px-2 flex items-center" style="width: <%= pct %>%">
                  <% if pct > 10 %><%= pct %>%<% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% elsif question.numeric_type? %>
          <% values = q_answers.map(&:numeric_value).compact %>
          <% if values.any? %>
            <div class="grid grid-cols-3 gap-4 text-center">
              <div class="bg-slate-50 rounded-lg p-3">
                <div class="text-[20px] font-bold text-slate-900"><%= (values.sum / values.size).round(1) %></div>
                <div class="text-[11px] text-slate-500"><%= t("surveys.results.average") %></div>
              </div>
              <div class="bg-slate-50 rounded-lg p-3">
                <div class="text-[20px] font-bold text-slate-900"><%= values.min %></div>
                <div class="text-[11px] text-slate-500"><%= t("surveys.results.min") %></div>
              </div>
              <div class="bg-slate-50 rounded-lg p-3">
                <div class="text-[20px] font-bold text-slate-900"><%= values.max %></div>
                <div class="text-[11px] text-slate-500"><%= t("surveys.results.max") %></div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="space-y-1.5">
            <% q_answers.first(5).each do |ans| %>
              <% if ans.uploaded_file.attached? %>
                <div class="bg-slate-50 rounded-lg px-3 py-2 text-[13px] text-slate-700 flex items-center gap-2">
                  📎 <%= link_to ans.uploaded_file.filename.to_s, rails_blob_path(ans.uploaded_file, disposition: "attachment"), class: "text-indigo-600 hover:underline", target: "_blank" %>
                  <span class="text-slate-400 text-[11px]">(<%= number_to_human_size(ans.uploaded_file.byte_size) %>)</span>
                </div>
              <% elsif ans.text_value.present? %>
                <div class="bg-slate-50 rounded-lg px-3 py-2 text-[13px] text-slate-700">"<%= ans.text_value %>"</div>
              <% end %>
            <% end %>
            <% if q_answers.count > 5 %>
              <p class="text-[12px] text-slate-400 text-center"><%= t("surveys.results.more_responses", count: q_answers.count - 5) %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div><!-- /panel-summary -->

<!-- Tab: AI Insights -->
<div id="panel-ai" class="hidden flex-col flex-1 min-h-0 overflow-hidden" style="display:none;">
  <div class="h-full flex flex-col rounded-[12px] border overflow-hidden" style="border-color:rgba(139,92,246,0.2); background:rgba(245,243,255,0.6);">

    <!-- Card header: cố định -->
    <div class="flex-shrink-0 flex items-center gap-2 px-4 py-3" style="background:rgba(139,92,246,0.08); border-bottom:1px solid rgba(139,92,246,0.15);">
      <span class="text-[14px]">🔮</span>
      <span class="text-[13px] font-bold text-violet-700"><%= t("surveys.results.ai_executive_summary") %></span>
      <span id="ai-generated-time" class="text-[10px] text-slate-400 ml-1">
        <%= @ai_analysis ? I18n.l(@ai_analysis.created_at.in_time_zone, format: :short) : "" %>
      </span>
      <div class="ml-auto flex flex-col items-end gap-1">
        <div class="flex items-center gap-2">
          <!-- Language selector -->
          <div class="relative">
            <select id="ai-lang"
              class="appearance-none pl-3 pr-7 py-1.5 text-[12px] font-semibold bg-white border border-slate-200 rounded-lg text-slate-600 hover:border-violet-300 focus:outline-none focus:border-violet-400 cursor-pointer">
              <option value="vi" <%= current_workspace.language == "vi" ? "selected" : "" %>><%= t("surveys.results.report_lang_vi") %></option>
              <option value="en" <%= current_workspace.language == "en" ? "selected" : "" %>><%= t("surveys.results.report_lang_en") %></option>
            </select>
            <span class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 text-[10px]">▾</span>
          </div>
          <span class="text-[10px] text-slate-400 font-medium"><%= t("surveys.results.ai_requires") %></span>
          <button id="analyze-btn" onclick="requestAiAnalysis()" <%= @total_responses == 0 ? 'disabled' : '' %>
            class="px-3 py-1.5 bg-violet-600 hover:bg-violet-700 text-white text-[12px] font-semibold rounded-lg flex items-center gap-1.5 disabled:opacity-40 disabled:cursor-not-allowed">
            <span id="analyze-spinner" class="hidden w-3 h-3 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
            ✨ <%= t("surveys.results.analyze_btn") %>
          </button>
        </div>
        <% if @total_responses == 0 %>
          <span class="text-[10px] font-semibold text-red-500 flex items-center gap-1">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <%= t("surveys.results.no_responses_to_analyze") %>
          </span>
        <% elsif @ai_analysis %>
          <% if @new_responses_since_analysis > 0 %>
            <span class="text-[10px] font-semibold text-amber-600 flex items-center gap-1">
              <span class="inline-block w-1.5 h-1.5 rounded-full bg-amber-500"></span>
              <%= t("surveys.results.new_responses_since_analysis", count: @new_responses_since_analysis) %>
            </span>
          <% else %>
            <span class="text-[10px] text-red-500 font-medium"><%= t("surveys.results.no_new_responses") %></span>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Card body: scrollable -->
    <div id="ai-panel" class="flex-1 min-h-0 overflow-y-auto p-5">
      <% if @ai_analysis %>
        <%= render "admin/surveys/ai_analysis_card", analysis: @ai_analysis %>
      <% else %>
        <div class="flex flex-col items-center justify-center h-full text-center text-slate-400 py-12">
          <div class="text-4xl mb-3">🔮</div>
          <p class="text-[13px]"><%= t("surveys.results.get_analysis") %></p>
        </div>
      <% end %>
    </div>

  </div>
</div><!-- /panel-ai -->

<!-- Tab: Create Report -->
<div id="panel-report" class="hidden">
  <% all_reports = @survey.ai_analysis_results.where(result_type: "executive_report").order(created_at: :desc) %>

  <div class="grid grid-cols-[1fr_340px] gap-5">

    <!-- Left: Create new report -->
    <div class="bg-white rounded-[12px] border border-slate-200 shadow-sm overflow-hidden flex flex-col">
      <!-- Header -->
      <div class="flex-shrink-0 flex items-center gap-2 px-4 py-3" style="background:rgba(139,92,246,0.08); border-bottom:1px solid rgba(139,92,246,0.15);">
        <span class="text-[14px]">📄</span>
        <span class="text-[13px] font-bold text-violet-700"><%= t("surveys.results.executive_report") %></span>
        <span class="ml-2 text-[10px] text-slate-400 font-medium">15 credits / lần</span>
      </div>

      <div class="p-5 flex flex-col gap-4 flex-1">
        <!-- Status area -->
        <div id="report-status"></div>

        <!-- Context input -->
        <div>
          <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1.5">
            Ngữ cảnh & Trọng tâm báo cáo
          </label>
          <textarea id="report-context" rows="5" maxlength="800"
            placeholder="Mô tả mục đích báo cáo, đối tượng nhận, và định dạng bạn muốn...&#10;&#10;Ví dụ: Báo cáo cho cuộc họp ban giám đốc tháng 6. Tập trung vào vấn đề môi trường làm việc. Tạo file Word có bảng tóm tắt và biểu đồ minh hoạ."
            class="w-full px-3 py-2.5 text-[13px] text-slate-800 rounded-lg resize-none outline-none"
            style="border:1.5px solid #e2e8f0; font-size:13px; line-height:1.6;"
            onfocus="this.style.borderColor='#8b5cf6'" onblur="this.style.borderColor='#e2e8f0'"
            oninput="updateReportBtn()"></textarea>
        </div>

        <!-- Language -->
        <div>
          <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1.5">Ngôn ngữ</label>
          <div class="relative w-48">
            <select id="report-lang"
              class="w-full appearance-none pl-3 pr-7 py-2 text-[12px] font-semibold bg-white border border-slate-200 rounded-lg text-slate-600 focus:outline-none focus:border-violet-400 cursor-pointer">
              <option value="vi" <%= current_workspace.language == "vi" ? "selected" : "" %>>🇻🇳 Tiếng Việt</option>
              <option value="en" <%= current_workspace.language == "en" ? "selected" : "" %>>🇬🇧 English</option>
            </select>
            <span class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 text-[10px]">▾</span>
          </div>
        </div>

        <!-- Warning if no analysis -->
        <% if @total_responses == 0 %>
          <div class="flex items-start gap-2 px-3 py-2.5 rounded-lg text-[12px]" style="background:rgba(239,68,68,0.07); border:1px solid rgba(239,68,68,0.25); color:#991b1b;">
            <span class="flex-shrink-0 mt-0.5">🚫</span>
            <span><strong><%= t("surveys.results.no_responses_cannot_report") %></strong></span>
          </div>
        <% elsif !@ai_analysis %>
          <div class="flex items-start gap-2 px-3 py-2.5 rounded-lg text-[12px]" style="background:rgba(245,158,11,0.08); border:1px solid rgba(245,158,11,0.25); color:#92400e;">
            <span class="flex-shrink-0 mt-0.5">⚠️</span>
            <span>Chạy <strong>AI Insight</strong> trước để báo cáo được tạo ra chất lượng hơn.</span>
          </div>
        <% end %>

        <!-- Generate button -->
        <button id="report-btn" onclick="requestReport()" disabled
          class="w-full py-2.5 text-[13px] font-bold text-white rounded-lg flex items-center justify-center gap-2 hover:opacity-90 transition-opacity disabled:opacity-40 disabled:cursor-not-allowed"
          style="background:linear-gradient(135deg,#7c3aed,#6366f1);">
          <span id="report-spinner" class="hidden w-3.5 h-3.5 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
          ✨ Tạo báo cáo với AI
        </button>
      </div>
    </div>

    <!-- Right: Reports history -->
    <div class="rounded-[12px] border overflow-hidden flex flex-col" style="border-color:rgba(139,92,246,0.2); background:rgba(245,243,255,0.4);">
      <!-- Header -->
      <div class="flex-shrink-0 flex items-center gap-2 px-4 py-3" style="background:rgba(139,92,246,0.08); border-bottom:1px solid rgba(139,92,246,0.15);">
        <span class="text-[14px]">📋</span>
        <span class="text-[13px] font-bold text-violet-700">Báo cáo đã tạo</span>
        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-violet-100 text-violet-600"><%= all_reports.count %></span>
      </div>

      <div id="reports-list" class="flex flex-col gap-3 p-4 overflow-y-auto flex-1" style="max-height:calc(100vh - 320px);">
        <% if all_reports.any? %>
          <% all_reports.each do |rpt| %>
            <% rpt_meta   = rpt.output["_meta"] || {} %>
            <% rpt_fmt    = rpt_meta["format"] || "pdf" %>
            <% rpt_lang   = rpt_meta["language"] == "en" ? "EN" : "VI" %>
            <% rpt_ctx    = rpt_meta["user_context"] %>
            <% rpt_title  = rpt.output["title"].presence || @survey.title %>
            <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4" id="report-card-<%= rpt.id %>">
              <div class="flex items-start justify-between gap-2 mb-2">
                <div class="flex-1 min-w-0">
                  <div class="text-[12px] font-semibold text-slate-800 truncate"><%= rpt_title %></div>
                  <div class="flex items-center gap-2 mt-1">
                    <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold <%= rpt_fmt == 'pdf' ? 'bg-red-50 text-red-600' : rpt_fmt == 'word' ? 'bg-blue-50 text-blue-600' : 'bg-emerald-50 text-emerald-600' %>">
                      <%= rpt_fmt == 'word' ? 'WORD' : rpt_fmt.upcase %>
                    </span>
                    <span class="text-[10px] text-slate-400 font-medium"><%= rpt_lang %></span>
                    <span class="text-[10px] text-slate-400"><%= rpt.created_at.in_time_zone.strftime("%d/%m/%Y %H:%M") %></span>
                  </div>
                </div>
              </div>
              <% if rpt_ctx.present? %>
                <p class="text-[11px] text-slate-500 italic mb-2 line-clamp-2">"<%= rpt_ctx %>"</p>
              <% end %>
              <p class="text-[11px] text-slate-600 line-clamp-2 mb-3">
                <%= rpt.output["executive_summary"]&.truncate(100) %>
              </p>
              <div class="flex gap-2">
                <a href="<%= export_report_survey_path(@survey, report_id: rpt.id, format_type: rpt_fmt) %>"
                   data-turbo="false"
                   onclick="btnDownloadLoading(this)"
                   class="flex-1 inline-flex items-center justify-center gap-1.5 px-3 py-1.5 text-[11px] font-semibold rounded-lg text-white hover:opacity-90 transition-opacity"
                   style="background:linear-gradient(135deg,#7c3aed,#6366f1);">
                  ⬇ Tải <%= rpt_fmt == 'word' ? 'WORD' : rpt_fmt.upcase %>
                </a>
                <button onclick="deleteReport(<%= rpt.id %>, '<%= delete_report_survey_path(@survey, report_id: rpt.id) %>')"
