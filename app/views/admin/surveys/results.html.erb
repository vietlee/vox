// ── Progress ring helper ──────────────────────────────────────────────────────
function makeProgressRing(containerId, phases, intervalMs) {
  const totalPhases = phases.length;
  let   phase = 0, pct = 0, timer = null;

  const html = `
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 16px;gap:8px;">
      <!-- % on top -->
      <span id="${containerId}-pct" style="font-size:13px;font-weight:800;color:#7c3aed;letter-spacing:-0.3px;">0%</span>
      <!-- Ring + icon stacked -->
      <div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">
        <svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">
          <circle cx="44" cy="44" r="38" stroke="#ede9fe" stroke-width="6"/>
          <circle id="${containerId}-ring" cx="44" cy="44" r="38"
            stroke="#7c3aed" stroke-width="6" stroke-linecap="round"
            stroke-dasharray="238.8" stroke-dashoffset="238.8"
            style="transition:stroke-dashoffset 0.6s ease;"/>
        </svg>
        <!-- VOX logo pulsing in center -->
        <div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">
          <svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">
            <rect x="0" y="0" width="36" height="36" rx="9" fill="#1A6BFF"/>
            <polygon points="10,24 6,31 16,24" fill="white"/>
            <rect x="6" y="6" width="24" height="19" rx="5" fill="white"/>
            <rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/>
            <rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/>
            <rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/>
          </svg>
        </div>
      </div>
      <p id="${containerId}-phase" style="font-size:12px;font-weight:600;color:#6366f1;text-align:center;max-width:220px;margin:0;">${phases[0]}</p>
    </div>`;

  document.getElementById(containerId).innerHTML = html;

  const ring  = document.getElementById(`${containerId}-ring`);
  const pctEl = document.getElementById(`${containerId}-pct`);
  const phEl  = document.getElementById(`${containerId}-phase`);

  function setProgress(p) {
    const offset = 238.8 * (1 - p / 100);
    if (ring)  ring.style.strokeDashoffset = offset;
    if (pctEl) pctEl.textContent = Math.round(p) + '%';
  }

  // Phases advance up to 85%; after that, slow creep to 98% keeps the bar moving
  const milestones = phases.map((_, i) => Math.round(((i + 1) / totalPhases) * 85));

  timer = setInterval(() => {
    const target = milestones[phase] || 85;
    pct = Math.min(pct + 1, target);
    setProgress(pct);

    if (phEl && pct >= (milestones[phase] || 85) && phase < totalPhases - 1) {
      phase++;
      phEl.textContent = phases[phase];
    }

    // Switch to slow-creep once all phases are done
    if (pct >= 85 && phase >= totalPhases - 1) {
      clearInterval(timer);
      // Creep 0.4% every 3 s — visibly moving but slow; stops at 98%
      timer = setInterval(() => {
        if (pct >= 98) { clearInterval(timer); return; }
        pct = Math.min(pct + 0.4, 98);
        setProgress(pct);
      }, 3000);
    }
  }, intervalMs);

  return {
    finish: () => {
      clearInterval(timer);
      if (ring)  ring.style.strokeDashoffset = '0';
      if (pctEl) pctEl.textContent = '100%';
    }
  };
}

// ── Tab switching ─────────────────────────────────────────────────────────────
const VALID_TABS = ['summary', 'individual', 'ai', 'report'];

function switchTab(tab) {
  VALID_TABS.forEach(t => {
    const panel = document.getElementById('panel-' + t);
    if (!panel) return;
    if (t === tab) {
      panel.classList.remove('hidden');
      // AI panel needs flex display to fill height properly
      if (t === 'ai') panel.style.display = 'flex';
    } else {
      panel.classList.add('hidden');
      if (t === 'ai') panel.style.display = '';
    }
    const btn = document.getElementById('tab-' + t);
    if (!btn) return;
    if (t === tab) {
      btn.classList.add('text-indigo-600', 'border-slate-600');
      btn.classList.remove('text-slate-400', 'border-transparent', 'hover:text-slate-600');
    } else {
      btn.classList.remove('text-indigo-600', 'border-slate-600');
      btn.classList.add('text-slate-400', 'border-transparent', 'hover:text-slate-600');
    }
  });
  // Toggle outer wrapper: AI tab fills viewport, others scroll freely
  const wrap = document.getElementById('tab-content-wrap');
  if (wrap) {
    if (tab === 'ai') {
      wrap.classList.remove('overflow-y-auto');
      wrap.classList.add('overflow-hidden', 'flex', 'flex-col');
    } else {
      wrap.classList.add('overflow-y-auto');
      wrap.classList.remove('overflow-hidden', 'flex', 'flex-col');
    }
  }
  // Persist active tab in URL hash so language switcher reloads restore it
  history.replaceState(null, '', location.pathname + location.search + '#' + tab);
}

// Restore tab from URL hash on load
(function() {
  const hash = location.hash.replace('#', '');
  const urlParams = new URLSearchParams(location.search);
  // Auto-switch to individual tab when paginating responses
  if (urlParams.has('responses_page') || hash === 'individual') {
    switchTab('individual');
  } else if (VALID_TABS.includes(hash)) {
    switchTab(hash);
  }

  // Update language switcher links to carry the current hash through reloads
  document.querySelectorAll('a[href*="?locale="]').forEach(function(link) {
    link.addEventListener('click', function() {
      this.href = this.href.split('#')[0] + location.hash;
    });
  });
})();

