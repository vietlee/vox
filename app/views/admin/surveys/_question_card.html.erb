<div class="question-card bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 group" data-question-id="<%= question.id %>">
  <div class="flex items-start gap-3">
    <div class="flex-shrink-0 text-slate-400 cursor-move pt-0.5">⠿</div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-2">
        <span class="inline-flex items-center px-2 py-0.5 rounded-md bg-slate-100 text-[10px] font-semibold text-slate-500 uppercase">
          <%= question.question_type.humanize %>
        </span>
        <% if question.required? %>
          <span class="text-[10px] text-red-500 font-semibold">Required</span>
        <% end %>
      </div>
      <p class="text-[13px] font-semibold text-slate-900"><%= question.title %></p>
      <% if question.question_options.any? %>
        <div class="mt-2 space-y-1">
          <% question.question_options.first(3).each do |opt| %>
            <div class="flex items-center gap-2 text-[12px] text-slate-500">
              <span class="w-3.5 h-3.5 rounded-full border border-slate-300 flex-shrink-0"></span>
              <%= opt.label %>
            </div>
          <% end %>
          <% if question.question_options.count > 3 %>
            <div class="text-[11px] text-slate-400">+<%= question.question_options.count - 3 %> more options</div>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="flex gap-1 opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0">
      <button class="p-1.5 rounded-md hover:bg-slate-100 text-slate-400 hover:text-slate-600 text-[12px]">✏️</button>
      <%= button_to survey_question_path(@survey, question), method: :delete, data: { confirm: "Delete this question?" },
          class: "p-1.5 rounded-md hover:bg-red-50 text-slate-400 hover:text-red-500 text-[12px]" do %>🗑️<% end %>
    </div>
  </div>
</div>
