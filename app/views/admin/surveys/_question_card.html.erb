<%
  has_options    = %w[single_choice multiple_choice dropdown ranking].include?(question.question_type)
  has_min_max    = %w[linear_scale rating nps].include?(question.question_type)
  survey_id      = question.survey_id
  q_url          = survey_question_path(survey_id, question)
  opts_url       = survey_question_question_options_path(survey_id, question)
  cond           = question.conditional_logic.presence || {}
  cond_source    = cond['source_question_id'].to_s
  cond_op        = cond['operator'].presence || 'equals'
  cond_value     = cond['value'].to_s
  has_condition  = cond_source.present?
  q_min_label    = question.settings["min_label"].to_s
  q_max_label    = question.settings["max_label"].to_s
%>

<div class="question-card bg-white rounded-[10px] border border-slate-200 shadow-sm group" data-question-id="<%= question.id %>">

  <!-- Summary row -->
  <div class="flex items-start gap-3 p-4">
    <div class="drag-handle flex-shrink-0 text-slate-300 cursor-grab active:cursor-grabbing pt-0.5 text-[16px] select-none">⠿</div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1.5">
        <span class="question-type-badge inline-flex items-center px-2 py-0.5 rounded-md bg-slate-100 text-[10px] font-semibold text-slate-500 uppercase">
          <%= question.question_type.humanize %>
        </span>
        <span class="question-required-badge text-[10px] text-red-500 font-semibold <%= 'hidden' unless question.required? %>"><%= t("surveys.question_card.required_label") %></span>
      </div>
      <p class="question-summary-title text-[13px] font-semibold text-slate-900 leading-snug"><%= question.title %></p>
      <div id="opts-preview-<%= question.id %>" class="mt-1.5 space-y-0.5">
        <% question.question_options.first(3).each do |opt| %>
          <div class="flex items-center gap-2 text-[12px] text-slate-400">
            <span class="w-3 h-3 rounded-full border border-slate-300 flex-shrink-0"></span>
            <%= opt.label %>
          </div>
        <% end %>
        <% if question.question_options.count > 3 %>
          <div class="text-[11px] text-slate-400"><%= t("surveys.question_card.more_options", count: question.question_options.count - 3) %></div>
        <% end %>
      </div>
    </div>
    <div class="flex gap-1 flex-shrink-0">
      <button onclick="toggleEdit(<%= question.id %>)"
        class="p-1.5 rounded-md hover:bg-indigo-50 text-slate-400 hover:text-indigo-600 text-[13px] transition-colors">✏️</button>
      <button onclick="showDeleteQuestionModal(<%= question.id %>, '<%= q_url %>', '<%= j question.title %>')"
        class="p-1.5 rounded-md hover:bg-red-50 text-slate-400 hover:text-red-500 text-[13px] border-0 bg-transparent cursor-pointer">🗑️</button>
    </div>
  </div>

  <!-- Inline editor -->
  <div id="edit-panel-<%= question.id %>" class="hidden border-t border-slate-100 p-4 bg-slate-50 rounded-b-[10px] space-y-3">

    <div>
      <label class="block text-[11px] font-semibold text-slate-600 mb-1"><%= t("surveys.question_card.question_label") %></label>
      <input type="text" id="q-title-<%= question.id %>" value="<%= question.title %>"
        class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 outline-none bg-white"
        onblur="saveQuestion(<%= question.id %>, '<%= q_url %>')">
    </div>

    <div>
      <label class="block text-[11px] font-semibold text-slate-600 mb-1"><%= t("surveys.question_card.description_label") %></label>
      <textarea id="q-description-<%= question.id %>" rows="2"
        class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white resize-none"
        placeholder="<%= j t("surveys.question_card.description_placeholder") %>"
        onblur="saveQuestion(<%= question.id %>, '<%= q_url %>')"><%= question.description %></textarea>
    </div>

    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-[11px] font-semibold text-slate-600 mb-1"><%= t("surveys.question_card.type_label") %></label>
        <select id="q-type-<%= question.id %>"
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white"
          onchange="saveQuestion(<%= question.id %>, '<%= q_url %>')">
          <% Question.question_types.keys.each do |type| %>
            <option value="<%= type %>" <%= 'selected' if question.question_type == type %>><%= question_type_label(type) %></option>
          <% end %>
        </select>
      </div>
      <div class="flex items-end pb-1">
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="checkbox" id="q-required-<%= question.id %>" <%= 'checked' if question.required? %>
            class="w-4 h-4 accent-indigo-600"
            onchange="saveQuestion(<%= question.id %>, '<%= q_url %>')">
          <span class="text-[12px] font-semibold text-slate-600"><%= t("surveys.question_card.required_label") %></span>
        </label>
      </div>
    </div>

    <!-- Min/Max labels (linear_scale, rating, nps) -->
    <div id="minmax-panel-<%= question.id %>" class="<%= has_min_max ? '' : 'hidden' %> grid grid-cols-2 gap-3">
      <div>
        <label class="block text-[11px] font-semibold text-slate-600 mb-1">Nhãn nhỏ nhất</label>
        <input type="text" id="q-min-label-<%= question.id %>" value="<%= q_min_label %>"
          placeholder="VD: Rất không hài lòng"
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white"
          onblur="saveQuestion(<%= question.id %>, '<%= q_url %>')">
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-slate-600 mb-1">Nhãn lớn nhất</label>
        <input type="text" id="q-max-label-<%= question.id %>" value="<%= q_max_label %>"
          placeholder="VD: Rất hài lòng"
          class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white"
          onblur="saveQuestion(<%= question.id %>, '<%= q_url %>')">
      </div>
    </div>

    <% if has_options %>
      <div>
        <label class="block text-[11px] font-semibold text-slate-600 mb-2"><%= t("surveys.question_card.options_label") %></label>
        <div id="opts-list-<%= question.id %>" class="space-y-1.5 mb-2">
          <% question.question_options.each do |opt| %>
            <div class="flex items-center gap-2 opt-row" data-opt-id="<%= opt.id %>">
              <input type="text" value="<%= opt.label %>"
                class="flex-1 px-2.5 py-1.5 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white"
                onblur="saveOption(<%= question.id %>, <%= opt.id %>, this.value, '<%= survey_question_question_option_path(survey_id, question, opt) %>')">
              <button onclick="deleteOption(<%= question.id %>, <%= opt.id %>, this, '<%= survey_question_question_option_path(survey_id, question, opt) %>')"
                class="w-6 h-6 flex items-center justify-center text-slate-300 hover:text-red-500 rounded transition-colors text-[15px] flex-shrink-0 border-0 bg-transparent cursor-pointer">×</button>
            </div>
          <% end %>
        </div>
        <div class="flex gap-2">
          <input type="text" id="new-opt-<%= question.id %>" placeholder="<%= j t("surveys.question_card.add_option_placeholder") %>"
            class="flex-1 px-2.5 py-1.5 border border-dashed border-slate-300 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white"
            onkeydown="if(event.key==='Enter'){addOption(<%= question.id %>, '<%= opts_url %>')}">
          <button onclick="addOption(<%= question.id %>, '<%= opts_url %>')"
            class="px-3 py-1.5 bg-slate-700 hover:bg-blue-500 text-white text-[11px] font-semibold rounded-lg border-0 cursor-pointer"><%= t("surveys.question_card.add_btn") %></button>
        </div>
      </div>
    <% end %>

    <!-- Skip Logic -->
    <div class="border-t border-slate-100 pt-3 mt-1">
      <div class="flex items-center justify-between mb-1.5">
        <span class="text-[11px] font-semibold text-slate-500 uppercase tracking-wide">⚡ <%= t("surveys.skip_logic.section_label") %></span>
        <button type="button" onclick="toggleCondition(<%= question.id %>)"
          id="cond-toggle-<%= question.id %>"
          class="text-[11px] text-indigo-500 hover:text-indigo-700 font-semibold border-0 bg-transparent cursor-pointer">
          <%= has_condition ? t("surveys.skip_logic.edit") : t("surveys.skip_logic.add") %>
        </button>
      </div>
      <% if has_condition %>
        <p id="cond-active-<%= question.id %>" class="text-[11px] text-indigo-600 mb-1.5"><%= t("surveys.skip_logic.active") %></p>
      <% else %>
        <p id="cond-active-<%= question.id %>" class="text-[11px] text-indigo-600 mb-1.5 hidden"><%= t("surveys.skip_logic.active") %></p>
      <% end %>
      <div id="cond-panel-<%= question.id %>" class="<%= has_condition ? '' : 'hidden' %> space-y-2">
        <p class="text-[11px] text-slate-500"><%= t("surveys.skip_logic.show_if") %></p>
        <select id="cond-source-<%= question.id %>"
          class="w-full px-2 py-1.5 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white"
          onchange="onCondSourceChange(<%= question.id %>)"
          data-current="<%= cond_source %>">
          <option value="">— <%= t("surveys.skip_logic.select_question") %> —</option>
        </select>
        <div class="flex gap-2">
          <select id="cond-op-<%= question.id %>"
            onchange="onCondOpChange(<%= question.id %>)"
            class="px-2 py-1.5 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white">
            <option value="equals"       <%= 'selected' if cond_op == 'equals' %>><%= t("surveys.skip_logic.op_equals") %></option>
            <option value="not_equals"   <%= 'selected' if cond_op == 'not_equals' %>><%= t("surveys.skip_logic.op_not_equals") %></option>
            <option value="answered"     <%= 'selected' if cond_op == 'answered' %>><%= t("surveys.skip_logic.op_answered") %></option>
            <option value="not_answered" <%= 'selected' if cond_op == 'not_answered' %>><%= t("surveys.skip_logic.op_not_answered") %></option>
          </select>
          <input type="text" id="cond-value-<%= question.id %>"
            value="<%= cond_value %>"
            placeholder="<%= j t("surveys.skip_logic.value_placeholder") %>"
            class="flex-1 px-2 py-1.5 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white"
            style="<%= %w[answered not_answered].include?(cond_op) ? 'display:none' : '' %>">
        </div>
        <div class="flex gap-2">
          <button onclick="saveCondition(<%= question.id %>, '<%= q_url %>')"
            class="px-3 py-1.5 bg-blue-500 hover:bg-blue-600 text-white text-[11px] font-semibold rounded-lg border-0 cursor-pointer">
            <%= t("surveys.skip_logic.save") %>
          </button>
          <button onclick="clearCondition(<%= question.id %>, '<%= q_url %>')"
            class="px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[11px] font-semibold rounded-lg border-0 cursor-pointer">
            <%= t("surveys.skip_logic.clear") %>
          </button>
        </div>
      </div>
    </div>

    <div class="flex justify-end pt-1">
      <button onclick="toggleEdit(<%= question.id %>)"
        class="px-3 py-1.5 text-[12px] font-semibold text-slate-500 hover:text-slate-700 border-0 bg-transparent cursor-pointer"><%= t("surveys.question_card.close") %></button>
    </div>
  </div>

</div>

<script>
(function() {
// i18n string passed from Rails for the "+N more" label
window['MORE_OPTIONS_LABEL_<%= question.id %>'] = "<%= j t("surveys.question_card.more_options", count: "__N__") %>";

function toggleEdit(id) {
  document.getElementById('edit-panel-' + id).classList.toggle('hidden');
}

// ── Rebuild the summary options preview from current editor rows ──────────────
function updateOptionsPreview(qId) {
  const preview = document.getElementById('opts-preview-' + qId);
  if (!preview) return;

  const rows   = document.querySelectorAll('#opts-list-' + qId + ' .opt-row');
  const labels = Array.from(rows)
    .map(r => r.querySelector('input[type="text"]')?.value?.trim())
    .filter(Boolean);

  let html = '';
  labels.slice(0, 3).forEach(label => {
    const safe = label.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    html += `<div class="flex items-center gap-2 text-[12px] text-slate-400">
      <span class="w-3 h-3 rounded-full border border-slate-300 flex-shrink-0"></span>
      ${safe}
    </div>`;
  });
  if (labels.length > 3) {
    const tpl   = window['MORE_OPTIONS_LABEL_' + qId] || '+__N__';
    const label = tpl.replace('__N__', labels.length - 3);
    html += `<div class="text-[11px] text-slate-400">${label}</div>`;
  }
  preview.innerHTML = html;
}

// ── Save question title / type / required ─────────────────────────────────────
async function saveQuestion(id, url) {
  const title       = document.getElementById('q-title-' + id)?.value?.trim();
  const description = document.getElementById('q-description-' + id)?.value ?? '';
  const type        = document.getElementById('q-type-' + id)?.value;
  const required    = document.getElementById('q-required-' + id)?.checked;
  if (!title) return;
  const minLabel = document.getElementById('q-min-label-' + id)?.value ?? '';
  const maxLabel = document.getElementById('q-max-label-' + id)?.value ?? '';
  const minMaxTypes = ['linear_scale', 'rating', 'nps'];
  const settings = minMaxTypes.includes(type) ? { min_label: minLabel, max_label: maxLabel } : {};
  // Show/hide min-max panel when type changes
  const minMaxPanel = document.getElementById('minmax-panel-' + id);
  if (minMaxPanel) minMaxPanel.classList.toggle('hidden', !minMaxTypes.includes(type));
  const res = await fetch(url, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question: { title, description, question_type: type, required, settings } })
  });
  if (!res.ok) return;
  const card = document.querySelector('[data-question-id="' + id + '"]');
  if (!card) return;

  const summaryTitle = card.querySelector('.question-summary-title');
  if (summaryTitle) summaryTitle.textContent = title;

  const typeBadge = card.querySelector('.question-type-badge');
  if (typeBadge && type) {
    // Mirrors application_helper.rb question_type_label()
    const labels = {
      single_choice:   "<%= j t('surveys.question_types.single_choice') %>",
      multiple_choice: "<%= j t('surveys.question_types.multiple_choice') %>",
      rating:          "<%= j t('surveys.question_types.rating') %>",
      short_text:      "<%= j t('surveys.question_types.short_text') %>",
      long_text:       "<%= j t('surveys.question_types.long_text') %>",
      dropdown:        "<%= j t('surveys.question_types.dropdown') %>",
      linear_scale:    "<%= j t('surveys.question_types.linear_scale') %>",
      matrix:          "<%= j t('surveys.question_types.matrix') %>",
      date_time:       "<%= j t('surveys.question_types.date_time') %>",
      file_upload:     "<%= j t('surveys.question_types.file_upload') %>",
      nps:             "<%= j t('surveys.question_types.nps') %>",
      ranking:         "Ranking"
    };
    typeBadge.textContent = labels[type] || type.replace(/_/g, ' ');
  }

  const reqBadge = card.querySelector('.question-required-badge');
  if (reqBadge) reqBadge.classList.toggle('hidden', !required);
}

// ── Add option ────────────────────────────────────────────────────────────────
async function addOption(qId, url) {
  const input = document.getElementById('new-opt-' + qId);
  const label = input.value.trim();
  if (!label) return;
  const res = await fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question_option: { label } })
  });
  if (!res.ok) return;
  const opt = await res.json();
  const row = document.createElement('div');
  row.className = 'flex items-center gap-2 opt-row';
  row.dataset.optId = opt.id;
  const optUrl = url.replace('/question_options', '/question_options/' + opt.id);

  const inp = document.createElement('input');
  inp.type = 'text';
  inp.value = label;
  inp.className = 'flex-1 px-2.5 py-1.5 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-400 outline-none bg-white';
  inp.addEventListener('blur', () => saveOption(qId, opt.id, inp.value, optUrl));

  const del = document.createElement('button');
  del.textContent = '×';
  del.className = 'w-6 h-6 flex items-center justify-center text-slate-300 hover:text-red-500 rounded transition-colors text-[15px] flex-shrink-0 border-0 bg-transparent cursor-pointer';
  del.addEventListener('click', () => deleteOption(qId, opt.id, del, optUrl));

  row.appendChild(inp);
  row.appendChild(del);
  document.getElementById('opts-list-' + qId).appendChild(row);

  input.value = '';
  input.focus();
  updateOptionsPreview(qId);
}

// ── Save option label ─────────────────────────────────────────────────────────
async function saveOption(qId, optId, label, url) {
  label = label.trim();
  if (!label) return;
  await fetch(url, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question_option: { label } })
  });
  updateOptionsPreview(qId);
}

// ── Delete question ───────────────────────────────────────────────────────────
async function deleteQuestion(id, url) {
  const res = await fetch(url, {
    method: 'DELETE',
    headers: { 'Accept': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content }
  });
  if (!res.ok) return;
  const card = document.querySelector('[data-question-id="' + id + '"]');
  if (!card) return;
  card.style.transition = 'opacity 0.2s ease, transform 0.2s ease';
  card.style.opacity = '0';
  card.style.transform = 'translateY(-6px)';
  setTimeout(() => card.remove(), 220);
}

// ── Delete option ─────────────────────────────────────────────────────────────
async function deleteOption(qId, optId, btn, url) {
  const res = await fetch(url, { method: 'DELETE', headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content } });
  if (!res.ok) return;
  btn.closest('.opt-row').remove();
  updateOptionsPreview(qId);
}

// ── Skip Logic ────────────────────────────────────────────────────────────────
const I18N_SKIP = {
  no_question: "<%= j t('surveys.skip_logic.no_question_alert') %>",
  saved_ok:    "<%= j t('surveys.skip_logic.saved_ok') %>",
  active:      "<%= j t('surveys.skip_logic.active') %>",
  add:         "<%= j t('surveys.skip_logic.add') %>",
  edit:        "<%= j t('surveys.skip_logic.edit') %>"
};

function toggleCondition(id) {
  const panel = document.getElementById('cond-panel-' + id);
  if (!panel) return;
  panel.classList.toggle('hidden');
  if (!panel.classList.contains('hidden')) {
    populateSourceQuestions(id);
  }
}

function populateSourceQuestions(id) {
  const select = document.getElementById('cond-source-' + id);
  if (!select) return;
  const current = select.dataset.current || '';
  // Save first option placeholder text
  const placeholder = select.options[0]?.text || '';
  select.innerHTML = '';
  const blank = document.createElement('option');
  blank.value = '';
  blank.textContent = placeholder;
  select.appendChild(blank);

  let found = 0;
  document.querySelectorAll('.question-card[data-question-id]').forEach(card => {
    const qId = card.dataset.questionId;
    if (String(qId) === String(id)) return; // skip self
    const title = card.querySelector('.question-summary-title')?.textContent?.trim() || ('Q' + qId);
    const opt = document.createElement('option');
    opt.value = qId;
    opt.textContent = title.length > 55 ? title.substring(0, 52) + '…' : title;
    if (String(qId) === String(current)) opt.selected = true;
    select.appendChild(opt);
    found++;
  });
  if (found === 0) {
    const noOpt = document.createElement('option');
    noOpt.value = '';
    noOpt.disabled = true;
    noOpt.textContent = '<%= I18n.locale == :vi ? "(Cần ít nhất 2 câu hỏi)" : "(Need at least 2 questions)" %>';
    select.appendChild(noOpt);
  }
}

function onCondSourceChange(id) {
  const select = document.getElementById('cond-source-' + id);
  if (select) select.dataset.current = select.value;
}

function onCondOpChange(id) {
  const op    = document.getElementById('cond-op-' + id)?.value;
  const input = document.getElementById('cond-value-' + id);
  if (!input) return;
  const hide = (op === 'answered' || op === 'not_answered');
  input.style.display = hide ? 'none' : '';
}

async function saveCondition(id, url) {
  const sourceId = document.getElementById('cond-source-' + id)?.value;
  const operator = document.getElementById('cond-op-' + id)?.value || 'equals';
  const value    = document.getElementById('cond-value-' + id)?.value?.trim() || '';

  if (!sourceId) { alert(I18N_SKIP.no_question); return; }

  const logic = { source_question_id: String(sourceId), operator, value };
  const res = await fetch(url, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question: { conditional_logic: logic } })
  });
  if (!res.ok) return;

  // Update toggle button & active badge
  const toggle = document.getElementById('cond-toggle-' + id);
  if (toggle) toggle.textContent = I18N_SKIP.edit;
  const badge = document.getElementById('cond-active-' + id);
  if (badge) badge.classList.remove('hidden');
  // Remember current source for next repopulate
  const sel = document.getElementById('cond-source-' + id);
  if (sel) sel.dataset.current = sourceId;

  // Flash save button to ✓ Đã lưu for 2s
  const saveBtn = document.querySelector(`button[onclick="saveCondition(${id}, '${url}')"]`);
  if (saveBtn) {
    const orig = saveBtn.textContent;
    const origCls = saveBtn.className;
    saveBtn.textContent = '✓ ' + (I18N_SKIP.saved_ok || 'Đã lưu');
    saveBtn.className = saveBtn.className.replace('bg-blue-500 hover:bg-blue-600', 'bg-emerald-500 hover:bg-emerald-500');
    saveBtn.disabled = true;
    setTimeout(() => {
      saveBtn.textContent = orig;
      saveBtn.className = origCls;
      saveBtn.disabled = false;
    }, 2000);
  }
}

async function clearCondition(id, url) {
  const res = await fetch(url, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question: { conditional_logic: {} } })
  });
  if (!res.ok) return;

  const sel = document.getElementById('cond-source-' + id);
  if (sel) { sel.value = ''; sel.dataset.current = ''; }
  const valInput = document.getElementById('cond-value-' + id);
  if (valInput) valInput.value = '';
  document.getElementById('cond-panel-' + id)?.classList.add('hidden');
  const toggle = document.getElementById('cond-toggle-' + id);
  if (toggle) toggle.textContent = I18N_SKIP.add;
  const badge = document.getElementById('cond-active-' + id);
  if (badge) badge.classList.add('hidden');
}

// Auto-populate condition panel if it starts visible (has_condition == true)
if (!document.getElementById('cond-panel-<%= question.id %>')?.classList.contains('hidden')) {
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => populateSourceQuestions(<%= question.id %>));
  } else {
    setTimeout(() => populateSourceQuestions(<%= question.id %>), 0);
  }
}

// Expose functions called from onclick= attributes
Object.assign(window, { toggleEdit, saveQuestion, addOption, saveOption, deleteQuestion, deleteOption, updateOptionsPreview, toggleCondition, onCondSourceChange, onCondOpChange, saveCondition, clearCondition, populateSourceQuestions });
})(); // end IIFE
</script>
