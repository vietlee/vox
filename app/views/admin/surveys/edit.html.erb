<% content_for :title, @survey.title %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<!-- ── Page header (fixed) ──────────────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-3 bg-slate-100">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <%= render "admin/shared/back_btn" %>
    <div class="min-w-0 flex-1">
      <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight"><%= @survey.title %></h1>
      <p class="text-[12px] text-slate-500 mt-0.5"><%= t("surveys.builder_subtitle", count: @survey.questions.count) %></p>
    </div>
    <div class="flex gap-2 flex-wrap flex-shrink-0">
      <% if @survey.draft? %>
        <%= button_to publish_survey_path(@survey), method: :patch, class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-emerald-50 hover:text-emerald-700 hover:border-emerald-200 text-slate-700 transition-colors whitespace-nowrap" do %>
          🚀 <%= t("surveys.publish") %>
        <% end %>
      <% elsif @survey.active? %>
        <button onclick="showSurveyCloseConfirm()"
          class="inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-red-50 hover:text-red-600 hover:border-red-200 text-slate-700 transition-colors whitespace-nowrap">
          ⏹ <%= t("surveys.close_action") %>
        </button>
        <form id="survey-close-form" action="<%= close_survey_path(@survey) %>" method="post" class="hidden">
          <%= hidden_field_tag :_method, :patch %>
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        </form>
      <% end %>
      <%= link_to results_survey_path(@survey), class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-slate-50 hover:border-slate-300 text-slate-700 transition-colors whitespace-nowrap" do %>
        📊 <%= t("surveys.results_btn") %>
      <% end %>
      <%= link_to results_survey_path(@survey) + "#ai", class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-violet-50 hover:text-violet-700 hover:border-violet-200 text-slate-700 transition-colors whitespace-nowrap" do %>
        <%= t("surveys.results.tab_ai") %>
      <% end %>
      <%= link_to results_survey_path(@survey) + "#report", class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-blue-50 hover:text-blue-700 hover:border-blue-200 text-slate-700 transition-colors whitespace-nowrap" do %>
        📄 <%= t("surveys.results.tab_report").gsub(/\A📄\s*/, '') %>
      <% end %>
      <% if @survey.active? || @survey.closed? %>
        <%= link_to share_survey_path(@survey), class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-slate-50 hover:border-slate-300 text-slate-700 transition-colors whitespace-nowrap" do %>
          🔗 <%= t("surveys.share_btn") %>
        <% end %>
      <% else %>
        <span title="<%= I18n.locale == :vi ? 'Phát hành khảo sát trước khi chia sẻ' : 'Publish the survey before sharing' %>"
              class="inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-slate-50 border border-slate-200 text-slate-300 cursor-not-allowed whitespace-nowrap select-none">
          🔗 <%= t("surveys.share_btn") %>
        </span>
      <% end %>
    </div>
  </div>
</div>

<!-- ── Scrollable builder content ───────────────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-y-auto px-6 pt-3 pb-6">
<div class="grid grid-cols-[1fr_280px] gap-5">
  <!-- Builder canvas -->
  <div class="space-y-4">
    <!-- Survey info card -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <%= form_with model: @survey, url: survey_path(@survey), method: :patch, local: true, multipart: true, data: { turbo: false } do |f| %>
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("surveys.form.title_label") %> *</label>
            <%= f.text_field :title, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
          </div>
          <div class="col-span-2">
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("surveys.form.description_label") %></label>
            <%= f.text_area :description, rows: 2, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] text-slate-700 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none" %>
          </div>
          <div class="col-span-2">
            <%= render "admin/surveys/logo_upload" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("surveys.form.identity_mode_label") %></label>
            <%= f.select :identity_mode,
                  Survey.identity_modes.keys.map { |k| [t("surveys.form.identity_modes.#{k}"), k] }, {},
                  class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] text-slate-700 focus:border-indigo-500 outline-none",
                  onchange: "onIdentityChange(this.value)" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("surveys.form.max_responses_label") %></label>
            <%= f.number_field :max_responses, placeholder: t("surveys.form.max_responses_placeholder"), class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
          </div>
        </div>

        <!-- SSO provider picker -->
        <div id="sso-providers-wrap" style="<%= @survey.login_required? ? '' : 'display:none;' %>" class="px-4 py-3 rounded-xl border border-indigo-100 bg-indigo-50/60">
          <label class="block text-[11px] font-semibold text-slate-500 mb-2">
            <%= I18n.locale == :vi ? "Cho phép đăng nhập với" : "Allow sign in with" %>
          </label>
          <div class="flex gap-4">
            <% [["google", "🔵 Google"], ["microsoft", "🟦 Microsoft"], ["both", I18n.locale == :vi ? "✅ Cả hai" : "✅ Both"]].each do |val, lbl| %>
              <label class="flex items-center gap-1.5 text-[12px] font-semibold text-slate-600 cursor-pointer">
                <%= f.radio_button :login_providers, val,
                      checked: @survey.login_providers == val || (@survey.login_providers.blank? && val == "both"),
                      class: "accent-indigo-600" %>
                <%= lbl %>
              </label>
            <% end %>
          </div>
        </div>

        <div class="flex gap-3 mt-4 pt-4 border-t border-slate-100">
          <%= f.submit t("surveys.save_changes"), class: "px-4 py-2 bg-blue-500 text-white text-[13px] font-semibold rounded-lg hover:bg-blue-600 cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <!-- Questions list: fixed height, scrolls within -->
    <div id="questions-container" class="space-y-3 max-h-[calc(200vh-840px)] overflow-y-auto pr-0.5 min-h-[120px]">
      <% @survey.questions.each_with_index do |question, idx| %>
        <%= render "admin/surveys/question_card", question: question, idx: idx %>
      <% end %>
    </div>

    <!-- Add question buttons -->
    <div class="bg-white rounded-[10px] border border-dashed border-slate-300 p-5">
      <p class="text-[12px] font-semibold text-slate-500 text-center mb-3"><%= t("surveys.add_question") %></p>
      <div class="flex flex-wrap gap-2 justify-center">
        <% Question.question_types.keys.each do |type| %>
          <button onclick="addQuestion('<%= type %>')"
            class="px-3 py-1.5 bg-slate-100 hover:bg-indigo-50 hover:text-indigo-700 text-slate-600 text-[11px] font-medium rounded-lg transition-colors">
            <%= question_type_label(type) %>
          </button>
        <% end %>
      </div>
      <!-- AI Question Helper -->
      <div class="mt-3 pt-3 border-t border-slate-100">
        <div class="flex gap-2">
          <input id="ai-q-input" type="text" placeholder="<%= j t("surveys.ai_check_placeholder") %>"
            class="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-violet-400 outline-none">
          <button id="ai-check-btn" onclick="checkQuestion()"
            class="flex items-center gap-1.5 px-3 py-2 bg-violet-600 text-white text-[12px] font-semibold rounded-lg hover:bg-violet-700 transition-all disabled:opacity-60 disabled:cursor-not-allowed">
            <span id="ai-check-icon">✨</span>
            <svg id="ai-check-spinner" class="hidden animate-spin w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
            </svg>
            <span id="ai-check-label"><%= t("surveys.ai_check_btn") %></span>
          </button>
        </div>
        <div id="ai-question-feedback" class="mt-2 hidden"></div>
      </div>
    </div>
  </div>

  <!-- Settings panel -->
  <div class="space-y-4">
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
      <h3 class="text-[13px] font-bold text-slate-900 mb-3">⚙️ <%= t("surveys.settings.title") %></h3>
      <%= form_with model: @survey, url: survey_path(@survey), method: :patch, local: true, data: { turbo: false } do |f| %>
        <div class="space-y-3">
          <div class="flex items-center justify-between py-2 border-b border-slate-100">
            <span class="text-[13px] text-slate-700"><%= t("surveys.settings.show_progress") %></span>
            <%= f.check_box :show_progress, class: "w-4 h-4 accent-indigo-600" %>
          </div>
          <div class="flex items-center justify-between py-2 border-b border-slate-100">
            <span class="text-[13px] text-slate-700"><%= t("surveys.settings.show_results") %></span>
            <%= f.check_box :show_results, class: "w-4 h-4 accent-indigo-600" %>
          </div>
          <div id="allow-edit-row" class="flex items-start justify-between py-2 border-b border-slate-100 gap-2 <%= 'opacity-40 pointer-events-none' unless @survey.email_required? %>">
            <div>
              <span class="text-[13px] text-slate-700"><%= t("surveys.settings.allow_edit") %></span>
              <p id="allow-edit-note" class="text-[11px] text-slate-400 mt-0.5 leading-snug">
                <% if @survey.email_required? %>
                  <%= t("surveys.settings.allow_edit_note_active") %>
                <% else %>
                  <%= t("surveys.settings.allow_edit_note_disabled") %>
                <% end %>
              </p>
            </div>
            <%= f.check_box :allow_edit, id: "allow-edit-checkbox", class: "w-4 h-4 accent-indigo-600 flex-shrink-0 mt-0.5" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1"><%= t("surveys.settings.opens_at") %></label>
            <%= f.datetime_local_field :starts_at, class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-500 outline-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1"><%= t("surveys.settings.closes_at") %></label>
            <%= f.datetime_local_field :ends_at, class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-500 outline-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1"><%= t("surveys.settings.thank_you") %></label>
            <%= f.text_area :thank_you_message, rows: 2, class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[12px] resize-none focus:border-indigo-500 outline-none" %>
          </div>
        </div>
        <%= f.submit t("surveys.settings.save"), class: "w-full mt-3 py-2 bg-slate-800 text-white text-[12px] font-semibold rounded-lg hover:bg-blue-600 cursor-pointer" %>
      <% end %>
    </div>

    <!-- QR Code -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 text-center">
      <h3 class="text-[13px] font-bold text-slate-900 mb-3"><%= t("surveys.qr_code") %></h3>
      <% if @survey.qr_code %>
        <img src="<%= qr_image_path(@survey.qr_code.token) %>" alt="QR Code" class="mx-auto w-36 h-36 rounded-lg">
        <p class="text-[11px] text-slate-400 mt-2"><%= t("surveys.qr_scans", count: @survey.qr_code.scan_count) %></p>
      <% end %>
    </div>
  </div>
</div>
</div><!-- /scrollable -->

<!-- ── Delete question modal ─────────────────────────────────────────────────── -->
<div id="q-delete-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center bg-black/40 backdrop-blur-sm"
       onclick="closeDeleteQuestionModal()">
    <div class="bg-white rounded-2xl shadow-2xl w-[400px] max-w-full mx-4 p-6" onclick="event.stopPropagation()">
      <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl" style="background:#fee2e2;">🗑️</div>
      <h3 class="text-[17px] font-bold text-slate-900 text-center mb-2"><%= t("surveys.delete_question_confirm") %></h3>
      <p id="q-delete-body" class="text-[13px] text-slate-500 text-center leading-relaxed mb-6 truncate px-2"></p>
      <div class="flex gap-3">
        <button onclick="closeDeleteQuestionModal()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 border-0 cursor-pointer transition-colors">
          <%= t("surveys.cancel") %>
        </button>
        <button onclick="confirmDeleteQuestion()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold text-white border-0 cursor-pointer transition-colors"
          style="background:#ef4444;">
          <%= t("surveys.delete_question_confirm_btn", default: "Xoá") %>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  let _qDeleteId, _qDeleteUrl;

  window.showDeleteQuestionModal = function(id, url, title) {
    _qDeleteId  = id;
    _qDeleteUrl = url;
    const body = document.getElementById('q-delete-body');
    if (body) body.textContent = title ? '"' + title + '"' : '';
    document.getElementById('q-delete-modal').classList.remove('hidden');
  };

  window.closeDeleteQuestionModal = function() {
    document.getElementById('q-delete-modal').classList.add('hidden');
  };

  window.confirmDeleteQuestion = async function() {
    closeDeleteQuestionModal();
    if (typeof deleteQuestion === 'function') {
      deleteQuestion(_qDeleteId, _qDeleteUrl);
    }
  };
})();
</script>

<style>
  .sq-ghost  { opacity: 0.35; }
  .sq-chosen { outline: 2px solid #a5b4fc; border-radius: 10px; }
</style>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
<script>
(function() {
const REORDER_URL = '<%= reorder_survey_questions_path(@survey) %>';
const I18N = {
  question_looks_good: "<%= j t('surveys.question_card.question_label') %>",
  ai_check_suggestion: "Suggestion"
};

async function addQuestion(type) {
  const btn = event.currentTarget;
  btn.disabled = true;
  btn.style.opacity = '0.5';

  const resp = await fetch('<%= survey_questions_path(@survey) %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question: { question_type: type, title: 'New question', position: document.querySelectorAll('.question-card').length } })
  });

  btn.disabled = false;
  btn.style.opacity = '';

  if (!resp.ok) return;
  const data = await resp.json();

  const container = document.getElementById('questions-container');
  const tmp = document.createElement('div');
  tmp.innerHTML = data.html.trim();
  const card = tmp.firstElementChild;
  card.style.opacity = '0';
  card.style.transform = 'translateY(8px)';
  card.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
  container.appendChild(card);

  // innerHTML does not execute <script> tags — run them manually.
  // Search in `tmp` (not just `card`) because the partial's <script> is a
  // sibling of the card div, not a descendant.
  tmp.querySelectorAll('script').forEach(oldScript => {
    const s = document.createElement('script');
    s.textContent = oldScript.textContent;
    document.head.appendChild(s);
    s.remove();
  });

  requestAnimationFrame(() => {
    card.style.opacity = '1';
    card.style.transform = 'translateY(0)';
  });

  const editPanel = card.querySelector('[id^="edit-panel-"]');
  if (editPanel) editPanel.classList.remove('hidden');
  card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

function setCheckLoading(on) {
  const btn     = document.getElementById('ai-check-btn');
  const icon    = document.getElementById('ai-check-icon');
  const spinner = document.getElementById('ai-check-spinner');
  const label   = document.getElementById('ai-check-label');
  if (!btn) return;
  btn.disabled = on;
  icon?.classList.toggle('hidden', on);
  spinner?.classList.toggle('hidden', !on);
  if (label) label.textContent = on
    ? '<%= j t("surveys.ai_check_loading") %>'
    : '<%= j t("surveys.ai_check_btn") %>';
}

async function checkQuestion() {
  const text = document.getElementById('ai-q-input').value;
  if (!text.trim()) return;

  setCheckLoading(true);
  document.getElementById('ai-question-feedback').classList.add('hidden');

  try {
    const resp = await fetch('<%= ai_check_question_path %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
      body: JSON.stringify({ question_text: text })
    });
    const data = await resp.json();
    if (window.handleAiUpgrade(resp, data, '<%= j t("surveys.tab_ai") %>')) {
      setCheckLoading(false); return;
    }
    const { job_id } = data;
    pollJobStatus(job_id, (result) => {
      setCheckLoading(false);
      window.deductDisplayCredits?.(1); // question checker costs 1 credit
      const fb = document.getElementById('ai-question-feedback');
      fb.classList.remove('hidden');
      fb.innerHTML = result.severity === 'none'
        ? `<div class="p-2.5 bg-emerald-50 border border-emerald-200 rounded-lg text-[12px] text-emerald-700">✓ <%= j t("surveys.ai_check_ok") %></div>`
        : `<div class="p-2.5 bg-amber-50 border border-amber-200 rounded-lg text-[12px] text-amber-800">⚠ ${result.explanation}<br><span class="font-semibold"><%= j t("surveys.ai_check_suggestion") %>:</span> ${result.suggestion}</div>`;
    });
  } catch(e) {
    setCheckLoading(false);
  }
}

async function pollJobStatus(jobId, onDone) {
  try {
    const resp = await fetch('<%= ai_job_status_path("__ID__") %>'.replace('__ID__', jobId));
    const data = await resp.json();
    if (data.status === 'done')   { onDone(data.output); }
    else if (data.status === 'failed') { setCheckLoading(false); }
    else { setTimeout(() => pollJobStatus(jobId, onDone), 1500); }
  } catch(e) {
    setCheckLoading(false);
  }
}

// ── Drag-and-drop reorder ─────────────────────────────────────────────────────
function _initSortable() {
  const container = document.getElementById('questions-container');
  if (!container || typeof Sortable === 'undefined') return;
  // Guard against double-init (turbo:load fires after DOMContentLoaded too)
  if (container.dataset.sortableReady) return;
  container.dataset.sortableReady = '1';

  Sortable.create(container, {
    handle:     '.drag-handle',
    animation:  150,
    ghostClass: 'sq-ghost',
    chosenClass:'sq-chosen',

    onEnd() {
      const order = Array.from(
        container.querySelectorAll('[data-question-id]')
      ).map(el => el.dataset.questionId);

      fetch(REORDER_URL, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content
        },
        body: JSON.stringify({ order })
      });
    }
  });
}

// turbo:load fires on both initial load and Turbo navigations
document.addEventListener('turbo:load', _initSortable);
// Fallback for non-Turbo environments
if (document.readyState !== 'loading') { _initSortable(); }
else { document.addEventListener('DOMContentLoaded', _initSortable); }

// ── Expose onclick functions ──────────────────────────────────────────────────
Object.assign(window, { addQuestion, checkQuestion });

// SSO provider picker toggle
window.onIdentityChange = function(val) {
  var wrap = document.getElementById('sso-providers-wrap');
  if (wrap) wrap.style.display = val === 'login_required' ? '' : 'none';

  // allow_edit only works with email_required
  var editRow  = document.getElementById('allow-edit-row');
  var editNote = document.getElementById('allow-edit-note');
  var editChk  = document.getElementById('allow-edit-checkbox');
  if (!editRow) return;
  var isEmail = val === 'email_required';
  editRow.classList.toggle('opacity-40', !isEmail);
  editRow.classList.toggle('pointer-events-none', !isEmail);
  if (!isEmail && editChk) editChk.checked = false;
  if (editNote) {
    editNote.textContent = isEmail
      ? '<%= j t("surveys.settings.allow_edit_note_active") %>'
      : '<%= j t("surveys.settings.allow_edit_note_disabled") %>';
  }
};

})(); // end IIFE

function showSurveyCloseConfirm() {
  document.getElementById('survey-close-modal').classList.remove('hidden');
}
function hideSurveyCloseConfirm() {
  document.getElementById('survey-close-modal').classList.add('hidden');
}
</script>

<!-- Close Survey Confirm Modal -->
<div id="survey-close-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 flex items-center justify-center bg-black/40 backdrop-blur-sm p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-[380px] max-w-full p-6">
      <div class="w-12 h-12 rounded-full bg-amber-50 flex items-center justify-center mx-auto mb-4 text-2xl">🔒</div>
      <h3 class="text-[17px] font-bold text-slate-900 text-center mb-2"><%= t("surveys.close_modal_title", default: "Đóng khảo sát?") %></h3>
      <p class="text-[13px] text-slate-500 text-center leading-relaxed mb-6"><%= t("surveys.close_modal_body", default: "Khảo sát sẽ ngừng nhận phản hồi. Bạn có thể mở lại bất cứ lúc nào.") %></p>
      <div class="flex gap-3">
        <button onclick="hideSurveyCloseConfirm()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors cursor-pointer border-0">
          <%= t("surveys.cancel") %>
        </button>
        <button onclick="document.getElementById('survey-close-form').requestSubmit()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-amber-500 text-white hover:bg-amber-600 transition-colors cursor-pointer border-0">
          <%= t("surveys.close_action") %>
        </button>
      </div>
    </div>
  </div>
</div>
