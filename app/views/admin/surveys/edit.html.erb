<% content_for :title, @survey.title %>

<div class="flex items-start justify-between mb-5">
  <div>
    <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight"><%= @survey.title %></h1>
    <p class="text-[12px] text-slate-500 mt-0.5">Survey Builder · <%= @survey.questions.count %> questions</p>
  </div>
  <div class="flex gap-2">
    <% if @survey.draft? %>
      <%= button_to publish_survey_path(@survey), method: :patch, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-emerald-600 text-white hover:bg-emerald-700" do %>
        🚀 Publish
      <% end %>
    <% end %>
    <%= link_to results_survey_path(@survey), class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 text-slate-700 hover:bg-slate-50" do %>
      📊 Kết quả
    <% end %>
    <%= link_to share_survey_path(@survey), class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 text-slate-700 hover:bg-slate-50" do %>
      🔗 Share
    <% end %>
  </div>
</div>

<div class="grid grid-cols-[1fr_280px] gap-5">
  <!-- Builder canvas -->
  <div class="space-y-4">
    <!-- Survey info card -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <%= form_with model: @survey, url: survey_path(@survey), method: :patch, local: false do |f| %>
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Survey Title *</label>
            <%= f.text_field :title, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] text-slate-900 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
          </div>
          <div class="col-span-2">
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Description</label>
            <%= f.text_area :description, rows: 2, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] text-slate-700 focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Identity Mode</label>
            <%= f.select :identity_mode, Survey.identity_modes.keys.map { |k| [k.humanize, k] }, {}, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] text-slate-700 focus:border-indigo-500 outline-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Max Responses</label>
            <%= f.number_field :max_responses, placeholder: "Unlimited", class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
          </div>
        </div>
        <div class="flex gap-3 mt-4 pt-4 border-t border-slate-100">
          <%= f.submit "Save Changes", class: "px-4 py-2 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700 cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <!-- Questions list -->
    <div id="questions-container" class="space-y-3">
      <% @survey.questions.each_with_index do |question, idx| %>
        <%= render "admin/surveys/question_card", question: question, idx: idx %>
      <% end %>
    </div>

    <!-- Add question buttons -->
    <div class="bg-white rounded-[10px] border border-dashed border-slate-300 p-5">
      <p class="text-[12px] font-semibold text-slate-500 text-center mb-3">Add Question</p>
      <div class="flex flex-wrap gap-2 justify-center">
        <% Question.question_types.keys.each do |type| %>
          <button onclick="addQuestion('<%= type %>')"
            class="px-3 py-1.5 bg-slate-100 hover:bg-indigo-50 hover:text-indigo-700 text-slate-600 text-[11px] font-medium rounded-lg transition-colors">
            <%= question_type_label(type) %>
          </button>
        <% end %>
      </div>
      <!-- AI Question Helper -->
      <div class="mt-3 pt-3 border-t border-slate-100">
        <div class="flex gap-2">
          <input id="ai-q-input" type="text" placeholder="Type a question and get AI feedback..."
            class="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-violet-400 outline-none">
          <button onclick="checkQuestion()" class="px-3 py-2 bg-gradient-to-r from-violet-500 to-indigo-500 text-white text-[12px] font-semibold rounded-lg hover:opacity-90">
            🤖 Check
          </button>
        </div>
        <div id="ai-question-feedback" class="mt-2 hidden"></div>
      </div>
    </div>
  </div>

  <!-- Settings panel -->
  <div class="space-y-4">
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
      <h3 class="text-[13px] font-bold text-slate-900 mb-3">⚙️ Settings</h3>
      <%= form_with model: @survey, url: survey_path(@survey), method: :patch, local: true do |f| %>
        <div class="space-y-3">
          <div class="flex items-center justify-between py-2 border-b border-slate-100">
            <span class="text-[13px] text-slate-700">Show progress bar</span>
            <%= f.check_box :show_progress, class: "w-4 h-4 accent-indigo-600" %>
          </div>
          <div class="flex items-center justify-between py-2 border-b border-slate-100">
            <span class="text-[13px] text-slate-700">Show results after submit</span>
            <%= f.check_box :show_results, class: "w-4 h-4 accent-indigo-600" %>
          </div>
          <div class="flex items-center justify-between py-2 border-b border-slate-100">
            <span class="text-[13px] text-slate-700">Allow editing after submit</span>
            <%= f.check_box :allow_edit, class: "w-4 h-4 accent-indigo-600" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1">Opens at</label>
            <%= f.datetime_local_field :starts_at, class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-500 outline-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1">Closes at</label>
            <%= f.datetime_local_field :ends_at, class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-500 outline-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1">Thank you message</label>
            <%= f.text_area :thank_you_message, rows: 2, class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[12px] resize-none focus:border-indigo-500 outline-none" %>
          </div>
        </div>
        <%= f.submit "Save Settings", class: "w-full mt-3 py-2 bg-slate-800 text-white text-[12px] font-semibold rounded-lg hover:bg-slate-700 cursor-pointer" %>
      <% end %>
    </div>

    <!-- QR Code -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 text-center">
      <h3 class="text-[13px] font-bold text-slate-900 mb-3">QR Code</h3>
      <% if @survey.qr_code %>
        <img src="<%= qr_image_path(@survey.qr_code.token) %>" alt="QR Code" class="mx-auto w-36 h-36 rounded-lg">
        <p class="text-[11px] text-slate-400 mt-2"><%= @survey.qr_code.scan_count %> scans</p>
      <% end %>
    </div>
  </div>
</div>

<script>
async function addQuestion(type) {
  const btn = event.currentTarget;
  btn.disabled = true;
  btn.style.opacity = '0.5';

  const resp = await fetch('<%= survey_questions_path(@survey) %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question: { question_type: type, title: 'New question', position: document.querySelectorAll('.question-card').length } })
  });

  btn.disabled = false;
  btn.style.opacity = '';

  if (!resp.ok) return;
  const data = await resp.json();

  // Insert card HTML before the "Add question" panel
  const container = document.getElementById('questions-container');
  const tmp = document.createElement('div');
  tmp.innerHTML = data.html.trim();
  const card = tmp.firstElementChild;
  card.style.opacity = '0';
  card.style.transform = 'translateY(8px)';
  card.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
  container.appendChild(card);

  // Animate in
  requestAnimationFrame(() => {
    card.style.opacity = '1';
    card.style.transform = 'translateY(0)';
  });

  // Auto-open the edit panel for the new card
  const editPanel = card.querySelector('[id^="edit-panel-"]');
  if (editPanel) editPanel.classList.remove('hidden');

  // Scroll to new card
  card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

async function checkQuestion() {
  const text = document.getElementById('ai-q-input').value;
  if (!text.trim()) return;
  const resp = await fetch('<%= ai_check_question_path %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
    body: JSON.stringify({ question_text: text })
  });
  const { job_id } = await resp.json();
  pollJobStatus(job_id, (result) => {
    const fb = document.getElementById('ai-question-feedback');
    fb.classList.remove('hidden');
    fb.innerHTML = result.severity === 'none'
      ? `<div class="p-2 bg-emerald-50 border border-emerald-200 rounded-lg text-[11px] text-emerald-700">✓ Question looks good!</div>`
      : `<div class="p-2 bg-amber-50 border border-amber-200 rounded-lg text-[11px] text-amber-800">⚠ ${result.explanation}<br><strong>Suggestion:</strong> ${result.suggestion}</div>`;
  });
}

async function pollJobStatus(jobId, onDone) {
  const resp = await fetch('<%= ai_job_status_path("__ID__") %>'.replace('__ID__', jobId));
  const data = await resp.json();
  if (data.status === 'done') onDone(data.output);
  else if (data.status === 'failed') alert('AI error: ' + data.error);
  else setTimeout(() => pollJobStatus(jobId, onDone), 1500);
}
</script>
