<%# Renders a persisted AiAnalysisResult for a survey %>
<% result     = analysis.output %>
<% sentiment  = result["sentiment"] || {} %>
<% themes     = result["top_themes"] || result["themes"] || result["open_text_themes"] || [] %>
<% anomalies  = result["anomalies"] || [] %>
<% recs       = result["recommendations"] || [] %>
<% highlights = result["highlights"] || [] %>
<% q_insights = result["question_insights"] || [] %>
<% key_metrics= result["key_metrics"] || {} %>

<%# Unique ID per card to support multiple on page %>
<% card_id = "ai-#{analysis.id}" %>

<%# Build "câu hỏi số N" → full title lookup from question_insights + _computed %>
<%
  q_title_map = {}
  # From question_insights: q_position like "câu hỏi số 3" → question title
  (result["question_insights"] || []).each do |qi|
    pos_label = qi["q_position"].to_s.downcase.strip
    q_title_map[pos_label] = qi["question"].to_s if qi["question"].present?
  end
  # Helper: replace "Câu hỏi số N" with "Câu hỏi số N — [title]", expandable if long
  inject_q_title = ->(text, prefix_id) {
    out = text.to_s.dup
    out.gsub!(/[Cc]âu hỏi số (\d+)/i) do |match|
      n = $1
      key = "câu hỏi số #{n}"
      title = q_title_map[key]
      next match unless title.present?
      if title.length > 50
        uid = "#{prefix_id}-qt#{n}"
        short = title.truncate(50)
        %(<span>#{match} — <span style="color:#6366f1;font-style:italic"><span id="#{uid}-s">#{short}<button onclick="document.getElementById('#{uid}-s').style.display='none';document.getElementById('#{uid}-f').style.display='inline'" style="background:none;border:0;cursor:pointer;padding:0;color:#818cf8;font-size:9px;margin-left:3px">...xem thêm</button></span><span id="#{uid}-f" style="display:none">#{title}<button onclick="document.getElementById('#{uid}-f').style.display='none';document.getElementById('#{uid}-s').style.display='inline'" style="background:none;border:0;cursor:pointer;padding:0;color:#94a3b8;font-size:9px;margin-left:3px">thu gọn</button></span></span></span>)
      else
        "#{match} — <span style=\"color:#6366f1;font-style:italic\">#{title}</span>"
      end
    end
    out.html_safe
  }
%>

<div class="space-y-4 text-[13px]">

  <!-- ① Executive Summary — first paragraph visible, rest collapsible -->
  <% if result["executive_summary"].present? %>
    <% summary = result["executive_summary"] %>
    <% paras = summary.split(/\n\n+/).map(&:strip).reject(&:blank?) %>
    <% first_para = paras.first %>
    <% rest_paras = paras[1..] %>
    <div class="rounded-xl p-3.5" style="background:rgba(99,102,241,0.05);border:1px solid rgba(99,102,241,0.12);">
      <p class="text-[12px] text-slate-700 leading-relaxed"><%= first_para %></p>
      <% if rest_paras.any? %>
        <div id="<%= card_id %>-full" class="hidden mt-2 pt-2 border-t border-indigo-100 space-y-2">
          <% rest_paras.each do |para| %>
            <p class="text-[12px] text-slate-600 leading-relaxed"><%= para %></p>
          <% end %>
        </div>
        <button onclick="document.getElementById('<%= card_id %>-full').classList.toggle('hidden'); this.textContent = this.textContent.includes('▼') ? '▲ Thu gọn' : '▼ Đọc thêm'"
          class="text-[10px] text-indigo-400 font-semibold mt-1.5 border-0 bg-transparent cursor-pointer p-0 hover:text-indigo-600">▼ Đọc thêm</button>
      <% end %>
    </div>
  <% end %>

  <!-- ② Key metrics — 2-col chips -->
  <% if key_metrics.any? %>
    <div class="grid grid-cols-2 gap-2">
      <% if key_metrics["standout_high"].present? %>
        <div class="rounded-lg px-3 py-2" style="background:rgba(16,185,129,0.07);border:1px solid rgba(16,185,129,0.18);">
          <div class="text-[9px] font-bold text-emerald-600 uppercase tracking-wide mb-1">▲ Điểm sáng</div>
          <p class="text-[11px] text-slate-700 leading-snug"><%= key_metrics["standout_high"] %></p>
        </div>
      <% end %>
      <% if key_metrics["standout_low"].present? %>
        <div class="rounded-lg px-3 py-2" style="background:rgba(239,68,68,0.05);border:1px solid rgba(239,68,68,0.15);">
          <div class="text-[9px] font-bold text-red-500 uppercase tracking-wide mb-1">▼ Cần cải thiện</div>
          <p class="text-[11px] text-slate-700 leading-snug"><%= key_metrics["standout_low"] %></p>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- ③ Sentiment donut + themes bar — side by side -->
  <% has_sentiment = sentiment["positive"].present? || sentiment["negative"].present? %>
  <% has_themes    = themes.any? && themes.any? { |t| t["theme"].present? } %>
  <% if has_sentiment || has_themes %>
    <div class="grid <%= (has_sentiment && has_themes) ? 'grid-cols-2' : 'grid-cols-1' %> gap-3">

      <!-- Sentiment donut -->
      <% if has_sentiment %>
        <%
          pos_val = sentiment["positive"].to_s.gsub(/[^0-9.]/, '').to_f
          neu_val = sentiment["neutral"].to_s.gsub(/[^0-9.]/, '').to_f
          neg_val = sentiment["negative"].to_s.gsub(/[^0-9.]/, '').to_f
          total_s = pos_val + neu_val + neg_val
          total_s = 100.0 if total_s.zero?
          # Largest remainder rounding — guarantees sum = 100
          raw   = [pos_val, neu_val, neg_val].map { |v| v / total_s * 100 }
          floors = raw.map(&:floor)
          remainders = raw.each_with_index.map { |v, i| [v - floors[i], i] }.sort_by { |r, _| -r }
          deficit = 100 - floors.sum
          deficit.times { |k| floors[remainders[k][1]] += 1 }
          pos_r, neu_r, neg_r = floors
        %>
        <div class="rounded-xl border border-slate-100 bg-white p-3">
          <div class="text-[9px] font-bold text-slate-400 uppercase tracking-wide mb-2">Cảm xúc tổng thể</div>
          <!-- Donut left, legend + note fill remaining space -->
          <div class="flex items-start gap-4">
            <canvas id="<%= card_id %>-sentiment" width="96" height="96" style="width:96px;height:96px;flex-shrink:0;"></canvas>
            <div class="flex-1 min-w-0">
              <div class="space-y-2 mb-2">
                <% [["Tích cực", pos_r, "#34d399", "text-emerald-600"], ["Trung lập", neu_r, "#cbd5e1", "text-slate-400"], ["Tiêu cực", neg_r, "#f87171", "text-red-500"]].each do |label, val, color, text_cls| %>
                  <div class="flex items-center gap-2 text-[11px]">
                    <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background:<%= color %>;"></span>
                    <span class="text-slate-600 flex-1"><%= label %></span>
                    <strong class="<%= text_cls %>"><%= "#{val}%" %></strong>
                  </div>
                <% end %>
              </div>
              <% if sentiment["sentiment_note"].present? %>
                <p class="text-[10px] text-slate-400 italic leading-relaxed"><%= sentiment["sentiment_note"] %></p>
              <% end %>
            </div>
          </div>
        </div>
        <script>
        (function(){
          function drawSentimentDonut_<%= card_id.gsub('-','_') %>() {
            const canvas = document.getElementById('<%= card_id %>-sentiment');
            if (!canvas || canvas._drawn) return;
            canvas._drawn = true;
            const dpr = window.devicePixelRatio || 1;
            const size = 96;
            canvas.width  = size * dpr;
            canvas.height = size * dpr;
            canvas.style.width  = size + 'px';
            canvas.style.height = size + 'px';
            const ctx = canvas.getContext('2d');
            ctx.scale(dpr, dpr);
            const data   = [<%= pos_val %>, <%= neu_val %>, <%= neg_val %>];
            const colors = ['#34d399','#cbd5e1','#f87171'];
            const total  = data.reduce((a,b)=>a+b,0) || 100;
            const cx = size/2, cy = size/2, r = 44, innerR = 28;
            let angle = -Math.PI/2;
            data.forEach((val,i)=>{
              if (val <= 0) return;
              const slice = (val/total)*2*Math.PI;
              ctx.beginPath();
              ctx.moveTo(cx,cy);
              ctx.arc(cx,cy,r,angle,angle+slice);
              ctx.closePath();
              ctx.fillStyle = colors[i];
              ctx.fill();
              angle += slice;
            });
            // Donut hole
            ctx.beginPath();
            ctx.arc(cx,cy,innerR,0,2*Math.PI);
            ctx.fillStyle = '#fff';
            ctx.fill();
            // Center: dominant value
            const dominant = data.indexOf(Math.max(...data));
            ctx.fillStyle = colors[dominant];
            ctx.font = 'bold 15px system-ui,sans-serif';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillText(Math.round(data[dominant])+'%', cx, cy);
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', drawSentimentDonut_<%= card_id.gsub('-','_') %>);
          } else {
            drawSentimentDonut_<%= card_id.gsub('-','_') %>();
          }
          document.addEventListener('turbo:load', drawSentimentDonut_<%= card_id.gsub('-','_') %>);
        })();
        </script>
      <% end %>

      <!-- Themes list (open-text qualitative themes) -->
      <% if has_themes %>
        <div class="rounded-xl border border-slate-100 bg-white p-3">
          <div class="text-[9px] font-bold text-slate-400 uppercase tracking-wide mb-2">Chủ đề nổi bật</div>
          <div class="space-y-2">
            <% themes.first(5).each do |t| %>
              <% next unless t["theme"].present? %>
              <% sent_cls = t["sentiment"] == "positive" ? "text-emerald-500" : t["sentiment"] == "negative" ? "text-red-400" : "text-slate-400" %>
              <div>
                <div class="flex items-center gap-1.5 mb-0.5">
                  <span class="<%= sent_cls %> text-[10px]">●</span>
                  <span class="text-[10px] font-semibold text-slate-700"><%= t["theme"] %></span>
                </div>
                <% quotes = t["representative_quotes"].presence || [] %>
                <% if quotes.any? %>
                  <p class="text-[9px] text-slate-400 italic leading-snug pl-3">"<%= quotes.first.to_s.truncate(100) %>"</p>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  <% end %>

  <!-- ④ Question insights — all questions, sorted by concern level -->
  <% if q_insights.any? %>
    <%
      concern_order = { "high" => 0, "medium" => 1, "low" => 2 }
      sorted_insights = q_insights.sort_by { |qi| concern_order[qi["concern_level"].to_s] || 3 }
      flagged = sorted_insights.select { |qi| %w[high medium].include?(qi["concern_level"].to_s) }
      low_insights = sorted_insights.select { |qi| qi["concern_level"].to_s == "low" }
    %>
    <div>
      <div class="text-[9px] font-bold text-slate-400 uppercase tracking-wide mb-2">Phân tích từng câu hỏi</div>
      <div class="space-y-1.5" id="<%= card_id %>-insights">
        <!-- High/medium always visible -->
        <% flagged.each do |qi| %>
          <% is_high = qi["concern_level"] == "high" %>
          <% q_full = qi["question"].to_s; qi_id = "qi-#{card_id}-#{qi['question_id']}" %>
          <div class="flex gap-2 items-start rounded-lg px-2.5 py-2 bg-white border border-slate-100">
            <span class="text-[8px] font-black w-4 h-4 flex items-center justify-center rounded flex-shrink-0 mt-0.5 <%= is_high ? 'bg-red-100 text-red-500' : 'bg-amber-100 text-amber-500' %>"><%= is_high ? "!" : "~" %></span>
            <div class="flex-1 min-w-0">
              <div class="text-[10px] font-semibold text-slate-700 leading-snug">
                <% if q_full.length > 60 %>
                  <span id="<%= qi_id %>-s"><%= q_full.truncate(60) %><button onclick="document.getElementById('<%= qi_id %>-s').style.display='none';document.getElementById('<%= qi_id %>-f').style.display='inline'" class="text-indigo-400 text-[9px] ml-1 bg-transparent border-0 cursor-pointer p-0">...xem thêm</button></span>
                  <span id="<%= qi_id %>-f" style="display:none"><%= q_full %><button onclick="document.getElementById('<%= qi_id %>-f').style.display='none';document.getElementById('<%= qi_id %>-s').style.display='inline'" class="text-slate-400 text-[9px] ml-1 bg-transparent border-0 cursor-pointer p-0">thu gọn</button></span>
                <% else %><%= q_full %><% end %>
              </div>
              <div class="text-[10px] text-slate-500 mt-0.5 leading-snug"><%= qi["finding"] %></div>
            </div>
          </div>
        <% end %>
        <!-- Low concern: collapsed by default -->
        <% if low_insights.any? %>
          <div id="<%= card_id %>-low-insights" class="hidden space-y-1.5">
            <% low_insights.each do |qi| %>
              <% q_full = qi["question"].to_s; qi_id = "qi-#{card_id}-#{qi['question_id']}-l" %>
              <div class="flex gap-2 items-start rounded-lg px-2.5 py-2 bg-white border border-slate-100">
                <span class="text-[8px] w-4 h-4 flex items-center justify-center rounded flex-shrink-0 mt-0.5 bg-slate-100 text-slate-400">·</span>
                <div class="flex-1 min-w-0">
                  <div class="text-[10px] font-semibold text-slate-600 leading-snug">
                    <% if q_full.length > 60 %>
                      <span id="<%= qi_id %>-s"><%= q_full.truncate(60) %><button onclick="document.getElementById('<%= qi_id %>-s').style.display='none';document.getElementById('<%= qi_id %>-f').style.display='inline'" class="text-indigo-400 text-[9px] ml-1 bg-transparent border-0 cursor-pointer p-0">...xem thêm</button></span>
                      <span id="<%= qi_id %>-f" style="display:none"><%= q_full %><button onclick="document.getElementById('<%= qi_id %>-f').style.display='none';document.getElementById('<%= qi_id %>-s').style.display='inline'" class="text-slate-400 text-[9px] ml-1 bg-transparent border-0 cursor-pointer p-0">thu gọn</button></span>
                    <% else %><%= q_full %><% end %>
                  </div>
                  <div class="text-[10px] text-slate-400 mt-0.5 leading-snug"><%= qi["finding"] %></div>
                </div>
              </div>
            <% end %>
          </div>
          <button onclick="
            const el = document.getElementById('<%= card_id %>-low-insights');
            el.classList.toggle('hidden');
            this.textContent = el.classList.contains('hidden') ? '▼ Xem thêm <%= low_insights.size %> câu hỏi' : '▲ Thu gọn';
          " class="text-[10px] text-slate-400 hover:text-slate-600 font-medium bg-transparent border-0 cursor-pointer p-0 mt-0.5">
            ▼ Xem thêm <%= low_insights.size %> câu hỏi
          </button>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- ⑤ Highlights — compact bullets -->
  <% if highlights.any? %>
    <div class="rounded-xl p-3" style="background:rgba(16,185,129,0.04);border:1px solid rgba(16,185,129,0.12);">
      <div class="text-[9px] font-bold text-emerald-600 uppercase tracking-wide mb-1.5">✦ Điểm tích cực</div>
      <ul class="space-y-1">
        <% highlights.first(4).each_with_index do |h, hi| %>
          <li class="text-[11px] text-slate-700 leading-snug flex gap-1.5">
            <span class="text-emerald-400 flex-shrink-0">·</span><%= inject_q_title.call(h, "#{card_id}-hl#{hi}") %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- ⑥ Anomalies — compact -->
  <% if anomalies.any? %>
    <div>
      <div class="text-[9px] font-bold text-slate-400 uppercase tracking-wide mb-1.5">⚡ Bất thường</div>
      <ul class="space-y-1">
        <% anomalies.first(3).each_with_index do |a, ai| %>
          <li class="text-[11px] text-slate-600 leading-snug flex gap-1.5">
            <span class="text-amber-400 flex-shrink-0">⚡</span><%= inject_q_title.call(a, "#{card_id}-an#{ai}") %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- ⑦ Recommendations — action only, priority badge, rationale collapsed -->
  <% if recs.any? %>
    <div class="pt-3 border-t border-slate-100">
      <div class="text-[9px] font-bold text-slate-400 uppercase tracking-wide mb-2">→ Khuyến nghị</div>
      <div class="space-y-1.5">
        <% recs.first(5).each_with_index do |rec, ri| %>
          <% pri = rec.is_a?(Hash) ? rec["priority"].to_s : "" %>
          <% pri_cls = pri=="high" ? "bg-red-100 text-red-600" : pri=="medium" ? "bg-amber-100 text-amber-600" : "bg-slate-100 text-slate-400" %>
          <% rec_id = "#{card_id}-rec-#{ri}" %>
          <div class="rounded-lg border border-slate-100 bg-white overflow-hidden">
            <button type="button" onclick="(function(el){el.nextElementSibling.classList.toggle('hidden');el.querySelector('.rec-arrow').textContent=el.nextElementSibling.classList.contains('hidden')?'▾':'▴'})(this)"
              class="w-full flex items-start gap-2 px-2.5 py-2 text-left bg-transparent border-0 cursor-pointer hover:bg-slate-50 transition-colors">
              <% if pri.present? %>
                <span class="text-[8px] font-black px-1.5 py-0.5 rounded flex-shrink-0 mt-0.5 <%= pri_cls %>"><%= pri.upcase %></span>
              <% end %>
              <span class="text-[11px] text-slate-800 font-medium leading-snug flex-1"><%= rec.is_a?(Hash) ? rec["action"] : rec %></span>
              <span class="rec-arrow text-slate-300 text-[10px] flex-shrink-0 mt-0.5">▾</span>
            </button>
            <div class="hidden px-2.5 pb-2 border-t border-slate-50">
              <% if rec.is_a?(Hash) && rec["rationale"].present? %>
                <p class="text-[10px] text-slate-500 leading-snug mt-1.5"><%= rec["rationale"] %></p>
              <% end %>
              <% if rec.is_a?(Hash) && rec["impact"].present? %>
                <p class="text-[10px] text-indigo-500 font-medium mt-1">→ <%= rec["impact"] %></p>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
