    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lỗi server');
    setMdContent(`hist-tr-text-${id}`, data.result || '');
    document.getElementById(`hist-tr-text-${id}`).dataset.plain = data.result || '';
    document.getElementById(`hist-tr-result-${id}`).classList.remove('hidden');
    const used = parseInt(res.headers.get('X-Credits-Used') || '2');
    if (used > 0) deductLocal(used);
  } catch(e) { showHistErr(id, 'tr', '⚠️ ' + e.message); }
  finally     { setHistBtn(id, 'tr', false); }
}
async function deleteHistory(id) {
  if (!confirm(I18N.hist_del_confirm)) return;
  const url = DELETE_HISTORY_URL.replace('__ID__', id);
  try {
    const res = await fetch(url, { method:'DELETE', headers:{'X-CSRF-Token':CSRF} });
    if (res.ok) {
      document.getElementById(`hist-${id}`)?.remove();
      const remaining = document.querySelectorAll('[id^="hist-detail-"]').length;
      const badge = document.getElementById('history-count-badge');
      badge.textContent = remaining;
      badge.classList.toggle('hidden', remaining === 0);
      if (remaining === 0) {
        document.getElementById('history-list').innerHTML = `
          <div class="text-center py-16 px-4">
            <div class="text-5xl mb-3">📭</div>
            <p class="text-slate-600 text-[14px] font-semibold mb-1">${I18N.hist_empty_title}</p>
            <p class="text-slate-400 text-[13px]">${I18N.hist_empty_desc}</p>
          </div>`;
      }
    }
  } catch(e) { alert('Xóa thất bại.'); }
}
function copyHistText(id, btn) {
  const el = document.getElementById(`hist-text-${id}`);
  copyWithFeedback(el.dataset.full || el.textContent, btn);
}
function downloadHistText(id, name) {
  const el = document.getElementById(`hist-text-${id}`);
  const a  = document.createElement('a');
  a.href     = URL.createObjectURL(new Blob([el.dataset.full || el.textContent], { type:'text/plain' }));
  a.download = `${(name||'transcript').replace(/[^a-z0-9]/gi,'_').substring(0,40)}-${Date.now()}.txt`;
  a.click();
}
function copyHistSumResult(id, btn) {
  const el = document.getElementById(`hist-sum-text-${id}`);
  copyWithFeedback(el.dataset.plain || el.innerText, btn);
}
function copyHistTrResult(id, btn) {
  const el = document.getElementById(`hist-tr-text-${id}`);
  copyWithFeedback(el.dataset.plain || el.innerText, btn);
}
function setHistBtn(id, type, loading) {
  const btn  = document.getElementById(`hist-${type}-btn-${id}`);
  const lbl  = document.getElementById(`hist-${type}-lbl-${id}`);
  const spin = document.getElementById(`hist-${type}-spin-${id}`);
  btn.disabled = loading;
  lbl.textContent = loading ? I18N.ai_processing
    : (type === 'sum' ? I18N.hist_ai_sum.replace(/^\S+\s*/,'') : I18N.hist_ai_tr.replace(/^\S+\s*/,''));
  spin.classList.toggle('hidden', !loading);
}
function showHistErr(id, type, msg) {
  const el = document.getElementById(`hist-${type}-err-${id}`);
  if (el) { el.textContent = msg; el.classList.remove('hidden'); }
}
function clearHistErr(id, type) { document.getElementById(`hist-${type}-err-${id}`)?.classList.add('hidden'); }
function histSourceIcon(src) { return src==='mic'?'🎙️':src==='url'?'🔗':'🎵'; }

// ── Markdown renderer ─────────────────────────────────────────────────────
function renderMarkdown(raw) {
  if (!raw) return '';
  // HTML-escape first (security)
  const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  // Inline formatting (runs on already-escaped text)
  const inline = s => s
    .replace(/\*\*\*(.+?)\*\*\*/g, '<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g,     '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,         '<em>$1</em>')
    .replace(/`(.+?)`/g,           '<code>$1</code>');

  const lines  = raw.split('\n');
  let html     = '';
  let listType = null;   // 'ul' | 'ol' | null
  let para     = [];

  const flushPara = () => {
    if (!para.length) return;
    html += `<p>${inline(para.join(' '))}</p>`;
    para = [];
  };
  const flushList = () => {
    if (listType) { html += `</${listType}>`; listType = null; }
  };

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i];
    const raw  = line.trim();

    // Horizontal rule
    if (/^[-*_]{3,}$/.test(raw)) {
      flushPara(); flushList(); html += '<hr>'; continue;
    }
    // Blockquote
    if (raw.startsWith('> ')) {
      flushPara(); flushList();
      html += `<blockquote>${inline(esc(raw.slice(2)))}</blockquote>`; continue;
    }
    // Headings
    const hm = raw.match(/^(#{1,3})\s+(.+)/);
    if (hm) {
      flushPara(); flushList();
      const lvl = hm[1].length;
      html += `<h${lvl}>${inline(esc(hm[2]))}</h${lvl}>`; continue;
    }
    // Unordered list (•, -, *, +)
    const ulm = raw.match(/^[•\-\*\+]\s+(.+)/);
    if (ulm) {
      flushPara();
      if (listType !== 'ul') { flushList(); html += '<ul>'; listType = 'ul'; }
      html += `<li><span class="bul">•</span><span>${inline(esc(ulm[1]))}</span></li>`; continue;
    }
    // Ordered list
    const olm = raw.match(/^(\d+)[.)]\s+(.+)/);
    if (olm) {
      flushPara();
      if (listType !== 'ol') { flushList(); html += '<ol>'; listType = 'ol'; }
      html += `<li><span class="bul">${olm[1]}.</span><span>${inline(esc(olm[2]))}</span></li>`; continue;
    }
    // Empty line
    if (raw === '') {
      flushPara(); flushList(); continue;
    }
    // Normal text — accumulate into paragraph
    flushList();
    para.push(esc(raw));
  }
  flushPara(); flushList();
  return html;
}
function setMdContent(elId, text) {
  const el = document.getElementById(elId);
  if (!el) return;
  el.innerHTML = renderMarkdown(text);
}

// ── Utils ─────────────────────────────────────────────────────────────────
function getSupportedMimeType() {
  return ['audio/webm;codecs=opus','audio/webm','audio/ogg;codecs=opus','audio/mp4']
    .find(t => MediaRecorder.isTypeSupported(t)) || '';
}
function getPlainText(elId) {
  const el = document.getElementById(elId);
  return el.dataset.plain ?? el.innerText ?? el.textContent;
}
function copyWithFeedback(text, btn) {
  const orig = btn.innerHTML;
  navigator.clipboard.writeText(text).then(() => {
    btn.innerHTML = '✅ Đã sao chép';
    btn.disabled = true;
    setTimeout(() => { btn.innerHTML = orig; btn.disabled = false; }, 1800);
  }).catch(() => {
    btn.innerHTML = '❌ Lỗi';
    setTimeout(() => { btn.innerHTML = orig; }, 1500);
  });
}
function copyText(elId, btn) {
  copyWithFeedback(getPlainText(elId), btn || event.currentTarget);
}
function downloadText(elId, name) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([getPlainText(elId)], { type:'text/plain' }));
  a.download = `${name}-${Date.now()}.txt`; a.click();
}
function formatBytes(b) {
  return b < 1024 ? b+' B' : b < 1048576 ? (b/1024).toFixed(1)+' KB' : (b/1048576).toFixed(1)+' MB';
}
function fmtTime(sec) {
  if (sec == null) return '—';
  return `${Math.floor(sec/60)}:${(sec%60).toFixed(1).padStart(4,'0')}`;
}
function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

checkTranscribeButton();
</script>
