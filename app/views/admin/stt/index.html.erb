function toggleHistoryDetail(id) {
  const detail = document.getElementById(`hist-detail-${id}`);
  const toggle = document.getElementById(`hist-toggle-${id}`);
  const isOpen = !detail.classList.contains('hidden');
  // Close all others first
  document.querySelectorAll('[id^="hist-detail-"]').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('[id^="hist-toggle-"]').forEach(el => { el.textContent = 'Xem chi tiết ▾'; });
  if (!isOpen) {
    detail.classList.remove('hidden');
    toggle.textContent = 'Thu lại ▴';
  }
}

function toggleHistAiPanel(id, type) {
  const panel = document.getElementById(`hist-${type}-${id}`);
  const isOpen = panel.classList.contains('open');
  // Close both panels for this item first
  [`hist-sum-${id}`, `hist-tr-${id}`].forEach(k => {
    document.getElementById(k)?.classList.remove('open');
  });
  if (!isOpen) panel.classList.add('open');
}

async function doHistSummarize(id) {
  const textEl = document.getElementById(`hist-text-${id}`);
  const text   = textEl.dataset.full || textEl.textContent;
  if (!text?.trim()) return;
  if (getRemainingCredits() < 2) {
    showHistErr(id, 'sum', '⚠️ Không đủ credits (cần 2).'); return;
  }
  setHistBtn(id, 'sum', true);
  clearHistErr(id, 'sum');
  document.getElementById(`hist-sum-result-${id}`).classList.add('hidden');
  try {
    const fd = new FormData();
    fd.append('text',     text);
    fd.append('language', document.getElementById(`hist-sum-lang-${id}`).value);
    const res  = await fetch(SUMMARIZE_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lỗi server');
    document.getElementById(`hist-sum-text-${id}`).textContent = data.result || '';
    document.getElementById(`hist-sum-result-${id}`).classList.remove('hidden');
    const used = parseInt(res.headers.get('X-Credits-Used') || '2');
    if (used > 0) deductLocal(used);
  } catch(e) { showHistErr(id, 'sum', '⚠️ ' + e.message); }
  finally     { setHistBtn(id, 'sum', false); }
}

async function doHistTranslate(id) {
  const textEl = document.getElementById(`hist-text-${id}`);
  const text   = textEl.dataset.full || textEl.textContent;
  if (!text?.trim()) return;
  if (getRemainingCredits() < 2) {
    showHistErr(id, 'tr', '⚠️ Không đủ credits (cần 2).'); return;
  }
  setHistBtn(id, 'tr', true);
  clearHistErr(id, 'tr');
  document.getElementById(`hist-tr-result-${id}`).classList.add('hidden');
  try {
    const fd = new FormData();
    fd.append('text',            text);
    fd.append('target_language', document.getElementById(`hist-tr-lang-${id}`).value);
    const res  = await fetch(TRANSLATE_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lỗi server');
    document.getElementById(`hist-tr-text-${id}`).textContent = data.result || '';
    document.getElementById(`hist-tr-result-${id}`).classList.remove('hidden');
    const used = parseInt(res.headers.get('X-Credits-Used') || '2');
    if (used > 0) deductLocal(used);
  } catch(e) { showHistErr(id, 'tr', '⚠️ ' + e.message); }
  finally     { setHistBtn(id, 'tr', false); }
}

async function deleteHistory(id) {
  if (!confirm('Xóa transcript này?')) return;
  const url = DELETE_HISTORY_URL.replace('__ID__', id);
  try {
    const res = await fetch(url, { method:'DELETE', headers:{'X-CSRF-Token':CSRF} });
    if (res.ok) {
      const el = document.getElementById(`hist-${id}`);
      el?.remove();
      // Update badge count
      const remaining = document.querySelectorAll('[id^="hist-"]').length;
      const badge = document.getElementById('history-count-badge');
      badge.textContent = remaining;
      badge.classList.toggle('hidden', remaining === 0);
      if (remaining === 0) {
        document.getElementById('history-list').innerHTML = `
          <div class="text-center py-12 px-4">
            <div class="text-4xl mb-3">📭</div>
            <p class="text-slate-500 text-[13px] font-semibold mb-1">Chưa có lịch sử</p>
            <p class="text-slate-400 text-[12px]">Transcript sẽ được lưu tự động sau mỗi lần chuyển đổi</p>
          </div>`;
      }
    }
  } catch(e) { alert('Xóa thất bại. Vui lòng thử lại.'); }
}

function copyHistText(id) {
  const el = document.getElementById(`hist-text-${id}`);
  navigator.clipboard.writeText(el.dataset.full || el.textContent);
}
function downloadHistText(id, name) {
  const el = document.getElementById(`hist-text-${id}`);
  const a  = document.createElement('a');
  a.href     = URL.createObjectURL(new Blob([el.dataset.full || el.textContent], { type:'text/plain' }));
  a.download = `${(name || 'transcript').replace(/[^a-z0-9]/gi,'_').substring(0,40)}-${Date.now()}.txt`;
  a.click();
}
function copyHistSumResult(id) {
  navigator.clipboard.writeText(document.getElementById(`hist-sum-text-${id}`).textContent);
}
function copyHistTrResult(id) {
  navigator.clipboard.writeText(document.getElementById(`hist-tr-text-${id}`).textContent);
}

function setHistBtn(id, type, loading) {
  const btn  = document.getElementById(`hist-${type}-btn-${id}`);
  const lbl  = document.getElementById(`hist-${type}-lbl-${id}`);
  const spin = document.getElementById(`hist-${type}-spin-${id}`);
  btn.disabled = loading;
  lbl.textContent  = loading ? 'Đang xử lý...' : (type === 'sum' ? 'Tóm tắt' : 'Dịch');
  spin.classList.toggle('hidden', !loading);
}
function showHistErr(id, type, msg) {
  const el = document.getElementById(`hist-${type}-err-${id}`);
  if (el) { el.textContent = msg; el.classList.remove('hidden'); }
}
function clearHistErr(id, type) {
  document.getElementById(`hist-${type}-err-${id}`)?.classList.add('hidden');
}
function histSourceIcon(src) {
  return src === 'mic' ? '🎙️' : src === 'url' ? '🔗' : '🎵';
}

checkTranscribeButton();
</script>
<% end %>
