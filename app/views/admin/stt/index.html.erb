  histPage = 1;
  const container = document.getElementById('history-list');
  container.innerHTML = `<div class="text-center py-10 text-slate-400 text-[13px]"><%= j t('stt.history_loading') %></div>`;
  document.getElementById('hist-load-more-wrap').classList.add('hidden');
  try {
    const res  = await fetch(HISTORY_URL + '?page=1', { headers:{'X-CSRF-Token':CSRF} });
    const data = await res.json();
    historyLoaded = true;
    histPage     = 1;
    histTotal    = data.total;
    histHasMore  = data.has_more;
    renderHistory(data.items, data.total, data.has_more);
  } catch(e) {
    container.innerHTML = `<div class="text-center py-10 text-red-400 text-[12px]">${I18N.hist_error}</div>`;
  }
}
async function loadMoreHistory() {
  if (!histHasMore) return;
  const btn  = document.getElementById('hist-load-more-btn');
  const lbl  = document.getElementById('hist-load-more-lbl');
  const spin = document.getElementById('hist-load-more-spin');
  btn.disabled = true;
  lbl.textContent = I18N.ai_processing;
  spin.classList.remove('hidden');
  try {
    const nextPage = histPage + 1;
    const res  = await fetch(HISTORY_URL + '?page=' + nextPage, { headers:{'X-CSRF-Token':CSRF} });
    const data = await res.json();
    histPage    = nextPage;
    histTotal   = data.total;
    histHasMore = data.has_more;
    appendHistory(data.items, data.total, data.has_more);
  } catch(e) { /* silent */ }
  finally {
    btn.disabled = false;
    lbl.textContent = I18N.hist_load_more;
    spin.classList.add('hidden');
  }
}

