<% content_for :title, "Speech to Text" %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<style>
  @keyframes pulse-mic {
    0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.5); }
    50%       { box-shadow: 0 0 0 12px rgba(239,68,68,0); }
  }
  .mic-recording { animation: pulse-mic 1.4s ease-in-out infinite; }
  .drop-zone-hover { border-color: #6366f1 !important; background: #eef2ff !important; }
  .src-tab { transition: all 0.15s; }
  .src-tab.active { background:#fff; border-color:#e2e8f0; color:#1e293b; font-weight:700; box-shadow:0 1px 4px rgba(0,0,0,0.07); }
  .right-tab { transition: all 0.15s; }
  .right-tab.active { background:#fff; border-color:#e2e8f0; color:#1e293b; font-weight:700; box-shadow:0 1px 4px rgba(0,0,0,0.07); }
  .pp-panel { display:none; }
  .pp-panel.open { display:block; }
  .hist-ai-panel { display:none; }
  .hist-ai-panel.open { display:block; }
  .line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
</style>

<!-- ── Page header ──────────────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-4 bg-slate-100">
  <div class="flex items-start justify-between">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <h1 class="text-[21px] font-extrabold text-slate-900 flex items-center gap-2">
          🎤 Speech to Text
        </h1>
        <p class="text-[13px] text-slate-500 mt-0.5">
          Chuyển âm thanh / video thành văn bản · ElevenLabs Scribe v2 ·
          <span class="text-indigo-500 font-semibold"><%= t("stt.credit_rate") %></span>
        </p>
      </div>
    </div>
    <% unless ENV["ELEVENLABS_API_KEY"].present? %>
      <div class="px-3 py-2 bg-amber-50 border border-amber-200 rounded-lg text-amber-700 text-[12px] font-semibold">
        ⚠️ ELEVENLABS_API_KEY chưa được cấu hình
      </div>
    <% end %>
  </div>
</div>

<!-- ── Scrollable content ────────────────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-y-auto px-6 py-5">

<% if @has_stt %>
  <div class="grid grid-cols-[1fr_1fr] gap-5 items-start">

    <!-- ═══════════════════════════════════════════════════════════════
         LEFT — File / URL
         ═══════════════════════════════════════════════════════════════ -->
    <div class="space-y-4">
      <div class="bg-white rounded-xl border border-slate-200 p-5">

        <!-- Source tabs -->
        <div class="flex gap-1 p-1 bg-slate-100 rounded-lg mb-4">
          <button id="tab-file" onclick="switchTab('file')"
            class="src-tab active flex-1 py-1.5 text-[12px] rounded-md border border-transparent text-slate-600 cursor-pointer bg-transparent">
            📁 Tải file lên
          </button>
          <button id="tab-url" onclick="switchTab('url')"
            class="src-tab flex-1 py-1.5 text-[12px] rounded-md border border-transparent text-slate-400 cursor-pointer bg-transparent">
            🔗 URL / YouTube
          </button>
        </div>

        <!-- ── TAB: File ─────────────────────────────────────────── -->
        <div id="panel-file">
          <div id="drop-zone"
               class="border-2 border-dashed border-slate-300 rounded-xl p-8 text-center cursor-pointer transition-all hover:border-indigo-400 hover:bg-indigo-50/40"
               onclick="document.getElementById('file-input').click()"
               ondragover="event.preventDefault(); this.classList.add('drop-zone-hover')"
               ondragleave="this.classList.remove('drop-zone-hover')"
               ondrop="handleFileDrop(event)">

            <%# ── Audio+Video icon: split left=waveform / right=play ── %>
            <svg class="mx-auto mb-3 text-slate-400" width="64" height="52" viewBox="0 0 64 52" fill="none">
              <!-- Outer card -->
              <rect x="1" y="1" width="62" height="50" rx="7" stroke="currentColor" stroke-width="1.8" fill="currentColor" fill-opacity="0.04"/>
              <!-- Divider line -->
              <line x1="32" y1="9" x2="32" y2="43" stroke="currentColor" stroke-width="1.4" stroke-dasharray="2 2" opacity="0.3"/>

              <!-- LEFT: Audio waveform (5 bars, taller in center) -->
              <rect x="8"  y="25" width="3.5" height="8"  rx="1.75" fill="currentColor" opacity="0.40"/>
              <rect x="13" y="20" width="3.5" height="13" rx="1.75" fill="currentColor" opacity="0.55"/>
              <rect x="18" y="16" width="3.5" height="21" rx="1.75" fill="currentColor" opacity="0.75"/>
              <rect x="23" y="20" width="3.5" height="13" rx="1.75" fill="currentColor" opacity="0.55"/>
              <rect x="28" y="25" width="3.5" height="8"  rx="1.75" fill="currentColor" opacity="0.40"/>

              <!-- RIGHT: Camera body -->
              <rect x="35" y="17" width="22" height="16" rx="3" stroke="currentColor" stroke-width="1.8" fill="none" opacity="0.8"/>
              <!-- Camera lens -->
              <circle cx="46" cy="25" r="5" stroke="currentColor" stroke-width="1.8" fill="none" opacity="0.8"/>
              <circle cx="46" cy="25" r="2" fill="currentColor" opacity="0.5"/>
              <!-- Camera viewfinder dot -->
              <circle cx="54" cy="20" r="1.2" fill="currentColor" opacity="0.5"/>
              <!-- Record dot on camera -->
              <circle cx="38.5" cy="20" r="1.2" fill="currentColor" opacity="0.4"/>
            </svg>

            <p class="text-[13px] font-semibold text-slate-600 mb-1">Kéo thả file vào đây hoặc click để chọn</p>
            <p class="text-[11px] text-slate-400">MP3, MP4, WAV, M4A, WebM, FLAC, OGG · Tối đa 2 GB</p>
            <input type="file" id="file-input" accept="audio/*,video/*" class="hidden" onchange="handleFileSelect(this)">
          </div>

          <!-- File preview (hidden until file selected) -->
          <div id="file-preview" class="hidden mt-3 px-4 py-3 bg-slate-50 rounded-lg border border-slate-200 flex items-center gap-3">
            <svg id="file-type-icon" class="flex-shrink-0" width="28" height="24" viewBox="0 0 64 52" fill="none">
              <rect x="1" y="1" width="62" height="50" rx="7" stroke="#6366f1" stroke-width="2" fill="#eef2ff"/>
              <line x1="32" y1="9" x2="32" y2="43" stroke="#6366f1" stroke-width="1.4" stroke-dasharray="2 2" opacity="0.4"/>
              <rect x="8"  y="25" width="3.5" height="8"  rx="1.75" fill="#6366f1" opacity="0.5"/>
              <rect x="13" y="20" width="3.5" height="13" rx="1.75" fill="#6366f1" opacity="0.65"/>
              <rect x="18" y="16" width="3.5" height="21" rx="1.75" fill="#6366f1" opacity="0.85"/>
              <rect x="23" y="20" width="3.5" height="13" rx="1.75" fill="#6366f1" opacity="0.65"/>
              <rect x="28" y="25" width="3.5" height="8"  rx="1.75" fill="#6366f1" opacity="0.5"/>
              <rect x="35" y="17" width="22" height="16" rx="3" stroke="#6366f1" stroke-width="2" fill="none"/>
              <circle cx="46" cy="25" r="5" stroke="#6366f1" stroke-width="2" fill="none"/>
              <circle cx="46" cy="25" r="2" fill="#6366f1" opacity="0.6"/>
            </svg>
            <div class="flex-1 min-w-0">
              <p id="file-name" class="text-[13px] font-semibold text-slate-800 truncate"></p>
              <p id="file-size" class="text-[11px] text-slate-400"></p>
            </div>
            <button onclick="clearFile()" class="text-slate-400 hover:text-red-500 text-[18px] leading-none border-0 bg-transparent cursor-pointer">×</button>
          </div>

          <!-- Credit estimate (hidden until duration known) -->
          <div id="file-credit-info" class="hidden mt-3 flex items-center justify-between px-3 py-2 bg-indigo-50 border border-indigo-100 rounded-lg">
            <span class="text-[12px] text-indigo-700">🕐 <span id="file-duration-text" class="font-semibold"></span></span>
            <span class="text-[12px] font-bold text-indigo-600">Ước tính: <span id="file-credit-estimate">—</span></span>
          </div>
        </div>

        <!-- ── TAB: URL ───────────────────────────────────────────── -->
        <div id="panel-url" class="hidden">
          <div class="mb-2">
            <label class="block text-[11px] font-semibold text-slate-500 mb-1.5">
              URL video / audio <span class="font-normal text-slate-400 ml-1">(YouTube, Vimeo, TikTok, Facebook, SoundCloud…)</span>
            </label>
            <div class="flex gap-2">
              <input type="url" id="url-input" placeholder="https://www.youtube.com/watch?v=..."
                class="flex-1 px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:outline-none focus:ring-2 focus:ring-indigo-300 placeholder-slate-400">
              <button onclick="clearUrl()" class="px-3 py-2.5 text-slate-400 hover:text-red-500 border border-slate-200 rounded-lg bg-white cursor-pointer text-[15px] transition-colors">×</button>
            </div>
          </div>
          <div class="flex flex-wrap gap-1.5 mt-2">
            <% %w[YouTube Vimeo TikTok Facebook Instagram SoundCloud Dailymotion X/Twitter].each do |site| %>
              <span class="px-2 py-0.5 bg-slate-100 text-slate-500 text-[10px] font-semibold rounded-full"><%= site %></span>
            <% end %>
            <span class="px-2 py-0.5 bg-indigo-50 text-indigo-500 text-[10px] font-semibold rounded-full">+1000 nguồn khác</span>
          </div>
          <p class="text-[11px] text-slate-400 mt-2">⚡ Powered by <strong>yt-dlp</strong> · Chỉ tải audio, không cần đăng nhập · Video công khai</p>
          <div class="mt-3 flex items-start gap-2 px-3 py-2 bg-amber-50 border border-amber-100 rounded-lg">
            <span class="text-amber-500 mt-px">💡</span>
            <span class="text-[12px] text-amber-700">Credit tính theo độ dài video sau khi tải xong. Cần ít nhất <strong>1 credit</strong>.</span>
          </div>
        </div>

        <!-- ── Shared settings ───────────────────────────────────── -->
        <div class="grid grid-cols-2 gap-3 mt-4">
          <div>
            <label class="block text-[11px] font-semibold text-slate-500 mb-1">Model</label>
            <select id="file-model" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:outline-none focus:ring-2 focus:ring-indigo-300">
              <option value="scribe_v2" selected>Scribe v2</option>
              <option value="scribe_v1">Scribe v1</option>
            </select>
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-slate-500 mb-1">Ngôn ngữ</label>
            <select id="file-language" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:outline-none focus:ring-2 focus:ring-indigo-300">
              <option value="">Tự động nhận diện</option>
              <option value="vi">Tiếng Việt</option>
              <option value="en">English</option>
              <option value="ja">日本語</option>
              <option value="ko">한국어</option>
              <option value="zh">中文</option>
              <option value="fr">Français</option>
              <option value="de">Deutsch</option>
              <option value="es">Español</option>
            </select>
          </div>
          <div>
            <label class="block text-[11px] font-semibold text-slate-500 mb-1">Timestamps</label>
            <select id="file-timestamps" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:outline-none focus:ring-2 focus:ring-indigo-300">
              <option value="none" selected>Không</option>
              <option value="word">Từng từ</option>
            </select>
          </div>
          <div class="flex items-end pb-0.5">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" id="file-diarize" class="w-4 h-4 accent-indigo-600">
              <span class="text-[12px] font-semibold text-slate-600">Nhận diện người nói</span>
            </label>
          </div>
        </div>

        <!-- Credit warning -->
        <div id="stt-credit-warning" class="hidden mt-3 p-3 bg-red-50 border border-red-200 rounded-xl text-red-700 text-[13px] flex items-start gap-2">
          <span class="text-base leading-none mt-px">⚠️</span>
          <span id="stt-credit-warning-text"></span>
        </div>

        <!-- Transcribe button -->
        <button id="transcribe-btn" onclick="transcribeSource()"
          class="mt-4 w-full py-2.5 bg-blue-500 hover:bg-blue-600 text-white text-[13px] font-bold rounded-xl transition-colors flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
          <span id="transcribe-btn-label">🎤 Chuyển thành văn bản</span>
          <svg id="transcribe-spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>
      </div>

      <!-- ── Transcript result (hidden until success) ─────────────── -->
      <div id="file-result" class="hidden bg-white rounded-xl border border-slate-200 p-5 space-y-4">

        <!-- Header + action buttons -->
        <div class="flex items-center justify-between">
          <h3 class="text-[12px] font-bold text-slate-600 uppercase tracking-wide">Kết quả</h3>
          <div class="flex gap-2 flex-wrap items-center">
            <span id="file-lang-badge"         class="hidden px-2 py-0.5 bg-indigo-100 text-indigo-700 text-[11px] font-semibold rounded-full"></span>
            <span id="file-credits-used-badge" class="hidden px-2 py-0.5 bg-violet-100 text-violet-700 text-[11px] font-semibold rounded-full"></span>
            <button onclick="copyText('file-transcript-text')"
              class="px-2.5 py-1 text-[11px] font-semibold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg border-0 cursor-pointer">📋 Sao chép</button>
            <button onclick="downloadText('file-transcript-text','transcript')"
              class="px-2.5 py-1 text-[11px] font-semibold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg border-0 cursor-pointer">⬇ Tải về</button>
          </div>
        </div>

        <!-- Transcript text -->
        <div id="file-transcript-text"
             class="min-h-[100px] max-h-[320px] overflow-y-auto p-3 bg-slate-50 rounded-lg border border-slate-100 text-[13px] text-slate-800 leading-relaxed whitespace-pre-wrap font-mono"></div>

        <!-- Word timestamps (collapsible) -->
        <div id="file-words-wrap" class="hidden">
          <button onclick="toggleWords()" class="text-[11px] text-indigo-600 font-semibold hover:text-indigo-700 border-0 bg-transparent cursor-pointer">
            🕐 Xem timestamps từng từ ▾
          </button>
          <div id="file-words" class="hidden mt-2 max-h-[160px] overflow-y-auto text-[11px] text-slate-500 font-mono space-y-0.5 bg-slate-50 p-3 rounded-lg border border-slate-100"></div>
        </div>

        <!-- ── Post-process: Summarize / Translate ─────────────── -->
        <div class="border-t border-slate-100 pt-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wide">AI Hỗ trợ</span>
            <span class="text-[10px] text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">2 credits / lần</span>
          </div>
          <div class="flex gap-2 flex-wrap">
            <!-- Summarize button -->
            <button onclick="togglePanel('summarize')"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-[12px] font-semibold bg-violet-50 hover:bg-violet-100 text-violet-700 border border-violet-200 rounded-lg cursor-pointer transition-colors">
              📝 Tóm tắt
            </button>
            <!-- Translate button -->
            <button onclick="togglePanel('translate')"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 text-[12px] font-semibold bg-blue-50 hover:bg-blue-100 text-blue-700 border border-blue-200 rounded-lg cursor-pointer transition-colors">
              🌐 Dịch
            </button>
          </div>

          <!-- Summarize panel -->
          <div id="panel-summarize" class="pp-panel mt-3 p-4 bg-violet-50 border border-violet-100 rounded-xl space-y-3">
            <div class="flex items-center gap-3">
              <label class="text-[12px] font-semibold text-violet-700 whitespace-nowrap">Ngôn ngữ tóm tắt:</label>
              <select id="summarize-language" class="flex-1 px-3 py-1.5 border border-violet-200 rounded-lg text-[12px] bg-white focus:outline-none focus:ring-2 focus:ring-violet-300">
                <option value="vi">🇻🇳 Tiếng Việt</option>
                <option value="en">🇺🇸 English</option>
                <option value="zh">🇨🇳 中文</option>
                <option value="ja">🇯🇵 日本語</option>
                <option value="ko">🇰🇷 한국어</option>
                <option value="fr">🇫🇷 Français</option>
                <option value="de">🇩🇪 Deutsch</option>
                <option value="es">🇪🇸 Español</option>
                <option value="th">🇹🇭 Thai</option>
                <option value="id">🇮🇩 Indonesian</option>
              </select>
              <button id="summarize-btn" onclick="doSummarize()"
                class="px-4 py-1.5 bg-violet-600 hover:bg-violet-700 text-white text-[12px] font-bold rounded-lg cursor-pointer border-0 transition-colors disabled:opacity-50 flex items-center gap-1.5">
                <span id="summarize-btn-label">Tóm tắt</span>
                <svg id="summarize-spinner" class="hidden w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
              </button>
            </div>
            <div id="summarize-result" class="hidden">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[11px] font-bold text-violet-700 uppercase">Tóm tắt</span>
                <div class="flex gap-1.5">
                  <button onclick="copyText('summarize-text')" class="px-2 py-0.5 text-[10px] font-semibold bg-violet-100 hover:bg-violet-200 text-violet-700 rounded cursor-pointer border-0">📋 Copy</button>
                  <button onclick="downloadText('summarize-text','summary')" class="px-2 py-0.5 text-[10px] font-semibold bg-violet-100 hover:bg-violet-200 text-violet-700 rounded cursor-pointer border-0">⬇ Tải</button>
                </div>
              </div>
              <div id="summarize-text" class="max-h-[200px] overflow-y-auto p-3 bg-white rounded-lg border border-violet-100 text-[12px] text-slate-800 leading-relaxed whitespace-pre-wrap"></div>
            </div>
            <div id="summarize-error" class="hidden text-[12px] text-red-600 font-semibold"></div>
          </div>

          <!-- Translate panel -->
          <div id="panel-translate" class="pp-panel mt-3 p-4 bg-blue-50 border border-blue-100 rounded-xl space-y-3">
            <div class="flex items-center gap-3">
              <label class="text-[12px] font-semibold text-blue-700 whitespace-nowrap">Dịch sang:</label>
              <select id="translate-language" class="flex-1 px-3 py-1.5 border border-blue-200 rounded-lg text-[12px] bg-white focus:outline-none focus:ring-2 focus:ring-blue-300">
                <option value="en">🇺🇸 English</option>
                <option value="vi">🇻🇳 Tiếng Việt</option>
                <option value="zh">🇨🇳 中文</option>
                <option value="ja">🇯🇵 日本語</option>
                <option value="ko">🇰🇷 한국어</option>
                <option value="fr">🇫🇷 Français</option>
                <option value="de">🇩🇪 Deutsch</option>
                <option value="es">🇪🇸 Español</option>
                <option value="th">🇹🇭 Thai</option>
                <option value="id">🇮🇩 Indonesian</option>
              </select>
              <button id="translate-btn" onclick="doTranslate()"
                class="px-4 py-1.5 bg-blue-600 hover:bg-blue-700 text-white text-[12px] font-bold rounded-lg cursor-pointer border-0 transition-colors disabled:opacity-50 flex items-center gap-1.5">
                <span id="translate-btn-label">Dịch</span>
                <svg id="translate-spinner" class="hidden w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
              </button>
            </div>
            <div id="translate-result" class="hidden">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-[11px] font-bold text-blue-700 uppercase">Bản dịch</span>
                <div class="flex gap-1.5">
                  <button onclick="copyText('translate-text')" class="px-2 py-0.5 text-[10px] font-semibold bg-blue-100 hover:bg-blue-200 text-blue-700 rounded cursor-pointer border-0">📋 Copy</button>
                  <button onclick="downloadText('translate-text','translation')" class="px-2 py-0.5 text-[10px] font-semibold bg-blue-100 hover:bg-blue-200 text-blue-700 rounded cursor-pointer border-0">⬇ Tải</button>
                </div>
              </div>
              <div id="translate-text" class="max-h-[200px] overflow-y-auto p-3 bg-white rounded-lg border border-blue-100 text-[12px] text-slate-800 leading-relaxed whitespace-pre-wrap"></div>
            </div>
            <div id="translate-error" class="hidden text-[12px] text-red-600 font-semibold"></div>
          </div>
        </div>
      </div>

      <!-- Error -->
      <div id="file-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-[13px]"></div>
    </div>

    <!-- ═══════════════════════════════════════════════════════════════
         RIGHT — Tabs: Ghi âm Realtime | Lịch sử
         ═══════════════════════════════════════════════════════════════ -->
    <div class="space-y-3">

      <!-- Tab bar -->
      <div class="flex gap-1 p-1 bg-slate-100 rounded-lg">
        <button id="right-tab-mic" onclick="switchRightTab('mic')"
          class="right-tab active flex-1 py-1.5 text-[12px] rounded-md border border-transparent text-slate-600 cursor-pointer bg-transparent">
          🎙️ Ghi âm Realtime
        </button>
        <button id="right-tab-history" onclick="switchRightTab('history')"
          class="right-tab flex-1 py-1.5 text-[12px] rounded-md border border-transparent text-slate-400 cursor-pointer bg-transparent flex items-center justify-center gap-1.5">
          📋 Lịch sử
          <span id="history-count-badge" class="hidden bg-indigo-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full leading-none">0</span>
        </button>
      </div>

      <!-- ── PANEL: Ghi âm ──────────────────────────────────────── -->
      <div id="right-panel-mic" class="space-y-3">
        <div class="bg-white rounded-xl border border-slate-200 p-5">
          <h2 class="text-[13px] font-bold text-slate-700 mb-1 flex items-center gap-2">
            🎙️ Ghi âm Realtime
            <span class="text-[10px] font-normal text-slate-400 bg-slate-100 px-2 py-0.5 rounded-full">Chunk mode · mỗi 5s gửi lên</span>
          </h2>
          <p class="text-[11px] text-slate-400 mb-4">
            🪙 <span class="font-semibold text-violet-600">1 credit / đoạn (5 giây)</span> · Còn lại:
            <span id="mic-credit-remaining" class="font-bold text-slate-600"><%= @remaining_credits %></span> credit
          </p>
          <div class="flex flex-col items-center py-6">
            <button id="mic-btn" onclick="toggleMic()"
              class="w-20 h-20 rounded-full bg-slate-100 hover:bg-red-100 border-2 border-slate-200 hover:border-red-400 flex items-center justify-center text-4xl transition-all cursor-pointer">
              🎙️
            </button>
            <p id="mic-status" class="mt-3 text-[12px] text-slate-500 font-semibold">Click để bắt đầu ghi âm</p>
            <div class="mt-3 w-48 h-2 bg-slate-100 rounded-full overflow-hidden">
              <div id="vol-bar" class="h-full bg-emerald-400 rounded-full transition-all" style="width:0%"></div>
            </div>
            <p id="mic-timer" class="hidden mt-2 text-[12px] font-mono text-red-600 font-bold">00:00</p>
            <p id="mic-no-credit" class="hidden mt-2 text-[12px] text-red-600 font-semibold text-center">⚠️ Không đủ AI credits để ghi âm</p>
          </div>
          <div class="grid grid-cols-2 gap-3 border-t border-slate-100 pt-4">
            <div>
              <label class="block text-[11px] font-semibold text-slate-500 mb-1">Model</label>
              <select id="mic-model" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:outline-none focus:ring-2 focus:ring-indigo-300">
                <option value="scribe_v2" selected>Scribe v2</option>
                <option value="scribe_v1">Scribe v1</option>
              </select>
            </div>
            <div>
              <label class="block text-[11px] font-semibold text-slate-500 mb-1">Ngôn ngữ</label>
              <select id="mic-language" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[12px] focus:outline-none focus:ring-2 focus:ring-indigo-300">
                <option value="">Tự động</option>
                <option value="vi">Tiếng Việt</option>
                <option value="en">English</option>
                <option value="ja">日本語</option>
                <option value="ko">한국어</option>
                <option value="zh">中文</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Realtime transcript -->
        <div class="bg-white rounded-xl border border-slate-200 p-5">
          <div class="flex items-center justify-between mb-3">
            <div class="flex items-center gap-2">
              <h3 class="text-[12px] font-bold text-slate-600 uppercase tracking-wide">Transcript</h3>
              <span id="mic-sending-badge" class="hidden text-[10px] font-semibold text-amber-600 bg-amber-50 border border-amber-200 px-2 py-0.5 rounded-full animate-pulse">⏳ Đang xử lý...</span>
            </div>
            <div class="flex gap-2">
              <button onclick="clearMicTranscript()" class="px-2.5 py-1 text-[11px] font-semibold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg border-0 cursor-pointer">🗑 Xóa</button>
              <button onclick="copyText('mic-transcript-text')" class="px-2.5 py-1 text-[11px] font-semibold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg border-0 cursor-pointer">📋 Sao chép</button>
              <button onclick="downloadText('mic-transcript-text','transcript-mic')" class="px-2.5 py-1 text-[11px] font-semibold bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-lg border-0 cursor-pointer">⬇ Tải về</button>
            </div>
          </div>
          <div id="mic-transcript-text"
               class="min-h-[200px] max-h-[480px] overflow-y-auto p-3 bg-slate-50 rounded-lg border border-slate-100 text-[13px] text-slate-800 leading-relaxed whitespace-pre-wrap font-mono">
            <span class="text-slate-400 text-[12px]">Transcript sẽ xuất hiện ở đây sau mỗi 5 giây ghi âm...</span>
          </div>
          <p id="chunk-counter" class="hidden mt-2 text-[11px] text-slate-400"></p>
        </div>
      </div><!-- /right-panel-mic -->

      <!-- ── PANEL: Lịch sử ─────────────────────────────────────── -->
      <div id="right-panel-history" class="hidden">
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
          <!-- Header -->
          <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
            <span class="text-[12px] font-bold text-slate-600 uppercase tracking-wide">📋 Lịch sử Transcript</span>
            <button onclick="loadHistory(true)" class="text-[11px] text-indigo-600 hover:text-indigo-700 font-semibold border-0 bg-transparent cursor-pointer">↺ Làm mới</button>
          </div>
          <!-- List container -->
          <div id="history-list" class="divide-y divide-slate-100 max-h-[680px] overflow-y-auto">
            <div class="text-center py-10 text-slate-400 text-[13px]">Đang tải...</div>
          </div>
        </div>
      </div><!-- /right-panel-history -->

    </div><!-- /right col -->

  </div>

<% else %>
  <%# ── UPGRADE LANDING PAGE ─────────────────────────────────────────── %>
  <div class="max-w-2xl mx-auto py-10">
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
      <div class="bg-gradient-to-br from-violet-600 to-indigo-600 px-8 py-10 text-center text-white">
        <div class="text-5xl mb-4">🎤</div>
        <h2 class="text-2xl font-extrabold mb-2">Speech to Text</h2>
        <p class="text-indigo-200 text-[14px]"><%= t("stt.upgrade_desc") %></p>
      </div>
      <div class="px-8 py-6">
        <p class="text-[12px] font-bold text-slate-500 uppercase tracking-widest mb-4"><%= t("stt.upgrade_title") %></p>
        <ul class="space-y-3 mb-6">
          <% [:upgrade_feature_1, :upgrade_feature_2, :upgrade_feature_3, :upgrade_feature_4].each do |key| %>
            <li class="flex items-center gap-3 text-[13px] text-slate-700">
              <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0 text-[11px] font-bold">✓</span>
              <%= t("stt.#{key}") %>
            </li>
          <% end %>
        </ul>
        <div class="mb-6 px-4 py-3 bg-violet-50 border border-violet-100 rounded-xl flex items-center gap-3">
          <span class="text-2xl">🪙</span>
          <div>
            <p class="text-[13px] font-bold text-violet-800">Giá sử dụng</p>
            <p class="text-[12px] text-violet-600"><%= t("stt.credit_rate") %> · ElevenLabs Scribe v2 (~$0.40/giờ)</p>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="rounded-xl border-2 border-indigo-500 bg-indigo-50 p-4 text-center">
            <div class="text-[11px] font-bold text-indigo-600 uppercase tracking-wide mb-1">Pro</div>
            <div class="text-xl font-extrabold text-slate-800">190.000₫<span class="text-[12px] font-normal text-slate-400"><%= t("stt.per_month") %></span></div>
            <div class="text-[11px] text-slate-500 mt-1"><%= t("stt.pro_credits") %></div>
          </div>
          <div class="rounded-xl border-2 border-violet-500 bg-violet-50 p-4 text-center">
            <div class="text-[11px] font-bold text-violet-600 uppercase tracking-wide mb-1">Enterprise</div>
            <div class="text-xl font-extrabold text-slate-800">390.000₫<span class="text-[12px] font-normal text-slate-400"><%= t("stt.per_month") %></span></div>
            <div class="text-[11px] text-slate-500 mt-1"><%= t("stt.enterprise_credits") %></div>
          </div>
        </div>
        <%= link_to subscription_path, class: "block w-full py-3 bg-violet-600 hover:bg-violet-700 text-white text-[14px] font-bold rounded-xl text-center transition-colors" do %>
          <%= t("stt.upgrade_btn") %> →
        <% end %>
      </div>
    </div>
  </div>
<% end %>

</div>

<% if @has_stt %>
<script>
const TRANSCRIBE_URL     = "<%= stt_transcribe_path %>";
const TRANSCRIBE_URL_URL = "<%= stt_transcribe_url_path %>";
const CHUNK_URL          = "<%= stt_transcribe_chunk_path %>";
const SUMMARIZE_URL      = "<%= stt_summarize_path %>";
const TRANSLATE_URL      = "<%= stt_translate_path %>";
const HISTORY_URL        = "<%= stt_history_path %>";
const SAVE_MIC_URL       = "<%= stt_save_mic_path %>";
const DELETE_HISTORY_URL = "<%= stt_destroy_history_path(id: '__ID__') %>";
const CSRF               = document.querySelector('meta[name="csrf-token"]').content;
const SECS_PER_CREDIT    = 60;

// ── Credits ───────────────────────────────────────────────────────────────
function getRemainingCredits() {
  return typeof window.__currentCredits === "number"
    ? window.__currentCredits
    : parseInt(document.getElementById('mic-credit-remaining')?.textContent || "0") || 0;
}
function deductLocal(amount) {
  if (typeof window.deductDisplayCredits === "function") window.deductDisplayCredits(amount);
  const el = document.getElementById('mic-credit-remaining');
  if (el) el.textContent = Math.max(0, getRemainingCredits() - amount);
}
function creditsForSecs(secs) {
  return Math.max(Math.ceil(secs > 0 ? secs / SECS_PER_CREDIT : 1), 1);
}

// ── Right-column tabs (Mic | History) ────────────────────────────────────
let historyLoaded = false;
function switchRightTab(tab) {
  ['mic','history'].forEach(t => {
    document.getElementById(`right-panel-${t}`).classList.toggle('hidden', t !== tab);
    document.getElementById(`right-tab-${t}`).classList.toggle('active', t === tab);
  });
  if (tab === 'history' && !historyLoaded) loadHistory();
}

// ── Source tabs (File | URL) ──────────────────────────────────────────────
let activeTab = 'file';
function switchTab(tab) {
  activeTab = tab;
  ['file','url'].forEach(t => {
    document.getElementById(`panel-${t}`).classList.toggle('hidden', t !== tab);
    document.getElementById(`tab-${t}`).classList.toggle('active', t === tab);
  });
  document.getElementById('file-result').classList.add('hidden');
  document.getElementById('file-error').classList.add('hidden');
  hideCreditWarning();
  checkTranscribeButton();
}

// ── File Upload ───────────────────────────────────────────────────────────
let selectedFile = null, fileDurationSecs = 0;

function handleFileSelect(input) { if (input.files[0]) setFile(input.files[0]); }
function handleFileDrop(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.remove('drop-zone-hover');
  if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]);
}
function setFile(file) {
  selectedFile = file; fileDurationSecs = 0;
  document.getElementById('drop-zone').classList.add('hidden');
  document.getElementById('file-preview').classList.remove('hidden');
  document.getElementById('file-name').textContent = file.name;
  document.getElementById('file-size').textContent = formatBytes(file.size);
  document.getElementById('file-credit-info').classList.add('hidden');
  hideResultError(); hideCreditWarning();

  // Read duration without uploading
  const isVid = file.type.startsWith('video/') || /\.(mp4|mkv|avi|mov|webm)$/i.test(file.name);
  const media = document.createElement(isVid ? 'video' : 'audio');
  media.preload = 'metadata';
  const url = URL.createObjectURL(file);
  media.src = url;
  media.onloadedmetadata = () => {
    URL.revokeObjectURL(url);
    const dur = media.duration;
    if (dur && isFinite(dur)) {
      fileDurationSecs = dur;
      const credits = creditsForSecs(dur);
      const mins = Math.floor(dur / 60), secs = Math.round(dur % 60);
      const el = document.getElementById('file-credit-estimate');
      el.textContent    = `${credits} credit${credits > 1 ? 's' : ''}`;
      el.style.color    = credits > getRemainingCredits() ? '#dc2626' : '#4f46e5';
      document.getElementById('file-duration-text').textContent = `${mins}:${String(secs).padStart(2,'0')} phút`;
      document.getElementById('file-credit-info').classList.remove('hidden');
    }
    checkTranscribeButton();
  };
  media.onerror = () => { URL.revokeObjectURL(url); checkTranscribeButton(); };
}
function clearFile() {
  selectedFile = null; fileDurationSecs = 0;
  document.getElementById('file-input').value = '';
  document.getElementById('drop-zone').classList.remove('hidden');
  document.getElementById('file-preview').classList.add('hidden');
  document.getElementById('file-credit-info').classList.add('hidden');
  hideResultError(); hideCreditWarning(); checkTranscribeButton();
}
function clearUrl() {
  document.getElementById('url-input').value = '';
  hideResultError(); hideCreditWarning(); checkTranscribeButton();
}

// ── Credit guard ──────────────────────────────────────────────────────────
function checkTranscribeButton() {
  const btn = document.getElementById('transcribe-btn');
  const rem = getRemainingCredits();
  if (activeTab === 'file' && selectedFile && fileDurationSecs > 0) {
    const need = creditsForSecs(fileDurationSecs);
    if (need > rem) { showCreditWarning(need, rem); btn.disabled = true; return; }
  }
  if (activeTab === 'url' && rem < 1) { showCreditWarning(1, 0); btn.disabled = true; return; }
  hideCreditWarning(); btn.disabled = false;
}
function showCreditWarning(need, rem) {
  const el = document.getElementById('stt-credit-warning');
  document.getElementById('stt-credit-warning-text').textContent =
    `Cần ${need} credit nhưng bạn chỉ còn ${rem} credit. Vui lòng nạp thêm hoặc chọn file ngắn hơn.`;
  el.classList.remove('hidden');
}
function hideCreditWarning() { document.getElementById('stt-credit-warning')?.classList.add('hidden'); }

// ── Transcribe ────────────────────────────────────────────────────────────
async function transcribeSource() { activeTab === 'file' ? await transcribeFile() : await transcribeUrl(); }

async function transcribeFile() {
  if (!selectedFile) { showFileError("Vui lòng chọn file audio/video."); return; }
  if (fileDurationSecs > 0 && creditsForSecs(fileDurationSecs) > getRemainingCredits()) {
    showCreditWarning(creditsForSecs(fileDurationSecs), getRemainingCredits()); return;
  }
  setLoading(true, "Đang tải lên & xử lý...");
  hideResultError();
  const fd = new FormData();
  fd.append('audio_file',    selectedFile);
  fd.append('duration_secs', fileDurationSecs > 0 ? fileDurationSecs.toFixed(1) : '0');
  fd.append('model',         document.getElementById('file-model').value);
  fd.append('language_code', document.getElementById('file-language').value);
  fd.append('timestamps',    document.getElementById('file-timestamps').value);
  fd.append('diarize',       document.getElementById('file-diarize').checked ? 'true' : 'false');
  await doTranscribe(TRANSCRIBE_URL, fd);
}
async function transcribeUrl() {
  const url = document.getElementById('url-input').value.trim();
  if (!url) { showFileError("Vui lòng nhập URL."); return; }
  if (getRemainingCredits() < 1) { showCreditWarning(1, 0); return; }
  setLoading(true, "Đang tải audio từ URL...");
  hideResultError();
  const fd = new FormData();
  fd.append('url',           url);
  fd.append('model',         document.getElementById('file-model').value);
  fd.append('language_code', document.getElementById('file-language').value);
  fd.append('timestamps',    document.getElementById('file-timestamps').value);
  fd.append('diarize',       document.getElementById('file-diarize').checked ? 'true' : 'false');
  await doTranscribe(TRANSCRIBE_URL_URL, fd);
}
async function doTranscribe(endpoint, fd) {
  try {
    const res  = await fetch(endpoint, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (!res.ok) {
      showFileError(data.upgrade_required ? "Gói của bạn không hỗ trợ tính năng này."
                  : data.error || "Lỗi server.");
      if (data.insufficient_credits) checkTranscribeButton();
      return;
    }
    const used = parseInt(res.headers.get("X-Credits-Used") || "0");
    if (used > 0) deductLocal(used);
    showResult(data, used);
    checkTranscribeButton();
  } catch (e) { showFileError("Không thể kết nối server. Vui lòng thử lại."); }
  finally { setLoading(false, "🎤 Chuyển thành văn bản"); }
}
function showResult(data, used) {
  document.getElementById('file-transcript-text').textContent = data.text || "(không có kết quả)";
  const lb = document.getElementById('file-lang-badge');
  if (data.language_code) { lb.textContent = `🌐 ${data.language_code.toUpperCase()}`; lb.classList.remove('hidden'); }
  const cb = document.getElementById('file-credits-used-badge');
  if (used > 0) { cb.textContent = `🪙 -${used} credit`; cb.classList.remove('hidden'); }
  const words = data.words || [];
  if (words.length > 0) {
    document.getElementById('file-words').innerHTML = words.map(w =>
      `<div>[${fmtTime(w.start)}–${fmtTime(w.end)}] <span class="text-slate-800 font-semibold">${escHtml(w.text)}</span>${w.speaker_id ? ` <span class="text-indigo-400">${w.speaker_id}</span>` : ''}</div>`
    ).join('');
    document.getElementById('file-words-wrap').classList.remove('hidden');
  } else {
    document.getElementById('file-words-wrap').classList.add('hidden');
  }
  // Reset AI panels when new transcript arrives
  ['summarize','translate'].forEach(k => {
    document.getElementById(`panel-${k}`).classList.remove('open');
    document.getElementById(`${k}-result`).classList.add('hidden');
    document.getElementById(`${k}-error`).classList.add('hidden');
  });
  document.getElementById('file-result').classList.remove('hidden');
  // Invalidate history cache so next open shows new record
  historyLoaded = false;
}
function setLoading(on, label) {
  const btn = document.getElementById('transcribe-btn');
  btn.disabled = on;
  document.getElementById('transcribe-btn-label').textContent = on ? label : '🎤 Chuyển thành văn bản';
  document.getElementById('transcribe-spinner').classList.toggle('hidden', !on);
}
function showFileError(msg) {
  document.getElementById('file-error').textContent = '⚠️ ' + msg;
  document.getElementById('file-error').classList.remove('hidden');
}
function hideResultError() {
  document.getElementById('file-result').classList.add('hidden');
  document.getElementById('file-error').classList.add('hidden');
}
function toggleWords() { document.getElementById('file-words').classList.toggle('hidden'); }

// ── Post-process panel toggle ─────────────────────────────────────────────
function togglePanel(key) {
  const panel = document.getElementById(`panel-${key}`);
  const isOpen = panel.classList.contains('open');
  // Close all panels first
  ['summarize','translate'].forEach(k => document.getElementById(`panel-${k}`).classList.remove('open'));
  if (!isOpen) panel.classList.add('open');
}

// ── Summarize ─────────────────────────────────────────────────────────────
async function doSummarize() {
  const text = document.getElementById('file-transcript-text').textContent.trim();
  if (!text || text === "(không có kết quả)") return;
  if (getRemainingCredits() < 2) {
    document.getElementById('summarize-error').textContent = '⚠️ Không đủ credits (cần 2).';
    document.getElementById('summarize-error').classList.remove('hidden'); return;
  }
  const btn = document.getElementById('summarize-btn');
  btn.disabled = true;
  document.getElementById('summarize-btn-label').textContent = 'Đang xử lý...';
  document.getElementById('summarize-spinner').classList.remove('hidden');
  document.getElementById('summarize-error').classList.add('hidden');
  document.getElementById('summarize-result').classList.add('hidden');

  try {
    const fd = new FormData();
    fd.append('text',     text);
    fd.append('language', document.getElementById('summarize-language').value);
    const res  = await fetch(SUMMARIZE_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lỗi server');
    document.getElementById('summarize-text').textContent = data.result || '';
    document.getElementById('summarize-result').classList.remove('hidden');
    const used = parseInt(res.headers.get('X-Credits-Used') || '2');
    if (used > 0) deductLocal(used);
  } catch(e) {
    document.getElementById('summarize-error').textContent = '⚠️ ' + e.message;
    document.getElementById('summarize-error').classList.remove('hidden');
  } finally {
    btn.disabled = false;
    document.getElementById('summarize-btn-label').textContent = 'Tóm tắt';
    document.getElementById('summarize-spinner').classList.add('hidden');
  }
}

// ── Translate ─────────────────────────────────────────────────────────────
async function doTranslate() {
  const text = document.getElementById('file-transcript-text').textContent.trim();
  if (!text || text === "(không có kết quả)") return;
  if (getRemainingCredits() < 2) {
    document.getElementById('translate-error').textContent = '⚠️ Không đủ credits (cần 2).';
    document.getElementById('translate-error').classList.remove('hidden'); return;
  }
  const btn = document.getElementById('translate-btn');
  btn.disabled = true;
  document.getElementById('translate-btn-label').textContent = 'Đang dịch...';
  document.getElementById('translate-spinner').classList.remove('hidden');
  document.getElementById('translate-error').classList.add('hidden');
  document.getElementById('translate-result').classList.add('hidden');

  try {
    const fd = new FormData();
    fd.append('text',            text);
    fd.append('target_language', document.getElementById('translate-language').value);
    const res  = await fetch(TRANSLATE_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lỗi server');
    document.getElementById('translate-text').textContent = data.result || '';
    document.getElementById('translate-result').classList.remove('hidden');
    const used = parseInt(res.headers.get('X-Credits-Used') || '2');
    if (used > 0) deductLocal(used);
  } catch(e) {
    document.getElementById('translate-error').textContent = '⚠️ ' + e.message;
    document.getElementById('translate-error').classList.remove('hidden');
  } finally {
    btn.disabled = false;
    document.getElementById('translate-btn-label').textContent = 'Dịch';
    document.getElementById('translate-spinner').classList.add('hidden');
  }
}

// ── Realtime Mic ──────────────────────────────────────────────────────────
let mediaRecorder=null, micStream=null, micTimer=null;
let micSeconds=0, chunkCount=0, audioCtx=null, analyser=null, volInterval=null;
let isMicRecording=false;
async function toggleMic() { isMicRecording ? stopMic() : await startMic(); }
async function startMic() {
  if (getRemainingCredits() < 1) { document.getElementById('mic-no-credit').classList.remove('hidden'); return; }
  document.getElementById('mic-no-credit').classList.add('hidden');
  try { micStream = await navigator.mediaDevices.getUserMedia({ audio:true, video:false }); }
  catch(e) { alert("Không thể truy cập microphone: " + e.message); return; }
  audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  analyser = audioCtx.createAnalyser();
  audioCtx.createMediaStreamSource(micStream).connect(analyser);
  analyser.fftSize = 256;
  const buf = new Uint8Array(analyser.frequencyBinCount);
  volInterval = setInterval(() => {
    analyser.getByteFrequencyData(buf);
    document.getElementById('vol-bar').style.width = Math.min(buf.reduce((a,b)=>a+b,0)/buf.length*2,100)+'%';
  }, 80);
  mediaRecorder = new MediaRecorder(micStream, { mimeType: getSupportedMimeType() });
  mediaRecorder.ondataavailable = e => { if (e.data.size > 0) sendChunk(e.data); };
  mediaRecorder.start(5000);
  micSeconds = 0;
  document.getElementById('mic-timer').classList.remove('hidden');
  micTimer = setInterval(() => {
    micSeconds++;
    document.getElementById('mic-timer').textContent =
      `${String(Math.floor(micSeconds/60)).padStart(2,'0')}:${String(micSeconds%60).padStart(2,'0')}`;
  }, 1000);
  isMicRecording = true;
  const btn = document.getElementById('mic-btn');
  btn.textContent = '⏹';
  btn.classList.add('mic-recording','bg-red-100','border-red-400');
  btn.classList.remove('bg-slate-100','border-slate-200');
  document.getElementById('mic-status').textContent = '🔴 Đang ghi âm... Click để dừng';
  const txtEl = document.getElementById('mic-transcript-text');
  if (txtEl.querySelector('span.text-slate-400')) txtEl.innerHTML = '';
}
function stopMic() {
  if (mediaRecorder?.state !== 'inactive') mediaRecorder?.stop();
  micStream?.getTracks().forEach(t => t.stop());
  clearInterval(micTimer); clearInterval(volInterval); audioCtx?.close();
  isMicRecording = false;
  document.getElementById('vol-bar').style.width = '0%';
  document.getElementById('mic-timer').classList.add('hidden');
  const btn = document.getElementById('mic-btn');
  btn.textContent = '🎙️';
  btn.classList.remove('mic-recording','bg-red-100','border-red-400');
  btn.classList.add('bg-slate-100','border-slate-200');
  document.getElementById('mic-status').textContent = 'Click để bắt đầu ghi âm';
  // Auto-save mic transcript if there's content
  const txtEl = document.getElementById('mic-transcript-text');
  const text = txtEl.innerText?.trim() || '';
  const hasPlaceholder = txtEl.querySelector('span.text-slate-400') !== null;
  if (!hasPlaceholder && text.length > 0 && chunkCount > 0) {
    saveMicTranscript(text);
  }
}
async function saveMicTranscript(text) {
  try {
    const fd = new FormData();
    fd.append('text',          text);
    fd.append('language_code', document.getElementById('mic-language').value);
    fd.append('duration_secs', micSeconds.toString());
    fd.append('credits_used',  chunkCount.toString());
    await fetch(SAVE_MIC_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    historyLoaded = false; // force reload next time history tab opens
  } catch(e) { /* silent */ }
}
async function sendChunk(blob) {
  if (getRemainingCredits() < 1) { stopMic(); document.getElementById('mic-no-credit').classList.remove('hidden'); return; }
  document.getElementById('mic-sending-badge').classList.remove('hidden');
  const fd = new FormData();
  fd.append('chunk', blob, 'chunk.webm');
  fd.append('model', document.getElementById('mic-model').value);
  fd.append('language_code', document.getElementById('mic-language').value);
  try {
    const res  = await fetch(CHUNK_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (res.ok && data.text?.trim()) {
      const el = document.getElementById('mic-transcript-text');
      el.textContent += (el.textContent ? ' ' : '') + data.text.trim();
      el.scrollTop = el.scrollHeight;
      chunkCount++;
      const counter = document.getElementById('chunk-counter');
      counter.textContent = `${chunkCount} đoạn đã xử lý`;
      counter.classList.remove('hidden');
      const used = parseInt(res.headers.get('X-Credits-Used') || '1');
      deductLocal(used);
      document.getElementById('mic-credit-remaining').textContent = getRemainingCredits();
      if (getRemainingCredits() < 1 && isMicRecording) { stopMic(); document.getElementById('mic-no-credit').classList.remove('hidden'); }
    } else if (!res.ok && data.insufficient_credits) {
      stopMic(); document.getElementById('mic-no-credit').classList.remove('hidden');
    }
  } catch(e) { console.warn('STT chunk error:', e); }
  finally { document.getElementById('mic-sending-badge').classList.add('hidden'); }
}
function clearMicTranscript() {
  document.getElementById('mic-transcript-text').innerHTML =
    '<span class="text-slate-400 text-[12px]">Transcript sẽ xuất hiện ở đây sau mỗi 5 giây ghi âm...</span>';
  chunkCount = 0;
  document.getElementById('chunk-counter').textContent = '';
  document.getElementById('chunk-counter').classList.add('hidden');
  document.getElementById('mic-no-credit').classList.add('hidden');
}

// ── Utils ─────────────────────────────────────────────────────────────────
function getSupportedMimeType() {
  return ['audio/webm;codecs=opus','audio/webm','audio/ogg;codecs=opus','audio/mp4']
    .find(t => MediaRecorder.isTypeSupported(t)) || '';
}
function copyText(elId) {
  const el = document.getElementById(elId);
  navigator.clipboard.writeText(el.textContent).then(() => {
    const btn = event.target; const orig = btn.textContent;
    btn.textContent = '✅ Đã sao chép'; setTimeout(() => btn.textContent = orig, 1500);
  });
}
function downloadText(elId, name) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([document.getElementById(elId).textContent], { type:'text/plain' }));
  a.download = `${name}-${Date.now()}.txt`; a.click();
}
function formatBytes(b) {
  return b < 1024 ? b+' B' : b < 1048576 ? (b/1024).toFixed(1)+' KB' : (b/1048576).toFixed(1)+' MB';
}
function fmtTime(sec) {
  if (sec == null) return '—';
  return `${Math.floor(sec/60)}:${(sec%60).toFixed(1).padStart(4,'0')}`;
}
function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
// ── History ───────────────────────────────────────────────────────────────
async function loadHistory(force = false) {
  if (historyLoaded && !force) return;
  const container = document.getElementById('history-list');
  container.innerHTML = '<div class="text-center py-10 text-slate-400 text-[13px]">Đang tải...</div>';
  try {
    const res  = await fetch(HISTORY_URL, { headers:{'X-CSRF-Token':CSRF} });
    const data = await res.json();
    historyLoaded = true;
    renderHistory(data);
  } catch(e) {
    container.innerHTML = '<div class="text-center py-10 text-red-400 text-[12px]">Lỗi tải lịch sử. Thử lại.</div>';
  }
}

