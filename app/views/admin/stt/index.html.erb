var LANG_OPTS_SUM = `<option value="vi">🇻🇳 Tiếng Việt</option><option value="en">🇺🇸 English</option><option value="zh">🇨🇳 中文</option><option value="ja">🇯🇵 日本語</option><option value="ko">🇰🇷 한국어</option><option value="fr">🇫🇷 Français</option><option value="de">🇩🇪 Deutsch</option><option value="es">🇪🇸 Español</option><option value="th">🇹🇭 Thai</option><option value="id">🇮🇩 Indonesian</option>`;
var LANG_OPTS_TR  = `<option value="en">🇺🇸 English</option><option value="vi">🇻🇳 Tiếng Việt</option><option value="zh">🇨🇳 中文</option><option value="ja">🇯🇵 日本語</option><option value="ko">🇰🇷 한국어</option><option value="fr">🇫🇷 Français</option><option value="de">🇩🇪 Deutsch</option><option value="es">🇪🇸 Español</option><option value="th">🇹🇭 Thai</option><option value="id">🇮🇩 Indonesian</option>`;

function _aiModalShowPh(icon, text) {
  document.getElementById('ai-modal-ph-icon').textContent = icon;
  document.getElementById('ai-modal-ph-text').textContent = text;
  document.getElementById('ai-modal-ph').style.display    = '';
