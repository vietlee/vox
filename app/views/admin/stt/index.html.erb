async function doHistSummarize(id) {
  const textEl = document.getElementById(`hist-text-${id}`);
  const text   = textEl.dataset.full || textEl.textContent;
  if (!text?.trim()) return;
  if (getRemainingCredits() < 2) { showHistErr(id, 'sum', '⚠️ ' + I18N.ai_no_credits); return; }
  setHistBtn(id, 'sum', true);
  clearHistErr(id, 'sum');
  document.getElementById(`hist-sum-result-${id}`).classList.add('hidden');
  try {
    const fd = new FormData();
    fd.append('text',     text);
    fd.append('language', document.getElementById(`hist-sum-lang-${id}`).value);
    const res  = await fetch(SUMMARIZE_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lỗi server');
    setMdContent(`hist-sum-text-${id}`, data.result || '');
    document.getElementById(`hist-sum-text-${id}`).dataset.plain = data.result || '';
    document.getElementById(`hist-sum-result-${id}`).classList.remove('hidden');
    const used = parseInt(res.headers.get('X-Credits-Used') || '2');
    if (used > 0) deductLocal(used);
  } catch(e) { showHistErr(id, 'sum', '⚠️ ' + e.message); }
  finally     { setHistBtn(id, 'sum', false); }
}
