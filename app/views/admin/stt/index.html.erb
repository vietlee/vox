<% if @has_stt %>
<script>
// ── URL constants ─────────────────────────────────────────────────────────
var TRANSCRIBE_URL     = "<%= stt_transcribe_path %>";
var TRANSCRIBE_URL_URL = "<%= stt_transcribe_url_path %>";
var CHUNK_URL          = "<%= stt_transcribe_chunk_path %>";
var SUMMARIZE_URL      = "<%= stt_summarize_path %>";
var TRANSLATE_URL      = "<%= stt_translate_path %>";
var HISTORY_URL        = "<%= stt_history_path %>";
var SAVE_MIC_URL       = "<%= stt_save_mic_path %>";
var DELETE_HISTORY_URL = "<%= stt_destroy_history_path(id: '__ID__') %>";
var CSRF               = document.querySelector('meta[name="csrf-token"]').content;
var SECS_PER_CREDIT    = 60;

// ── I18n strings used in JS ───────────────────────────────────────────────
var I18N = {
  btn_transcribe:    "<%= j t('stt.btn_transcribe') %>",
  btn_uploading:     "<%= j t('stt.btn_uploading') %>",
  btn_downloading:   "<%= j t('stt.btn_downloading') %>",
  mic_start:         "<%= j t('stt.mic_start_hint') %>",
  mic_recording:     "<%= j t('stt.mic_recording') %>",
  ts_show:           "<%= j t('stt.timestamps_show') %>",
  ts_hide:           "<%= j t('stt.timestamps_hide') %>",
  ai_sum_lbl:        "<%= j t('stt.ai_summarize').gsub(/^\S+\s*/, '') %>",
  ai_tr_lbl:         "<%= j t('stt.ai_translate').gsub(/^\S+\s*/, '') %>",
  ai_processing:     "<%= j t('stt.ai_processing') %>",
  ai_no_credits:     "<%= j t('stt.ai_no_credits') %>",
  mic_chunks:        "<%= j t('stt.mic_chunks') %>",
  hist_view:         "<%= j t('stt.history_view') %>",
  hist_collapse:     "<%= j t('stt.history_collapse') %>",
  hist_delete:       "<%= j t('stt.history_delete') %>",
  hist_del_confirm:  "<%= j t('stt.history_delete_confirm') %>",
  hist_content:      "<%= j t('stt.history_content') %>",
  hist_empty_title:  "<%= j t('stt.history_empty_title') %>",
  hist_empty_desc:   "<%= j t('stt.history_empty_desc') %>",
  hist_error:        "<%= j t('stt.history_error') %>",
  hist_ai_credits:   "<%= j t('stt.ai_credits') %>",
  hist_ai_sum:       "<%= j t('stt.ai_summarize') %>",
  hist_ai_tr:        "<%= j t('stt.ai_translate') %>",
  hist_sum_lang:     "<%= j t('stt.ai_sum_lang') %>",
  hist_tr_lang:      "<%= j t('stt.ai_tr_lang') %>",
  hist_sum_result:   "<%= j t('stt.ai_sum_result') %>",
  hist_tr_result:    "<%= j t('stt.ai_tr_result') %>",
  hist_copy:         "<%= j t('stt.ai_copy') %>",
  hist_download:     "⬇ <%= j t('stt.download_btn') %>",
  hist_ai_title:     "<%= j t('stt.ai_title') %>",
  hist_load_more:    "<%= j t('stt.history_load_more') %>",
  ai_sum_hint:       "<%= j t('stt.ai_sum_hint') %>",
  ai_tr_hint:        "<%= j t('stt.ai_tr_hint') %>",
};

// ── TTS for speaker segments ──────────────────────────────────────────────
var HAS_TTS      = <%= @has_tts ? 'true' : 'false' %>;
var TTS_PATH     = "<%= tts_generate_path %>";
// Pre-selected diverse voices: female/male alternating, different accents
// ElevenLabs premade voice IDs (always available on any API key)
var SPEAKER_VOICES = [
  "EXAVITQu4vr4xnSDxMaL",  // Rachel — female, American
  "TxGEqnHWrfWFTfGW9XjX",  // Josh   — male,   American
  "AZnzlk1XvdvUeBnXmlld",  // Domi   — female, American
  "VR6AewLTigWG4xSOukaG",  // Arnold — male,   American
  "pNInz6obpgDQGcFmaJgB",  // Adam   — male,   American
  "MF3mGyEYCl7XYWbV9V6O",  // Elli   — female, American
  "jBpfuIE2acCO8z3wKNLl",  // Gigi   — female, American
  "t0jbNlBVZ17f02VDIeMI",  // Jessie — male,   American
];
var _ttsAudio   = null;   // currently playing Audio object
var _ttsPlayBtn = null;   // button that triggered current playback

function playSpeakerSegment(btn, text, speakerIdx) {
  // If same button clicked again → stop playback
  if (_ttsPlayBtn === btn && _ttsAudio) {
    _ttsAudio.pause();
    _ttsAudio = null;
    _resetPlayBtn(btn);
    _ttsPlayBtn = null;
    return;
  }
  // Stop any existing playback
  if (_ttsAudio) { _ttsAudio.pause(); _ttsAudio = null; }
  if (_ttsPlayBtn && _ttsPlayBtn !== btn) _resetPlayBtn(_ttsPlayBtn);

  var voiceId = SPEAKER_VOICES[speakerIdx % SPEAKER_VOICES.length];
  _ttsPlayBtn = btn;
  btn.disabled = true;
  btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" fill="none" viewBox="0 0 24 24">'
    + '<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>'
    + '<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>'
    + '</svg>';

  var fd = new FormData();
  fd.append('text',     text);
  fd.append('voice_id', voiceId);
  fd.append('model',    'eleven_turbo_v2_5');

  fetch(TTS_PATH, { method: 'POST', headers: { 'X-CSRF-Token': CSRF }, body: fd })
    .then(function(res) {
      if (!res.ok) return res.json().then(function(j){ throw new Error(j.error || 'TTS thất bại'); });
      return res.blob();
    })
    .then(function(blob) {
      var url = URL.createObjectURL(blob);
      _ttsAudio = new Audio(url);
      // Show stop icon while playing
      btn.disabled = false;
      btn.innerHTML = '<svg class="w-3.5 h-3.5 text-rose-500" fill="currentColor" viewBox="0 0 24 24">'
        + '<rect x="6" y="6" width="12" height="12" rx="1.5"/></svg>';
      _ttsAudio.onended = function() {
        URL.revokeObjectURL(url);
        _resetPlayBtn(btn);
        _ttsAudio = null;
        _ttsPlayBtn = null;
      };
      _ttsAudio.play();
    })
    .catch(function(e) {
      _resetPlayBtn(btn);
      _ttsAudio = null;
      _ttsPlayBtn = null;
      btn.title = e.message;
      setTimeout(function(){ btn.title = 'Nghe'; }, 3000);
    });
}
function _resetPlayBtn(btn) {
  btn.disabled = false;
  btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">'
    + '<path d="M8 5v14l11-7z"/></svg>';
}

// ── Diarize → auto-enable word timestamps ─────────────────────────────────
// Speaker diarization requires word-level timestamps to build speaker segments.
// Automatically lock the timestamps select to "word" when diarize is checked.
function syncDiarizeTimestamps(checked) {
  var tsSelect = document.getElementById('file-timestamps');
  if (checked) {
    tsSelect.value = 'word';
    tsSelect.disabled = true;
    tsSelect.title = 'Word timestamps bắt buộc khi bật nhận diện người nói';
  } else {
    tsSelect.disabled = false;
    tsSelect.title = '';
  }
}
document.getElementById('file-diarize').addEventListener('change', function() {
  syncDiarizeTimestamps(this.checked);
});
// Also apply on page load — browser may restore checkbox state from previous session
syncDiarizeTimestamps(document.getElementById('file-diarize').checked);

// ── Credits ───────────────────────────────────────────────────────────────
function getRemainingCredits() {
  return typeof window.__currentCredits === "number"
    ? window.__currentCredits
    : parseInt(document.getElementById('mic-credit-remaining')?.textContent || "0") || 0;
}
function deductLocal(amount) {
  if (typeof window.deductDisplayCredits === "function") window.deductDisplayCredits(amount);
  const el = document.getElementById('mic-credit-remaining');
  if (el) el.textContent = Math.max(0, getRemainingCredits() - amount);
}
function creditsForSecs(secs) {
  return Math.max(Math.ceil(secs > 0 ? secs / SECS_PER_CREDIT : 1), 1);
}

// ── History badge helpers ─────────────────────────────────────────────────
var historyLoaded = false;
var histPage = 1, histTotal = 0, histHasMore = false;

function _histBadgeSync() {
  // Keep histTotal in sync with the server-rendered initial value on first load
  if (histTotal === 0) {
    const badge = document.getElementById('history-count-badge');
    histTotal = parseInt(badge.textContent) || 0;
  }
}
function bumpHistoryBadge(delta = 1) {
  _histBadgeSync();
  histTotal = Math.max(0, histTotal + delta);
  const badge = document.getElementById('history-count-badge');
  badge.textContent = histTotal;
  badge.classList.toggle('hidden', histTotal === 0);
}
function switchMainTab(tab, pushHash = true) {
  ['file','mic','history'].forEach(t => {
    document.getElementById(`main-panel-${t}`).classList.toggle('hidden', t !== tab);
    document.getElementById(`main-tab-${t}`).classList.toggle('active', t === tab);
  });
  if (tab === 'history' && !historyLoaded) loadHistory();
  if (pushHash) history.replaceState(null, '', '#' + tab);
}
// Restore tab from URL hash on load
(function() {
  const tab = window.location.hash.replace('#','');
  if (['file','mic','history'].includes(tab)) switchMainTab(tab, false);
})();

// ── Source sub-tabs (File | URL) ──────────────────────────────────────────
var activeSrcTab = 'file';
function switchSrcTab(tab) {
  activeSrcTab = tab;
  ['file','url'].forEach(t => {
    document.getElementById(`src-panel-${t}`).classList.toggle('hidden', t !== tab);
    document.getElementById(`src-tab-${t}`).classList.toggle('active', t === tab);
  });
  document.getElementById('file-result').classList.add('hidden');
  document.getElementById('file-empty-state').classList.remove('hidden');
  document.getElementById('file-error').classList.add('hidden');
  hideCreditWarning();
  checkTranscribeButton();
}

// ── File Upload ───────────────────────────────────────────────────────────
var selectedFile = null, fileDurationSecs = 0;

function handleFileSelect(input) { if (input.files[0]) setFile(input.files[0]); }
function handleFileDrop(e) {
  e.preventDefault();
  document.getElementById('drop-zone').classList.remove('drop-zone-hover');
  if (e.dataTransfer.files[0]) setFile(e.dataTransfer.files[0]);
}
function setFile(file) {
  selectedFile = file; fileDurationSecs = 0;
  document.getElementById('drop-zone').classList.add('hidden');
  document.getElementById('file-preview').classList.remove('hidden');
  document.getElementById('file-name').textContent = file.name;
  document.getElementById('file-size').textContent = formatBytes(file.size);
  document.getElementById('file-credit-info').classList.add('hidden');
  hideResultError(); hideCreditWarning();

  const isVid = file.type.startsWith('video/') || /\.(mp4|mkv|avi|mov|webm)$/i.test(file.name);
  const media = document.createElement(isVid ? 'video' : 'audio');
  media.preload = 'metadata';
  const url = URL.createObjectURL(file);
  media.src = url;
  media.onloadedmetadata = () => {
    URL.revokeObjectURL(url);
    const dur = media.duration;
    if (dur && isFinite(dur)) {
      fileDurationSecs = dur;
      const credits = creditsForSecs(dur);
      const mins = Math.floor(dur / 60), secs = Math.round(dur % 60);
      const el = document.getElementById('file-credit-estimate');
      el.textContent = `${credits} credit${credits > 1 ? 's' : ''}`;
      el.style.color = credits > getRemainingCredits() ? '#dc2626' : '#4f46e5';
      document.getElementById('file-duration-text').textContent = `${mins}:${String(secs).padStart(2,'0')} phút`;
      document.getElementById('file-credit-info').classList.remove('hidden');
    }
    checkTranscribeButton();
  };
  media.onerror = () => { URL.revokeObjectURL(url); checkTranscribeButton(); };
}
function clearFile() {
  selectedFile = null; fileDurationSecs = 0;
  document.getElementById('file-input').value = '';
  document.getElementById('drop-zone').classList.remove('hidden');
  document.getElementById('file-preview').classList.add('hidden');
  document.getElementById('file-credit-info').classList.add('hidden');
  hideResultError(); hideCreditWarning(); checkTranscribeButton();
}
function clearUrl() {
  document.getElementById('url-input').value = '';
  hideResultError(); hideCreditWarning(); checkTranscribeButton();
}

// ── Credit guard ──────────────────────────────────────────────────────────
function checkTranscribeButton() {
  const btn = document.getElementById('transcribe-btn');
  const rem = getRemainingCredits();
  if (activeSrcTab === 'file' && selectedFile && fileDurationSecs > 0) {
    const need = creditsForSecs(fileDurationSecs);
    if (need > rem) { showCreditWarning(need, rem); btn.disabled = true; return; }
  }
  if (activeSrcTab === 'url' && rem < 1) { showCreditWarning(1, 0); btn.disabled = true; return; }
  hideCreditWarning(); btn.disabled = false;
}
function showCreditWarning(need, rem) {
  const text = `⚠️ Cần ${need} credit nhưng bạn chỉ còn ${rem} credit. Vui lòng nạp thêm hoặc chọn file ngắn hơn.`;
  document.getElementById('stt-credit-warning-text').textContent = text;
  document.getElementById('stt-credit-warning').classList.remove('hidden');
}
function hideCreditWarning() {
  document.getElementById('stt-credit-warning')?.classList.add('hidden');
  const txt = document.getElementById('stt-credit-warning-text');
  if (txt) txt.textContent = '';
}

// ── Transcribe ────────────────────────────────────────────────────────────
async function transcribeSource() {
  activeSrcTab === 'file' ? await transcribeFile() : await transcribeUrl();
}
async function transcribeFile() {
  if (!selectedFile) { showFileError("Vui lòng chọn file audio/video."); return; }
  if (fileDurationSecs > 0 && creditsForSecs(fileDurationSecs) > getRemainingCredits()) {
    showCreditWarning(creditsForSecs(fileDurationSecs), getRemainingCredits()); return;
  }
  setLoading(true, I18N.btn_uploading);
  hideResultError();
  const fd = new FormData();
  fd.append('audio_file',    selectedFile);
  fd.append('duration_secs', fileDurationSecs > 0 ? fileDurationSecs.toFixed(1) : '0');
  fd.append('model',         document.getElementById('file-model').value);
  fd.append('language_code', document.getElementById('file-language').value);
  fd.append('timestamps',    document.getElementById('file-timestamps').value);
  fd.append('diarize',       document.getElementById('file-diarize').checked ? 'true' : 'false');
  await doTranscribe(TRANSCRIBE_URL, fd);
}
async function transcribeUrl() {
  const url = document.getElementById('url-input').value.trim();
  if (!url) { showFileError("Vui lòng nhập URL."); return; }
  if (getRemainingCredits() < 1) { showCreditWarning(1, 0); return; }
  setLoading(true, I18N.btn_downloading);
  hideResultError();
  const fd = new FormData();
  fd.append('url',           url);
  fd.append('model',         document.getElementById('file-model').value);
  fd.append('language_code', document.getElementById('file-language').value);
  fd.append('timestamps',    document.getElementById('file-timestamps').value);
  fd.append('diarize',       document.getElementById('file-diarize').checked ? 'true' : 'false');
  await doTranscribe(TRANSCRIBE_URL_URL, fd);
}
// JS-side timeout: 11 min — slightly longer than server STT_READ_TIMEOUT (600s) + upload buffer.
// Ensures the user gets a friendly message instead of a silent browser-level connection drop.
var TRANSCRIBE_TIMEOUT_MS = 660000;

async function doTranscribe(endpoint, fd) {
  const ctrl = new AbortController();
  const tid  = setTimeout(() => ctrl.abort(), TRANSCRIBE_TIMEOUT_MS);
  try {
    const res  = await fetch(endpoint, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd, signal:ctrl.signal });
    const data = await res.json();
    if (!res.ok) {
      showFileError(data.upgrade_required ? "Gói của bạn không hỗ trợ tính năng này."
                  : data.error || "Lỗi server.");
      if (data.insufficient_credits) checkTranscribeButton();
      return;
    }
    const used = parseInt(res.headers.get("X-Credits-Used") || "0");
    if (used > 0) deductLocal(used);
    showResult(data, used);
    checkTranscribeButton();
  } catch(e) {
    if (e.name === 'AbortError') {
      showFileError("Quá thời gian xử lý (>11 phút). File quá lớn hoặc đường truyền chậm — vui lòng thử file ngắn hơn.");
    } else {
      showFileError("Không thể kết nối server. Vui lòng thử lại.");
    }
  } finally {
    clearTimeout(tid);
    setLoading(false, I18N.btn_transcribe);
  }
}
function showResult(data, used) {
  document.getElementById('file-empty-state').classList.add('hidden');
  // Always populate plain text (used by copy/download/AI even when speaker view is shown)
  document.getElementById('file-transcript-text').textContent = data.text || "(không có kết quả)";

  var lb = document.getElementById('file-lang-badge');
  if (data.language_code) { lb.textContent = '🌐 ' + data.language_code.toUpperCase(); lb.classList.remove('hidden'); }
  var cb = document.getElementById('file-credits-used-badge');
  if (used > 0) { cb.textContent = '🪙 -' + used + ' credit'; cb.classList.remove('hidden'); }

  // Prefer pre-built speaker_segments from server (already grouped).
  // Fall back to building from words array if segments not provided.
  var words    = data.words || [];
  var segments = data.speaker_segments || null;
  if (!segments && words.some(function(w){ return w.speaker_id; })) {
    segments = buildSpeakerSegments(words);
  }

  if (segments && segments.length > 0) {
    // Show diarization view by default
    var speakerIds = [...new Set(segments.map(function(s){ return s.speaker_id; }))];
    renderSpeakerView(segments, speakerIds);
    document.getElementById('speaker-count-badge').textContent = speakerIds.length + ' người nói được phát hiện';
    document.getElementById('view-toggle').classList.remove('hidden');
    document.getElementById('file-words-wrap').classList.add('hidden');
    setView('speaker');
  } else if (words.length > 0) {
    // Word timestamps without speaker diarization
    document.getElementById('file-words').innerHTML = words.map(function(w){
      return '<div>[' + fmtTime(w.start) + '–' + fmtTime(w.end) + '] <span class="text-slate-800 font-semibold">' + escHtml(w.text) + '</span></div>';
    }).join('');
    document.getElementById('file-words-wrap').classList.remove('hidden');
    document.getElementById('view-toggle').classList.add('hidden');
    setView('text');
  } else {
    document.getElementById('file-words-wrap').classList.add('hidden');
    document.getElementById('view-toggle').classList.add('hidden');
    setView('text');
  }

  closeAiModal();
  document.getElementById('file-result').classList.remove('hidden');
  historyLoaded = false;
  bumpHistoryBadge(1);
}

// ── Speaker diarization ───────────────────────────────────────────────────
// Colors chosen for maximum visual contrast between adjacent speakers.
// Each entry: dot (avatar bg), text (name label), bar (left accent border color)
var SPEAKER_COLORS = [
  { dot: 'bg-blue-500',    text: 'text-blue-600',    bar: 'border-blue-400',    bg: 'bg-blue-50'    },
  { dot: 'bg-emerald-500', text: 'text-emerald-600', bar: 'border-emerald-400', bg: 'bg-emerald-50' },
  { dot: 'bg-orange-500',  text: 'text-orange-600',  bar: 'border-orange-400',  bg: 'bg-orange-50'  },
  { dot: 'bg-violet-500',  text: 'text-violet-600',  bar: 'border-violet-400',  bg: 'bg-violet-50'  },
  { dot: 'bg-rose-500',    text: 'text-rose-600',    bar: 'border-rose-400',    bg: 'bg-rose-50'    },
  { dot: 'bg-cyan-500',    text: 'text-cyan-600',    bar: 'border-cyan-400',    bg: 'bg-cyan-50'    },
  { dot: 'bg-amber-500',   text: 'text-amber-600',   bar: 'border-amber-400',   bg: 'bg-amber-50'   },
  { dot: 'bg-pink-500',    text: 'text-pink-600',    bar: 'border-pink-400',    bg: 'bg-pink-50'    },
];
var speakerColorMap = {};

function buildSpeakerSegments(words) {
  var segments = [];
  var current = null;
  for (var i = 0; i < words.length; i++) {
    var w = words[i];
    if (!w.text || !w.text.trim()) continue;  // skip spacing/empty tokens
    var sid = w.speaker_id || 'unknown';
    if (!current || current.speaker_id !== sid) {
      if (current) segments.push(current);
      current = { speaker_id: sid, start: w.start, end: w.end, tokens: [] };
    }
    current.tokens.push(w.text);
    current.end = w.end;
  }
  if (current) segments.push(current);
  return segments;
}

// Build speaker view HTML from segments array (reused in live result + history)
function buildSpeakerViewHtml(segments) {
  // Build a local color map + speaker index map for voice assignment
  var localColorMap  = {};
  var speakerIdxMap  = {};
  var colorIdx = 0;
  segments.forEach(function(seg) {
    if (!(seg.speaker_id in localColorMap)) {
      localColorMap[seg.speaker_id] = SPEAKER_COLORS[colorIdx % SPEAKER_COLORS.length];
      speakerIdxMap[seg.speaker_id] = colorIdx;
      colorIdx++;
    }
  });
  return segments.map(function(seg) {
    var c          = localColorMap[seg.speaker_id] || SPEAKER_COLORS[0];
    var spkIdx     = speakerIdxMap[seg.speaker_id] || 0;
    var label      = seg.speaker_id.replace(/_/g, ' ').replace(/\b\w/g, function(l){ return l.toUpperCase(); });
    var initials   = label.replace('Speaker ', 'S');
    var ts         = fmtTimeShort(seg.start);
    var rawText    = (seg.tokens || []).join(' ');
    var text       = escHtml(rawText);
    var escapedForAttr = rawText.replace(/\\/g, '\\\\').replace(/'/g, "\\'").replace(/"/g, '&quot;').replace(/\n/g, ' ');
    var actionBtns = '<div class="flex-shrink-0 self-start pt-0.5 flex items-center gap-0.5 opacity-0 group-hover/seg:opacity-100 transition-opacity">'
      // TTS play button (only shown when workspace has TTS access)
      + (HAS_TTS
          ? '<button onclick="playSpeakerSegment(this, &quot;' + escapedForAttr + '&quot;, ' + spkIdx + ')"'
            + ' class="p-1 rounded text-slate-400 hover:text-slate-700 hover:bg-white/70 transition-colors border-0 bg-transparent cursor-pointer" title="Nghe">'
            + '<svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>'
            + '</button>'
          : '')
      // Copy button
      + '<button onclick="copySpeakerText(this, &quot;' + escapedForAttr + '&quot;)"'
      + ' class="p-1 rounded text-slate-400 hover:text-slate-700 hover:bg-white/70 transition-colors border-0 bg-transparent cursor-pointer" title="Copy">'
      + '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>'
      + '</button>'
      + '</div>';
    return '<div class="group/seg flex gap-3 py-3 px-3 rounded-xl ' + c.bg + ' border-l-4 ' + c.bar + '">'
      + '<div class="flex-shrink-0 pt-0.5">'
      + '<div class="w-8 h-8 rounded-full ' + c.dot + ' flex items-center justify-center text-white text-[10px] font-bold select-none shadow-sm">' + escHtml(initials) + '</div>'
      + '</div>'
      + '<div class="flex-1 min-w-0">'
      + '<div class="flex items-center gap-2 mb-1">'
      + '<span class="text-[12px] font-bold ' + c.text + '">' + escHtml(label) + '</span>'
      + '<span class="text-[11px] text-slate-400 font-mono">' + ts + '</span>'
      + '</div>'
      + '<div class="text-[13px] text-slate-700 leading-relaxed">' + text + '</div>'
      + '</div>'
      + actionBtns
      + '</div>';
  }).join('<div class="h-2"></div>');
}

function renderSpeakerView(segments, speakerIds) {
  // Keep global map in sync for setView toggle state
  speakerColorMap = {};
  speakerIds.forEach(function(sid, i) {
    speakerColorMap[sid] = SPEAKER_COLORS[i % SPEAKER_COLORS.length];
  });
  document.getElementById('file-speaker-view').innerHTML = buildSpeakerViewHtml(segments);
}

// Switch between speaker and plain text view in a history detail panel
function setHistView(id, view) {
  var sv   = document.getElementById('hist-speaker-' + id);
  var tv   = document.getElementById('hist-text-'    + id);
  var spkB = document.getElementById('hist-spk-btn-' + id);
  var txtB = document.getElementById('hist-txt-btn-' + id);
  if (!sv || !tv) return;
  var isSpeaker = (view === 'speaker');
  sv.classList.toggle('hidden', !isSpeaker);
  tv.classList.toggle('hidden',  isSpeaker);
  var activeClass   = 'px-2.5 py-0.5 text-[10px] font-semibold rounded-md transition-colors bg-white shadow-sm text-slate-800';
  var inactiveClass = 'px-2.5 py-0.5 text-[10px] font-semibold rounded-md transition-colors text-slate-500 hover:text-slate-700';
  if (spkB) spkB.className = isSpeaker  ? activeClass : inactiveClass;
  if (txtB) txtB.className = !isSpeaker ? activeClass : inactiveClass;
}

var currentView = 'text';
function setView(view) {
  currentView = view;
  var isSpeaker = (view === 'speaker');
  document.getElementById('file-speaker-view').classList.toggle('hidden', !isSpeaker);
  document.getElementById('file-transcript-text').classList.toggle('hidden', isSpeaker);
  // Words wrap: only visible in text view, and only if it already had content
  if (isSpeaker) {
    document.getElementById('file-words-wrap').classList.add('hidden');
  }
  // Active button styling
  var sbtn = document.getElementById('view-speaker-btn');
  var tbtn = document.getElementById('view-text-btn');
  if (sbtn && tbtn) {
    sbtn.className = 'px-3 py-1 text-[11px] font-semibold rounded-md transition-colors ' + (isSpeaker ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700');
    tbtn.className = 'px-3 py-1 text-[11px] font-semibold rounded-md transition-colors ' + (!isSpeaker ? 'bg-white shadow-sm text-slate-800' : 'text-slate-500 hover:text-slate-700');
  }
}

function fmtTimeShort(sec) {
  if (sec == null) return '';
  var m = Math.floor(sec / 60);
  var s = Math.floor(sec % 60);
  return m + ':' + (s < 10 ? '0' : '') + s;
}

function copySpeakerText(btn, text) {
  navigator.clipboard.writeText(text).then(function() {
    var orig = btn.innerHTML;
    btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
    btn.classList.add('opacity-100');
    setTimeout(function() { btn.innerHTML = orig; btn.classList.remove('opacity-100'); }, 1500);
  }).catch(function() {
    var orig = btn.innerHTML;
    btn.innerHTML = '✕';
    setTimeout(function() { btn.innerHTML = orig; }, 1200);
  });
}

function setLoading(on, label) {
  const btn = document.getElementById('transcribe-btn');
  btn.disabled = on;
  document.getElementById('transcribe-btn-label').textContent = on ? label : I18N.btn_transcribe;
  document.getElementById('transcribe-spinner').classList.toggle('hidden', !on);
}
function showFileError(msg) {
