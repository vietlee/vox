}
async function submitAiModal() {
  if (!aiModal.text) return;
  if (getRemainingCredits() < 2) {
    _aiModalHidePh();
    document.getElementById('ai-modal-result').classList.add('hidden');
    document.getElementById('ai-modal-error').textContent = '⚠️ ' + I18N.ai_no_credits;
    document.getElementById('ai-modal-error').classList.remove('hidden');
    return;
  }
  const submitBtn = document.getElementById('ai-modal-submit');
  const lbl       = document.getElementById('ai-modal-submit-lbl');
  const prevLbl   = lbl.textContent;
  submitBtn.disabled = true;
  lbl.textContent = I18N.ai_processing;
  document.getElementById('ai-modal-spin').classList.remove('hidden');
  document.getElementById('ai-modal-error').classList.add('hidden');
  document.getElementById('ai-modal-result').classList.add('hidden');
  // Show loading placeholder
  _aiModalShowPh('⏳', I18N.ai_processing);
  try {
    const fd  = new FormData();
    const lng = document.getElementById('ai-modal-lang').value;
    fd.append('text', aiModal.text);
    if (aiModal.mode === 'summarize') fd.append('language', lng);
    else fd.append('target_language', lng);
    const url  = aiModal.mode === 'summarize' ? SUMMARIZE_URL : TRANSLATE_URL;
    const res  = await fetch(url, { method:'POST', headers:{'X-CSRF-Token':CSRF}, body:fd });
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'Lỗi server');
    const textEl = document.getElementById('ai-modal-text');
    textEl.innerHTML     = renderMarkdown(data.result || '');
    textEl.dataset.plain = data.result || '';
    _aiModalHidePh();
    document.getElementById('ai-modal-result').classList.remove('hidden');
    const used = parseInt(res.headers.get('X-Credits-Used') || '2');
    if (used > 0) deductLocal(used);
  } catch(e) {
    _aiModalShowPh('❌', e.message);
    document.getElementById('ai-modal-error').classList.add('hidden');
  } finally {
    submitBtn.disabled = false;
    document.getElementById('ai-modal-spin').classList.add('hidden');
    lbl.textContent = prevLbl;
  }
}
