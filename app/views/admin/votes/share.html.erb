<% content_for :title, t("votes.share.title") %>
<div class="max-w-[560px]">
  <div class="flex items-center gap-3 mb-5">
    <%= render "admin/shared/back_btn" %>
    <h1 class="text-[19px] font-extrabold text-slate-900">🔗 <%= t("votes.share.title") %></h1>
  </div>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 space-y-4">
    <div>
      <label class="block text-[12px] font-semibold text-slate-500 mb-1.5"><%= t("votes.share.participant_link") %></label>
      <div class="flex gap-2">
        <input readonly value="<%= request.base_url + participate_vote_path(@vote.slug) %>"
          class="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-[12px] bg-slate-50 text-slate-700">
        <button onclick="voxCopy(this.previousElementSibling.value, this)" class="vox-copy-btn">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 11H2.5A1.5 1.5 0 0 1 1 9.5V2.5A1.5 1.5 0 0 1 2.5 1H9.5A1.5 1.5 0 0 1 11 2.5V3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span>Sao chép</span>
        </button>
      </div>
    </div>
    <div>
      <label class="block text-[12px] font-semibold text-slate-500 mb-1.5"><%= t("votes.share.presenter_link") %></label>
      <div class="flex gap-2">
        <input readonly value="<%= request.base_url + present_vote_path(@vote.slug) %>"
          class="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-[12px] bg-slate-50 text-slate-700">
        <a href="<%= present_vote_path(@vote.slug) %>" target="_blank" class="px-3 py-2 bg-indigo-50 rounded-lg text-[12px] text-indigo-700 hover:bg-indigo-100"><%= t("votes.share.open") %></a>
      </div>
    </div>
  </div>
</div>
