<% content_for :title, t("votes.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<% sub = current_workspace.active_subscription %>

<!-- ── Page header (always visible) ─────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-start justify-between mb-4">
    <div>
      <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight">🗳️ <%= t("votes.title") %></h1>
      <div class="flex items-center gap-3 mt-0.5">
        <p class="text-[12px] text-slate-500"><%= t("votes.subtitle") %></p>
        <% if sub&.max_votes %>
          <% pct = sub.votes_pct %>
          <div class="flex items-center gap-1.5">
            <div class="w-20 h-1.5 rounded-full overflow-hidden bg-slate-200">
              <div class="h-1.5 rounded-full" style="width:<%= pct %>%; background:<%= pct >= 100 ? '#f59e0b' : pct >= 75 ? '#f97316' : '#6366f1' %>;"></div>
            </div>
            <span class="text-[11px] font-semibold <%= pct >= 100 ? 'text-amber-600' : 'text-slate-500' %>">
              <%= sub.votes_used %> / <%= sub.max_votes %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
    <% if sub && !sub.within_vote_limit? %>
      <%= link_to billing_subscription_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-white border border-amber-300 hover:bg-amber-50 hover:border-amber-400 text-amber-700 transition-colors" do %>
        ⚠️ <%= t("subscription.limit_reached_short") %> · <%= t("subscription.upgrade") %>
      <% end %>
    <% else %>
      <%= link_to new_vote_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-blue-500 hover:bg-blue-600 text-white transition-colors" do %>
        + <%= t("votes.new") %>
      <% end %>
    <% end %>
  </div>
</div>

<!-- ── Card area (fills remaining height) ───────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <!-- Card header: search + filters (fixed) -->
    <div class="flex-shrink-0 flex items-center gap-2 px-4 py-3 flex-wrap border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <div class="relative w-60">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        <input id="search-input" type="text" placeholder="<%= t("votes.search_placeholder") %>"
          class="w-full pl-8 pr-3 py-1.5 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white"
          oninput="filterVotes()">
      </div>
      <select id="status-filter" onchange="filterVotes()"
        class="px-3 py-1.5 text-[12px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white text-slate-600 cursor-pointer">
        <option value=""><%= t("votes.all_statuses") %></option>
        <option value="draft"><%= t("status.draft") %></option>
        <option value="active"><%= t("status.active") %></option>
        <option value="closed"><%= t("status.closed") %></option>
      </select>
      <select id="type-filter" onchange="filterVotes()"
        class="px-3 py-1.5 text-[12px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white text-slate-600 cursor-pointer">
        <option value=""><%= t("votes.all_types") %></option>
        <option value="single_choice"><%= t("votes.type.single_choice") %></option>
        <option value="multiple_choice"><%= t("votes.type.multiple_choice") %></option>
        <option value="word_cloud"><%= t("votes.type.word_cloud") %></option>
        <option value="open_ended"><%= t("votes.type.open_ended") %></option>
        <option value="ranking"><%= t("votes.type.ranking") %></option>
        <option value="qa_upvote"><%= t("votes.type.qa_upvote") %></option>
      </select>
    </div>

    <!-- Table (scrollable) -->
    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @votes.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("votes.col_vote") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("votes.col_type") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("votes.col_status") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("votes.col_votes") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">
                <% next_sort = @sort == "desc" ? "asc" : "desc" %>
                <%= link_to votes_path(sort: next_sort, status: params[:status], type: params[:type]),
                    class: "inline-flex items-center gap-1 hover:text-indigo-600 transition-colors" do %>
                  <%= t("surveys.col_created") %>
                  <span class="text-[10px]"><%= @sort == "desc" ? "↓" : "↑" %></span>
                <% end %>
              </th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <% @votes.each do |vote| %>
              <tr class="border-b border-indigo-50 hover:bg-white/70 transition-colors vote-row" id="vote-row-<%= vote.id %>"
                  data-title="<%= vote.title.downcase %>"
                  data-status="<%= vote.status %>"
                  data-type="<%= vote.vote_type %>">
                <td class="px-4 py-3">
                  <%= link_to vote_path(vote), class: "text-[13px] font-semibold text-slate-900 hover:text-indigo-600 transition-colors" do %>
                    <%= vote.title.truncate(60) %>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-[12px] text-slate-500"><%= t("votes.type.#{vote.vote_type}", default: vote.vote_type.humanize) %></td>
                <td class="px-4 py-3" id="vote-status-<%= vote.id %>"><%= vote_status_badge(vote) %></td>
                <td class="px-4 py-3 text-[13px] text-slate-700" id="vote-count-<%= vote.id %>"><%= vote.participant_count %></td>
                <td class="px-4 py-3 text-[12px] text-slate-500"><%= vote.created_at.strftime("%d/%m/%Y") %></td>
                <td class="px-4 py-3">
                  <div class="flex gap-1.5 justify-end" id="vote-actions-<%= vote.id %>">
                    <% if vote.draft? %>
                      <button onclick="openVote(<%= vote.id %>, '<%= open_vote_path(vote) %>', '<%= present_vote_path(vote) %>')"
                        class="px-2.5 py-1 text-[11px] bg-emerald-50 rounded-md text-emerald-700 hover:bg-emerald-100 cursor-pointer border-0">
                        <%= t("votes.open") %>
                      </button>
                    <% end %>
                    <% if vote.active? %>
                      <%= link_to present_vote_path(vote), class: "px-2.5 py-1 text-[11px] bg-indigo-50 rounded-md text-indigo-700 hover:bg-indigo-100", target: "_blank" do %><%= t("votes.present") %><% end %>
                      <button onclick="closeVote(<%= vote.id %>, '<%= close_vote_path(vote) %>')"
                        class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-700 hover:bg-red-100 cursor-pointer border-0">
                        <%= t("votes.close") %>
                      </button>
                    <% end %>
                    <%= link_to results_vote_path(vote), class: "px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200" do %><%= t("votes.results_btn") %><% end %>
                    <%= link_to edit_vote_path(vote), class: "px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200" do %><%= t("votes.edit_btn") %><% end %>
                    <% unless vote.active? %>
                      <button onclick="confirmDelete(<%= vote.id %>, '<%= j(vote.title) %>', '<%= vote_path(vote) %>')"
                        class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-500 hover:bg-red-100 cursor-pointer border-0">
                        <%= t("votes.delete") %>
                      </button>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
            <tr id="no-results-row" class="hidden">
              <td colspan="6" class="px-4 py-12 text-center text-[13px] text-slate-400"><%= t("votes.not_found") %></td>
            </tr>
          </tbody>
        </table>
      <% else %>
        <div class="flex flex-col items-center justify-center py-20 text-slate-400">
          <div class="text-4xl mb-3">🗳️</div>
          <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("votes.empty") %></h3>
          <p class="text-[13px] text-slate-400 mb-4"><%= t("votes.empty_desc") %></p>
          <%= link_to t("votes.create_vote"), new_vote_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-semibold bg-blue-500 text-white hover:bg-blue-600 transition-colors" %>
        </div>
      <% end %>
    </div><!-- /scrollable -->

    <!-- Pagination (fixed at bottom) -->
    <% if @pagy && @pagy.pages > 1 %>
      <div class="flex-shrink-0 flex items-center justify-between px-4 py-2.5 border-t" style="border-color:rgba(99,102,241,0.12); background:rgba(99,102,241,0.04);">
        <p class="text-[11px] text-slate-500">
          <% from = (@pagy.page - 1) * @pagy.items + 1; to = [@pagy.page * @pagy.items, @pagy.count].min %>
          <%= t("votes.showing") %> <%= from %>–<%= to %> <%= t("votes.of") %> <%= @pagy.count %>
        </p>
        <div class="flex gap-1">
          <% if @pagy.page > 1 %>
            <%= link_to votes_path(page: @pagy.page - 1, q: params[:q]),
              class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %><%= t("votes.prev") %><% end %>
          <% end %>
          <% if @pagy.page < @pagy.pages %>
            <%= link_to votes_path(page: @pagy.page + 1, q: params[:q]),
              class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %><%= t("votes.next") %><% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div><!-- /card -->
</div><!-- /card area -->

<!-- Delete confirm modal -->
<div id="delete-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="document.getElementById('delete-modal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600 text-[18px]">🗑</div>
      <div>
        <p class="text-[15px] font-bold text-slate-800"><%= t("votes.delete_confirm_title") %></p>
        <p class="text-[12px] text-slate-500 mt-0.5"><%= t("votes.delete_confirm_irreversible") %></p>
      </div>
    </div>
    <p class="text-[13px] text-slate-600 mb-5"><%= t("votes.delete_confirm_msg") %> <span id="delete-modal-title" class="font-semibold text-slate-800"></span>?</p>
    <div class="flex gap-2 justify-end">
      <button onclick="document.getElementById('delete-modal').classList.add('hidden')"
        class="px-4 py-2 text-[13px] font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg border-0 cursor-pointer">
        <%= t("votes.cancel") %>
      </button>
      <button id="delete-confirm-btn"
        class="px-4 py-2 text-[13px] font-semibold text-white bg-red-600 hover:bg-red-700 rounded-lg border-0 cursor-pointer">
        <%= t("votes.delete") %>
      </button>
    </div>
  </div>
  </div>
</div>

<script>
const csrf = document.querySelector('meta[name="csrf-token"]').content;

function confirmDelete(id, title, url) {
  document.getElementById('delete-modal-title').textContent = `"${title}"`;
  document.getElementById('delete-confirm-btn').onclick = () => deleteVote(id, url);
  document.getElementById('delete-modal').classList.remove('hidden');
}

async function deleteVote(id, url) {
  const res = await fetch(url, { method: 'DELETE', headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json' } });
  if (res.ok) {
    document.getElementById('delete-modal').classList.add('hidden');
    document.getElementById(`vote-row-${id}`)?.remove();
    if (!document.querySelectorAll('tr.vote-row:not(.hidden)').length)
      document.getElementById('no-results-row')?.classList.remove('hidden');
  }
}

function filterVotes() {
  const q      = document.getElementById('search-input').value.toLowerCase().trim();
  const status = document.getElementById('status-filter').value;
  const type   = document.getElementById('type-filter').value;
  let visible  = 0;
  document.querySelectorAll('tr.vote-row').forEach(row => {
    const show = (!q || row.dataset.title.includes(q)) &&
                 (!status || row.dataset.status === status) &&
                 (!type   || row.dataset.type   === type);
    row.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  document.getElementById('no-results-row')?.classList.toggle('hidden', visible > 0);
}

async function openVote(id, openUrl, presentUrl) {
  const res = await fetch(openUrl, { method: 'PATCH', headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json', 'Content-Type': 'application/json' } });
  if (!res.ok) return;
  const statusCell = document.getElementById(`vote-status-${id}`);
  if (statusCell) statusCell.innerHTML = '<span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-emerald-100 text-emerald-700"><%= t("status.active") %></span>';
  const actions = document.getElementById(`vote-actions-${id}`);
  if (actions) {
    const closeUrl = openUrl.replace('/open', '/close');
    actions.innerHTML = `
      <a href="${presentUrl}" target="_blank" class="px-2.5 py-1 text-[11px] bg-indigo-50 rounded-md text-indigo-700 hover:bg-indigo-100"><%= t("votes.present") %></a>
      <button onclick="closeVote(${id}, '${closeUrl}')" class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-700 hover:bg-red-100 cursor-pointer border-0"><%= t("votes.close") %></button>
      <a href="${openUrl.replace('/open', '/results')}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200"><%= t("votes.results_btn") %></a>
      <a href="${openUrl.replace('/open', '/edit')}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200"><%= t("votes.edit_btn") %></a>`;
  }
  window.open(presentUrl, '_blank');
}

async function closeVote(id, url) {
  const res = await fetch(url, { method: 'PATCH', headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json', 'Content-Type': 'application/json' } });
  if (!res.ok) return;
  const statusCell = document.getElementById(`vote-status-${id}`);
  if (statusCell) statusCell.innerHTML = '<span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-red-100 text-red-600"><%= t("status.closed") %></span>';
  const actions = document.getElementById(`vote-actions-${id}`);
  if (actions) {
    const openPath = url.replace('/close', '/open');
    actions.innerHTML = `
      <form action="${openPath}" method="post" style="display:inline">
        <input type="hidden" name="_method" value="patch">
        <input type="hidden" name="authenticity_token" value="${csrf}">
        <button class="px-2.5 py-1 text-[11px] bg-emerald-50 rounded-md text-emerald-700 hover:bg-emerald-100 border-0 cursor-pointer"><%= t("votes.open") %></button>
      </form>
      <a href="${url.replace('/close', '/results')}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200"><%= t("votes.results_btn") %></a>
      <a href="${url.replace('/close', '/edit')}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200"><%= t("votes.edit_btn") %></a>`;
  }
}
</script>
