<% content_for :title, "Live Votes" %>
<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900 tracking-tight">🗳️ Live Votes</h1>
    <p class="text-[13px] text-slate-500 mt-0.5">Real-time audience voting for meetings</p>
  </div>
  <%= link_to new_vote_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-indigo-600 text-white hover:bg-indigo-700" do %>
    + New Vote
  <% end %>
</div>

<div class="flex gap-3 mb-4">
  <div class="relative flex-1 max-w-sm">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
    <input id="search-input" type="text" placeholder="Tìm theo tên vote..."
      class="w-full pl-9 pr-3 py-2 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white"
      oninput="filterVotes()">
  </div>
  <select id="status-filter" onchange="filterVotes()"
    class="px-3 py-2 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white text-slate-600 cursor-pointer">
    <option value="">Tất cả trạng thái</option>
    <option value="draft">Draft</option>
    <option value="active">Active</option>
    <option value="closed">Closed</option>
  </select>
  <select id="type-filter" onchange="filterVotes()"
    class="px-3 py-2 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white text-slate-600 cursor-pointer">
    <option value="">Tất cả loại</option>
    <option value="single_choice">Một lựa chọn</option>
    <option value="multiple_choice">Nhiều lựa chọn</option>
    <option value="word_cloud">Word Cloud</option>
    <option value="open_ended">Trả lời tự do</option>
    <option value="ranking">Xếp hạng</option>
    <option value="qa_upvote">Q&A Upvote</option>
  </select>
</div>

<div class="bg-white rounded-[10px] border border-slate-200 shadow-sm overflow-hidden">
  <% if @votes.any? %>
    <table class="w-full border-collapse">
      <thead>
        <tr class="bg-slate-50 border-b border-slate-200">
          <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Vote</th>
          <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Type</th>
          <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Status</th>
          <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Votes</th>
          <th class="px-4 py-2.5"></th>
        </tr>
      </thead>
      <tbody>
        <% @votes.each do |vote| %>
          <tr class="border-b border-slate-100 hover:bg-slate-50 vote-row" id="vote-row-<%= vote.id %>"
              data-title="<%= vote.title.downcase %>"
              data-status="<%= vote.status %>"
              data-type="<%= vote.vote_type %>">
            <td class="px-4 py-3">
              <%= link_to vote_path(vote), class: "text-[13px] font-semibold text-slate-900 hover:text-indigo-600" do %>
                <%= vote.title.truncate(60) %>
              <% end %>
            </td>
            <td class="px-4 py-3 text-[12px] text-slate-500"><%= vote.vote_type.humanize %></td>
            <td class="px-4 py-3" id="vote-status-<%= vote.id %>"><%= vote_status_badge(vote) %></td>
            <td class="px-4 py-3 text-[13px] text-slate-700" id="vote-count-<%= vote.id %>"><%= vote.participant_count %></td>
            <td class="px-4 py-3">
              <div class="flex gap-1.5 justify-end" id="vote-actions-<%= vote.id %>">
                <% if vote.draft? || vote.closed? %>
                  <button onclick="openVote(<%= vote.id %>, '<%= open_vote_path(vote) %>', '<%= present_vote_path(vote) %>')"
                    class="px-2.5 py-1 text-[11px] bg-emerald-50 rounded-md text-emerald-700 hover:bg-emerald-100 cursor-pointer border-0">
                    ▶ Open
                  </button>
                <% end %>
                <% if vote.active? %>
                  <%= link_to present_vote_path(vote), class: "px-2.5 py-1 text-[11px] bg-indigo-50 rounded-md text-indigo-700 hover:bg-indigo-100", target: "_blank" do %>Present<% end %>
                  <button onclick="closeVote(<%= vote.id %>, '<%= close_vote_path(vote) %>')"
                    class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-700 hover:bg-red-100 cursor-pointer border-0">
                    ■ Close
                  </button>
                <% end %>
                <%= link_to results_vote_path(vote), class: "px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200" do %>Results<% end %>
                <%= link_to edit_vote_path(vote), class: "px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200" do %>Edit<% end %>
                <% unless vote.active? %>
                  <button onclick="confirmDelete(<%= vote.id %>, '<%= vote.title.gsub("'", "\\'") %>', '<%= vote_path(vote) %>')"
                    class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-500 hover:bg-red-100 cursor-pointer border-0">
                    Xoá
                  </button>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <tr id="no-results-row" class="hidden">
          <td colspan="5" class="px-4 py-12 text-center text-[13px] text-slate-400">Không tìm thấy vote nào phù hợp.</td>
        </tr>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-16">
      <div class="text-4xl mb-3">🗳️</div>
      <h3 class="text-[15px] font-semibold text-slate-700 mb-1">No votes yet</h3>
      <p class="text-[13px] text-slate-400 mb-4">Create live votes for your meetings and presentations</p>
      <%= link_to "Create Vote", new_vote_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-semibold bg-indigo-600 text-white hover:bg-indigo-700" %>
    </div>
  <% end %>
</div>

<!-- Delete confirm modal -->
<div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="document.getElementById('delete-modal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-2xl shadow-2xl p-6 w-full max-w-sm mx-4">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600 text-[18px]">🗑</div>
      <div>
        <p class="text-[15px] font-bold text-slate-800">Xoá vote?</p>
        <p class="text-[12px] text-slate-500 mt-0.5">Thao tác này không thể hoàn tác.</p>
      </div>
    </div>
    <p class="text-[13px] text-slate-600 mb-5">Bạn có chắc muốn xoá vote <span id="delete-modal-title" class="font-semibold text-slate-800"></span>?</p>
    <div class="flex gap-2 justify-end">
      <button onclick="document.getElementById('delete-modal').classList.add('hidden')"
        class="px-4 py-2 text-[13px] font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg border-0 cursor-pointer">
        Huỷ
      </button>
      <button id="delete-confirm-btn"
        class="px-4 py-2 text-[13px] font-semibold text-white bg-red-600 hover:bg-red-700 rounded-lg border-0 cursor-pointer">
        Xoá
      </button>
    </div>
  </div>
</div>

<script>
const csrf = document.querySelector('meta[name="csrf-token"]').content;

// ── Delete ─────────────────────────────────────────────────────────────────
function confirmDelete(id, title, url) {
  const modal = document.getElementById('delete-modal');
  document.getElementById('delete-modal-title').textContent = `"${title}"`;
  document.getElementById('delete-confirm-btn').onclick = () => deleteVote(id, url);
  modal.classList.remove('hidden');
}

async function deleteVote(id, url) {
  const res = await fetch(url, {
    method: 'DELETE',
    headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json' }
  });
  if (res.ok) {
    document.getElementById('delete-modal').classList.add('hidden');
    const row = document.getElementById(`vote-row-${id}`);
    row?.remove();
    // Show no-results if table is now empty
    const remaining = document.querySelectorAll('tr.vote-row:not(.hidden)');
    if (remaining.length === 0) {
      document.getElementById('no-results-row')?.classList.remove('hidden');
    }
  }
}

function filterVotes() {
  const q      = document.getElementById('search-input').value.toLowerCase().trim();
  const status = document.getElementById('status-filter').value;
  const type   = document.getElementById('type-filter').value;
  const rows   = document.querySelectorAll('tr.vote-row');
  let visible  = 0;

  rows.forEach(row => {
    const matchTitle  = !q      || row.dataset.title.includes(q);
    const matchStatus = !status || row.dataset.status === status;
    const matchType   = !type   || row.dataset.type   === type;
    const show = matchTitle && matchStatus && matchType;
    row.classList.toggle('hidden', !show);
    if (show) visible++;
  });

  document.getElementById('no-results-row')?.classList.toggle('hidden', visible > 0);
}

async function openVote(id, openUrl, presentUrl) {
  const res = await fetch(openUrl, {
    method: 'PATCH',
    headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json', 'Content-Type': 'application/json' }
  });
  if (!res.ok) return;

  // Update status badge
  const statusCell = document.getElementById(`vote-status-${id}`);
  if (statusCell) statusCell.innerHTML = '<span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-emerald-100 text-emerald-700">Active</span>';

  // Update actions — show Present + Close
  const actions = document.getElementById(`vote-actions-${id}`);
  if (actions) {
    const closeUrl = openUrl.replace('/open', '/close');
    const resultsUrl = openUrl.replace('/open', '/results');
    const editUrl = openUrl.replace('/open', '/edit');
    actions.innerHTML = `
      <a href="${presentUrl}" target="_blank" class="px-2.5 py-1 text-[11px] bg-indigo-50 rounded-md text-indigo-700 hover:bg-indigo-100">Present</a>
      <button onclick="closeVote(${id}, '${closeUrl}')" class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-700 hover:bg-red-100 cursor-pointer border-0">■ Close</button>
      <a href="${resultsUrl}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200">Results</a>
      <a href="${editUrl}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200">Edit</a>
    `;
  }

  // Open present view in new tab
  window.open(presentUrl, '_blank');
}

async function closeVote(id, url) {
  const res = await fetch(url, {
    method: 'PATCH',
    headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json', 'Content-Type': 'application/json' }
  });
  if (!res.ok) return;

  // Update status badge
  const statusCell = document.getElementById(`vote-status-${id}`);
  if (statusCell) statusCell.innerHTML = '<span class="px-2 py-0.5 rounded-full text-[11px] font-semibold bg-red-100 text-red-600">Closed</span>';

  // Update actions — remove Present/Close, show Open + Results
  const actions = document.getElementById(`vote-actions-${id}`);
  if (actions) {
    const openPath = url.replace('/close', '/open');
    const resultsPath = url.replace('/close', '/results');
    actions.innerHTML = `
      <form action="${openPath}" method="post" style="display:inline">
        <input type="hidden" name="_method" value="patch">
        <input type="hidden" name="authenticity_token" value="${csrf}">
        <button class="px-2.5 py-1 text-[11px] bg-emerald-50 rounded-md text-emerald-700 hover:bg-emerald-100 border-0 cursor-pointer">▶ Open</button>
      </form>
      <a href="${resultsPath}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200">Results</a>
      <a href="${url.replace('/close', '/edit')}" class="px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200">Edit</a>
    `;
  }
}
</script>
