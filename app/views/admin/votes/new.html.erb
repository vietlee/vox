<% content_for :title, t("votes.new") %>

<div class="max-w-[680px]">
  <div class="flex items-center gap-3 mb-6">
    <%= render "admin/shared/back_btn" %>
    <h1 class="text-[21px] font-extrabold text-slate-900 tracking-tight">🗳️ <%= t("votes.new") %></h1>
  </div>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with model: @vote, url: votes_path, local: true do |f| %>
      <% if @vote.errors.any? %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-[13px] text-red-700">
          <% @vote.errors.full_messages.each do |msg| %>
            <div>• <%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("votes.form.question") %> *</label>
          <%= f.text_field :title, required: true, placeholder: t("votes.form.question_placeholder"),
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("votes.form.vote_type") %></label>
            <%= f.select :vote_type,
              %w[single_choice multiple_choice].map { |k| [t("votes.type.#{k}"), k] }, {},
              class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none",
              onchange: "onTypeChange(this.value)" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("votes.form.identity") %></label>
            <%= f.select :identity_mode,
              Vote.identity_modes.keys.map { |k| [t("votes.identity.#{k}"), k] }, {},
              class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none",
              onchange: "onIdentityChange(this.value)" %>
          </div>
        </div>

        <!-- SSO provider picker — shown only when identity_mode = sso_required -->
        <div id="sso-providers-wrap" style="display:none;" class="px-4 py-3 rounded-xl border border-indigo-100 bg-indigo-50/60">
          <label class="block text-[11px] font-semibold text-slate-500 mb-2">
            <%= I18n.locale == :vi ? "Cho phép đăng nhập với" : "Allow sign in with" %>
          </label>
          <div class="flex gap-4">
            <% [["google", "🔵 Google"], ["microsoft", "🟦 Microsoft"], ["both", I18n.locale == :vi ? "✅ Cả hai" : "✅ Both"]].each do |val, lbl| %>
              <label class="flex items-center gap-1.5 text-[12px] font-semibold text-slate-600 cursor-pointer">
                <%= f.radio_button :login_providers, val, checked: val == "both", class: "accent-indigo-600" %>
                <%= lbl %>
              </label>
            <% end %>
          </div>
        </div>

        <!-- Type description card -->
        <div id="type-hint" class="rounded-lg px-4 py-3 text-[12px] leading-relaxed" style="background:#f8faff; border:1px solid #e0e7ff;">
          <span id="type-icon" class="font-bold mr-1"></span>
          <span id="type-desc"></span>
        </div>

        <!-- Next-step hint: options are added in the edit screen -->
        <div id="options-next-step-hint" class="rounded-xl px-4 py-3.5 flex items-start gap-3"
             style="background:linear-gradient(135deg,#eef2ff,#f5f3ff); border:1px solid #c7d2fe;">
          <div class="w-7 h-7 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5"
               style="background:#6366f1;">
            <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <div>
            <p class="text-[12px] font-bold text-indigo-700 mb-0.5">
              <%= I18n.locale == :vi ? "Các lựa chọn sẽ được thêm ở bước tiếp theo" : "Options will be added in the next step" %>
            </p>
            <p class="text-[11px] text-indigo-500 leading-relaxed">
              <%= I18n.locale == :vi ? "Sau khi tạo vote, bạn sẽ được chuyển đến màn hình chỉnh sửa để thêm, sắp xếp và tuỳ chỉnh từng lựa chọn." : "After creating the vote, you'll be taken to the edit screen to add and customize each option." %>
            </p>
          </div>
        </div>

        <div class="flex gap-2 pt-4 border-t border-slate-100">
          <%= f.submit t("votes.create_vote"), class: "px-5 py-2.5 bg-slate-600 text-white text-[13px] font-semibold rounded-lg hover:bg-slate-700 cursor-pointer" %>
          <%= link_to t("votes.cancel"), votes_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg hover:bg-slate-200" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
const TYPE_INFO = {
  single_choice:   { icon: '☑️',  desc: '<%= j t("votes.type_desc.single_choice") %>'   },
  multiple_choice: { icon: '✅',  desc: '<%= j t("votes.type_desc.multiple_choice") %>' },
  ranking:         { icon: '🏆',  desc: '<%= j t("votes.type_desc.ranking") %>'         },
  word_cloud:      { icon: '☁️',  desc: '<%= j t("votes.type_desc.word_cloud") %>'      },
  open_ended:      { icon: '📝',  desc: '<%= j t("votes.type_desc.open_ended") %>'      },
  qa_upvote:       { icon: '🙋',  desc: '<%= j t("votes.type_desc.qa_upvote") %>'       },
};

function onTypeChange(val) {
  const info = TYPE_INFO[val] || TYPE_INFO['single_choice'];
  document.getElementById('type-icon').textContent = info.icon + ' ';
  document.getElementById('type-desc').innerHTML = info.desc;
}

function onIdentityChange(val) {
  document.getElementById('sso-providers-wrap').style.display = val === 'sso_required' ? '' : 'none';
}

// Init on page load — use turbo:load so it fires on both Turbo navigation and hard refresh
function initNewVotePage() {
  const typeSelect = document.querySelector('select[name="vote[vote_type]"]');
  if (!typeSelect) return;
  onTypeChange(typeSelect.value || 'single_choice');
  onIdentityChange(document.querySelector('select[name="vote[identity_mode]"]')?.value || 'anonymous');
}
document.addEventListener('turbo:load', initNewVotePage);
// Fallback for non-Turbo environments
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initNewVotePage);
} else {
  initNewVotePage();
}
</script>
