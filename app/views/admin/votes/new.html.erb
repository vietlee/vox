<% content_for :title, t("votes.new") %>

<div class="max-w-[680px]">
  <h1 class="text-[21px] font-extrabold text-slate-900 tracking-tight mb-6">🗳️ <%= t("votes.new") %></h1>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with model: @vote, url: votes_path, local: true do |f| %>
      <% if @vote.errors.any? %>
        <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-[13px] text-red-700">
          <% @vote.errors.full_messages.each do |msg| %>
            <div>• <%= msg %></div>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("votes.form.question") %> *</label>
          <%= f.text_field :title, required: true, placeholder: t("votes.form.question_placeholder"),
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("votes.form.vote_type") %></label>
            <%= f.select :vote_type,
              %w[single_choice multiple_choice].map { |k| [t("votes.type.#{k}"), k] }, {},
              class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none",
              onchange: "onTypeChange(this.value)" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("votes.form.identity") %></label>
            <%= f.select :identity_mode,
              Vote.identity_modes.keys.map { |k| [t("votes.identity.#{k}"), k] }, {},
              class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
        </div>

        <!-- Type description card -->
        <div id="type-hint" class="rounded-lg px-4 py-3 text-[12px] leading-relaxed" style="background:#f8faff; border:1px solid #e0e7ff;">
          <span id="type-icon" class="font-bold mr-1"></span>
          <span id="type-desc"></span>
        </div>

        <!-- Options (hidden for word_cloud, open_ended, qa_upvote) -->
        <div id="options-wrap">
          <label class="block text-[12px] font-semibold text-slate-700 mb-2"><%= t("votes.form.options") %></label>
          <div id="options-list" class="space-y-2">
            <% 2.times do |i| %>
              <div class="flex gap-2 option-row">
                <input type="text" name="vote[vote_options_attributes][<%= i %>][label]"
                  placeholder="<%= t("votes.form.option_placeholder", n: i + 1) %>"
                  class="flex-1 px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none">
              </div>
            <% end %>
          </div>
          <button type="button" onclick="addOption()"
            class="mt-2 text-[12px] text-indigo-600 hover:text-indigo-700 font-medium"><%= t("votes.form.add_option") %></button>
        </div>

        <div class="flex gap-2 pt-4 border-t border-slate-100">
          <%= f.submit t("votes.create_vote"), class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700 cursor-pointer" %>
          <%= link_to t("votes.cancel"), votes_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg hover:bg-slate-200" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
const TYPE_INFO = {
  single_choice:   { icon: '☑️',  desc: '<%= j t("votes.type_desc.single_choice") %>',   hasOptions: true  },
  multiple_choice: { icon: '✅',  desc: '<%= j t("votes.type_desc.multiple_choice") %>', hasOptions: true  },
  ranking:         { icon: '🏆',  desc: '<%= j t("votes.type_desc.ranking") %>',         hasOptions: true  },
  word_cloud:      { icon: '☁️',  desc: '<%= j t("votes.type_desc.word_cloud") %>',      hasOptions: false },
  open_ended:      { icon: '📝',  desc: '<%= j t("votes.type_desc.open_ended") %>',      hasOptions: false },
  qa_upvote:       { icon: '🙋',  desc: '<%= j t("votes.type_desc.qa_upvote") %>',       hasOptions: false },
};

let optionIdx = 2;

function onTypeChange(val) {
  const info = TYPE_INFO[val] || TYPE_INFO['single_choice'];
  document.getElementById('type-icon').textContent = info.icon + ' ';
  document.getElementById('type-desc').innerHTML = info.desc;
  document.getElementById('options-wrap').style.display = info.hasOptions ? '' : 'none';
}

function addOption() {
  const list = document.getElementById('options-list');
  const div = document.createElement('div');
  div.className = 'flex gap-2 option-row';
  optionIdx++;
  const placeholder = "<%= j t("votes.form.option_placeholder", n: "IDX") %>".replace('IDX', optionIdx);
  div.innerHTML = `<input type="text" name="vote[vote_options_attributes][${optionIdx}][label]" placeholder="${placeholder}" class="flex-1 px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none">`;
  list.appendChild(div);
}

// Init description on page load
onTypeChange(document.querySelector('select[name="vote[vote_type]"]')?.value || 'single_choice');
</script>
