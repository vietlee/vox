<% content_for :title, @vote.title %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>
<% content_for :breadcrumb do %>
  <%= link_to t("votes.show.breadcrumb"), votes_path, class: "hover:text-slate-600" %> <span class="text-slate-300 mx-1">/</span>
  <span class="text-slate-700 font-medium"><%= @vote.title %></span>
<% end %>

<!-- ── Page header (fixed) ──────────────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-3 bg-slate-100">
<div class="flex items-start justify-between">
  <div class="flex items-start gap-3">
    <%= render "admin/shared/back_btn" %>
    <div>
      <h1 class="text-[21px] font-extrabold text-slate-900"><%= @vote.title %></h1>
      <div class="flex items-center gap-2 mt-1">
        <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold <%= @vote.active? ? 'bg-emerald-100 text-emerald-700' : @vote.draft? ? 'bg-slate-100 text-slate-500' : 'bg-red-100 text-red-700' %>">
          <%= t("status.#{@vote.status}", default: @vote.status.capitalize) %>
        </span>
        <span class="text-[12px] text-slate-400">
          <%= t("votes.type.#{@vote.vote_type}", default: @vote.vote_type.humanize) %> · <%= @vote.participant_count %> <%= t("votes.show.participants") %>
        </span>
      </div>
    </div>
  </div>
  <div class="flex gap-2">
    <% if @vote.draft? %>
      <button onclick="openVoteFromShow()" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-emerald-50 hover:text-emerald-700 hover:border-emerald-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors cursor-pointer">
        <%= t("votes.show.open_vote") %>
      </button>
      <script>
      function openVoteFromShow() {
        const win = window.open('', '_blank');
        if (win) {
          win.document.write(
            '<html><head><title>Opening…</title></head>' +
            '<body style="margin:0;background:#0a0f1e;display:flex;align-items:center;justify-content:center;height:100vh;">' +
            '<p style="color:#a5b4fc;font-family:sans-serif;font-size:18px;font-weight:700;">⏳ Đang mở vote…</p>' +
            '</body></html>'
          );
        }
        fetch('<%= open_vote_path(@vote) %>', {
          method: 'PATCH',
          headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content, 'Accept': 'application/json' }
        }).then(res => {
          if (res.ok) {
            if (win) win.location.href = '<%= present_vote_path(@vote) %>';
            window.location.reload();
          } else {
            if (win) win.close();
          }
        }).catch(() => { if (win) win.close(); });
      }
      </script>
    <% elsif @vote.active? %>
      <%= button_to close_vote_path(@vote), method: :patch, class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-red-50 hover:text-red-700 hover:border-red-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %>
        <%= t("votes.show.close_vote") %>
      <% end %>
      <%= link_to present_vote_path(@vote), target: "_blank", class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %>
        <%= t("votes.show.present") %>
      <% end %>
    <% end %>
    <% if @vote.closed? %>
      <%= link_to results_vote_path(@vote), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-indigo-50 border border-indigo-200 hover:bg-indigo-100 text-indigo-700 text-[13px] font-semibold rounded-lg transition-colors" do %>
        <%= t("votes.show.view_results") %>
      <% end %>
    <% end %>
    <%= link_to edit_vote_path(@vote), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-slate-50 hover:border-slate-300 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %>
      <%= t("votes.show.edit") %>
    <% end %>
  </div>
</div>
</div><!-- /page header -->

<!-- ── Scrollable content ────────────────────────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-y-auto px-6 pt-3 pb-6">
<div class="grid grid-cols-3 gap-4 items-start">
  <div class="col-span-2 bg-white rounded-xl border border-slate-200 p-5" style="height:100%">
    <h2 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("votes.show.options_heading") %></h2>
    <% if @vote.vote_options.any? %>
      <div class="space-y-2 max-h-72 overflow-y-auto">
        <% @vote.vote_options.order(:position).each do |opt| %>
          <div class="flex items-center justify-between py-2 border-b border-slate-50 last:border-0">
            <span class="text-[13px] text-slate-700 font-medium"><%= opt.label %></span>
            <span class="text-[12px] text-slate-400"><%= t("votes.show.votes_count", count: opt.votes_count) %></span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-[13px] text-slate-400">
        <%= t("votes.show.no_options") %>
        <%= link_to t("votes.show.no_options_link"), edit_vote_path(@vote), class: "text-indigo-500 hover:underline" %>
        <%= t("votes.show.no_options_suffix") %>
      </p>
    <% end %>
  </div>

  <div class="space-y-4">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("votes.show.settings_heading") %></h2>
      <dl class="space-y-2 text-[12px]">
        <div class="flex justify-between">
          <dt class="text-slate-400"><%= t("votes.show.setting_identity") %></dt>
          <dd class="text-slate-700"><%= t("votes.identity.#{@vote.identity_mode}", default: @vote.identity_mode.humanize) %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-slate-400"><%= t("votes.show.setting_live_results") %></dt>
          <dd class="text-slate-700"><%= @vote.show_results_live? ? t("votes.show.yes") : t("votes.show.no") %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-slate-400"><%= t("votes.show.setting_countdown") %></dt>
          <dd class="text-slate-700"><%= @vote.countdown_seconds&.positive? ? "#{@vote.countdown_seconds}s" : t("votes.show.no_countdown") %></dd>
        </div>
      </dl>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-2"><%= t("votes.show.share_heading") %></h2>
      <% _vs_full  = participate_vote_url(@vote.slug) %>
      <% _vs_short = short_url_for(_vs_full, workspace: current_workspace) rescue _vs_full %>
      <p class="text-[12px] text-slate-400 mb-2"><%= t("votes.show.public_link") %></p>
      <div class="flex gap-1 mb-1">
        <input id="vote-link" readonly value="<%= _vs_short %>"
          class="flex-1 px-2.5 py-1.5 bg-slate-50 border border-slate-200 rounded text-[11px] font-mono text-slate-600 min-w-0">
        <button onclick="voxCopy(document.getElementById('vote-link').value, this)" class="vox-copy-btn">
          <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          <span>Sao chép</span>
        </button>
      </div>
      <% if _vs_short != _vs_full %>
        <p class="text-[11px] text-slate-400 mb-2">Full: <span class="font-mono"><%= _vs_full %></span></p>
      <% else %>
        <div class="mb-3"></div>
      <% end %>
      <% if @vote.qr_code %>
        <div class="text-center">
          <img id="vote-qr-img" src="<%= qr_image_path(@vote.qr_code.token) %>" alt="QR Code" class="w-32 h-32 mx-auto rounded-lg border border-slate-100" crossorigin="anonymous">
          <p class="text-[10px] text-slate-400 mt-1"><%= t("votes.show.scans", count: @vote.qr_code.scan_count) %></p>
          <div class="flex items-center justify-center gap-2 mt-2">
            <button onclick="copyQrImage(document.getElementById('vote-qr-img'), this)"
              class="vox-copy-btn">
              <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              <span>Copy QR</span>
            </button>
            <a href="<%= qr_image_path(@vote.qr_code.token) %>" download="qr-<%= @vote.slug %>.png"
              class="inline-flex items-center gap-1 px-3 py-1 bg-slate-100 text-slate-600 text-[11px] font-semibold rounded hover:bg-slate-200">
              <%= t("votes.show.download_qr") %>
            </a>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>


<% if @responses.any? %>
  <div class="mt-5 bg-white rounded-xl border border-slate-200 overflow-hidden" style="height:100%">
    <div class="flex items-center justify-between px-5 py-3 border-b border-slate-100">
      <h2 class="text-[13px] font-bold text-slate-700">
        <%= @vote.email_required? ? t("votes.show.responses_by_email", default: "Phản hồi theo email") : t("votes.show.responses", default: "Phản hồi") %>
      </h2>
      <span class="text-[12px] text-slate-400"><%= @responses.count %> <%= t("votes.show.participants") %></span>
    </div>
    <div class="overflow-x-auto max-h-96 overflow-y-auto">
      <table class="w-full text-[12px] border-collapse">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="sticky top-0 bg-slate-50 text-left px-4 py-2.5 font-semibold text-slate-500 uppercase tracking-[0.4px] text-[11px]">
              <%= @vote.email_required? ? "Email" : t("votes.show.col_user", default: "Người dùng") %>
            </th>
            <th class="sticky top-0 bg-slate-50 text-left px-4 py-2.5 font-semibold text-slate-500 uppercase tracking-[0.4px] text-[11px]"><%= t("votes.show.col_choice", default: "Lựa chọn") %></th>
            <th class="sticky top-0 bg-slate-50 text-left px-4 py-2.5 font-semibold text-slate-500 uppercase tracking-[0.4px] text-[11px]"><%= t("votes.show.col_time", default: "Thời gian") %></th>
          </tr>
        </thead>
        <tbody>
          <% @responses.each do |r| %>
            <tr class="border-b border-slate-100 hover:bg-slate-50">
              <td class="px-4 py-3 font-medium text-slate-800">
                <% if r.respondent_email.present? %>
                  <%= r.respondent_email %>
                <% else %>
                  <span class="text-slate-400 font-mono">···<%= r.respondent_token&.last(6) %></span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-slate-700">
                <% if r.text_value.present? %>
                  <%= r.text_value.truncate(80) %>
                <% elsif r.selected_option_ids.present? %>
                  <div class="flex flex-wrap gap-1">
                    <% Array(r.selected_option_ids).each do |oid| %>
                      <% opt = @option_map[oid.to_s] %>
                      <span class="px-2 py-0.5 bg-indigo-50 text-indigo-700 rounded-full text-[11px] font-medium">
                        <%= opt&.label || "Option ##{oid}" %>
                      </span>
                    <% end %>
                  </div>
                <% else %>
                  <span class="text-slate-300">—</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-slate-400"><%= r.created_at.strftime("%d/%m %H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% end %>

</div><!-- /scrollable -->
