<% content_for :title, @vote.title %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>
<% editable = @vote.draft? %>

<%# Quill rich text editor (only loaded on this page) %>
<% if editable %>
<link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet">
<% end %>

<style>
  @keyframes slideUp {
    from { opacity:0; transform:translateY(12px) scale(0.97); }
    to   { opacity:1; transform:translateY(0)    scale(1);    }
  }
  .option-row { transition: border-color 0.1s; }

  /* ── Quill editor inside option rows ── */
  .desc-wrap .ql-toolbar.ql-snow {
    padding: 3px 6px;
    border: none;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
    border-radius: 8px 8px 0 0;
  }
  .desc-wrap .ql-container.ql-snow {
    border: none;
    font-size: 12px;
    font-family: inherit;
  }
  .desc-wrap .ql-editor {
    padding: 6px 10px;
    min-height: 56px;
    font-size: 12px;
    color: #475569;
    line-height: 1.5;
  }
  .desc-wrap .ql-editor.ql-blank::before {
    font-style: normal;
    color: #94a3b8;
    font-size: 12px;
  }
  .desc-wrap .ql-toolbar .ql-formats { margin-right: 6px; }
  .desc-wrap .ql-snow .ql-picker { font-size: 11px; }
  .desc-wrap .ql-snow.ql-toolbar button,
  .desc-wrap .ql-snow .ql-toolbar button { width: 22px; height: 22px; padding: 2px; }
</style>

<!-- ── Page header (fixed) ──────────────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-3 bg-slate-100">
  <div class="flex items-center gap-3">
    <%= render "admin/shared/back_btn" %>
    <div>
      <h1 class="text-[19px] font-extrabold text-slate-900"><%= @vote.title %></h1>
      <p class="text-[12px] text-slate-500 mt-0.5">
        <% status_badge = { "draft" => "bg-slate-100 text-slate-500", "active" => "bg-emerald-100 text-emerald-700", "closed" => "bg-red-100 text-red-600" } %>
        <span class="inline-flex px-2 py-0.5 rounded text-[11px] font-semibold <%= status_badge[@vote.status] %>"><%= t("status.#{@vote.status}").upcase %></span>
      </p>
    </div>
    <div class="ml-auto flex gap-2">
      <% if @vote.active? %>
        <%= link_to present_vote_path(@vote), target: "_blank", class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %><%= t("votes.edit.present") %><% end %>
        <%= button_to close_vote_path(@vote), method: :patch, class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-red-50 hover:text-red-700 hover:border-red-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors cursor-pointer" do %><%= t("votes.edit.close_vote") %><% end %>
      <% elsif @vote.draft? %>
        <button onclick="openVote()" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-emerald-50 hover:text-emerald-700 hover:border-emerald-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors cursor-pointer"><%= t("votes.edit.open_vote") %></button>
        <script>
        function openVote() {
          // Open a blank tab SYNCHRONOUSLY (must be in direct click handler to bypass popup blocker).
          // Then activate the vote, and only navigate the blank tab to the present URL once the vote
          // is confirmed active — so the page loads with @vote.active? = true and the close button
          // is server-rendered, avoiding the race condition of the old approach.
          const win = window.open('', '_blank');
          if (win) {
            win.document.write(
              '<html><head><title>Opening…</title></head>' +
              '<body style="margin:0;background:#0a0f1e;display:flex;align-items:center;justify-content:center;height:100vh;">' +
              '<p style="color:#a5b4fc;font-family:sans-serif;font-size:18px;font-weight:700;">⏳ Đang mở vote…</p>' +
              '</body></html>'
            );
          }
          fetch('<%= open_vote_path(@vote) %>', {
            method: 'PATCH',
            headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content, 'Accept': 'application/json' }
          }).then(res => {
            if (res.ok) {
              // Vote is now active — navigate present tab (close button will be server-rendered)
              if (win) win.location.href = '<%= present_vote_path(@vote) %>';
              window.location.href = '<%= vote_path(@vote) %>';
            } else {
              if (win) win.close();
            }
          }).catch(() => { if (win) win.close(); });
        }
        </script>
      <% elsif @vote.closed? %>
        <span class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 text-slate-400 text-[13px] font-semibold rounded-lg cursor-not-allowed select-none" title="<%= t('votes_errors.cannot_reopen_closed') %>">
          🔒 <%= t("status.closed").upcase %>
        </span>
      <% end %>
    </div>
  </div>
</div><!-- /page header -->

<!-- ── Scrollable content ────────────────────────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-y-auto px-6 pt-3 pb-6">

  <% unless editable %>
    <div class="mb-4 flex items-center gap-2 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-[13px] text-amber-700 font-medium">
      <span>⚠</span>
      <span><%= t("votes.edit.draft_only", status: @vote.status.upcase) %></span>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-5 items-start">

    <!-- Vote Settings -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 <%= 'opacity-70' unless editable %>">
      <h2 class="text-[13px] font-bold text-slate-700 mb-4"><%= t("votes.edit.settings") %></h2>
      <%= form_with model: @vote, url: vote_path(@vote), method: :patch, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("votes.edit.question_label") %></label>
            <%= f.text_field :title,
                  class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                  disabled: !editable %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("votes.edit.type_label") %></label>
              <%= f.select :vote_type,
                    %w[single_choice multiple_choice].map { |k| [t("votes.type.#{k}"), k] },
                    { selected: @vote.vote_type },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    disabled: !editable %>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("votes.edit.identity_label") %></label>
              <%= f.select :identity_mode,
                    Vote.identity_modes.keys.map { |k| [t("votes.identity.#{k}"), k] },
                    { selected: @vote.identity_mode },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    disabled: !editable,
                    onchange: editable ? "onIdentityChange(this.value)" : nil %>
            </div>
          </div>

          <%
            _cs       = @vote.countdown_seconds.to_i
            _cd_unit  = (_cs > 0 && _cs < 60) ? "seconds" : "minutes"
            _cd_value = _cd_unit == "seconds" ? _cs : (_cs == 0 ? 0 : (_cs / 60.0).ceil)
          %>
          <div class="flex items-end gap-6">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">
                <%= t("votes.edit.countdown_label") %>
              </label>
              <div class="flex items-center gap-2">
                <input type="number" name="vote[countdown_minutes]" id="countdown-value-input"
                       value="<%= _cd_value %>"
                       min="0" <%= 'max="59"' if _cd_unit == "seconds" %>
                       placeholder="0 = <%= I18n.locale == :vi ? "tắt" : "off" %>"
                       class="w-24 px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none <%= 'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable %>"
                       <%= "disabled" unless editable %>>
                <% if editable %>
                  <div class="flex rounded-lg border border-slate-200 overflow-hidden text-[12px] font-semibold select-none">
                    <label id="unit-label-minutes"
                           class="flex items-center px-3 py-2.5 cursor-pointer transition-colors"
                           style="<%= _cd_unit == 'minutes' ? 'background:#1e3a5f;color:#fff;' : 'background:#fff;color:#64748b;' %>">
                      <input type="radio" name="vote[countdown_unit]" value="minutes" class="sr-only"
                             <%= "checked" if _cd_unit == "minutes" %>
                             onchange="onCountdownUnitChange('minutes')">
                      <%= I18n.locale == :vi ? "Phút" : "Min" %>
                    </label>
                    <label id="unit-label-seconds"
                           class="flex items-center px-3 py-2.5 cursor-pointer transition-colors border-l border-slate-200"
                           style="<%= _cd_unit == 'seconds' ? 'background:#1e3a5f;color:#fff;' : 'background:#fff;color:#64748b;' %>">
                      <input type="radio" name="vote[countdown_unit]" value="seconds" class="sr-only"
                             <%= "checked" if _cd_unit == "seconds" %>
                             onchange="onCountdownUnitChange('seconds')">
                      <%= I18n.locale == :vi ? "Giây" : "Sec" %>
                    </label>
                  </div>
                <% else %>
                  <span class="text-[12px] text-slate-400">
                    <%= _cd_unit == "seconds" ? (I18n.locale == :vi ? "giây" : "sec") : (I18n.locale == :vi ? "phút" : "min") %>
                  </span>
                <% end %>
              </div>
            </div>
            <div class="flex flex-col gap-2 pb-0.5">
              <label class="flex items-center gap-2 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed opacity-60' %>">
                <%= f.check_box :show_results_live, class: "w-4 h-4 accent-indigo-600", disabled: !editable %>
                <span class="text-[12px] font-semibold text-slate-600"><%= t("votes.edit.show_results_live") %></span>
              </label>
              <label class="flex items-center gap-2 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed opacity-60' %>">
                <%= f.check_box :allow_multiple_votes, class: "w-4 h-4 accent-indigo-600", disabled: !editable %>
                <span class="text-[12px] font-semibold text-slate-600"><%= t("votes.edit.allow_multiple") %></span>
              </label>
            </div>
          </div>

          <!-- SSO provider picker — shown only when identity_mode = sso_required -->
          <div id="sso-providers-wrap" style="<%= @vote.sso_required? ? '' : 'display:none;' %>" class="px-4 py-3 rounded-xl border border-indigo-100 bg-indigo-50/60">
            <label class="block text-[11px] font-semibold text-slate-500 mb-2">
              <%= I18n.locale == :vi ? "Cho phép đăng nhập với" : "Allow sign in with" %>
            </label>
            <div class="flex gap-4">
              <% [["google", "🔵 Google"], ["microsoft", "🟦 Microsoft"], ["both", I18n.locale == :vi ? "✅ Cả hai" : "✅ Both"]].each do |val, lbl| %>
                <label class="flex items-center gap-1.5 text-[12px] font-semibold text-slate-600 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed' %>">
                  <%= f.radio_button :login_providers, val,
                        disabled: !editable,
                        checked: @vote.login_providers == val || (@vote.login_providers.blank? && val == "both"),
                        class: "accent-indigo-600" %>
                  <%= lbl %>
                </label>
              <% end %>
            </div>
          </div>
          <% if editable %>
          <script>
            function onIdentityChange(val) {
              document.getElementById('sso-providers-wrap').style.display = val === 'sso_required' ? '' : 'none';
            }
            function onCountdownUnitChange(unit) {
              const input = document.getElementById('countdown-value-input');
              const lMin  = document.getElementById('unit-label-minutes');
              const lSec  = document.getElementById('unit-label-seconds');
              if (unit === 'seconds') {
                input.setAttribute('max', '59');
                if (parseInt(input.value || '0') > 59) input.value = 59;
              } else {
                input.removeAttribute('max');
              }
              if (lMin) { lMin.style.background = unit === 'minutes' ? '#1e3a5f' : '#fff'; lMin.style.color = unit === 'minutes' ? '#fff' : '#64748b'; }
              if (lSec) { lSec.style.background = unit === 'seconds' ? '#1e3a5f' : '#fff'; lSec.style.color = unit === 'seconds' ? '#fff' : '#64748b'; }
            }
          </script>
          <% end %>

          <!-- ── Ranking / Leaderboard ────────────────────────────────── -->
          <div class="pt-1">
            <div class="flex items-center gap-2 mb-2">
              <span class="text-[12px] font-bold text-slate-700">🏆 <%= I18n.locale == :vi ? "Bảng xếp hạng sau bầu chọn" : "Post-vote Leaderboard" %></span>
              <span class="text-[10px] text-slate-400 font-normal"><%= I18n.locale == :vi ? "(hiển thị ở màn hình Present)" : "(shown on Present screen)" %></span>
            </div>

            <div class="px-3 py-3 rounded-xl border border-slate-100 bg-slate-50/70 space-y-3">
              <!-- Enable toggle -->
              <label class="flex items-center gap-2 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed opacity-60' %>">
                <input type="hidden"    name="vote[settings][ranking_enabled]" value="0">
                <input type="checkbox"  name="vote[settings][ranking_enabled]" value="1"
                       id="ranking-enabled-cb"
                       class="w-4 h-4 accent-indigo-600"
                       <%= "checked" if @vote.ranking_enabled? %>
                       <%= "disabled" unless editable %>
                       onchange="toggleRankingOptions(this.checked)">
                <span class="text-[12px] font-semibold text-slate-600">
                  <%= I18n.locale == :vi ? "Bật bảng xếp hạng" : "Enable leaderboard" %>
                </span>
              </label>

              <!-- Top N input — only shown when enabled -->
              <div id="ranking-options-wrap" style="<%= @vote.ranking_enabled? ? 'display:flex' : 'display:none' %>" class="items-center gap-3">
                <label class="text-[12px] font-semibold text-slate-600 whitespace-nowrap">
                  <%= I18n.locale == :vi ? "Hiển thị top" : "Show top" %>
                </label>
                <input type="number"
                       name="vote[settings][ranking_top]"
                       value="<%= @vote.ranking_top %>"
                       min="1" max="10"
                       class="w-16 px-2 py-1.5 border border-slate-200 rounded-lg text-[13px] text-center focus:border-indigo-500 outline-none <%= 'bg-slate-100 text-slate-400 cursor-not-allowed' unless editable %>"
                       <%= "disabled" unless editable %>>
                <span class="text-[12px] text-slate-500">
                  <%= I18n.locale == :vi ? "vị trí" : "positions" %>
                  <span class="text-slate-400">(1–10)</span>
                </span>
              </div>
            </div>
          </div>
          <% if editable %>
          <script>
            function toggleRankingOptions(checked) {
              document.getElementById('ranking-options-wrap').style.display = checked ? 'flex' : 'none';
            }
          </script>
          <% end %>

          <% if editable %>
            <div class="pt-2">
              <%= f.submit t("votes.edit.save_settings"), class: "px-5 py-2.5 bg-blue-500 text-white text-[13px] font-semibold rounded-lg hover:bg-blue-600 cursor-pointer border-0" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Vote Options -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 <%= 'opacity-70' unless editable %>">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-[13px] font-bold text-slate-700"><%= t("votes.edit.options") %></h2>
        <% if editable %>
          <span class="text-[11px] text-slate-400"><%= t("votes.edit.options_count", count: @vote.vote_options.count) %></span>
        <% else %>
          <span class="text-[11px] text-amber-600 bg-amber-50 border border-amber-200 px-2.5 py-1 rounded-lg"><%= t("votes.edit.locked") %></span>
        <% end %>
      </div>

      <div id="options-list" class="space-y-2 mb-4">
        <% @vote.vote_options.includes(:image_attachment, :image_blob).each do |opt| %>
          <div class="option-row rounded-xl border border-slate-200 bg-slate-50/50 overflow-hidden" data-id="<%= opt.id %>" draggable="<%= editable %>" style="<%= editable ? 'cursor:grab;' : '' %>">
            <!-- Label row -->
            <div class="flex items-center gap-2 px-2 py-1.5">
              <div class="w-5 text-center text-slate-300 text-[13px] select-none flex-shrink-0" style="<%= editable ? 'cursor:grab;' : '' %>">≡</div>
              <% if opt.image.attached? %>
                <img src="<%= url_for(opt.image) %>" class="w-7 h-7 rounded-lg object-cover flex-shrink-0 border border-slate-200">
              <% end %>
              <input type="text" value="<%= opt.label %>"
                class="flex-1 px-2 py-1.5 bg-transparent border-0 text-[13px] font-medium text-slate-800 focus:outline-none focus:bg-white focus:rounded-lg <%= 'text-slate-400 cursor-not-allowed' unless editable %>"
                <%= "readonly disabled" unless editable %>
                onblur="<%= editable ? "updateOptionLabel(#{opt.id}, this.value)" : "" %>"
                onkeydown="if(event.key==='Enter'){this.blur();}">
              <% if editable %>
                <%# Image upload button %>
                <button type="button" onclick="document.getElementById('img-input-<%= opt.id %>').click()"
                  data-opt-id="<%= opt.id %>"
                  title="<%= opt.image.attached? ? 'Đổi ảnh' : 'Thêm ảnh' %>"
                  class="img-upload-btn w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg transition-colors border-0 cursor-pointer overflow-hidden <%= opt.image.attached? ? 'bg-emerald-100 text-emerald-600' : 'bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100' %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </button>
                <input type="file" accept="image/*" style="display:none" id="img-input-<%= opt.id %>"
                       onchange="uploadOptionImage(<%= opt.id %>, this)">
                <% if opt.image.attached? %>
                  <button type="button" onclick="removeOptionImage(<%= opt.id %>, this)"
                    title="Xóa ảnh"
                    class="w-5 h-5 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-400 rounded transition-colors border-0 bg-transparent cursor-pointer text-[13px] font-bold">✕</button>
                <% end %>
                <%# Description toggle %>
                <button type="button" onclick="toggleDesc(this)"
                  title="<%= opt.description.present? ? 'Đang có mô tả' : 'Thêm mô tả' %>"
                  class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg text-[11px] font-bold transition-colors border-0 cursor-pointer <%= opt.description.present? ? 'bg-indigo-100 text-indigo-600' : 'bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100' %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h7"/></svg>
                </button>
                <button type="button" onclick="deleteOption(<%= opt.id %>, this)" class="w-7 h-7 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-500 rounded-lg transition-colors border-0 bg-transparent cursor-pointer text-[18px]">×</button>
              <% end %>
            </div>
            <!-- Description row (collapsible, Quill editor) -->
            <% if editable %>
              <%# Always start hidden — icon being indigo signals "has content, click to expand".
                  This avoids the "2 clicks" problem caused by the panel being visually empty
                  (quill-wrap is an empty div) before Quill initialises.
                  data-content uses h() so HTML entities like " inside style="…" are escaped
                  and dataset.content returns the full untruncated HTML string. %>
              <div class="desc-wrap hidden px-3 pb-3">
                <div class="rounded-lg border border-slate-200 overflow-hidden bg-white quill-wrap"
                     data-opt-id="<%= opt.id %>"
                     data-content="<%= h(opt.description.to_s) %>">
                  <%# Quill mounts here via JS %>
                </div>
              </div>
            <% elsif opt.description.present? %>
              <% _desc = render_vote_desc(opt.description) %>
              <% if _desc %>
                <div class="px-9 pb-2 option-desc-html text-[12px] text-slate-400"><%= _desc %></div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if editable %>
        <div class="flex gap-2">
          <input type="text" id="new-option-input" placeholder="<%= j t("votes.edit.add_option_placeholder") %>"
            class="flex-1 px-3 py-2 border border-dashed border-slate-300 rounded-lg text-[13px] focus:border-indigo-400 outline-none"
            onkeydown="if(event.key==='Enter' && !event.isComposing){addOption();}">
          <button type="button" onclick="addOption()" class="px-4 py-2 bg-slate-800 text-white text-[12px] font-semibold rounded-lg hover:bg-blue-600">Lưu</button>
        </div>
        <button type="button" onclick="addOption()" class="mt-2 text-[12px] text-indigo-600 hover:text-indigo-700 font-medium">+ Thêm lựa chọn</button>
      <% end %>
    </div>

  </div>

</div><!-- /scrollable -->

<% if editable %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>
<script>
const voteId = <%= @vote.id %>;
const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
const DELETE_OPTION_CONFIRM = "<%= j t('votes.edit.delete_option_confirm') %>";
const REORDER_URL = "<%= reorder_vote_vote_options_path(@vote) %>";

// ── Quill instances map ──────────────────────────────────────────────────────
const quillInstances = {};
const TOOLBAR = [
  ['bold', 'italic', 'underline'],
  [{ list: 'ordered' }, { list: 'bullet' }],
  [{ color: [] }],
  ['clean']
];

function initQuill(wrap, optId) {
  // Check if THIS DOM element already has Quill (Quill adds ql-container class on init).
  // Do NOT rely on quillInstances[optId] — after Turbo navigation the DOM is replaced
  // but the JS context persists, leaving stale references in quillInstances.
  if (wrap.classList.contains('ql-container')) return quillInstances[optId];
  delete quillInstances[optId]; // clear any stale cache entry from a previous DOM

  const q = new Quill(wrap, {
    theme: 'snow',
    placeholder: 'Mô tả thêm cho lựa chọn này…',
    modules: { toolbar: TOOLBAR }
  });

  // Load existing content AFTER init via clipboard API (correct Quill way).
  // Setting wrap.innerHTML before init works on first load but breaks re-init
  // because Quill wraps the container in its own structure on first init.
  const savedContent = (wrap.dataset.content || '').trim();
  if (savedContent) {
    q.clipboard.dangerouslyPasteHTML(savedContent);
    q.history.clear(); // don't count initial load as an undoable action
  }

  // Guard: ignore text-change events fired during the initial paste above
  let timer, ready = false;
  setTimeout(() => { ready = true; }, 80);

  q.on('text-change', () => {
    if (!ready) return;
    clearTimeout(timer);
    timer = setTimeout(() => {
      const html = q.root.innerHTML;
      updateOptionDesc(optId, html === '<p><br></p>' ? '' : html);
    }, 700);
  });
  quillInstances[optId] = q;
  return q;
}

// Init Quill for any already-visible description panels.
// Listen on BOTH DOMContentLoaded (first hard load) and turbo:load (Turbo
// Drive navigations — form submit+redirect replaces DOM but not JS context,
// so DOMContentLoaded never fires again on subsequent visits).
function _initVisibleDescPanels() {
  document.querySelectorAll('.desc-wrap:not(.hidden) .quill-wrap').forEach(wrap => {
    initQuill(wrap, wrap.dataset.optId);
  });
}
document.addEventListener('DOMContentLoaded', _initVisibleDescPanels);
document.addEventListener('turbo:load', _initVisibleDescPanels);

// ── Drag-and-drop reorder ──────────────────────────────────────────────────
(function initDragDrop() {
  const list = document.getElementById('options-list');
  let dragged = null;

  list.addEventListener('dragstart', e => {
    const row = e.target.closest('.option-row');
    if (!row) return;
    dragged = row;
    setTimeout(() => row.style.opacity = '0.4', 0);
    e.dataTransfer.effectAllowed = 'move';
  });

  list.addEventListener('dragend', () => {
    if (dragged) dragged.style.opacity = '1';
    list.querySelectorAll('.option-row').forEach(r => r.style.borderColor = '');
    dragged = null;
    saveOrder();
  });

  list.addEventListener('dragover', e => {
    e.preventDefault();
    const row = e.target.closest('.option-row');
    if (row && row !== dragged) {
      list.querySelectorAll('.option-row').forEach(r => r.style.borderColor = '');
      row.style.borderColor = '#1e3a5f';
      const rect = row.getBoundingClientRect();
      const after = e.clientY > rect.top + rect.height / 2;
      list.insertBefore(dragged, after ? row.nextSibling : row);
    }
  });

  list.addEventListener('dragleave', e => {
    const row = e.target.closest('.option-row');
    if (row) row.style.borderColor = '';
  });

  list.addEventListener('drop', e => e.preventDefault());

  function saveOrder() {
    const ids = [...list.querySelectorAll('.option-row')].map(r => r.dataset.id);
    fetch(REORDER_URL, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ ids })
    });
  }
})();

function toggleDesc(btn) {
  const row  = btn.closest('.option-row');
  const wrap = row.querySelector('.desc-wrap');
  if (!wrap) return;
  const hidden = wrap.classList.toggle('hidden');
  btn.classList.toggle('bg-indigo-100', !hidden);
  btn.classList.toggle('text-indigo-600', !hidden);
  btn.classList.toggle('text-slate-300', hidden);
  if (!hidden) {
    const optId = row.dataset.id;
    const qWrap = wrap.querySelector('.quill-wrap');
    if (qWrap) {
      const q = initQuill(qWrap, optId);
      setTimeout(() => q.focus(), 50);
    }
  }
}

async function addOption() {
  const input = document.getElementById('new-option-input');
  const label = input.value.trim();
  if (!label) return;

  const res = await fetch(`/votes/${voteId}/vote_options`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ label })
  });
  if (!res.ok) return;
  const opt = await res.json();

  const row = document.createElement('div');
  row.className = 'option-row rounded-xl border border-slate-200 bg-slate-50/50 overflow-hidden';
  row.dataset.id = opt.id;
  row.draggable = true;
  row.style.cursor = 'grab';
  row.innerHTML = `
    <div class="flex items-center gap-2 px-2 py-1.5">
      <div class="w-5 text-center text-slate-300 text-[13px] select-none flex-shrink-0" style="cursor:grab;">≡</div>
      <input type="text" value="${escHtml(opt.label)}"
        class="flex-1 px-2 py-1.5 bg-transparent border-0 text-[13px] font-medium text-slate-800 focus:outline-none focus:bg-white focus:rounded-lg"
        onblur="updateOptionLabel(${opt.id}, this.value)"
        onkeydown="if(event.key==='Enter'){this.blur();}">
      <button type="button" onclick="document.getElementById('img-input-${opt.id}').click()"
        data-opt-id="${opt.id}" title="Thêm ảnh"
        class="img-upload-btn w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg transition-colors border-0 cursor-pointer bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </button>
      <input type="file" accept="image/*" style="display:none" id="img-input-${opt.id}"
             onchange="uploadOptionImage(${opt.id}, this)">
      <button type="button" onclick="toggleDesc(this)" title="Thêm mô tả"
        class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg text-[11px] font-bold transition-colors border-0 cursor-pointer bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h7"/></svg>
      </button>
      <button type="button" onclick="deleteOption(${opt.id}, this)" class="w-7 h-7 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-500 rounded-lg transition-colors border-0 bg-transparent cursor-pointer text-[18px]">×</button>
    </div>
    <div class="desc-wrap hidden px-3 pb-3">
      <div class="rounded-lg border border-slate-200 overflow-hidden bg-white quill-wrap"
           data-opt-id="${opt.id}" data-content=""></div>
    </div>
  `;
  document.getElementById('options-list').appendChild(row);
  input.value = '';
  input.focus();
}

async function updateOptionLabel(id, label) {
  label = label.trim();
  if (!label) return;
  await fetch(`/vote_options/${id}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ label })
  });
}

async function updateOptionDesc(id, description) {
  await fetch(`/vote_options/${id}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ description })
  });
}

function deleteOption(id, btn) {
  const label = btn.closest('.option-row')?.querySelector('input[type="text"]')?.value?.trim() || DELETE_OPTION_CONFIRM;
  showDeleteModal(label, async () => {
    const res = await fetch(`/vote_options/${id}`, { method: 'DELETE', headers: { 'X-CSRF-Token': csrfToken } });
    if (res.ok) btn.closest('.option-row').remove();
  });
}

async function uploadOptionImage(id, input) {
  const file = input.files[0];
  if (!file) return;

  const row = input.closest('.option-row');
  const labelRow = row.querySelector('.flex.items-center.gap-2');

  // ── Show local preview instantly (no waiting for server) ──
  const localUrl = URL.createObjectURL(file);
  let thumb = row.querySelector('.opt-img-thumb');
  if (!thumb) {
    thumb = document.createElement('img');
    thumb.className = 'opt-img-thumb w-7 h-7 rounded-lg object-cover flex-shrink-0 border border-slate-200';
    const handle = labelRow.querySelector('.w-5');
    handle.after(thumb);
  }
  thumb.src = localUrl;

  // Turn camera button green immediately
  const camBtn = labelRow.querySelector('.img-upload-btn');
  if (camBtn) { camBtn.className = camBtn.className.replace('bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100', 'bg-emerald-100 text-emerald-600'); }

  // Add remove button immediately if not there
  if (!labelRow.querySelector('.img-remove-btn')) {
    const rmBtn = document.createElement('button');
    rmBtn.type = 'button';
    rmBtn.className = 'img-remove-btn w-5 h-5 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-400 rounded transition-colors border-0 bg-transparent cursor-pointer text-[13px] font-bold';
    rmBtn.title = 'Xóa ảnh';
    rmBtn.textContent = '✕';
    rmBtn.onclick = () => removeOptionImage(id, rmBtn);
    camBtn?.after(rmBtn);
  }

  // ── Upload in background, swap to server URL when done ──
  const fd = new FormData();
  fd.append('image', file);
  const res = await fetch(`/vote_options/${id}/update_image`, {
    method: 'PATCH',
    headers: { 'X-CSRF-Token': csrfToken },
    body: fd
  });
  URL.revokeObjectURL(localUrl); // free memory
  if (res.ok) {
    const { url } = await res.json();
    thumb.src = url; // swap to permanent server URL
  } else {
    // Upload failed — revert UI
    thumb.remove();
    if (camBtn) { camBtn.className = camBtn.className.replace('bg-emerald-100 text-emerald-600', 'bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100'); }
    labelRow.querySelector('.img-remove-btn')?.remove();
  }
  input.value = '';
}

async function removeOptionImage(id, btn) {
  const res = await fetch(`/vote_options/${id}/destroy_image`, {
    method: 'DELETE',
    headers: { 'X-CSRF-Token': csrfToken }
  });
  if (!res.ok) return;

  const row = btn.closest('.option-row');
  const labelRow = row.querySelector('.flex.items-center.gap-2');

  // Remove thumbnail
  row.querySelector('.opt-img-thumb')?.remove();
  // Remove remove-button
  btn.remove();
  // Reset camera button style
  const camBtn = labelRow.querySelector('.img-upload-btn');
  if (camBtn) { camBtn.className = camBtn.className.replace('bg-emerald-100 text-emerald-600', 'bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100'); }
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Delete option modal ────────────────────────────────────────────────────
let _deleteCallback = null;
function showDeleteModal(label, onConfirm) {
  const m = document.getElementById('delete-option-modal');
  if (!m) return;
  document.getElementById('delete-option-label').textContent = label;
  m.style.display = 'flex';
  _deleteCallback = onConfirm;
}

// ── Unsaved changes detection ─────────────────────────────────────────────
// Uses per-element WeakMap snapshots instead of string serialization so it
// works reliably across page reloads and with radio/checkbox combos.
// Uses inline style to show/hide the bar instead of Tailwind classes to
// avoid cascade conflicts (flex overriding hidden).
// Uses event delegation for all bar/modal buttons — those elements are
// rendered AFTER this <script> tag and cannot be found by getElementById
// at setup time.
const _sf = document.querySelector('form[action*="/votes/"]');
let   _sfDirty = false;
const _sfSnaps = new WeakMap();

function _sfTakeSnap() {
  if (!_sf) return;
  Array.from(_sf.elements).forEach(el => {
    if (!el.name || el.disabled || el.type === 'hidden' || el.type === 'submit' || el.type === 'button') return;
    _sfSnaps.set(el, (el.type === 'checkbox' || el.type === 'radio') ? el.checked : el.value);
  });
}
function _sfChanged() {
  if (!_sf) return false;
  return Array.from(_sf.elements).some(el => {
    if (!el.name || el.disabled || el.type === 'hidden' || el.type === 'submit' || el.type === 'button') return false;
    if (!_sfSnaps.has(el)) return false;
    return _sfSnaps.get(el) !== ((el.type === 'checkbox' || el.type === 'radio') ? el.checked : el.value);
  });
}
function _sfShowBar() { const b = document.getElementById('unsaved-bar'); if (b) b.style.display = 'flex'; }
function _sfHideBar() { const b = document.getElementById('unsaved-bar'); if (b) b.style.display = 'none'; }
function _sfMarkDirty() { if (_sfDirty || !_sfChanged()) return; _sfDirty = true;  _sfShowBar(); }
function _sfMarkClean() { _sfDirty = false; _sfHideBar(); }

if (_sf) {
  _sfTakeSnap();
  // Re-snapshot after first paint to absorb any browser form-restoration
  requestAnimationFrame(() => { if (!_sfDirty) _sfTakeSnap(); });
  _sf.addEventListener('input',  _sfMarkDirty);
  _sf.addEventListener('change', _sfMarkDirty);
  _sf.addEventListener('submit', _sfMarkClean);
  window.addEventListener('beforeunload', e => {
    if (!_sfDirty) return;
    e.preventDefault(); e.returnValue = '';
  });
}

// ── Delegated handler — modal buttons, bar buttons, nav dirty-guard ────────
// (All targets rendered after this <script> tag — must use delegation)
document.addEventListener('click', e => {
  // Delete modal: cancel or backdrop click
  if (e.target.closest('#delete-modal-cancel') || e.target === document.getElementById('delete-option-modal')) {
    document.getElementById('delete-option-modal').style.display = 'none';
    _deleteCallback = null;
    return;
  }
  // Delete modal: confirm
  if (e.target.closest('#delete-modal-confirm')) {
    document.getElementById('delete-option-modal').style.display = 'none';
    const cb = _deleteCallback; _deleteCallback = null;
    if (cb) cb();
    return;
  }
  // Unsaved bar: discard
  if (e.target.closest('#unsaved-discard-btn')) {
    _sf?.reset();
    const ie = _sf?.querySelector('[name="vote[identity_mode]"]');
    if (ie) onIdentityChange(ie.value);
    const rc = document.getElementById('ranking-enabled-cb');
    if (rc) toggleRankingOptions(rc.checked);
    const ue = _sf?.querySelector('[name="vote[countdown_unit]"]:checked');
    if (ue) onCountdownUnitChange(ue.value);
    _sfMarkClean();
    return;
  }
  // Unsaved bar: quick-save
  if (e.target.closest('#unsaved-save-btn')) {
    _sf?.querySelector('[type="submit"]')?.click();
    return;
  }
  // Navigation guard
  if (!_sfDirty) return;
  const link = e.target.closest('a[href]');
  if (!link || link.target === '_blank' || link.href.startsWith('#') || _sf?.contains(link)) return;
  const ok = confirm('<%= I18n.locale == :vi ? "Bạn có thay đổi chưa được lưu. Rời trang sẽ mất dữ liệu — tiếp tục không?" : "You have unsaved changes. Leave this page and discard them?" %>');
  if (!ok) e.preventDefault();
  else _sfMarkClean();
});
</script>

<!-- ── Delete option confirmation modal ──────────────────────────────────── -->
<div id="delete-option-modal"
     class="fixed inset-0 z-[200] items-center justify-center p-4"
     style="display:none; background:rgba(15,23,42,0.72); backdrop-filter:blur(3px);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6"
       style="animation:slideUp 0.2s ease forwards;">
    <div class="flex items-start gap-3 mb-4">
      <div class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </div>
      <div>
        <h3 class="text-[15px] font-bold text-slate-900">
          <%= I18n.locale == :vi ? "Xoá lựa chọn?" : "Delete option?" %>
        </h3>
        <p class="text-[12px] text-slate-500 mt-0.5">
          <%= I18n.locale == :vi ? "Không thể hoàn tác sau khi xoá" : "This action cannot be undone" %>
        </p>
      </div>
    </div>
    <div class="bg-slate-50 border border-slate-100 rounded-lg px-3 py-2 mb-5">
      <p id="delete-option-label" class="text-[13px] font-semibold text-slate-700 truncate"></p>
    </div>
    <div class="flex gap-2 justify-end">
      <button id="delete-modal-cancel"
              class="px-4 py-2 text-[13px] font-semibold text-slate-600 bg-slate-100 hover:bg-slate-200 rounded-lg border-0 cursor-pointer transition-colors">
        <%= I18n.locale == :vi ? "Huỷ" : "Cancel" %>
      </button>
      <button id="delete-modal-confirm"
              class="px-4 py-2 text-[13px] font-semibold text-white bg-red-500 hover:bg-red-600 rounded-lg border-0 cursor-pointer transition-colors">
        🗑 <%= I18n.locale == :vi ? "Xoá" : "Delete" %>
      </button>
    </div>
  </div>
</div>

<% end %>

<!-- ── Unsaved changes sticky bar ─────────────────────────────────────────
     Hidden via inline style so _sfShowBar/_sfHideBar (style.display) override
