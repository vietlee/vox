<% content_for :title, @vote.title %>
<% editable = @vote.draft? %>

<%# Quill rich text editor (only loaded on this page) %>
<% if editable %>
<link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet">
<% end %>

<style>
  .option-row { transition: border-color 0.1s; }

  /* ── Quill editor inside option rows ── */
  .desc-wrap .ql-toolbar.ql-snow {
    padding: 3px 6px;
    border: none;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
    border-radius: 8px 8px 0 0;
  }
  .desc-wrap .ql-container.ql-snow {
    border: none;
    font-size: 12px;
    font-family: inherit;
  }
  .desc-wrap .ql-editor {
    padding: 6px 10px;
    min-height: 56px;
    font-size: 12px;
    color: #475569;
    line-height: 1.5;
  }
  .desc-wrap .ql-editor.ql-blank::before {
    font-style: normal;
    color: #94a3b8;
    font-size: 12px;
  }
  .desc-wrap .ql-toolbar .ql-formats { margin-right: 6px; }
  .desc-wrap .ql-snow .ql-picker { font-size: 11px; }
  .desc-wrap .ql-snow.ql-toolbar button,
  .desc-wrap .ql-snow .ql-toolbar button { width: 22px; height: 22px; padding: 2px; }
</style>

<div class="max-w-[720px]">
  <div class="flex items-center gap-3 mb-5">
    <div>
      <h1 class="text-[19px] font-extrabold text-slate-900"><%= @vote.title %></h1>
      <p class="text-[12px] text-slate-500 mt-0.5">
        <% status_badge = { "draft" => "bg-slate-100 text-slate-500", "active" => "bg-emerald-100 text-emerald-700", "closed" => "bg-red-100 text-red-600" } %>
        <span class="inline-flex px-2 py-0.5 rounded text-[11px] font-semibold <%= status_badge[@vote.status] %>"><%= t("status.#{@vote.status}").upcase %></span>
      </p>
    </div>
    <div class="ml-auto flex gap-2">
      <% if @vote.active? %>
        <%= link_to present_vote_path(@vote), target: "_blank", class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %><%= t("votes.edit.present") %><% end %>
        <%= button_to close_vote_path(@vote), method: :patch, class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-red-50 hover:text-red-700 hover:border-red-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors cursor-pointer" do %><%= t("votes.edit.close_vote") %><% end %>
      <% elsif @vote.draft? %>
        <button onclick="openVote()" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-emerald-50 hover:text-emerald-700 hover:border-emerald-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors cursor-pointer"><%= t("votes.edit.open_vote") %></button>
        <script>
        function openVote() {
          window.open('<%= present_vote_path(@vote) %>', '_blank');
          fetch('<%= open_vote_path(@vote) %>', {
            method: 'PATCH',
            headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content, 'Accept': 'application/json' }
          }).then(res => {
            if (res.ok) window.location.href = '<%= vote_path(@vote) %>';
          });
        }
        </script>
      <% elsif @vote.closed? %>
        <span class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 text-slate-400 text-[13px] font-semibold rounded-lg cursor-not-allowed select-none" title="<%= t('votes_errors.cannot_reopen_closed') %>">
          🔒 <%= t("status.closed").upcase %>
        </span>
      <% end %>
    </div>
  </div>

  <% unless editable %>
    <div class="mb-4 flex items-center gap-2 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-[13px] text-amber-700 font-medium">
      <span>⚠</span>
      <span><%= t("votes.edit.draft_only", status: @vote.status.upcase) %></span>
    </div>
  <% end %>

  <div class="space-y-4">

    <!-- Vote Settings -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 <%= 'opacity-70' unless editable %>">
      <h2 class="text-[13px] font-bold text-slate-700 mb-4"><%= t("votes.edit.settings") %></h2>
      <%= form_with model: @vote, url: vote_path(@vote), method: :patch, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("votes.edit.question_label") %></label>
            <%= f.text_field :title,
                  class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                  disabled: !editable %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("votes.edit.type_label") %></label>
              <%= f.select :vote_type,
                    %w[single_choice multiple_choice].map { |k| [t("votes.type.#{k}"), k] },
                    { selected: @vote.vote_type },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    disabled: !editable %>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("votes.edit.identity_label") %></label>
              <%= f.select :identity_mode,
                    Vote.identity_modes.keys.map { |k| [t("votes.identity.#{k}"), k] },
                    { selected: @vote.identity_mode },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    disabled: !editable,
                    onchange: editable ? "onIdentityChange(this.value)" : nil %>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("votes.edit.countdown_label") %></label>
              <%= f.number_field :countdown_seconds, min: 0,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    placeholder: t("votes.edit.countdown_placeholder"),
                    disabled: !editable %>
            </div>
            <div class="flex flex-col justify-end pb-0.5">
              <label class="flex items-center gap-2 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed opacity-60' %>">
                <%= f.check_box :show_results_live, class: "w-4 h-4 accent-indigo-600", disabled: !editable %>
                <span class="text-[12px] font-semibold text-slate-600"><%= t("votes.edit.show_results_live") %></span>
              </label>
            </div>
            <div class="flex flex-col justify-end pb-0.5">
              <label class="flex items-center gap-2 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed opacity-60' %>">
                <%= f.check_box :allow_multiple_votes, class: "w-4 h-4 accent-indigo-600", disabled: !editable %>
                <span class="text-[12px] font-semibold text-slate-600"><%= t("votes.edit.allow_multiple") %></span>
              </label>
            </div>
          </div>

          <!-- SSO provider picker — shown only when identity_mode = sso_required -->
          <div id="sso-providers-wrap" style="<%= @vote.sso_required? ? '' : 'display:none;' %>" class="px-4 py-3 rounded-xl border border-indigo-100 bg-indigo-50/60">
            <label class="block text-[11px] font-semibold text-slate-500 mb-2">
              <%= I18n.locale == :vi ? "Cho phép đăng nhập với" : "Allow sign in with" %>
            </label>
            <div class="flex gap-4">
              <% [["google", "🔵 Google"], ["microsoft", "🟦 Microsoft"], ["both", I18n.locale == :vi ? "✅ Cả hai" : "✅ Both"]].each do |val, lbl| %>
                <label class="flex items-center gap-1.5 text-[12px] font-semibold text-slate-600 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed' %>">
                  <%= f.radio_button :login_providers, val,
                        disabled: !editable,
                        checked: @vote.login_providers == val || (@vote.login_providers.blank? && val == "both"),
                        class: "accent-indigo-600" %>
                  <%= lbl %>
                </label>
              <% end %>
            </div>
          </div>
          <% if editable %>
          <script>
            function onIdentityChange(val) {
              document.getElementById('sso-providers-wrap').style.display = val === 'sso_required' ? '' : 'none';
            }
          </script>
          <% end %>

          <% if editable %>
            <div class="pt-2">
              <%= f.submit t("votes.edit.save_settings"), class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700 cursor-pointer border-0" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Vote Options -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 <%= 'opacity-70' unless editable %>">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-[13px] font-bold text-slate-700"><%= t("votes.edit.options") %></h2>
        <% if editable %>
          <span class="text-[11px] text-slate-400"><%= t("votes.edit.options_count", count: @vote.vote_options.count) %></span>
        <% else %>
          <span class="text-[11px] text-amber-600 bg-amber-50 border border-amber-200 px-2.5 py-1 rounded-lg"><%= t("votes.edit.locked") %></span>
        <% end %>
      </div>

      <div id="options-list" class="space-y-2 mb-4">
        <% @vote.vote_options.includes(:image_attachment, :image_blob).each do |opt| %>
          <div class="option-row rounded-xl border border-slate-200 bg-slate-50/50 overflow-hidden" data-id="<%= opt.id %>" draggable="<%= editable %>" style="<%= editable ? 'cursor:grab;' : '' %>">
            <!-- Label row -->
            <div class="flex items-center gap-2 px-2 py-1.5">
              <div class="w-5 text-center text-slate-300 text-[13px] select-none flex-shrink-0" style="<%= editable ? 'cursor:grab;' : '' %>">≡</div>
              <% if opt.image.attached? %>
                <img src="<%= url_for(opt.image) %>" class="w-7 h-7 rounded-lg object-cover flex-shrink-0 border border-slate-200">
              <% end %>
              <input type="text" value="<%= opt.label %>"
                class="flex-1 px-2 py-1.5 bg-transparent border-0 text-[13px] font-medium text-slate-800 focus:outline-none focus:bg-white focus:rounded-lg <%= 'text-slate-400 cursor-not-allowed' unless editable %>"
                <%= "readonly disabled" unless editable %>
                onblur="<%= editable ? "updateOptionLabel(#{opt.id}, this.value)" : "" %>"
                onkeydown="if(event.key==='Enter'){this.blur();}">
              <% if editable %>
                <%# Image upload button %>
                <button type="button" onclick="document.getElementById('img-input-<%= opt.id %>').click()"
                  data-opt-id="<%= opt.id %>"
                  title="<%= opt.image.attached? ? 'Đổi ảnh' : 'Thêm ảnh' %>"
                  class="img-upload-btn w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg transition-colors border-0 cursor-pointer overflow-hidden <%= opt.image.attached? ? 'bg-emerald-100 text-emerald-600' : 'bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100' %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </button>
                <input type="file" accept="image/*" style="display:none" id="img-input-<%= opt.id %>"
                       onchange="uploadOptionImage(<%= opt.id %>, this)">
                <% if opt.image.attached? %>
                  <button type="button" onclick="removeOptionImage(<%= opt.id %>, this)"
                    title="Xóa ảnh"
                    class="w-5 h-5 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-400 rounded transition-colors border-0 bg-transparent cursor-pointer text-[13px] font-bold">✕</button>
                <% end %>
                <%# Description toggle %>
                <button type="button" onclick="toggleDesc(this)"
                  title="<%= opt.description.present? ? 'Đang có mô tả' : 'Thêm mô tả' %>"
                  class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg text-[11px] font-bold transition-colors border-0 cursor-pointer <%= opt.description.present? ? 'bg-indigo-100 text-indigo-600' : 'bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100' %>">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h7"/></svg>
                </button>
                <button type="button" onclick="deleteOption(<%= opt.id %>, this)" class="w-7 h-7 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-500 rounded-lg transition-colors border-0 bg-transparent cursor-pointer text-[18px]">×</button>
              <% end %>
            </div>
            <!-- Description row (collapsible, Quill editor) -->
            <% if editable %>
              <div class="desc-wrap <%= opt.description.present? ? '' : 'hidden' %> px-3 pb-3">
                <div class="rounded-lg border border-slate-200 overflow-hidden bg-white quill-wrap"
                     data-opt-id="<%= opt.id %>"
                     data-content="<%= opt.description.to_s %>">
                  <%# Quill mounts here via JS %>
                </div>
              </div>
            <% elsif opt.description.present? %>
              <% _desc = render_vote_desc(opt.description) %>
              <% if _desc %>
                <div class="px-9 pb-2 option-desc-html text-[12px] text-slate-400"><%= _desc %></div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if editable %>
        <div class="flex gap-2">
          <input type="text" id="new-option-input" placeholder="<%= j t("votes.edit.add_option_placeholder") %>"
            class="flex-1 px-3 py-2 border border-dashed border-slate-300 rounded-lg text-[13px] focus:border-indigo-400 outline-none"
            onkeydown="if(event.key==='Enter' && !event.isComposing){addOption();}">
          <button type="button" onclick="addOption()" class="px-4 py-2 bg-slate-800 text-white text-[12px] font-semibold rounded-lg hover:bg-slate-700">Lưu</button>
        </div>
        <button type="button" onclick="addOption()" class="mt-2 text-[12px] text-indigo-600 hover:text-indigo-700 font-medium">+ Thêm lựa chọn</button>
      <% end %>
    </div>

  </div>
</div>

<% if editable %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>
<script>
const voteId = <%= @vote.id %>;
const csrfToken = document.querySelector('meta[name="csrf-token"]').content;
const DELETE_OPTION_CONFIRM = "<%= j t('votes.edit.delete_option_confirm') %>";
const REORDER_URL = "<%= reorder_vote_vote_options_path(@vote) %>";

// ── Quill instances map ──────────────────────────────────────────────────────
const quillInstances = {};
const TOOLBAR = [
  ['bold', 'italic', 'underline'],
  [{ list: 'ordered' }, { list: 'bullet' }],
  [{ color: [] }],
  ['clean']
];

function initQuill(wrap, optId) {
  if (quillInstances[optId]) return quillInstances[optId];
  const q = new Quill(wrap, {
    theme: 'snow',
    placeholder: 'Mô tả thêm cho lựa chọn này…',
    modules: { toolbar: TOOLBAR }
  });
  const savedContent = wrap.dataset.content || '';
  if (savedContent) q.root.innerHTML = savedContent;

  let timer;
  q.on('text-change', () => {
    clearTimeout(timer);
    timer = setTimeout(() => {
      const html = q.root.innerHTML;
      updateOptionDesc(optId, html === '<p><br></p>' ? '' : html);
    }, 700);
  });
  quillInstances[optId] = q;
  return q;
}

// Init Quill for any already-visible description panels on load
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.desc-wrap:not(.hidden) .quill-wrap').forEach(wrap => {
    initQuill(wrap, wrap.dataset.optId);
  });
});

// ── Drag-and-drop reorder ──────────────────────────────────────────────────
(function initDragDrop() {
  const list = document.getElementById('options-list');
  let dragged = null;

  list.addEventListener('dragstart', e => {
    const row = e.target.closest('.option-row');
    if (!row) return;
    dragged = row;
    setTimeout(() => row.style.opacity = '0.4', 0);
    e.dataTransfer.effectAllowed = 'move';
  });

  list.addEventListener('dragend', () => {
    if (dragged) dragged.style.opacity = '1';
    list.querySelectorAll('.option-row').forEach(r => r.style.borderColor = '');
    dragged = null;
    saveOrder();
  });

  list.addEventListener('dragover', e => {
    e.preventDefault();
    const row = e.target.closest('.option-row');
    if (row && row !== dragged) {
      list.querySelectorAll('.option-row').forEach(r => r.style.borderColor = '');
      row.style.borderColor = '#6366f1';
      const rect = row.getBoundingClientRect();
      const after = e.clientY > rect.top + rect.height / 2;
      list.insertBefore(dragged, after ? row.nextSibling : row);
    }
  });

  list.addEventListener('dragleave', e => {
    const row = e.target.closest('.option-row');
    if (row) row.style.borderColor = '';
  });

  list.addEventListener('drop', e => e.preventDefault());

  function saveOrder() {
    const ids = [...list.querySelectorAll('.option-row')].map(r => r.dataset.id);
    fetch(REORDER_URL, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
      body: JSON.stringify({ ids })
    });
  }
})();

function toggleDesc(btn) {
  const row  = btn.closest('.option-row');
  const wrap = row.querySelector('.desc-wrap');
  if (!wrap) return;
  const hidden = wrap.classList.toggle('hidden');
  btn.classList.toggle('bg-indigo-100', !hidden);
  btn.classList.toggle('text-indigo-600', !hidden);
  btn.classList.toggle('text-slate-300', hidden);
  if (!hidden) {
    const optId = row.dataset.id;
    const qWrap = wrap.querySelector('.quill-wrap');
    if (qWrap) {
      const q = initQuill(qWrap, optId);
      setTimeout(() => q.focus(), 50);
    }
  }
}

async function addOption() {
  const input = document.getElementById('new-option-input');
  const label = input.value.trim();
  if (!label) return;

  const res = await fetch(`/votes/${voteId}/vote_options`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ label })
  });
  if (!res.ok) return;
  const opt = await res.json();

  const row = document.createElement('div');
  row.className = 'option-row rounded-xl border border-slate-200 bg-slate-50/50 overflow-hidden';
  row.dataset.id = opt.id;
  row.draggable = true;
  row.style.cursor = 'grab';
  row.innerHTML = `
    <div class="flex items-center gap-2 px-2 py-1.5">
      <div class="w-5 text-center text-slate-300 text-[13px] select-none flex-shrink-0" style="cursor:grab;">≡</div>
      <input type="text" value="${escHtml(opt.label)}"
        class="flex-1 px-2 py-1.5 bg-transparent border-0 text-[13px] font-medium text-slate-800 focus:outline-none focus:bg-white focus:rounded-lg"
        onblur="updateOptionLabel(${opt.id}, this.value)"
        onkeydown="if(event.key==='Enter'){this.blur();}">
      <button type="button" onclick="document.getElementById('img-input-${opt.id}').click()"
        data-opt-id="${opt.id}" title="Thêm ảnh"
        class="img-upload-btn w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg transition-colors border-0 cursor-pointer bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      </button>
      <input type="file" accept="image/*" style="display:none" id="img-input-${opt.id}"
             onchange="uploadOptionImage(${opt.id}, this)">
      <button type="button" onclick="toggleDesc(this)" title="Thêm mô tả"
        class="w-7 h-7 flex-shrink-0 flex items-center justify-center rounded-lg text-[11px] font-bold transition-colors border-0 cursor-pointer bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h10M4 18h7"/></svg>
      </button>
      <button type="button" onclick="deleteOption(${opt.id}, this)" class="w-7 h-7 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-500 rounded-lg transition-colors border-0 bg-transparent cursor-pointer text-[18px]">×</button>
    </div>
    <div class="desc-wrap hidden px-3 pb-3">
      <div class="rounded-lg border border-slate-200 overflow-hidden bg-white quill-wrap"
           data-opt-id="${opt.id}" data-content=""></div>
    </div>
  `;
  document.getElementById('options-list').appendChild(row);
  input.value = '';
  input.focus();
}

async function updateOptionLabel(id, label) {
  label = label.trim();
  if (!label) return;
  await fetch(`/vote_options/${id}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ label })
  });
}

async function updateOptionDesc(id, description) {
  await fetch(`/vote_options/${id}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ description })
  });
}

async function deleteOption(id, btn) {
  if (!confirm(DELETE_OPTION_CONFIRM)) return;
  const res = await fetch(`/vote_options/${id}`, { method: 'DELETE', headers: { 'X-CSRF-Token': csrfToken } });
  if (res.ok) btn.closest('.option-row').remove();
}

async function uploadOptionImage(id, input) {
  const file = input.files[0];
  if (!file) return;
  const fd = new FormData();
  fd.append('image', file);
  const res = await fetch(`/vote_options/${id}/update_image`, {
    method: 'PATCH',
    headers: { 'X-CSRF-Token': csrfToken },
    body: fd
  });
  if (!res.ok) return;
  const { url } = await res.json();

  const row = input.closest('.option-row');
  const labelRow = row.querySelector('.flex.items-center.gap-2');

  // Update or insert thumbnail preview next to drag handle
  let thumb = row.querySelector('.opt-img-thumb');
  if (!thumb) {
    thumb = document.createElement('img');
    thumb.className = 'opt-img-thumb w-7 h-7 rounded-lg object-cover flex-shrink-0 border border-slate-200';
    const handle = labelRow.querySelector('.w-5');
    handle.after(thumb);
  }
  thumb.src = url;

  // Update camera button style → green (has image)
  const camBtn = labelRow.querySelector('.img-upload-btn');
  if (camBtn) { camBtn.className = camBtn.className.replace('bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100', 'bg-emerald-100 text-emerald-600'); }

  // Add remove button if not there
  if (!labelRow.querySelector('.img-remove-btn')) {
    const rmBtn = document.createElement('button');
    rmBtn.type = 'button';
    rmBtn.className = 'img-remove-btn w-5 h-5 flex-shrink-0 flex items-center justify-center text-slate-300 hover:text-red-400 rounded transition-colors border-0 bg-transparent cursor-pointer text-[13px] font-bold';
    rmBtn.title = 'Xóa ảnh';
    rmBtn.textContent = '✕';
    rmBtn.onclick = () => removeOptionImage(id, rmBtn);
    camBtn?.after(rmBtn);
  }
  input.value = '';
}

async function removeOptionImage(id, btn) {
  const res = await fetch(`/vote_options/${id}/destroy_image`, {
    method: 'DELETE',
    headers: { 'X-CSRF-Token': csrfToken }
  });
  if (!res.ok) return;

  const row = btn.closest('.option-row');
  const labelRow = row.querySelector('.flex.items-center.gap-2');

  // Remove thumbnail
  row.querySelector('.opt-img-thumb')?.remove();
  // Remove remove-button
  btn.remove();
  // Reset camera button style
  const camBtn = labelRow.querySelector('.img-upload-btn');
  if (camBtn) { camBtn.className = camBtn.className.replace('bg-emerald-100 text-emerald-600', 'bg-transparent text-slate-300 hover:text-slate-500 hover:bg-slate-100'); }
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
<% end %>
