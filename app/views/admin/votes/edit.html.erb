<% content_for :title, @vote.title %>
<% editable = @vote.draft? %>

<div class="max-w-[720px]">
  <div class="flex items-center gap-3 mb-5">
    <div>
      <h1 class="text-[19px] font-extrabold text-slate-900"><%= @vote.title %></h1>
      <p class="text-[12px] text-slate-500 mt-0.5">
        <% status_badge = { "draft" => "bg-slate-100 text-slate-500", "active" => "bg-emerald-100 text-emerald-700", "closed" => "bg-red-100 text-red-600" } %>
        <span class="inline-flex px-2 py-0.5 rounded text-[11px] font-semibold <%= status_badge[@vote.status] %>"><%= @vote.status.upcase %></span>
      </p>
    </div>
    <div class="ml-auto flex gap-2">
      <% if @vote.active? %>
        <%= link_to present_vote_path(@vote), target: "_blank", class: "px-4 py-2 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700" do %>🖥 Trình chiếu<% end %>
        <%= button_to close_vote_path(@vote), method: :patch, class: "px-4 py-2 bg-red-500 text-white text-[13px] font-semibold rounded-lg hover:bg-red-600 border-0 cursor-pointer" do %>■ Đóng vote<% end %>
      <% elsif @vote.draft? %>
        <button onclick="openVote()" class="px-4 py-2 bg-emerald-600 text-white text-[13px] font-semibold rounded-lg hover:bg-emerald-700 border-0 cursor-pointer">▶ Mở vote</button>
        <script>
        async function openVote() {
          const res = await fetch('<%= open_vote_path(@vote) %>', {
            method: 'PATCH',
            headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content, 'Accept': 'application/json' }
          });
          if (res.ok) {
            window.open('<%= present_vote_path(@vote) %>', '_blank');
            location.reload();
          }
        }
        </script>
      <% end %>
    </div>
  </div>

  <% unless editable %>
    <div class="mb-4 flex items-center gap-2 px-4 py-3 bg-amber-50 border border-amber-200 rounded-lg text-[13px] text-amber-700 font-medium">
      <span>⚠</span>
      <span>Chỉ có thể chỉnh sửa vote ở trạng thái <strong>Draft</strong>. Vote đang ở trạng thái <strong><%= @vote.status.upcase %></strong> nên tất cả trường đã bị khoá.</span>
    </div>
  <% end %>

  <div class="space-y-4">

    <!-- Vote Settings -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 <%= 'opacity-70' unless editable %>">
      <h2 class="text-[13px] font-bold text-slate-700 mb-4">Cài đặt</h2>
      <%= form_with model: @vote, url: vote_path(@vote), method: :patch, local: true do |f| %>
        <div class="space-y-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Câu hỏi</label>
            <%= f.text_field :title,
                  class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                  disabled: !editable %>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Loại vote</label>
              <%= f.select :vote_type,
                    [["Một lựa chọn", "single_choice"], ["Nhiều lựa chọn", "multiple_choice"], ["Word Cloud", "word_cloud"], ["Trả lời tự do", "open_ended"], ["Xếp hạng", "ranking"], ["Q&A Upvote", "qa_upvote"]],
                    { selected: @vote.vote_type },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    disabled: !editable %>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Danh tính</label>
              <%= f.select :identity_mode,
                    [["Ẩn danh", "anonymous"], ["Yêu cầu email", "email_required"]],
                    { selected: @vote.identity_mode },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    disabled: !editable %>
            </div>
          </div>

          <div class="grid grid-cols-3 gap-4">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Đếm ngược (giây)</label>
              <%= f.number_field :countdown_seconds, min: 0,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none #{'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable}",
                    placeholder: "0 = tắt",
                    disabled: !editable %>
            </div>
            <div class="flex flex-col justify-end pb-0.5">
              <label class="flex items-center gap-2 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed opacity-60' %>">
                <%= f.check_box :show_results_live, class: "w-4 h-4 accent-indigo-600", disabled: !editable %>
                <span class="text-[12px] font-semibold text-slate-600">Hiển thị kết quả live</span>
              </label>
            </div>
            <div class="flex flex-col justify-end pb-0.5">
              <label class="flex items-center gap-2 <%= editable ? 'cursor-pointer' : 'cursor-not-allowed opacity-60' %>">
                <%= f.check_box :allow_multiple_votes, class: "w-4 h-4 accent-indigo-600", disabled: !editable %>
                <span class="text-[12px] font-semibold text-slate-600">Cho phép vote nhiều lần</span>
              </label>
            </div>
          </div>

          <% if editable %>
            <div class="pt-2">
              <%= f.submit "Lưu cài đặt", class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700 cursor-pointer border-0" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Vote Options -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6 <%= 'opacity-70' unless editable %>">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-[13px] font-bold text-slate-700">Các lựa chọn</h2>
        <% if editable %>
          <span class="text-[11px] text-slate-400"><%= @vote.vote_options.count %> lựa chọn</span>
        <% else %>
          <span class="text-[11px] text-amber-600 bg-amber-50 border border-amber-200 px-2.5 py-1 rounded-lg">🔒 Không thể chỉnh sửa</span>
        <% end %>
      </div>

      <div id="options-list" class="space-y-2 mb-4">
        <% @vote.vote_options.each do |opt| %>
          <div class="option-row flex items-center gap-2" data-id="<%= opt.id %>">
            <div class="w-5 text-center text-slate-300 text-[13px] select-none">≡</div>
            <input type="text" value="<%= opt.label %>"
              class="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 outline-none <%= 'bg-slate-50 text-slate-400 cursor-not-allowed' unless editable %>"
              <%= "readonly disabled" unless editable %>
              onblur="<%= editable ? "updateOption(#{opt.id}, this.value)" : "" %>"
              onkeydown="if(event.key==='Enter'){this.blur();}">
            <% if editable %>
              <button onclick="deleteOption(<%= opt.id %>, this)" class="w-7 h-7 flex items-center justify-center text-slate-300 hover:text-red-500 rounded transition-colors text-[16px]">×</button>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if editable %>
        <div class="flex gap-2">
          <input type="text" id="new-option-input" placeholder="Thêm lựa chọn mới..."
            class="flex-1 px-3 py-2 border border-dashed border-slate-300 rounded-lg text-[13px] focus:border-indigo-400 outline-none"
            onkeydown="if(event.key==='Enter'){addOption();}">
          <button onclick="addOption()" class="px-4 py-2 bg-slate-800 text-white text-[12px] font-semibold rounded-lg hover:bg-slate-700">+ Thêm</button>
        </div>
      <% end %>
    </div>

  </div>
</div>

<% if editable %>
<script>
const voteId = <%= @vote.id %>;
const csrfToken = document.querySelector('meta[name="csrf-token"]').content;

async function addOption() {
  const input = document.getElementById('new-option-input');
  const label = input.value.trim();
  if (!label) return;

  const res = await fetch(`/votes/${voteId}/vote_options`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ label })
  });
  if (!res.ok) return;
  const opt = await res.json();

  const row = document.createElement('div');
  row.className = 'option-row flex items-center gap-2';
  row.dataset.id = opt.id;
  row.innerHTML = `
    <div class="w-5 text-center text-slate-300 text-[13px] select-none">≡</div>
    <input type="text" value="${escHtml(opt.label)}"
      class="flex-1 px-3 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 outline-none"
      onblur="updateOption(${opt.id}, this.value)"
      onkeydown="if(event.key==='Enter'){this.blur();}">
    <button onclick="deleteOption(${opt.id}, this)" class="w-7 h-7 flex items-center justify-center text-slate-300 hover:text-red-500 rounded transition-colors text-[16px]">×</button>
  `;
  document.getElementById('options-list').appendChild(row);
  input.value = '';
  input.focus();
}

async function updateOption(id, label) {
  label = label.trim();
  if (!label) return;
  await fetch(`/vote_options/${id}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrfToken },
    body: JSON.stringify({ label })
  });
}

async function deleteOption(id, btn) {
  if (!confirm('Xoá lựa chọn này?')) return;
  const res = await fetch(`/vote_options/${id}`, {
    method: 'DELETE',
    headers: { 'X-CSRF-Token': csrfToken }
  });
  if (res.ok) btn.closest('.option-row').remove();
}

function escHtml(str) {
  return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
<% end %>
