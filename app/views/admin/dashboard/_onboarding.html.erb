<%# Onboarding checklist — shown only when not all steps are complete and not dismissed %>
<% return if onboarding[:complete] %>
<% pct = (onboarding[:done].to_f / onboarding[:total] * 100).round %>

<div id="onboarding-banner"
     class="rounded-[12px] border mb-6 overflow-hidden"
     style="background:linear-gradient(135deg,#eef2ff 0%,#f5f3ff 100%); border-color:rgba(99,102,241,0.2);">

  <!-- Header row -->
  <div class="flex items-start justify-between px-5 pt-5 pb-3">
    <div>
      <h2 class="text-[15px] font-extrabold text-slate-900 tracking-tight"><%= t("onboarding.title") %></h2>
      <p class="text-[12px] text-slate-500 mt-0.5"><%= t("onboarding.subtitle") %></p>
    </div>
    <button onclick="dismissOnboarding()"
      class="text-slate-400 hover:text-slate-600 border-0 bg-transparent cursor-pointer text-[18px] leading-none mt-0.5"
      title="<%= t('onboarding.dismiss') %>">×</button>
  </div>

  <!-- Progress bar -->
  <div class="px-5 pb-4">
    <div class="flex items-center justify-between text-[11px] text-slate-500 mb-1.5">
      <span><%= t("onboarding.progress", done: onboarding[:done], total: onboarding[:total]) %></span>
      <span class="font-semibold text-indigo-600"><%= pct %>%</span>
    </div>
    <div class="h-1.5 bg-white/70 rounded-full overflow-hidden">
      <div class="h-full rounded-full transition-all duration-500"
           style="width:<%= pct %>%; background:linear-gradient(90deg,#6366f1,#a855f7);"></div>
    </div>
  </div>

  <!-- Checklist -->
  <div class="px-5 pb-5 grid sm:grid-cols-2 gap-2">
    <% onboarding[:items].each do |item| %>
      <div class="flex items-center gap-3 py-2.5 px-3 rounded-[8px] <%= item[:done] ? 'bg-white/60' : 'bg-white' %>
                  border border-white/80">
        <!-- Check icon -->
        <div class="flex-shrink-0 w-5 h-5 rounded-full flex items-center justify-center
                    <%= item[:done] ? 'bg-indigo-600' : 'border-2 border-slate-300 bg-white' %>">
          <% if item[:done] %>
            <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
            </svg>
          <% end %>
        </div>
        <!-- Label -->
        <span class="text-[13px] <%= item[:done] ? 'line-through text-slate-400' : 'font-semibold text-slate-800' %> flex-1">
          <%= t(item[:label]) %>
        </span>
        <!-- Action link -->
        <% if !item[:done] && item[:url] %>
          <%= link_to t("common.start"), item[:url],
                class: "text-[11px] font-semibold text-indigo-600 hover:text-indigo-800 flex-shrink-0" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<script>
function dismissOnboarding() {
  const banner = document.getElementById('onboarding-banner');
  if (banner) {
    banner.style.transition = 'opacity 0.3s ease, max-height 0.4s ease';
    banner.style.opacity = '0';
    banner.style.maxHeight = '0';
    banner.style.overflow = 'hidden';
    setTimeout(() => banner.remove(), 420);
  }
  // Remember dismissal in localStorage
  try { localStorage.setItem('vox_onboarding_dismissed_<%= current_workspace.id %>', '1'); } catch(e) {}
}

// Auto-dismiss if user previously dismissed
(function() {
  try {
    if (localStorage.getItem('vox_onboarding_dismissed_<%= current_workspace.id %>') === '1') {
      const b = document.getElementById('onboarding-banner');
      if (b) b.remove();
    }
  } catch(e) {}
})();
</script>
