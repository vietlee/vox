<% content_for :title, t("dashboard.title") %>

<!-- Header -->
<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900 tracking-tight"><%= t("dashboard.title") %></h1>
    <p class="text-[13px] text-slate-500 mt-0.5"><%= current_workspace.name %> · <%= Date.current.strftime("%B %Y") %></p>
  </div>
</div>

<!-- KPI row — 2 rows x 4 cols to avoid cramping -->
<div class="grid grid-cols-4 gap-3 mb-6" style="grid-auto-rows: 72px">
  <%= link_to surveys_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden hover:shadow-md transition-shadow group flex items-center gap-3" do %>
    <span class="text-2xl">📋</span>
    <div>
      <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.stat_surveys") %></div>
      <div class="text-[20px] font-extrabold text-slate-900 group-hover:text-indigo-600 transition-colors leading-tight"><%= @surveys_count %></div>
    </div>
  <% end %>
  <%= link_to votes_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden hover:shadow-md transition-shadow group flex items-center gap-3" do %>
    <span class="text-2xl">🗳️</span>
    <div>
      <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.stat_votes") %></div>
      <div class="text-[20px] font-extrabold text-slate-900 group-hover:text-violet-600 transition-colors leading-tight"><%= @votes_count %></div>
    </div>
  <% end %>
  <%= link_to feedback_boards_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden hover:shadow-md transition-shadow group flex items-center gap-3" do %>
    <span class="text-2xl">💬</span>
    <div>
      <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.stat_feedback") %></div>
      <div class="text-[20px] font-extrabold text-slate-900 group-hover:text-emerald-600 transition-colors leading-tight"><%= @feedbacks_count %></div>
    </div>
  <% end %>
  <%= link_to members_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden hover:shadow-md transition-shadow group flex items-center gap-3" do %>
    <span class="text-2xl">👥</span>
    <div>
      <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.stat_members") %></div>
      <div class="text-[20px] font-extrabold text-slate-900 group-hover:text-sky-600 transition-colors leading-tight"><%= @members_count %></div>
    </div>
  <% end %>
  <%= link_to quiz_sets_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden hover:shadow-md transition-shadow group flex items-center gap-3" do %>
    <span class="text-2xl">🧠</span>
    <div>
      <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.stat_quiz") %></div>
      <div class="text-[20px] font-extrabold text-slate-900 group-hover:text-indigo-600 transition-colors leading-tight"><%= @quiz_sets_count %></div>
    </div>
  <% end %>
  <%= link_to learning_paths_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden hover:shadow-md transition-shadow group flex items-center gap-3" do %>
    <span class="text-2xl">🗺️</span>
    <div>
      <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.stat_paths") %></div>
      <div class="text-[20px] font-extrabold text-slate-900 group-hover:text-blue-600 transition-colors leading-tight"><%= @learning_paths_count %></div>
    </div>
  <% end %>
  <%= link_to flashcard_decks_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden hover:shadow-md transition-shadow group flex items-center gap-3" do %>
    <span class="text-2xl">🃏</span>
    <div>
      <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.stat_flashcard") %></div>
      <div class="text-[20px] font-extrabold text-slate-900 group-hover:text-orange-600 transition-colors leading-tight"><%= @flashcard_decks_count %></div>
    </div>
  <% end %>
  <!-- AI Credits mini -->
  <% if (sub = @subscription) %>
    <div class="bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3.5 overflow-hidden flex items-center gap-3">
      <span class="text-2xl">🎯</span>
      <div class="flex-1 min-w-0">
        <div class="text-[11px] text-slate-400 uppercase tracking-wide font-medium"><%= t("dashboard.ai_credits") %></div>
        <div class="text-[13px] font-bold text-slate-900 leading-tight"><%= sub.credit_used %> / <%= sub.max_ai_credits.to_i > 0 ? sub.max_ai_credits : "∞" %></div>
        <div class="h-1 bg-slate-100 rounded-full mt-1 overflow-hidden">
          <div class="h-1 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-full" style="width:<%= sub.max_ai_credits.to_i > 0 ? (100 - sub.credit_percentage) : 100 %>%"></div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<!-- Main 2-column layout -->
<div class="grid grid-cols-[1fr_280px] gap-5">

  <!-- Left: activity panels -->
  <div class="space-y-5">

    <!-- Surveys + Votes side by side -->
    <div class="grid grid-cols-2 gap-5">

      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-[13px] font-bold text-slate-900"><%= t("dashboard.section_surveys") %></h2>
          <%= link_to surveys_path, class: "text-[11px] text-indigo-600 hover:underline" do %><%= t("dashboard.view_all") %><% end %>
        </div>
        <% if @active_surveys.any? %>
          <% @active_surveys.each do |survey| %>
            <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-0">
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= survey.title %></div>
                <div class="text-[10px] text-slate-400"><%= t("dashboard.n_responses", count: survey.response_count) %> · <%= survey.created_at.strftime("%b %d") %></div>
              </div>
              <%= link_to results_survey_path(survey), class: "text-[10px] px-2 py-1 bg-slate-100 rounded-lg text-slate-600 hover:bg-slate-200 flex-shrink-0" do %><%= t("dashboard.btn_results") %><% end %>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-6">
            <p class="text-[12px] text-slate-400"><%= t("dashboard.no_surveys") %></p>
            <%= link_to t("dashboard.new_survey"), new_survey_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline block" %>
          </div>
        <% end %>
      </div>

      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-[13px] font-bold text-slate-900"><%= t("dashboard.section_votes") %></h2>
          <%= link_to votes_path, class: "text-[11px] text-indigo-600 hover:underline" do %><%= t("dashboard.view_all") %><% end %>
        </div>
        <% if @active_votes.any? %>
          <% @active_votes.each do |vote| %>
            <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-0">
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= vote.title %></div>
                <div class="text-[10px] text-slate-400"><%= vote.participant_count %> votes</div>
              </div>
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse flex-shrink-0"></span>
              <%= link_to present_vote_path(vote), class: "text-[10px] px-2 py-1 bg-indigo-50 rounded-lg text-indigo-700 hover:bg-[#1e3a5f] hover:text-white flex-shrink-0" do %><%= t("dashboard.btn_present") %><% end %>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-6">
            <p class="text-[12px] text-slate-400"><%= t("dashboard.no_votes") %></p>
            <%= link_to t("dashboard.new_vote"), new_vote_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline block" %>
          </div>
        <% end %>
      </div>

    </div>

    <!-- Quiz + Learning paths side by side -->
    <div class="grid grid-cols-2 gap-5">

      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-[13px] font-bold text-slate-900"><%= t("dashboard.section_quiz") %></h2>
          <%= link_to quiz_sets_path, class: "text-[11px] text-indigo-600 hover:underline" do %><%= t("dashboard.view_all") %><% end %>
        </div>
        <% if @recent_quiz_sets.any? %>
          <% @recent_quiz_sets.each do |qs| %>
            <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-0">
              <div class="w-7 h-7 bg-indigo-50 rounded-lg flex items-center justify-center shrink-0 text-sm">🧠</div>
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= qs.title %></div>
                <div class="text-[10px] text-slate-400"><%= t("dashboard.n_questions", count: qs.quiz_questions.count) %> · <%= qs.created_at.strftime("%b %d") %></div>
              </div>
              <%= link_to quiz_set_path(qs), class: "text-[10px] px-2 py-1 bg-slate-100 rounded-lg text-slate-600 hover:bg-slate-200 flex-shrink-0" do %><%= t("dashboard.btn_open") %><% end %>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-6">
            <p class="text-[12px] text-slate-400"><%= t("dashboard.no_quiz") %></p>
            <%= link_to t("dashboard.new_quiz"), new_quiz_set_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline block" %>
          </div>
        <% end %>
      </div>

      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-[13px] font-bold text-slate-900"><%= t("dashboard.section_paths") %></h2>
          <%= link_to learning_paths_path, class: "text-[11px] text-indigo-600 hover:underline" do %><%= t("dashboard.view_all") %><% end %>
        </div>
        <% if @recent_learning_paths.any? %>
          <% @recent_learning_paths.each do |lp| %>
            <div class="flex items-center gap-3 py-2.5 border-b border-slate-100 last:border-0">
              <div class="w-7 h-7 bg-blue-50 rounded-lg flex items-center justify-center shrink-0 text-sm">🗺️</div>
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= lp.title %></div>
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] text-slate-400"><%= t("dashboard.n_lessons", count: lp.learning_path_items.count) %></span>
                  <% if lp.published? %>
                    <span class="text-[9px] px-1 py-0.5 bg-emerald-100 text-emerald-700 rounded font-bold">Live</span>
                  <% end %>
                  <% if lp.ai_generated? %>
                    <span class="text-[9px] px-1.5 py-0.5 rounded-full font-bold text-white" style="background:linear-gradient(135deg,#7c3aed,#4f46e5);">✨ AI</span>
                  <% end %>
                </div>
              </div>
              <%= link_to learning_path_path(lp), class: "text-[10px] px-2 py-1 bg-slate-100 rounded-lg text-slate-600 hover:bg-slate-200 flex-shrink-0" do %><%= t("dashboard.btn_open") %><% end %>
            </div>
          <% end %>
        <% else %>
          <div class="text-center py-6">
            <p class="text-[12px] text-slate-400"><%= t("dashboard.no_paths") %></p>
            <%= link_to t("dashboard.new_path"), new_learning_path_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline block" %>
          </div>
        <% end %>
      </div>

    </div>

  </div>

  <!-- Right sidebar -->
  <div class="space-y-4">

    <!-- AI Tools -->
    <div class="bg-gradient-to-br from-violet-50 to-indigo-50 border border-violet-200 rounded-[10px] p-4">
      <h2 class="text-[13px] font-bold text-slate-900 mb-3"><%= t("dashboard.section_ai_tools") %></h2>
      <div class="space-y-2">
        <%= link_to ai_chat_page_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">💬</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800"><%= t("dashboard.ai_tools_chat") %></div>
            <div class="text-[10px] text-slate-400"><%= t("dashboard.ai_tools_chat_sub") %></div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <%= link_to ai_tutor_page_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">🎓</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800"><%= t("dashboard.ai_tools_tutor") %></div>
            <div class="text-[10px] text-slate-400"><%= t("dashboard.ai_tools_tutor_sub") %></div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <%= link_to new_content_outline_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">🖥️</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800"><%= t("dashboard.ai_tools_slide") %></div>
            <div class="text-[10px] text-slate-400"><%= t("dashboard.ai_tools_slide_sub") %></div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <%= link_to new_document_summary_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">📄</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800"><%= t("dashboard.ai_tools_summary") %></div>
            <div class="text-[10px] text-slate-400"><%= t("dashboard.ai_tools_summary_sub") %></div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
    </div>

    <!-- Recent feedback -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
      <h2 class="text-[13px] font-bold text-slate-900 mb-3"><%= t("dashboard.section_feedback") %></h2>
      <% if @recent_feedbacks.any? %>
        <% @recent_feedbacks.each do |fb| %>
          <div class="py-2.5 border-b border-slate-100 last:border-0">
            <p class="text-[11px] text-slate-700 line-clamp-2"><%= fb.content.truncate(80) %></p>
            <div class="flex items-center gap-1.5 mt-1">
              <% if fb.flagged? %><span class="text-[9px] text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded">⚠ <%= t("feedback.flagged") %></span><% end %>
              <span class="text-[9px] text-slate-400 ml-auto"><%= fb.created_at.strftime("%b %d") %></span>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-[12px] text-slate-400 text-center py-4"><%= t("dashboard.no_feedback_items") %></p>
      <% end %>
    </div>

  </div>
</div>
