<% content_for :title, t("dashboard.title") %>
<% content_for :main_class, 'flex-1 overflow-hidden p-6 flex flex-col' %>

<!-- Header -->
<div class="flex items-start justify-between mb-5 flex-shrink-0">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900 tracking-tight"><%= t("dashboard.title") %></h1>
    <p class="text-[13px] text-slate-500 mt-0.5"><%= current_workspace.name %> · <%= Date.current.strftime("%B %Y") %></p>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to surveys_path, class: "px-3 py-2 bg-white border border-slate-200 rounded-xl text-[12px] font-semibold text-slate-600 hover:bg-slate-50 transition-colors shadow-sm" do %>
      + Tạo khảo sát
    <% end %>
    <%= link_to new_quiz_set_path, class: "px-3 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-xl text-[12px] font-bold text-white transition-colors shadow-sm" do %>
      + Tạo Quiz
    <% end %>
  </div>
</div>

<!-- KPI row — 7 stats -->
<div class="grid grid-cols-7 gap-3 mb-5 flex-shrink-0">
  <%= link_to surveys_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3 hover:shadow-md transition-shadow group" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xl">📋</span>
      <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Khảo sát</span>
    </div>
    <div class="text-[22px] font-extrabold text-slate-900 group-hover:text-indigo-600 transition-colors"><%= @surveys_count %></div>
    <div class="text-[10px] text-slate-400 mt-0.5">∞ Không giới hạn</div>
  <% end %>

  <%= link_to votes_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3 hover:shadow-md transition-shadow group" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xl">🗳️</span>
      <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Bình chọn</span>
    </div>
    <div class="text-[22px] font-extrabold text-slate-900 group-hover:text-violet-600 transition-colors"><%= @votes_count %></div>
    <div class="text-[10px] text-slate-400 mt-0.5">∞ Không giới hạn</div>
  <% end %>

  <%= link_to feedback_boards_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3 hover:shadow-md transition-shadow group" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xl">💬</span>
      <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Góp ý</span>
    </div>
    <div class="text-[22px] font-extrabold text-slate-900 group-hover:text-emerald-600 transition-colors"><%= @feedbacks_count %></div>
    <div class="text-[10px] text-slate-400 mt-0.5">∞ Không giới hạn</div>
  <% end %>

  <%= link_to quiz_sets_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3 hover:shadow-md transition-shadow group" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xl">🧠</span>
      <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Quiz</span>
    </div>
    <div class="text-[22px] font-extrabold text-slate-900 group-hover:text-indigo-600 transition-colors"><%= @quiz_sets_count %></div>
    <div class="text-[10px] text-slate-400 mt-0.5">∞ Không giới hạn</div>
  <% end %>

  <%= link_to learning_paths_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3 hover:shadow-md transition-shadow group" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xl">🗺️</span>
      <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Lộ trình</span>
    </div>
    <div class="text-[22px] font-extrabold text-slate-900 group-hover:text-blue-600 transition-colors"><%= @learning_paths_count %></div>
    <div class="text-[10px] text-slate-400 mt-0.5">∞ Không giới hạn</div>
  <% end %>

  <%= link_to flashcard_decks_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3 hover:shadow-md transition-shadow group" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xl">🃏</span>
      <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Flashcard</span>
    </div>
    <div class="text-[22px] font-extrabold text-slate-900 group-hover:text-orange-600 transition-colors"><%= @flashcard_decks_count %></div>
    <div class="text-[10px] text-slate-400 mt-0.5">∞ Không giới hạn</div>
  <% end %>

  <%= link_to members_path, class: "bg-white border border-slate-200 rounded-[10px] shadow-sm px-4 py-3 hover:shadow-md transition-shadow group" do %>
    <div class="flex items-center justify-between mb-1">
      <span class="text-xl">👥</span>
      <span class="text-[10px] text-slate-400 font-medium uppercase tracking-wide">Thành viên</span>
    </div>
    <div class="text-[22px] font-extrabold text-slate-900 group-hover:text-sky-600 transition-colors"><%= @members_count %></div>
    <div class="text-[10px] text-slate-400 mt-0.5">∞ Không giới hạn</div>
  <% end %>
</div>

<!-- Main grid: 3 columns -->
<div class="flex-1 min-h-0 grid grid-cols-[1fr_1fr_300px] gap-4">

  <!-- Col 1: Survey + Vote -->
  <div class="flex flex-col gap-4 min-h-0 overflow-hidden">

    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 flex flex-col flex-1 min-h-0">
      <div class="flex items-center justify-between mb-3 flex-shrink-0">
        <h2 class="text-[13px] font-bold text-slate-900">📋 Khảo sát đang chạy</h2>
        <%= link_to surveys_path, class: "text-[11px] text-indigo-600 hover:underline" do %>Xem tất cả →<% end %>
      </div>
      <div class="overflow-y-auto flex-1 -mr-1 pr-1">
        <% if @active_surveys.any? %>
          <% @active_surveys.each do |survey| %>
            <div class="flex items-center gap-3 py-2 border-b border-slate-100 last:border-0">
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= survey.title %></div>
                <div class="text-[10px] text-slate-400"><%= survey.response_count %> phản hồi · <%= survey.created_at.strftime("%b %d") %></div>
              </div>
              <%= link_to results_survey_path(survey), class: "text-[10px] px-2 py-1 bg-slate-100 rounded-lg text-slate-600 hover:bg-slate-200 flex-shrink-0" do %>Kết quả<% end %>
            </div>
          <% end %>
        <% else %>
          <div class="flex flex-col items-center justify-center h-full text-center py-6">
            <span class="text-3xl mb-2">📋</span>
            <p class="text-[12px] text-slate-400">Chưa có khảo sát nào</p>
            <%= link_to "+ Tạo mới", new_survey_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 flex flex-col flex-1 min-h-0">
      <div class="flex items-center justify-between mb-3 flex-shrink-0">
        <h2 class="text-[13px] font-bold text-slate-900">🗳️ Bình chọn đang chạy</h2>
        <%= link_to votes_path, class: "text-[11px] text-indigo-600 hover:underline" do %>Xem tất cả →<% end %>
      </div>
      <div class="overflow-y-auto flex-1 -mr-1 pr-1">
        <% if @active_votes.any? %>
          <% @active_votes.each do |vote| %>
            <div class="flex items-center gap-3 py-2 border-b border-slate-100 last:border-0">
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= vote.title %></div>
                <div class="text-[10px] text-slate-400"><%= vote.participant_count %> votes · Trực tiếp</div>
              </div>
              <span class="flex-shrink-0 w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
              <%= link_to present_vote_path(vote), class: "text-[10px] px-2 py-1 bg-indigo-50 rounded-lg text-indigo-700 hover:bg-indigo-100 flex-shrink-0" do %>Trình chiếu<% end %>
            </div>
          <% end %>
        <% else %>
          <div class="flex flex-col items-center justify-center h-full text-center py-6">
            <span class="text-3xl mb-2">🗳️</span>
            <p class="text-[12px] text-slate-400">Chưa có bình chọn nào</p>
            <%= link_to "+ Tạo mới", new_vote_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <!-- Col 2: Quiz + Learning Paths -->
  <div class="flex flex-col gap-4 min-h-0 overflow-hidden">

    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 flex flex-col flex-1 min-h-0">
      <div class="flex items-center justify-between mb-3 flex-shrink-0">
        <h2 class="text-[13px] font-bold text-slate-900">🧠 Quiz gần đây</h2>
        <%= link_to quiz_sets_path, class: "text-[11px] text-indigo-600 hover:underline" do %>Xem tất cả →<% end %>
      </div>
      <div class="overflow-y-auto flex-1 -mr-1 pr-1">
        <% if @recent_quiz_sets.any? %>
          <% @recent_quiz_sets.each do |qs| %>
            <div class="flex items-center gap-3 py-2 border-b border-slate-100 last:border-0">
              <div class="w-7 h-7 bg-indigo-50 rounded-lg flex items-center justify-center shrink-0 text-sm">🧠</div>
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= qs.title %></div>
                <div class="text-[10px] text-slate-400"><%= qs.quiz_questions.count %> câu · <%= qs.created_at.strftime("%b %d") %></div>
              </div>
              <%= link_to quiz_set_path(qs), class: "text-[10px] px-2 py-1 bg-slate-100 rounded-lg text-slate-600 hover:bg-slate-200 flex-shrink-0" do %>Mở<% end %>
            </div>
          <% end %>
        <% else %>
          <div class="flex flex-col items-center justify-center h-full text-center py-6">
            <span class="text-3xl mb-2">🧠</span>
            <p class="text-[12px] text-slate-400">Chưa có quiz nào</p>
            <%= link_to "+ Tạo Quiz mới", new_quiz_set_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>

    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 flex flex-col flex-1 min-h-0">
      <div class="flex items-center justify-between mb-3 flex-shrink-0">
        <h2 class="text-[13px] font-bold text-slate-900">🗺️ Lộ trình học gần đây</h2>
        <%= link_to learning_paths_path, class: "text-[11px] text-indigo-600 hover:underline" do %>Xem tất cả →<% end %>
      </div>
      <div class="overflow-y-auto flex-1 -mr-1 pr-1">
        <% if @recent_learning_paths.any? %>
          <% @recent_learning_paths.each do |lp| %>
            <div class="flex items-center gap-3 py-2 border-b border-slate-100 last:border-0">
              <div class="w-7 h-7 bg-blue-50 rounded-lg flex items-center justify-center shrink-0 text-sm">🗺️</div>
              <div class="flex-1 min-w-0">
                <div class="text-[12px] font-semibold text-slate-900 truncate"><%= lp.title %></div>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <span class="text-[10px] text-slate-400"><%= lp.learning_path_items.count %> bài</span>
                  <% if lp.published? %>
                    <span class="text-[9px] px-1.5 py-0.5 bg-emerald-100 text-emerald-700 rounded-full font-bold">Đã phát hành</span>
                  <% else %>
                    <span class="text-[9px] px-1.5 py-0.5 bg-slate-100 text-slate-500 rounded-full">Nháp</span>
                  <% end %>
                  <% if lp.ai_generated? %>
                    <span class="text-[9px] px-1.5 py-0.5 bg-violet-100 text-violet-700 rounded-full font-bold">✨ AI</span>
                  <% end %>
                </div>
              </div>
              <%= link_to learning_path_path(lp), class: "text-[10px] px-2 py-1 bg-slate-100 rounded-lg text-slate-600 hover:bg-slate-200 flex-shrink-0" do %>Mở<% end %>
            </div>
          <% end %>
        <% else %>
          <div class="flex flex-col items-center justify-center h-full text-center py-6">
            <span class="text-3xl mb-2">🗺️</span>
            <p class="text-[12px] text-slate-400">Chưa có lộ trình nào</p>
            <%= link_to "+ Tạo lộ trình", new_learning_path_path, class: "text-[11px] text-indigo-600 mt-1 hover:underline" %>
          </div>
        <% end %>
      </div>
    </div>

  </div>

  <!-- Col 3: Right sidebar -->
  <div class="flex flex-col gap-4 min-h-0 overflow-hidden">

    <!-- AI Tools shortcuts -->
    <div class="bg-gradient-to-br from-violet-50 to-indigo-50 border border-violet-200 rounded-[10px] p-4 flex-shrink-0">
      <h2 class="text-[13px] font-bold text-slate-900 mb-3">✨ Công cụ AI</h2>
      <div class="space-y-2">
        <%= link_to ai_chat_page_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">💬</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800">AI Chat</div>
            <div class="text-[10px] text-slate-400">Trò chuyện với AI</div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <%= link_to ai_tutor_page_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">🎓</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800">AI Tutor</div>
            <div class="text-[10px] text-slate-400">Gia sư thông minh</div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <%= link_to new_content_outline_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">✍️</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800">Tạo nội dung</div>
            <div class="text-[10px] text-slate-400">Dàn ý, slide, bài học</div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <%= link_to new_document_summary_path, class: "flex items-center gap-2.5 px-3 py-2.5 bg-white rounded-xl hover:shadow-sm transition-all border border-violet-100 group" do %>
          <span class="text-base">📄</span>
          <div class="flex-1 min-w-0">
            <div class="text-[12px] font-semibold text-slate-800">Tóm tắt tài liệu</div>
            <div class="text-[10px] text-slate-400">PDF, Word, văn bản</div>
          </div>
          <svg class="w-3.5 h-3.5 text-slate-300 group-hover:text-violet-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
    </div>

    <!-- Recent feedback -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 flex flex-col flex-1 min-h-0">
      <div class="flex items-center justify-between mb-3 flex-shrink-0">
        <h2 class="text-[13px] font-bold text-slate-900">💬 Góp ý gần đây</h2>
      </div>
      <div class="overflow-y-auto flex-1 -mr-1 pr-1">
        <% if @recent_feedbacks.any? %>
          <% @recent_feedbacks.each do |fb| %>
            <div class="py-2 border-b border-slate-100 last:border-0">
              <p class="text-[11px] text-slate-700 line-clamp-2"><%= fb.content.truncate(70) %></p>
              <div class="flex items-center gap-1.5 mt-1">
                <% if fb.flagged? %><span class="text-[9px] text-amber-600 bg-amber-50 px-1.5 py-0.5 rounded">⚠ Cảnh báo</span><% end %>
                <% if fb.safe? && !fb.flagged? %><span class="text-[9px] text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded">An toàn</span><% end %>
                <span class="text-[9px] text-slate-400 ml-auto"><%= fb.created_at.strftime("%b %d") %></span>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="flex flex-col items-center justify-center h-full text-center py-6">
            <span class="text-2xl mb-2">💬</span>
            <p class="text-[12px] text-slate-400">Chưa có góp ý</p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- AI Credits -->
    <% if (sub = @subscription) %>
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 flex-shrink-0">
        <h2 class="text-[13px] font-bold text-slate-900 mb-2.5">🎯 AI Credits</h2>
        <div class="flex justify-between text-[11px] mb-1">
          <span class="text-slate-500">Đã dùng</span>
          <span class="font-bold text-slate-900"><%= sub.credit_used %> / <%= sub.max_ai_credits || "∞" %></span>
        </div>
        <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
          <div class="h-1.5 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-full transition-all" style="width: <%= 100 - sub.credit_percentage %>%"></div>
        </div>
        <div class="text-[10px] text-slate-400 mt-1.5">Làm mới <%= Date.current.end_of_month.strftime("%d/%m") %></div>
      </div>
    <% end %>

  </div>
</div>
