<% content_for :title, "Settings" %>
<div class="max-w-[700px]">
  <h1 class="text-[21px] font-extrabold text-slate-900 mb-6">⚙️ Workspace Settings</h1>
  <%= form_with model: @workspace, url: workspace_settings_path, method: :patch, local: true do |f| %>
    <div class="space-y-4">
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
        <h2 class="text-[14px] font-bold text-slate-900 mb-4">General</h2>
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Company Name</label>
            <%= f.text_field :name, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Language</label>
            <%= f.select :language, [["Tiếng Việt", "vi"], ["English", "en"]], {},
              class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Brand Color</label>
            <div class="flex gap-2 items-center">
              <%= f.color_field :brand_color, class: "w-12 h-10 border border-slate-200 rounded-lg cursor-pointer" %>
              <%= f.text_field :brand_color, class: "flex-1 px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none font-mono" %>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
        <h2 class="text-[14px] font-bold text-slate-900 mb-4">Security</h2>
        <div class="space-y-3">
          <div class="flex items-center justify-between py-2 border-b border-slate-100">
            <span class="text-[13px] text-slate-700">Require 2FA for all admins</span>
            <%= f.check_box :force_2fa, class: "w-4 h-4 accent-indigo-600 rounded" %>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Session timeout (days)</label>
            <%= f.number_field :session_timeout_days, min: 1, max: 365, class: "w-32 px-3 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
        </div>
      </div>
      <div class="flex gap-2">
        <%= f.submit "Save Settings", class: "px-6 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
