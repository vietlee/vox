<% content_for :title, t("settings.title") %>
<div class="max-w-[700px]">
  <div class="flex items-center gap-3 mb-6">
    <%= render "admin/shared/back_btn" %>
    <h1 class="text-[21px] font-extrabold text-slate-900">⚙️ <%= t("settings.workspace_settings") %></h1>
  </div>
  <%= form_with model: @workspace, url: workspace_settings_path, method: :patch, local: true do |f| %>
    <div class="space-y-4">
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
        <h2 class="text-[14px] font-bold text-slate-900 mb-4"><%= t("settings.general") %></h2>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("settings.company_name") %></label>
          <%= f.text_field :name, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
      </div>
      <!-- Email notifications -->
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
        <h2 class="text-[14px] font-bold text-slate-900 mb-1">🔔 <%= t("settings.notifications_section") %></h2>
        <p class="text-[12px] text-slate-400 mb-4"><%= I18n.locale == :vi ? "Áp dụng cho tất cả admin của workspace" : "Applies to all workspace admins" %></p>
        <div class="space-y-4">
          <label class="flex items-start gap-3 cursor-pointer group">
            <%= f.check_box :notify_on_new_feedback,
                  class: "mt-0.5 w-4 h-4 accent-indigo-600 flex-shrink-0 cursor-pointer" %>
            <div>
              <span class="text-[13px] font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">
                <%= t("settings.notify_on_new_feedback") %>
              </span>
              <p class="text-[12px] text-slate-400 mt-0.5"><%= t("settings.notify_on_new_feedback_desc") %></p>
            </div>
          </label>
          <label class="flex items-start gap-3 cursor-pointer group">
            <%= f.check_box :notify_on_new_response,
                  class: "mt-0.5 w-4 h-4 accent-indigo-600 flex-shrink-0 cursor-pointer" %>
            <div>
              <span class="text-[13px] font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">
                <%= t("settings.notify_on_new_response") %>
              </span>
              <p class="text-[12px] text-slate-400 mt-0.5"><%= t("settings.notify_on_new_response_desc") %></p>
            </div>
          </label>
        </div>
      </div>

      <div class="flex gap-2">
        <%= f.submit t("settings.save"), class: "px-6 py-2.5 bg-blue-500 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
      </div>
    </div>
  <% end %>

  <%# ── Danger Zone ──────────────────────────────────────────────────────── %>
  <div class="mt-10 bg-white rounded-[10px] border border-red-200 shadow-sm p-5">
    <h2 class="text-[14px] font-bold text-red-600 mb-1">
      ⚠️ <%= I18n.locale == :vi ? "Vùng nguy hiểm" : "Danger Zone" %>
    </h2>
    <p class="text-[12px] text-slate-500 mb-4">
      <%= I18n.locale == :vi ?
        "Xóa workspace sẽ xóa vĩnh viễn toàn bộ dữ liệu: surveys, votes, feedback, thành viên. Hành động này không thể hoàn tác." :
        "Deleting this workspace permanently removes all data: surveys, votes, feedback, members. This action cannot be undone." %>
    </p>
    <% if @is_last_owned_workspace %>
      <div class="flex items-start gap-2 bg-red-50 border border-red-200 rounded-lg px-3 py-2.5 mb-4">
        <span class="text-red-500 mt-0.5">⚠️</span>
        <p class="text-[12px] text-red-700 font-semibold">
          <%= I18n.locale == :vi ?
            "Đây là workspace duy nhất của bạn. Nếu xóa, bạn sẽ bị đăng xuất và tài khoản sẽ không còn workspace nào." :
            "This is your only workspace. Deleting it will sign you out and your account will have no workspaces." %>
        </p>
      </div>
    <% end %>
    <button type="button" onclick="document.getElementById('delete-workspace-modal').style.display='flex'"
      class="px-4 py-2 bg-red-600 text-white text-[13px] font-semibold rounded-lg hover:bg-red-700">
      🗑 <%= I18n.locale == :vi ? "Xóa workspace này" : "Delete this workspace" %>
    </button>
  </div>
</div>

<%# ── Confirmation Modal ────────────────────────────────────────────────── %>
<div id="delete-workspace-modal" style="display:none; position:fixed; inset:0; z-index:50; align-items:center; justify-content:center; background:rgba(0,0,0,0.5);">
  <div class="bg-white rounded-2xl shadow-2xl p-6 w-full max-w-md mx-4">
    <h3 class="text-[17px] font-extrabold text-slate-900 mb-2">
      <%= I18n.locale == :vi ? "Xác nhận xóa workspace" : "Confirm workspace deletion" %>
    </h3>
    <p class="text-[13px] text-slate-500 mb-4">
      <% if @is_last_owned_workspace %>
        <%= I18n.locale == :vi ?
          "Đây là workspace cuối cùng. Sau khi xóa bạn sẽ bị đăng xuất. Nhập tên workspace để xác nhận." :
          "This is your last workspace. You will be signed out after deletion. Type the workspace name to confirm." %>
      <% else %>
        <%= I18n.locale == :vi ?
          "Nhập tên workspace để xác nhận. Sau khi xóa bạn sẽ được chuyển sang workspace khác." :
          "Type the workspace name to confirm. You will be switched to another workspace after deletion." %>
      <% end %>
    </p>
    <p class="text-[12px] font-bold text-slate-700 mb-2">
      <%= I18n.locale == :vi ? "Tên workspace:" : "Workspace name:" %>
      <span class="text-red-600"><%= @workspace.name %></span>
    </p>
    <input type="text" id="confirm-workspace-name"
      placeholder="<%= @workspace.name %>"
      class="w-full px-3 py-2.5 border border-slate-300 rounded-lg text-[13px] mb-4 focus:border-red-400 outline-none">

    <%# Hidden form for DELETE — JS submits it when name matches %>
    <%= form_with url: workspace_settings_path, method: :delete, id: "delete-workspace-form", data: { turbo: false } do %>
    <% end %>
    <button type="button" id="confirm-delete-btn"
      onclick="document.getElementById('delete-workspace-form').submit()"
      style="opacity:0.4; cursor:not-allowed; pointer-events:none;"
      class="w-full py-2.5 bg-red-600 text-white text-[13px] font-bold rounded-lg border-0">
      🗑 <%= I18n.locale == :vi ? "Xóa vĩnh viễn" : "Delete permanently" %>
    </button>

    <button type="button" onclick="document.getElementById('delete-workspace-modal').style.display='none'"
      class="w-full mt-2 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg hover:bg-slate-200">
      <%= I18n.locale == :vi ? "Hủy" : "Cancel" %>
    </button>
  </div>
</div>

<script>
  (function(){
    var input = document.getElementById('confirm-workspace-name');
    var btn   = document.getElementById('confirm-delete-btn');
    var name  = <%= raw @workspace.name.to_json %>;
    if (!input || !btn) return;
    input.addEventListener('input', function(){
      var match = this.value.trim() === name;
      btn.style.opacity        = match ? '1'            : '0.4';
      btn.style.cursor         = match ? 'pointer'      : 'not-allowed';
      btn.style.pointerEvents  = match ? 'auto'         : 'none';
    });
  })();
</script>
