<% content_for :title, t("quiz.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight">📋 <%= t("quiz.title") %></h1>
        <p class="text-[12px] text-slate-500 mt-0.5"><%= @quiz_sets.count %> bộ câu hỏi</p>
      </div>
    </div>
    <%= link_to new_quiz_set_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors" do %>
      + <%= t("quiz.new") %>
    <% end %>
  </div>
</div>

<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
        <input id="qs-search" type="text" placeholder="Tìm kiếm bộ câu hỏi..."
          class="w-full pl-8 pr-3 py-1.5 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white"
          oninput="filterRows('qs-search','qs-row','qs-no-results')">
      </div>
      <span class="text-[11px] text-slate-400 ml-auto"><%= @quiz_sets.count %> bộ câu hỏi</span>
    </div>

    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @quiz_sets.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Tên bộ câu hỏi</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Trạng thái</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Câu hỏi</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Lượt làm</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Tạo lúc</th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <tr id="qs-no-results" class="hidden">
              <td colspan="6" class="px-4 py-10 text-center text-[13px] text-slate-400">Không tìm thấy kết quả</td>
            </tr>
            <% @quiz_sets.each do |qs| %>
              <tr class="qs-row border-b border-slate-200 hover:bg-white/70 transition-colors"
                  data-title="<%= qs.title.downcase %>">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <%= link_to qs.title, edit_quiz_set_path(qs),
                        class: "text-[13px] font-semibold text-slate-800 hover:text-indigo-600 transition-colors",
                        data: { turbo: false } %>
                    <% if qs.ai_generated? %>
                      <span class="text-[9px] px-1.5 py-0.5 rounded-full font-bold text-white" style="background:linear-gradient(135deg,#7c3aed,#4f46e5);">✦ AI</span>
                    <% end %>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <% if qs.published? %>
                    <span class="text-[11px] font-bold text-emerald-600">Đang mở</span>
                  <% else %>
                    <span class="text-[11px] font-semibold text-slate-400">Bản nháp</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-[13px] text-slate-600"><%= qs.question_count %></td>
                <td class="px-4 py-3 text-[13px] text-slate-600"><%= qs.attempt_count %></td>
                <td class="px-4 py-3 text-[12px] text-slate-400"><%= qs.created_at.strftime("%d/%m %H:%M") %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1 justify-end">
                    <% if qs.published? %>
                      <button onclick="copyLink('<%= quiz_url(qs.share_token) %>')" title="Sao chép link"
                              class="text-[12px] text-slate-500 hover:text-indigo-600 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer">Link</button>
                      <%= link_to "Kết quả", results_quiz_set_path(qs),
                          class: "text-[12px] text-slate-500 hover:text-indigo-600 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors" %>
                    <% end %>
                    <%= link_to "Sửa", edit_quiz_set_path(qs),
                        class: "text-[12px] text-slate-500 hover:text-indigo-600 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors",
                        data: { turbo: false } %>
                    <button type="button" onclick="confirmDelete('<%= quiz_set_path(qs) %>', '<%= j qs.title %>')"
                            class="text-[12px] text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors border-0 bg-transparent cursor-pointer">Xóa</button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="py-20 text-center">
          <div class="text-5xl mb-4">📋</div>
          <h3 class="text-[15px] font-bold text-slate-700 mb-2"><%= t("quiz.empty_title") %></h3>
          <p class="text-[13px] text-slate-400 mb-5"><%= t("quiz.empty_desc") %></p>
          <%= link_to t("quiz.new"), new_quiz_set_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div id="generic-delete-modal" style="display:none; position:fixed; inset:0; z-index:60; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.5);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.18); width:100%; max-width:380px; padding:28px 24px;">
    <div style="width:48px; height:48px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg style="width:24px;height:24px;" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 style="font-size:16px; font-weight:800; color:#1E293B; text-align:center; margin:0 0 8px;">Xóa bộ câu hỏi?</h3>
    <p id="generic-delete-desc" style="font-size:13px; color:#64748B; text-align:center; margin:0 0 20px;"></p>
    <div style="display:flex; gap:8px;">
      <button id="generic-delete-btn" onclick="executeGenericDelete()"
              style="flex:1; padding:11px; background:#EF4444; color:#fff; font-weight:700; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Xóa</button>
      <button onclick="document.getElementById('generic-delete-modal').style.display='none'"
              style="flex:1; padding:11px; background:#F1F5F9; color:#475569; font-weight:600; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Hủy</button>
    </div>
  </div>
</div>

<div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[13px] font-semibold px-4 py-2 rounded-xl shadow-lg hidden z-50">
  <%= t("quiz.link_copied") %>
</div>

<script>
let _deletePath = null;
function confirmDelete(path, title) {
  _deletePath = path;
  document.getElementById('generic-delete-desc').textContent = 'Bạn sắp xóa "' + title + '". Hành động này không thể hoàn tác.';
  document.getElementById('generic-delete-modal').style.display = 'flex';
}
window.executeGenericDelete = function() {
  if (!_deletePath) return;
  const btn = document.getElementById('generic-delete-btn'); btn.disabled = true; btn.textContent = '...';
  const f = document.createElement('form'); f.method = 'POST'; f.action = _deletePath;
  const m = document.createElement('input'); m.type='hidden'; m.name='_method'; m.value='delete';
  const c = document.createElement('input'); c.type='hidden'; c.name='authenticity_token'; c.value=document.querySelector('meta[name="csrf-token"]').content;
  f.appendChild(m); f.appendChild(c); document.body.appendChild(f); f.submit();
};
function copyLink(url) {
  navigator.clipboard.writeText(url).then(function() {
    var t = document.getElementById('copy-toast'); t.classList.remove('hidden');
    setTimeout(function() { t.classList.add('hidden'); }, 2000);
  });
}
function filterRows(searchId, rowClass, noResultId) {
  var q = document.getElementById(searchId).value.toLowerCase();
  var rows = document.querySelectorAll('.' + rowClass);
  var found = 0;
  rows.forEach(function(r) { var show = !q || (r.dataset.title||'').includes(q); r.style.display = show ? '' : 'none'; if(show) found++; });
  document.getElementById(noResultId).classList.toggle('hidden', found > 0 || !q);
}
</script>
