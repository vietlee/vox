<% content_for :title, t("quiz.title") %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-[22px] font-extrabold text-slate-900"><%= t("quiz.title") %></h1>
    <p class="text-[13px] text-slate-500 mt-0.5"><%= t("quiz.subtitle") %></p>
  </div>
  <%= link_to new_quiz_set_path, class: "flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
    <%= t("quiz.new") %>
  <% end %>
</div>

<% if @quiz_sets.empty? %>
  <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
    <div class="text-5xl mb-4">📚</div>
    <h3 class="text-[16px] font-bold text-slate-700 mb-2"><%= t("quiz.empty_title") %></h3>
    <p class="text-[13px] text-slate-400 mb-6"><%= t("quiz.empty_desc") %></p>
    <%= link_to t("quiz.new"), new_quiz_set_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" %>
  </div>
<% else %>
  <div class="space-y-3">
    <% @quiz_sets.each do |qs| %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 flex items-center gap-4">
        <!-- Status icon -->
        <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 <%= qs.published? ? 'bg-emerald-50' : 'bg-slate-100' %>">
          <span class="text-xl"><%= qs.ai_generated? ? "🤖" : "📝" %></span>
        </div>

        <!-- Info -->
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5">
            <%= link_to qs.title, edit_quiz_set_path(qs), class: "text-[14px] font-bold text-slate-900 hover:text-indigo-600 truncate transition-colors", data: { turbo: false } %>
            <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold <%= qs.published? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
              <%= qs.published? ? t("quiz.status_published") : t("quiz.status_draft") %>
            </span>
            <% if qs.ai_generated? %>
              <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-violet-100 text-violet-700">AI</span>
            <% end %>
          </div>
          <div class="flex items-center gap-3 text-[12px] text-slate-400">
            <span>📋 <%= t("quiz.n_questions", count: qs.question_count) %></span>
            <span>👥 <%= t("quiz.n_attempts", count: qs.attempt_count) %></span>
            <% if qs.avg_score %>
              <span>⭐ TB <%= qs.avg_score %>%</span>
            <% end %>
            <span><%= qs.created_at.strftime("%d/%m/%Y") %></span>
          </div>
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-2 flex-shrink-0">
          <% if qs.published? %>
            <% quiz_url = quiz_url(qs.share_token) %>
            <button onclick="copyLink('<%= quiz_url %>')"
                    title="<%= t('quiz.copy_link') %>"
                    class="p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            </button>
            <%= link_to results_quiz_set_path(qs), title: t("quiz.results"),
                class: "p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            <% end %>
          <% end %>
          <%= link_to edit_quiz_set_path(qs), title: t("common.edit"),
              class: "p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors",
              data: { turbo: false } do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          <% end %>
          <% if qs.published? %>
            <%= button_to unpublish_quiz_set_path(qs), method: :patch, title: t("quiz.unpublish"),
                class: "p-2 text-slate-400 hover:text-amber-600 hover:bg-amber-50 rounded-lg transition-colors border-0 bg-transparent cursor-pointer" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
            <% end %>
          <% else %>
            <% if qs.question_count > 0 %>
              <%= button_to publish_quiz_set_path(qs), method: :patch, title: t("quiz.publish"),
                  class: "p-2 text-slate-400 hover:text-emerald-600 hover:bg-emerald-50 rounded-lg transition-colors border-0 bg-transparent cursor-pointer" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
            <% end %>
          <% end %>
          <button type="button" onclick="confirmDeleteQuizSet('<%= quiz_set_path(qs) %>', '<%= j qs.title %>')"
                  class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors border-0 bg-transparent cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[13px] font-semibold px-4 py-2 rounded-xl shadow-lg hidden z-50">
  <%= t("quiz.link_copied") %>
</div>

<!-- Delete confirm modal -->
<div id="qs-delete-modal" style="display:none; position:fixed; inset:0; z-index:60; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.5);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.18); width:100%; max-width:380px; padding:28px 24px;">
    <div style="width:48px; height:48px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg style="width:24px;height:24px;color:#EF4444;" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 style="font-size:16px; font-weight:800; color:#1E293B; text-align:center; margin:0 0 8px;"><%= t("quiz.confirm_delete_title") %></h3>
    <p id="qs-delete-desc" style="font-size:13px; color:#64748B; text-align:center; margin:0 0 20px;"></p>
    <div style="display:flex; gap:8px;">
      <button id="qs-delete-confirm-btn" onclick="executeDeleteQuizSet()"
              style="flex:1; padding:11px; background:#EF4444; color:#fff; font-weight:700; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">
        <%= t("common.delete") %>
      </button>
      <button onclick="closeDeleteQuizSetModal()"
              style="flex:1; padding:11px; background:#F1F5F9; color:#475569; font-weight:600; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">
        <%= t("common.cancel") %>
      </button>
    </div>
  </div>
</div>

<script>
let _pendingDeletePath = null;

function confirmDeleteQuizSet(path, title) {
  _pendingDeletePath = path;
  document.getElementById('qs-delete-desc').textContent =
    '<%= j t("quiz.confirm_delete_desc") %>'.replace('%{title}', title);
  document.getElementById('qs-delete-modal').style.display = 'flex';
}

function closeDeleteQuizSetModal() {
  document.getElementById('qs-delete-modal').style.display = 'none';
  _pendingDeletePath = null;
}

function executeDeleteQuizSet() {
  if (!_pendingDeletePath) return;
  const btn = document.getElementById('qs-delete-confirm-btn');
  btn.disabled = true;
  btn.textContent = '...';
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = _pendingDeletePath;
  const method = document.createElement('input');
  method.type = 'hidden'; method.name = '_method'; method.value = 'delete';
  const csrf = document.createElement('input');
  csrf.type = 'hidden'; csrf.name = 'authenticity_token';
  csrf.value = document.querySelector('meta[name="csrf-token"]').content;
  form.appendChild(method);
  form.appendChild(csrf);
  document.body.appendChild(form);
  form.submit();
}

function copyLink(url) {
  navigator.clipboard.writeText(url).then(function() {
    var t = document.getElementById('copy-toast');
    t.classList.remove('hidden');
    setTimeout(function() { t.classList.add('hidden'); }, 2000);
  });
}
</script>
