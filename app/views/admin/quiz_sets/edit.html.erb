<% content_for :title, @quiz_set.title %>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache, no-preview">
  <script>
    MathJax = {
      tex: { inlineMath: [['$', '$'], ['\\(', '\\)']], displayMath: [['$$', '$$'], ['\\[', '\\]']] },
      options: { skipHtmlTags: ['script','noscript','style','textarea','pre','input'] }
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
<% end %>

<div class="flex items-center gap-3 mb-4">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[18px] font-extrabold text-slate-900 truncate"><%= @quiz_set.title %></h1>
  </div>
  <div class="flex items-center gap-2 flex-wrap flex-shrink-0">
    <% if @quiz_set.published? %>
      <span class="inline-flex items-center gap-1 px-2.5 py-1.5 rounded-[7px] text-[12px] font-bold bg-emerald-500 text-white"><%= t("quiz.status_published") %></span>
      <% quiz_url = quiz_url(@quiz_set.share_token) %>
      <button onclick="copyLink('<%= quiz_url %>')"
              class="inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:border-[#1e3a5f] hover:text-white text-slate-700 transition-colors whitespace-nowrap">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
        <%= t("quiz.copy_link") %>
      </button>
      <%= button_to unpublish_quiz_set_path(@quiz_set), method: :patch,
          class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:text-white hover:border-[#1e3a5f] text-slate-700 cursor-pointer transition-colors whitespace-nowrap" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/></svg>
        <%= t("quiz.unpublish") %>
      <% end %>
    <% else %>
      <span class="inline-flex items-center px-2.5 py-1.5 rounded-[7px] text-[12px] font-bold bg-slate-100 text-slate-500"><%= t("quiz.status_draft") %></span>
      <% if @questions.any? %>
        <%= button_to publish_quiz_set_path(@quiz_set), method: :patch,
            class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-emerald-600 hover:bg-emerald-700 text-white cursor-pointer transition-colors whitespace-nowrap border-0" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          <%= t("quiz.publish") %>
        <% end %>
      <% end %>
    <% end %>
    <%= link_to results_quiz_set_path(@quiz_set),
        class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:text-white hover:border-[#1e3a5f] text-slate-700 transition-colors whitespace-nowrap" do %>
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      <%= t("quiz.results") %> (<%= @quiz_set.attempt_count %>)
    <% end %>
    <%= render "admin/shared/assign_learner_modal",
               resource_type: "quiz",
               assign_url: assign_learner_quiz_set_path(@quiz_set),
               assignments_url: learner_assignments_quiz_set_path(@quiz_set),
               remove_assignment_url: remove_assignment_quiz_set_path(@quiz_set),
               resource_title: @quiz_set.title,
               published: @quiz_set.published? %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

  <!-- Left: Question list -->
  <div class="lg:col-span-2 space-y-3">

    <!-- AI Generate panel -->
    <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 shadow-sm">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-lg">✨</span>
        <h3 class="text-[13px] font-bold text-slate-800"><%= t("quiz.ai_generate_title") %></h3>
        <span class="text-[10px] px-1.5 py-0.5 bg-[#1e3a5f] text-white rounded-full font-bold">5 credits</span>
      </div>
      <p class="text-[12px] text-slate-500 mb-3"><%= t("quiz.ai_generate_desc") %></p>

      <!-- Yêu cầu của bạn — luôn hiển thị -->
      <div class="mb-3">
        <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1.5">
          💬 <%= t("quiz.ai_custom_prompt") %> <span class="font-normal text-slate-400 normal-case" id="ai-prompt-optional-label">(<%= t("quiz.optional") %>)</span>
        </label>
        <div id="ai-prompt-quill-wrap" style="border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#fff;">
          <div id="ai-prompt-quill-editor" style="min-height:80px;font-size:13px;"></div>
        </div>
        <div id="ai-empty-error" class="hidden mt-1.5 text-[11px] text-red-500 font-medium">
          ⚠️ Vui lòng nhập yêu cầu hoặc upload tài liệu (hoặc cả hai) để AI tạo câu hỏi.
        </div>
      </div>

      <div id="ai-upload-area">
        <!-- Drop zone -->
        <div id="ai-drop-zone"
             onclick="document.getElementById('ai-file-input').click()"
             ondragover="aiDragOver(event)" ondragleave="aiDragLeave(event)" ondrop="aiDrop(event)"
             class="border-2 border-dashed border-slate-300 hover:border-[#1e3a5f] bg-white rounded-xl px-4 py-4 text-center cursor-pointer transition-colors">
          <div class="text-xl mb-1">📂</div>
          <p class="text-[12px] font-semibold text-slate-600 transition-colors" id="ai-drop-label"><%= t("quiz.drop_or_click") %></p>
          <p class="text-[11px] text-slate-400 mt-0.5 transition-colors"><%= t("quiz.ai_file_hint") %></p>
          <input type="file" id="ai-file-input" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg"
                 class="hidden" multiple onchange="aiFileSelected(this)">
        </div>
        <!-- Selected files list (shown after files chosen) -->
        <div id="ai-file-selected" class="hidden mt-2 space-y-1.5">
          <div id="ai-file-list"></div>
          <button onclick="document.getElementById('ai-file-input').click()" class="text-[11px] text-slate-500 hover:text-[#1e3a5f] font-semibold transition-colors">+ Thêm file</button>
        </div>
      </div>

      <!-- Essay toggle -->
      <div class="flex items-center gap-2 mt-3">
        <label class="flex items-center gap-2 cursor-pointer select-none">
          <div class="relative">
            <input type="checkbox" id="ai-include-essay" class="sr-only peer">
            <div class="w-9 h-5 bg-slate-200 peer-checked:bg-[#1e3a5f] rounded-full transition-colors"></div>
            <div class="absolute top-0.5 left-0.5 w-4 h-4 bg-white rounded-full shadow transition-transform peer-checked:translate-x-4"></div>
          </div>
          <span class="text-[12px] font-semibold text-slate-600">✍️ Bao gồm câu tự luận (essay)</span>
        </label>
      </div>

      <!-- Count mode + generate (luôn hiển thị) -->
      <div class="flex items-center gap-2 flex-wrap mt-3">
        <span class="text-[11px] font-bold text-slate-500 uppercase tracking-wide flex-shrink-0"><%= t("quiz.questions_count") %>:</span>
        <div class="flex rounded-lg border border-slate-200 bg-white overflow-hidden text-[12px] font-semibold flex-shrink-0">
          <button id="mode-auto" onclick="setCountMode('auto')"
                  class="px-3 py-1.5 bg-[#1e3a5f] text-white transition-colors whitespace-nowrap">
            <%= t("quiz.count_mode_auto") %>
          </button>
          <button id="mode-custom" onclick="setCountMode('custom')"
                  class="px-3 py-1.5 text-slate-500 hover:bg-slate-50 transition-colors whitespace-nowrap">
            <%= t("quiz.count_mode_custom") %>
          </button>
        </div>
        <div id="ai-count-wrap" class="hidden items-center gap-1 flex-shrink-0">
          <input type="number" id="ai-count" value="10" min="3" max="50"
                 class="w-16 px-2 py-1.5 border border-slate-300 rounded-lg text-[13px] font-bold text-center text-[#1e3a5f] outline-none focus:border-[#1e3a5f]">
          <span class="text-[11px] text-slate-400"><%= t("quiz.count_unit") %></span>
        </div>
        <button onclick="runAiGenerate()" id="ai-generate-btn"
                class="ml-auto px-4 py-1.5 bg-[#1e3a5f] hover:bg-[#16304f] text-white text-[12px] font-bold rounded-lg transition-colors whitespace-nowrap flex-shrink-0">
          ✨ <%= t("quiz.generate") %>
        </button>
      </div>
      <p id="ai-count-hint" class="text-[11px] text-slate-400 mt-1.5"><%= t("quiz.count_mode_auto_hint") %></p>
      <div id="ai-progress" class="hidden"></div>
      <div id="ai-error" class="hidden mt-2 text-[12px] text-red-600 bg-red-50 rounded-lg px-3 py-2"></div>
    </div>

    <!-- Questions -->
    <div class="flex items-center justify-between">
      <h2 class="text-[14px] font-bold text-slate-700">
        📋 <%= t("quiz.questions") %> (<span id="q-count"><%= @questions.count %></span>)
      </h2>
      <button onclick="addQuestion()"
              class="flex items-center gap-1.5 px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[12px] font-bold rounded-lg transition-colors">
        + <%= t("quiz.add_question") %>
      </button>
    </div>

    <div id="questions-list" class="space-y-3">
      <% @questions.each_with_index do |q, i| %>
        <%= render "question_row", question: q, quiz_set: @quiz_set, index: i %>
      <% end %>
    </div>

    <% if @questions.empty? %>
      <div id="empty-state" class="bg-white rounded-xl border border-dashed border-slate-300 p-8 text-center">
        <div class="text-3xl mb-2">📝</div>
        <p class="text-[13px] text-slate-400"><%= t("quiz.no_questions") %></p>
      </div>
    <% end %>

  </div>

  <!-- Right: Settings -->
  <div class="space-y-4">
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
      <h3 class="text-[13px] font-bold text-slate-700 mb-3">⚙️ <%= t("quiz.settings") %></h3>
      <%= form_with model: @quiz_set, url: quiz_set_path(@quiz_set), method: :patch, local: true, id: "quiz-settings-form", class: "space-y-3" do |f| %>
        <div>
          <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1"><%= t("quiz.field_title") %></label>
          <%= f.text_field :title, class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1"><%= t("quiz.time_limit") %></label>
          <%= f.number_field :time_limit_minutes, min: 0, placeholder: t("quiz.no_limit"),
              class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
        </div>
        <!-- Total score -->
        <div>
          <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1">Tổng điểm bài thi</label>
          <div class="flex items-center gap-2">
            <input type="number" id="total-score-field" name="quiz_set[total_score]" min="1"
                 value="<%= @quiz_set.computed_total_score %>"
                 class="flex-1 px-2.5 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-[#1e3a5f] outline-none font-bold text-slate-700">
            <button type="button" onclick="distributePoints()" id="distribute-btn"
                    class="flex-shrink-0 px-2.5 py-2 bg-[#1e3a5f] hover:bg-[#16304f] text-white text-[11px] font-bold rounded-lg transition-colors whitespace-nowrap">
              ✨ Phân điểm AI
            </button>
          </div>
          <p class="text-[11px] text-slate-400 mt-1">Nhập tổng điểm rồi nhấn "Phân điểm AI" để tự động chia điểm cho từng câu theo độ khó.</p>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1"><%= t("quiz.passing_score_label") %></label>
          <div class="flex gap-1.5 mb-1.5">
            <button type="button" id="ps-type-percent" onclick="setPassingScoreType('percent')"
                    class="px-2.5 py-1 text-[11px] font-bold rounded-lg border-2 transition-all <%= @quiz_set.passing_score_type == 'points' ? 'border-slate-200 text-slate-500' : 'border-[#1e3a5f] bg-[#eef3fa] text-[#1e3a5f]' %>">
              %
            </button>
            <button type="button" id="ps-type-points" onclick="setPassingScoreType('points')"
                    class="px-2.5 py-1 text-[11px] font-bold rounded-lg border-2 transition-all <%= @quiz_set.passing_score_type == 'points' ? 'border-[#1e3a5f] bg-[#eef3fa] text-[#1e3a5f]' : 'border-slate-200 text-slate-500' %>">
              Điểm
            </button>
          </div>
          <div class="relative">
            <%= f.number_field :passing_score, min: 1, value: @quiz_set.passing_score || 80,
                class: "w-full px-2.5 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-[#1e3a5f] outline-none pr-10" %>
            <span id="ps-unit-label" class="absolute right-2.5 top-1/2 -translate-y-1/2 text-[12px] text-slate-400 font-semibold">
              <%= @quiz_set.passing_score_type == 'points' ? 'đ' : '%' %>
            </span>
          </div>
          <%= f.hidden_field :passing_score_type, id: "passing_score_type_hidden", value: @quiz_set.passing_score_type || 'percent' %>
          <p class="text-[11px] text-slate-400 mt-1"><%= t("quiz.passing_score_hint") %></p>
        </div>
        <!-- Result mode -->
        <div>
          <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1.5"><%= t("quiz.result_mode_label") %></label>
          <% has_essay = @quiz_set.has_essay? %>
          <% if has_essay %>
            <div class="flex items-center gap-2 px-3 py-2 bg-amber-50 border border-amber-200 rounded-lg mb-1.5">
              <span class="text-[13px]">✍️</span>
              <p class="text-[11px] text-amber-700 font-semibold">Bài có câu tự luận → kết quả luôn gửi sau khi chấm.</p>
            </div>
          <% end %>
          <div class="grid grid-cols-2 gap-1.5" id="result-mode-cards">
            <div id="rmode-immediate"
                 onclick="selectResultMode('result_immediate')"
                 class="flex flex-col items-center gap-1 p-2.5 rounded-lg border-2 transition-all select-none
                   <%= has_essay ? 'border-slate-200 opacity-40 cursor-not-allowed' : 'cursor-pointer hover:border-slate-300' %>
                   <%= @quiz_set.result_immediate? && !has_essay ? 'border-[#1e3a5f] bg-[#eef3fa]' : 'border-slate-200' %>">
              <span class="text-[18px]">⚡</span>
              <span class="text-[11px] font-bold text-slate-700"><%= t("quiz.result_mode_immediate") %></span>
              <span class="text-[10px] text-slate-400 text-center leading-tight"><%= t("quiz.result_mode_immediate_desc") %></span>
            </div>
            <div id="rmode-later"
                 onclick="selectResultMode('result_later')"
                 class="flex flex-col items-center gap-1 p-2.5 rounded-lg border-2 cursor-pointer transition-all select-none
                   <%= @quiz_set.result_later? || has_essay ? 'border-[#1e3a5f] bg-[#eef3fa]' : 'border-slate-200 hover:border-slate-300' %>">
              <span class="text-[18px]">📧</span>
              <span class="text-[11px] font-bold text-slate-700"><%= t("quiz.result_mode_later") %></span>
              <span class="text-[10px] text-slate-400 text-center leading-tight"><%= t("quiz.result_mode_later_desc") %></span>
            </div>
          </div>
          <%= f.hidden_field :result_mode, id: "result_mode_hidden", value: @quiz_set.result_later? || has_essay ? 'result_later' : @quiz_set.result_mode %>
        </div>
        <div class="space-y-2">
          <label class="flex items-center gap-2 text-[13px] text-slate-600">
            <%= f.check_box :allow_retake, class: "w-4 h-4 rounded" %>
            <%= t("quiz.allow_retake") %>
          </label>
          <%= f.hidden_field :show_answers, value: "1" %>
        </div>
        <%= f.submit t("common.save"), class: "w-full py-2 bg-[#1e3a5f] hover:bg-[#16304f] text-white text-[13px] font-bold rounded-lg cursor-pointer transition-colors" %>
      <% end %>
    </div>

    <!-- Share link -->
    <% if @quiz_set.published? %>
      <% share_url = quiz_url(@quiz_set.share_token) %>
      <% short_url = short_url_for(share_url, workspace: current_workspace) %>
      <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-4 space-y-3">
        <h3 class="text-[12px] font-bold text-emerald-800">🔗 <%= t("quiz.share_link") %></h3>

        <!-- Short link -->
        <div>
          <p class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Short link</p>
          <div class="flex items-center gap-1.5">
            <div class="flex-1 bg-white border border-emerald-200 rounded-lg px-2.5 py-1.5 text-[12px] text-slate-700 font-mono truncate">
              <%= short_url %>
            </div>
            <button onclick="copyLink('<%= short_url %>')"
                    class="flex-shrink-0 px-2.5 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-[11px] font-bold rounded-lg transition-colors">
              Copy
            </button>
          </div>
        </div>

        <!-- Full URL -->
        <div>
          <p class="text-[10px] font-bold text-emerald-600 uppercase tracking-wide mb-1">Full URL</p>
          <div class="bg-white border border-emerald-200 rounded-lg px-2.5 py-1.5 text-[11px] text-slate-500 break-all">
            <%= share_url %>
          </div>
        </div>

      </div>
    <% end %>

    <!-- QR Code — same style as survey -->
    <% if @quiz_set.published? && @quiz_set.qr_code %>
      <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4 text-center">
        <h3 class="text-[13px] font-bold text-slate-900 mb-3">QR Code</h3>
        <img id="quiz-qr-img" src="<%= qr_image_path(@quiz_set.qr_code.token) %>" alt="QR Code" class="mx-auto w-36 h-36 rounded-lg" crossorigin="anonymous">
        <p class="text-[11px] text-slate-400 mt-2 mb-3"><%= @quiz_set.qr_code.scan_count %> lượt scan</p>
        <div class="flex gap-2 justify-center">
          <button onclick="copyQrImage(document.getElementById('quiz-qr-img'), this)"
                  class="vox-copy-btn">
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            <span>Copy QR</span>
          </button>
          <a href="<%= qr_image_path(@quiz_set.qr_code.token) %>" download="quiz-qr.png"
             class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-600 text-[11px] font-semibold rounded-lg hover:bg-slate-200 transition-colors">
            ⬇ Tải QR
          </a>
        </div>
      </div>
    <% end %>
  </div>
</div>

<!-- Add Question Modal -->
<div id="add-q-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-4" style="background:rgba(15,23,42,0.5)">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-lg p-6 max-h-[90vh] overflow-y-auto">
    <h3 class="text-[16px] font-bold text-slate-900 mb-4">+ <%= t("quiz.add_question") %></h3>

    <!-- Question type selector -->
    <div class="mb-4">
      <label class="block text-[11px] font-bold text-slate-500 uppercase mb-2"><%= t("quiz.question_type") %></label>
      <div class="grid grid-cols-2 gap-2">
        <button onclick="selectQType('multiple_choice', false)" id="qtype-mc1"
                class="group qtype-btn flex items-center gap-2 px-3 py-2.5 rounded-xl border-2 border-[#1e3a5f] bg-[#eef3fa] text-[#1e3a5f] text-[12px] font-bold transition-all text-left">
          <span class="text-lg">🔘</span>
          <div>
            <div class="font-bold"><%= t("quiz.type_mc") %></div>
            <div class="text-[10px] font-normal text-[#4a7fa8] group-hover:text-white"><%= t("quiz.type_mc_hint") %></div>
          </div>
        </button>
        <button onclick="selectQType('multiple_choice', true)" id="qtype-mc-multi"
                class="group qtype-btn flex items-center gap-2 px-3 py-2.5 rounded-xl border-2 border-slate-200 text-slate-600 text-[12px] font-bold transition-all text-left hover:border-[#1e3a5f] hover:bg-[#1e3a5f] hover:text-white">
          <span class="text-lg">☑️</span>
          <div>
            <div class="font-bold"><%= t("quiz.type_mc_multi") %></div>
            <div class="text-[10px] font-normal text-slate-400 group-hover:text-white"><%= t("quiz.type_mc_multi_hint") %></div>
          </div>
        </button>
        <button onclick="selectQType('true_false', false)" id="qtype-tf"
                class="group qtype-btn flex items-center gap-2 px-3 py-2.5 rounded-xl border-2 border-slate-200 text-slate-600 text-[12px] font-bold transition-all text-left hover:border-[#1e3a5f] hover:bg-[#1e3a5f] hover:text-white">
          <span class="text-lg">✅</span>
          <div>
            <div class="font-bold"><%= t("quiz.type_tf") %></div>
            <div class="text-[10px] font-normal text-slate-400 group-hover:text-white"><%= t("quiz.type_tf_hint") %></div>
          </div>
        </button>
        <button onclick="selectQType('essay', false)" id="qtype-essay"
                class="group qtype-btn flex items-center gap-2 px-3 py-2.5 rounded-xl border-2 border-slate-200 text-slate-600 text-[12px] font-bold transition-all text-left hover:border-[#1e3a5f] hover:bg-[#1e3a5f] hover:text-white">
          <span class="text-lg">📝</span>
          <div>
            <div class="font-bold">Tự luận (Essay)</div>
            <div class="text-[10px] font-normal text-slate-400 group-hover:text-white">Câu hỏi mở, AI chấm điểm</div>
          </div>
        </button>
      </div>
    </div>

    <!-- Essay rubric (chỉ hiện khi type = essay) -->
    <div id="modal-essay-section" class="hidden space-y-2">
      <div>
        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Tiêu chí chấm điểm (Rubric)</label>
        <div id="rubric-quill-wrap" style="border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#fff;">
          <div id="rubric-quill-editor" style="min-height:80px;font-size:13px;"></div>
        </div>
      </div>
    </div>

    <div class="space-y-3">
      <div>
        <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1"><%= t("quiz.question_text") %> *</label>
        <textarea id="new-q-text" rows="3" placeholder="<%= t('quiz.question_placeholder') %>"
                  class="w-full px-3 py-2 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none resize-none"></textarea>
      </div>

      <!-- Options section (hidden for short_answer) -->
      <div id="modal-opts-section">
        <div class="flex items-center justify-between mb-1.5">
          <label class="text-[11px] font-bold text-slate-500 uppercase"><%= t("quiz.options") %> *</label>
          <span id="modal-opts-hint-label" class="text-[10px] text-slate-400"><%= t("quiz.options_hint_single") %></span>
        </div>
        <!-- Option list -->
        <div id="modal-opts-list" class="space-y-1.5 mb-2"></div>
        <!-- Add option input (hidden for true_false) -->
        <div id="modal-add-opt-row" class="flex gap-2">
          <input type="text" id="modal-opt-input" placeholder="<%= t('quiz.option_add_placeholder') %>"
                 class="flex-1 px-3 py-2 border border-slate-200 rounded-xl text-[13px] focus:border-indigo-500 outline-none"
                 onkeydown="if(event.key==='Enter'){event.preventDefault();addModalOption()}">
          <button onclick="addModalOption()"
                  class="px-3 py-2 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-500 text-[12px] font-semibold rounded-xl transition-colors flex-shrink-0">
            + <%= t("quiz.add_option") %>
          </button>
        </div>
        <p id="modal-opts-error" class="hidden text-[11px] text-red-500 mt-1"></p>
      </div>

      <div class="flex gap-3">
        <div class="flex-1">
          <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1"><%= t("quiz.explanation") %></label>
          <input type="text" id="new-q-explanation" placeholder="<%= t('quiz.explanation_placeholder') %>"
                 class="w-full px-3 py-2 border border-slate-200 rounded-xl text-[13px] focus:border-[#1e3a5f] outline-none">
        </div>
        <div class="w-24 flex-shrink-0">
          <label class="block text-[11px] font-bold text-slate-500 uppercase mb-1">Điểm</label>
          <input type="number" id="new-q-points" value="1" min="1"
                 class="w-full px-3 py-2 border border-slate-200 rounded-xl text-[13px] focus:border-[#1e3a5f] outline-none text-center font-bold">
        </div>
      </div>
    </div>
    <div class="flex gap-2 mt-4">
      <button onclick="submitNewQuestion()"
              class="flex-1 py-2.5 bg-[#1e3a5f] hover:bg-[#16304f] text-white text-[13px] font-bold rounded-xl transition-colors">
        <%= t("quiz.add_question") %>
      </button>
      <button onclick="closeAddModal()"
              class="px-4 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-xl">
        <%= t("common.cancel") %>
      </button>
    </div>
  </div>
</div>

<div id="copy-toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 bg-slate-800 text-white text-[13px] px-4 py-2 rounded-xl shadow-lg hidden z-50">
  <%= t("quiz.link_copied") %>
</div>

<!-- AI Loading Overlay -->
<div id="ai-loading-overlay"
     style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center;
            background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center;
              box-shadow:0 20px 60px rgba(0,0,0,0.22); max-width:320px; width:90%; position:relative;">
    <button onclick="minimizeAiTask()" title="Thu nhỏ — tiếp tục làm việc khác" data-navy-hover="1"
            style="position:absolute;top:12px;right:12px;display:flex;align-items:center;gap:5px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:5px 11px;font-size:11px;font-weight:700;cursor:pointer;color:#1e3a5f;transition:background .15s,border-color .15s;"
            onmouseenter="this.style.background='#e8f0f8';this.style.borderColor='#b3cbe3'" onmouseleave="this.style.background='#fff';this.style.borderColor='#e2e8f0'">
      <svg width="12" height="3" viewBox="0 0 12 3" fill="none"><rect y="0.5" width="12" height="2" rx="1" fill="#1e3a5f"/></svg>
      Thu nhỏ
    </button>
    <div id="ai-ring-container"></div>
    <p style="font-size:11px; color:#94A3B8; margin:12px 0 0;">Nhấn <strong style="color:#1e3a5f">Thu nhỏ</strong> để tiếp tục làm việc.</p>
  </div>
</div>

<style>
@keyframes vox-pulse {
  0%,100% { transform:scale(1); opacity:1; }
  50%      { transform:scale(0.88); opacity:0.75; }
}
</style>

<!-- Confirm Delete Modal -->
<div id="confirm-delete-modal" class="fixed inset-0 z-[60] hidden items-center justify-center p-4" style="background:rgba(15,23,42,0.5);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 text-center animate-in">
    <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4">
      <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
      </svg>
    </div>
    <h3 class="text-[16px] font-bold text-slate-800 mb-1"><%= t("quiz.confirm_delete_question") %></h3>
    <p class="text-[13px] text-slate-400 mb-5">Hành động này không thể hoàn tác.</p>
    <div class="flex gap-2">
      <button onclick="cancelDeleteQuestion()"
              class="flex-1 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors">
        Huỷ
      </button>
      <button onclick="confirmDeleteQuestion()"
              class="flex-1 py-2.5 bg-red-500 hover:bg-red-600 text-white text-[13px] font-bold rounded-xl transition-colors">
        🗑 Xoá
      </button>
    </div>
  </div>
</div>

<script>
// Guard: Turbo Drive re-executes scripts on every visit; re-assigning window vars is safe, re-declaring const is not.
window.ROUTES = {
  questions:        "<%= quiz_set_quiz_questions_path(@quiz_set) %>",
  aiGenerate:       "<%= ai_generate_quiz_set_path(@quiz_set) %>",
  aiGenerateStatus: "<%= ai_generate_status_quiz_set_path(@quiz_set) %>",
  distributePoints: "<%= distribute_points_quiz_set_path(@quiz_set) %>",
  editQuizSet:      "<%= edit_quiz_set_path(@quiz_set) %>"
};
window.QUIZ_SET_META = {
  id:    "quiz-<%= @quiz_set.id %>",
  title: <%= raw @quiz_set.title.to_json %>
};

function minimizeAiTask() {
  document.getElementById('ai-loading-overlay').style.display = 'none';
  if (window.VoxTaskManager) {
    VoxTaskManager.add({
      id:          QUIZ_SET_META.id,
      icon:        '🎯',
      label:       'Tạo Quiz',
      title:       QUIZ_SET_META.title,
      poll_url:    ROUTES.aiGenerateStatus,
      redirect_url: ROUTES.editQuizSet
    });
  }
}

<% if @quiz_set.ai_generating? %>
// Quiz đang sinh câu hỏi từ background job — đăng ký task window ngay
document.addEventListener('DOMContentLoaded', function() {
  if (window.VoxTaskManager) {
    VoxTaskManager.add({
      id:           QUIZ_SET_META.id,
      icon:         '🎯',
      label:        'Tạo Quiz',
      title:        QUIZ_SET_META.title,
      poll_url:     ROUTES.aiGenerateStatus,
      redirect_url: ROUTES.editQuizSet
    });
  }
});
<% end %>

function copyLink(url) {
  navigator.clipboard.writeText(url).then(function() {
    var t = document.getElementById('copy-toast');
    t.classList.remove('hidden');
    setTimeout(function() { t.classList.add('hidden'); }, 2000);
  });
}

// ── Question type selection ──────────────────────────────────────
var selectedQType = 'multiple_choice';
var selectedAllowMultiple = false;

var QTYPE_COLORS = {
  'mc1':      { border: 'border-indigo-500',  bg: 'bg-indigo-50',  text: 'text-indigo-700' },
  'mc-multi': { border: 'border-violet-500',  bg: 'bg-violet-50',  text: 'text-violet-700' },
  'tf':       { border: 'border-amber-500',   bg: 'bg-amber-50',   text: 'text-amber-700' },
  'sa':       { border: 'border-emerald-500', bg: 'bg-emerald-50', text: 'text-emerald-700' }
};
var QTYPE_HINTS = {
  'mc1':      '💡 <%= j t("quiz.hint_mc1") %>',
  'mc-multi': '💡 <%= j t("quiz.hint_mc_multi") %>',
  'tf':       '💡 <%= j t("quiz.hint_tf") %>',
  'sa':       '💡 <%= j t("quiz.hint_sa") %>'
};

// ── Modal options state ──────────────────────────────────────────
var modalOptions = [];

function renderModalOptions() {
  const list = document.getElementById('modal-opts-list');
  if (!list) return;
  if (modalOptions.length === 0) {
    list.innerHTML = '<p class="text-[11px] text-slate-400 italic py-1">Chưa có lựa chọn nào.</p>';
    return;
  }
  list.innerHTML = modalOptions.map(function(opt, idx) {
    const isCorrect = opt.correct;
    const shape = selectedAllowMultiple ? 'rounded' : 'rounded-full';
    const correctCls = isCorrect
      ? 'bg-emerald-500 border-emerald-500 text-white'
      : 'border-slate-300 text-slate-300 hover:border-emerald-400';
    const onclick = selectedAllowMultiple
      ? 'toggleModalCorrect(' + idx + ')'
      : 'setModalCorrect(' + idx + ')';
    const rowCls = isCorrect ? 'bg-emerald-50 border-emerald-200' : 'bg-white border-slate-150';
    const canDelete = !(selectedQType === 'true_false');
    return '<div class="flex items-center gap-2 px-2.5 py-1.5 rounded-lg border ' + rowCls + '">' +
      '<button onclick="' + onclick + '" title="Đánh dấu đúng" type="button"' +
      '  class="w-5 h-5 ' + shape + ' border-2 flex-shrink-0 flex items-center justify-center transition-all text-[9px] font-bold ' + correctCls + '">' +
      (isCorrect ? '✓' : '') + '</button>' +
      '<span class="flex-1 text-[13px] ' + (isCorrect ? 'text-emerald-800 font-semibold' : 'text-slate-700') + '">' + escHtml(opt.text) + '</span>' +
      (canDelete
        ? '<button onclick="removeModalOption(' + idx + ')" type="button" class="text-slate-300 hover:text-red-400 transition-colors flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button>'
        : '') +
      '</div>';
  }).join('');
}

function addModalOption() {
  const input = document.getElementById('modal-opt-input');
  const text = (input ? input.value : '').trim();
  if (!text) { if (input) input.focus(); return; }
  modalOptions.push({ text: text, correct: false });
  renderModalOptions();
  input.value = '';
  input.focus();
}

function removeModalOption(idx) {
  modalOptions.splice(idx, 1);
  renderModalOptions();
}

function setModalCorrect(idx) {
  modalOptions.forEach(function(o, i) { o.correct = (i === idx); });
  renderModalOptions();
}

function toggleModalCorrect(idx) {
  modalOptions[idx].correct = !modalOptions[idx].correct;
  renderModalOptions();
}

function selectQType(type, allowMultiple) {
  selectedQType = type;
  selectedAllowMultiple = allowMultiple;
  const key = type === 'true_false' ? 'tf' : type === 'short_answer' ? 'sa' : type === 'essay' ? 'essay' : (allowMultiple ? 'mc-multi' : 'mc1');
  const idMap = { 'mc1': 'qtype-mc1', 'mc-multi': 'qtype-mc-multi', 'tf': 'qtype-tf', 'sa': 'qtype-sa', 'essay': 'qtype-essay' };
  document.querySelectorAll('.qtype-btn').forEach(function(btn) {
    btn.classList.remove('border-[#1e3a5f]','bg-[#eef3fa]','text-[#1e3a5f]');
    btn.classList.add('border-slate-200','text-slate-600','hover:border-[#1e3a5f]','hover:bg-[#1e3a5f]','hover:text-white');
  });
  const activeBtn = document.getElementById(idMap[key]);
  if (activeBtn) {
    activeBtn.classList.remove('border-slate-200','text-slate-600');
    activeBtn.classList.add('border-[#1e3a5f]','bg-[#eef3fa]','text-[#1e3a5f]');
  }

  const optsSection   = document.getElementById('modal-opts-section');
  const essaySection  = document.getElementById('modal-essay-section');
  const addOptRow     = document.getElementById('modal-add-opt-row');
  const hintLabel     = document.getElementById('modal-opts-hint-label');
  if (!optsSection) return;

  // Default points by type
  const pointsField = document.getElementById('new-q-points');
  if (pointsField && type === 'essay') pointsField.value = 5;
  else if (pointsField && type === 'true_false') pointsField.value = 1;
  else if (pointsField) pointsField.value = 1;

  if (type === 'short_answer' || type === 'essay') {
    optsSection.classList.add('hidden');
    modalOptions = [];
    if (essaySection) essaySection.classList[type === 'essay' ? 'remove' : 'add']('hidden');
  } else if (type === 'true_false') {
    optsSection.classList.remove('hidden');
    if (essaySection) essaySection.classList.add('hidden');
    if (addOptRow) addOptRow.classList.add('hidden');
    if (hintLabel) hintLabel.textContent = '<%= j t("quiz.options_hint_single") %>';
    if (!modalOptions.some(function(o) { return o.text === 'Đúng' || o.text === 'True'; })) {
      modalOptions = [{ text: 'Đúng', correct: true }, { text: 'Sai', correct: false }];
    }
    renderModalOptions();
  } else {
    optsSection.classList.remove('hidden');
    if (essaySection) essaySection.classList.add('hidden');
    if (addOptRow) addOptRow.classList.remove('hidden');
    if (hintLabel) hintLabel.textContent = allowMultiple ? '<%= j t("quiz.options_hint_multi") %>' : '<%= j t("quiz.options_hint_single") %>';
    if (modalOptions.some(function(o) { return o.text === 'Đúng' || o.text === 'Sai'; })) {
      modalOptions = [];
    }
    renderModalOptions();
  }
}

function addQuestion() {
  document.getElementById('new-q-text').value = '';
  document.getElementById('new-q-explanation').value = '';
  _resetRubric();
  const errEl = document.getElementById('modal-opts-error');
  if (errEl) { errEl.classList.add('hidden'); errEl.textContent = ''; }
  modalOptions = [];
  selectQType('multiple_choice', false);
  var m = document.getElementById('add-q-modal');
  m.classList.remove('hidden'); m.classList.add('flex');
  setTimeout(function() { document.getElementById('new-q-text').focus(); }, 50);
}
function closeAddModal() {
  var m = document.getElementById('add-q-modal');
  m.classList.add('hidden'); m.classList.remove('flex');
}
var _addQModal = document.getElementById('add-q-modal');
if (_addQModal && !_addQModal._hasClickListener) {
  _addQModal._hasClickListener = true;
  _addQModal.addEventListener('click', function(e) { if (e.target === this) closeAddModal(); });
}

async function submitNewQuestion() {
  const text = document.getElementById('new-q-text').value.trim();
  if (!text) { document.getElementById('new-q-text').focus(); return; }

  // Validate options
  const errEl = document.getElementById('modal-opts-error');
  function showOptsError(msg) {
    if (errEl) { errEl.textContent = msg; errEl.classList.remove('hidden'); }
  }
  if (errEl) errEl.classList.add('hidden');

  const needsOptions = selectedQType !== 'short_answer' && selectedQType !== 'essay';
  if (needsOptions) {
    if (selectedQType !== 'true_false' && modalOptions.length < 2) {
      showOptsError('Vui lòng thêm ít nhất 2 lựa chọn.');
      document.getElementById('modal-opt-input')?.focus();
      return;
    }
    if (!modalOptions.some(function(o) { return o.correct; })) {
      showOptsError('<%= j t("quiz.error_mark_correct") %>');
      return;
    }
  }

  const explanation = document.getElementById('new-q-explanation').value.trim();
  const points      = parseInt(document.getElementById('new-q-points').value) || 1;
  const rubric      = selectedQType === 'essay' ? (_getRubricText()) : null;
  const token = document.querySelector('meta[name="csrf-token"]').content;
  const res = await fetch(ROUTES.questions, {
    method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token },
    body: JSON.stringify({
      quiz_question: {
        question_text:  text,
        question_type:  selectedQType,
        allow_multiple: selectedAllowMultiple,
        explanation:    explanation,
        points:         points,
        essay_rubric:   rubric
      },
      options: (selectedQType !== 'short_answer' && selectedQType !== 'essay') ? modalOptions : []
    })
  });
  const data = await res.json();
  if (data.success) {
    const list = document.getElementById('questions-list');
    const empty = document.getElementById('empty-state');
    if (empty) empty.remove();
    const idx = list.children.length;
    list.insertAdjacentHTML('beforeend', questionCardHtml(data, idx));
    updateCount(1);
    closeAddModal();
    const newEl = list.lastElementChild;
    newEl?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    if (window.MathJax) MathJax.typesetPromise([newEl]);
  } else {
    showOptsError(data.error || '<%= j t("common.error_generic", default: "An error occurred.") %>');
  }
}

function questionCardHtml(q, index) {
  const num = (index !== undefined ? index + 1 : '?');
  let typeBadge = '';
  if (q.question_type === 'multiple_choice') {
    typeBadge = q.allow_multiple
      ? '<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-violet-100 text-violet-700 flex-shrink-0"><%= j t("quiz.badge_multi") %></span>'
      : '<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-indigo-100 text-indigo-700 flex-shrink-0"><%= j t("quiz.badge_single") %></span>';
  } else if (q.question_type === 'true_false') {
    typeBadge = '<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-amber-100 text-amber-700 flex-shrink-0"><%= j t("quiz.badge_tf") %></span>';
  } else if (q.question_type === 'essay') {
    typeBadge = '<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-rose-100 text-rose-700 flex-shrink-0">📝 Tự luận</span>';
  } else {
    typeBadge = '<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-emerald-100 text-emerald-700 flex-shrink-0"><%= j t("quiz.badge_sa") %></span>';
  }

  const pts = q.points || 1;
  const ptsLabel = Number.isInteger(pts) ? pts : parseFloat(pts).toFixed(1).replace('.0','');
  const pointsBadge = `<span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-slate-100 text-slate-600 flex-shrink-0">${ptsLabel}đ</span>`;

  const explanation = q.explanation
    ? `<p class="text-[11px] text-slate-400 italic mb-2">💡 ${escHtml(q.explanation)}</p>` : '';

  let bodyHtml = '';
  if (q.question_type === 'short_answer') {
    bodyHtml = '<p class="text-[12px] text-slate-400 italic mb-3">✍️ <%= j t("quiz.student_types_answer") %></p>';
  } else if (q.question_type === 'essay') {
    const rubric = q.essay_rubric ? `<p class="text-[11px] text-slate-400 italic mb-3">📋 Rubric: ${escHtml(q.essay_rubric)}</p>` : '';
    bodyHtml = `<p class="text-[12px] text-slate-400 italic mb-2">📝 Học viên viết câu trả lời tự luận. AI sẽ chấm điểm.</p>${rubric}`;
  } else {
    const opts = (q.options || []).map(function(o) { return optionHtml(o.id, o.text, o.correct, q.id, q.allow_multiple); }).join('');
    const addRow = q.question_type !== 'true_false'
      ? `<div class="flex gap-2">
          <input type="text" id="opt-input-${q.id}" placeholder="<%= j t('quiz.option_placeholder') %>"
                 class="flex-1 px-2.5 py-1.5 border border-slate-200 rounded-lg text-[12px] focus:border-indigo-500 outline-none"
                 onkeydown="if(event.key==='Enter'){event.preventDefault();addOption(${q.id})}">
          <button onclick="addOption(${q.id})"
                  class="px-3 py-1.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-500 text-[12px] font-semibold rounded-lg transition-colors">
            + <%= j t("quiz.add_option") %>
          </button>
        </div>` : '';
    bodyHtml = `<div id="opts-${q.id}" class="space-y-0.5 mb-3">${opts}</div>${addRow}`;
  }

  return `<div id="q-${q.id}" class="bg-white rounded-xl border border-slate-200 shadow-sm p-4" data-allow-multiple="${q.allow_multiple}">
    <div class="flex items-start gap-3">
      <div class="w-6 h-6 rounded-full bg-indigo-100 text-indigo-700 text-[11px] font-bold flex items-center justify-center flex-shrink-0 mt-0.5">${num}</div>
      <div class="flex-1 min-w-0">
        <div class="flex items-start gap-2 mb-2 flex-wrap">
          <p class="text-[14px] font-semibold text-slate-800 flex-1">${escHtml(q.question_text)}</p>
          ${typeBadge}
          ${pointsBadge}
        </div>
        ${explanation}
        ${bodyHtml}
      </div>
      <button onclick="deleteQuestion(${q.id})" class="text-slate-300 hover:text-red-400 transition-colors flex-shrink-0 mt-0.5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      </button>
    </div>
  </div>`;
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function updateCount(delta) {
  const el = document.getElementById('q-count');
  el.textContent = parseInt(el.textContent) + delta;
  recalcTotalScore();
}

function recalcTotalScore() {
  var total = 0;
  document.querySelectorAll('#questions-list [id^="q-"]').forEach(function(card) {
    var badge = Array.from(card.querySelectorAll('.rounded-full')).find(function(b) { return /^\d+đ$/.test(b.textContent.trim()); });
    if (badge) total += parseInt(badge.textContent);
  });
  if (total > 0) {
    var field = document.getElementById('total-score-field');
    if (field) field.value = total;
  }
}

var _pendingDeleteId = null;

function deleteQuestion(id) {
  _pendingDeleteId = id;
  const m = document.getElementById('confirm-delete-modal');
  m.classList.remove('hidden'); m.classList.add('flex');
}

function cancelDeleteQuestion() {
  _pendingDeleteId = null;
  const m = document.getElementById('confirm-delete-modal');
  m.classList.add('hidden'); m.classList.remove('flex');
}

async function confirmDeleteQuestion() {
  const id = _pendingDeleteId;
  if (!id) return;
  cancelDeleteQuestion();
  const token = document.querySelector('meta[name="csrf-token"]').content;
  const res = await fetch(ROUTES.questions + '/' + id, { method: 'DELETE', headers: { 'X-CSRF-Token': token } });
  if ((await res.json()).success) {
    const el = document.getElementById('q-' + id);
    if (el) { el.style.transition = 'opacity .2s'; el.style.opacity = '0'; setTimeout(function() { el.remove(); }, 200); }
    updateCount(-1);
  }
}

var _delModal = document.getElementById('confirm-delete-modal');
if (_delModal && !_delModal._hasClickListener) {
  _delModal._hasClickListener = true;
  _delModal.addEventListener('click', function(e) { if (e.target === this) cancelDeleteQuestion(); });
}

async function addOption(questionId) {
  const input = document.getElementById('opt-input-' + questionId);
  const text = input.value.trim();
  if (!text) return;
  const token = document.querySelector('meta[name="csrf-token"]').content;
  const res = await fetch(ROUTES.questions + '/' + questionId + '/quiz_options', {
    method: 'POST', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token },
    body: JSON.stringify({ quiz_option: { option_text: text, is_correct: false } })
  });
  const data = await res.json();
  if (data.success) {
    const list = document.getElementById('opts-' + questionId);
    const qEl = document.getElementById('q-' + questionId);
    const allowMultiple = qEl && qEl.dataset.allowMultiple === 'true';
    const optContainer = document.getElementById('opts-' + questionId);
    optContainer.insertAdjacentHTML('beforeend', optionHtml(data.id, text, false, questionId, allowMultiple));
    if (window.MathJax) MathJax.typesetPromise([optContainer.lastElementChild]);
    input.value = '';
    input.focus();
  }
}

function optionHtml(id, text, correct, qid, allowMultiple) {
  const correctCls = correct ? 'bg-emerald-500 border-emerald-500' : 'border-slate-300 hover:border-emerald-400';
  const deleteBtn = `<button onclick="deleteOption(${qid}, ${id})" class="text-slate-300 hover:text-red-400 transition-colors">
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>`;
  if (allowMultiple) {
    return `<div id="opt-${id}" class="flex items-center gap-2 py-1">
      <button onclick="toggleCorrect(${qid}, ${id}, this)" title="Đánh dấu đúng"
              data-correct="${correct}"
              class="w-5 h-5 rounded border-2 flex-shrink-0 transition-colors ${correctCls}"
              id="check-${id}"></button>
      <span class="flex-1 text-[13px] text-slate-700">${escHtml(text)}</span>
      ${deleteBtn}
    </div>`;
  } else {
    return `<div id="opt-${id}" class="flex items-center gap-2 py-1">
      <button onclick="setCorrect(${qid}, ${id})" title="Đánh dấu đúng"
              class="w-5 h-5 rounded-full border-2 flex-shrink-0 transition-colors ${correctCls}"
              id="radio-${id}"></button>
      <span class="flex-1 text-[13px] text-slate-700">${escHtml(text)}</span>
      ${deleteBtn}
    </div>`;
  }
}

async function setCorrect(questionId, optionId) {
  const token = document.querySelector('meta[name="csrf-token"]').content;
  document.querySelectorAll(`#q-${questionId} [id^="radio-"]`).forEach(function(el) {
    el.classList.remove('bg-emerald-500', 'border-emerald-500');
    el.classList.add('border-slate-300');
  });
  const btn = document.getElementById('radio-' + optionId);
  if (btn) { btn.classList.add('bg-emerald-500', 'border-emerald-500'); btn.classList.remove('border-slate-300'); }
  await fetch(ROUTES.questions + '/' + questionId + '/quiz_options/' + optionId, {
    method: 'PATCH', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token },
    body: JSON.stringify({ quiz_option: { is_correct: 'true' } })
  });
}

async function toggleCorrect(questionId, optionId, btn) {
  const token = document.querySelector('meta[name="csrf-token"]').content;
  const nowCorrect = btn.dataset.correct !== 'true';
  btn.dataset.correct = String(nowCorrect);
  if (nowCorrect) {
    btn.classList.add('bg-emerald-500', 'border-emerald-500'); btn.classList.remove('border-slate-300');
  } else {
    btn.classList.remove('bg-emerald-500', 'border-emerald-500'); btn.classList.add('border-slate-300');
  }
  await fetch(ROUTES.questions + '/' + questionId + '/quiz_options/' + optionId, {
    method: 'PATCH', headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token },
    body: JSON.stringify({ quiz_option: { is_correct: String(nowCorrect) } })
  });
}

async function deleteOption(questionId, optionId) {
  const token = document.querySelector('meta[name="csrf-token"]').content;
  const res = await fetch(ROUTES.questions + '/' + questionId + '/quiz_options/' + optionId, {
    method: 'DELETE', headers: { 'X-CSRF-Token': token }
  });
  if ((await res.json()).success) {
    document.getElementById('opt-' + optionId).remove();
  }
}

