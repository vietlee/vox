var PLACEHOLDER_NO_FILE  = 'VD: Tạo 15 câu về Chương 3 – Hàm số bậc hai, dành cho HS lớp 10, 60% nhận biết 40% thông hiểu, thêm câu đánh lừa...';
var PLACEHOLDER_HAS_FILE = 'VD: Tập trung vào chương 3, dùng ngôn ngữ đơn giản, thêm câu đánh lừa, bỏ qua phần phụ lục...';

function _syncPromptPlaceholder(hasFile) {
  var lbl = document.getElementById('ai-prompt-optional-label');
  var ph = hasFile ? PLACEHOLDER_HAS_FILE : PLACEHOLDER_NO_FILE;
  // update Quill placeholder via DOM
  var editor = document.querySelector('#ai-prompt-quill-editor .ql-editor');
  if (editor) editor.setAttribute('data-placeholder', ph);
  if (lbl) lbl.textContent = hasFile ? '(tuỳ chọn)' : '(bắt buộc nếu không upload tài liệu)';
}

var _aiFiles = []; // DataTransfer-backed file list

function aiFileSelected(input) {
  if (!input.files.length) return;
  Array.from(input.files).forEach(function(f) {
    if (!_aiFiles.find(function(x){ return x.name === f.name && x.size === f.size; })) {
      _aiFiles.push(f);
    }
  });
  input.value = ''; // reset so same file can be re-added if removed
  renderAiFileList();
}

function renderAiFileList() {
  const list = document.getElementById('ai-file-list');
  const sel  = document.getElementById('ai-file-selected');
  const zone = document.getElementById('ai-drop-zone');
  if (_aiFiles.length === 0) {
    sel.classList.add('hidden');
    zone.classList.remove('hidden');
    _syncPromptPlaceholder(false);
    return;
  }
  zone.classList.add('hidden');
  sel.classList.remove('hidden');
  list.innerHTML = _aiFiles.map(function(f, i) {
    const ext = f.name.split('.').pop().toLowerCase();
    return '<div class="flex items-center gap-2 bg-white border border-violet-200 rounded-lg px-3 py-2">' +
      (FILE_ICONS[ext] || '<div style="width:28px;height:28px;border-radius:6px;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z" fill="#94a3b8"/><path d="M14 2v6h6" stroke="#cbd5e1" stroke-width="1.5"/></svg></div>') +
      '<span class="text-[12px] font-semibold text-slate-700 truncate flex-1 min-w-0">' + f.name + '</span>' +
      '<span class="text-[11px] text-slate-400 flex-shrink-0">' + (f.size > 1048576 ? (f.size/1048576).toFixed(1)+'MB' : Math.round(f.size/1024)+'KB') + '</span>' +
      '<button onclick="aiRemoveFile(' + i + ')" class="text-slate-300 hover:text-red-400 transition-colors flex-shrink-0 ml-1">' +
        '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>' +
      '</button></div>';
  }).join('');
  document.getElementById('ai-empty-error').classList.add('hidden');
  _syncPromptPlaceholder(true);
}

function aiRemoveFile(idx) {
  _aiFiles.splice(idx, 1);
  renderAiFileList();
}

function aiClearFile() {
  _aiFiles = [];
  document.getElementById('ai-file-input').value = '';
  renderAiFileList();
}

function aiDragOver(e) {
  e.preventDefault();
  document.getElementById('ai-drop-zone').classList.add('border-violet-500', 'bg-violet-50');
}

function aiDragLeave(e) {
  document.getElementById('ai-drop-zone').classList.remove('border-violet-500', 'bg-violet-50');
}

function aiDrop(e) {
  e.preventDefault();
  aiDragLeave(e);
  Array.from(e.dataTransfer.files).forEach(function(f) {
    if (!_aiFiles.find(function(x){ return x.name === f.name && x.size === f.size; })) {
      _aiFiles.push(f);
    }
  });
  renderAiFileList();
}

var AI_PHASES = [
  'Đang đọc tài liệu...', 'Đang phân tích nội dung...', 'Đang tạo câu hỏi...',
  'Đang kiểm tra đáp án...', 'Đang hoàn thiện bộ đề...'
];

function makeProgressRing(containerId, phases, intervalMs) {
  const totalPhases = phases.length;
  let phase = 0, pct = 0, timer = null;
  const html = `
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">
      <span id="${containerId}-pct" style="font-size:13px;font-weight:800;color:#1e3a5f;letter-spacing:-0.3px;">0%</span>
      <div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">
        <svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">
          <circle cx="44" cy="44" r="38" stroke="#d9e5f1" stroke-width="6"/>
          <circle id="${containerId}-ring" cx="44" cy="44" r="38"
            stroke="#1e3a5f" stroke-width="6" stroke-linecap="round"
            stroke-dasharray="238.8" stroke-dashoffset="238.8"
            style="transition:stroke-dashoffset 0.6s ease;"/>
        </svg>
        <div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">
          <img src="/icon-mark.svg" width="40" height="40" alt="VOX" style="display:block;">
        </div>
      </div>
      <p id="${containerId}-phase" style="font-size:12px;font-weight:600;color:#1e3a5f;text-align:center;max-width:220px;margin:0;">${phases[0]}</p>
    </div>`;
  document.getElementById(containerId).innerHTML = html;
  const ring  = document.getElementById(`${containerId}-ring`);
  const pctEl = document.getElementById(`${containerId}-pct`);
  const phEl  = document.getElementById(`${containerId}-phase`);
  function setProgress(p) {
    ring.style.strokeDashoffset = 238.8 * (1 - p / 100);
    pctEl.textContent = Math.round(p) + '%';
  }
  const milestones = phases.map((_, i) => Math.round(((i + 1) / totalPhases) * 85));
  timer = setInterval(() => {
    const target = milestones[phase] || 85;
    pct = Math.min(pct + 1, target);
    setProgress(pct);
    if (pct >= (milestones[phase] || 85) && phase < totalPhases - 1) {
      phase++;
      phEl.textContent = phases[phase];
    }
    if (pct >= 85 && phase >= totalPhases - 1) {
      clearInterval(timer);
      timer = setInterval(() => {
        if (pct >= 98) { clearInterval(timer); return; }
        pct = Math.min(pct + 0.4, 98);
        setProgress(pct);
      }, 3000);
    }
  }, intervalMs);
  return {
    finish: () => { clearInterval(timer); ring.style.strokeDashoffset = '0'; pctEl.textContent = '100%'; }
  };
}

var _aiRingCtrl = null;

function showAiLoadingOverlay() {
  document.getElementById('ai-loading-overlay').style.display = 'flex';
  _aiRingCtrl = makeProgressRing('ai-ring-container', AI_PHASES, 300);
}

function hideAiLoadingOverlay() {
  if (_aiRingCtrl) _aiRingCtrl.finish();
  document.getElementById('ai-loading-overlay').style.display = 'none';
  _aiRingCtrl = null;
}

function selectResultMode(mode) {
  // Don't allow switching to immediate if quiz has essay questions
  if (mode === 'result_immediate' && document.getElementById('rmode-immediate').classList.contains('cursor-not-allowed')) return;
  document.getElementById('result_mode_hidden').value = mode;
  var imm = document.getElementById('rmode-immediate');
  var lat = document.getElementById('rmode-later');
  var showAnswersRow = document.getElementById('show-answers-row');
  if (mode === 'result_immediate') {
    imm.classList.remove('border-slate-200'); imm.classList.add('border-[#1e3a5f]','bg-[#eef3fa]');
    lat.classList.remove('border-[#1e3a5f]','bg-[#eef3fa]'); lat.classList.add('border-slate-200');
    if (showAnswersRow) showAnswersRow.classList.remove('hidden');
  } else {
    lat.classList.remove('border-slate-200'); lat.classList.add('border-[#1e3a5f]','bg-[#eef3fa]');
    imm.classList.remove('border-[#1e3a5f]','bg-[#eef3fa]'); imm.classList.add('border-slate-200');
    if (showAnswersRow) showAnswersRow.classList.add('hidden');
  }
}

var _currentPassingScoreType = '<%= @quiz_set.passing_score_type || "percent" %>';

function setPassingScoreType(type) {
  var scoreField = document.getElementById('quiz_set_passing_score');
  var total = parseInt(document.getElementById('total-score-field').value) || 0;
  var current = parseInt(scoreField.value) || 0;

  // Convert value when switching type
  if (type !== _currentPassingScoreType && total > 0) {
    if (type === 'points') {
      // percent → points
      scoreField.value = Math.round(current / 100 * total);
    } else {
      // points → percent
      scoreField.value = Math.min(100, Math.round(current / total * 100));
    }
  }
  _currentPassingScoreType = type;

  document.getElementById('passing_score_type_hidden').value = type;
  document.getElementById('ps-unit-label').textContent = type === 'points' ? 'đ' : '%';
  var pBtn = document.getElementById('ps-type-percent');
  var dBtn = document.getElementById('ps-type-points');
  if (type === 'percent') {
    pBtn.classList.add('border-[#1e3a5f]','bg-[#eef3fa]','text-[#1e3a5f]');
    pBtn.classList.remove('border-slate-200','text-slate-500');
    dBtn.classList.remove('border-[#1e3a5f]','bg-[#eef3fa]','text-[#1e3a5f]');
    dBtn.classList.add('border-slate-200','text-slate-500');
  } else {
    dBtn.classList.add('border-[#1e3a5f]','bg-[#eef3fa]','text-[#1e3a5f]');
    dBtn.classList.remove('border-slate-200','text-slate-500');
    pBtn.classList.remove('border-[#1e3a5f]','bg-[#eef3fa]','text-[#1e3a5f]');
    pBtn.classList.add('border-slate-200','text-slate-500');
  }
}


async function distributePoints() {
  const total = parseInt(document.getElementById('total-score-field').value);
  if (!total || total < 1) { alert('Vui lòng nhập tổng điểm trước.'); return; }
  const btn = document.getElementById('distribute-btn');
  btn.textContent = '⏳ Đang phân điểm...';
  btn.disabled = true;
  try {
    const token = document.querySelector('meta[name="csrf-token"]').content;
    const res = await fetch(ROUTES.distributePoints, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token, 'Accept': 'application/json' },
      body: JSON.stringify({ total_score: total })
    });
    const data = await res.json();
    if (data.ok) {
      // Update points badges in question cards
      data.points.forEach(function(p) {
        var card = document.getElementById('q-' + p.id);
        if (!card) return;
        var badges = card.querySelectorAll('.rounded-full');
        var label = Number.isInteger(p.points) ? p.points : parseFloat(p.points).toFixed(1).replace('.0','');
        badges.forEach(function(b) {
          if (b.textContent.trim().match(/^[\d.]+đ$/)) b.textContent = label + 'đ';
        });
      });
      btn.textContent = '✅ Đã phân điểm!';
      setTimeout(function() { btn.textContent = '✨ Phân điểm AI'; btn.disabled = false; }, 2000);
    } else {
      alert(data.error || 'Lỗi phân điểm.');
      btn.textContent = '✨ Phân điểm AI'; btn.disabled = false;
    }
  } catch(e) {
    alert('Lỗi kết nối.'); btn.textContent = '✨ Phân điểm AI'; btn.disabled = false;
  }
}

async function runAiGenerate() {
  const count = aiCountMode === 'auto' ? 0 : document.getElementById('ai-count').value;
  const customPrompt = _getAiPromptText();
  const errEl = document.getElementById('ai-empty-error');
  if (!_aiFiles.length && !customPrompt) {
    if (errEl) errEl.classList.remove('hidden');
    if (_aiPromptQuill) _aiPromptQuill.focus();
    return;
  }
  if (errEl) errEl.classList.add('hidden');
  const formData = new FormData();
  _aiFiles.forEach(function(f) { formData.append('files[]', f); });
  formData.append('questions_count', count);
  formData.append('custom_prompt', customPrompt);
  formData.append('include_essay', document.getElementById('ai-include-essay').checked ? 'true' : 'false');
  formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);
  document.getElementById('ai-error').classList.add('hidden');
  document.getElementById('ai-generate-btn').disabled = true;
  showAiLoadingOverlay();
  try {
    const res = await fetch(ROUTES.aiGenerate, {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    });
    const data = await res.json();
    if (data.error) {
      hideAiLoadingOverlay();
      document.getElementById('ai-generate-btn').disabled = false;
      if (handleAiError(data, res)) return;
      document.getElementById('ai-error').textContent = data.error;
      document.getElementById('ai-error').classList.remove('hidden');
      return;
    }
    if (data.pending && data.poll_url) {
      pollAiStatus(data.poll_url);
    } else if (data.success) {
      if (_aiRingCtrl) _aiRingCtrl.finish();
      window.location.href = data.redirect;
    }
  } catch(e) {
    hideAiLoadingOverlay();
    document.getElementById('ai-error').textContent = e.message;
    document.getElementById('ai-error').classList.remove('hidden');
    document.getElementById('ai-generate-btn').disabled = false;
  }
}

async function pollAiStatus(pollUrl) {
  // If overlay was minimized, VoxTaskManager takes over — stop local polling
  const overlay = document.getElementById('ai-loading-overlay');
  if (overlay && overlay.style.display === 'none' && window.VoxTaskManager) return;
  try {
    const res = await fetch(pollUrl, { headers: { 'Accept': 'application/json' } });
    const data = await res.json();
    if (data.pending) {
      setTimeout(() => pollAiStatus(pollUrl), 3000);
    } else if (data.success) {
      // Re-check: if minimized or navigated away, let VoxTaskManager handle it
      const overlayNow = document.getElementById('ai-loading-overlay');
      const isGoneOrHidden = !overlayNow || overlayNow.style.display === 'none';
      if (isGoneOrHidden && window.VoxTaskManager) return;
      if (_aiRingCtrl) _aiRingCtrl.finish();
      window.location.href = data.redirect;
    } else if (data.failed || data.error) {
      hideAiLoadingOverlay();
      document.getElementById('ai-generate-btn').disabled = false;
      if (handleAiError(data, res)) return;
      document.getElementById('ai-error').textContent = data.error || 'AI gặp lỗi. Vui lòng thử lại.';
      document.getElementById('ai-error').classList.remove('hidden');
    } else {
      setTimeout(() => pollAiStatus(pollUrl), 3000);
    }
  } catch(e) {
    setTimeout(() => pollAiStatus(pollUrl), 3000);
  }
}

// ── Rubric Quill ────────────────────────────────────────────────────
var _rubricQuill = null;

function _initRubricQuill() {
  if (_rubricQuill) return;
  if (typeof Quill === 'undefined') return;
  var el = document.getElementById('rubric-quill-editor');
  if (!el) return;
  _rubricQuill = new Quill(el, {
    theme: 'snow',
    placeholder: 'Mô tả các tiêu chí AI dùng để chấm điểm câu tự luận này...',
    modules: {
      toolbar: [
        ['bold', 'italic'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['clean']
      ]
    }
  });
}

function _getRubricText() {
  if (_rubricQuill) return _rubricQuill.getText().trim();
  return '';
}

function _resetRubric() {
  if (_rubricQuill) _rubricQuill.setContents([]);
}

(function waitQuillRubric(tries) {
  if (typeof Quill !== 'undefined') { _initRubricQuill(); return; }
  if (tries > 50) return;
  setTimeout(function() { waitQuillRubric(tries + 1); }, 100);
})(0);

// ── AI prompt Quill ────────────────────────────────────────────────
var _aiPromptQuill = null;

function _initAiPromptQuill() {
  if (_aiPromptQuill) return;
  if (typeof Quill === 'undefined') return;
  var el = document.getElementById('ai-prompt-quill-editor');
  if (!el) return;
  _aiPromptQuill = new Quill(el, {
    theme: 'snow',
    placeholder: PLACEHOLDER_NO_FILE,
    modules: {
      toolbar: [
        ['bold', 'italic', 'underline'],
        [{ list: 'ordered' }, { list: 'bullet' }],
        ['clean']
      ]
    }
  });
  _syncPromptPlaceholder(false);
}

(function waitQuill(tries) {
  if (typeof Quill !== 'undefined') { _initAiPromptQuill(); return; }
  if (tries > 50) return;
  setTimeout(function() { waitQuill(tries + 1); }, 100);
})(0);

function _getAiPromptText() {
  if (_aiPromptQuill) return _aiPromptQuill.getText().trim();
  return '';
}
</script>

