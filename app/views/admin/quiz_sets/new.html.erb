<% content_for :title, t("quiz.new") %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900"><%= t("quiz.new") %></h1>
</div>

<div class="max-w-xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @quiz_set, url: quiz_sets_path, local: true do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide"><%= t("quiz.field_title") %> *</label>
        <%= f.text_field :title, required: true, placeholder: t("quiz.title_placeholder"),
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide"><%= t("quiz.field_desc") %></label>
        <%= f.text_area :description, rows: 3, placeholder: t("quiz.desc_placeholder"),
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none resize-none" %>
      </div>
      <div class="flex gap-2 pt-2">
        <%= f.submit t("quiz.create_and_add"), class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors" %>
        <%= link_to t("common.cancel"), quiz_sets_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
