<% content_for :title, t("quiz.new") %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900"><%= t("quiz.new") %></h1>
</div>

<div class="max-w-2xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @quiz_set, url: quiz_sets_path, local: true, id: "quiz-set-form" do |f| %>
    <div class="space-y-5">

      <!-- Tên bộ đề -->
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide"><%= t("quiz.field_title") %> *</label>
        <%= f.text_field :title, required: true, placeholder: t("quiz.title_placeholder"),
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>

      <!-- Best practice tips -->
      <div style="background:#f8faff;border:1px solid #e0e7ff;border-radius:12px;padding:14px 16px;">
        <div class="flex items-center gap-2 mb-2">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="#1e3a5f" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          <span class="text-[12px] font-bold text-indigo-700 uppercase tracking-wide">Gợi ý tạo bộ đề hiệu quả</span>
        </div>
        <ul class="space-y-1.5">
          <li class="flex items-start gap-2 text-[12px] text-slate-600">
            <span class="text-indigo-400 mt-0.5 shrink-0">✓</span>
            <span><strong>Xác định mục tiêu rõ ràng</strong> — VD: "Kiểm tra kiến thức Chương 3 – Hàm số bậc hai dành cho HS lớp 10"</span>
          </li>
          <li class="flex items-start gap-2 text-[12px] text-slate-600">
            <span class="text-indigo-400 mt-0.5 shrink-0">✓</span>
            <span><strong>Ghi rõ đối tượng & thời gian</strong> — VD: "25 câu, hoàn thành trong 30 phút, dành cho nhân viên mới"</span>
          </li>
          <li class="flex items-start gap-2 text-[12px] text-slate-600">
            <span class="text-indigo-400 mt-0.5 shrink-0">✓</span>
            <span><strong>Nêu nguồn tài liệu tham khảo</strong> — VD: "Dựa trên SGK Toán 10 – Kết nối tri thức, trang 45–68"</span>
          </li>
          <li class="flex items-start gap-2 text-[12px] text-slate-600">
            <span class="text-indigo-400 mt-0.5 shrink-0">✓</span>
            <span><strong>Phân loại mức độ câu hỏi</strong> — VD: "60% nhận biết, 30% thông hiểu, 10% vận dụng"</span>
          </li>
        </ul>
      </div>

      <% if params[:source_text].present? %>
        <div class="bg-indigo-50 border border-indigo-200 rounded-xl px-4 py-3 text-[12px] text-indigo-700 flex items-center gap-2">
          <svg id="qs-suggest-spinner" class="animate-spin w-3.5 h-3.5 text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
          </svg>
          <span id="qs-suggest-icon" class="hidden">✅</span>
          <span id="qs-suggest-msg">AI đang phân tích tài liệu và đề xuất tiêu đề...</span>
        </div>
        <%= hidden_field_tag "source_text", params[:source_text] %>
      <% end %>
      <div class="flex gap-2 pt-1">
        <%= f.submit t("quiz.create_and_add"), id: "qs-submit",
            class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors" %>
        <%= link_to t("common.cancel"), quiz_sets_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>

<% if params[:source_text].present? %>
<script>
(function() {
  var titleField = document.querySelector('[name="quiz_set[title]"]');
  var sourceText = <%= raw params[:source_text].to_s.to_json %>;

  var spinner = document.getElementById('qs-suggest-spinner');
  var iconEl  = document.getElementById('qs-suggest-icon');
  var msgEl   = document.getElementById('qs-suggest-msg');

  function setDone(msg) {
    if (spinner) spinner.classList.add('hidden');
    if (iconEl)  iconEl.classList.remove('hidden');
    if (msgEl)   msgEl.textContent = msg;
    titleField.placeholder = <%= raw t("quiz.title_placeholder").to_json %>;
  }

  var fd = new FormData();
  fd.append('content', sourceText.slice(0, 3000));
  fd.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

  fetch('<%= ai_suggest_meta_path %>', { method: 'POST', body: fd })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.title) titleField.value = d.title;
      setDone('Đã nhận nội dung tài liệu — AI sẽ tạo câu hỏi từ tài liệu này sau khi bạn tạo bộ đề.');
    })
    .catch(function() {
      setDone('Đã nhận nội dung tài liệu — AI sẽ tạo câu hỏi từ tài liệu này sau khi bạn tạo bộ đề.');
    });
})();
</script>
<% end %>

