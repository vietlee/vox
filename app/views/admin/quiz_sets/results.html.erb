<% content_for :title, t("quiz.results_title", title: @quiz_set.title) %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1">
    <h1 class="text-[20px] font-extrabold text-slate-900"><%= t("quiz.results") %></h1>
    <p class="text-[13px] text-slate-500"><%= @quiz_set.title %></p>
  </div>
  <% if @quiz_set.result_later? && @attempts.any? %>
    <button onclick="sendAllResultEmails(this)"
            class="inline-flex items-center gap-1.5 px-3 py-2 rounded-[7px] text-[13px] font-semibold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors border-0 cursor-pointer">
      📧 Gửi tất cả kết quả
    </button>
  <% end %>
</div>

<!-- Stats -->
<% total_pts = @quiz_set.quiz_questions.sum(:points) %>
<% avg_pts = @all_attempts.any? ? (@all_attempts.sum(:earned_points).to_f / @all_attempts.count).round(1) : nil %>
<div class="grid grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <div class="text-[28px] font-black text-indigo-600"><%= @all_attempts.count %></div>
    <div class="text-[12px] text-slate-400 font-semibold"><%= t("quiz.total_attempts") %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <div class="text-[28px] font-black text-emerald-600"><%= @quiz_set.avg_score || "—" %><% if @quiz_set.avg_score %>%<% end %></div>
    <div class="text-[12px] text-slate-400 font-semibold"><%= t("quiz.avg_score") %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <div class="text-[28px] font-black text-sky-600">
      <% if avg_pts %><%= avg_pts %>/<%= total_pts %><% else %>—<% end %>
    </div>
    <div class="text-[12px] text-slate-400 font-semibold">Điểm TB tuyệt đối</div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <% passed = @all_attempts.select(&:passed?).count %>
    <div class="text-[28px] font-black text-violet-600"><%= @all_attempts.any? ? "#{(passed * 100.0 / @all_attempts.count).round}%" : "—" %></div>
    <div class="text-[12px] text-slate-400 font-semibold"><%= t("quiz.pass_rate") %></div>
  </div>
</div>

<!-- Tabs -->
<% has_ai = @all_attempts.any? %>
<div class="flex mb-4" style="border-bottom:2px solid #e2e8f0;">
  <button id="tab-results" onclick="switchResultTab('results')"
          style="flex:1;padding:10px 16px;font-size:13px;font-weight:700;color:#1e293b;background:#fff;border:0;border-bottom:2px solid #1e3a5f;margin-bottom:-2px;cursor:pointer;transition:all .15s;">
    📋 Danh sách kết quả
  </button>
  <div style="width:1px;background:#e2e8f0;margin:8px 0 10px;flex-shrink:0;"></div>
  <button id="tab-class-ai" onclick="switchResultTab('class-ai')"
          style="flex:1;padding:10px 16px;font-size:13px;font-weight:600;color:#94a3b8;background:#fff;border:0;border-bottom:2px solid transparent;margin-bottom:-2px;cursor:pointer;transition:all .15s;<%= has_ai ? '' : 'opacity:.4;pointer-events:none;' %>">
    ✨ Phân tích AI toàn bộ
    <span style="font-size:10px;font-weight:700;background:#d9e5f1;color:#1e3a5f;padding:1px 7px;border-radius:20px;margin-left:5px;vertical-align:middle;">AI</span>
  </button>
</div>

<!-- Pane: Results list -->
<div id="pane-results">
<div class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
  <% if @attempts.empty? %>
    <div class="p-12 text-center">
      <div class="text-4xl mb-3">📭</div>
      <p class="text-[14px] text-slate-400"><%= t("quiz.no_attempts") %></p>
    </div>
  <% else %>
    <table class="w-full text-[13px]">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
          <th class="text-left px-4 py-3 text-[11px] font-bold text-slate-500 uppercase">Họ tên</th>
          <th class="text-left px-4 py-3 text-[11px] font-bold text-slate-500 uppercase"><%= t("quiz.email") %></th>
          <th class="text-center px-4 py-3 text-[11px] font-bold text-slate-500 uppercase"><%= t("quiz.score") %></th>
          <th class="text-center px-4 py-3 text-[11px] font-bold text-slate-500 uppercase"><%= t("quiz.result") %></th>
          <th class="text-right px-4 py-3 text-[11px] font-bold text-slate-500 uppercase"><%= t("quiz.submitted_at") %></th>
          <th class="text-center px-4 py-3 text-[11px] font-bold text-slate-500 uppercase"></th>
          <% if @quiz_set.result_later? %>
            <th class="text-center px-4 py-3 text-[11px] font-bold text-slate-500 uppercase">Email</th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @attempts.each do |attempt| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3 font-semibold">
              <%= link_to attempt.participant_name, attempt_detail_quiz_set_path(@quiz_set, attempt_id: attempt.id), data: { turbo: false }, class: "text-slate-800 hover:text-indigo-600 hover:underline" %>
            </td>
            <td class="px-4 py-3">
              <%= link_to attempt.participant_email, attempt_detail_quiz_set_path(@quiz_set, attempt_id: attempt.id), data: { turbo: false }, class: "text-slate-400 hover:text-indigo-600 hover:underline text-[13px]" %>
            </td>
            <td class="px-4 py-3 text-center">
              <span class="font-bold <%= attempt.passed? ? 'text-emerald-600' : 'text-red-500' %>">
                <%= attempt.score_pct %>%
              </span>
              <span class="text-slate-400 text-[11px]"> (<%= attempt.earned_points %>/<%= attempt.total_points %>)</span>
            </td>
            <td class="px-4 py-3 text-center">
              <span class="text-[11px] px-2 py-0.5 rounded-full font-bold <%= attempt.passed? ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-600' %>">
                <%= attempt.passed? ? t("quiz.passed") : t("quiz.failed") %>
              </span>
            </td>
            <td class="px-4 py-3 text-right text-slate-400 text-[12px]">
              <%= attempt.submitted_at.strftime("%d/%m/%Y %H:%M") %>
            </td>
            <td class="px-4 py-3 text-center">
              <%= link_to attempt_detail_quiz_set_path(@quiz_set, attempt_id: attempt.id),
                  data: { turbo: false },
                  class: "inline-flex items-center gap-1 px-2.5 py-1 bg-slate-50 hover:bg-indigo-50 hover:text-indigo-600 text-slate-500 text-[11px] font-semibold rounded-lg transition-colors border border-slate-200" do %>
                👁 Xem chi tiết
              <% end %>
            </td>
            <% if @quiz_set.result_later? %>
              <td class="px-4 py-3 text-center">
                <button onclick="sendResultEmail(<%= attempt.id %>, this)"
                        class="inline-flex items-center gap-1 px-2.5 py-1 bg-indigo-50 hover:bg-indigo-100 text-indigo-600 text-[11px] font-bold rounded-lg transition-colors border-0 cursor-pointer">
                  📧 Gửi kết quả
                </button>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%# Pagination %>
<% if @pagy && @pagy.pages > 1 %>
  <div class="flex items-center justify-between mt-4 px-1">
    <p class="text-[12px] text-slate-400">
      Hiển thị <%= @pagy.from %>–<%= @pagy.to %> / <%= @pagy.count %> kết quả
    </p>
    <div class="flex gap-1">
      <% if @pagy.prev %>
        <%= link_to "‹ Trước", results_quiz_set_path(@quiz_set, page: @pagy.prev),
            class: "px-3 py-1.5 text-[12px] font-semibold rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-50" %>
      <% end %>
      <% (@pagy.from > 1 ? [[@pagy.page - 1, 1].max, @pagy.page, [@pagy.page + 1, @pagy.pages].min] : (1..[@pagy.pages, 3].min).to_a).uniq.each do |p| %>
        <%= link_to p, results_quiz_set_path(@quiz_set, page: p),
            class: "px-3 py-1.5 text-[12px] font-semibold rounded-lg border #{p == @pagy.page ? 'bg-indigo-600 text-white border-indigo-600' : 'border-slate-200 bg-white text-slate-600 hover:bg-slate-50'}" %>
      <% end %>
      <% if @pagy.next %>
        <%= link_to "Sau ›", results_quiz_set_path(@quiz_set, page: @pagy.next),
            class: "px-3 py-1.5 text-[12px] font-semibold rounded-lg border border-slate-200 bg-white text-slate-600 hover:bg-slate-50" %>
      <% end %>
    </div>
  </div>
<% end %>

</div><!-- /pane-results -->

<!-- Pane: Class AI -->
<div id="pane-class-ai" style="display:none;">
  <!-- Empty state (chưa có kết quả) -->
  <% if has_ai && @quiz_set.ai_class_evaluation.blank? %>
  <div id="class-ai-empty" style="background:#fff;border:1.5px dashed #7aaac9;border-radius:16px;padding:48px 24px;text-align:center;">
    <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,#f5f3ff,#d9e5f1);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:28px;">✨</div>
    <p style="font-size:15px;font-weight:800;color:#1e293b;margin:0 0 8px;">Phân tích AI toàn bộ kết quả</p>
    <p style="font-size:13px;color:#64748b;line-height:1.6;margin:0 0 6px;">AI sẽ phân tích dữ liệu của <strong><%= @all_attempts.count %> người</strong> tham gia —<br>tìm ra câu yếu, xu hướng sai và đề xuất cải thiện.</p>
    <p style="font-size:11px;color:#94a3b8;margin:0 0 20px;">Chi phí: 3 credits · Kết quả được lưu lại</p>
    <button onclick="runClassAiEval(this)" id="class-ai-run-btn"
            style="display:inline-flex;align-items:center;gap:8px;padding:10px 24px;border-radius:10px;font-size:13px;font-weight:700;background:linear-gradient(135deg,#1e3a5f,#6d28d9);color:#fff;border:0;cursor:pointer;box-shadow:0 4px 14px rgba(124,58,237,.35);">
      ✨ Chạy phân tích AI
    </button>
  </div>
  <% end %>

  <!-- Loading -->
  <div id="class-ai-loading" style="display:none;flex-direction:column;align-items:center;justify-content:center;gap:14px;min-height:220px;border-radius:16px;background:linear-gradient(135deg,#f5f3ff,#eef2ff);border:1.5px solid #7aaac9;padding:32px 20px;">
    <div style="position:relative;width:72px;height:72px;display:flex;align-items:center;justify-content:center;">
      <div style="position:absolute;inset:-8px;border-radius:50%;border:2px dashed #7aaac9;animation:rb-orbit 3s linear infinite"></div>
      <img src="/icon.svg" style="width:56px;height:56px;border-radius:14px;box-shadow:0 4px 16px rgba(124,58,237,.25);animation:vox-pulse 1.6s ease-in-out infinite;object-fit:contain"
           onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
      <div style="display:none;width:56px;height:56px;border-radius:14px;background:linear-gradient(135deg,#1e3a5f,#1e3a5f);align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(124,58,237,.25);animation:vox-pulse 1.6s ease-in-out infinite">
        <svg width="28" height="28" viewBox="0 0 36 36"><rect width="36" height="36" rx="9" fill="white" fill-opacity=".9"/><rect x="6" y="6" width="24" height="19" rx="5" fill="white"/><rect x="23" y="10" width="4" height="9" rx="1" fill="#1e3a5f"/></svg>
      </div>
    </div>
    <div style="text-align:center">
      <div style="font-size:11px;font-weight:700;color:#1e3a5f;letter-spacing:1px;text-transform:uppercase;margin-bottom:5px">✦ AI đang phân tích</div>
      <div style="font-size:14px;font-weight:700;color:#3b0764;margin-bottom:4px;">Đang phân tích toàn bộ kết quả...</div>
      <div id="class-ai-loading-sub" style="font-size:12px;color:#1e3a5f;opacity:.8;">Đọc dữ liệu từng câu hỏi</div>
    </div>
  </div>

  <!-- Result (cached hoặc vừa tạo) -->
  <div id="class-ai-result" style="<%= @quiz_set.ai_class_evaluation.present? ? '' : 'display:none;' %>background:#fff;border:1px solid #e2e8f0;border-radius:16px;overflow:hidden;">
    <div style="display:flex;align-items:center;gap:8px;padding:12px 20px;background:linear-gradient(135deg,#f5f3ff,#d9e5f1);border-bottom:1px solid #e9d5ff;">
      <span style="font-size:14px;">✨</span>
      <span style="font-size:13px;font-weight:700;color:#6d28d9;">Phân tích AI — Toàn bộ kết quả</span>
      <% if @quiz_set.ai_class_evaluated_at %>
        <span style="font-size:11px;color:#4a80a8;margin-left:4px;" id="class-ai-timestamp"><%= @quiz_set.ai_class_evaluated_at.strftime("%d/%m/%Y %H:%M") %></span>
      <% else %>
        <span style="font-size:11px;color:#4a80a8;margin-left:4px;" id="class-ai-timestamp"></span>
      <% end %>
      <button onclick="runClassAiEval(null, true)" style="margin-left:auto;display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:600;background:#faf5ff;border:1px solid #e9d5ff;color:#1e3a5f;cursor:pointer;">↻ Tạo lại</button>
    </div>
    <div id="class-ai-content" style="padding:24px 28px;font-size:13px;color:#475569;line-height:1.65;">
      <%= @quiz_set.ai_class_evaluation&.html_safe %>
    </div>
  </div>
</div><!-- /pane-class-ai -->

<!-- Toast -->
<div id="email-toast" style="display:none; position:fixed; bottom:24px; left:50%; transform:translateX(-50%);
     background:#1E293B; color:#fff; font-size:13px; font-weight:600; padding:10px 20px; border-radius:12px; z-index:50; white-space:nowrap;">
</div>

<!-- Send All Confirm Modal -->
<div id="send-all-modal" style="display:none; position:fixed; inset:0; z-index:50; background:rgba(15,23,42,0.45); backdrop-filter:blur(3px); align-items:center; justify-content:center;">
  <div style="background:#fff; border-radius:16px; box-shadow:0 20px 60px rgba(0,0,0,0.2); padding:28px 28px 24px; max-width:380px; width:90%; margin:auto; animation:modal-pop .18s ease both;">
    <div style="width:44px;height:44px;border-radius:50%;background:#EFF6FF;display:flex;align-items:center;justify-content:center;margin-bottom:16px;">
      <span style="font-size:22px;">📧</span>
    </div>
    <h3 style="font-size:16px;font-weight:800;color:#0F172A;margin:0 0 8px;">Gửi kết quả cho tất cả?</h3>
    <p style="font-size:13px;color:#64748B;margin:0 0 24px;line-height:1.6;">
      Email kết quả sẽ được gửi đến <strong><%= @all_attempts.count %> người</strong> đã nộp bài.
    </p>
    <div style="display:flex;gap:10px;">
      <button onclick="closeSendAllModal()" style="flex:1;padding:10px;border-radius:9px;border:1.5px solid #E2E8F0;background:#fff;font-size:13px;font-weight:600;color:#64748B;cursor:pointer;">Hủy</button>
      <button onclick="executeSendAll()" style="flex:1;padding:10px;border-radius:9px;border:0;background:#4F46E5;color:#fff;font-size:13px;font-weight:700;cursor:pointer;">📧 Gửi tất cả</button>
    </div>
  </div>
</div>
<style>
@keyframes modal-pop { from { opacity:0; transform:scale(.95) translateY(8px); } to { opacity:1; transform:scale(1) translateY(0); } }
</style>

<style>
@keyframes vox-pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.08);opacity:.85} }
@keyframes rb-orbit  { to { transform:rotate(360deg); } }
</style>
<script>
var CLASS_AI_URL   = '<%= ai_evaluate_results_quiz_set_path(@quiz_set) %>';
var classAiPhrases = ['Đọc dữ liệu từng câu hỏi','Tính tỷ lệ đúng/sai','Phân tích điểm yếu chung','Tổng hợp đề xuất cải thiện'];
var classPhIdx = 0, classPhTimer = null;
var _classAiBtn = null;

function switchResultTab(tab) {
  document.getElementById('pane-results').style.display   = tab === 'results'   ? 'block' : 'none';
  document.getElementById('pane-class-ai').style.display  = tab === 'class-ai'  ? 'block' : 'none';
  var tr = document.getElementById('tab-results');
  var ta = document.getElementById('tab-class-ai');
  var base = 'flex:1;padding:10px 16px;font-size:13px;background:#fff;border:0;margin-bottom:-2px;cursor:pointer;transition:all .15s;';
  if (tab === 'results') {
    tr.style.cssText = base + 'font-weight:700;color:#1e293b;border-bottom:2px solid #1e3a5f;';
    ta.style.cssText = base + 'font-weight:600;color:#94a3b8;border-bottom:2px solid transparent;';
  } else {
    tr.style.cssText = base + 'font-weight:600;color:#94a3b8;border-bottom:2px solid transparent;';
    ta.style.cssText = base + 'font-weight:700;color:#1e3a5f;border-bottom:2px solid #1e3a5f;';
  }
  history.replaceState(null, '', tab === 'class-ai' ? '#tab-ai' : '#');
}

// Restore tab from hash
(function() { if (window.location.hash === '#tab-ai') switchResultTab('class-ai'); }());

function runClassAiEval(triggerBtn, force) {
  if (triggerBtn) _classAiBtn = triggerBtn;
  var empty   = document.getElementById('class-ai-empty');
  var loading = document.getElementById('class-ai-loading');
  var result  = document.getElementById('class-ai-result');

  if (empty)  empty.style.display  = 'none';
  result.style.display  = 'none';
  loading.style.display = 'flex';

  if (_classAiBtn) { _classAiBtn.disabled = true; _classAiBtn.innerHTML = '⏳ Đang phân tích...'; }

  classPhIdx = 0;
  document.getElementById('class-ai-loading-sub').textContent = classAiPhrases[0];
  classPhTimer = setInterval(function() {
    classPhIdx = (classPhIdx + 1) % classAiPhrases.length;
    document.getElementById('class-ai-loading-sub').textContent = classAiPhrases[classPhIdx];
  }, 2000);

  fetch(CLASS_AI_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
    body: JSON.stringify({ force: force ? '1' : '' })
  }).then(function(r) { return r.json(); }).then(function(data) {
    clearInterval(classPhTimer);
    loading.style.display = 'none';
    if (_classAiBtn) { _classAiBtn.disabled = false; _classAiBtn.innerHTML = '✨ Chạy phân tích AI'; }
    if (data.html) {
      document.getElementById('class-ai-content').innerHTML = data.html;
      if (!data.cached) {
        var ts = new Date().toLocaleString('vi-VN', {day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'});
        document.getElementById('class-ai-timestamp').textContent = ts;
        if (window.deductDisplayCredits) window.deductDisplayCredits(3);
      }
      result.style.display = 'block';
      document.getElementById('tab-class-ai').innerHTML = '✨ Phân tích AI toàn bộ <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#10b981;margin-left:6px;vertical-align:middle;"></span> <span style="font-size:10px;font-weight:700;background:#d9e5f1;color:#1e3a5f;padding:1px 7px;border-radius:20px;margin-left:5px;vertical-align:middle;">AI</span>';
    } else {
      if (empty) empty.style.display = 'block';
      alert('Lỗi: ' + (data.error || 'Không thể phân tích'));
    }
  }).catch(function() {
    clearInterval(classPhTimer);
    loading.style.display = 'none';
    if (empty) empty.style.display = 'block';
    if (_classAiBtn) { _classAiBtn.disabled = false; _classAiBtn.innerHTML = '✨ Chạy phân tích AI'; }
    alert('Lỗi kết nối');
  });
}

<% if @quiz_set.ai_class_evaluation.present? %>
// Mark tab AI — cached result already on page
(function() {
  var ta = document.getElementById('tab-class-ai');
  if (ta) ta.innerHTML = '✨ Phân tích AI toàn bộ <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#10b981;margin-left:6px;vertical-align:middle;"></span> <span style="font-size:10px;font-weight:700;background:#d9e5f1;color:#1e3a5f;padding:1px 7px;border-radius:20px;margin-left:5px;vertical-align:middle;">AI</span>';
}());
<% end %>
</script>

<% if @quiz_set.result_later? %>
<script>
var SEND_EMAIL_URL = '<%= send_result_email_quiz_set_path(@quiz_set) %>';
var ATTEMPT_IDS = [<%= @all_attempts.pluck(:id).join(',') %>];
var _sendAllMasterBtn = null;

function sendAllResultEmails(masterBtn) {
  _sendAllMasterBtn = masterBtn;
  var m = document.getElementById('send-all-modal');
  m.style.display = 'flex';
}
function closeSendAllModal() {
  document.getElementById('send-all-modal').style.display = 'none';
}
function executeSendAll() {
  closeSendAllModal();
  var masterBtn = _sendAllMasterBtn;
  masterBtn.disabled = true;
  masterBtn.textContent = '⏳ Đang gửi...';
  var promises = ATTEMPT_IDS.map(function(id) {
    return fetch(SEND_EMAIL_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
      body: JSON.stringify({ attempt_id: id })
    }).then(function(r) { return r.json(); });
  });
  Promise.all(promises).then(function(results) {
    var failed = results.filter(function(r) { return !r.success; }).length;
    if (failed === 0) {
      masterBtn.textContent = '✅ Đã gửi tất cả';
      masterBtn.className = masterBtn.className.replace('bg-indigo-600 hover:bg-indigo-700', 'bg-emerald-600');
      showToast('Đã gửi kết quả đến tất cả học sinh!');
    } else {
      masterBtn.disabled = false;
      masterBtn.textContent = '📧 Gửi tất cả kết quả';
      showToast('Có ' + failed + ' email gửi thất bại', true);
    }
  }).catch(function() {
    masterBtn.disabled = false;
    masterBtn.textContent = '📧 Gửi tất cả kết quả';
    showToast('Lỗi kết nối', true);
  });
}

function sendResultEmail(attemptId, btn) {
  btn.disabled = true;
  btn.textContent = '⏳ Đang gửi...';
  fetch(SEND_EMAIL_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
    body: JSON.stringify({ attempt_id: attemptId })
  })
  .then(r => r.json())
  .then(data => {
    if (data.success) {
      btn.textContent = '✅ Đã gửi';
      btn.className = btn.className.replace('bg-indigo-50 hover:bg-indigo-100 text-indigo-600', 'bg-emerald-50 text-emerald-600');
      showToast('Email kết quả đã được gửi thành công!');
    } else {
      btn.disabled = false; btn.textContent = '📧 Gửi kết quả';
      showToast('Lỗi: ' + (data.error || 'Không thể gửi email'), true);
    }
  })
  .catch(() => { btn.disabled = false; btn.textContent = '📧 Gửi kết quả'; showToast('Lỗi kết nối', true); });
}
function showToast(msg, err) {
  var t = document.getElementById('email-toast');
  t.textContent = msg;
  t.style.background = err ? '#DC2626' : '#1E293B';
  t.style.display = 'block';
  setTimeout(() => { t.style.display = 'none'; }, 3000);
}
</script>
<% end %>
