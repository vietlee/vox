<% content_for :title, t("profile.title") %>

<div class="max-w-[560px]">
  <div class="mb-6">
    <div class="flex items-center gap-3">
      <%= render "admin/shared/back_btn" %>
      <h1 class="text-[21px] font-extrabold text-slate-900 tracking-tight">👤 <%= t("profile.title") %></h1>
    </div>
    <p class="text-[13px] text-slate-500 mt-0.5"><%= t("profile.subtitle") %></p>
  </div>


  <%= form_with url: profile_path, method: :patch, local: true, class: "space-y-5" do |f| %>
    <!-- Personal info -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <h2 class="text-[13px] font-bold text-slate-900 mb-4">👤 <%= t("profile.personal_info") %></h2>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("profile.name_label") %></label>
          <input type="text" name="name" value="<%= current_user.name %>" required
            class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none">
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("profile.email_label") %></label>
          <input type="email" value="<%= current_user.email %>" disabled
            class="w-full px-3 py-2.5 border border-slate-100 rounded-lg text-[14px] bg-slate-50 text-slate-400 cursor-not-allowed">
          <p class="text-[11px] text-slate-400 mt-1"><%= t("profile.email_note") %></p>
        </div>
      </div>
    </div>

    <!-- Change password -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <h2 class="text-[13px] font-bold text-slate-900 mb-1">🔑 <%= t("profile.change_password") %></h2>
      <p class="text-[12px] text-slate-400 mb-4"><%= t("profile.password_hint") %></p>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("profile.current_password") %></label>
          <input type="password" name="current_password" autocomplete="current-password"
            class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none">
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("profile.new_password") %></label>
          <input type="password" name="new_password" autocomplete="new-password"
            class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none">
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("profile.confirm_password") %></label>
          <input type="password" name="confirm_password" autocomplete="new-password"
            class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none">
        </div>
      </div>
    </div>

    <div class="flex justify-end">
      <button type="submit"
        class="px-5 py-2.5 bg-[#1e3a5f] text-white text-[13px] font-semibold rounded-lg hover:bg-[#1e3a5f] transition-colors">
        <%= t("profile.save_btn") %>
      </button>
    </div>
  <% end %>
</div>
