<% content_for :title, "Lộ trình học tập" %>

<div class="p-6 max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-[20px] font-extrabold text-slate-900">🗺️ Lộ trình học tập</h1>
      <p class="text-[13px] text-slate-500 mt-0.5">Tạo và quản lý lộ trình học có cấu trúc</p>
    </div>
    <%= link_to new_learning_path_path, class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-lg" do %>
      + Tạo lộ trình
    <% end %>
  </div>

  <% if @my_assignments.any? %>
    <div class="mb-6">
      <h2 class="text-[13px] font-bold text-slate-700 mb-3 uppercase tracking-wide">📌 Lộ trình được giao cho tôi</h2>
      <div class="grid gap-3">
        <% @my_assignments.each do |asgn| %>
          <%= link_to learning_path_assignment_path(asgn), class: "block bg-indigo-50 border border-indigo-200 rounded-xl p-4 hover:bg-indigo-100 transition-colors" do %>
            <div class="flex items-center justify-between">
              <div>
                <div class="text-[14px] font-bold text-indigo-900"><%= asgn.learning_path.title %></div>
                <div class="text-[12px] text-indigo-700 mt-0.5">Tiến độ: <%= asgn.progress_pct %>%<%= asgn.due_date ? " · Hạn: #{asgn.due_date.strftime('%d/%m/%Y')}" : "" %></div>
              </div>
              <div class="text-[12px] text-indigo-600 font-semibold">Học ngay →</div>
            </div>
            <div class="mt-2 h-1.5 bg-indigo-200 rounded-full overflow-hidden">
              <div class="h-1.5 bg-indigo-600 rounded-full" style="width: <%= asgn.progress_pct %>%"></div>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @learning_paths.any? %>
    <div class="grid gap-4">
      <% @learning_paths.each do |lp| %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5 flex items-start gap-4">
          <div class="text-2xl">🗺️</div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-[14px] font-bold text-slate-900"><%= lp.title %></span>
              <span class="text-[10px] px-2 py-0.5 rounded-full <%= lp.published? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-600' %>"><%= lp.published? ? "Đã phát hành" : "Nháp" %></span>
              <% if lp.ai_generated? %><span class="text-[10px] px-2 py-0.5 bg-purple-100 text-purple-700 rounded-full">✨ AI</span><% end %>
            </div>
            <div class="text-[12px] text-slate-500 mt-0.5"><%= lp.learning_path_items.size %> bài · <%= lp.subject.presence || "Tổng hợp" %> · <%= lp.created_by.name rescue "?" %></div>
          </div>
          <div class="flex gap-2">
            <%= link_to learning_path_path(lp), class: "text-[12px] px-3 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg" do %>Xem<% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 text-slate-400">
      <div class="text-5xl mb-3">🗺️</div>
      <p class="text-[14px]">Chưa có lộ trình nào. Tạo lộ trình đầu tiên!</p>
      <%= link_to "+ Tạo lộ trình", new_learning_path_path, class: "mt-2 inline-block text-indigo-600 text-[13px] font-semibold" %>
    </div>
  <% end %>
</div>
