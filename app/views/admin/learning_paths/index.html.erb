<% content_for :title, "Lộ trình học tập" %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight">🗺️ Lộ trình học tập</h1>
        <p class="text-[12px] font-bold text-slate-500 mt-0.5">Xây dựng chương trình học theo lộ trình có cấu trúc, giao cho học viên</p>
      </div>
    </div>
    <%= link_to new_learning_path_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors" do %>
      + Tạo lộ trình
    <% end %>
  </div>
</div>

<% if @my_assignments.any? %>
  <div class="flex-shrink-0 px-6 pt-2 pb-0">
    <div class="text-[11px] font-bold text-slate-500 uppercase tracking-widest mb-2">📌 Được giao cho tôi</div>
    <div class="grid grid-cols-2 gap-3 mb-4">
      <% @my_assignments.each do |asgn| %>
        <a href="<%= learning_path_assignment_path(asgn) %>" class="block bg-white border border-indigo-200 hover:border-indigo-400 rounded-xl p-4 transition-colors group">
          <div class="flex items-start justify-between gap-2 mb-3">
            <div class="text-[13px] font-bold text-slate-900 group-hover:text-indigo-600 transition-colors line-clamp-1"><%= asgn.learning_path.title %></div>
            <span class="text-[12px] font-bold text-indigo-600 shrink-0"><%= asgn.progress_pct %>%</span>
          </div>
          <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
            <div class="h-1.5 bg-indigo-500 rounded-full transition-all" style="width: <%= asgn.progress_pct %>%"></div>
          </div>
          <div class="mt-2 text-[11px] text-slate-400">
            <%= asgn.learning_path.learning_path_items.count %> bài
            <% if asgn.due_date %> · Hạn <%= asgn.due_date.strftime("%d/%m/%Y") %><% end %>
          </div>
        </a>
      <% end %>
    </div>
  </div>
<% end %>

<div class="flex-1 min-h-0 overflow-hidden px-6 pt-<%= @my_assignments.any? ? 0 : 3 %> pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
        <input type="text" placeholder="Tìm kiếm lộ trình..."
          class="w-full pl-8 pr-3 py-1.5 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white"
          oninput="filterRows(this,'lp-row','lp-no-results')">
      </div>
      <span class="text-[11px] text-slate-400 ml-auto"><%= @learning_paths.count %> lộ trình</span>
    </div>

    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @learning_paths.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Tên lộ trình</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Bài học</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Người học</th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5">Tạo lúc</th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <tr id="lp-no-results" class="hidden">
              <td colspan="5" class="px-4 py-10 text-center text-[13px] text-slate-400">Không tìm thấy kết quả</td>
            </tr>
            <% @learning_paths.each do |lp| %>
              <tr class="lp-row border-b border-slate-200 hover:bg-white/70 transition-colors"
                  data-title="<%= lp.title.downcase %>">
                <td class="px-4 py-3">
                  <%= link_to lp.title, learning_path_path(lp),
                      class: "text-[13px] font-semibold text-slate-800 hover:text-indigo-600 transition-colors" %>
                </td>
                <td class="px-4 py-3 text-[13px] text-slate-600"><%= lp.learning_path_items.size %> bài</td>
                <td class="px-4 py-3 text-[13px] text-slate-600"><%= lp.learning_path_assignments.count %></td>
                <td class="px-4 py-3 text-[12px] text-slate-400"><%= lp.created_at.strftime("%d/%m %H:%M") %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1 justify-end">
                    <%= link_to "Xem", learning_path_path(lp),
                        class: "text-[12px] text-slate-500 hover:text-indigo-600 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors" %>
                    <%= link_to "Sửa", edit_learning_path_path(lp),
                        class: "text-[12px] text-slate-500 hover:text-indigo-600 font-semibold px-2 py-1 rounded hover:bg-indigo-50 transition-colors" %>
                    <button type="button" onclick="confirmDelete('<%= learning_path_path(lp) %>', '<%= j lp.title %>')"
                            class="text-[12px] text-red-400 hover:text-red-600 font-semibold px-2 py-1 rounded hover:bg-red-50 transition-colors border-0 bg-transparent cursor-pointer">Xóa</button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% elsif @my_assignments.empty? %>
        <div class="py-20 text-center">
          <div class="text-5xl mb-4">🗺️</div>
          <h3 class="text-[15px] font-bold text-slate-700 mb-2">Chưa có lộ trình nào</h3>
          <p class="text-[13px] text-slate-400 mb-5">Tạo và quản lý lộ trình học có cấu trúc, giao cho người tham gia</p>
          <%= link_to "Tạo lộ trình đầu tiên", new_learning_path_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div id="lp-delete-modal" style="display:none; position:fixed; inset:0; z-index:60; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.5);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.18); width:100%; max-width:380px; padding:28px 24px;">
    <div style="width:48px; height:48px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg style="width:24px;height:24px;" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 style="font-size:16px; font-weight:800; color:#1E293B; text-align:center; margin:0 0 8px;">Xóa lộ trình?</h3>
    <p id="lp-delete-desc" style="font-size:13px; color:#64748B; text-align:center; margin:0 0 20px;"></p>
    <div style="display:flex; gap:8px;">
      <button id="lp-delete-btn" onclick="executeDelete()"
              style="flex:1; padding:11px; background:#EF4444; color:#fff; font-weight:700; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Xóa</button>
      <button onclick="document.getElementById('lp-delete-modal').style.display='none'"
              style="flex:1; padding:11px; background:#F1F5F9; color:#475569; font-weight:600; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Hủy</button>
    </div>
  </div>
</div>

<script>
let _lpDeletePath = null;
function confirmDelete(path, title) {
  _lpDeletePath = path;
  document.getElementById('lp-delete-desc').textContent = 'Bạn sắp xóa "' + title + '". Hành động này không thể hoàn tác.';
  document.getElementById('lp-delete-modal').style.display = 'flex';
}
function executeDelete() {
  if (!_lpDeletePath) return;
  const btn = document.getElementById('lp-delete-btn'); btn.disabled = true; btn.textContent = '...';
  const f = document.createElement('form'); f.method = 'POST'; f.action = _lpDeletePath;
  const m = document.createElement('input'); m.type='hidden'; m.name='_method'; m.value='delete';
  const c = document.createElement('input'); c.type='hidden'; c.name='authenticity_token'; c.value=document.querySelector('meta[name="csrf-token"]').content;
  f.appendChild(m); f.appendChild(c); document.body.appendChild(f); f.submit();
}
function filterRows(input, rowClass, noResultId) {
  var q = input.value.toLowerCase();
  var rows = document.querySelectorAll('.' + rowClass);
  var found = 0;
  rows.forEach(function(r) { var show = !q || (r.dataset.title||'').includes(q); r.style.display = show ? '' : 'none'; if(show) found++; });
  document.getElementById(noResultId).classList.toggle('hidden', found > 0 || !q);
}
</script>
