<% content_for :title, @learning_path.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @learning_path.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 flex-wrap">
      <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold <%= @learning_path.published? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
        <%= @learning_path.published? ? "Đã phát hành" : "Nháp" %>
      </span>
      <% if @learning_path.subject.present? %><span class="text-[12px] text-slate-400"><%= @learning_path.subject %></span><% end %>
      <% if @learning_path.ai_generated? %><span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-violet-100 text-violet-700">✨ AI</span><% end %>
    </div>
  </div>
  <div class="flex items-center gap-2 flex-shrink-0">
    <% unless @learning_path.published? %>
      <%= button_to publish_learning_path_path(@learning_path), method: :patch,
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
        Phát hành
      <% end %>
    <% end %>
    <%= link_to edit_learning_path_path(@learning_path),
        class: "flex items-center gap-1.5 px-3 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[13px] font-semibold rounded-xl transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
      Chỉnh sửa
    <% end %>
  </div>
</div>

<div class="grid grid-cols-[1fr_300px] gap-5">
  <!-- Left -->
  <div class="space-y-4">
    <!-- AI Generate -->
    <div class="bg-gradient-to-r from-violet-50 to-indigo-50 border border-violet-200 rounded-2xl p-5">
      <div class="flex items-start gap-3 mb-3">
        <div class="w-8 h-8 bg-violet-100 rounded-xl flex items-center justify-center shrink-0">
          <svg class="w-4 h-4 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <div>
          <div class="text-[13px] font-bold text-violet-900">✨ Tạo bài học bằng AI</div>
          <div class="text-[12px] text-violet-700 mt-0.5">AI sẽ tạo 5–8 bài học xen kẽ bài kiểm tra dựa trên chủ đề · <strong>5 credits</strong></div>
        </div>
      </div>
      <%= form_with url: ai_generate_learning_path_path(@learning_path), method: :post, local: true, id: "ai-lp-form" do %>
        <div class="flex gap-2">
          <input type="text" name="prompt" placeholder="Mô tả thêm: đối tượng, mức độ, trọng tâm..."
                 class="flex-1 px-3 py-2 border border-violet-200 rounded-xl text-[13px] bg-white focus:border-violet-400 outline-none">
          <button type="submit" id="ai-lp-btn" class="px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
            Tạo ngay
          </button>
        </div>
      <% end %>
    </div>

    <!-- Items list -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
        <h3 class="text-[14px] font-bold text-slate-900">📚 Danh sách bài học (<%= @items.size %>)</h3>
        <button onclick="document.getElementById('add-item-row').classList.toggle('hidden')"
                class="flex items-center gap-1.5 px-3 py-1.5 text-[12px] font-semibold bg-indigo-50 hover:bg-indigo-100 text-indigo-700 rounded-lg transition-colors border-0 cursor-pointer">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Thêm bài
        </button>
      </div>

      <!-- Add item row -->
      <div id="add-item-row" class="hidden px-5 py-3 bg-slate-50 border-b border-slate-100">
        <div class="flex gap-2">
          <input type="text" id="new-item-title" placeholder="Tên bài học hoặc bài kiểm tra..."
                 class="flex-1 px-3 py-2 border border-slate-200 rounded-xl text-[13px] focus:border-indigo-500 outline-none bg-white">
          <select id="new-item-type" class="px-3 py-2 border border-slate-200 rounded-xl text-[13px] bg-white text-slate-700 focus:border-indigo-500 outline-none">
            <option value="lesson">📖 Bài học</option>
            <option value="quiz">📝 Bài kiểm tra</option>
          </select>
          <button onclick="addItem()" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
            Thêm
          </button>
        </div>
      </div>

      <% if @items.empty? %>
        <div class="p-12 text-center">
          <div class="text-4xl mb-3">📖</div>
          <p class="text-[14px] text-slate-400">Chưa có bài học nào. Dùng AI hoặc thêm thủ công.</p>
        </div>
      <% else %>
        <div class="divide-y divide-slate-100">
          <% @items.each_with_index do |item, i| %>
            <div class="flex items-center gap-3 px-5 py-3.5 hover:bg-slate-50 group">
              <span class="text-slate-300 group-hover:text-slate-400 cursor-grab text-lg leading-none">⠿</span>
              <div class="w-7 h-7 rounded-lg flex items-center justify-center text-[13px] shrink-0 <%= item.quiz? ? 'bg-violet-50 text-violet-700' : 'bg-indigo-50 text-indigo-700' %>">
                <%= item.quiz? ? "📝" : "📖" %>
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-[13px] font-semibold text-slate-900"><%= i+1 %>. <%= item.title %></div>
                <div class="text-[11px] text-slate-400 mt-0.5">
                  <%= item.quiz? ? "Bài kiểm tra" : "Bài học" %> · ~<%= item.estimated_minutes %> phút
                </div>
              </div>
              <button onclick="deleteItem(<%= item.id %>)" title="Xóa"
                      class="hidden group-hover:block p-1.5 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors border-0 bg-transparent cursor-pointer">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Right -->
  <div class="space-y-4">
    <!-- Assign -->
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-100">
        <h3 class="text-[14px] font-bold text-slate-900">👤 Giao cho người tham gia</h3>
      </div>
      <div class="p-4">
        <%= form_with url: assign_learning_path_path(@learning_path), method: :post, local: true do %>
          <div class="space-y-3">
            <% if @workspace_members.empty? %>
              <p class="text-[12px] text-slate-400 text-center py-4">Chưa có thành viên trong workspace</p>
            <% else %>
              <div class="border border-slate-200 rounded-xl overflow-hidden max-h-44 overflow-y-auto">
                <% @workspace_members.each do |member| %>
                  <label class="flex items-center gap-2.5 px-3 py-2.5 hover:bg-slate-50 cursor-pointer border-b border-slate-100 last:border-0">
                    <input type="checkbox" name="user_ids[]" value="<%= member.id %>" class="w-4 h-4 rounded text-indigo-600">
                    <div class="flex-1 min-w-0">
                      <div class="text-[12px] font-semibold text-slate-800 truncate"><%= member.name %></div>
                      <div class="text-[11px] text-slate-400 truncate"><%= member.email %></div>
                    </div>
                  </label>
                <% end %>
              </div>
            <% end %>
            <div>
              <label class="block text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-1">Hạn nộp (tuỳ chọn)</label>
              <input type="date" name="due_date" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-[13px] focus:border-indigo-500 outline-none">
            </div>
            <button type="submit" class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
              Giao lộ trình
            </button>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Progress -->
    <% if @assignments.any? %>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100">
          <h3 class="text-[14px] font-bold text-slate-900">📊 Tiến độ (<%= @assignments.size %> người)</h3>
        </div>
        <div class="divide-y divide-slate-100">
          <% @assignments.each do |asgn| %>
            <div class="px-5 py-3">
              <div class="flex items-center justify-between text-[12px] mb-1.5">
                <span class="font-semibold text-slate-700 truncate"><%= asgn.assignee.name rescue "?" %></span>
                <span class="text-slate-500 shrink-0 ml-2"><%= asgn.progress_pct %>%</span>
              </div>
              <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
                <div class="h-1.5 bg-indigo-500 rounded-full" style="width:<%= asgn.progress_pct %>%"></div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<script>
function addItem() {
  const title = document.getElementById('new-item-title').value.trim();
  const type = document.getElementById('new-item-type').value;
  if (!title) return;
  fetch('<%= learning_path_learning_path_items_path(@learning_path) %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content },
    body: JSON.stringify({ learning_path_item: { title, item_type: type, estimated_minutes: 15 } })
  }).then(() => location.reload());
}
function deleteItem(id) {
  if (!confirm('Xóa bài học này?')) return;
  fetch('<%= learning_path_learning_path_items_path(@learning_path) %>/' + id, {
    method: 'DELETE',
    headers: { 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content }
  }).then(() => location.reload());
}
document.getElementById('ai-lp-form').addEventListener('submit', function() {
  document.getElementById('ai-lp-btn').disabled = true;
  showAiLoadingOverlay();
});
</script>

<%= render "shared/ai_loading_overlay", phases: ["Đang phân tích yêu cầu...", "Đang thiết kế lộ trình...", "Đang tạo bài học...", "Đang sắp xếp thứ tự..."] %>
