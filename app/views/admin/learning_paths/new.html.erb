<% content_for :title, "Tạo lộ trình học tập" %>

<div class="flex items-center gap-3 mb-4">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">🗺️ Tạo lộ trình học tập</h1>
</div>

<!-- Step guide -->
<div class="flex items-center gap-3 mb-6 max-w-xl">
  <div class="flex items-center gap-2 px-3 py-1.5 bg-indigo-600 text-white text-[12px] font-bold rounded-full">
    <span class="w-4 h-4 bg-white text-indigo-600 rounded-full flex items-center justify-center text-[10px] font-black">1</span>
    Đặt tên lộ trình
  </div>
  <div class="flex-1 h-px bg-slate-200"></div>
  <div class="flex items-center gap-2 px-3 py-1.5 bg-slate-100 text-slate-400 text-[12px] font-bold rounded-full">
    <span class="w-4 h-4 bg-slate-300 text-white rounded-full flex items-center justify-center text-[10px] font-black">2</span>
    Thêm bài học
  </div>
</div>

<div class="max-w-xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @learning_path, url: learning_paths_path, local: true do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Tiêu đề lộ trình *</label>
        <%= f.text_field :title, required: true,
            placeholder: "VD: Python căn bản, Ôn thi Toán THPT, Digital Marketing...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Môn học / Lĩnh vực</label>
        <%= f.text_field :subject, placeholder: "VD: Lập trình, Toán học, Marketing...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Mô tả</label>
        <%= f.text_area :description, rows: 3,
            placeholder: "Mô tả ngắn về lộ trình này...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none resize-none" %>
      </div>
      <div class="flex gap-2 pt-1">
        <%= f.submit "Tiếp theo: Thêm bài học →", class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors" %>
        <%= link_to "Hủy", learning_paths_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
