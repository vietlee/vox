<% content_for :title, "Tạo lộ trình học tập" %>
<div class="p-6 max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Quay lại", learning_paths_path, class: "text-[13px] text-slate-500 hover:text-slate-700" %>
    <h1 class="text-[20px] font-extrabold text-slate-900 mt-2">🗺️ Tạo lộ trình học tập</h1>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
    <%= form_with model: @learning_path, url: learning_paths_path do |f| %>
      <div class="space-y-5">
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Tiêu đề lộ trình *</label>
          <%= f.text_field :title, placeholder: "VD: Khóa học Python căn bản, Ôn thi Toán THPT, Digital Marketing...", required: true, class: "w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Môn học / Lĩnh vực</label>
          <%= f.text_field :subject, placeholder: "VD: Lập trình, Toán học, Marketing...", class: "w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[14px] outline-none focus:border-indigo-500" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Mô tả</label>
          <%= f.text_area :description, placeholder: "Mô tả ngắn về lộ trình này...", rows: 3, class: "w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[14px] resize-none outline-none focus:border-indigo-500" %>
        </div>
        <%= f.submit "Tạo lộ trình →", class: "w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-[14px] font-bold rounded-xl cursor-pointer border-0" %>
      </div>
    <% end %>
  </div>
</div>
