<% content_for :title, "Chỉnh sửa lộ trình" %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">Chỉnh sửa lộ trình</h1>
</div>

<div class="max-w-xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @learning_path, url: learning_path_path(@learning_path), method: :patch, local: true do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Tiêu đề *</label>
        <%= f.text_field :title, required: true,
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Môn học / Lĩnh vực</label>
        <%= f.text_field :subject,
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Mô tả</label>
        <%= f.text_area :description, rows: 3,
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none resize-none" %>
      </div>
      <div class="flex gap-2 pt-1">
        <%= f.submit "Lưu thay đổi", class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors" %>
        <%= link_to "Hủy", learning_path_path(@learning_path), class: "px-5 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
