<% content_for :title, t("ai.chat_title") %>
<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>

<style>
  /* Markdown rendered content inside AI bubbles */
  .ai-md p            { margin: 0 0 0.55em; line-height: 1.6; }
  .ai-md p:last-child { margin-bottom: 0; }
  .ai-md h1, .ai-md h2, .ai-md h3 { font-weight: 700; margin: 0.8em 0 0.3em; line-height: 1.3; color: #1e293b; }
  .ai-md h1 { font-size: 15px; }
  .ai-md h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.04em; color: #1e3a5f; }
  .ai-md h3 { font-size: 13px; }
  .ai-md strong { font-weight: 700; color: #1e293b; }
  .ai-md em { font-style: italic; }
  .ai-md ul, .ai-md ol { margin: 0.4em 0 0.55em 1.1em; padding: 0; }
  .ai-md li { margin-bottom: 0.2em; line-height: 1.55; }
  .ai-md ul li { list-style: disc; }
  .ai-md ol li { list-style: decimal; }
  .ai-md table { border-collapse: collapse; width: 100%; margin: 0.6em 0; font-size: 12px; }
  .ai-md th { background: #f1f5f9; text-align: left; padding: 5px 10px; font-weight: 600; border: 1px solid #e2e8f0; }
  .ai-md td { padding: 5px 10px; border: 1px solid #e2e8f0; }
  .ai-md tr:nth-child(even) td { background: #f8fafc; }
  .ai-md code { background: #f1f5f9; border-radius: 4px; padding: 1px 5px; font-size: 11px; font-family: monospace; }
  .ai-md pre  { background: #f1f5f9; border-radius: 8px; padding: 10px 12px; overflow-x: auto; margin: 0.5em 0; }
  .ai-md pre code { background: none; padding: 0; }
  .ai-md blockquote { border-left: 3px solid #a5b4fc; margin: 0.5em 0; padding: 4px 12px; color: #64748b; }
  .ai-md hr { border: none; border-top: 1px solid #e2e8f0; margin: 0.7em 0; }
</style>

<script src="https://cdn.jsdelivr.net/npm/marked@12/marked.min.js"></script>

<div class="flex items-center justify-between mb-5">
  <div class="flex items-center gap-3">
    <%= render "admin/shared/back_btn" %>
    <div class="w-11 h-11 rounded-lg flex items-center justify-center p-0.5 shrink-0"><%= render "admin/shared/ai_bot_icon" %></div>
    <div>
      <h1 class="text-[19px] font-extrabold text-slate-900"><%= t("ai.chat_title") %></h1>
      <p class="text-[13px] font-medium text-slate-600 mt-0.5"><%= t("ai.chat_subtitle") %></p>
    </div>
  </div>
  <% sub = current_workspace.active_subscription %>
  <div class="flex items-center gap-2">
    <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold" style="background:rgba(139,92,246,0.08); border:1px solid rgba(139,92,246,0.2); color:#1e3a5f;">
      ⚡ <span id="credit-display"><%= sub&.credit_balance || 0 %></span> <%= t("ai.credits_remaining") %> · <%= t("ai.credits_per_msg") %>
    </div>
    <button onclick="confirmClearChat()" class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:text-white hover:border-[#1e3a5f] text-slate-500 transition-colors">
      🗑 <%= t("ai.clear_chat") %>
    </button>
  </div>
</div>

<div class="grid grid-cols-[1fr_260px] gap-5 h-[calc(100vh-180px)]">

  <!-- Chat area -->
  <div class="flex flex-col bg-white rounded-[10px] border border-slate-200 shadow-sm overflow-hidden">

    <!-- Messages -->
    <div id="chat-messages" class="flex-1 overflow-y-auto p-5 space-y-4">
      <!-- Welcome message -->
      <div class="flex gap-3 max-w-2xl">
        <div class="w-14 h-14 rounded-xl flex items-center justify-center p-1 shrink-0 mt-0.5"><%= render "admin/shared/ai_bot_icon" %></div>
        <div class="bg-white border border-slate-200 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm max-w-lg text-[13px] text-slate-700 leading-relaxed">
          <%= t("ai.welcome_msg", workspace: current_workspace.name).html_safe %>
        </div>
      </div>
    </div>

    <!-- Input area -->
    <div class="border-t border-slate-100 p-4">
      <div class="flex gap-2 items-end">
        <textarea id="chat-input" rows="1" placeholder="<%= t("ai.input_placeholder") %>"
          class="flex-1 px-4 py-2.5 border border-slate-200 rounded-xl text-[13px] text-slate-800 outline-none resize-none leading-relaxed"
          style="max-height:120px;"
          onfocus="this.style.borderColor='#1e3a5f'" onblur="this.style.borderColor='#e2e8f0'"
          onkeydown="handleKey(event)"
          oninput="toggleSendBtn(this.value)"
          onkeyup="toggleSendBtn(this.value)"
          oncompositionend="toggleSendBtn(this.value)"></textarea>
        <button id="send-btn" onclick="sendMessage()" disabled
          class="px-4 py-2.5 text-[13px] font-bold rounded-xl flex-shrink-0 border-0 flex items-center gap-1.5 transition-all"
          style="background:#f1f0fb; color:#4a80a8; border:1px solid #d9e5f1; cursor:not-allowed;">
          <%= t("ai.send") %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/></svg>
        </button>
      </div>
      <p class="text-[10px] text-slate-400 mt-2"><%= t("ai.input_hint") %></p>
    </div>
  </div>

  <!-- Sidebar: suggestions + stats -->
  <div class="space-y-4 overflow-y-auto">

    <!-- Quick prompts -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
      <h3 class="text-[12px] font-bold text-slate-700 mb-3">💡 <%= t("ai.suggestions") %></h3>
      <div class="space-y-2">
        <% t("ai.quick_prompts").each do |prompt| %>
          <button onclick="usePrompt(this.dataset.p)" data-p="<%= h(prompt) %>"
            class="w-full text-left px-3 py-2 rounded-lg text-[12px] text-slate-600 hover:bg-[#1e3a5f] hover:text-white border border-slate-100 hover:border-[#1e3a5f] transition-colors">
            <%= prompt %>
          </button>
        <% end %>
      </div>
    </div>

    <!-- Stats snapshot -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-4">
      <h3 class="text-[12px] font-bold text-slate-700 mb-3">📊 <%= t("ai.workspace_data") %></h3>
      <div class="space-y-2 text-[12px]">
        <div class="flex justify-between">
          <span class="text-slate-500"><%= t("kpi.surveys") %></span>
          <strong class="text-slate-800"><%= current_workspace.surveys.count %></strong>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500"><%= t("kpi.votes") %></span>
          <strong class="text-slate-800"><%= current_workspace.votes.count %></strong>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500"><%= t("kpi.feedback") %></span>
          <strong class="text-slate-800"><%= current_workspace.feedback_boards.count %></strong>
        </div>
        <div class="flex justify-between">
          <span class="text-slate-500"><%= t("members.title") %></span>
          <strong class="text-slate-800"><%= current_workspace.users.count %></strong>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Clear chat confirm modal -->
<div id="clear-chat-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-[380px] max-w-full mx-4 p-6">
      <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center text-2xl mx-auto mb-4">🗑️</div>
      <h3 class="text-[16px] font-bold text-slate-900 text-center mb-2"><%= t("ai.clear_chat_confirm_title") %></h3>
      <p class="text-[13px] text-slate-500 text-center leading-relaxed mb-6"><%= t("ai.clear_chat_confirm_body") %></p>
      <div class="flex gap-3">
        <button onclick="closeClearConfirm()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 border-0 cursor-pointer transition-colors">
          <%= t("ai.clear_chat_confirm_cancel") %>
        </button>
        <button onclick="doClearChat()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold text-white border-0 cursor-pointer transition-colors"
          style="background:#ef4444;">
          <%= t("ai.clear_chat_confirm_ok") %>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
const CHAT_URL      = "<%= ai_chat_path %>";
const STATUS_URL    = "<%= ai_job_status_path("__ID__") %>";
const CSRF          = document.querySelector('meta[name="csrf-token"]').content;
const YOU_LABEL     = "<%= j t('ai.you_label') %>";
const ERROR_RETRY   = "<%= j t('ai.error_retry') %>";
const ERROR_CONNECT = "<%= j t('ai.error_connect') %>";
const NO_RESPONSE   = "<%= j t('ai.no_response') %>";
const AI_ERROR      = "<%= j t('ai.ai_error') %>";
const USER_INITIALS = "<%= j current_user.initials %>";
const AI_BOT_ICON  = <%= render("admin/shared/ai_bot_icon").to_json %>;

// ── localStorage key per workspace ───────────────────────────────────────────
const STORAGE_KEY = "vox_chat_<%= current_workspace.id %>_<%= current_user.id %>";

let conversationHistory = [];

// ── Persistence helpers ───────────────────────────────────────────────────────
function saveChat() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({
      history: conversationHistory,
      html:    document.getElementById('chat-messages').innerHTML
    }));
  } catch(e) {}
}

function restoreChat() {
  try {
    const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
    if (!saved || !saved.history?.length) return;
    conversationHistory = saved.history;
    document.getElementById('chat-messages').innerHTML = saved.html;
    // scroll to bottom
    const el = document.getElementById('chat-messages');
    el.scrollTop = el.scrollHeight;
  } catch(e) {}
}

function toggleSendBtn(value) {
  const btn = document.getElementById('send-btn');
  if (!btn || btn._sending) return;
  const hasText = value.trim().length > 0;
  btn.disabled = !hasText;
  if (hasText) {
    btn.style.background = '#d9e5f1';
    btn.style.color      = '#6d28d9';
    btn.style.border     = '1px solid #b3cbe3';
    btn.style.cursor     = 'pointer';
  } else {
    btn.style.background = '#f1f0fb';
    btn.style.color      = '#4a80a8';
    btn.style.border     = '1px solid #d9e5f1';
    btn.style.cursor     = 'not-allowed';
  }
}

function handleKey(e) {
  // e.isComposing = true khi IME tiếng Việt đang hoàn thành ký tự → không submit
  if (e.key === 'Enter' && !e.shiftKey && !e.isComposing) {
    e.preventDefault();
    sendMessage();
  }
  // Auto-resize
  const ta = document.getElementById('chat-input');
  ta.style.height = 'auto';
  ta.style.height = Math.min(ta.scrollHeight, 120) + 'px';
}

function usePrompt(text) {
  const input = document.getElementById('chat-input');
  input.value = text;
  input.focus();
  toggleSendBtn(text);
}

function confirmClearChat() {
  document.getElementById('clear-chat-modal').classList.remove('hidden');
}

function closeClearConfirm() {
  document.getElementById('clear-chat-modal').classList.add('hidden');
}

function doClearChat() {
  closeClearConfirm();
  conversationHistory = [];
  localStorage.removeItem(STORAGE_KEY);
  const messages = document.getElementById('chat-messages');
  while (messages.children.length > 1) messages.removeChild(messages.lastChild);
}

// alias kept for backward compatibility
const clearChat = doClearChat;

function escapeHtml(text) {
  return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderContent(isUser, content) {
  if (isUser) return escapeHtml(content).replace(/\n/g, '<br>');
  try {
    return marked.parse(content, { breaks: true, gfm: true });
  } catch(e) {
    return escapeHtml(content).replace(/\n/g, '<br>');
  }
}

function appendMessage(role, content) {
  const messages = document.getElementById('chat-messages');
  const isUser   = role === 'user';
  const wrapper  = document.createElement('div');
  wrapper.className = 'flex gap-3 max-w-2xl' + (isUser ? ' ml-auto flex-row-reverse' : '');
  if (!isUser) {
    const av = document.createElement('div');
    av.className = 'w-14 h-14 rounded-xl flex items-center justify-center p-1 shrink-0 mt-0.5';
    av.innerHTML = AI_BOT_ICON;
    wrapper.appendChild(av);
  }
  const bubble = document.createElement('div');
  bubble.className = isUser
    ? 'bg-violet-600 text-white rounded-2xl rounded-tr-sm px-4 py-3 max-w-sm text-[13px]'
    : 'bg-white border border-slate-200 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm max-w-lg text-[13px] text-slate-700 leading-relaxed ai-md';
  bubble.innerHTML = renderContent(isUser, content);
  wrapper.appendChild(bubble);
  messages.appendChild(wrapper);
  messages.scrollTop = messages.scrollHeight;
  return wrapper;
}

function appendTyping() {
  const messages = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.id = 'typing-indicator';
  div.className = 'flex gap-3 max-w-2xl';
  div.innerHTML = '<div class="w-14 h-14 rounded-xl flex items-center justify-center p-1 shrink-0 mt-0.5">' + AI_BOT_ICON + '</div>' +
    '<div class="bg-white border border-slate-200 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm flex gap-1 items-center">' +
    '<span class="w-2 h-2 rounded-full bg-violet-400 animate-bounce" style="animation-delay:0ms"></span>' +
    '<span class="w-2 h-2 rounded-full bg-violet-400 animate-bounce" style="animation-delay:150ms"></span>' +
    '<span class="w-2 h-2 rounded-full bg-violet-400 animate-bounce" style="animation-delay:300ms"></span>' +
    '</div>';
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

async function sendMessage() {
  const input = document.getElementById('chat-input');
  const msg   = input.value.trim();
  if (!msg) return;

  const btn = document.getElementById('send-btn');
  btn._sending = true;
  btn.disabled = true;
  btn.style.background = '#f1f0fb';
  btn.style.color      = '#4a80a8';
  btn.style.border     = '1px solid #d9e5f1';
  btn.style.cursor     = 'not-allowed';

  appendMessage('user', msg);
  conversationHistory.push({ role: 'user', content: msg });
  input.value = '';
  input.style.height = 'auto';
  appendTyping();

  try {
    const res = await fetch(CHAT_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF, 'Accept': 'application/json' },
      body: JSON.stringify({ message: msg, history: conversationHistory.slice(-10) })
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      document.getElementById('typing-indicator')?.remove();
      if ((res.status === 402 || err.upgrade_required) && window.showAiUpgradeModal) {
        window.showAiUpgradeModal('<%= j t("ai.chat_title") %>', err.insufficient_credits);
      } else {
        appendMessage('assistant', '❌ ' + (err.error || ERROR_RETRY));
      }
      btn._sending = false; toggleSendBtn(document.getElementById('chat-input').value);
      return;
    }

    const { job_id } = await res.json();
    pollChat(job_id, btn);
  } catch (e) {
    document.getElementById('typing-indicator')?.remove();
    appendMessage('assistant', '❌ ' + ERROR_CONNECT);
    btn.disabled = false; btn.style.opacity = '';
  }
}

async function pollChat(jobId, btn) {
  const res  = await fetch(STATUS_URL.replace('__ID__', jobId));
  const data = await res.json();

  if (data.status === 'done') {
    document.getElementById('typing-indicator')?.remove();
    const reply = data.output?.response || NO_RESPONSE;
    appendMessage('assistant', reply);
    conversationHistory.push({ role: 'assistant', content: reply });

    window.deductDisplayCredits?.(2); // AI chat costs 2 credits
    saveChat();

    btn.disabled = false; btn.style.opacity = '';
  } else if (data.status === 'failed') {
    document.getElementById('typing-indicator')?.remove();
    appendMessage('assistant', '❌ ' + AI_ERROR + ': ' + (data.error || 'Unknown error'));
    btn.disabled = false; btn.style.opacity = '';
  } else {
    setTimeout(() => pollChat(jobId, btn), 1500);
  }
}

// ── Restore conversation on page load ─────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  restoreChat();
  document.getElementById('clear-chat-modal')?.addEventListener('click', e => {
    if (e.target === e.currentTarget) closeClearConfirm();
  });
});
document.addEventListener('turbo:load', restoreChat);

// ── Expose onclick functions ──────────────────────────────────────────────────
Object.assign(window, { sendMessage, clearChat, usePrompt, handleKey, confirmClearChat, closeClearConfirm, doClearChat, toggleSendBtn });
})(); // end IIFE
</script>
