<% content_for :title, t("ai_tutor.title") %>
<% content_for :main_class, 'flex-1 overflow-hidden flex flex-col' %>
<% content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>

<!-- Header -->
<div class="flex items-center gap-3 px-6 py-4 border-b border-slate-200 bg-white flex-shrink-0">
  <%= render "admin/shared/back_btn" %>
  <div class="flex items-center gap-3 flex-1 min-w-0">
    <div class="w-11 h-11 rounded-lg flex items-center justify-center p-0.5 shrink-0"><%= render "admin/shared/ai_bot_icon" %></div>
    <div>
      <div class="text-[19px] font-extrabold text-slate-900"><%= t("ai_tutor.title") %></div>
      <div class="text-[13px] font-medium text-slate-600 mt-0.5">
        <% if @context_title.present? %>
          <%= t("ai_tutor.context_label") %> <strong class="text-slate-800"><%= @context_title %></strong>
        <% else %>
          <%= t("ai_tutor.subtitle") %>
        <% end %>
      </div>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @has_tts %>
      <button id="auto-speak-btn" onclick="toggleAutoSpeak()" title="<%= t('ai_tutor.auto_speak') %>"
              class="flex items-center gap-1.5 text-[11px] px-3 py-1.5 rounded-xl border transition-colors cursor-pointer bg-slate-50 border-slate-200 text-slate-400 hover:border-violet-300 hover:text-violet-600">
        <svg id="speak-icon-off" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/></svg>
        <svg id="speak-icon-on" class="w-3.5 h-3.5 hidden text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 6v12m0 0l-3-3m3 3l3-3M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zM18.364 5.636a9 9 0 010 12.728"/></svg>
        <span id="speak-label"><%= t("ai_tutor.auto_speak") %></span>
      </button>
    <% end %>
    <button onclick="clearHistory()" title="<%= t('ai_tutor.clear_history') %>"
            class="text-[11px] text-slate-400 hover:text-white hover:bg-[#1e3a5f] border border-slate-200 hover:border-[#1e3a5f] rounded-xl px-3 py-1.5 transition-colors cursor-pointer bg-slate-50">
      🗑 <%= t("ai_tutor.clear_history") %>
    </button>
    <div class="text-[11px] text-slate-400 bg-slate-50 border border-slate-200 rounded-xl px-3 py-1.5">
      <%= t("ai_tutor.credit_label") %>
    </div>
  </div>
</div>

<% if @context_type == "document_summary" && @context_title.present? %>
<div class="flex-shrink-0 mx-5 mt-3">
  <div class="flex items-center gap-2.5 px-4 py-2.5 bg-violet-50 border border-violet-200 rounded-xl">
    <svg class="w-4 h-4 text-violet-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
    <span class="text-[12px] text-violet-700"><%= t("ai_tutor.asking_about") %> <strong><%= @context_title %></strong></span>
    <%= link_to document_summary_path(@context_id), class: "ml-auto text-[11px] text-violet-500 hover:text-violet-700 font-semibold shrink-0" do %>
      <%= t("ai_tutor.view_document") %>
    <% end %>
  </div>
</div>
<% end %>

<!-- Messages -->
<div id="chat-messages" class="flex-1 overflow-y-auto p-5 space-y-4">
  <!-- Welcome -->
  <div class="flex gap-3 max-w-2xl">
    <div class="w-14 h-14 rounded-xl flex items-center justify-center p-1 shrink-0 mt-0.5"><%= render "admin/shared/ai_bot_icon" %></div>
    <div class="bg-white border border-slate-200 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm max-w-lg">
      <p class="text-[13px] text-slate-700 leading-relaxed">
        <%= t("ai_tutor.welcome_p1") %>
      </p>
      <p class="text-[13px] text-slate-700 leading-relaxed mt-2">
        <%= t("ai_tutor.welcome_p2").html_safe %>
      </p>
    </div>
  </div>
</div>

<!-- Voice recording indicator -->
<div id="voice-indicator" style="display:none" class="flex-shrink-0 flex items-center justify-center gap-2.5 py-2 bg-red-50">
  <div class="flex gap-0.5 items-end">
    <% 5.times do |i| %>
      <div class="w-[3px] bg-red-400 rounded-full animate-bounce" style="height:<%= [8,13,10,15,8][i] %>px;animation-delay:<%= i * 0.08 %>s"></div>
    <% end %>
  </div>
  <span class="text-[12px] font-semibold text-red-500"><%= t("ai_tutor.recording") %></span>
  <!-- Send -->
  <button onclick="stopRecording(false)" title="Gửi"
          class="w-7 h-7 flex items-center justify-center rounded-full bg-red-500 hover:bg-red-600 text-white cursor-pointer border-0 transition-colors">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
  </button>
  <!-- Cancel -->
  <button onclick="stopRecording(true)" title="Hủy"
          class="w-7 h-7 flex items-center justify-center rounded-full bg-red-100 hover:bg-[#1e3a5f] hover:text-white text-red-500 cursor-pointer border-0 transition-colors">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
  </button>
</div>

<!-- Input area -->
<div class="border-t border-slate-200 bg-white p-4 flex-shrink-0">
  <div class="max-w-3xl mx-auto">
    <!-- File attachment preview -->
    <div id="attach-preview" class="hidden flex-wrap gap-2 mb-2"></div>

    <!-- Input row -->
    <div class="flex gap-2 items-end">
      <!-- Textarea wrapper -->
      <div class="relative flex-1">
        <textarea id="tutor-input"
                  placeholder="<%= t('ai_tutor.input_placeholder') %>"
                  rows="2"
                  class="w-full px-4 pt-3 pb-9 border border-slate-200 rounded-2xl text-[14px] resize-none focus:border-violet-500 focus:ring-2 focus:ring-violet-100 outline-none transition-all"
                  oninput="toggleSend(this.value)" onkeyup="toggleSend(this.value)" oncompositionend="toggleSend(this.value)"></textarea>

        <input id="attach-input" type="file" class="hidden" multiple
               accept=".txt,.md,.csv,.json,.html,.xml,.pdf,.docx,.doc,.png,.jpg,.jpeg,.gif,.webp"
               onchange="handleAttach(this)">

        <!-- Bottom-right: attach + mic -->
        <div class="absolute bottom-2 right-2 flex items-center gap-0.5">
          <label for="attach-input" title="Đính kèm file"
                 class="w-7 h-7 flex items-center justify-center rounded-lg text-slate-400 hover:text-white hover:bg-[#1e3a5f] cursor-pointer transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/>
            </svg>
          </label>
          <% if @has_stt %>
          <button id="mic-btn" onclick="toggleRecording()"
                  title="Click để nói"
                  class="w-7 h-7 flex items-center justify-center rounded-lg text-slate-400 hover:text-white hover:bg-[#1e3a5f] border-0 cursor-pointer transition-colors select-none bg-transparent p-0">
            <svg id="mic-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
            </svg>
          </button>
          <% end %>
        </div>
      </div>

      <!-- Right buttons: voice call + send -->
      <div class="flex flex-col gap-1.5 self-end shrink-0">
        <% if @has_stt && @has_tts %>
        <button onclick="enterVoiceCall()"
                class="flex items-center justify-center w-11 h-11 rounded-2xl border-0 cursor-pointer transition-all bg-[#6C5CE7] hover:bg-[#5a4bd1] shadow-sm" title="Trò chuyện cùng AI">
          <svg viewBox="0 0 32 32" width="22" height="22" xmlns="http://www.w3.org/2000/svg">
            <circle cx="16" cy="16" r="16" fill="white"/>
            <rect x="7"  y="13" width="2.5" height="6"  rx="1.25" fill="#6C5CE7"/>
            <rect x="11" y="10" width="2.5" height="12" rx="1.25" fill="#6C5CE7"/>
            <rect x="15" y="8"  width="2.5" height="16" rx="1.25" fill="#6C5CE7"/>
            <rect x="19" y="10" width="2.5" height="12" rx="1.25" fill="#6C5CE7"/>
            <rect x="23" y="13" width="2.5" height="6"  rx="1.25" fill="#6C5CE7"/>
          </svg>
        </button>
        <% end %>
        <button id="send-btn" onclick="sendMsg()" disabled
                class="flex items-center justify-center w-11 h-11 bg-violet-600 hover:bg-violet-700 text-white font-bold rounded-2xl border-0 cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="mt-1.5">
      <span class="text-[11px] text-slate-400 flex items-center gap-1 flex-wrap">
        <span><%= t("ai_tutor.enter_hint") %></span>
        <% if @has_stt %>
        <span class="flex items-center gap-1">
          · Click
          <svg class="w-3 h-3 inline text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
          </svg>
          <%= t("ai_tutor.voice_hint") %>
        </span>
        <% end %>
      </span>
    </div>
  </div>
</div>

<script>
(function() {
const contextType = '<%= j @context_type %>';
const contextId   = '<%= j @context_id %>';
const STORAGE_KEY = 'vox_tutor_history_<%= current_workspace.id %>_<%= current_user.id %>';
const MAX_STORED  = 40; // số tin nhắn tối đa lưu
const csrf = () => document.querySelector('meta[name="csrf-token"]').content;

// Load history từ localStorage
let chatHistory = [];
try {
  const saved = localStorage.getItem(STORAGE_KEY);
  if (saved) chatHistory = JSON.parse(saved);
} catch(e) { chatHistory = []; }

// Render lại lịch sử khi tải trang
(function restoreHistory() {
  if (!chatHistory.length) return;
  chatHistory.forEach(m => appendMsg(m.role, m.content));
  // scroll xuống cuối
  const c = document.getElementById('chat-messages');
  if (c) c.scrollTop = c.scrollHeight;
})();

function saveHistory() {
  try {
    // Giữ tối đa MAX_STORED tin nhắn gần nhất
    const trimmed = chatHistory.slice(-MAX_STORED);
    localStorage.setItem(STORAGE_KEY, JSON.stringify(trimmed));
  } catch(e) {}
}

function clearHistory() {
  chatHistory = [];
  localStorage.removeItem(STORAGE_KEY);
  document.getElementById('chat-messages').innerHTML = '';
}

// ── File attachment ──────────────────────────────────────────
let _attachedFiles = []; // [{ name, content, type }]

function handleAttach(input) {
  const files = Array.from(input.files);
  if (!files.length) return;
  input.value = '';
  let pending = files.length;
  files.forEach(file => {
    const isImage = file.type.startsWith('image/');
    const reader = new FileReader();
    reader.onload = function(e) {
      _attachedFiles.push({ name: file.name, content: e.target.result, type: isImage ? 'image' : 'text' });
      pending--;
      if (pending === 0) {
        renderAttachPreview();
        toggleSend(document.getElementById('tutor-input').value);
      }
    };
    if (isImage) reader.readAsDataURL(file);
    else reader.readAsText(file);
  });
}

function renderAttachPreview() {
  const wrap = document.getElementById('attach-preview');
  if (!_attachedFiles.length) { wrap.innerHTML = ''; wrap.classList.add('hidden'); wrap.classList.remove('flex'); return; }
  wrap.classList.remove('hidden');
  wrap.classList.add('flex');
  wrap.innerHTML = _attachedFiles.map((f, i) => {
    const isImg = f.type === 'image';
    return isImg
      ? `<div class="relative group/chip">
           <img src="${f.content}" class="w-10 h-10 rounded-xl object-cover border border-violet-200 shadow-sm">
           <button onclick="removeAttach(${i})" class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-slate-700 hover:bg-red-500 text-white rounded-full border-0 cursor-pointer flex items-center justify-center p-0 opacity-0 group-hover/chip:opacity-100 transition-opacity">
             <svg class="w-2.5 h-2.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
           </button>
         </div>`
      : `<div class="flex items-center gap-1.5 bg-violet-50 border border-violet-200 rounded-xl px-2.5 py-1.5 text-[11px] text-violet-700 font-medium max-w-[140px]">
           <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
           <span class="truncate">${f.name}</span>
           <button onclick="removeAttach(${i})" class="ml-0.5 text-violet-400 hover:text-red-500 transition-colors border-0 bg-transparent cursor-pointer p-0 leading-none shrink-0">
             <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
           </button>
         </div>`;
  }).join('');
}

function removeAttach(i) {
  _attachedFiles.splice(i, 1);
  renderAttachPreview();
  toggleSend(document.getElementById('tutor-input').value);
}

function toggleSend(v) {
  document.getElementById('send-btn').disabled = !v.trim() && !_attachedFiles.length;
}

async function sendMsg() {
  const input = document.getElementById('tutor-input');
  const msg = input.value.trim();
  if (!msg && !_attachedFiles.length) return;

  let displayMsg = msg;
  let payloadMsg = msg;

  if (_attachedFiles.length) {
    const parts = _attachedFiles.map(f => {
      if (f.type === 'image') return `[Hình ảnh đính kèm: ${f.name}]`;
      return `Nội dung file (${f.name}):\n\`\`\`\n${f.content.slice(0, 8000)}\n\`\`\``;
    });
    payloadMsg = [msg, ...parts].filter(Boolean).join('\n\n');
    displayMsg = msg; // images shown in bubble via preview, text files show name
    _attachedFiles = [];
    renderAttachPreview();
  }

  input.value = ''; toggleSend(''); input.style.height = '';
  chatHistory.push({ role: 'user', content: payloadMsg });
  saveHistory();
  appendMsg('user', displayMsg);
  const thinkingEl = appendMsg('assistant', '<span class="inline-flex gap-1"><span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:0s"></span><span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:.15s"></span><span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:.3s"></span></span>', true);
  try {
    const res = await fetch('<%= ai_tutor_path %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf() },
      body: JSON.stringify({ message: payloadMsg, history: chatHistory.slice(0,-1), context_type: contextType, context_id: contextId })
    });
    const data = await res.json();
    const reply = data.response || data.error || 'Lỗi không xác định';
    thinkingEl.innerHTML = md(reply);
    if (data.response) {
      chatHistory.push({ role: 'assistant', content: data.response });
      saveHistory();
      if (typeof window.deductDisplayCredits === 'function') window.deductDisplayCredits(1);
      if (_autoSpeak) speakText(data.response);
      addSpeakButton(thinkingEl, data.response);
    }
  } catch(e) {
    thinkingEl.innerHTML = '<span class="text-red-500">Lỗi kết nối. Thử lại.</span>';
  }
}

function appendMsg(role, html, raw = false) {
  const container = document.getElementById('chat-messages');
  const wrapper = document.createElement('div');
  const isUser = role === 'user';
  wrapper.className = 'flex gap-3 max-w-2xl' + (isUser ? ' ml-auto flex-row-reverse' : '');
  if (!isUser) {
    const av = document.createElement('div');
    av.className = 'w-14 h-14 rounded-xl flex items-center justify-center p-1 shrink-0 mt-0.5';
    av.innerHTML = <%= raw render("admin/shared/ai_bot_icon").to_s.to_json %>;
    wrapper.appendChild(av);
  }
  const bubble = document.createElement('div');
  bubble.className = isUser
    ? 'bg-violet-600 text-white rounded-2xl rounded-tr-sm px-4 py-3 max-w-sm text-[13px]'
    : 'bg-white border border-slate-200 rounded-2xl rounded-tl-sm px-4 py-3 shadow-sm max-w-lg text-[13px] text-slate-700 leading-relaxed';
  bubble.innerHTML = raw ? html : (isUser ? escHtml(html) : md(html));
  wrapper.appendChild(bubble);
  container.appendChild(wrapper);
  container.scrollTop = container.scrollHeight;
  return bubble;
}

function md(t) {
  return (t||'')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,'<em>$1</em>')
    .replace(/`(.+?)`/g,'<code class="bg-slate-100 px-1 rounded text-[12px] font-mono">$1</code>')
    .replace(/\n/g,'<br>');
}
function escHtml(t) { return (t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

document.getElementById('tutor-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey && !e.isComposing) {
    e.preventDefault();
    if (!document.getElementById('send-btn').disabled) sendMsg();
  }
});

// ── TTS: Auto-speak ──────────────────────────────────────────────────────────
const HAS_TTS = <%= @has_tts ? 'true' : 'false' %>;
let _autoSpeak = false;
let _currentAudio = null;

function toggleAutoSpeak() {
  _autoSpeak = !_autoSpeak;
  const btn = document.getElementById('auto-speak-btn');
  const iconOff = document.getElementById('speak-icon-off');
  const iconOn  = document.getElementById('speak-icon-on');
  const label   = document.getElementById('speak-label');
  if (!btn) return;
  if (_autoSpeak) {
    btn.className = btn.className.replace('border-slate-200 text-slate-400', 'border-violet-400 text-violet-600 bg-violet-50');
    iconOff.classList.add('hidden'); iconOn.classList.remove('hidden');
    label.textContent = 'Tắt tự đọc';
  } else {
    btn.className = btn.className.replace('border-violet-400 text-violet-600 bg-violet-50', 'border-slate-200 text-slate-400');
    iconOn.classList.add('hidden'); iconOff.classList.remove('hidden');
    label.textContent = 'Tự đọc câu trả lời';
    if (_currentAudio) { _currentAudio.pause(); _currentAudio = null; }
  }
}

function addSpeakButton(bubble, text) {
  if (!HAS_TTS) return;
  const btn = document.createElement('button');
  btn.className = 'mt-2 flex items-center gap-1 text-[10px] text-slate-400 hover:text-violet-600 cursor-pointer bg-transparent border-0 p-0 transition-colors';
  btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 6v12m0 0l-3-3m3 3l3-3M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/></svg> Nghe';
  btn.onclick = () => speakText(text, btn);
  bubble.appendChild(btn);
}

async function speakText(text, btn) {
  if (!HAS_TTS) return;
  if (_currentAudio) { _currentAudio.pause(); _currentAudio = null; }
  const plain = text.replace(/\*\*(.+?)\*\*/g,'$1').replace(/\*(.+?)\*/g,'$1').replace(/`(.+?)`/g,'$1').replace(/#+\s/g,'').trim();
  const chunk = plain.slice(0, 1000); // limit to avoid huge TTS cost
  if (btn) { btn.innerHTML = '⏳ Đang tải...'; btn.disabled = true; }
  try {
    const fd = new FormData();
    fd.append('text', chunk);
    fd.append('model', 'eleven_turbo_v2_5');
    fd.append('source', 'tutor');
    fd.append('authenticity_token', csrf());
    const res = await fetch('<%= tts_generate_path %>', { method: 'POST', body: fd });
    if (!res.ok) throw new Error('TTS failed');
    const blob = await res.blob();
    const url  = URL.createObjectURL(blob);
    _currentAudio = new Audio(url);
    _currentAudio.onended = () => { URL.revokeObjectURL(url); _currentAudio = null; if (btn) { btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M12 6v12m0 0l-3-3m3 3l3-3M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/></svg> Nghe'; btn.disabled = false; } };
    _currentAudio.play();
    if (btn) { btn.innerHTML = '🔊 Đang phát'; }
  } catch(e) {
    if (btn) { btn.innerHTML = '⚠ Lỗi'; btn.disabled = false; }
  }
}

// ── VOICE CALL MODE ──────────────────────────────────────────────────────────
let _vcActive    = false;
let _vcListening = false;
let _vcRecorder  = null;
let _vcChunks    = [];
let _vcStream    = null;
let _vcAnalyser  = null;
let _vcSilTimer  = null;
let _vcAudioCtx  = null;
let _vcAnimFrame = null;
let _vcVoiceId   = localStorage.getItem('vc_voice_id') || '';
let _vcVoiceLang = localStorage.getItem('vc_voice_lang') || 'vi';
let _vcSpeed     = parseFloat(localStorage.getItem('vc_speed') || '0.95');

// ── Voice picker modal ────────────────────────────────────────────────────────
let _voiceList = null; // cached from API

function enterVoiceCall() {
  if (!HAS_STT || !HAS_TTS) return;
  openVoicePicker();
}

function openVoicePicker() {
  document.getElementById('vc-picker').style.display = 'flex';
  document.body.style.overflow = 'hidden';
  if (!_voiceList) loadVoiceList();
}

function closeVoicePicker() {
  document.getElementById('vc-picker').style.display = 'none';
  document.body.style.overflow = '';
}

async function loadVoiceList() {
  const el = document.getElementById('vc-voice-grid');
  el.innerHTML = '<div class="col-span-2 flex flex-col items-center gap-2 py-10 text-slate-400"><svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg><span class="text-[13px]">Đang tải giọng...</span></div>';
  try {
    const res = await fetch('<%= tts_voices_path %>', { headers: { 'X-CSRF-Token': csrf() } });
    const data = await res.json();
    // API returns array of { id, name, preview_url, category, language }
    _voiceList = (Array.isArray(data) ? data : (data.voices || [])).filter(v => v.id && v.name);
    renderVoiceGrid();
  } catch(e) {
    el.innerHTML = '<p class="text-red-400 text-[13px] col-span-2 text-center py-6">Không thể tải danh sách giọng</p>';
  }
}

function renderVoiceGrid() {
  const el = document.getElementById('vc-voice-grid');
  if (!_voiceList || !_voiceList.length) {
    el.innerHTML = '<p class="text-slate-500 text-[13px] col-span-2 text-center py-8">Không có giọng nào khả dụng</p>';
    return;
  }
  el.innerHTML = _voiceList.map((v, i) => {
    const isSelected = v.id === _vcVoiceId;
    const lang = v.language || 'en';
    const cat  = v.category || 'custom';
    // avatar color based on index
    const colors = ['#4a80a8','#2d5f8a','#3b82f6','#8b5cf6','#10b981','#f59e0b'];
    const color  = colors[i % colors.length];
    const initials = v.name.split(' ').map(w => w[0]).join('').slice(0,2).toUpperCase();
    const selBg   = 'rgba(74,128,168,0.18)';
    const selBdr  = '#4a80a8';
    const normBg  = 'rgba(255,255,255,0.04)';
    const normBdr = 'rgba(255,255,255,0.1)';
    return `
      <div data-vid="${v.id}" onclick="selectVoice('${v.id}', this)"
           class="vc-voice-card relative flex flex-col gap-2.5 p-3.5 rounded-2xl cursor-pointer"
           style="border:1.5px solid ${isSelected ? selBdr : normBdr};background:${isSelected ? selBg : normBg}">
        <!-- Avatar + name row -->
        <div class="flex items-center gap-2.5">
          <div class="w-9 h-9 rounded-full flex items-center justify-center shrink-0 text-[12px] font-bold text-white"
               style="background:${isSelected ? '#4a80a8' : color}">
            ${initials}
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-[13px] font-semibold truncate leading-tight" style="color:${isSelected ? '#fff' : 'rgba(255,255,255,0.85)'}">${v.name}</p>
            <p class="text-[10px] truncate capitalize" style="color:rgba(255,255,255,0.35)">${lang} · ${cat}</p>
          </div>
          ${isSelected ? `<svg class="w-4 h-4 shrink-0" fill="#4a80a8" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>` : ''}
        </div>
        <!-- Preview button -->
        <button onclick="event.stopPropagation(); previewVoice('${v.id}', this)"
                class="vc-preview-btn w-full flex items-center justify-center gap-1.5 py-1.5 rounded-xl text-[11px] font-medium border-0 cursor-pointer"
                style="background:${isSelected ? 'rgba(74,128,168,0.3)' : 'rgba(255,255,255,0.07)'};color:${isSelected ? '#7aaac9' : 'rgba(255,255,255,0.4)'}">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          Nghe thử
        </button>
      </div>`;
  }).join('');
}

function selectVoice(voiceId, el) {
  _vcVoiceId = voiceId;
  localStorage.setItem('vc_voice_id', voiceId);
  const v = _voiceList.find(x => x.id === voiceId);
  if (v) {
    _vcVoiceLang = v.language || 'vi';
    localStorage.setItem('vc_voice_lang', _vcVoiceLang);
    document.getElementById('vc-selected-name').textContent = v.name;
  }
  renderVoiceGrid();
}

let _previewAudio = null;
async function previewVoice(voiceId, btn) {
  if (_previewAudio) { _previewAudio.pause(); _previewAudio = null; }
  btn.innerHTML = '<svg class="w-3.5 h-3.5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>';
  try {
    const fd = new FormData();
    fd.append('text', 'Xin chào! Tôi là trợ lý AI của bạn.');
    fd.append('voice_id', voiceId);
    fd.append('model', 'eleven_turbo_v2_5');
    fd.append('source', 'flashcard');
    fd.append('authenticity_token', csrf());
    const res = await fetch('<%= tts_generate_path %>', { method: 'POST', body: fd });
    if (res.ok) {
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      _previewAudio = new Audio(url);
      _previewAudio.onended = () => URL.revokeObjectURL(url);
      _previewAudio.play();
    }
  } catch(e) {}
  btn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
}

function startVoiceCall() {
  closeVoicePicker();
  _vcActive = true;
  document.getElementById('vc-overlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
  // Sync selected voice name to top bar
  var vnd = document.getElementById('vc-voice-name-display');
  if (vnd && _voiceList) {
    var sv = _voiceList.find(function(x){ return x.id === _vcVoiceId; });
    if (sv) vnd.textContent = sv.name;
  }
  vcSetStatus('listening');
  vcStartListening();
}

function exitVoiceCall() {
  _vcActive = false;
  vcStopAll();
  document.getElementById('vc-overlay').style.display = 'none';
  document.body.style.overflow = '';
  if (_currentAudio) { _currentAudio.pause(); _currentAudio = null; }
}

function vcSetStatus(state) {
  const states = {
    listening:  { label: 'Đang lắng nghe...', sub: 'Cứ nói tự nhiên, tự động gửi khi bạn dừng', color: '#6C5CE7', pulse: true,  tapDisabled: false },
    processing: { label: 'Đang xử lý...',     sub: 'AI đang suy nghĩ',                           color: '#f59e0b', pulse: false, tapDisabled: true  },
    speaking:   { label: 'AI đang nói...',     sub: 'Nhấn mic để ngắt và hỏi tiếp',              color: '#10b981', pulse: true,  tapDisabled: false },
    idle:       { label: 'Sẵn sàng',           sub: 'Bắt đầu nói bất cứ lúc nào',               color: '#94a3b8', pulse: false, tapDisabled: false },
  };
  const s = states[state] || states.idle;
  const el  = document.getElementById('vc-status-label');
  const sub = document.getElementById('vc-status-sub');
  const ring = document.getElementById('vc-ring');
  const dot  = document.getElementById('vc-dot');
  const tap  = document.getElementById('vc-tap-btn');
  if (el)   el.textContent = s.label;
  if (sub)  sub.textContent = s.sub;
  /* Update orb glow, wisp colors and ring colors by state */
  var glowAnims = {
    listening:  'vc-blob 7s ease-in-out infinite, vc-glow-listening 2.5s ease-in-out infinite',
    speaking:   'vc-blob 3.5s ease-in-out infinite, vc-glow-speaking 1.6s ease-in-out infinite',
    processing: 'vc-blob 4.5s ease-in-out infinite, vc-glow-processing 1.0s ease-in-out infinite',
    idle:       'vc-blob 10s ease-in-out infinite, vc-glow-idle 4s ease-in-out infinite'
  };
  var w1Colors = {
    listening:  'conic-gradient(from 0deg at 50% 50%,transparent 0%,rgba(167,139,250,.90) 10%,transparent 22%,rgba(96,165,250,.75) 38%,transparent 52%,rgba(236,72,153,.65) 68%,transparent 80%,rgba(34,211,238,.55) 94%,transparent 100%)',
    speaking:   'conic-gradient(from 0deg at 50% 50%,transparent 0%,rgba(52,211,153,.95) 10%,transparent 22%,rgba(16,185,129,.80) 38%,transparent 52%,rgba(110,231,183,.75) 68%,transparent 80%,rgba(34,211,238,.60) 94%,transparent 100%)',
    processing: 'conic-gradient(from 0deg at 50% 50%,transparent 0%,rgba(251,191,36,.90) 10%,transparent 22%,rgba(245,158,11,.75) 38%,transparent 52%,rgba(252,211,77,.70) 68%,transparent 80%,rgba(167,139,250,.55) 94%,transparent 100%)',
    idle:       'conic-gradient(from 0deg at 50% 50%,transparent 0%,rgba(100,116,139,.45) 15%,transparent 38%,rgba(71,85,105,.35) 58%,transparent 78%,rgba(100,116,139,.30) 96%,transparent 100%)'
  };
  var ringColors = { listening: 'rgba(139,92,246,0.35)', speaking: 'rgba(16,185,129,0.35)', processing: 'rgba(245,158,11,0.35)', idle: 'rgba(100,116,139,0.20)' };
  var dotColors  = { listening: '#6366f1', speaking: '#10b981', processing: '#f59e0b', idle: '#64748b' };
  if (dot) { dot.style.animation = glowAnims[state] || glowAnims.idle; }
  var w1 = document.getElementById('vc-wisp1'); if (w1) w1.style.background = w1Colors[state] || w1Colors.idle;
  var r1 = document.getElementById('vc-ring1'); if (r1) r1.style.borderColor = ringColors[state] || ringColors.idle;
  var r2 = document.getElementById('vc-ring2'); if (r2) r2.style.borderColor = (ringColors[state] || ringColors.idle).replace('0.35','0.15');
  var di = document.getElementById('vc-dot-indicator'); if (di) di.style.background = dotColors[state] || dotColors.idle;
  if (tap) { tap.disabled = s.tapDisabled; tap.style.opacity = s.tapDisabled ? '0.4' : '1'; }
  var barsWrap = document.getElementById('vc-bars-wrap');
  var barEls = document.querySelectorAll('.vc-bar');
  if (state === 'listening') {
    barsWrap.style.opacity = '1';
    barsWrap.style.color = '#6366f1';
    barEls.forEach(function(b){ b.style.animation = ''; }); // restore CSS animation until analyser kicks in
  } else if (state === 'speaking') {
    barsWrap.style.opacity = '1';
    barsWrap.style.color = '#10b981';
    barEls.forEach(function(b){ b.style.animation = ''; }); // let CSS wave run
  } else if (state === 'processing') {
    barsWrap.style.opacity = '0.5';
    barsWrap.style.color = '#f59e0b';
    barEls.forEach(function(b){ b.style.animation = ''; });
  } else {
    barsWrap.style.opacity = '0.20';
    barEls.forEach(function(b){ b.style.animation = ''; });
  }
}

async function vcStartListening() {
  if (!_vcActive) return;
  vcSetStatus('listening');
  _vcListening = true;
  _vcChunks = [];
  try {
    _vcStream = await navigator.mediaDevices.getUserMedia({ audio: true });
    _vcAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const source = _vcAudioCtx.createMediaStreamSource(_vcStream);
    _vcAnalyser = _vcAudioCtx.createAnalyser();
    _vcAnalyser.fftSize = 256;
    source.connect(_vcAnalyser);
    vcAnimateBars();
    vcDetectSilence();

    _vcRecorder = new MediaRecorder(_vcStream, { mimeType: 'audio/webm' });
    _vcRecorder.ondataavailable = e => { if (e.data.size > 0) _vcChunks.push(e.data); };
    _vcRecorder.onstop = async () => {
      vcStopStream();
      if (!_vcActive || _vcChunks.length === 0) return;
      vcSetStatus('processing');
      await vcProcessAndReply();
    };
    _vcRecorder.start(200);
  } catch(e) {
    vcSetStatus('idle');
    document.getElementById('vc-status-sub').textContent = 'Không thể truy cập mic';
  }
}

function vcDetectSilence() {
  const data = new Uint8Array(_vcAnalyser.frequencyBinCount);
  let silenceMs = 0;
  let speechDetected = false;
  const SPEECH_THRESHOLD = 20;  // avg > 20 = đang nói
  const SILENCE_THRESHOLD = 14; // avg < 14 = im lặng
  const SILENCE_LIMIT = 1000;   // 1.0s im lặng sau khi nói → gửi
  const MAX_RECORD = 30000;
  const startTime = Date.now();

  function check() {
    if (!_vcListening || !_vcActive) return;
    _vcAnalyser.getByteFrequencyData(data);
    const avg = data.reduce((a, b) => a + b, 0) / data.length;

    if (avg >= SPEECH_THRESHOLD) {
      speechDetected = true;
      silenceMs = 0;
    } else if (speechDetected && avg < SILENCE_THRESHOLD) {
      silenceMs += 100;
      if (silenceMs >= SILENCE_LIMIT) { vcStopListening(); return; }
    }

    if (Date.now() - startTime > MAX_RECORD) { vcStopListening(); return; }
    _vcSilTimer = setTimeout(check, 100);
  }
  _vcSilTimer = setTimeout(check, 300);
}

function vcAnimateBars() {
  if (!_vcAnalyser) return;
  _vcAnalyser.fftSize = 512;
  _vcAnalyser.smoothingTimeConstant = 0.80;
  const data = new Uint8Array(_vcAnalyser.frequencyBinCount);
  const bars = document.querySelectorAll('.vc-bar');
  const smoothed = new Array(bars.length).fill(0.10);
  // Voice frequency range: ~80Hz-4kHz = first 35% of bins at 48kHz
  const voiceBins = Math.floor(_vcAnalyser.frequencyBinCount * 0.35);
  function frame() {
    if (!_vcActive) return;
    _vcAnalyser.getByteFrequencyData(data);
    const slice = Math.max(1, Math.floor(voiceBins / bars.length));
    bars.forEach((b, i) => {
      // Average a small window around this band
      let sum = 0, cnt = Math.min(slice, 4);
      for (let j = 0; j < cnt; j++) sum += (data[i * slice + j] || 0);
      const raw = sum / cnt;
      // Aggressive boost for low signals (power < 1 amplifies quiet sounds)
      const boosted = Math.pow(raw / 255, 0.45);
      const target = Math.max(0.08, Math.min(1.0, boosted * 1.4));
      smoothed[i] = smoothed[i] * 0.4 + target * 0.6;
      b.style.transform = 'scaleY(' + smoothed[i].toFixed(3) + ')';
      b.style.animation = 'none';
    });
    _vcAnimFrame = requestAnimationFrame(frame);
  }
  _vcAnimFrame = requestAnimationFrame(frame);
}

function vcStopListening() {
  _vcListening = false;
  clearTimeout(_vcSilTimer);
  if (_vcRecorder && _vcRecorder.state === 'recording') _vcRecorder.stop();
}

function vcStopStream() {
  if (_vcStream) { _vcStream.getTracks().forEach(t => t.stop()); _vcStream = null; }
  if (_vcAudioCtx) { _vcAudioCtx.close().catch(()=>{}); _vcAudioCtx = null; }
  if (_vcAnimFrame) { cancelAnimationFrame(_vcAnimFrame); _vcAnimFrame = null; }
}

function vcStopAll() {
  _vcListening = false;
  clearTimeout(_vcSilTimer);
  if (_vcRecorder && _vcRecorder.state !== 'inactive') { try { _vcRecorder.stop(); } catch(e){} }
  vcStopStream();
}

function vcTapMic() {
  if (!_vcActive) return;
  if (_vcListening) {
    // Force-stop & send
    vcStopListening();
  } else if (_vcAudioCtx) {
    // Currently speaking — interrupt
    if (_currentAudio) { _currentAudio.pause(); _currentAudio = null; }
    setTimeout(() => { if (_vcActive) vcStartListening(); }, 200);
  } else {
    vcStartListening();
  }
}

async function vcProcessAndReply() {
  if (_vcChunks.length === 0) { if (_vcActive) vcStartListening(); return; }
  const blob = new Blob(_vcChunks, { type: 'audio/webm' });
  _vcChunks = [];

  // Show processing immediately so user knows we received their voice
  vcSetStatus('processing');
  const txEl2 = document.getElementById('vc-transcript');
  if (txEl2) { txEl2.textContent = '⏳ Đang nhận dạng giọng nói...'; txEl2.style.opacity = '1'; }

  // STT
  const fd = new FormData();
  fd.append('chunk', blob, 'voice.webm');
  fd.append('authenticity_token', csrf());
  let userText = '';
  try {
    const r = await fetch('<%= stt_transcribe_chunk_path %>', { method: 'POST', body: fd });
    const d = await r.json();
    userText = (d.text || '').trim();
  } catch(e) {}

  if (!userText) { if (_vcActive) vcStartListening(); return; }

  // Show in chat
  appendMsg('user', userText);
  chatHistory.push({ role: 'user', content: userText });
  saveHistory();

  // Update transcript display + show processing state immediately
  const txEl = document.getElementById('vc-transcript');
  if (txEl) { txEl.textContent = '🗣 ' + userText; txEl.style.opacity = '1'; }
  vcSetStatus('processing');

  // AI — streaming response, pipeline TTS per sentence
  const thinkEl = appendMsg('assistant', '<span class="inline-flex gap-1"><span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce"></span><span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:.15s"></span><span class="w-1.5 h-1.5 bg-slate-400 rounded-full animate-bounce" style="animation-delay:.3s"></span></span>', true);
  let reply = '';
  let vcRes;
  try {
    vcRes = await fetch('<%= ai_tutor_voice_path %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf() },
      body: JSON.stringify({ message: userText, history: chatHistory.slice(0,-1), context_type: contextType, context_id: contextId, voice_language: _vcVoiceLang })
    });
  } catch(e) { thinkEl.innerHTML = '<span class="text-red-500">Lỗi kết nối.</span>'; if (_vcActive) vcStartListening(); return; }

  if (!vcRes.ok) { thinkEl.innerHTML = '<span class="text-red-500">Lỗi kết nối.</span>'; if (_vcActive) vcStartListening(); return; }

  // TTS pipeline: fetch per sentence in parallel, play strictly in order
  const ttsQueue = [];    // { url: string|null, failed: bool }
  let   ttsNext  = 0;     // next index to play
  let   ttsDone  = false; // all sentences have been queued
  let   ttsPlaying = false; // guard: only one audio at a time

  async function vcFetchTTS(text, idx) {
    const clean = text.replace(/\*\*(.+?)\*\*/g,'$1').replace(/\*(.+?)\*/g,'$1')
                      .replace(/`(.+?)`/g,'$1').replace(/#+\s*/g,'').trim();
    if (!clean) { ttsQueue[idx].failed = true; vcAdvancePlay(); return; }
    const fd2 = new FormData();
    fd2.append('text', clean); fd2.append('model', 'eleven_flash_v2_5');
    fd2.append('source', 'voice_call'); fd2.append('skip_normalize', 'true');
    fd2.append('speed', String(_vcSpeed));
    fd2.append('stability', '0.75');    // high = consistent volume & tone
    fd2.append('similarity', '0.85');   // high = stays true to chosen voice
    fd2.append('style', '0.0');         // 0 = no style exaggeration (more stable)
    fd2.append('authenticity_token', csrf());
    if (_vcVoiceId) fd2.append('voice_id', _vcVoiceId);
    try {
      const ar = await fetch('<%= tts_generate_path %>', { method: 'POST', body: fd2 });
      if (!ar.ok) { ttsQueue[idx].failed = true; }
      else { const blob = await ar.blob(); ttsQueue[idx].url = URL.createObjectURL(blob); }
    } catch(e) { ttsQueue[idx].failed = true; }
    vcAdvancePlay();
  }

  // Called whenever a TTS fetch completes or an audio clip ends.
  // Plays the next ready chunk in order; ignores if already playing.
  function vcAdvancePlay() {
    if (!_vcActive || ttsPlaying) return;
    // Skip past failed entries
    while (ttsNext < ttsQueue.length && ttsQueue[ttsNext].failed) ttsNext++;
    // Check if finished
    if (ttsNext >= ttsQueue.length) {
      if (ttsDone) { if (_vcActive) vcStartListening(); }
      return;
    }
    const entry = ttsQueue[ttsNext];
    if (!entry.url) return; // not ready yet — will be called again when ready
    ttsNext++;
    ttsPlaying = true;
    vcSetStatus('speaking');
    _currentAudio = new Audio(entry.url);
    _currentAudio.onended = () => {
      URL.revokeObjectURL(entry.url);
      _currentAudio = null;
      ttsPlaying = false;
      vcAdvancePlay(); // play next in sequence
    };
    _currentAudio.play().catch(() => {
      _currentAudio = null;
      ttsPlaying = false;
      vcAdvancePlay();
    });
  }

  let sentBuf = '';
  let ttsIdx  = 0;

  function vcQueueSentence(text) {
    if (!text.trim()) return;
    const i = ttsIdx++;
    ttsQueue.push({ url: null, failed: false });
    vcFetchTTS(text, i);
  }

  function vcFlushSentences(force) {
    const re = /^(.*?[.!?。！？]+)\s*/s;
    let m;
    while ((m = sentBuf.match(re))) {
      if (m[1].trim().length < 4) { sentBuf = sentBuf.slice(m[0].length); continue; }
      vcQueueSentence(m[1]);
      sentBuf = sentBuf.slice(m[0].length);
    }
    if (force && sentBuf.trim()) { vcQueueSentence(sentBuf); sentBuf = ''; }
  }

  // Read the streaming body
  try {
    const reader  = vcRes.body.getReader();
    const decoder = new TextDecoder();
    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      const chunk = decoder.decode(value, { stream: true });
      reply   += chunk;
      sentBuf += chunk;
      thinkEl.innerHTML = md(reply);
      vcFlushSentences(false);
    }
    vcFlushSentences(true);
  } catch(e) { /* network error mid-stream */ }

  if (reply) {
    chatHistory.push({ role: 'assistant', content: reply });
    saveHistory();
    if (typeof window.deductDisplayCredits === 'function') window.deductDisplayCredits(1);
    addSpeakButton(thinkEl, reply);
    if (txEl) txEl.textContent = '🤖 ' + reply.slice(0, 80) + (reply.length > 80 ? '...' : '');
  }

  ttsDone = true;
  if (ttsIdx === 0) { if (_vcActive) vcStartListening(); return; }
  // All TTS may have already finished before ttsDone was set — trigger check
  vcAdvancePlay();
}

// ── STT: Voice input ─────────────────────────────────────────────────────────
const HAS_STT = <%= @has_stt ? 'true' : 'false' %>;
let _mediaRecorder = null;
let _audioChunks   = [];
let _cancelled     = false;

function toggleRecording() {
  if (_mediaRecorder) { stopRecording(false); } else { startRecording(); }
}

async function startRecording() {
  if (!HAS_STT || _mediaRecorder) return;
  _cancelled = false;
  _audioChunks = [];
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    _mediaRecorder = new MediaRecorder(stream, { mimeType: 'audio/webm' });
    _mediaRecorder.ondataavailable = e => { if (e.data.size > 0) _audioChunks.push(e.data); };
    _mediaRecorder.onstop = async () => {
      stream.getTracks().forEach(t => t.stop());
      document.getElementById('voice-indicator').style.display = 'none';
      document.getElementById('mic-btn').classList.remove('bg-red-100','text-red-600');
      if (_cancelled || _audioChunks.length === 0) { _mediaRecorder = null; return; }
      const blob = new Blob(_audioChunks, { type: 'audio/webm' });
      await transcribeAndSend(blob);
      _mediaRecorder = null;
    };
    _mediaRecorder.start(250);
    document.getElementById('voice-indicator').style.display = 'flex';
    document.getElementById('mic-btn').classList.add('bg-red-100','text-red-600');
  } catch(e) {
    alert('Không thể truy cập microphone. Vui lòng cấp quyền và thử lại.');
    _mediaRecorder = null;
  }
}

function stopRecording(cancel) {
  if (!_mediaRecorder) return;
  _cancelled = cancel;
  _mediaRecorder.stop();
}

async function transcribeAndSend(blob) {
  const input = document.getElementById('tutor-input');
  input.placeholder = '⏳ Đang nhận dạng giọng nói...';
  input.disabled = true;
  try {
    const fd = new FormData();
    fd.append('chunk', blob, 'voice.webm');
    fd.append('authenticity_token', csrf());
    const res  = await fetch('<%= stt_transcribe_chunk_path %>', { method: 'POST', body: fd });
    const data = await res.json();
    if (data.text && data.text.trim()) {
      input.value = data.text.trim();
      toggleSend(input.value);
      // auto-send after short delay so user sees the text
      setTimeout(() => { if (input.value.trim()) sendMsg(); }, 600);
    } else {
      input.placeholder = 'Không nhận được giọng nói. Thử lại...';
    }
  } catch(e) {
    input.placeholder = 'Lỗi nhận dạng. Thử lại...';
  } finally {
    input.disabled = false;
    setTimeout(() => { input.placeholder = 'Hỏi bất cứ điều gì bạn muốn hiểu...'; }, 2000);
  }
}

// Expose functions called from HTML event attributes
window.clearHistory = clearHistory;
window.handleAttach = handleAttach;
window.removeAttach = removeAttach;
window.sendMsg = sendMsg;
window.toggleAutoSpeak = toggleAutoSpeak;
window.enterVoiceCall = enterVoiceCall;
window.toggleSend = toggleSend;
window.sendMsg = sendMsg;
window.removeAttach = removeAttach;
window.previewVoice = previewVoice;
window.closeVoicePicker = closeVoicePicker;
window.selectVoice = selectVoice;
window.startVoiceCall = startVoiceCall;
window.exitVoiceCall = exitVoiceCall;
window.toggleRecording = toggleRecording;
window.stopRecording = stopRecording;

const VC_SPEEDS = [0.75, 0.85, 0.95, 1.0, 1.1];
function vcSyncSpeedLabel() {
  const lbl = document.getElementById('vc-speed-label');
  if (lbl) lbl.textContent = _vcSpeed + '×';
  const btnDec = document.getElementById('vc-speed-dec');
  const btnInc = document.getElementById('vc-speed-inc');
  if (btnDec) btnDec.style.opacity = _vcSpeed <= VC_SPEEDS[0] ? '0.3' : '1';
  if (btnInc) btnInc.style.opacity = _vcSpeed >= VC_SPEEDS[VC_SPEEDS.length-1] ? '0.3' : '1';
}
window.vcSpeedDec = function() {
  const idx = VC_SPEEDS.indexOf(_vcSpeed);
  if (idx <= 0) return;
  _vcSpeed = VC_SPEEDS[idx - 1];
  localStorage.setItem('vc_speed', String(_vcSpeed));
  vcSyncSpeedLabel();
};
window.vcSpeedInc = function() {
  const idx = VC_SPEEDS.indexOf(_vcSpeed);
  if (idx >= VC_SPEEDS.length - 1) return;
  _vcSpeed = VC_SPEEDS[idx + 1];
  localStorage.setItem('vc_speed', String(_vcSpeed));
  vcSyncSpeedLabel();
};
document.addEventListener('DOMContentLoaded', vcSyncSpeedLabel);
})();
</script>

