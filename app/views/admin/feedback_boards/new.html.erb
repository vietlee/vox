<% content_for :title, "New Board" %>
<div class="max-w-[600px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5">💬 New Feedback Board</h1>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with model: @board, url: feedback_boards_path, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Board Title *</label>
          <%= f.text_field :title, required: true, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Description</label>
          <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none resize-none" %>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Identity Mode</label>
            <%= f.select :identity_mode, FeedbackBoard.identity_modes.keys.map { |k| [k.humanize, k] }, {}, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
        </div>
        <div class="flex flex-col gap-2 pt-2">
          <label class="flex items-center gap-2 text-[13px] text-slate-700">
            <%= f.check_box :auto_moderation, class: "accent-indigo-600 w-4 h-4 rounded" %> Enable AI auto-moderation
          </label>
          <label class="flex items-center gap-2 text-[13px] text-slate-700">
            <%= f.check_box :allow_upvotes, class: "accent-indigo-600 w-4 h-4 rounded" %> Allow upvoting
          </label>
          <label class="flex items-center gap-2 text-[13px] text-slate-700">
            <%= f.check_box :allow_replies, class: "accent-indigo-600 w-4 h-4 rounded" %> Allow replies
          </label>
        </div>
        <div class="flex gap-2 pt-4 border-t border-slate-100">
          <%= f.submit "Create Board", class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to "Cancel", feedback_boards_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
