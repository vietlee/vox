<% content_for :title, @board.title %>
<div class="max-w-[600px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5">Edit: <%= @board.title %></h1>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with model: @board, url: feedback_board_path(@board), method: :patch, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Title</label>
          <%= f.text_field :title, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Description</label>
          <%= f.text_area :description, rows: 3, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none resize-none" %>
        </div>
        <div class="flex gap-2 pt-4">
          <%= f.submit "Save", class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to "View Feedbacks", feedback_board_feedbacks_path(@board), class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
