<% content_for :title, @board.title %>

<div class="max-w-5xl mx-auto">
  <!-- Page header -->
  <div class="flex items-center justify-between mb-6">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <div class="flex items-center gap-2 text-[12px] text-slate-400 mb-1">
          <%= link_to t("feedback_boards.index.title"), feedback_boards_path, class: "hover:text-indigo-600 transition-colors" %>
          <span>/</span>
          <span class="text-slate-600 font-medium truncate max-w-[240px]"><%= @board.title %></span>
        </div>
        <h1 class="text-[22px] font-extrabold text-slate-900"><%= t("feedback_boards.edit_heading", title: @board.title) %></h1>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to feedback_board_feedbacks_path(@board),
            class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-semibold bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 shadow-sm transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-3 3-3-3z"/></svg>
        <%= t("feedback_boards.form.view_feedbacks") %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-[1fr_300px] gap-5 items-start">
    <!-- Left: form -->
    <div class="space-y-4">
      <!-- Main info card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <h2 class="text-[13px] font-bold text-slate-500 uppercase tracking-wider mb-4"><%= t("feedback_boards.form.general_info", default: "Thông tin chung") %></h2>
        <%= form_with model: @board, url: feedback_board_path(@board), method: :patch, local: true, multipart: true, data: { turbo: false } do |f| %>
          <div class="space-y-4">
            <%= render "admin/feedback_boards/logo_upload" %>

            <div>
              <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("feedback_boards.form.title") %> <span class="text-red-500">*</span></label>
              <%= f.text_field :title, required: true,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all",
                    placeholder: t("feedback_boards.form.title_placeholder", default: "Nhập tiêu đề bảng góp ý…") %>
            </div>

            <div>
              <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("feedback_boards.form.description") %></label>
              <%= f.text_area :description, rows: 3,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none transition-all",
                    placeholder: t("feedback_boards.form.description_placeholder", default: "Mô tả ngắn về bảng góp ý này…") %>
            </div>

            <div>
              <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("feedback_boards.form.identity_mode") %></label>
              <%= f.select :identity_mode,
                    FeedbackBoard.identity_modes.keys.map { |k| [t("feedback_boards.form.identity_modes.#{k}"), k] }, {},
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all bg-white" %>
            </div>

            <!-- Settings -->
            <div class="border-t border-slate-100 pt-4">
              <p class="text-[11px] font-bold text-slate-400 uppercase tracking-wider mb-3"><%= t("feedback_boards.form.settings") %></p>
              <div class="grid grid-cols-2 gap-3">
                <% [
                  [:auto_moderation,  t("feedback_boards.form.auto_moderation"),  "🤖", true],
                  [:manual_approval,  t("feedback_boards.form.manual_approval"),  "✅", true],
                  [:allow_upvotes,    t("feedback_boards.form.allow_upvotes"),    "👍", true],
                  [:allow_replies,    t("feedback_boards.form.allow_replies"),    "💬", true],
                  [:allow_voice_input, t("feedback_boards.form.allow_voice_input_short", default: "Nhập giọng nói"), "🎙", @has_stt],
                ].each do |field, label, icon, enabled| %>
                  <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 transition-all <%= enabled ? 'cursor-pointer hover:bg-slate-50 hover:border-indigo-200' : 'opacity-50 cursor-not-allowed' %>">
                    <span class="text-[16px]"><%= icon %></span>
                    <span class="flex-1 text-[12px] font-medium text-slate-700">
                      <%= label %>
                      <% unless enabled %>
                        <span class="ml-1 px-1 py-0.5 text-[9px] font-bold bg-amber-100 text-amber-700 rounded-full uppercase tracking-wide">Pro+</span>
                      <% end %>
                    </span>
                    <%= f.check_box field, { class: "w-4 h-4 accent-indigo-600 cursor-pointer", disabled: !enabled }, "1", "0" %>
                  </label>
                <% end %>
              </div>
            </div>

            <div class="flex gap-2 pt-2 border-t border-slate-100">
              <%= f.submit t("feedback_boards.form.save_btn"),
                    class: "px-5 py-2.5 bg-blue-500 hover:bg-blue-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer transition-colors shadow-sm" %>
              <%= link_to t("feedback_boards.form.cancel"), feedback_boards_path,
                    class: "px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[13px] font-semibold rounded-lg transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Right: share & QR panel -->
    <div class="space-y-4">
      <!-- Share card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-3 flex items-center gap-1.5">
          <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
          <%= t("feedback_boards.show.share") %>
        </h2>
        <p class="text-[11px] text-slate-400 mb-2"><%= t("feedback_boards.show.public_link") %></p>
        <div class="flex gap-1.5 mb-1">
          <input id="feedback-link" readonly value="<%= participate_feedback_url(@board.slug) %>"
            class="flex-1 px-2.5 py-2 bg-slate-50 border border-slate-200 rounded-lg text-[11px] font-mono text-slate-600 min-w-0 truncate">
          <button onclick="navigator.clipboard.writeText(document.getElementById('feedback-link').value);this.textContent='✓';this.classList.add('bg-emerald-600');setTimeout(()=>{this.textContent='<%= j t("feedback_boards.show.copy") %>';this.classList.remove('bg-emerald-600')},2000)"
            class="px-3 py-2 bg-blue-500 hover:bg-blue-600 text-white text-[11px] font-semibold rounded-lg transition-colors cursor-pointer flex-shrink-0"><%= t("feedback_boards.show.copy") %></button>
        </div>
      </div>

      <!-- QR Code card -->
      <% if @board.qr_code %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
          <h2 class="text-[13px] font-bold text-slate-700 mb-3 flex items-center gap-1.5">
            <svg class="w-4 h-4 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/></svg>
            QR Code
          </h2>
          <p class="text-[11px] text-slate-400 mb-3"><%= t("feedback_boards.show.qr_scan") %></p>
          <div class="flex justify-center mb-3">
            <div class="inline-block p-3 bg-white border-2 border-slate-100 rounded-xl shadow-sm">
              <img src="<%= qr_image_path(@board.qr_code.token) %>" alt="QR Code" class="w-40 h-40">
            </div>
          </div>
          <p class="text-[11px] text-slate-400 text-center mb-3">
            <span class="font-semibold text-slate-600"><%= @board.qr_code.scan_count %></span>
            <%= t("feedback_boards.show.scan_count", count: @board.qr_code.scan_count) %>
          </p>
          <a href="<%= qr_image_path(@board.qr_code.token) %>" download="qr-<%= @board.slug %>.svg"
            class="flex items-center justify-center gap-1.5 px-3 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[12px] font-semibold rounded-lg transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
            <%= t("feedback_boards.show.download_qr") %>
          </a>
        </div>
      <% end %>

      <!-- Quick link to public board -->
      <a href="<%= participate_feedback_url(@board.slug) %>" target="_blank"
        class="flex items-center justify-between gap-2 w-full px-4 py-3 bg-indigo-50 hover:bg-indigo-100 border border-indigo-200 text-indigo-700 text-[12px] font-semibold rounded-xl transition-colors">
        <span>Xem bảng công khai</span>
        <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </a>
    </div>
  </div>
</div>
