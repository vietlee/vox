<% content_for :title, t("feedback_boards.title") %>
<div class="flex items-start justify-between mb-5">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900 tracking-tight">💬 <%= t("feedback_boards.title") %></h1>
    <p class="text-[13px] text-slate-500 mt-0.5"><%= t("feedback_boards.subtitle") %></p>
  </div>
  <%= link_to new_feedback_board_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-white border border-slate-200 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-300 text-slate-700 transition-colors" do %>
    <%= t("feedback_boards.new_board") %>
  <% end %>
</div>

<!-- Search bar -->
<%= form_with url: feedback_boards_path, method: :get, local: true, id: "fb-search-form", class: "mb-5" do |f| %>
  <div class="relative w-1/2">
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
    </svg>
    <%= f.text_field :q, value: @q,
          placeholder: t("feedback_boards.search_placeholder"),
          id: "fb-search-input",
          autocomplete: "off",
          class: "w-full pl-9 pr-4 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none bg-white" %>
    <% if @q.present? %>
      <%= link_to feedback_boards_path, class: "absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 text-[16px] leading-none" do %>×<% end %>
    <% end %>
  </div>
<% end %>

<script>
  (function() {
    var input = document.getElementById('fb-search-input');
    var form  = document.getElementById('fb-search-form');
    var timer;
    if (!input) return;
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() { form.submit(); }, 300);
    });
  })();
</script>

<!-- Result count when searching -->
<% if @q.present? %>
  <p class="text-[12px] text-slate-500 mb-4">
    <%= t("feedback_boards.search_results", count: @pagy.count, q: @q) %>
  </p>
<% end %>

<div class="grid grid-cols-3 gap-4">
  <% @boards.each do |board| %>
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <div class="flex items-start justify-between mb-3">
        <h3 class="text-[14px] font-bold text-slate-900"><%= board.title %></h3>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold <%= board.active? ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
          <%= t("status.#{board.status}", default: board.status.capitalize) %>
        </span>
      </div>
      <% if board.description.present? %>
        <p class="text-[12px] text-slate-500 mb-3 line-clamp-2"><%= board.description %></p>
      <% end %>
      <div class="flex items-center gap-3 text-[12px] text-slate-500 mb-4">
        <span><%= board.feedbacks.count %> <%= t("feedback_boards.col_feedbacks") %></span>
        <span>·</span>
        <span><%= board.feedbacks.where(moderation_status: :flagged).count %> <%= t("feedback_boards.col_flagged") %></span>
      </div>
      <div class="flex gap-2">
        <%= link_to feedback_board_path(board), class: "flex-1 py-2 text-center bg-indigo-50 text-indigo-700 text-[12px] font-semibold rounded-lg hover:bg-indigo-100" do %><%= t("feedback_boards.view") %><% end %>
        <%= link_to edit_feedback_board_path(board), class: "py-2 px-3 bg-slate-100 text-slate-600 text-[12px] font-semibold rounded-lg hover:bg-slate-200" do %><%= t("feedback_boards.edit") %><% end %>
      </div>
    </div>
  <% end %>

  <% if @boards.empty? %>
    <div class="col-span-3 text-center py-16">
      <div class="text-4xl mb-3">💬</div>
      <% if @q.present? %>
        <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("feedback_boards.search_empty") %></h3>
        <p class="text-[13px] text-slate-400"><%= t("feedback_boards.search_empty_desc", q: @q) %></p>
      <% else %>
        <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("feedback_boards.empty") %></h3>
        <p class="text-[13px] text-slate-400 mb-4"><%= t("feedback_boards.empty_desc") %></p>
        <%= link_to t("feedback_boards.create_board"), new_feedback_board_path, class: "mt-3 inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-300 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" %>
      <% end %>
    </div>
  <% end %>
</div>

<!-- Pagination -->
<% if @pagy && @pagy.pages > 1 %>
  <div class="flex items-center justify-between mt-6">
    <p class="text-[12px] text-slate-500">
      <% from = (@pagy.page - 1) * @pagy.items + 1
         to   = [@pagy.page * @pagy.items, @pagy.count].min %>
      <%= t("feedback_boards.showing") %> <%= from %>–<%= to %> / <%= @pagy.count %>
    </p>
    <div class="flex gap-1">
      <% if @pagy.page > 1 %>
        <%= link_to feedback_boards_path(page: @pagy.page - 1, q: @q.presence),
              class: "px-3 py-1.5 text-[12px] border border-slate-200 rounded-lg text-slate-600 hover:bg-slate-50" do %>
          ← <%= t("audit_log.prev") %>
        <% end %>
      <% end %>

      <% window_start = [1, @pagy.page - 2].max
         window_end   = [window_start + 4, @pagy.pages].min
         window_start = [window_end - 4, 1].max %>
      <% (window_start..window_end).each do |p| %>
        <%= link_to feedback_boards_path(page: p, q: @q.presence),
              class: "px-3 py-1.5 text-[12px] border rounded-lg #{p == @pagy.page ? 'bg-indigo-600 border-indigo-600 text-white font-semibold' : 'border-slate-200 text-slate-600 hover:bg-slate-50'}" do %>
          <%= p %>
        <% end %>
      <% end %>

      <% if @pagy.page < @pagy.pages %>
        <%= link_to feedback_boards_path(page: @pagy.page + 1, q: @q.presence),
              class: "px-3 py-1.5 text-[12px] border border-slate-200 rounded-lg text-slate-600 hover:bg-slate-50" do %>
          <%= t("audit_log.next") %> →
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
