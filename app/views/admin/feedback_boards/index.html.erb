<% content_for :title, t("feedback_boards.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<!-- ── Page header (always visible) ─────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-start gap-3 justify-between mb-4">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[28px] bg-slate-100 shrink-0">💬</div>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight"><%= t("feedback_boards.title") %></h1>
        <p class="text-[13px] font-medium text-slate-600 mt-0.5"><%= t("feedback_boards.subtitle") %></p>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to new_feedback_board_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-[13px] font-bold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        <%= t("feedback_boards.new_board") %>
      <% end %>
    </div>
  </div>
</div>

<!-- ── Card area (fills remaining height) ───────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <!-- Card header: search (fixed) -->
    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <div class="relative w-72">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        <%= form_with url: feedback_boards_path, method: :get, local: true, id: "fb-search-form" do |f| %>
          <%= f.text_field :q, value: @q,
                placeholder: t("feedback_boards.search_placeholder"),
                id: "fb-search-input",
                autocomplete: "off",
                class: "w-full pl-8 pr-8 py-1.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 outline-none bg-white" %>
        <% end %>
        <% if @q.present? %>
          <%= link_to feedback_boards_path, class: "absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 text-[15px] leading-none" do %>✕<% end %>
        <% end %>
      </div>
      <span class="text-[11px] text-slate-400 ml-auto"><%= @boards.total_count rescue @boards.count %> <%= t("feedback_boards.subtitle") %></span>
    </div>

    <!-- Table (scrollable) -->
    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @boards.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("feedback_boards.title") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("surveys.col_status") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("feedback_boards.col_feedbacks").capitalize %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("surveys.col_created") %></th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <% @boards.each do |board| %>
              <tr class="border-b border-slate-200 hover:bg-white/70 transition-colors" id="fb-row-<%= board.id %>">
                <td class="px-4 py-3">
                  <%= link_to feedback_board_path(board), class: "group block" do %>
                    <div class="text-[13px] font-semibold text-slate-900 group-hover:text-indigo-600 transition-colors"><%= board.title %></div>
                    <% if board.description.present? %>
                      <div class="text-[11px] text-slate-400 truncate max-w-xs"><%= board.description %></div>
                    <% end %>
                  <% end %>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold <%= board.active? ? 'bg-emerald-50 text-emerald-700' : board.closed? ? 'bg-amber-50 text-amber-700' : 'bg-slate-100 text-slate-500' %>">
                    <%= t("status.#{board.status}", default: board.status.capitalize) %>
                  </span>
                </td>
                <td class="px-4 py-3 text-[13px] text-slate-700">
                  <%= board.feedbacks.count %>
                  <% flagged = board.feedbacks.where(moderation_status: :flagged).count %>
                  <% if flagged > 0 %>
                    <span class="ml-1 text-[11px] text-amber-600 font-semibold">· ⚠ <%= flagged %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-[12px] text-slate-500"><%= board.created_at.strftime("%d/%m/%Y") %></td>
                <td class="px-4 py-3">
                  <div class="flex gap-1 justify-end flex-wrap">
                    <%= link_to feedback_board_path(board),
                          class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-slate-200 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-slate-500 hover:text-white text-[12px] font-semibold rounded-lg transition-colors" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                      Xem
                    <% end %>
                    <%= link_to edit_feedback_board_path(board),
                          class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-slate-200 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-slate-500 hover:text-white text-[12px] font-semibold rounded-lg transition-colors" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                      Sửa
                    <% end %>
                    <% if board.active? %>
                      <%= button_to close_feedback_board_path(board), method: :patch,
                            data: { confirm: t("feedback_boards.close_confirm", default: "Đóng bảng góp ý này?") },
                            class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-amber-50 border border-amber-100 hover:bg-[#1e3a5f] hover:border-[#1e3a5f] hover:text-white text-amber-700 text-[12px] font-semibold rounded-lg transition-colors cursor-pointer" do %>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                        Đóng
                      <% end %>
                    <% elsif board.closed? %>
                      <%= button_to reopen_feedback_board_path(board), method: :patch,
                            class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-emerald-50 border border-emerald-100 hover:bg-[#1e3a5f] hover:border-[#1e3a5f] hover:text-white text-emerald-700 text-[12px] font-semibold rounded-lg transition-colors cursor-pointer" do %>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                        Mở lại
                      <% end %>
                    <% end %>
                    <button type="button"
                            onclick="showFbDeleteConfirm('<%= feedback_board_path(board) %>', '<%= j board.title %>')"
                            class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-red-100 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-red-400 hover:text-white text-[12px] font-semibold rounded-lg transition-colors cursor-pointer">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      Xóa
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="flex flex-col items-center justify-center py-20 text-slate-400">
          <div class="text-4xl mb-3">💬</div>
          <% if @q.present? %>
            <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("feedback_boards.search_empty") %></h3>
            <p class="text-[13px] text-slate-400"><%= t("feedback_boards.search_empty_desc", q: @q) %></p>
          <% else %>
            <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("feedback_boards.empty") %></h3>
            <p class="text-[13px] text-slate-400 mb-4"><%= t("feedback_boards.empty_desc") %></p>
            <%= link_to t("feedback_boards.create_board"), new_feedback_board_path,
                  class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-semibold bg-indigo-600 text-white hover:bg-indigo-700 transition-colors" %>
          <% end %>
        </div>
      <% end %>
    </div><!-- /scrollable -->

    <!-- Pagination (fixed at bottom) -->
    <% if @pagy && @pagy.pages > 1 %>
      <div class="flex-shrink-0 flex items-center justify-between px-4 py-2.5 border-t" style="border-color:rgba(99,102,241,0.12); background:rgba(99,102,241,0.04);">
        <p class="text-[11px] text-slate-500">
          <% from = (@pagy.page - 1) * @pagy.items + 1
             to   = [@pagy.page * @pagy.items, @pagy.count].min %>
          <%= t("feedback_boards.showing") %> <%= from %>–<%= to %> / <%= @pagy.count %>
        </p>
        <div class="flex gap-1">
          <% if @pagy.page > 1 %>
            <%= link_to feedback_boards_path(page: @pagy.page - 1, q: @q.presence),
                  class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %>
              ← <%= t("surveys.prev") %>
            <% end %>
          <% end %>
          <% if @pagy.page < @pagy.pages %>
            <%= link_to feedback_boards_path(page: @pagy.page + 1, q: @q.presence),
                  class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %>
              <%= t("surveys.next") %> →
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div><!-- /card -->
</div><!-- /card area -->

<!-- Delete confirm modal -->
<div id="fb-delete-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center bg-black/40 backdrop-blur-sm"
       onclick="closeFbDeleteConfirm()">
    <div class="bg-white rounded-2xl shadow-2xl w-[400px] max-w-full mx-4 p-6" onclick="event.stopPropagation()">
      <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl" style="background:#fee2e2;">🗑️</div>
      <h3 class="text-[17px] font-bold text-slate-900 text-center mb-2"><%= t("feedback_boards.delete_title", default: "Xoá bảng góp ý?") %></h3>
      <p id="fb-delete-body" class="text-[13px] text-slate-500 text-center leading-relaxed mb-6"></p>
      <div class="flex gap-3">
        <button onclick="closeFbDeleteConfirm()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 border-0 cursor-pointer">
          <%= t("feedback_boards.form.cancel") %>
        </button>
        <form id="fb-delete-form" method="post" class="flex-1">
          <input type="hidden" name="_method" value="delete">
          <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
          <button type="submit"
            class="w-full py-2.5 rounded-xl text-[13px] font-semibold text-white border-0 cursor-pointer"
            style="background:#ef4444;">
            <%= t("surveys.delete") %>
          </button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  // Auto-submit search on type
  var input = document.getElementById('fb-search-input');
  var form  = document.getElementById('fb-search-form');
  var timer;
  if (input && form) {
    input.addEventListener('input', function() {
      clearTimeout(timer);
      timer = setTimeout(function() { form.submit(); }, 300);
    });
  }

  // Delete modal
  window.showFbDeleteConfirm = function(url, title) {
    document.getElementById('fb-delete-form').action = url;
    document.getElementById('fb-delete-body').textContent =
      'Bảng "' + title + '" sẽ bị xoá vĩnh viễn cùng toàn bộ góp ý bên trong. Hành động không thể hoàn tác.';
    document.getElementById('fb-delete-modal').classList.remove('hidden');
  };

  window.closeFbDeleteConfirm = function() {
    document.getElementById('fb-delete-modal').classList.add('hidden');
  };
})();
</script>
