<% content_for :title, @board.title %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>
<% content_for :breadcrumb do %>
  <%= link_to t("feedback_boards.show.breadcrumb"), feedback_boards_path, class: "hover:text-slate-600" %> <span class="text-slate-300 mx-1">/</span>
  <span class="text-slate-700 font-medium"><%= @board.title %></span>
<% end %>

<!-- ── Page header (fixed) ──────────────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-3 bg-slate-100">
  <div class="flex items-start justify-between gap-3 flex-wrap">
    <%= render "admin/shared/back_btn" %>
    <div class="min-w-0 flex-1">
      <h1 class="text-[21px] font-extrabold text-slate-900"><%= @board.title %></h1>
      <div class="flex items-center gap-2 mt-1">
        <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold <%= @board.active? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
          <%= t("status.#{@board.status}") %>
        </span>
        <span class="text-[12px] text-slate-400"><%= t("feedback_boards.show.feedbacks_count", count: @board.feedbacks.count) %></span>
      </div>
    </div>
    <div class="flex gap-2 flex-wrap flex-shrink-0">
      <%= link_to participate_feedback_path(@board.slug), class: "inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:border-[#1e3a5f] hover:text-white text-slate-700 text-[13px] font-semibold rounded-lg transition-colors whitespace-nowrap", target: "_blank" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        <%= t("feedback_boards.show.view_public") %>
      <% end %>
      <%= link_to feedback_board_feedbacks_path(@board), class: "inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:text-white hover:border-[#1e3a5f] text-slate-700 text-[13px] font-semibold rounded-lg transition-colors whitespace-nowrap" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        <%= t("feedback_boards.show.manage") %>
      <% end %>
      <%= link_to feedback_board_feedbacks_path(@board) + "#ai", class: "inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:text-white hover:border-[#1e3a5f] text-slate-700 text-[13px] font-semibold rounded-lg transition-colors whitespace-nowrap" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        <%= t("feedback_boards.feedbacks_page.tab_ai_summary") %>
      <% end %>
      <%= link_to edit_feedback_board_path(@board), class: "inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:border-[#1e3a5f] hover:text-white text-slate-700 text-[13px] font-semibold rounded-lg transition-colors whitespace-nowrap" do %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        <%= t("feedback_boards.edit") %>
      <% end %>
      <% if @board.active? %>
        <%= button_to close_feedback_board_path(@board), method: :patch, class: "inline-flex items-center gap-1.5 px-3 py-2 bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:text-white hover:border-[#1e3a5f] text-slate-700 text-[13px] font-semibold rounded-lg transition-colors whitespace-nowrap" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
          <%= t("feedback_boards.show.close_board") %>
        <% end %>
      <% elsif @board.closed? %>
        <%= button_to reopen_feedback_board_path(@board), method: :patch, class: "inline-flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-semibold rounded-lg transition-colors whitespace-nowrap border-0" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          <%= t("feedback_boards.reopen", default: "Mở lại") %>
        <% end %>
      <% end %>
    </div>
  </div>
</div><!-- /page header -->

<!-- ── Content area (fixed, no outer scroll) ─────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="grid grid-cols-3 gap-4 h-full" style="grid-template-rows:1fr;">

    <!-- Góp ý gần đây — fills height, list scrolls inside -->
    <div class="col-span-2 bg-white rounded-xl border border-slate-200 flex flex-col min-h-0">
      <!-- Card header -->
      <div class="flex-shrink-0 flex items-center justify-between px-5 py-3.5 border-b border-slate-100">
        <h2 class="text-[13px] font-bold text-slate-700"><%= t("feedback_boards.show.recent") %></h2>
        <%= link_to feedback_board_feedbacks_path(@board), class: "text-[12px] text-indigo-500 hover:text-indigo-700 font-medium" do %>
          <%= t("feedback_boards.show.view_all") %> →
        <% end %>
      </div>
      <!-- Scrollable list -->
      <div class="flex-1 min-h-0 overflow-y-auto">
        <% recent = @board.feedbacks.order(created_at: :desc).limit(50) %>
        <% if recent.any? %>
          <% recent.each do |fb| %>
            <div class="group flex items-start justify-between gap-3 px-5 py-3 border-b border-slate-50 last:border-0 hover:bg-[#1e3a5f] hover:text-white transition-colors">
              <div class="min-w-0">
                <p class="text-[13px] text-slate-700 group-hover:text-white leading-snug"><%= fb.content.truncate(140) %></p>
                <div class="flex items-center gap-2 mt-1 text-[11px] text-slate-400 group-hover:text-white">
                  <span>👍 <%= fb.upvotes_count %></span>
                  <span class="text-slate-300 group-hover:text-white">·</span>
                  <span><%= I18n.l(fb.created_at.in_time_zone, format: :short) %></span>
                </div>
              </div>
              <span class="flex-shrink-0 px-1.5 py-0.5 rounded text-[10px] font-semibold mt-0.5 group-hover:bg-transparent group-hover:text-white
                <%= fb.safe? ? 'bg-emerald-50 text-emerald-700' : fb.flagged? ? 'bg-amber-50 text-amber-700' : 'bg-slate-100 text-slate-500' %>">
                <%= t("feedbacks.#{fb.moderation_status}") %>
              </span>
            </div>
          <% end %>
        <% else %>
          <div class="flex flex-col items-center justify-center h-full py-16 text-slate-400">
            <div class="text-3xl mb-2">💬</div>
            <p class="text-[13px]"><%= t("feedback_boards.show.no_feedbacks") %></p>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Right column: Cài đặt + Chia sẻ -->
    <div class="flex flex-col gap-4 min-h-0">

      <!-- Cài đặt (fixed height) -->
      <div class="flex-shrink-0 bg-white rounded-xl border border-slate-200 p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("feedback_boards.show.settings") %></h2>
        <dl class="space-y-2.5 text-[12px]">
          <div class="flex justify-between items-center">
            <dt class="text-slate-400"><%= t("feedback_boards.show.identity") %></dt>
            <dd class="text-slate-700 font-medium"><%= t("feedback_boards.form.identity_modes.#{@board.identity_mode}") %></dd>
          </div>
          <div class="flex justify-between items-center">
            <dt class="text-slate-400"><%= t("feedback_boards.show.auto_moderation") %></dt>
            <dd class="font-semibold <%= @board.auto_moderation? ? 'text-emerald-600' : 'text-slate-400' %>">
              <%= @board.auto_moderation? ? t("feedback_boards.show.on") : t("feedback_boards.show.off") %>
            </dd>
          </div>
          <div class="flex justify-between items-center">
            <dt class="text-slate-400"><%= t("feedback_boards.show.manual_approval") %></dt>
            <dd class="font-semibold <%= @board.manual_approval? ? 'text-emerald-600' : 'text-slate-400' %>">
              <%= @board.manual_approval? ? t("feedback_boards.show.on") : t("feedback_boards.show.off") %>
            </dd>
          </div>
          <div class="flex justify-between items-center">
            <dt class="text-slate-400"><%= t("feedback_boards.show.upvotes") %></dt>
            <dd class="font-semibold <%= @board.allow_upvotes? ? 'text-emerald-600' : 'text-slate-400' %>">
              <%= @board.allow_upvotes? ? t("feedback_boards.show.on") : t("feedback_boards.show.off") %>
            </dd>
          </div>
          <div class="flex justify-between items-center">
            <dt class="text-slate-400">🎙 <%= t("feedback_boards.form.allow_voice_input_short", default: "Nhập giọng nói") %></dt>
            <dd class="font-semibold <%= @board.allow_voice_input? ? 'text-emerald-600' : 'text-slate-400' %>">
              <%= @board.allow_voice_input? ? t("feedback_boards.show.on") : t("feedback_boards.show.off") %>
            </dd>
          </div>
        </dl>
      </div>

      <!-- Chia sẻ (fills remaining, internal scroll) -->
      <div class="flex-1 min-h-0 bg-white rounded-xl border border-slate-200 flex flex-col overflow-hidden">
        <div class="flex-shrink-0 px-5 pt-4 pb-3 border-b border-slate-100">
          <h2 class="text-[13px] font-bold text-slate-700"><%= t("feedback_boards.show.share") %></h2>
        </div>
        <div class="flex-1 min-h-0 overflow-y-auto px-5 py-4">
          <% _fb_full  = participate_feedback_url(@board.slug) %>
          <% _fb_short = short_url_for(_fb_full, workspace: current_workspace) rescue _fb_full %>
          <p class="text-[11px] text-slate-400 mb-2"><%= t("feedback_boards.show.public_link") %></p>
          <div class="flex gap-1 mb-1">
            <input id="feedback-link" readonly value="<%= _fb_short %>"
              class="flex-1 px-2.5 py-1.5 bg-slate-50 border border-slate-200 rounded text-[11px] font-mono text-slate-600 min-w-0">
            <button onclick="voxCopy(document.getElementById('feedback-link').value, this)" class="vox-copy-btn">
              <svg width="15" height="15" viewBox="0 0 20 20" fill="none"><rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              <span>Sao chép</span>
            </button>
          </div>
          <% if _fb_short != _fb_full %>
            <p class="text-[11px] text-slate-400 mb-4">Full: <span class="font-mono"><%= _fb_full %></span></p>
          <% else %>
            <div class="mb-4"></div>
          <% end %>

          <% if @board.qr_code %>
            <div class="text-center">
              <p class="text-[11px] text-slate-400 mb-2"><%= t("feedback_boards.show.qr_scan") %></p>
              <div class="inline-block p-3 bg-white border border-slate-200 rounded-xl shadow-sm">
                <img id="feedback-qr-img" src="<%= qr_image_path(@board.qr_code.token) %>" alt="QR Code" class="w-36 h-36" crossorigin="anonymous">
              </div>
              <p class="text-[10px] text-slate-400 mt-2"><%= t("feedback_boards.show.scan_count", count: @board.qr_code.scan_count) %></p>
              <div class="flex items-center justify-center gap-2 mt-2">
                <button onclick="copyQrImage(document.getElementById('feedback-qr-img'), this)"
                  class="vox-copy-btn">
                  <svg width="14" height="14" viewBox="0 0 20 20" fill="none"><rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/><path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
                  <span>Copy QR</span>
                </button>
                <a href="<%= qr_image_path(@board.qr_code.token) %>" download="qr-<%= @board.slug %>.png"
                  class="inline-flex items-center gap-1 px-3 py-1.5 bg-slate-100 text-slate-600 text-[11px] font-semibold rounded-lg hover:bg-slate-200">
                  <%= t("feedback_boards.show.download_qr") %>
                </a>
              </div>
            </div>
          <% end %>
        </div>
      </div>

    </div><!-- /right column -->

  </div><!-- /grid -->
</div><!-- /content area -->
