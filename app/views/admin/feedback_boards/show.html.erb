<% content_for :title, @board.title %>
<% content_for :breadcrumb do %>
  <%= link_to t("feedback_boards.show.breadcrumb"), feedback_boards_path, class: "hover:text-slate-600" %> <span class="text-slate-300 mx-1">/</span>
  <span class="text-slate-700 font-medium"><%= @board.title %></span>
<% end %>

<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900"><%= @board.title %></h1>
    <div class="flex items-center gap-2 mt-1">
      <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold <%= @board.active? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
        <%= t("status.#{@board.status}") %>
      </span>
      <span class="text-[12px] text-slate-400"><%= t("feedback_boards.show.feedbacks_count", count: @board.feedbacks.count) %></span>
    </div>
  </div>
  <div class="flex gap-2 flex-wrap">
    <%= link_to participate_feedback_path(@board.slug), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-slate-50 hover:border-slate-300 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors", target: "_blank" do %><%= t("feedback_boards.show.view_public") %><% end %>
    <%= link_to feedback_board_feedbacks_path(@board) + "#ai", class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-violet-50 hover:text-violet-700 hover:border-violet-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %><%= t("feedback_boards.feedbacks_page.tab_ai_summary") %><% end %>
    <%= link_to feedback_board_feedbacks_path(@board), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-indigo-50 hover:text-indigo-700 hover:border-indigo-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %><%= t("feedback_boards.show.manage") %><% end %>
    <%= link_to edit_feedback_board_path(@board), class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-slate-50 hover:border-slate-300 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %><%= t("feedback_boards.edit") %><% end %>
    <% if @board.active? %>
      <%= button_to close_feedback_board_path(@board), method: :patch, class: "inline-flex items-center gap-1.5 px-4 py-2 bg-white border border-slate-200 hover:bg-red-50 hover:text-red-700 hover:border-red-200 text-slate-700 text-[13px] font-semibold rounded-lg transition-colors" do %><%= t("feedback_boards.show.close_board") %><% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-3 gap-4">
  <div class="col-span-2 space-y-4">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("feedback_boards.show.recent") %></h2>
      <% recent = @board.feedbacks.order(created_at: :desc).limit(8) %>
      <% if recent.any? %>
        <div class="space-y-2">
          <% recent.each do |fb| %>
            <div class="py-2.5 border-b border-slate-50 last:border-0">
              <div class="flex items-start justify-between gap-3">
                <p class="text-[13px] text-slate-700 leading-snug"><%= fb.content.truncate(120) %></p>
                <span class="flex-shrink-0 px-1.5 py-0.5 rounded text-[10px] font-semibold <%= fb.safe? ? 'bg-emerald-50 text-emerald-700' : fb.flagged? ? 'bg-amber-50 text-amber-700' : 'bg-slate-100 text-slate-500' %>">
                  <%= t("feedbacks.#{fb.moderation_status}") %>
                </span>
              </div>
              <div class="flex items-center gap-2 mt-1 text-[11px] text-slate-400">
                <span>👍 <%= fb.upvotes_count %></span>
                <span><%= I18n.l(fb.created_at, format: :short) %></span>
              </div>
            </div>
          <% end %>
        </div>
        <%= link_to feedback_board_feedbacks_path(@board), class: "inline-block mt-3 text-[12px] text-indigo-500 hover:underline" do %><%= t("feedback_boards.show.view_all") %><% end %>
      <% else %>
        <p class="text-[13px] text-slate-400"><%= t("feedback_boards.show.no_feedbacks") %></p>
      <% end %>
    </div>
  </div>

  <div class="space-y-4">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("feedback_boards.show.settings") %></h2>
      <dl class="space-y-2 text-[12px]">
        <div class="flex justify-between"><dt class="text-slate-400"><%= t("feedback_boards.show.identity") %></dt><dd class="text-slate-700"><%= t("feedback_boards.form.identity_modes.#{@board.identity_mode}") %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-400"><%= t("feedback_boards.show.auto_moderation") %></dt><dd class="text-slate-700"><%= @board.auto_moderation? ? t("feedback_boards.show.on") : t("feedback_boards.show.off") %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-400"><%= t("feedback_boards.show.manual_approval") %></dt><dd class="text-slate-700"><%= @board.manual_approval? ? t("feedback_boards.show.on") : t("feedback_boards.show.off") %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-400"><%= t("feedback_boards.show.upvotes") %></dt><dd class="text-slate-700"><%= @board.allow_upvotes? ? t("feedback_boards.show.on") : t("feedback_boards.show.off") %></dd></div>
      </dl>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-2"><%= t("feedback_boards.show.share") %></h2>
      <p class="text-[11px] text-slate-400 mb-2"><%= t("feedback_boards.show.public_link") %></p>
      <div class="flex gap-1 mb-4">
        <input id="feedback-link" readonly value="<%= participate_feedback_url(@board.slug) %>"
          class="flex-1 px-2.5 py-1.5 bg-slate-50 border border-slate-200 rounded text-[11px] font-mono text-slate-600 min-w-0">
        <button onclick="navigator.clipboard.writeText(document.getElementById('feedback-link').value);this.textContent='✓';setTimeout(()=>this.textContent='<%= j t("feedback_boards.show.copy") %>',2000)"
          class="px-2 py-1 bg-indigo-50 text-indigo-700 text-[11px] font-semibold rounded hover:bg-indigo-100 border-0 cursor-pointer flex-shrink-0"><%= t("feedback_boards.show.copy") %></button>
      </div>

      <% if @board.qr_code %>
        <div class="text-center">
          <p class="text-[11px] text-slate-400 mb-2"><%= t("feedback_boards.show.qr_scan") %></p>
          <div class="inline-block p-3 bg-white border border-slate-200 rounded-xl shadow-sm">
            <img src="<%= qr_image_path(@board.qr_code.token) %>" alt="QR Code" class="w-40 h-40">
          </div>
          <p class="text-[10px] text-slate-400 mt-2"><%= t("feedback_boards.show.scan_count", count: @board.qr_code.scan_count) %></p>
          <a href="<%= qr_image_path(@board.qr_code.token) %>" download="qr-<%= @board.slug %>.svg"
            class="inline-flex items-center gap-1 mt-2 px-3 py-1.5 bg-slate-100 text-slate-600 text-[11px] font-semibold rounded-lg hover:bg-slate-200">
            <%= t("feedback_boards.show.download_qr") %>
          </a>
        </div>
      <% end %>
    </div>
  </div>
</div>
