<% content_for :title, @board.title %>
<% content_for :breadcrumb do %>
  <%= link_to "Feedback", feedback_boards_path, class: "hover:text-slate-600" %> <span class="text-slate-300 mx-1">/</span>
  <span class="text-slate-700 font-medium"><%= @board.title %></span>
<% end %>

<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900"><%= @board.title %></h1>
    <div class="flex items-center gap-2 mt-1">
      <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold <%= @board.active? ? 'bg-emerald-100 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
        <%= @board.status.capitalize %>
      </span>
      <span class="text-[12px] text-slate-400"><%= @board.feedbacks.count %> feedbacks</span>
    </div>
  </div>
  <div class="flex gap-2">
    <%= link_to participate_feedback_path(@board.slug), class: "px-4 py-2 bg-white border border-slate-200 hover:bg-slate-50 text-slate-600 text-[13px] font-semibold rounded-lg", target: "_blank" do %>↗ View Public<% end %>
    <%= link_to feedback_board_feedbacks_path(@board), class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white text-[13px] font-semibold rounded-lg" do %>Manage Feedbacks<% end %>
    <%= link_to edit_feedback_board_path(@board), class: "px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[13px] font-semibold rounded-lg" do %>Edit<% end %>
    <% if @board.active? %>
      <%= button_to close_feedback_board_path(@board), method: :patch, class: "px-4 py-2 bg-red-50 hover:bg-red-100 text-red-700 text-[13px] font-semibold rounded-lg" do %>Close Board<% end %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-3 gap-4">
  <div class="col-span-2 space-y-4">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-3">Recent Feedbacks</h2>
      <% recent = @board.feedbacks.order(created_at: :desc).limit(8) %>
      <% if recent.any? %>
        <div class="space-y-2">
          <% recent.each do |fb| %>
            <div class="py-2.5 border-b border-slate-50 last:border-0">
              <div class="flex items-start justify-between gap-3">
                <p class="text-[13px] text-slate-700 leading-snug"><%= fb.content.truncate(120) %></p>
                <span class="flex-shrink-0 px-1.5 py-0.5 rounded text-[10px] font-semibold <%= fb.safe? ? 'bg-emerald-50 text-emerald-700' : fb.flagged? ? 'bg-amber-50 text-amber-700' : 'bg-slate-100 text-slate-500' %>">
                  <%= fb.moderation_status.humanize %>
                </span>
              </div>
              <div class="flex items-center gap-2 mt-1 text-[11px] text-slate-400">
                <span>👍 <%= fb.upvotes_count %></span>
                <span><%= fb.created_at.strftime("%b %d, %H:%M") %></span>
              </div>
            </div>
          <% end %>
        </div>
        <%= link_to feedback_board_feedbacks_path(@board), class: "inline-block mt-3 text-[12px] text-indigo-500 hover:underline" do %>View all feedbacks →<% end %>
      <% else %>
        <p class="text-[13px] text-slate-400">No feedbacks yet.</p>
      <% end %>
    </div>
  </div>

  <div class="space-y-4">
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-3">Settings</h2>
      <dl class="space-y-2 text-[12px]">
        <div class="flex justify-between"><dt class="text-slate-400">Identity</dt><dd class="text-slate-700"><%= @board.identity_mode.humanize %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Auto-moderation</dt><dd class="text-slate-700"><%= @board.auto_moderation? ? "On" : "Off" %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Manual approval</dt><dd class="text-slate-700"><%= @board.manual_approval? ? "On" : "Off" %></dd></div>
        <div class="flex justify-between"><dt class="text-slate-400">Upvotes</dt><dd class="text-slate-700"><%= @board.allow_upvotes? ? "On" : "Off" %></dd></div>
      </dl>
    </div>

    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <h2 class="text-[13px] font-bold text-slate-700 mb-2">Chia sẻ</h2>
      <p class="text-[11px] text-slate-400 mb-2">Link công khai</p>
      <div class="flex gap-1 mb-4">
        <input id="feedback-link" readonly value="<%= participate_feedback_url(@board.slug) %>"
          class="flex-1 px-2.5 py-1.5 bg-slate-50 border border-slate-200 rounded text-[11px] font-mono text-slate-600 min-w-0">
        <button onclick="navigator.clipboard.writeText(document.getElementById('feedback-link').value);this.textContent='✓';setTimeout(()=>this.textContent='Copy',2000)"
          class="px-2 py-1 bg-indigo-50 text-indigo-700 text-[11px] font-semibold rounded hover:bg-indigo-100 border-0 cursor-pointer flex-shrink-0">Copy</button>
      </div>

      <% if @board.qr_code %>
        <div class="text-center">
          <p class="text-[11px] text-slate-400 mb-2">QR Code — Scan để mở form góp ý</p>
          <div class="inline-block p-3 bg-white border border-slate-200 rounded-xl shadow-sm">
            <img src="<%= qr_image_path(@board.qr_code.token) %>" alt="QR Code" class="w-40 h-40">
          </div>
          <p class="text-[10px] text-slate-400 mt-2"><%= @board.qr_code.scan_count %> lượt scan</p>
          <a href="<%= qr_image_path(@board.qr_code.token) %>" download="qr-<%= @board.slug %>.svg"
            class="inline-flex items-center gap-1 mt-2 px-3 py-1.5 bg-slate-100 text-slate-600 text-[11px] font-semibold rounded-lg hover:bg-slate-200">
            ↓ Tải QR Code
          </a>
        </div>
      <% end %>
    </div>
  </div>
</div>
