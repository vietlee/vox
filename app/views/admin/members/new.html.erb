<% content_for :title, t("members.new_title") %>
<div class="max-w-[500px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5">👥 <%= t("members.new_title") %></h1>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with model: [:admin, @member], url: members_path, local: true do |f| %>
      <% if @member.errors.any? %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
          <% @member.errors.full_messages.each do |msg| %>
            <p class="text-[13px] text-red-700">⚠ <%= msg %></p>
          <% end %>
        </div>
      <% end %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("members.full_name") %> *</label>
          <%= f.text_field :name, required: true,
                oninvalid: "this.setCustomValidity('#{j t("members.field_required")}')",
                oninput:   "this.setCustomValidity('')",
                class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("members.email") %> *</label>
          <%= f.email_field :email, required: true,
                oninvalid: "this.setCustomValidity(this.value ? '#{j t("members.email_invalid")}' : '#{j t("members.field_required")}')",
                oninput:   "this.setCustomValidity('')",
                class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none #{@member.errors[:email].any? ? 'border-red-400' : ''}" %>
        </div>
        <p class="text-[12px] text-slate-500 bg-slate-50 p-3 rounded-lg"><%= t("members.temp_password_note") %></p>
        <div class="flex gap-2 pt-2">
          <%= f.submit t("members.send_invitation"), class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to t("members.cancel"), members_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
