<% content_for :title, "Invite Member" %>
<div class="max-w-[500px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5">👥 Invite Team Member</h1>
  <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-6">
    <%= form_with url: members_path, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Full Name *</label>
          <%= f.text_field :name, required: true, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Email *</label>
          <%= f.email_field :email, required: true, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <p class="text-[12px] text-slate-500 bg-slate-50 p-3 rounded-lg">A temporary password will be generated and emailed. They must change it on first login.</p>
        <div class="flex gap-2 pt-2">
          <%= f.submit "Send Invitation", class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to "Cancel", members_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
