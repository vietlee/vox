<% content_for :title, t("members.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<!-- Delete confirm modal -->
<div id="delete-member-modal" class="fixed inset-0 z-50 items-center justify-center p-4" style="display:none; background:rgba(15,23,42,0.45); backdrop-filter:blur(2px);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 flex flex-col gap-4" onclick="event.stopPropagation()">
    <div class="w-12 h-12 rounded-full flex items-center justify-center mx-auto text-2xl" style="background:#fee2e2;">🗑️</div>
    <div class="text-center">
      <h3 class="text-[17px] font-bold text-slate-900 mb-1"><%= t("members.remove_confirm_title") %></h3>
      <p class="text-[13px] text-slate-500"><span id="delete-member-name" class="font-semibold text-slate-700"></span></p>
    </div>
    <p class="text-[13px] text-slate-600 leading-relaxed text-center"><%= t("members.remove_confirm_body") %></p>
    <div class="flex gap-3 pt-1">
      <button type="button" onclick="closeDeleteModal()"
        class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 border-0 cursor-pointer">
        <%= t("common.cancel") %>
      </button>
      <form id="delete-member-form" method="post" class="flex-1">
        <input type="hidden" name="_method" value="delete">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button type="submit" class="w-full py-2.5 rounded-xl text-[13px] font-semibold text-white border-0 cursor-pointer" style="background:#ef4444;">
          <%= t("members.remove") %>
        </button>
      </form>
    </div>
  </div>
</div>

<!-- ── Page header (always visible) ─────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight">👥 <%= t("members.title") %></h1>
        <p class="text-[12px] text-slate-500 mt-0.5"><%= t("members.subtitle") %></p>
      </div>
    </div>
    <%= link_to new_member_path, class: "inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold bg-slate-600 hover:bg-slate-700 text-white transition-colors" do %>
      + <%= t("members.invite") %>
    <% end %>
  </div>
</div>

<!-- ── Card area (fills remaining height) ───────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <!-- Card header: search -->
    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <div class="relative w-72">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
        </svg>
        <input id="member-search" type="text" placeholder="<%= t("members.search_placeholder", default: "Tìm thành viên...") %>"
          oninput="filterMembers(this.value)"
          autocomplete="off"
          class="w-full pl-8 pr-8 py-1.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 outline-none bg-white">
        <button id="member-search-clear" onclick="clearMemberSearch()"
          class="absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 text-[15px] leading-none hidden border-0 bg-transparent cursor-pointer">✕</button>
      </div>
      <span class="text-[11px] text-slate-400 ml-auto"><%= @members.count %> <%= t("members.subtitle") %></span>
    </div>

    <!-- Table (scrollable) -->
    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @members.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("members.col_member") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("members.col_status") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("members.col_joined") %></th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <% @members.each do |membership| %>
              <% member = membership.user %>
              <tr class="border-b border-indigo-50 hover:bg-white/70 transition-colors member-row"
                  data-member-text="<%= j "#{member.name} #{member.email}".downcase %>">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[12px] font-bold text-white flex-shrink-0">
                      <%= member.initials %>
                    </div>
                    <div>
                      <div class="text-[13px] font-semibold text-slate-900"><%= member.name %></div>
                      <div class="text-[11px] text-slate-400"><%= member.email %></div>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <span class="inline-flex px-2 py-0.5 rounded-full text-[11px] font-semibold <%= membership.active? ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
                    <%= t("status.#{membership.status}", default: membership.status.capitalize) %>
                  </span>
                </td>
                <td class="px-4 py-3 text-[12px] text-slate-500"><%= I18n.l(membership.created_at.to_date) %></td>
                <td class="px-4 py-3">
                  <div class="flex gap-1.5 justify-end flex-wrap">
                    <%= button_to reset_password_member_path(member), method: :post,
                          data: { confirm: t("members.reset_password_confirm", email: member.email) },
                          class: "px-2.5 py-1 text-[11px] bg-amber-50 rounded-md text-amber-700 hover:bg-amber-100 font-medium border-0 cursor-pointer" do %>
                      🔑 <%= t("members.reset_password") %>
                    <% end %>
                    <%= button_to toggle_status_member_path(member), method: :patch,
                          class: "px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200 font-medium border-0 cursor-pointer" do %>
                      <%= membership.active? ? t("members.disable") : t("members.enable") %>
                    <% end %>
                    <button type="button" onclick="openDeleteModal('<%= member_path(member) %>', '<%= j member.name %>')"
                            class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-500 hover:bg-red-100 font-medium border-0 cursor-pointer">
                      <%= t("members.remove") %>
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <!-- Empty search state -->
        <div id="member-empty-search" class="hidden flex flex-col items-center justify-center py-20 text-slate-400">
          <div class="text-4xl mb-3">🔍</div>
          <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("members.search_empty", default: "Không tìm thấy thành viên") %></h3>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-20 text-slate-400">
          <div class="text-4xl mb-3">👥</div>
          <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("members.empty") %></h3>
          <%= link_to t("members.invite"), new_member_path,
                class: "mt-3 inline-flex items-center gap-1.5 px-4 py-2 rounded-lg text-[13px] font-semibold bg-indigo-600 text-white hover:bg-indigo-700 transition-colors" %>
        </div>
      <% end %>
    </div>

  </div><!-- /card -->
</div><!-- /card area -->

<script>
(function() {
  function openDeleteModal(url, name) {
    document.getElementById('delete-member-name').textContent = name;
    document.getElementById('delete-member-form').action = url;
    document.getElementById('delete-member-modal').style.display = 'flex';
  }
  function closeDeleteModal() {
    document.getElementById('delete-member-modal').style.display = 'none';
  }
  const modal = document.getElementById('delete-member-modal');
  if (modal) modal.addEventListener('click', closeDeleteModal);

  function filterMembers(value) {
    const q = value.trim().toLowerCase();
    const rows = document.querySelectorAll('.member-row');
    let visible = 0;
    rows.forEach(row => {
      const match = q === '' || (row.dataset.memberText || '').includes(q);
      row.style.display = match ? '' : 'none';
      if (match) visible++;
    });
    const emptyEl = document.getElementById('member-empty-search');
    if (emptyEl) emptyEl.classList.toggle('hidden', visible > 0);
    const clearBtn = document.getElementById('member-search-clear');
    if (clearBtn) clearBtn.classList.toggle('hidden', value === '');
  }

  function clearMemberSearch() {
    const input = document.getElementById('member-search');
    if (input) { input.value = ''; input.focus(); }
    filterMembers('');
  }

  Object.assign(window, { openDeleteModal, closeDeleteModal, filterMembers, clearMemberSearch });
})();
</script>
