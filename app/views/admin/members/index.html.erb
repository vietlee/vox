<% content_for :title, t("members.title") %>

<!-- Delete confirm modal -->
<div id="delete-member-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(15,23,42,0.45); backdrop-filter:blur(2px);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 flex flex-col gap-4" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
      </div>
      <div>
        <h3 class="text-[15px] font-bold text-slate-900"><%= t("members.remove_confirm_title") %></h3>
        <p class="text-[12px] text-slate-500 mt-0.5"><span id="delete-member-name" class="font-semibold text-slate-700"></span></p>
      </div>
    </div>
    <p class="text-[13px] text-slate-600 leading-relaxed"><%= t("members.remove_confirm_body") %></p>
    <div class="flex gap-2 pt-1">
      <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200">
        <%= t("common.cancel") %>
      </button>
      <form id="delete-member-form" method="post" class="flex-1">
        <input type="hidden" name="_method" value="delete">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
        <button type="submit" class="w-full px-4 py-2 rounded-lg text-[13px] font-semibold bg-red-600 text-white hover:bg-red-700">
          <%= t("members.remove") %>
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  function openDeleteModal(url, name) {
    document.getElementById('delete-member-name').textContent = name;
    document.getElementById('delete-member-form').action = url;
    document.getElementById('delete-member-modal').classList.remove('hidden');
  }
  function closeDeleteModal() {
    document.getElementById('delete-member-modal').classList.add('hidden');
  }
  document.getElementById('delete-member-modal').addEventListener('click', closeDeleteModal);
</script>

<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900">👥 <%= t("members.title") %></h1>
    <p class="text-[13px] text-slate-500 mt-0.5"><%= @members.count %> <%= t("members.subtitle") %></p>
  </div>
  <%= link_to new_member_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-[7px] text-[13px] font-semibold bg-indigo-600 text-white hover:bg-indigo-700" do %>
    <%= t("members.invite") %>
  <% end %>
</div>

<div class="bg-white rounded-[10px] border border-slate-200 shadow-sm overflow-hidden">
  <table class="w-full border-collapse">
    <thead>
      <tr class="bg-slate-50 border-b border-slate-200">
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("members.col_member") %></th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("members.col_status") %></th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("members.col_joined") %></th>
        <th class="px-4 py-2.5"></th>
      </tr>
    </thead>
    <tbody>
      <% @members.each do |membership| %>
        <% member = membership.user %>
        <tr class="border-b border-slate-100 hover:bg-slate-50">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[12px] font-bold text-white flex-shrink-0">
                <%= member.initials %>
              </div>
              <div>
                <div class="text-[13px] font-semibold text-slate-900"><%= member.name %></div>
                <div class="text-[11px] text-slate-400"><%= member.email %></div>
              </div>
            </div>
          </td>
          <td class="px-4 py-3">
            <span class="inline-flex px-2 py-0.5 rounded-full text-[11px] font-semibold <%= membership.active? ? 'bg-emerald-50 text-emerald-700' : 'bg-slate-100 text-slate-500' %>">
              <%= t("status.#{membership.status}", default: membership.status.capitalize) %>
            </span>
          </td>
          <td class="px-4 py-3 text-[12px] text-slate-500"><%= I18n.l(membership.created_at.to_date) %></td>
          <td class="px-4 py-3">
            <div class="flex gap-1.5 justify-end">
              <%= button_to reset_password_member_path(member), method: :post,
                    data: { confirm: t("members.reset_password_confirm", email: member.email) },
                    class: "px-2.5 py-1 text-[11px] bg-amber-50 rounded-md text-amber-700 hover:bg-amber-100" do %>
                🔑 <%= t("members.reset_password") %>
              <% end %>
              <%= button_to toggle_status_member_path(member), method: :patch, class: "px-2.5 py-1 text-[11px] bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200" do %>
                <%= membership.active? ? t("members.disable") : t("members.enable") %>
              <% end %>
              <button type="button" onclick="openDeleteModal('<%= member_path(member) %>', '<%= j member.name %>')"
                      class="px-2.5 py-1 text-[11px] bg-red-50 rounded-md text-red-600 hover:bg-red-100">
                <%= t("members.remove") %>
              </button>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @members.empty? %>
        <tr>
          <td colspan="4" class="px-4 py-12 text-center text-slate-400 text-[13px]">
            <%= t("members.empty") %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
