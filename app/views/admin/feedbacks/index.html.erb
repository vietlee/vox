<% content_for :title, @board.title %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>
<style>
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.75); }
  }
  @keyframes slideUp {
    from { transform: translateY(100%); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  #bulk-bar { animation: slideUp 0.2s ease; }
</style>

<!-- Bulk action confirm modal -->
<div id="bulk-confirm-modal" class="fixed inset-0 z-50 items-center justify-center p-4" style="display:none; background:rgba(15,23,42,0.45); backdrop-filter:blur(2px);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 flex flex-col gap-4" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3">
      <div id="bulk-modal-icon-wrap" class="w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0">
      </div>
      <div>
        <h3 id="bulk-modal-title" class="text-[15px] font-bold text-slate-900"></h3>
        <p id="bulk-modal-body" class="text-[12px] text-slate-500 mt-0.5"></p>
      </div>
    </div>
    <div class="flex gap-2 pt-1">
      <button type="button" onclick="closeBulkConfirmModal()" class="flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200">
        <%= t("common.cancel") %>
      </button>
      <button id="bulk-modal-confirm-btn" type="button" class="flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold text-white">
      </button>
    </div>
  </div>
</div>
<script>
  let _bulkConfirmCallback = null;

  const BULK_MODAL_CONFIG = {
    approve: {
      icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
      iconBg: 'bg-emerald-50',
      btnClass: 'bg-emerald-600 hover:bg-emerald-700',
    },
    hide: {
      icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/><path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`,
      iconBg: 'bg-slate-100',
      btnClass: 'bg-slate-600 hover:bg-slate-700',
    },
    reject: {
      icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`,
      iconBg: 'bg-amber-50',
      btnClass: 'bg-amber-500 hover:bg-amber-600',
    },
    delete: {
      icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>`,
      iconBg: 'bg-red-50',
      btnClass: 'bg-red-600 hover:bg-red-700',
    }
  };

  function openBulkConfirmModal(action, title, body, btnLabel, onConfirm) {
    const cfg = BULK_MODAL_CONFIG[action] || BULK_MODAL_CONFIG.delete;
    document.getElementById('bulk-modal-icon-wrap').className = `w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0 ${cfg.iconBg}`;
    document.getElementById('bulk-modal-icon-wrap').innerHTML = cfg.icon;
    document.getElementById('bulk-modal-title').textContent   = title;
    document.getElementById('bulk-modal-body').textContent    = body;
    const btn = document.getElementById('bulk-modal-confirm-btn');
    btn.className = `flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold text-white ${cfg.btnClass}`;
    btn.textContent = btnLabel;
    _bulkConfirmCallback = onConfirm;
    btn.onclick = () => { const cb = _bulkConfirmCallback; closeBulkConfirmModal(); cb?.(); };
    document.getElementById('bulk-confirm-modal').style.display = 'flex';
  }

  function closeBulkConfirmModal() {
    document.getElementById('bulk-confirm-modal').style.display = 'none';
    _bulkConfirmCallback = null;
  }

  document.getElementById('bulk-confirm-modal').addEventListener('click', closeBulkConfirmModal);
</script>

<!-- Delete feedback confirm modal -->
<div id="delete-feedback-modal" class="fixed inset-0 z-50 items-center justify-center p-4" style="display:none; background:rgba(15,23,42,0.45); backdrop-filter:blur(2px);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 flex flex-col gap-4" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
      </div>
      <div>
        <h3 class="text-[15px] font-bold text-slate-900"><%= t("feedback_boards.feedbacks_page.delete_confirm_title", default: "Xoá góp ý") %></h3>
        <p class="text-[12px] text-slate-500 mt-0.5"><%= t("feedback_boards.feedbacks_page.delete_confirm_body", default: "Hành động này không thể hoàn tác.") %></p>
      </div>
    </div>
    <div class="flex gap-2 pt-1">
      <button type="button" onclick="closeDeleteFeedbackModal()" class="flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200">
        <%= t("common.cancel") %>
      </button>
      <button id="delete-feedback-confirm-btn" type="button" class="flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold bg-red-600 text-white hover:bg-red-700">
        <%= t("feedback_boards.feedbacks_page.delete") %>
      </button>
    </div>
  </div>
</div>
<script>
  function openDeleteFeedbackModal(id, url) {
    const btn = document.getElementById('delete-feedback-confirm-btn');
    btn.onclick = async () => {
      closeDeleteFeedbackModal();
      const CSRF = document.querySelector('meta[name=csrf-token]').content;
      const res = await fetch(url, { method: 'DELETE', headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json' } });
      if (!res.ok) return;
      const card = document.getElementById(`feedback-${id}`);
      if (card) {
        const wasApproved = card.dataset.status === 'approved';
        card.style.opacity = '0'; card.style.transform = 'translateX(10px)';
        setTimeout(() => { card.remove(); window.recordDeleted?.(wasApproved); }, 200);
      }
    };
    document.getElementById('delete-feedback-modal').style.display = 'flex';
  }
  function closeDeleteFeedbackModal() {
    document.getElementById('delete-feedback-modal').style.display = 'none';
  }
  document.getElementById('delete-feedback-modal').addEventListener('click', closeDeleteFeedbackModal);
</script>
<!-- Delete reply confirm modal -->
<div id="delete-reply-modal" class="fixed inset-0 z-50 items-center justify-center p-4" style="display:none; background:rgba(15,23,42,0.45); backdrop-filter:blur(2px);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm p-6 flex flex-col gap-4" onclick="event.stopPropagation()">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-red-50 flex items-center justify-center flex-shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-red-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </div>
      <div>
        <h3 class="text-[15px] font-bold text-slate-900"><%= t("feedback_boards.feedbacks_page.delete_reply", default: "Xoá phản hồi") %></h3>
        <p class="text-[12px] text-slate-500 mt-0.5"><%= t("feedback_boards.feedbacks_page.delete_confirm_body", default: "Hành động này không thể hoàn tác.") %></p>
      </div>
    </div>
    <div class="flex gap-2 pt-1">
      <button type="button" onclick="closeDeleteReplyModal()" class="flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200">
        <%= t("common.cancel") %>
      </button>
      <button id="delete-reply-confirm-btn" type="button" class="flex-1 px-4 py-2 rounded-lg text-[13px] font-semibold bg-red-600 text-white hover:bg-red-700">
        <%= t("feedback_boards.feedbacks_page.delete") %>
      </button>
    </div>
  </div>
</div>
<script>
  function openDeleteReplyModal(id, url) {
    const btn = document.getElementById('delete-reply-confirm-btn');
    btn.onclick = () => { closeDeleteReplyModal(); deleteAdminReply(id, url); };
    document.getElementById('delete-reply-modal').style.display = 'flex';
  }
  function closeDeleteReplyModal() {
    document.getElementById('delete-reply-modal').style.display = 'none';
  }
  document.getElementById('delete-reply-modal').addEventListener('click', closeDeleteReplyModal);
</script>
<!-- ── Page header: always visible (board title + tabs) ─────────────── -->
<div class="flex-shrink-0 px-6 pt-5 bg-slate-100">
  <div class="flex items-start justify-between mb-4">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900"><%= @board.title %></h1>
        <p id="board-subtitle" class="text-[12px] text-slate-500 mt-0.5"><%= t("feedback_boards.feedbacks_page.total", total: @board.feedbacks.count, pending: @board.feedbacks.where(status: :pending).count) %></p>
      </div>
    </div>
    <div class="flex gap-2">
      <%= link_to participate_feedback_path(@board.slug), class: "px-3 py-2 bg-white border border-slate-200 text-slate-600 text-[12px] font-semibold rounded-lg hover:bg-slate-50", target: "_blank" do %><%= t("feedback_boards.feedbacks_page.view_public") %><% end %>
    </div>
  </div>

  <!-- Tabs -->
  <div class="flex items-center gap-0 border-b border-slate-200">
  <button id="tab-btn-feedbacks"
    onclick="switchTab('feedbacks')"
    class="px-4 py-2.5 text-[13px] font-semibold border-b-2 -mb-px transition-colors border-slate-600 text-indigo-600">
    <%= t("feedback_boards.feedbacks_page.tab_feedbacks") %>
  </button>
  <button id="tab-btn-ai"
    onclick="switchTab('ai')"
    class="px-4 py-2.5 text-[13px] font-semibold border-b-2 -mb-px transition-colors border-transparent text-slate-400 hover:text-slate-600 flex items-center gap-1.5">
    <%= t("feedback_boards.feedbacks_page.tab_ai_summary") %>
    <% if @ai_summary %>
      <span id="ai-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block"></span>
    <% else %>
      <span id="ai-tab-dot" class="w-1.5 h-1.5 rounded-full bg-violet-500 inline-block hidden"></span>
    <% end %>
  </button>
  </div><!-- /tab bar -->
</div><!-- /page-header -->

<!-- Tab: Feedbacks (card UI) -->
<div id="tab-panel-feedbacks" class="flex-1 min-h-0 overflow-hidden px-6 pt-5 pb-5">

  <!-- Card wrapper -->
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <!-- ── Card header ────────────────────────────────────────────────── -->
    <div class="flex-shrink-0 flex items-center gap-2 px-4 py-3" style="background:rgba(99,102,241,0.08); border-bottom:1px solid rgba(99,102,241,0.15);">
      <span class="text-[14px]">💬</span>
      <span class="text-[13px] font-bold text-indigo-700"><%= t("feedback_boards.feedbacks_page.tab_feedbacks") %></span>
      <span id="feedbacks-card-count" class="px-2 py-0.5 rounded-full text-[10px] font-bold bg-indigo-100 text-indigo-600"><%= @board.feedbacks.approved.count %></span>
    </div>

    <!-- ── Pending / Flagged warning banners ──────────────────────────── -->
    <div id="banners-wrap" class="<%= (@pending_count > 0 || @flagged_count > 0) ? 'flex-shrink-0 flex gap-2 flex-wrap px-4 py-2.5 border-b border-indigo-50' : 'hidden' %>">
      <div id="pending-banner" class="<%= @pending_count > 0 ? '' : 'hidden' %> flex-1 min-w-0 flex items-center gap-2 px-3 py-2 rounded-[8px] border border-amber-200 bg-amber-50">
        <span class="text-[13px] flex-shrink-0">⏳</span>
        <p class="flex-1 min-w-0 text-[11px] font-semibold text-amber-800 truncate">
          <span id="pending-count-text"></span>
        </p>
        <%= link_to t("feedback_boards.feedbacks_page.review_now"),
              feedback_board_feedbacks_path(@board, status: "pending"),
              class: "text-[10px] font-bold text-amber-700 hover:text-amber-900 underline underline-offset-2 flex-shrink-0" %>
      </div>
      <div id="flagged-banner" class="<%= @flagged_count > 0 ? '' : 'hidden' %> flex-1 min-w-0 flex items-center gap-2 px-3 py-2 rounded-[8px] border border-red-200 bg-red-50">
        <span class="text-[13px] flex-shrink-0">🚩</span>
        <p class="flex-1 min-w-0 text-[11px] font-semibold text-red-800 truncate">
          <span id="flagged-count-text"></span>
        </p>
        <%= link_to t("feedback_boards.feedbacks_page.review_now"),
              feedback_board_feedbacks_path(@board, moderation: "flagged"),
              class: "text-[10px] font-bold text-red-700 hover:text-red-900 underline underline-offset-2 flex-shrink-0" %>
      </div>
    </div>

    <!-- ── Search ─────────────────────────────────────────────────────── -->
    <div class="flex-shrink-0 px-4 py-2.5 border-b border-indigo-50">
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-[12px] pointer-events-none">🔍</span>
        <input id="feedback-search" type="text" value="<%= params[:q] %>"
          placeholder="<%= t('feedback_boards.feedbacks_page.search_placeholder') %>"
          class="w-full pl-8 pr-8 py-1.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 outline-none bg-white"
          autocomplete="off">
        <button id="search-clear-btn" onclick="clearSearch()"
          class="absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 text-[13px] leading-none <%= params[:q].present? ? '' : 'hidden' %>">✕</button>
      </div>
    </div>

    <!-- ── Status filter pills ────────────────────────────────────────── -->
    <div class="flex-shrink-0 flex gap-1 px-4 py-2 border-b border-indigo-50 flex-wrap">
      <% ["", "pending", "approved", "hidden", "rejected"].each do |s| %>
        <% active = params[:status].to_s == s && params[:moderation].blank? %>
        <%= link_to feedback_board_feedbacks_path(@board, status: s.presence, q: params[:q]),
              class: "px-2.5 py-1 rounded-full text-[11px] font-semibold transition-colors #{active ? 'bg-blue-500 text-white' : 'bg-white text-slate-500 hover:bg-indigo-50 hover:text-indigo-600 border border-slate-200'}" do %>
          <%= s.blank? ? t("feedback_boards.feedbacks_page.all") : t("status.#{s}") %>
        <% end %>
      <% end %>
      <% flagged_active = params[:moderation] == "flagged" %>
      <%= link_to feedback_board_feedbacks_path(@board, moderation: "flagged", q: params[:q]),
            class: "px-2.5 py-1 rounded-full text-[11px] font-semibold transition-colors #{flagged_active ? 'bg-red-500 text-white' : 'bg-red-50 text-red-600 hover:bg-red-100 border border-red-100'}" do %>
        <%= t("feedback_boards.feedbacks_page.flagged_filter") %>
        <span id="flagged-tab-badge" class="ml-1 px-1.5 py-0.5 rounded-full text-[10px] font-bold <%= flagged_active ? 'bg-white text-red-500' : 'bg-red-500 text-white' %> <%= @flagged_count > 0 ? '' : 'hidden' %>"><%= @flagged_count %></span>
      <% end %>
    </div>

    <!-- ── Feedback list (scrollable) ─────────────────────────────────── -->
    <!-- Select-all header row -->
    <div class="flex-shrink-0 flex items-center gap-2 px-4 py-1.5 border-b border-indigo-50 bg-slate-50/60">
      <input type="checkbox" id="bulk-select-all" onchange="toggleSelectAll(this.checked)"
             class="w-3.5 h-3.5 accent-indigo-600 cursor-pointer flex-shrink-0">
      <label for="bulk-select-all" class="text-[11px] text-slate-400 cursor-pointer select-none">
        <%= t("feedback_boards.feedbacks_page.bulk_select_all", default: "Chọn tất cả") %>
      </label>
    </div>

    <div id="feedbacks-list" class="flex-1 min-h-0 overflow-y-auto divide-y divide-indigo-50/70">
      <% @feedbacks.each do |fb| %>
        <% mod = fb.moderation_status.to_s
           border_style = case mod
             when "moderation_pending" then "border-left: 3px solid #f59e0b;"
             when "flagged"            then "border-left: 3px solid #ef4444;"
             when "auto_rejected"      then "border-left: 3px solid #dc2626;"
             else ""
           end %>
        <div class="px-4 py-3 bg-white/60 hover:bg-white/90 transition-colors feedback-row" id="feedback-<%= fb.id %>" data-status="<%= fb.status %>" data-moderation="<%= fb.moderation_status %>" style="<%= border_style %>">
          <div class="flex gap-3">
            <!-- Bulk select checkbox -->
            <div class="flex-shrink-0 pt-1">
              <input type="checkbox" class="bulk-checkbox w-3.5 h-3.5 accent-indigo-600 cursor-pointer"
                     value="<%= fb.id %>" onchange="updateBulkBar()">
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                <% if fb.pinned? %>
                  <span class="pin-badge-<%= fb.id %> text-[10px] font-bold text-amber-600">📌 <%= t("feedback_boards.feedbacks_page.pinned") %></span>
                <% else %>
                  <span class="pin-badge-<%= fb.id %> hidden text-[10px] font-bold text-amber-600">📌 <%= t("feedback_boards.feedbacks_page.pinned") %></span>
                <% end %>
                <% badge_cls = case mod
                     when "safe"               then "bg-emerald-50 text-emerald-700"
                     when "flagged"            then "bg-red-50 text-red-600"
                     when "auto_rejected"      then "bg-red-100 text-red-700"
                     when "moderation_pending" then "bg-amber-50 text-amber-700"
                     else "bg-slate-100 text-slate-500"
                   end %>
                <span class="status-badge-<%= fb.id %> inline-flex items-center gap-1 text-[10px] px-2 py-0.5 rounded-full font-semibold <%= badge_cls %>">
                  <% if mod == "moderation_pending" %>
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-400 flex-shrink-0" style="animation: pulse 1.5s ease-in-out infinite;"></span>
                  <% elsif mod == "flagged" || mod == "auto_rejected" %>
                    <span class="flex-shrink-0">🚩</span>
                  <% end %>
                  <%= t("feedbacks.#{fb.moderation_status}") %>
                </span>
                <span class="text-[10px] text-slate-400 ml-auto flex-shrink-0"><%= I18n.l(fb.created_at.in_time_zone, format: :short) %></span>
              </div>
              <p class="text-[13px] text-slate-800 leading-relaxed mb-1.5"><%= fb.content %></p>
              <% if fb.images.attached? %>
                <div class="flex gap-2 flex-wrap mb-1.5">
                  <% fb.images.each do |img| %>
                    <img src="<%= url_for(img) %>" alt=""
                         class="rounded-lg object-cover"
                         style="height:60px; width:60px; border:1px solid #e2e8f0;">
                  <% end %>
                </div>
              <% end %>
              <div class="text-[11px] text-slate-400">
                <%= fb.anonymous? ? t("feedback_boards.feedbacks_page.anonymous") : (fb.author_name.presence || fb.author_email) %>
                · 👍 <%= fb.upvotes_count %> <%= t("feedback_boards.feedbacks_page.upvotes") %>
              </div>

              <!-- ── Admin reply ──────────────────────────────────────────── -->
              <% fb_has_reply = fb.admin_reply.present? || fb.admin_reply_image.attached? %>
              <div class="mt-2.5 pt-2 border-t border-slate-100">
                <!-- Existing reply display -->
                <div id="reply-display-<%= fb.id %>" style="<%= fb_has_reply ? '' : 'display:none' %>" class="mb-1.5">
                  <div class="flex items-start gap-2">
                    <div class="flex-1 bg-indigo-50 border border-indigo-100 rounded-lg px-3 py-2">
                      <div class="text-[10px] font-bold text-indigo-500 mb-1">↩ Admin</div>
                      <p class="text-[12px] text-slate-700 leading-relaxed" id="reply-text-<%= fb.id %>"><%= fb.admin_reply %></p>
                      <% if fb.admin_reply_image.attached? %>
                        <img id="reply-img-display-<%= fb.id %>"
                          src="<%= url_for(fb.admin_reply_image) %>"
                          class="mt-1.5 rounded-lg object-cover"
                          style="max-height:100px; max-width:160px; border:1px solid #e0e7ff;">
                      <% else %>
                        <img id="reply-img-display-<%= fb.id %>" src="" style="display:none" class="mt-1.5 rounded-lg object-cover" style="max-height:100px; max-width:160px; border:1px solid #e0e7ff;">
                      <% end %>
                    </div>
                    <!-- Sửa + Xoá buttons in display mode -->
                    <div class="flex flex-col gap-1 flex-shrink-0 mt-1">
                      <button onclick="openReplyEditor(<%= fb.id %>)"
                        class="px-2 py-0.5 text-[10px] font-semibold bg-white border border-slate-200 rounded-md text-slate-500 hover:bg-slate-50 cursor-pointer">
                        <%= t("feedback_boards.feedbacks_page.edit_reply", default: "Sửa") %>
                      </button>
                      <button onclick="openDeleteReplyModal(<%= fb.id %>, '<%= feedback_board_feedback_path(@board, fb) %>')"
                        class="px-2 py-0.5 text-[10px] font-semibold bg-red-50 border border-red-200 rounded-md text-red-500 hover:bg-red-100 cursor-pointer">
                        <%= t("feedback_boards.feedbacks_page.delete_reply", default: "Xoá") %>
                      </button>
                    </div>
                  </div>
                </div>

                <!-- Toggle button (shown when no reply) — use inline style to avoid flex/hidden conflict -->
                <button id="reply-toggle-<%= fb.id %>"
                  onclick="openReplyEditor(<%= fb.id %>)"
                  style="<%= fb_has_reply ? 'display:none' : 'display:inline-flex' %>; align-items:center; gap:4px;"
                  class="text-[11px] text-indigo-500 hover:text-indigo-700 font-semibold bg-transparent border-0 cursor-pointer px-0">
                  ↩ <%= t("feedback_boards.feedbacks_page.reply_btn", default: "Phản hồi") %>
                </button>

                <!-- Inline editor -->
                <div id="reply-editor-<%= fb.id %>" class="hidden mt-1.5">
                  <div class="relative">
                    <textarea id="reply-input-<%= fb.id %>"
                      rows="2"
                      placeholder="<%= j t("feedback_boards.feedbacks_page.reply_placeholder", default: "Nhập phản hồi của admin...") %>"
                      class="w-full px-3 py-2 pr-9 border border-indigo-200 rounded-lg text-[12px] text-slate-700 resize-none focus:border-indigo-400 outline-none bg-white leading-relaxed"><%= fb.admin_reply %></textarea>
                    <!-- Camera button -->
                    <button type="button" onclick="document.getElementById('reply-img-input-<%= fb.id %>').click()"
                      class="absolute bottom-2 right-2 w-5 h-5 flex items-center justify-center rounded text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                      </svg>
                    </button>
                    <input type="file" id="reply-img-input-<%= fb.id %>" accept="image/*" class="hidden"
                      onchange="previewReplyImage(<%= fb.id %>, this)">
                  </div>
                  <!-- Ảnh đang lưu (hiện trong editor để có thể xoá) -->
                  <div id="reply-existing-img-wrap-<%= fb.id %>"
                       style="<%= fb.admin_reply_image.attached? ? 'display:inline-block' : 'display:none' %>"
                       class="mt-1.5 relative inline-block">
                    <img id="reply-existing-img-<%= fb.id %>"
                         src="<%= fb.admin_reply_image.attached? ? url_for(fb.admin_reply_image) : '' %>"
                         alt="" class="rounded-lg object-cover"
                         style="max-height:80px; max-width:120px; border:1px solid #e0e7ff;">
                    <button type="button" onclick="removeExistingReplyImage(<%= fb.id %>)"
                      class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-red-500 text-white rounded-full text-[10px] flex items-center justify-center border-0 cursor-pointer leading-none">✕</button>
                  </div>
                  <!-- Preview ảnh mới vừa chọn -->
                  <div id="reply-img-preview-wrap-<%= fb.id %>" style="display:none" class="mt-1.5 relative inline-block">
                    <img id="reply-img-preview-<%= fb.id %>" src="" alt="" class="rounded-lg object-cover" style="max-height:80px; max-width:120px; border:1px solid #e0e7ff;">
                    <button type="button" onclick="clearReplyImage(<%= fb.id %>)"
                      class="absolute -top-1.5 -right-1.5 w-4 h-4 bg-red-500 text-white rounded-full text-[10px] flex items-center justify-center border-0 cursor-pointer leading-none">✕</button>
                  </div>
                  <div class="flex gap-2 mt-1.5 items-center">
                    <button onclick="saveAdminReply(<%= fb.id %>, '<%= feedback_board_feedback_path(@board, fb) %>')"
                      class="px-3 py-1 bg-blue-500 text-white text-[11px] font-semibold rounded-lg hover:bg-blue-600 border-0 cursor-pointer">
                      <%= t("feedback_boards.feedbacks_page.save_reply", default: "Lưu phản hồi") %>
                    </button>
                    <button onclick="cancelReplyEditor(<%= fb.id %>)"
                      class="px-3 py-1 bg-slate-100 text-slate-600 text-[11px] font-semibold rounded-lg hover:bg-slate-200 border-0 cursor-pointer">
                      <%= t("common.cancel") %>
                    </button>
                  </div>
                </div>
              </div>
              <!-- /admin reply -->

            </div>
            <!-- Action buttons -->
            <div class="flex flex-col gap-1 flex-shrink-0">
              <% if fb.flagged? %>
                <button id="mark-safe-btn-<%= fb.id %>"
                  onclick="feedbackAction(<%= fb.id %>, '<%= mark_safe_feedback_board_feedback_path(@board, fb) %>', 'PATCH', 'mark_safe')"
                  class="px-2 py-1 text-[10px] font-semibold bg-emerald-50 rounded-md text-emerald-700 hover:bg-emerald-100 border border-emerald-200">
                  <%= t("feedback_boards.feedbacks_page.mark_safe") %>
                </button>
              <% elsif fb.hidden? %>
                <button id="approve-btn-<%= fb.id %>"
                  onclick="feedbackAction(<%= fb.id %>, '<%= unhide_feedback_board_feedback_path(@board, fb) %>', 'PATCH', 'unhide')"
                  class="px-2 py-1 text-[10px] font-semibold bg-emerald-50 rounded-md text-emerald-700 hover:bg-emerald-100 border border-emerald-200">
                  <%= t("feedback_boards.feedbacks_page.restore") %>
                </button>
              <% else %>
                <button id="approve-btn-<%= fb.id %>"
                  onclick="feedbackAction(<%= fb.id %>, '<%= approve_feedback_board_feedback_path(@board, fb) %>', 'PATCH', 'approve')"
                  class="px-2 py-1 text-[10px] font-semibold bg-emerald-50 rounded-md text-emerald-700 hover:bg-emerald-100 border border-emerald-200 <%= fb.approved? ? 'hidden' : '' %>">
                  <%= t("feedback_boards.feedbacks_page.approve") %>
                </button>
                <button id="hide-btn-<%= fb.id %>"
                  onclick="feedbackAction(<%= fb.id %>, '<%= hide_feedback_board_feedback_path(@board, fb) %>', 'PATCH', 'hide')"
                  class="px-2 py-1 text-[10px] font-semibold bg-slate-100 rounded-md text-slate-600 hover:bg-slate-200 border border-slate-200">
                  <%= t("feedback_boards.feedbacks_page.hide") %>
                </button>
              <% end %>
              <button id="pin-btn-<%= fb.id %>"
                onclick="togglePin(<%= fb.id %>, '<%= pin_feedback_board_feedback_path(@board, fb) %>', '<%= unpin_feedback_board_feedback_path(@board, fb) %>')"
                data-pinned="<%= fb.pinned? ? '1' : '0' %>"
                class="px-2 py-1 text-[10px] font-semibold bg-amber-50 rounded-md text-amber-700 hover:bg-amber-100 border border-amber-200">
                <%= fb.pinned? ? t("feedback_boards.feedbacks_page.unpin") : t("feedback_boards.feedbacks_page.pin") %>
              </button>
              <button onclick="openDeleteFeedbackModal(<%= fb.id %>, '<%= feedback_board_feedback_path(@board, fb) %>')"
                class="px-2 py-1 text-[10px] font-semibold bg-red-50 rounded-md text-red-600 hover:bg-red-100 border border-red-200">
                <%= t("feedback_boards.feedbacks_page.delete") %>
              </button>
            </div>
          </div>
        </div>
      <% end %>

      <% if @feedbacks.empty? %>
        <div class="flex flex-col items-center justify-center py-16 text-slate-400">
          <div class="text-4xl mb-3">💬</div>
          <p class="text-[13px]"><%= t("feedback_boards.feedbacks_page.no_feedbacks") %></p>
        </div>
      <% end %>
    </div><!-- /feedbacks-list -->

    <!-- ── Pagination (fixed at bottom) ──────────────────────────────── -->
    <% if @pagy && @pagy.pages > 1 %>
      <div class="flex-shrink-0 flex items-center justify-between px-4 py-2.5 border-t border-indigo-50" style="background:rgba(99,102,241,0.04);">
        <p class="text-[11px] text-slate-500">
          <% from = (@pagy.page - 1) * @pagy.items + 1
             to   = [@pagy.page * @pagy.items, @pagy.count].min %>
          <%= from %>–<%= to %> / <%= @pagy.count %>
        </p>
        <div class="flex gap-1">
          <% if @pagy.page > 1 %>
            <%= link_to feedback_board_feedbacks_path(@board, page: @pagy.page - 1, status: params[:status], q: params[:q]),
                  class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-slate-50 bg-white" do %>
              ← <%= t("surveys.prev") %>
            <% end %>
          <% end %>
          <% window_start = [1, @pagy.page - 2].max
             window_end   = [@pagy.pages, window_start + 4].min
             window_start = [window_end - 4, 1].max %>
          <% (window_start..window_end).each do |p| %>
            <%= link_to feedback_board_feedbacks_path(@board, page: p, status: params[:status], q: params[:q]),
                  class: "px-2.5 py-1 text-[11px] border rounded-md #{p == @pagy.page ? 'bg-blue-500 border-slate-600 text-white font-semibold' : 'border-slate-200 text-slate-600 hover:bg-slate-50 bg-white'}" do %>
              <%= p %>
            <% end %>
          <% end %>
          <% if @pagy.page < @pagy.pages %>
            <%= link_to feedback_board_feedbacks_path(@board, page: @pagy.page + 1, status: params[:status], q: params[:q]),
                  class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-slate-50 bg-white" do %>
              <%= t("surveys.next") %> →
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div><!-- /card wrapper -->

<!-- ── Bulk action bar (hidden until items selected) ──────────────────────── -->
<div id="bulk-bar" style="display:none;"
     class="fixed bottom-0 left-0 right-0 z-40 flex items-center justify-between px-6 py-3 bg-slate-900 text-white shadow-2xl">
  <div class="flex items-center gap-3">
    <span class="text-[13px] font-semibold">
      <span id="bulk-count">0</span> <%= t("feedback_boards.feedbacks_page.bulk_selected", default: "đã chọn") %>
    </span>
    <button onclick="bulkSelectAll()" class="text-[11px] text-slate-400 hover:text-white underline underline-offset-2 border-0 bg-transparent cursor-pointer">
      <%= t("feedback_boards.feedbacks_page.bulk_select_all", default: "Chọn tất cả") %>
    </button>
    <button onclick="bulkDeselectAll()" class="text-[11px] text-slate-400 hover:text-white underline underline-offset-2 border-0 bg-transparent cursor-pointer">
      <%= t("feedback_boards.feedbacks_page.bulk_deselect", default: "Bỏ chọn") %>
    </button>
  </div>
  <div class="flex items-center gap-2">
    <button onclick="doBulkAction('approve')"
      class="px-3 py-1.5 text-[12px] font-semibold bg-emerald-500 hover:bg-emerald-600 text-white rounded-lg border-0 cursor-pointer transition-colors">
      ✓ <%= t("feedback_boards.feedbacks_page.bulk_approve", default: "Duyệt") %>
    </button>
    <button onclick="doBulkAction('hide')"
      class="px-3 py-1.5 text-[12px] font-semibold bg-slate-600 hover:bg-slate-500 text-white rounded-lg border-0 cursor-pointer transition-colors">
      🙈 <%= t("feedback_boards.feedbacks_page.bulk_hide", default: "Ẩn") %>
    </button>
    <button onclick="doBulkAction('reject')"
      class="px-3 py-1.5 text-[12px] font-semibold bg-amber-500 hover:bg-amber-600 text-white rounded-lg border-0 cursor-pointer transition-colors">
      ✕ <%= t("feedback_boards.feedbacks_page.bulk_reject", default: "Từ chối") %>
    </button>
    <button onclick="doBulkAction('delete')"
      class="px-3 py-1.5 text-[12px] font-semibold bg-red-600 hover:bg-red-700 text-white rounded-lg border-0 cursor-pointer transition-colors">
      🗑 <%= t("feedback_boards.feedbacks_page.bulk_delete", default: "Xóa") %>
    </button>
  </div>
</div>

</div><!-- /tab-panel-feedbacks -->

<!-- Tab: AI Insight (fills remaining height) -->
<div id="tab-panel-ai" style="display:none" class="flex-1 min-h-0 overflow-hidden px-6 pt-5 pb-5">

  <!-- 2-column layout: AI Analysis (left) | Action Items (right) -->
  <div class="grid grid-cols-12 gap-5" style="grid-template-rows:1fr; height:100%;">

    <!-- Left: Phân tích bằng AI -->
    <div class="col-span-7 min-h-0 flex flex-col rounded-[12px] border overflow-hidden" style="border-color:rgba(139,92,246,0.2); background:rgba(245,243,255,0.6);">

      <!-- Card header: cố định, không scroll -->
      <div class="flex-shrink-0 flex items-center gap-2 px-4 py-3" style="background:rgba(139,92,246,0.08); border-bottom:1px solid rgba(139,92,246,0.15);">
        <span class="text-[14px]">🔮</span>
        <span class="text-[13px] font-bold text-violet-700"><%= t("feedback_boards.feedbacks_page.ai_analysis_title") %></span>
        <span id="ai-generated-time" class="text-[10px] text-slate-400 ml-1">
          <%= @ai_summary ? I18n.l(@ai_summary.created_at.in_time_zone, format: :short) : "" %>
        </span>
        <% has_new     = @new_feedbacks_since_analysis.to_i > 0 %>
        <% no_new_note = @ai_summary.present? && !has_new %>
        <div class="ml-auto flex flex-col items-end gap-1">
          <div class="flex items-center gap-2">
            <!-- Language selector -->
            <div class="relative">
              <select id="ai-lang-select"
                class="appearance-none pl-3 pr-7 py-1.5 text-[12px] font-semibold bg-white border border-slate-200 rounded-lg text-slate-600 hover:border-violet-300 focus:outline-none focus:border-violet-400 cursor-pointer">
                <option value="vi" <%= current_workspace.language == "vi" ? "selected" : "" %>><%= t("feedback_boards.feedbacks_page.lang_vi") %></option>
                <option value="en" <%= current_workspace.language == "en" ? "selected" : "" %>><%= t("feedback_boards.feedbacks_page.lang_en") %></option>
              </select>
              <span class="pointer-events-none absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 text-[10px]">▾</span>
            </div>
            <span class="text-[10px] text-slate-400 font-medium">
              <%= t("feedback_boards.feedbacks_page.ai_credit_cost", n: 3) %>
            </span>
            <button onclick="aiSummarize()"
              id="ai-summarize-btn"
              class="px-3 py-1.5 text-white text-[12px] font-semibold rounded-lg flex items-center gap-1.5 <%= has_new ? 'bg-amber-500 hover:bg-amber-600' : 'bg-blue-500 hover:bg-blue-600' %>">
              <span id="ai-btn-spinner" class="hidden w-3 h-3 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
              <%= has_new ? t("feedback_boards.feedbacks_page.ai_summary_regenerate") : t("feedback_boards.feedbacks_page.ai_summarize") %>
            </button>
          </div>
          <% if no_new_note %>
            <span class="text-[10px] text-red-500 font-medium">
              <%= t("feedback_boards.feedbacks_page.ai_no_new_feedbacks") %>
            </span>
          <% end %>
        </div>
      </div>

      <!-- Banner cảnh báo: cố định, không scroll, ẩn khi phân tích lại -->
      <% if has_new %>
        <div id="ai-new-feedbacks-banner" class="flex-shrink-0 border-b border-amber-200 bg-amber-50">
          <div class="flex items-start gap-3 px-4 py-2.5">
            <span class="text-[16px] flex-shrink-0 mt-0.5">🔔</span>
            <div class="flex-1 min-w-0">
              <p class="text-[12px] font-bold text-amber-800">
                <%= t("feedback_boards.feedbacks_page.ai_new_feedbacks_banner", count: @new_feedbacks_since_analysis) %>
              </p>
              <p class="text-[11px] text-amber-700 mt-0.5 leading-snug">
                <%= t("feedback_boards.feedbacks_page.ai_reanalyze_items_note") %>
              </p>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Card body: scroll nội dung phân tích -->
      <div id="ai-summary-panel" class="flex-1 min-h-0 overflow-y-auto">
        <% if @ai_summary %>
          <%= render "admin/feedbacks/ai_summary_card", summary: @ai_summary %>
        <% else %>
          <div class="px-5 py-12 text-center text-slate-400">
            <div class="text-3xl mb-2">🔮</div>
            <p class="text-[13px]"><%= t("feedback_boards.feedbacks_page.ai_summary_empty") %></p>
          </div>
        <% end %>
      </div>

    </div>

    <!-- Right: Action Items -->
    <div class="col-span-5 min-h-0 flex flex-col" id="action-items-section">
      <%= render "admin/feedbacks/action_items_card",
                 action_items:      @action_items,
                 workspace_members: @workspace_members,
                 board:             @board %>
    </div>

  </div>

</div><!-- /tab-panel-ai -->

<script>
(function() {
const CSRF       = document.querySelector('meta[name=csrf-token]').content;
const STATUS_URL = "<%= ai_job_status_path("__ID__") %>";
const SUMMARIZE_URL = "<%= ai_summarize_feedback_board_path(@board) %>";
const HAS_SUMMARY = <%= @ai_summary ? 'true' : 'false' %>;
const I18N = {
  approved:            "<%= j t('status.approved') %>",
  unpin:               "<%= j t('feedback_boards.feedbacks_page.unpin') %>",
  pin:                 "<%= j t('feedback_boards.feedbacks_page.pin') %>",
  delete_confirm:      "<%= j t('feedback_boards.feedbacks_page.delete_confirm') %>",
  analyzing:           "<%= j t('feedback_boards.feedbacks_page.analyzing') %>",
  ai_summary_header:   "<%= j t('feedback_boards.feedbacks_page.ai_summary_header') %>",
  ai_summary_generated:"<%= j t('feedback_boards.feedbacks_page.ai_summary_generated', time: '') %>",
  ai_summary_sentiment:"<%= j t('feedback_boards.feedbacks_page.ai_summary_sentiment') %>",
  ai_summary_themes:   "<%= j t('feedback_boards.feedbacks_page.ai_summary_themes') %>",
  ai_summary_issues:   "<%= j t('feedback_boards.feedbacks_page.ai_summary_issues') %>",
  ai_summary_recs:     "<%= j t('feedback_boards.feedbacks_page.ai_summary_recommendations') %>",
  ai_summary_positive: "<%= j t('feedback_boards.feedbacks_page.ai_summary_positive') %>",
  ai_summary_neutral:  "<%= j t('feedback_boards.feedbacks_page.ai_summary_neutral') %>",
  ai_summary_negative: "<%= j t('feedback_boards.feedbacks_page.ai_summary_negative') %>",
  ai_summary_error:    "<%= j t('feedback_boards.feedbacks_page.ai_summary_error') %>",
  ai_summary_no_data:  "<%= j t('feedback_boards.feedbacks_page.ai_summary_no_data') %>",
  regenerate:          "<%= j t('feedback_boards.feedbacks_page.ai_summary_regenerate') %>",
  pending_banner:      "<%= j t('feedback_boards.feedbacks_page.pending_banner', count: '__N__') %>",
  flagged_banner:      "<%= j t('feedback_boards.feedbacks_page.flagged_banner', count: '__N__') %>"
};

// ── Live counters ─────────────────────────────────────────────────────────────
let pendingCount  = <%= @pending_count %>;
let flaggedCount  = <%= @flagged_count %>;
let totalCount    = <%= @board.feedbacks.count %>;
let approvedCount = <%= @board.feedbacks.approved.count %>;
const SUBTITLE_TPL = "<%= j t('feedback_boards.feedbacks_page.total', total: '__T__', pending: '__P__') %>";

function updateHeaderCounts() {
  const subtitle = document.getElementById('board-subtitle');
  if (subtitle) subtitle.textContent = SUBTITLE_TPL.replace('__T__', totalCount).replace('__P__', pendingCount);
  const badge = document.getElementById('feedbacks-card-count');
  if (badge) badge.textContent = approvedCount;
  // Show/hide empty state
  const list = document.getElementById('feedbacks-list');
  if (!list) return;
  const hasCards = list.querySelectorAll('.feedback-row').length > 0;
  let empty = list.querySelector('.feedback-empty-state');
  if (!hasCards && !empty) {
    empty = document.createElement('div');
    empty.className = 'feedback-empty-state flex flex-col items-center justify-center py-16 text-slate-400';
    empty.innerHTML = '<div class="text-4xl mb-3">💬</div><p class="text-[13px]"><%= j t("feedback_boards.feedbacks_page.no_feedbacks") %></p>';
    list.appendChild(empty);
  } else if (hasCards && empty) {
    empty.remove();
  }
}

function renderPendingText(n) { return I18N.pending_banner.replace('__N__', n); }
function renderFlaggedText(n) { return I18N.flagged_banner.replace('__N__', n); }

function updatePendingBanner(delta) {
  pendingCount += delta;
  const banner = document.getElementById('pending-banner');
  const text   = document.getElementById('pending-count-text');
  if (!banner) return;
  if (pendingCount <= 0) {
    banner.classList.add('hidden');
  } else {
    banner.classList.remove('hidden');
    text.textContent = renderPendingText(pendingCount);
  }
  syncBannersWrap();
}

function updateFlaggedBanner(delta) {
  flaggedCount += delta;
  const banner = document.getElementById('flagged-banner');
  const text   = document.getElementById('flagged-count-text');
  const badge  = document.getElementById('flagged-tab-badge');
  if (!banner) return;
  if (flaggedCount <= 0) {
    banner.classList.add('hidden');
    if (badge) badge.classList.add('hidden');
  } else {
    banner.classList.remove('hidden');
    text.textContent = renderFlaggedText(flaggedCount);
    if (badge) { badge.textContent = flaggedCount; badge.classList.remove('hidden'); }
  }
  syncBannersWrap();
}

function syncBannersWrap() {
  const wrap = document.getElementById('banners-wrap');
  if (!wrap) return;
  const hasPending = !document.getElementById('pending-banner')?.classList.contains('hidden');
  const hasFlagged = !document.getElementById('flagged-banner')?.classList.contains('hidden');
  if (hasPending || hasFlagged) {
    wrap.className = 'flex-shrink-0 flex gap-2 flex-wrap px-4 py-2.5 border-b border-indigo-50';
  } else {
    wrap.className = 'hidden';
  }
}

// Initialize text on load
(function() {
  const pt = document.getElementById('pending-count-text');
  const ft = document.getElementById('flagged-count-text');
  if (pt) pt.textContent = renderPendingText(pendingCount);
  if (ft) ft.textContent = renderFlaggedText(flaggedCount);
})();

// ── Progress ring ────────────────────────────────────────────────────────────
const RING_CIRCUMFERENCE = 251.2; // 2π × 40
const AI_STEPS = [
  { pct:  8, label: "<%= j t('feedback_boards.feedbacks_page.ai_progress.reading') %>" },
  { pct: 22, label: "<%= j t('feedback_boards.feedbacks_page.ai_progress.processing') %>" },
  { pct: 42, label: "<%= j t('feedback_boards.feedbacks_page.ai_progress.sentiment') %>" },
  { pct: 62, label: "<%= j t('feedback_boards.feedbacks_page.ai_progress.themes') %>" },
  { pct: 82, label: "<%= j t('feedback_boards.feedbacks_page.ai_progress.generating') %>" }
];
let _progressTimer = null;
let _currentStep   = 0;

function setProgress(pct, label) {
  const ring = document.getElementById('fb-progress-ring');
  const txt  = document.getElementById('fb-progress-pct');
  const lbl  = document.getElementById('fb-progress-label');
  if (!ring) return;
  ring.style.strokeDashoffset = RING_CIRCUMFERENCE * (1 - pct / 100);
  if (txt) txt.textContent = Math.round(pct) + '%';
  if (lbl && label !== undefined) lbl.textContent = label;
}

function startProgress() {
  _currentStep = 0;
  let _creepPct = 0;
  setProgress(AI_STEPS[0].pct, AI_STEPS[0].label);
  _progressTimer = setInterval(() => {
    if (_currentStep < AI_STEPS.length - 1) {
      _currentStep++;
      const s = AI_STEPS[_currentStep];
      setProgress(s.pct, s.label);
    } else {
      // Slow creep after last phase — 0.5% every tick, cap at 98%
      _creepPct = _creepPct || AI_STEPS[_currentStep].pct;
      if (_creepPct < 98) {
        _creepPct = Math.min(_creepPct + 0.5, 98);
        setProgress(_creepPct);
      }
    }
  }, 3000);
}

function finishProgress(onDone) {
  clearInterval(_progressTimer);
  setProgress(100, "<%= j t('feedback_boards.feedbacks_page.ai_progress.done') %>");
  setTimeout(onDone, 500);
}

function stopProgress() {
  clearInterval(_progressTimer);
}

function progressLoadingHtml() {
  return `
    <div class="px-5 py-10 text-center flex flex-col items-center justify-center h-full">
      <div class="relative inline-flex items-center justify-center mb-5">
        <svg width="96" height="96" class="-rotate-90">
          <circle cx="48" cy="48" r="40" fill="none" stroke="#e2e8f0" stroke-width="7"/>
          <circle id="fb-progress-ring" cx="48" cy="48" r="40" fill="none"
            stroke="url(#fb-ai-grad)" stroke-width="7" stroke-linecap="round"
            stroke-dasharray="${RING_CIRCUMFERENCE}" stroke-dashoffset="${RING_CIRCUMFERENCE}"
            style="transition:stroke-dashoffset 0.7s ease"/>
          <defs>
            <linearGradient id="fb-ai-grad" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%"   stop-color="#8b5cf6"/>
              <stop offset="100%" stop-color="#6366f1"/>
            </linearGradient>
          </defs>
        </svg>
        <span id="fb-progress-pct"
          class="absolute text-[20px] font-extrabold"
          style="background:linear-gradient(135deg,#8b5cf6,#6366f1);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">
          0%
        </span>
      </div>
      <p id="fb-progress-label" class="text-[13px] font-semibold text-slate-700 mb-1"></p>
      <p class="text-[11px] text-slate-400">${I18N.analyzing}</p>
    </div>`;
}

// ── Tab switching ──────────────────────────────────────────────────────────
function switchTab(name) {
  const panels = { feedbacks: 'tab-panel-feedbacks', ai: 'tab-panel-ai' };
  const buttons = { feedbacks: 'tab-btn-feedbacks', ai: 'tab-btn-ai' };

  Object.entries(panels).forEach(([key, id]) => {
    const panel = document.getElementById(id);
    const btn   = document.getElementById(buttons[key]);
    if (key === name) {
      // Use style.display so panels keep their own flex/block display value
      panel.style.display = '';
      btn.classList.remove('border-transparent', 'text-slate-400', 'hover:text-slate-600');
      btn.classList.add('border-slate-600', 'text-indigo-600');
    } else {
      panel.style.display = 'none';
      btn.classList.add('border-transparent', 'text-slate-400', 'hover:text-slate-600');
      btn.classList.remove('border-slate-600', 'text-indigo-600');
    }
  });
  // Persist tab in URL hash so language switcher reloads restore it
  history.replaceState(null, '', location.pathname + location.search + '#' + name);
}

// Restore tab from URL hash on load
(function() {
  const hash = location.hash.replace('#', '');
  if (hash === 'ai') {
    switchTab('ai');
  }
  // Update language switcher links to carry current hash through reloads
  document.querySelectorAll('a[href*="?locale="]').forEach(function(link) {
    link.addEventListener('click', function() {
      this.href = this.href.split('#')[0] + location.hash;
    });
  });
})();

// ── Feedback actions ────────────────────────────────────────────────────────
async function feedbackAction(id, url, method, action) {
  const res = await fetch(url, { method, headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json' } });
  if (!res.ok) return;

  const card       = document.getElementById(`feedback-${id}`);
  const approveBtn = document.getElementById(`approve-btn-${id}`);
  const badge      = document.querySelector(`.status-badge-${id}`);
  const wasPending    = card?.dataset.status === 'pending';
  const wasFlagged    = card?.dataset.moderation === 'flagged';

  if (action === 'approve') {
    if (approveBtn) approveBtn.classList.add('hidden');
    if (badge) {
      badge.textContent = I18N.approved;
      badge.className = `status-badge-${id} text-[10px] px-2 py-0.5 rounded-full bg-emerald-50 text-emerald-700`;
    }
    if (wasPending) updatePendingBanner(-1);
  } else if (action === 'mark_safe') {
    if (card) {
      card.style.opacity = '0';
      card.style.transform = 'translateX(10px)';
      setTimeout(() => card.remove(), 200);
    }
    if (wasFlagged) updateFlaggedBanner(-1);
    if (wasPending) updatePendingBanner(-1);
  } else if (action === 'hide' || action === 'unhide') {
    if (card) {
      card.style.opacity = '0';
      card.style.transform = 'translateX(10px)';
      setTimeout(() => card.remove(), 200);
    }
  }
}

async function togglePin(id, pinUrl, unpinUrl) {
  const btn    = document.getElementById(`pin-btn-${id}`);
  const pinned = btn.dataset.pinned === '1';
  const res = await fetch(pinned ? unpinUrl : pinUrl, { method: 'PATCH', headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json' } });
  if (!res.ok) return;
  const data = await res.json();

  const badge = document.querySelector(`.pin-badge-${id}`);
  if (data.pinned) {
    btn.dataset.pinned = '1';
    btn.textContent = I18N.unpin;
    if (badge) badge.classList.remove('hidden');
  } else {
    btn.dataset.pinned = '0';
    btn.textContent = I18N.pin;
    if (badge) badge.classList.add('hidden');
  }

  const list = document.getElementById('feedbacks-list');
  list.style.opacity = '0.4';
  setTimeout(() => {
    data.order.forEach(fid => {
      const card = document.getElementById(`feedback-${fid}`);
      if (card) list.appendChild(card);
    });
    list.style.opacity = '1';
  }, 150);
}

function deleteFeedback(id, url) {
  openDeleteFeedbackModal(id, url);
}

// ── AI Summary ──────────────────────────────────────────────────────────────
function renderSummaryCard(result, generatedAt) {
  // Update the generated time in the card header (always visible)
  const timeEl = document.getElementById('ai-generated-time');
  if (timeEl) timeEl.textContent = generatedAt || new Date().toLocaleString();

  const sentiment = result.sentiment || {};
  const themes    = result.themes    || [];
  const issues    = result.priority_issues    || [];
  const recs      = result.recommendations || [];

  const sentimentHtml = (sentiment.positive !== undefined || sentiment.neutral !== undefined || sentiment.negative !== undefined) ? `
    <div class="flex gap-2 flex-wrap items-center">
      <span class="text-[10px] font-bold text-slate-500 uppercase tracking-wide mr-1">${I18N.ai_summary_sentiment}:</span>
      <span class="px-2.5 py-1 rounded-full text-[11px] font-semibold bg-emerald-50 text-emerald-700">
        ▲ ${I18N.ai_summary_positive}: ${sentiment.positive || '–'}
      </span>
      <span class="px-2.5 py-1 rounded-full text-[11px] font-semibold bg-slate-100 text-slate-600">
        ● ${I18N.ai_summary_neutral}: ${sentiment.neutral || '–'}
      </span>
      <span class="px-2.5 py-1 rounded-full text-[11px] font-semibold bg-red-50 text-red-600">
        ▼ ${I18N.ai_summary_negative}: ${sentiment.negative || '–'}
      </span>
    </div>` : '';

  const themesHtml = themes.length ? `
    <div>
      <div class="text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-2">${I18N.ai_summary_themes}</div>
      <div class="flex gap-2 flex-wrap">
        ${themes.map(t => `<span class="px-2.5 py-1 rounded-full text-[11px] font-semibold border ${t.sentiment === 'positive' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : t.sentiment === 'negative' ? 'bg-red-50 text-red-600 border-red-200' : 'bg-slate-50 text-slate-600 border-slate-200'}">${t.name} <span class="opacity-60">(${t.count})</span></span>`).join('')}
      </div>
    </div>` : '';

  const issuesHtml = issues.length ? `
    <div>
      <div class="text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-2">${I18N.ai_summary_issues}</div>
      <ul class="space-y-1">
        ${issues.map(i => `<li class="flex gap-2 text-[12px] text-slate-700"><span class="text-red-400 flex-shrink-0">•</span>${i}</li>`).join('')}
      </ul>
    </div>` : '';

  const recsHtml = recs.length ? `
    <div>
      <div class="text-[11px] font-bold text-slate-500 uppercase tracking-wide mb-2">${I18N.ai_summary_recs}</div>
      <ul class="space-y-1">
        ${recs.map(r => `<li class="flex gap-2 text-[12px] text-slate-700"><span class="text-indigo-400 flex-shrink-0">→</span>${r}</li>`).join('')}
      </ul>
    </div>` : '';

  // Return body content only — the outer card + header are always in the DOM
  return `
    <div class="p-5 space-y-4">
      ${result.summary ? `<p class="text-[13px] text-slate-800 leading-relaxed">${result.summary}</p>` : ''}
      ${sentimentHtml}
      ${themesHtml}
      ${issuesHtml}
      ${recsHtml}
    </div>`;
}

async function aiSummarize() {
  const lang  = document.getElementById('ai-lang-select')?.value || 'vi';
  const panel = document.getElementById('ai-summary-panel');
  const btn   = document.getElementById('ai-summarize-btn');
  const spinner = document.getElementById('ai-btn-spinner');

  // Switch to AI tab first
  switchTab('ai');

  // Hide new-feedbacks banner (no longer relevant once analysis starts)
  const banner = document.getElementById('ai-new-feedbacks-banner');
  if (banner) banner.style.display = 'none';

  // Show progress ring loading state
  if (btn) btn.disabled = true;
  if (spinner) spinner.classList.remove('hidden');
  panel.innerHTML = progressLoadingHtml();
  // Kick off animated ring after the DOM is rendered
  requestAnimationFrame(() => startProgress());

  const resetBtn = () => {
    if (btn) btn.disabled = false;
    if (spinner) spinner.classList.add('hidden');
  };

  try {
    const resp = await fetch(SUMMARIZE_URL, {
      method: 'POST',
      headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json', 'Content-Type': 'application/json' },
      body: JSON.stringify({ language: lang })
    });
    const data = await resp.json();

    if (window.handleAiUpgrade(resp, data, '<%= j t("feedback_boards.feedbacks_page.ai_summarize") %>')) {
      stopProgress(); resetBtn(); panel.innerHTML = ''; return;
    }
    if (!resp.ok) {
      stopProgress();
      resetBtn();
      panel.innerHTML = `<div class="px-5 py-4 text-[13px] text-red-600">❌ ${data.error || I18N.ai_summary_error}</div>`;
      return;
    }

    pollJob(data.job_id, (result) => {
      finishProgress(() => {
        resetBtn();
        panel.innerHTML = renderSummaryCard(result, new Date().toLocaleString());
        const dot = document.getElementById('ai-tab-dot');
        if (dot) dot.classList.remove('hidden');
        window.deductDisplayCredits?.(3);
        // Reload action items section after analysis completes
        reloadActionItems();
      });
    }, () => {
      stopProgress();
      resetBtn();
      panel.innerHTML = `<div class="px-5 py-4 text-[13px] text-red-600">❌ ${I18N.ai_summary_error}</div>`;
    });
  } catch(e) {
    stopProgress();
    resetBtn();
    panel.innerHTML = `<div class="px-5 py-4 text-[13px] text-red-600">❌ ${I18N.ai_summary_error}</div>`;
  }
}

async function reloadActionItems() {
  try {
    const resp = await fetch(window.location.pathname + '?partial=action_items', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    const html = await resp.text();
    const section = document.getElementById('action-items-section');
    if (section && html) section.innerHTML = html;
  } catch(e) {}
}

async function pollJob(jobId, onDone, onFail) {
  const resp = await fetch(STATUS_URL.replace('__ID__', jobId));
  const data = await resp.json();
  if (data.status === 'done') {
    onDone(data.output);
  } else if (data.status === 'failed') {
    if (onFail) onFail(data.error);
  } else {
    setTimeout(() => pollJob(jobId, onDone, onFail), 2000);
  }
}

// ── Live search ───────────────────────────────────────────────────────────────
const BASE_URL   = "<%= feedback_board_feedbacks_path(@board) %>";
const CURRENT_STATUS    = "<%= params[:status] %>";
const CURRENT_MODERATION = "<%= params[:moderation] %>";
let searchTimer = null;

function buildSearchUrl(q) {
  const url = new URL(BASE_URL, location.origin);
  if (CURRENT_STATUS)    url.searchParams.set('status', CURRENT_STATUS);
  if (CURRENT_MODERATION) url.searchParams.set('moderation', CURRENT_MODERATION);
  if (q) url.searchParams.set('q', q);
  return url.toString();
}

async function liveSearch(q) {
  const list = document.getElementById('feedbacks-list');
  if (list) list.style.opacity = '0.5';

  try {
    const res  = await fetch(buildSearchUrl(q), { headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' } });
    const html = await res.text();
    const doc  = new DOMParser().parseFromString(html, 'text/html');
    const newList = doc.getElementById('feedbacks-list');
    if (list && newList) {
      list.innerHTML = newList.innerHTML;
      list.style.opacity = '1';
    }
  } catch(e) {
    if (list) list.style.opacity = '1';
  }
}

function clearSearch() {
  const input = document.getElementById('feedback-search');
  const clearBtn = document.getElementById('search-clear-btn');
  if (input) input.value = '';
  if (clearBtn) clearBtn.classList.add('hidden');
  liveSearch('');
}

(function() {
  const input    = document.getElementById('feedback-search');
  const clearBtn = document.getElementById('search-clear-btn');
  if (!input) return;

  input.addEventListener('input', function() {
    const q = this.value.trim();
    if (clearBtn) clearBtn.classList.toggle('hidden', q === '');
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => liveSearch(q), 300);
  });
})();

// ── Bulk selection ───────────────────────────────────────────────────────────
const BULK_URL = "<%= bulk_action_feedback_board_feedbacks_path(@board) %>";
const BULK_CONFIRM = {
  approve: "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_approve', default: 'Duyệt %{n} góp ý đã chọn?') %>",
  hide:    "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_hide',    default: 'Ẩn %{n} góp ý đã chọn?') %>",
  reject:  "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_reject',  default: 'Từ chối %{n} góp ý đã chọn?') %>",
  delete:  "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_delete',  default: 'Xóa vĩnh viễn %{n} góp ý đã chọn? Không thể hoàn tác.') %>"
};

function getCheckedIds() {
  return Array.from(document.querySelectorAll('.bulk-checkbox:checked')).map(cb => cb.value);
}

function updateBulkBar() {
  const ids = getCheckedIds();
  const bar = document.getElementById('bulk-bar');
  const countEl = document.getElementById('bulk-count');
  if (ids.length > 0) {
    countEl.textContent = ids.length;
    bar.style.display = 'flex';
  } else {
    bar.style.display = 'none';
  }
  // Sync select-all checkbox state
  const allCbs = document.querySelectorAll('.bulk-checkbox');
  const selectAll = document.getElementById('bulk-select-all');
  if (selectAll) {
    selectAll.checked = allCbs.length > 0 && ids.length === allCbs.length;
    selectAll.indeterminate = ids.length > 0 && ids.length < allCbs.length;
  }
}

function toggleSelectAll(checked) {
  document.querySelectorAll('.bulk-checkbox').forEach(cb => cb.checked = checked);
  updateBulkBar();
}

function bulkSelectAll()   { toggleSelectAll(true);  }
function bulkDeselectAll() { toggleSelectAll(false); }

const BULK_MODAL_LABELS = {
  approve: { title: "<%= j t('feedback_boards.feedbacks_page.bulk_approve', default: 'Duyệt') %>",      body: (n) => "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_approve', default: 'Duyệt %{n} góp ý đã chọn?') %>".replace('%{n}', n) },
  hide:    { title: "<%= j t('feedback_boards.feedbacks_page.bulk_hide',    default: 'Ẩn') %>",         body: (n) => "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_hide',    default: 'Ẩn %{n} góp ý đã chọn?') %>".replace('%{n}', n) },
  reject:  { title: "<%= j t('feedback_boards.feedbacks_page.bulk_reject',  default: 'Từ chối') %>",    body: (n) => "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_reject',  default: 'Từ chối %{n} góp ý đã chọn?') %>".replace('%{n}', n) },
  delete:  { title: "<%= j t('feedback_boards.feedbacks_page.bulk_delete',  default: 'Xóa') %>",        body: (n) => "<%= j t('feedback_boards.feedbacks_page.bulk_confirm_delete',  default: 'Xóa vĩnh viễn %{n} góp ý đã chọn? Không thể hoàn tác.') %>".replace('%{n}', n) }
};

function doBulkAction(action) {
  const ids = getCheckedIds();
  if (!ids.length) return;

  const lbl = BULK_MODAL_LABELS[action];
  openBulkConfirmModal(
    action,
    lbl.title,
    lbl.body(ids.length),
    lbl.title,
    () => executeBulkAction(action, ids)
  );
}

async function executeBulkAction(action, ids) {
  const res = await fetch(BULK_URL, {
    method: 'POST',
    headers: { 'X-CSRF-Token': CSRF, 'Content-Type': 'application/json', 'Accept': 'application/json' },
    body: JSON.stringify({ ids, bulk_action_type: action })
  });

  if (!res.ok) return;
  const data = await res.json();

  // Snapshot card statuses before removal (needed for counter updates)
  const cardSnapshots = ids.map(id => {
    const c = document.getElementById(`feedback-${id}`);
    return c ? { id, status: c.dataset.status, moderation: c.dataset.moderation } : null;
  }).filter(Boolean);

  // Remove or update cards in DOM
  ids.forEach(id => {
    const card = document.getElementById(`feedback-${id}`);
    if (!card) return;
    if (action === 'delete') {
      card.style.transition = 'opacity 0.2s, transform 0.2s';
      card.style.opacity = '0';
      card.style.transform = 'translateX(10px)';
      setTimeout(() => { card.remove(); updateHeaderCounts(); }, 220);
    } else if (action === 'approve') {
      // If currently filtering (status or moderation view), remove card since it may no longer match
      if (CURRENT_MODERATION || CURRENT_STATUS) {
        card.style.transition = 'opacity 0.2s, transform 0.2s';
        card.style.opacity = '0';
        card.style.transform = 'translateX(10px)';
        setTimeout(() => { card.remove(); updateHeaderCounts(); }, 220);
      } else {
        card.dataset.status = 'approved';
        card.dataset.moderation = 'safe';
        const badge = card.querySelector(`[class*="status-badge-"]`);
        if (badge) {
          badge.textContent = I18N.approved;
          badge.className = badge.className.replace(/bg-\w+-\d+ text-\w+-\d+/g, 'bg-emerald-50 text-emerald-700');
        }
      }
    } else {
      // hide / reject — remove from current filtered view
      card.style.transition = 'opacity 0.2s';
      card.style.opacity = '0';
      setTimeout(() => { card.remove(); updateHeaderCounts(); }, 220);
    }
  });

  // Update live counters
  if (action === 'delete') {
    totalCount -= cardSnapshots.length;
    approvedCount -= cardSnapshots.filter(s => s.status === 'approved').length;
  } else if (action === 'approve') {
    const wasNotApproved = cardSnapshots.filter(s => s.status !== 'approved').length;
    approvedCount += wasNotApproved;
    const pendingRemoved = cardSnapshots.filter(s => s.status === 'pending').length;
    if (pendingRemoved > 0) updatePendingBanner(-pendingRemoved);
    if (CURRENT_MODERATION === 'flagged') updateFlaggedBanner(-cardSnapshots.length);
  }

  // Update header (subtitle + badge) immediately for non-delete actions
  if (action !== 'delete') updateHeaderCounts();

  // Hide bulk bar
  toggleSelectAll(false);
}

function recordDeleted(wasApproved) {
  totalCount--;
  if (wasApproved) approvedCount--;
  updateHeaderCounts();
}

Object.assign(window, { feedbackAction, togglePin, deleteFeedback, aiSummarize, switchTab, clearSearch, openDeleteFeedbackModal, closeDeleteFeedbackModal, doBulkAction, executeBulkAction, updateBulkBar, toggleSelectAll, bulkSelectAll, bulkDeselectAll, recordDeleted, updateHeaderCounts });
})();
</script>

<script>
// ── Admin reply helpers ────────────────────────────────────────────────────────
(function() {
  // Track which feedbacks have had their existing image marked for removal
  const _removeExistingImg = {};

  function openReplyEditor(id) {
    // Reset removal flag and restore existing image wrap to match current saved state
    _removeExistingImg[id] = false;
    const displayImg   = document.getElementById('reply-img-display-' + id);
    const existingWrap = document.getElementById('reply-existing-img-wrap-' + id);
    if (existingWrap) {
      const hasSaved = displayImg && displayImg.src && !displayImg.src.endsWith('#') && displayImg.style.display !== 'none';
      if (hasSaved) {
        const editorImg = document.getElementById('reply-existing-img-' + id);
        if (editorImg) editorImg.src = displayImg.src;
        existingWrap.style.display = 'inline-block';
      } else {
        existingWrap.style.display = 'none';
      }
    }
    // Also clear any leftover new-image preview from a previous open
    clearReplyImage(id);

    document.getElementById('reply-editor-' + id)?.classList.remove('hidden');
    const display = document.getElementById('reply-display-' + id);
    const toggle  = document.getElementById('reply-toggle-'  + id);
    if (display) display.style.display = 'none';
    if (toggle)  toggle.style.display  = 'none';
    document.getElementById('reply-input-' + id)?.focus();
  }

  // Helper: show/hide reply UI based on whether reply exists
  function _syncReplyUI(id, hasReply) {
    document.getElementById('reply-editor-' + id)?.classList.add('hidden');
    const display = document.getElementById('reply-display-' + id);
    const toggle  = document.getElementById('reply-toggle-'  + id);
    if (display) display.style.display = hasReply ? ''           : 'none';
    if (toggle)  toggle.style.display  = hasReply ? 'none'       : 'inline-flex';
  }

  function cancelReplyEditor(id) {
    _removeExistingImg[id] = false;
    clearReplyImage(id);
    const hasText = (document.getElementById('reply-text-' + id)?.textContent || '').trim().length > 0;
    const imgDisp = document.getElementById('reply-img-display-' + id);
    const hasImg  = imgDisp && imgDisp.src && !imgDisp.src.endsWith('#') && imgDisp.style.display !== 'none';
    _syncReplyUI(id, hasText || hasImg);
  }

  function removeExistingReplyImage(id) {
    _removeExistingImg[id] = true;
    const wrap = document.getElementById('reply-existing-img-wrap-' + id);
    if (wrap) wrap.style.display = 'none';
  }

  function previewReplyImage(id, input) {
    if (!input.files || !input.files.length) return;
    const blobUrl = URL.createObjectURL(input.files[0]);
    const previewImg  = document.getElementById('reply-img-preview-' + id);
    const previewWrap = document.getElementById('reply-img-preview-wrap-' + id);
    if (previewImg)  { if (previewImg._blobUrl) URL.revokeObjectURL(previewImg._blobUrl); previewImg._blobUrl = blobUrl; previewImg.src = blobUrl; }
    if (previewWrap) previewWrap.style.display = 'inline-block';
  }

  function clearReplyImage(id) {
    const fileInput   = document.getElementById('reply-img-input-' + id);
    const previewImg  = document.getElementById('reply-img-preview-' + id);
    const previewWrap = document.getElementById('reply-img-preview-wrap-' + id);
    if (fileInput) fileInput.value = '';
    if (previewImg) { if (previewImg._blobUrl) URL.revokeObjectURL(previewImg._blobUrl); previewImg._blobUrl = null; previewImg.src = ''; }
    if (previewWrap) previewWrap.style.display = 'none';
  }

  async function saveAdminReply(id, url) {
    const input     = document.getElementById('reply-input-' + id);
    const content   = (input?.value || '').trim();
    const fileInput = document.getElementById('reply-img-input-' + id);
    const hasNewImg = fileInput && fileInput.files && fileInput.files.length > 0;
    const removeImg = !!_removeExistingImg[id];
    const CSRF      = document.querySelector('meta[name=csrf-token]').content;

    const fd = new FormData();
    fd.append('feedback[admin_reply]', content);
    if (hasNewImg) {
      fd.append('feedback[admin_reply_image]', fileInput.files[0]);
    } else if (removeImg) {
      fd.append('feedback[remove_admin_reply_image]', '1');
    }
    const res = await fetch(url, { method: 'PATCH', headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json' }, body: fd });
    if (!res.ok) return;
    const data = await res.json();

    // Update text display
    const textEl = document.getElementById('reply-text-' + id);
    if (textEl) textEl.textContent = data.admin_reply || content;

    // Update image display section
    const imgDisplay = document.getElementById('reply-img-display-' + id);
    if (imgDisplay) {
      if (data.image_url) { imgDisplay.src = data.image_url; imgDisplay.style.display = ''; }
      else { imgDisplay.style.display = 'none'; }
    }

    // Clear local preview and removal flag
    clearReplyImage(id);
    _removeExistingImg[id] = false;

    _syncReplyUI(id, !!(data.admin_reply || data.image_url));
  }

  async function deleteAdminReply(id, url) {
    const CSRF = document.querySelector('meta[name=csrf-token]').content;
    const res = await fetch(url, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF, 'Accept': 'application/json' },
      body: JSON.stringify({ feedback: { admin_reply: '' } })
    });
    if (!res.ok) return;

    const input = document.getElementById('reply-input-' + id);
    if (input) input.value = '';
    const textEl = document.getElementById('reply-text-' + id);
    if (textEl) textEl.textContent = '';
    const imgDisplay = document.getElementById('reply-img-display-' + id);
    if (imgDisplay) { imgDisplay.src = ''; imgDisplay.style.display = 'none'; }

    _syncReplyUI(id, false);
  }

  Object.assign(window, { openReplyEditor, cancelReplyEditor, saveAdminReply, deleteAdminReply, previewReplyImage, clearReplyImage, removeExistingReplyImage });
})();
</script>
