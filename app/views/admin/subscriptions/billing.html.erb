<% content_for :title, t("subscription.billing.title") %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[22px] font-extrabold text-slate-900"><%= t("subscription.billing.title") %></h1>
</div>

<!-- All features free banner -->
<div class="mb-6 max-w-2xl p-4 bg-emerald-50 border border-emerald-100 rounded-xl">
  <div class="text-[14px] font-bold text-emerald-700 mb-1"><%= t("subscription.all_features_free") %></div>
  <div class="text-[12px] text-emerald-600">
    <%= t("subscription.monthly_credits_info", count: Subscription.monthly_free_credits, date: @subscription&.next_credit_reset_formatted) %>
  </div>
</div>

<!-- AI Credits balance -->
<% if @subscription %>
  <% bal = @subscription.credit_balance.to_i %>
  <% used = @subscription.credit_used.to_i %>
  <% max = @subscription.max_ai_credits.to_i %>
  <% pct = max > 0 ? [[bal * 100 / max, 0].max, 100].min : (bal > 0 ? 100 : 0) %>
  <% low = bal <= 5 %>
  <div class="max-w-2xl mb-6 bg-white rounded-xl border <%= low ? 'border-amber-200' : 'border-slate-200' %> shadow-sm overflow-hidden">
    <!-- Top accent bar -->
    <div class="h-1 w-full bg-gradient-to-r <%= low ? 'from-amber-400 to-orange-400' : 'from-indigo-500 to-violet-500' %>"></div>
    <div class="p-5">
      <div class="flex items-start justify-between gap-4">
        <!-- Left: label + big number -->
        <div>
          <div class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-1">🪙 <%= t("dashboard.ai_credits") %></div>
          <div class="flex items-end gap-2">
            <span class="text-[40px] font-black leading-none <%= low ? 'text-amber-500' : 'text-violet-600' %>"><%= bal %></span>
            <span class="text-[13px] text-slate-400 mb-1.5"><%= t("ai.credits_remaining") %></span>
          </div>
        </div>
        <!-- Right: used / reset info -->
        <div class="text-right flex-shrink-0">
          <div class="text-[12px] text-slate-400 mb-1"><%= t("dashboard.ai_credits_used") %></div>
          <div class="text-[18px] font-bold text-slate-700"><%= used %><% if max > 0 %><span class="text-[13px] font-normal text-slate-400"> / <%= max %></span><% end %></div>
          <div class="text-[11px] text-slate-400 mt-2">
            <%= t("dashboard.ai_credits_resets") %> <%= @subscription.next_credit_reset_formatted %>
          </div>
        </div>
      </div>

      <!-- Progress bar -->
      <% if max > 0 %>
        <div class="mt-4">
          <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
            <div class="h-2 rounded-full transition-all bg-gradient-to-r <%= low ? 'from-amber-400 to-orange-400' : 'from-indigo-500 to-violet-500' %>"
                 style="width: <%= pct %>%"></div>
          </div>
          <div class="flex justify-between text-[10px] text-slate-400 mt-1">
            <span>0</span>
            <span><%= max %></span>
          </div>
        </div>
      <% end %>

      <!-- Low credit warning -->
      <% if low %>
        <div class="mt-3 flex items-center gap-2 text-[12px] text-amber-700 bg-amber-50 border border-amber-100 rounded-lg px-3 py-2">
          <span>⚠️</span>
          <span><%= t("ai.credits_low_warning") %></span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<!-- AI Credits Packs -->
<% if @addon_credits.any? %>
  <div class="max-w-2xl mb-8">
    <h2 class="text-[16px] font-extrabold text-slate-900 mb-1"><%= t("subscription.buy_more_credits") %></h2>
    <p class="text-[13px] text-slate-500 mb-5"><%= t("subscription.buy_more_credits_desc") %></p>
    <div class="space-y-3">
      <% @addon_credits.each do |addon| %>
        <div class="bg-white rounded-xl border border-violet-200 p-4 flex items-center gap-4">
          <div class="flex-1 min-w-0">
            <div class="font-bold text-[14px] text-slate-900 mb-0.5"><%= addon.name %></div>
            <div class="text-[12px] text-slate-400 mb-2"><%= addon.description %></div>
            <span class="text-[12px] text-violet-700 font-semibold">+<%= addon.ai_credits_bonus %> AI Credits</span>
          </div>
          <div class="flex-shrink-0 text-right">
            <div class="text-[13px] font-semibold text-slate-600 mb-2"><%= addon.price_formatted %></div>
            <%= button_to checkout_addon_subscription_path(addon_config_id: addon.id), method: :post,
                  data: { turbo: false },
                  class: "px-3 py-1.5 bg-violet-600 hover:bg-violet-700 text-white text-[12px] font-bold rounded-lg cursor-pointer border-0 transition-colors" do %>
              <%= t("subscription.buy_now") %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
