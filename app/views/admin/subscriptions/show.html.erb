<% content_for :title, t("subscription.title") %>
<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[21px] font-extrabold text-slate-900"><%= t("subscription.title") %></h1>
</div>

<% if @subscription %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-6">
    <!-- AI Credits card -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <h3 class="text-[13px] font-bold text-slate-900 mb-3"><%= t("dashboard.ai_credits") %></h3>
      <div class="text-[28px] font-black text-slate-900 mb-1"><%= @subscription.credit_balance %></div>
      <div class="text-[12px] text-slate-500 mb-3"><%= t("subscription.remaining") %></div>
      <% if @subscription.max_ai_credits.to_i > 0 %>
        <div class="h-2 bg-slate-100 rounded-full overflow-hidden mb-3">
          <div class="h-2 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-full" style="width: <%= @subscription.credit_percentage %>%"></div>
        </div>
      <% end %>
      <div class="text-[11px] text-slate-400">
        <%= t("subscription.monthly_credits_info", count: Subscription.monthly_free_credits, date: @subscription.next_credit_reset_formatted) %>
      </div>
    </div>

    <!-- Info card -->
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <h3 class="text-[13px] font-bold text-slate-900 mb-3"><%= t("subscription.plan_info") %></h3>
      <div class="space-y-2 text-[13px] text-slate-600">
        <div class="flex justify-between"><span><%= t("kpi.surveys") %></span><span class="font-bold text-slate-900">&infin;</span></div>
        <div class="flex justify-between"><span><%= t("kpi.votes") %></span><span class="font-bold text-slate-900">&infin;</span></div>
        <div class="flex justify-between"><span><%= t("kpi.feedback") %></span><span class="font-bold text-slate-900">&infin;</span></div>
        <div class="flex justify-between"><span><%= t("dynamic_forms.nav") %></span><span class="font-bold text-slate-900">&infin;</span></div>
        <div class="flex justify-between"><span><%= t("members.title") %></span><span class="font-bold text-slate-900">&infin;</span></div>
      </div>
      <div class="mt-3 text-[11px] text-emerald-600 font-semibold"><%= t("subscription.all_features_free") %></div>
    </div>
  </div>

  <!-- AI Credits add-on packs -->
  <% if @addon_credits.any? %>
    <div class="mb-6">
      <h2 class="text-[16px] font-extrabold text-slate-900 mb-1"><%= t("subscription.buy_more_credits") %></h2>
      <p class="text-[12px] text-slate-400 mb-4"><%= t("subscription.buy_more_credits_desc") %></p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @addon_credits.each do |addon| %>
          <div class="bg-white rounded-[10px] border border-violet-200 shadow-sm p-4 flex items-center gap-4">
            <div class="flex-1 min-w-0">
              <div class="text-[14px] font-bold text-slate-900"><%= addon.name %></div>
              <div class="text-[11px] text-slate-400 mb-1"><%= addon.description %></div>
              <div class="text-[12px] font-semibold text-violet-600">+<%= addon.ai_credits_bonus %> AI Credits</div>
            </div>
            <div class="flex items-center gap-3 flex-shrink-0">
              <span class="text-[13px] font-semibold text-slate-600"><%= addon.price_formatted %></span>
              <%= button_to checkout_addon_subscription_path(addon_config_id: addon.id), method: :post,
                    data: { turbo: false },
                    class: "px-3 py-1.5 bg-violet-600 hover:bg-violet-700 text-white text-[12px] font-bold rounded-lg cursor-pointer border-0 whitespace-nowrap" do %>
                <%= t("subscription.buy_now") %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Payment history -->
  <% if @payments.any? %>
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-200">
        <h2 class="text-[14px] font-bold text-slate-900"><%= t("subscription.payment_history") %></h2>
      </div>
      <table class="w-full border-collapse">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("subscription.col_date") %></th>
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("subscription.col_description") %></th>
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("subscription.col_amount") %></th>
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5"><%= t("subscription.col_status") %></th>
          </tr>
        </thead>
        <tbody>
          <% @payments.each do |payment| %>
            <tr class="border-b border-slate-100">
              <td class="px-4 py-3 text-[12px] text-slate-500 whitespace-nowrap"><%= I18n.l(payment.created_at.to_date) %></td>
              <td class="px-4 py-3 text-[13px] text-slate-700"><%= payment.description_label %></td>
              <td class="px-4 py-3 text-[13px] font-semibold text-slate-900 whitespace-nowrap"><%= payment.amount_formatted %></td>
              <td class="px-4 py-3">
                <span class="px-2 py-0.5 text-[11px] font-semibold rounded-full <%= payment.completed? ? 'bg-emerald-50 text-emerald-700' : payment.failed? ? 'bg-red-50 text-red-600' : 'bg-amber-50 text-amber-700' %>">
                  <%= t("status.#{payment.status}", default: payment.status.capitalize) %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-12 text-slate-400"><%= t("subscription.no_subscription") %></div>
<% end %>
