<% content_for :title, "Subscription" %>
<h1 class="text-[21px] font-extrabold text-slate-900 mb-6">💳 Subscription</h1>

<% if @subscription %>
  <div class="grid grid-cols-3 gap-5 mb-6">
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5 col-span-2">
      <div class="flex items-center gap-3 mb-4">
        <div class="px-3 py-1 bg-indigo-600 text-white text-[13px] font-bold rounded-full"><%= @subscription.plan.capitalize %></div>
        <span class="text-[13px] text-slate-500">Valid until <%= @subscription.ends_at&.strftime("%b %d, %Y") || "—" %></span>
      </div>
      <div class="grid grid-cols-3 gap-4 text-center mb-5">
        <div class="bg-slate-50 rounded-lg p-3">
          <div class="text-[18px] font-bold text-slate-900"><%= @subscription.max_surveys || "∞" %></div>
          <div class="text-[11px] text-slate-500">Max Surveys</div>
        </div>
        <div class="bg-slate-50 rounded-lg p-3">
          <div class="text-[18px] font-bold text-slate-900"><%= @subscription.max_supporters || "∞" %></div>
          <div class="text-[11px] text-slate-500">Supporters</div>
        </div>
        <div class="bg-slate-50 rounded-lg p-3">
          <div class="text-[18px] font-bold text-slate-900"><%= @subscription.max_ai_credits || "∞" %></div>
          <div class="text-[11px] text-slate-500">AI Credits</div>
        </div>
      </div>
      <% if !@subscription.enterprise? %>
        <div class="flex gap-2">
          <% ["pro", "enterprise"].reject { |p| p == @subscription.plan }.each do |plan| %>
            <%= button_to upgrade_subscription_path, params: { plan: plan }, method: :post, class: "px-4 py-2 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700" do %>Upgrade to <%= plan.capitalize %><% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm p-5">
      <h3 class="text-[13px] font-bold text-slate-900 mb-3">🎯 AI Credits</h3>
      <div class="text-[28px] font-black text-slate-900 mb-1"><%= @subscription.credit_balance %></div>
      <div class="text-[12px] text-slate-500 mb-3">of <%= @subscription.max_ai_credits || "∞" %> remaining</div>
      <% if @subscription.max_ai_credits %>
        <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
          <div class="h-2 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-full" style="width: <%= @subscription.credit_percentage %>%"></div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Payment history -->
  <% if @payments.any? %>
    <div class="bg-white rounded-[10px] border border-slate-200 shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-200">
        <h2 class="text-[14px] font-bold text-slate-900">Payment History</h2>
      </div>
      <table class="w-full border-collapse">
        <thead>
          <tr class="bg-slate-50 border-b border-slate-200">
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Date</th>
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Amount</th>
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Gateway</th>
            <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Status</th>
          </tr>
        </thead>
        <tbody>
          <% @payments.each do |payment| %>
            <tr class="border-b border-slate-100">
              <td class="px-4 py-3 text-[12px] text-slate-500"><%= payment.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-4 py-3 text-[13px] font-semibold text-slate-900"><%= payment.amount_formatted %></td>
              <td class="px-4 py-3 text-[12px] text-slate-500"><%= payment.gateway.capitalize %></td>
              <td class="px-4 py-3">
                <span class="px-2 py-0.5 text-[11px] font-semibold rounded-full <%= payment.completed? ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700' %>">
                  <%= payment.status.capitalize %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% else %>
  <div class="text-center py-12 text-slate-400">No subscription found. Contact support.</div>
<% end %>
