<% content_for :title, t("dynamic_forms.new_title") %>

<div class="max-w-[680px]">

  <!-- Header -->
  <div class="flex items-start gap-3 mb-6">
    <%= render "admin/shared/back_btn" %>
    <div>
      <div class="flex items-center gap-2 text-[12px] text-slate-400 mb-1">
        <%= link_to t("dynamic_forms.nav"), dynamic_forms_path, class: "hover:text-indigo-600 transition-colors" %>
        <span>/</span>
        <span class="text-slate-600 font-medium"><%= t("dynamic_forms.new_step") %></span>
      </div>
      <h1 class="text-[22px] font-extrabold text-slate-900 tracking-tight">📝 <%= t("dynamic_forms.new_title") %></h1>
      <p class="text-[13px] text-slate-400 mt-0.5"><%= t("dynamic_forms.new_subtitle") %></p>
    </div>
  </div>

  <!-- Card -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">

    <!-- Card header -->
    <div class="px-6 py-4 border-b border-slate-100" style="background:linear-gradient(135deg,#f8faff,#f0f4ff);">
      <p class="text-[12px] font-semibold text-indigo-600 uppercase tracking-wide"><%= t("dynamic_forms.basic_info_section") %></p>
    </div>

    <!-- Form -->
    <div class="p-6">
      <%= form_with model: @form, url: dynamic_forms_path, method: :post, local: true, data: { turbo: false } do |f| %>

        <% if @form.errors.any? %>
          <div class="mb-4 px-4 py-3 rounded-xl text-[13px] text-red-700 font-medium"
               style="background:rgba(239,68,68,0.06); border:1px solid rgba(239,68,68,0.2);">
            <%= @form.errors.full_messages.first %>
          </div>
        <% end %>

        <div class="space-y-5">

          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">
              <%= t("dynamic_forms.form_name_label") %> <span class="text-red-500">*</span>
            </label>
            <%= f.text_field :title, required: true, autofocus: true,
                  class: "w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all",
                  placeholder: t("dynamic_forms.title_placeholder") %>
          </div>

          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("dynamic_forms.description_label") %></label>
            <%= f.text_area :description, rows: 3,
                  class: "w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-[13px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none transition-all",
                  placeholder: t("dynamic_forms.description_placeholder") %>
          </div>

          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">
              <%= t("dynamic_forms.slug_label") %>
              <span class="text-slate-400 font-normal"><%= t("dynamic_forms.slug_hint_label") %></span>
            </label>
            <%= f.text_field :slug,
                  class: "w-full px-3.5 py-2.5 border border-slate-200 rounded-xl text-[13px] font-mono focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all",
                  placeholder: t("dynamic_forms.slug_placeholder") %>
            <p class="text-[11px] text-slate-400 mt-1.5">
              <%= t("dynamic_forms.slug_hint", slug: "slug").html_safe %>
            </p>
          </div>

        </div>

        <!-- Actions -->
        <div class="flex items-center gap-3 pt-5 mt-5 border-t border-slate-100">
          <%= f.submit t("dynamic_forms.next_btn"),
                class: "px-5 py-2.5 text-white text-[13px] font-semibold rounded-xl cursor-pointer transition-all hover:opacity-90 hover:-translate-y-0.5 shadow-sm",
                style: "background:linear-gradient(135deg,#1e3a5f,#1e3a5f); box-shadow:0 2px 10px rgba(99,102,241,0.3);" %>
          <%= link_to t("dynamic_forms.cancel"), dynamic_forms_path,
                class: "px-5 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
        </div>

      <% end %>
    </div>
  </div>

</div>
