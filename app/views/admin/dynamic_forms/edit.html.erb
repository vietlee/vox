function renderOption(uid, oi, o) {
  return `<div class="flex gap-1.5 items-center" id="opt-${uid}-${oi}">
    <input type="text" value="${escHtml(o.label||'')}" placeholder="${DF_I18N.add_option_placeholder}"
      oninput="setOption(${uid},${oi},'label',this.value); setOption(${uid},${oi},'value',this.value)"
      class="flex-1 px-2.5 py-1.5 border border-slate-200 rounded-lg text-[11px] outline-none focus:border-indigo-400 bg-white">
    <button type="button" onclick="removeOption(${uid},${oi})" class="w-5 h-5 flex items-center justify-center text-red-400 hover:text-red-600 flex-shrink-0 text-[11px]">✕</button>
  </div>`;
}

function addField() {
  const uid = _uid++;
  _fields.push({ _uid:uid, id:0, label:'', field_key:'', field_type:'text', placeholder:'', hint:'', required:false, options:[], min_length:null, max_length:null, min_value:null, max_value:null, admin_only:false, admin_editable:false, conditional_logic:{} });
  markUnsaved();
  renderAll();
  setTimeout(() => document.getElementById(`field-${uid}`)?.scrollIntoView({ behavior:'smooth', block:'nearest' }), 50);
}

function removeField(uid) {
  _pendingDeleteUid = uid;
  document.getElementById('field-delete-modal').classList.remove('hidden');
}

let _pendingDeleteUid = null;
window._confirmDeleteField = function() {
  if (_pendingDeleteUid === null) return;
  _fields = _fields.filter(f => f._uid !== _pendingDeleteUid);
  _pendingDeleteUid = null;
  document.getElementById('field-delete-modal').classList.add('hidden');
  markUnsaved();
  renderAll();
};
window._cancelDeleteField = function() {
  _pendingDeleteUid = null;
  document.getElementById('field-delete-modal').classList.add('hidden');
};

function moveField(uid, dir) {
  const i = _fields.findIndex(f => f._uid === uid);
  const j = i + dir;
  if (j < 0 || j >= _fields.length) return;
  [_fields[i], _fields[j]] = [_fields[j], _fields[i]];
  renderAll();
  markUnsaved();
}

function setFieldProp(uid, prop, val) {
  markUnsaved();
  const f = _fields.find(f => f._uid === uid);
  if (!f) return;
  if (prop === 'required') val = !!val;
  f[prop] = val;
  if (prop === 'label') {
    const auto = slugify(val);
    const keyEl = document.querySelector(`#field-${uid} input[oninput*="field_key"]`);
    if (keyEl && (!f.field_key || f._autoKey)) { f.field_key = auto; f._autoKey = true; keyEl.value = auto; }
  }
  if (prop === 'field_key') f._autoKey = false;
  if (prop === 'admin_only' || prop === 'admin_editable') { renderAll(); return; }
  if (prop === 'field_type') {
    if (val === 'file' && f.multiple == null) f.multiple = true;
    renderAll();
    if (['select','radio','checkboxes'].includes(val)) {
      setTimeout(() => {
        document.getElementById(`opts-${uid}`)
          ?.closest('div[style*="background:#f0f4ff"]')
          ?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }, 80);
    }
  }
}

function addOption(uid) {
  const f = _fields.find(f => f._uid === uid);
  if (!f) return;
  const oi = (f.options||[]).length;
  f.options = [...(f.options||[]), { label:'', value:'' }];
  const container = document.getElementById(`opts-${uid}`);
  const div = document.createElement('div');
  div.innerHTML = renderOption(uid, oi, f.options[oi]);
  container.appendChild(div.firstElementChild);
  markUnsaved();
}

function setOption(uid, oi, prop, val) {
  const f = _fields.find(f => f._uid === uid);
  if (!f || !f.options[oi]) return;
  f.options[oi][prop] = val;
  markUnsaved();
}

function removeOption(uid, oi) {
  const f = _fields.find(f => f._uid === uid);
  if (!f) return;
  f.options.splice(oi, 1);
  renderAll();
  markUnsaved();
}

function submitForm() {
  syncFieldsData();
  // Hide bar immediately so it doesn't flash on redirect
  const bar = document.getElementById('save-bar');
  if (bar) bar.style.display = 'none';
  document.getElementById('form-meta').submit();
}

function markUnsaved() {
  const bar = document.getElementById('save-bar');
  const spacer = document.getElementById('save-bar-spacer');
  if (bar && bar.style.display === 'none') {
    bar.style.display = 'flex';
    if (spacer) spacer.style.height = '64px';
  }
}

function syncFieldsData() {
  const data = _fields.map(f => ({
    id: f.id||0, label: f.label, field_key: f.field_key, field_type: f.field_type,
    placeholder: f.placeholder, hint: f.hint, required: f.required,
    options: (f.options||[]).map(o => ({ label:o.label, value:o.value })).filter(o=>o.label),
    min_length: f.min_length||null, max_length: f.max_length||null,
    min_value: f.min_value||null, max_value: f.max_value||null,
    accept: f.accept||null, max_size_mb: f.max_size_mb||null, multiple: !!f.multiple,
    admin_only: !!f.admin_only,
    admin_editable: !!f.admin_editable,
    conditional_logic: f.conditional_logic || {},
  }));
  document.getElementById('fields-data-input').value = JSON.stringify(data);
  syncSettingsData();
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── Assignee dropdown ────────────────────────────────────────────────────────
(function() {
  function renderTrigger() {
    const checked = Array.from(document.querySelectorAll('#assignee-hidden-inputs input:checked'));
    const content = document.getElementById('assignee-trigger-content');
    if (!content) return;
    if (checked.length === 0) {
      content.innerHTML = `<span class="text-[12px] text-slate-400">${DF_I18N.select_manager}</span>`;
    } else {
      content.innerHTML = checked.map(cb => {
        const name = cb.dataset.memberName || cb.value;
        return `<span class="inline-flex items-center gap-1 px-2 py-0.5 bg-indigo-50 text-indigo-700 text-[11px] font-semibold rounded-full">
          ${escHtml(name)}
          <button type="button" onclick="event.stopPropagation();toggleAssignee(${cb.value})"
            class="w-3.5 h-3.5 flex items-center justify-center rounded-full hover:bg-indigo-200 text-indigo-500 border-0 bg-transparent cursor-pointer leading-none">✕</button>
        </span>`;
      }).join('');
    }
  }

  window.toggleAssigneeDropdown = function() {
    const panel   = document.getElementById('assignee-panel');
    const chevron = document.getElementById('assignee-chevron');
    const isOpen  = !panel.classList.contains('hidden');
    if (isOpen) {
      panel.classList.add('hidden');
      chevron.style.transform = '';
    } else {
      panel.classList.remove('hidden');
      chevron.style.transform = 'rotate(180deg)';
      document.getElementById('assignee-search')?.focus();
    }
  };

  window.toggleAssignee = function(id) {
    const cb   = document.getElementById('assignee-cb-' + id);
    const box  = document.getElementById('assignee-check-' + id);
    const tick = document.getElementById('assignee-tick-' + id);
    if (!cb) return;
    cb.checked = !cb.checked;
    if (cb.checked) {
      box.classList.add('bg-indigo-600','border-indigo-600');
      box.classList.remove('border-slate-300','bg-white');
      tick.classList.remove('hidden');
    } else {
      box.classList.remove('bg-indigo-600','border-indigo-600');
      box.classList.add('border-slate-300','bg-white');
      tick.classList.add('hidden');
    }
    renderTrigger();
    markUnsaved();
  };

  window.filterAssignees = function(q) {
    const query = q.toLowerCase();
    document.querySelectorAll('.assignee-item').forEach(el => {
      const match = el.dataset.name.includes(query) || el.dataset.email.includes(query);
      el.style.display = match ? '' : 'none';
    });
  };

  // Close on outside click
  document.addEventListener('click', function(e) {
    const wrap = document.getElementById('assignee-dropdown-wrap');
    if (wrap && !wrap.contains(e.target)) {
      document.getElementById('assignee-panel')?.classList.add('hidden');
      const chevron = document.getElementById('assignee-chevron');
      if (chevron) chevron.style.transform = '';
    }
  });

  // Run immediately when script evaluates
  renderTrigger();
})();

// ── Conditional logic helpers ──────────────────────────────────────────────────
function toggleCondition(uid, enabled) {
  const f = _fields.find(f => f._uid === uid);
  if (!f) return;
  f.conditional_logic = { ...(f.conditional_logic||{}), enabled };
  const panel = document.getElementById(`cond-panel-${uid}`);
  if (panel) panel.classList.toggle('hidden', !enabled);
  markUnsaved();
}
function setConditionProp(uid, prop, val) {
  const f = _fields.find(f => f._uid === uid);
  if (!f) return;
  f.conditional_logic = { ...(f.conditional_logic||{}), [prop]: val };
  markUnsaved();
}

// ── Settings ──────────────────────────────────────────────────────────────────
let _settings = Object.assign(
  { custom_statuses: [], notify_assignee: false, notification_user_ids: [] },
  INITIAL_SETTINGS
);

function syncSettingsData() {
  const toSave = {
    ..._settings,
    custom_statuses:      (_settings.custom_statuses||[]).filter(s => s.trim() !== ''),
    notification_user_ids: (_settings.notification_user_ids||[]).map(Number).filter(Boolean),
  };
  document.getElementById('settings-data-input').value = JSON.stringify(toSave);
}

// Custom statuses
window.updateCustomStatus = function(i, val) { _settings.custom_statuses[i] = val; markUnsaved(); };
let _statusSortable = null;
function renderCustomStatuses() {
  const list = document.getElementById('custom-statuses-list');
  if (!list) return;
  list.innerHTML = (_settings.custom_statuses||[]).map((s, i) => `
    <div class="status-item flex gap-1.5 items-center" data-idx="${i}">
      <span class="status-drag-handle flex-shrink-0 cursor-grab active:cursor-grabbing text-slate-300 hover:text-slate-500 select-none text-base leading-none px-0.5" title="Kéo để sắp xếp">⠿</span>
      <input type="text" value="${escHtml(s)}" placeholder="Tên trạng thái..."
        oninput="updateCustomStatus(${i}, this.value)"
        class="flex-1 px-2.5 py-1.5 border border-slate-200 rounded-lg text-[11px] outline-none focus:border-indigo-400 bg-white">
      <button type="button" onclick="removeCustomStatus(${i})"
        class="w-5 h-5 flex items-center justify-center text-red-400 hover:text-red-600 text-[11px] flex-shrink-0">✕</button>
    </div>`).join('');

  // Init SortableJS on the statuses list
  if (_statusSortable) { try { _statusSortable.destroy(); } catch(e) {} }
  if (typeof Sortable !== 'undefined' && list.children.length > 1) {
    _statusSortable = Sortable.create(list, {
      handle: '.status-drag-handle',
      animation: 120,
      ghostClass: 'opacity-40',
      onEnd() {
        const newOrder = Array.from(list.querySelectorAll('.status-item')).map(el => {
          const idx = parseInt(el.dataset.idx);
          return _settings.custom_statuses[idx];
        });
        _settings.custom_statuses = newOrder;
        markUnsaved();
        renderCustomStatuses(); // re-render to sync indices
      }
    });
  }
}
window.addCustomStatus = function() {
  _settings.custom_statuses = [...(_settings.custom_statuses||[]), ''];
  renderCustomStatuses(); markUnsaved();
};
window.removeCustomStatus = function(i) {
  _settings.custom_statuses.splice(i, 1);
  renderCustomStatuses(); markUnsaved();
};

// Notify assignee toggle
function renderNotifyToggle() {
  const btn = document.getElementById('notify-assignee-toggle');
  if (!btn) return;
  const on = !!_settings.notify_assignee;
  btn.textContent = on ? 'Bật' : 'Tắt';
  btn.className = on
    ? 'px-3 py-1 rounded-full text-[11px] font-bold border-0 cursor-pointer transition-colors bg-emerald-100 text-emerald-700'
    : 'px-3 py-1 rounded-full text-[11px] font-bold border-0 cursor-pointer transition-colors bg-slate-100 text-slate-500';
}
window.toggleNotifyAssignee = function() {
  _settings.notify_assignee = !_settings.notify_assignee;
  renderNotifyToggle(); markUnsaved();
};

// Notification user IDs (checkboxes rendered in ERB, JS just tracks the array)
window.toggleNotificationUser = function(userId, checked) {
  let ids = _settings.notification_user_ids || [];
  if (checked) {
    if (!ids.includes(userId)) ids = [...ids, userId];
  } else {
    ids = ids.filter(id => Number(id) !== Number(userId));
  }
  _settings.notification_user_ids = ids;
  markUnsaved();
};

// Sync checkboxes state from INITIAL_SETTINGS on load
(function() {
  const ids = (_settings.notification_user_ids||[]).map(Number);
  document.querySelectorAll('[id^="notif-user-"]').forEach(cb => {
    const uid = parseInt(cb.dataset.userId);
    cb.checked = ids.includes(uid);
  });
})();

// Init settings UI
(function() {
  renderCustomStatuses();
  renderNotifyToggle();
  syncSettingsData();
})();

// Expose functions used from inline onclick= attributes
Object.assign(window, { syncFieldsData, addField, removeField, moveField, setFieldProp, addOption, removeOption, setOption, submitForm, markUnsaved, renderAll, toggleCondition, setConditionProp });

})(); // end outer IIFE — prevents Turbo redeclaration errors

// ── Floating "Add field" button ───────────────────────────────────────────────
// Hiện khi nút gốc cuộn ra khỏi viewport; ẩn khi không có trường nào (empty state đang show)
(function() {
  const mainBtn  = document.getElementById('add-field-btn-main');
  const floatWrap = document.getElementById('add-field-btn-float-wrap');
  if (!mainBtn || !floatWrap) return;

  function updateFloat(mainVisible) {
    const hasFields = document.querySelectorAll('#fields-container > *').length > 0;
    const show = !mainVisible && hasFields;
    floatWrap.style.opacity        = show ? '1' : '0';
    floatWrap.style.transform      = show ? 'translateY(0)' : 'translateY(6px)';
    floatWrap.style.pointerEvents  = show ? 'none' : 'none'; // wrapper is always none; button inside handles clicks
  }

  const observer = new IntersectionObserver(
    ([entry]) => updateFloat(entry.isIntersecting),
    { threshold: 0, rootMargin: '-10px 0px 0px 0px' }
  );
  observer.observe(mainBtn);

  window._updateFloatBtn = () => {
    const r = mainBtn.getBoundingClientRect();
    updateFloat(r.top >= 0 && r.bottom <= window.innerHeight);
  };
})();
</script>
