<% content_for :title, @form.title %>
<% content_for :main_class, "flex-1 overflow-y-auto" %>
<meta name="turbo-cache-control" content="no-cache">

<!-- Sticky header — flush with scroll container top, full width -->
<div style="position:sticky; top:0; z-index:50; background:#f1f5f9;
            border-bottom:1px solid #e2e8f0;
            box-shadow:0 2px 8px rgba(0,0,0,0.06);">
  <div class="px-6 py-3.5 flex items-center justify-between gap-3 flex-wrap">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <div class="flex items-center gap-2 text-[12px] text-slate-400 mb-1">
          <%= link_to t("dynamic_forms.nav"), dynamic_forms_path, class: "hover:text-indigo-600 transition-colors" %>
          <span>/</span>
          <span class="text-slate-600 font-medium truncate max-w-[240px]"><%= @form.title %></span>
        </div>
        <h1 class="text-[22px] font-extrabold text-slate-900">📝 <%= @form.title %></h1>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to submissions_dynamic_form_path(@form),
            class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-[12px] font-semibold bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 shadow-sm transition-colors" do %>
        📬 <%= t("dynamic_forms.submissions_btn", count: @form.submissions_count) %>
      <% end %>
      <%= link_to participate_dynamic_form_url(@form.slug), target: "_blank",
            class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-[12px] font-semibold bg-white border border-slate-200 text-slate-700 hover:bg-slate-50 shadow-sm transition-colors" do %>
        🔗 <%= t("dynamic_forms.view_form_btn") %>
      <% end %>
      <% if @form.draft? %>
        <%= button_to publish_dynamic_form_path(@form), method: :patch,
              class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-[12px] font-semibold bg-emerald-500 hover:bg-emerald-600 text-white shadow-sm transition-colors" do %>
          🚀 <%= t("dynamic_forms.publish_btn") %>
        <% end %>
      <% elsif @form.active? %>
        <%= button_to close_dynamic_form_path(@form), method: :patch,
              class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-[12px] font-semibold bg-white border border-slate-200 text-slate-700 hover:bg-red-50 hover:text-red-600 hover:border-red-200 shadow-sm transition-colors" do %>
          🔒 <%= t("dynamic_forms.close_btn") %>
        <% end %>
      <% elsif @form.closed? %>
        <%= button_to reopen_dynamic_form_path(@form), method: :patch,
              class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-[12px] font-semibold bg-white border border-emerald-200 text-emerald-700 hover:bg-emerald-50 shadow-sm transition-colors" do %>
          ✅ <%= t("dynamic_forms.reopen_btn") %>
        <% end %>
      <% end %>
      <% if @form.deletable? %>
        <%= button_to dynamic_form_path(@form), method: :delete,
              data: { confirm: t("dynamic_forms.delete_confirm", title: @form.title) },
              class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-[12px] font-semibold bg-white border border-red-200 text-red-500 hover:bg-red-50 shadow-sm transition-colors" do %>
          🗑 <%= t("dynamic_forms.delete_btn") %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<div class="px-6 pt-5 pb-24">
  <div class="grid grid-cols-[1fr_280px] gap-5 items-start">

    <!-- Left: Form info + Field Builder -->
    <div class="space-y-4">

      <!-- Basic info card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <h2 class="text-[13px] font-bold text-slate-500 uppercase tracking-wider mb-4"><%= t("dynamic_forms.general_info") %></h2>
        <%= form_with model: @form, url: dynamic_form_path(@form), method: :patch, local: true, multipart: true, data: { turbo: false }, id: "form-meta" do |f| %>
          <div class="space-y-3">
            <%= render "admin/dynamic_forms/logo_upload" %>
            <div>
              <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("dynamic_forms.form_name_label") %> <span class="text-red-500">*</span></label>
              <%= f.text_field :title, required: true,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all" %>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("dynamic_forms.description_label") %></label>
              <%= f.text_area :description, rows: 2,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none transition-all" %>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("dynamic_forms.slug_label") %></label>
              <%= f.text_field :slug,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] font-mono focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none transition-all" %>
            </div>
            <input type="hidden" name="fields_data" id="fields-data-input">
            <input type="hidden" name="settings_data" id="settings-data-input">
            <div class="pt-3 border-t border-slate-100 flex justify-end">
              <button type="submit" onclick="syncFieldsData()"
                class="inline-flex items-center gap-1.5 px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-[12px] font-semibold rounded-lg cursor-pointer transition-colors shadow-sm border-0">
                💾 <%= t("dynamic_forms.save_info_btn") %>
              </button>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Field Builder card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-[13px] font-bold text-slate-500 uppercase tracking-wider">
            <%= t("dynamic_forms.fields_section") %> &nbsp;<span class="text-indigo-600 font-bold" id="field-count">0</span>
          </h2>
          <button type="button" id="add-field-btn-main" onclick="addField()"
            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-500 hover:bg-blue-600 text-white text-[12px] font-semibold rounded-lg transition-colors">
            <%= t("dynamic_forms.add_field_btn") %>
          </button>
        </div>

        <div id="fields-container" class="space-y-3"></div>

        <div id="fields-empty" class="text-center py-10 text-slate-400 hidden">
          <div class="text-3xl mb-2">📋</div>
          <p class="text-[13px]"><%= t("dynamic_forms.no_fields_hint") %></p>
        </div>

        <!-- Sticky "Add field" — hiện khi scroll qua nút gốc và có ít nhất 1 trường -->
        <div id="add-field-btn-float-wrap"
             style="position:sticky; bottom:64px; z-index:30; pointer-events:none;
                    opacity:0; transform:translateY(6px);
                    transition: opacity 0.2s ease, transform 0.2s ease;
                    display:flex; justify-content:flex-end; margin-top:16px;">
          <button type="button" id="add-field-btn-float" onclick="addField()"
            style="pointer-events:auto;
                   background:linear-gradient(135deg,#3b82f6,#2563eb);
                   box-shadow:0 4px 16px rgba(37,99,235,0.3);"
            class="inline-flex items-center gap-2 px-4 py-2.5 text-white text-[13px] font-semibold rounded-xl border-0 cursor-pointer">
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            <%= t("dynamic_forms.add_field_btn") %>
          </button>
        </div>
      </div>
    </div>

    <!-- Right: Share + QR -->
    <div class="space-y-4">
      <!-- Share card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-3">🔗 <%= t("dynamic_forms.share_section") %></h2>
        <p class="text-[11px] text-slate-400 mb-2"><%= t("dynamic_forms.public_link") %></p>
        <div class="flex gap-1.5 mb-1">
          <input id="form-link" readonly value="<%= participate_dynamic_form_url(@form.slug) %>"
            class="flex-1 px-2.5 py-2 bg-slate-50 border border-slate-200 rounded-lg text-[11px] font-mono text-slate-600 min-w-0 truncate">
          <button onclick="navigator.clipboard.writeText(document.getElementById('form-link').value);this.textContent='✓';this.classList.add('bg-emerald-600');setTimeout(()=>{this.textContent='Copy';this.classList.remove('bg-emerald-600')},2000)"
            class="px-3 py-2 bg-blue-500 hover:bg-blue-600 text-white text-[11px] font-semibold rounded-lg transition-colors cursor-pointer flex-shrink-0"><%= t("dynamic_forms.copy_btn") %></button>
        </div>
      </div>

      <!-- QR card -->
      <% if @form.qr_code %>
        <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
          <h2 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("dynamic_forms.qr_title") %></h2>
          <p class="text-[11px] text-slate-400 mb-3"><%= t("dynamic_forms.qr_hint") %></p>
          <div class="flex justify-center mb-3">
            <div class="inline-block p-3 bg-white border-2 border-slate-100 rounded-xl shadow-sm">
              <img src="<%= qr_image_path(@form.qr_code.token) %>" alt="QR Code" class="w-40 h-40">
            </div>
          </div>
          <p class="text-[11px] text-slate-400 text-center mb-3">
            <%= t("dynamic_forms.qr_scanned", count: @form.qr_code.scan_count) %>
          </p>
          <a href="<%= qr_image_path(@form.qr_code.token) %>" download="qr-<%= @form.slug %>.png"
            class="flex items-center justify-center gap-1.5 px-3 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[12px] font-semibold rounded-lg transition-colors">
            ⬇ <%= t("dynamic_forms.qr_download") %>
          </a>
        </div>
      <% end %>

      <!-- Assignees card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-1">👥 <%= t("dynamic_forms.managers_section") %></h2>
        <p class="text-[11px] text-slate-400 mb-3"><%= t("dynamic_forms.managers_hint") %></p>

        <% if @members.any? %>
          <!-- Hidden checkboxes (bound to form-meta) -->
          <div id="assignee-hidden-inputs" style="display:none;">
            <% @members.each do |member| %>
              <input type="checkbox"
                     name="assignee_ids[]"
                     value="<%= member.id %>"
                     form="form-meta"
                     id="assignee-cb-<%= member.id %>"
                     data-member-name="<%= member.name.presence || member.email %>"
                     <%= @assignee_ids.include?(member.id) ? 'checked' : '' %>>
            <% end %>
          </div>

          <!-- Dropdown trigger -->
          <div class="relative" id="assignee-dropdown-wrap">
            <button type="button" id="assignee-trigger" onclick="toggleAssigneeDropdown()"
              class="w-full flex items-center justify-between gap-2 px-3 py-2.5 rounded-lg border border-slate-200 bg-white hover:border-indigo-300 transition-colors text-left"
              style="min-height:40px;">
              <div id="assignee-trigger-content" class="flex-1 flex flex-wrap gap-1 min-w-0">
                <!-- Populated by JS -->
              </div>
              <svg class="w-4 h-4 text-slate-400 flex-shrink-0 transition-transform" id="assignee-chevron"
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>

            <!-- Dropdown panel -->
            <div id="assignee-panel"
                 class="hidden absolute left-0 right-0 top-full mt-1 bg-white border border-slate-200 rounded-xl shadow-lg z-20 overflow-hidden">
              <!-- Search -->
              <div class="px-3 pt-3 pb-2">
                <input type="text" id="assignee-search" placeholder="<%= j t("dynamic_forms.search_member") %>"
                  oninput="filterAssignees(this.value)"
                  class="w-full px-2.5 py-1.5 border border-slate-200 rounded-lg text-[12px] outline-none focus:border-indigo-400 bg-slate-50">
              </div>
              <div id="assignee-list" class="max-h-48 overflow-y-auto pb-2">
                <% @members.each do |member| %>
                  <label class="assignee-item flex items-center gap-2.5 px-3 py-2 hover:bg-indigo-50 cursor-pointer transition-colors"
                         data-name="<%= (member.name.presence || member.email).downcase %>"
                         data-email="<%= member.email.downcase %>"
                         onclick="toggleAssignee(<%= member.id %>); event.preventDefault();">
                    <div id="assignee-check-<%= member.id %>"
                         class="w-4 h-4 rounded border-2 flex items-center justify-center flex-shrink-0 transition-all <%= @assignee_ids.include?(member.id) ? 'bg-indigo-600 border-indigo-600' : 'border-slate-300 bg-white' %>">
                      <svg class="w-2.5 h-2.5 text-white <%= @assignee_ids.include?(member.id) ? '' : 'hidden' %>"
                           id="assignee-tick-<%= member.id %>"
                           fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                      </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                      <p class="text-[12px] font-semibold text-slate-700 truncate"><%= member.name.presence || member.email %></p>
                      <% if member.name.present? %>
                        <p class="text-[10px] text-slate-400 truncate"><%= member.email %></p>
                      <% end %>
                    </div>
                  </label>
                <% end %>
              </div>
            </div>
          </div>

          <p class="text-[10px] text-slate-400 mt-2"><%= t("dynamic_forms.save_reminder").html_safe %></p>
        <% else %>
          <p class="text-[12px] text-slate-400 italic"><%= t("dynamic_forms.no_members") %></p>
        <% end %>
      </div>

      <!-- Settings card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-4">⚙️ Cài đặt form</h2>

        <!-- Custom statuses -->
        <div class="mb-4">
          <label class="block text-[11px] font-bold text-slate-600 uppercase tracking-wide mb-0.5">Trạng thái submission</label>
          <p class="text-[10px] text-slate-400 mb-1">Tùy chỉnh danh sách. Để trống = dùng mặc định.</p>
          <p class="text-[10px] text-amber-600 font-medium mb-2">⭐ Trạng thái đầu tiên là giá trị mặc định cho submission mới. Kéo thả để sắp xếp.</p>
          <div id="custom-statuses-list" class="space-y-1.5 mb-2"></div>
          <button type="button" onclick="addCustomStatus()"
            class="inline-flex items-center gap-1 px-2.5 py-1 text-[11px] font-semibold text-indigo-600 bg-indigo-50 hover:bg-indigo-100 rounded-lg border-0 cursor-pointer transition-colors">
            + Thêm trạng thái
          </button>
        </div>

        <div class="border-t border-slate-100 pt-4 mb-4">
          <div class="flex items-start justify-between gap-2">
            <div>
              <span class="text-[11px] font-bold text-slate-600">Thông báo người xử lý</span>
              <p class="text-[10px] text-slate-400 mt-0.5">Hỏi gửi email khi assign người mới</p>
            </div>
            <button id="notify-assignee-toggle" type="button" onclick="toggleNotifyAssignee()"
              class="px-3 py-1 rounded-full text-[11px] font-bold border-0 cursor-pointer transition-colors flex-shrink-0 bg-slate-100 text-slate-500">
              Tắt
            </button>
          </div>
        </div>

        <div class="border-t border-slate-100 pt-4">
          <label class="block text-[11px] font-bold text-slate-600 uppercase tracking-wide mb-0.5">Nhận thông báo submission mới</label>
          <p class="text-[10px] text-slate-400 mb-2">Chọn người nhận email khi có phản hồi mới. Nếu để trống, gửi đến admin của workspace.</p>
          <% if @form_assignees.any? %>
            <div class="space-y-0.5">
              <% @form_assignees.each do |user| %>
                <% uname = user.name.presence || user.email %>
                <label class="flex items-center gap-2.5 cursor-pointer py-1.5 px-2 rounded-lg hover:bg-slate-50 transition-colors">
                  <input type="checkbox"
                         id="notif-user-<%= user.id %>"
                         data-user-id="<%= user.id %>"
                         onchange="toggleNotificationUser(<%= user.id %>, this.checked)"
                         class="w-3.5 h-3.5 accent-indigo-600 flex-shrink-0"
                         <%= @notification_user_ids.include?(user.id) ? 'checked' : '' %>>
                  <div class="min-w-0">
                    <p class="text-[12px] font-semibold text-slate-700 truncate"><%= uname %></p>
                    <% if user.name.present? %>
                      <p class="text-[10px] text-slate-400 truncate"><%= user.email %></p>
                    <% end %>
                  </div>
                </label>
              <% end %>
            </div>
          <% else %>
            <p class="text-[11px] text-slate-400 italic">Chưa có người quản lý nào. Hãy thêm ở mục "Người quản lý" trước.</p>
          <% end %>
        </div>
      </div>

      <!-- Status card -->
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("dynamic_forms.status_section") %></h2>
        <dl class="space-y-2 text-[12px]">
          <div class="flex justify-between">
            <dt class="text-slate-400"><%= t("dynamic_forms.status_label") %></dt>
            <dd class="font-semibold <%= @form.draft? ? 'text-slate-500' : @form.active? ? 'text-emerald-600' : 'text-amber-600' %>">
              <%= @form.draft? ? t("dynamic_forms.status_draft") : @form.active? ? t("dynamic_forms.status_active") : t("dynamic_forms.status_closed") %>
            </dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-slate-400"><%= t("dynamic_forms.submissions_title") %></dt>
            <dd class="font-semibold text-slate-700"><%= @form.submissions_count %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-slate-400"><%= t("dynamic_forms.created_at_label") %></dt>
            <dd class="text-slate-500"><%= I18n.l(@form.created_at, format: :short) %></dd>
          </div>
        </dl>
      </div>
    </div>

  </div>
</div>


<!-- Field delete confirm modal -->
<div id="field-delete-modal" class="hidden fixed inset-0 z-50"
     onclick="if(event.target===this) _cancelDeleteField()">
  <div class="absolute inset-0 flex items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-2xl shadow-2xl w-[360px] max-w-full mx-4 p-6" onclick="event.stopPropagation()">
      <div class="w-10 h-10 rounded-full flex items-center justify-center mx-auto mb-3 text-xl" style="background:#fee2e2;">🗑️</div>
      <h3 class="text-[16px] font-bold text-slate-900 text-center mb-1"><%= t("dynamic_forms.delete_field_title") %></h3>
      <p class="text-[13px] text-slate-500 text-center mb-5"><%= t("dynamic_forms.delete_field_hint").html_safe %></p>
      <div class="flex gap-3">
        <button onclick="_cancelDeleteField()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold bg-slate-100 hover:bg-slate-200 text-slate-600 border-0 cursor-pointer transition-colors">
          <%= t("dynamic_forms.cancel") %>
        </button>
        <button onclick="_confirmDeleteField()"
          class="flex-1 py-2.5 rounded-xl text-[13px] font-semibold text-white border-0 cursor-pointer transition-colors"
          style="background:#ef4444;" onmouseenter="this.style.background='#dc2626'" onmouseleave="this.style.background='#ef4444'">
          <%= t("dynamic_forms.delete_field_confirm_btn") %>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .sortable-ghost  { opacity: 0.4; background: #eef2ff; border: 2px dashed #6366f1 !important; border-radius: 12px; }
  .sortable-chosen { box-shadow: 0 8px 24px rgba(99,102,241,0.2) !important; }
  .sortable-drag   { opacity: 0.95; }
</style>

<!-- Sticky save bar — hidden until there are unsaved changes -->
<div id="save-bar"
     class="flex items-center justify-between gap-3 px-6 py-2.5"
     style="display:none; position:fixed; bottom:0; left:0; right:0; z-index:100;
            background:#fffbeb; border-top:1px solid #fcd34d;
            box-shadow:0 -2px 12px rgba(251,191,36,0.2);">
  <div class="flex items-center gap-2">
    <span class="text-amber-500 text-[16px] flex-shrink-0">⚠</span>
    <p class="text-[13px] font-medium text-amber-800"><%= t("dynamic_forms.unsaved_warning") %></p>
  </div>
  <button type="button" onclick="submitForm()"
    class="inline-flex items-center gap-1.5 px-4 py-2 bg-amber-500 hover:bg-amber-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer transition-colors flex-shrink-0 border-0">
    💾 <%= t("dynamic_forms.save_all_btn") %>
  </button>
</div>
<div id="save-bar-spacer" style="height:0;"></div>

<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.3/Sortable.min.js" data-turbo-track="false"></script>
<script>
(function() {
const DF_I18N = {
  field_types: {
    text:       "<%= j t("dynamic_forms.field_types.text") %>",
    textarea:   "<%= j t("dynamic_forms.field_types.textarea") %>",
    email:      "<%= j t("dynamic_forms.field_types.email") %>",
    number:     "<%= j t("dynamic_forms.field_types.number") %>",
    phone:      "<%= j t("dynamic_forms.field_types.phone") %>",
    url:        "<%= j t("dynamic_forms.field_types.url") %>",
    date:       "<%= j t("dynamic_forms.field_types.date") %>",
    select:     "<%= j t("dynamic_forms.field_types.select") %>",
    radio:      "<%= j t("dynamic_forms.field_types.radio") %>",
    checkboxes: "<%= j t("dynamic_forms.field_types.checkboxes") %>",
    file:       "<%= j t("dynamic_forms.field_types.file") %>"
  },
  drag_title:            "<%= j t("dynamic_forms.js.drag_title") %>",
  label_placeholder:     "<%= j t("dynamic_forms.js.label_placeholder") %>",
  placeholder_ph:        "<%= j t("dynamic_forms.js.placeholder_placeholder") %>",
  hint_placeholder:      "<%= j t("dynamic_forms.js.hint_placeholder") %>",
  delete_field_title:    "<%= j t("dynamic_forms.js.delete_field_title") %>",
  add_option_placeholder:"<%= j t("dynamic_forms.js.add_option_placeholder") %>",
  options_empty_hint:    "<%= j t("dynamic_forms.js.options_empty_hint") %>",
  add_option_btn:        "<%= j t("dynamic_forms.js.add_option_btn") %>",
  options_section:       "<%= j t("dynamic_forms.js.options_section") %>",
  select_manager:        "<%= j t("dynamic_forms.js.select_manager") %>"
};
const INITIAL_FIELDS = <%= @form.dynamic_form_fields.map { |f|
  { id: f.id, label: f.label, field_key: f.field_key, field_type: f.field_type,
    placeholder: f.placeholder.to_s, hint: f.hint.to_s, required: f.required,
    options: f.options_list, min_length: f.min_length, max_length: f.max_length,
    min_value: f.min_value, max_value: f.max_value,
    accept: f.accept, max_size_mb: f.max_size_mb, multiple: f.multiple,
    conditional_logic: f.conditional_logic || {},
    admin_only: f.admin_only,
    admin_editable: f.admin_editable }
}.to_json.html_safe %>;
const INITIAL_SETTINGS = <%= @form.settings.to_json.html_safe %>;

// Vietnamese → ASCII transliteration for field key auto-generation
function slugify(str) {
  const map = {
    'à':'a','á':'a','ả':'a','ã':'a','ạ':'a','ă':'a','ằ':'a','ắ':'a','ẳ':'a','ẵ':'a','ặ':'a',
    'â':'a','ầ':'a','ấ':'a','ẩ':'a','ẫ':'a','ậ':'a','è':'e','é':'e','ẻ':'e','ẽ':'e','ẹ':'e',
    'ê':'e','ề':'e','ế':'e','ể':'e','ễ':'e','ệ':'e','ì':'i','í':'i','ỉ':'i','ĩ':'i','ị':'i',
    'ò':'o','ó':'o','ỏ':'o','õ':'o','ọ':'o','ô':'o','ồ':'o','ố':'o','ổ':'o','ỗ':'o','ộ':'o',
    'ơ':'o','ờ':'o','ớ':'o','ở':'o','ỡ':'o','ợ':'o','ù':'u','ú':'u','ủ':'u','ũ':'u','ụ':'u',
    'ư':'u','ừ':'u','ứ':'u','ử':'u','ữ':'u','ự':'u','ỳ':'y','ý':'y','ỷ':'y','ỹ':'y','ỵ':'y',
    'đ':'d'
  };
  return str.toLowerCase()
    .replace(/./g, c => map[c] || c)
    .replace(/\s+/g, '_')
    .replace(/[^a-z0-9_]/g, '')
    .replace(/_+/g, '_')
    .replace(/^_|_$/g, '');
}

const FIELD_TYPES = Object.entries(DF_I18N.field_types).map(([v, l]) => ({ value: v, label: l }));

let _fields = [];
let _uid = 1;
let _sortable = null;

function initFieldBuilder() {
  _uid = 1;
  _fields = INITIAL_FIELDS.map(f => ({ ...f, _uid: _uid++ }));
  if (_sortable) { _sortable.destroy(); _sortable = null; }
  renderAll();
}

// Run immediately; if Sortable CDN not ready yet, retry after it loads
if (typeof Sortable !== 'undefined') {
  initFieldBuilder();
} else {
  // CDN may still be loading (e.g. first Turbo navigation) — wait for it
  const _sortableScript = document.querySelector('script[src*="sortablejs"]');
  if (_sortableScript) {
    _sortableScript.addEventListener('load', initFieldBuilder, { once: true });
  } else {
    setTimeout(initFieldBuilder, 100);
  }
}

// Clear rendered fields before Turbo caches the page so cache doesn't show stale JS-rendered content
document.addEventListener('turbo:before-cache', function() {
  const container = document.getElementById('fields-container');
  if (container) container.innerHTML = '';
  const count = document.getElementById('field-count');
  if (count) count.textContent = '0';
  const empty = document.getElementById('fields-empty');
  if (empty) empty.classList.remove('hidden');
  if (_sortable) { _sortable.destroy(); _sortable = null; }
});

function renderAll() {
  const container = document.getElementById('fields-container');
  const empty     = document.getElementById('fields-empty');
  document.getElementById('field-count').textContent = _fields.length;
  if (_fields.length === 0) { container.innerHTML = ''; empty.classList.remove('hidden'); window._updateFloatBtn?.(); return; }
  empty.classList.add('hidden');
  container.innerHTML = _fields.map((f, i) => renderField(f, i)).join('');
  window._updateFloatBtn?.();

  // Init / re-init SortableJS on the container
  if (_sortable) _sortable.destroy();
  if (typeof Sortable !== 'undefined') {
  _sortable = Sortable.create(container, {
    handle: '.drag-handle',
    animation: 150,
    ghostClass: 'sortable-ghost',
    chosenClass: 'sortable-chosen',
    dragClass: 'sortable-drag',
    onEnd: function(evt) {
      // Reorder _fields to match new DOM order
      const newOrder = Array.from(container.children).map(el => {
        const uid = parseInt(el.id.replace('field-', ''));
        return _fields.find(f => f._uid === uid);
      }).filter(Boolean);
      _fields = newOrder;
      // Update number badges in place without full re-render
      container.querySelectorAll('.field-num-badge').forEach((badge, i) => {
        badge.textContent = i + 1;
      });
      markUnsaved();
    }
  });
  } // end if Sortable defined
}

