<%
  assignee     = submission.assignee
  display_name = assignee ? (assignee.name.presence || assignee.email) : t("dynamic_forms.unassigned")
  initials     = assignee ? display_name.first.upcase : "?"
  update_url   = update_submission_assignee_dynamic_form_path(submission.dynamic_form)
%>

<div class="relative inline-block" id="assignee-wrap-<%= submission.id %>">
  <button type="button"
    onclick="toggleAssigneeMenu(<%= submission.id %>)"
    class="inline-flex items-center gap-1.5 px-2 py-1 rounded-full text-[11px] font-semibold border cursor-pointer transition-all hover:opacity-80
           <%= assignee ? 'bg-indigo-50 text-indigo-700 border-indigo-200' : 'bg-slate-50 text-slate-500 border-slate-200' %>">
    <% if assignee %>
      <span class="w-4 h-4 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-[8px] font-black text-white flex-shrink-0">
        <%= initials %>
      </span>
    <% else %>
      <span class="w-4 h-4 rounded-full bg-slate-200 flex items-center justify-center text-[8px] text-slate-400 flex-shrink-0">?</span>
    <% end %>
    <span id="assignee-name-<%= submission.id %>" class="max-w-[90px] truncate"><%= display_name %></span>
    <svg class="w-3 h-3 opacity-60 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
    </svg>
  </button>

  <div id="assignee-menu-<%= submission.id %>"
    class="hidden absolute left-0 top-full mt-1 z-30 bg-white border border-slate-200 rounded-xl shadow-lg overflow-hidden min-w-[180px]">
    <!-- Unassigned -->
    <button type="button"
      onclick="setAssignee(<%= submission.id %>, null, '<%= j t("dynamic_forms.unassigned") %>', '<%= j update_url %>')"
      class="w-full flex items-center gap-2 px-3 py-2 text-[12px] hover:bg-slate-50 transition-colors text-left <%= submission.assignee_id.nil? ? 'bg-indigo-50 text-indigo-700' : 'text-slate-600' %>">
      <span class="w-5 h-5 rounded-full bg-slate-200 flex items-center justify-center text-[9px] text-slate-400 flex-shrink-0">?</span>
      <%= t("dynamic_forms.unassigned") %>
      <% if submission.assignee_id.nil? %>
        <svg class="w-3.5 h-3.5 ml-auto text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
        </svg>
      <% end %>
    </button>
    <div class="border-t border-slate-100"></div>
    <% handlers.each do |user| %>
      <% uname = user.name.presence || user.email %>
      <button type="button"
        onclick="setAssignee(<%= submission.id %>, <%= user.id %>, '<%= j uname %>', '<%= j update_url %>')"
        class="w-full flex items-center gap-2 px-3 py-2 text-[12px] hover:bg-slate-50 transition-colors text-left <%= submission.assignee_id == user.id ? 'bg-indigo-50 text-indigo-700' : 'text-slate-700' %>">
        <span class="w-5 h-5 rounded-full bg-gradient-to-br from-indigo-400 to-purple-500 flex items-center justify-center text-[9px] font-bold text-white flex-shrink-0">
          <%= uname.first.upcase %>
        </span>
        <span class="truncate flex-1"><%= uname %></span>
        <% if submission.assignee_id == user.id %>
          <svg class="w-3.5 h-3.5 ml-auto text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
          </svg>
        <% end %>
      </button>
    <% end %>
  </div>
</div>
