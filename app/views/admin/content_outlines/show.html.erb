<% content_for :title, @outline.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @outline.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "outline" => "📋 Dàn ý", "slide" => "🖥️ Slide", "slide_script" => "🖥️ Slide", "lesson_plan" => "📚 Kế hoạch buổi học" }[@outline.output_type] %></span>
      <% if @outline.subject.present? %><span>· <%= @outline.subject %></span><% end %>
      <span>· <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @outline.pptx_file.attached? %>
      <%= link_to rails_blob_path(@outline.pptx_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Tải PPTX
      <% end %>
    <% end %>
    <button type="button" id="regenerate-btn"
        onclick="handleRegenerate()"
        class="flex items-center gap-1.5 px-3 py-2 bg-violet-50 hover:bg-violet-100 text-violet-700 text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Tạo lại (5 credits)
    </button>
  </div>
</div>

<% if @outline.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url: status_content_outline_path(@outline, format: :json),
        message: "AI đang tạo #{@outline.output_type == 'slide' ? 'slide' : 'nội dung'}...",
        submessage: "Đừng tắt trang này." %>
<% elsif @outline.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">⚠️</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2">Có lỗi xảy ra khi tạo nội dung</h3>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "mt-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer" do %>
      Thử lại
    <% end %>
  </div>
<% elsif @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.include?("slide-deck-root") %>
  <!-- Slide viewer + editor layout -->
  <div id="slide-editor-layout" style="display:flex;gap:12px;align-items:flex-start;">

    <!-- SLIDE PANEL: thumbnail sidebar -->
    <div id="slide-panel" style="width:160px;flex-shrink:0;background:#f8fafc;border-radius:16px;border:1px solid #e2e8f0;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);display:flex;flex-direction:column;">
      <div style="padding:8px 10px 6px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
        <span style="font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.07em;">Slides</span>
        <button onclick="addBlankSlide()" title="Thêm slide mới" style="background:#6366f1;border:none;color:#fff;border-radius:6px;width:22px;height:22px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;padding:0;line-height:1;">+</button>
      </div>
      <div id="slide-thumb-list" style="display:flex;flex-direction:column;gap:6px;padding:8px;overflow-y:auto;flex:1;"></div>
    </div>

    <!-- CENTER: slide viewer -->
    <div id="slide-viewer-col" style="flex:1;min-width:0;">
      <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="border-b border-slate-100 px-4 py-2 flex items-center justify-between">
          <div class="flex items-center gap-3 flex-wrap">
            <span class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">🖥️ Slide</span>
            <div id="slide-dots" class="flex gap-1"></div>
          </div>
          <div class="flex items-center gap-2">
            <!-- WYSIWYG drag-edit toggle -->
            <button onclick="toggleWysiwyg()"
                    id="wysiwyg-btn"
                    title="Kéo thả chỉnh sửa trực tiếp trên slide"
                    class="text-[12px] text-slate-600 hover:text-violet-700 px-3 py-1 bg-slate-50 hover:bg-violet-50 rounded-lg transition-colors border-0 cursor-pointer font-medium">
              ✏️ Sửa trực tiếp
            </button>
            <!-- AI edit panel toggle -->
            <button onclick="toggleAiPanel()"
                    id="ai-panel-btn"
                    class="text-[12px] text-indigo-600 hover:text-indigo-700 px-3 py-1 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors border-0 cursor-pointer font-semibold">
              ✨ Sửa bằng AI
            </button>
            <div style="position:relative;display:inline-block;">
              <button onclick="toggleThemeMenu(this)"
                      id="theme-btn"
                      class="text-[12px] font-semibold text-violet-700 hover:text-white px-3 py-1 bg-violet-100 hover:bg-violet-600 rounded-lg transition-colors border-0 cursor-pointer">
                🖌️ Đổi theme
              </button>
              <div id="theme-menu" style="display:none;position:absolute;right:0;top:calc(100% + 6px);z-index:9999;background:#fff;border:1px solid #e2e8f0;border-radius:14px;box-shadow:0 12px 32px rgba(0,0,0,.16);padding:10px;min-width:240px;max-height:420px;overflow-y:auto;">
                <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;padding:2px 8px 8px;">Chọn theme</div>
                <% [["green","#064E3B","#34D399","Nature","Circles"],
                    ["blue","#1e3a5f","#60A5FA","Corporate","Split panel"],
                    ["purple","#3B0764","#C084FC","Creative","Circles"],
                    ["red","#7F1D1D","#FB923C","Bold","Diagonal stripe"],
                    ["teal","#134E4A","#2DD4BF","Minimal","Corner circle"],
                    ["amber","#78350F","#FBBF24","Warm","Wave"],
                    ["slate","#0F172A","#818CF8","Executive","Dot grid"],
                    ["earth","#3B1F0A","#D97706","Earth","Geometric"],
                    ["coral","#881337","#FB7185","Vibrant","Split panel"],
                    ["ocean","#021C2C","#38BDF8","Ocean","Corner circle"],
                    ["berry","#2D0416","#F472B6","Berry","Dot grid"],
                    ["midnight","#0F0B2D","#818CF8","Midnight","Geometric"],
                    ["rose","#4C0519","#FB923C","Rose","Diagonal stripe"],
                    ["forest","#052E16","#4ADE80","Forest","Split panel"],
                    ["gold","#1A0F00","#FCD34D","Gold","Corner circle"],
                    ["ice","#0C4A6E","#7DD3FC","Ice","Wave"],
                    ["charcoal","#111827","#F59E0B","Charcoal","Dot grid"],
                    ["lavender","#2E1065","#A78BFA","Lavender","Geometric"],
                    ["sunset","#7C2D12","#FB923C","Sunset","Split panel"],
                    ["jade","#022C22","#34D399","Jade","Clean minimal"]
                ].each do |name, dark, accent, label, subtitle| %>
                  <button onclick="applyTheme('<%= name %>')"
                          style="display:flex;align-items:center;gap:10px;width:100%;padding:7px 8px;border:none;background:none;cursor:pointer;border-radius:8px;text-align:left;"
                          onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='none'">
                    <span style="display:flex;flex-shrink:0;">
                      <span style="width:16px;height:16px;border-radius:50%;background:<%= dark %>;display:block;"></span>
                      <span style="width:16px;height:16px;border-radius:50%;background:<%= accent %>;display:block;margin-left:-6px;border:2px solid #fff;"></span>
                    </span>
                    <span style="flex:1;">
                      <span style="display:block;font-size:12px;font-weight:600;color:#1e293b;"><%= label %></span>
                      <span style="display:block;font-size:10px;color:#94a3b8;margin-top:1px;"><%= subtitle %></span>
                    </span>
                  </button>
                <% end %>
              </div>
            </div>
            <button onclick="recompileCurrentTheme()" title="Yêu cầu AI tạo lại nội dung slide theo theme hiện tại"
                    class="text-[12px] text-slate-500 hover:text-amber-700 px-3 py-1 bg-slate-50 hover:bg-amber-50 rounded-lg transition-colors border-0 cursor-pointer">
              ✨ AI tối ưu nội dung
            </button>
            <button onclick="enterFullscreen()"
                    class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
              ⛶ Toàn màn hình
            </button>
          </div>
        </div>

        <!-- WYSIWYG mode bar -->
        <div id="wysiwyg-bar" style="display:none;background:#4f46e5;color:#fff;padding:5px 12px;font-size:11px;font-weight:600;align-items:center;gap:8px;flex-wrap:wrap;">
          <span style="flex:1;min-width:160px;">✏️ Kéo di chuyển · Kéo góc resize · Double-click sửa text/biểu đồ</span>
          <!-- Slide background color panel -->
          <div style="position:relative;">
            <button id="bg-btn" onclick="toggleBgPanel()" style="background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;">
              🪣 Màu nền
              <span id="bg-preview" style="width:14px;height:14px;border-radius:3px;background:#fff;border:1px solid rgba(255,255,255,.4);display:inline-block;flex-shrink:0;"></span>
            </button>
            <div id="bg-panel" style="display:none;position:absolute;left:0;top:calc(100% + 6px);z-index:10001;background:#fff;color:#1e293b;border:1px solid #e2e8f0;border-radius:14px;box-shadow:0 12px 32px rgba(0,0,0,.18);padding:14px;width:260px;">
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;">Màu có sẵn</div>
              <div id="bg-swatches" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;"></div>
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;">Tuỳ chỉnh</div>
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                <input type="color" id="bg-color-input" style="width:36px;height:32px;border:1px solid #e2e8f0;border-radius:6px;cursor:pointer;padding:2px;" title="Chọn màu tuỳ chỉnh" oninput="var h=document.getElementById('bg-hex-input');if(h)h.value=this.value;updateBgPreview(this.value);">
                <input type="text" id="bg-hex-input" placeholder="#ffffff" maxlength="7"
                       style="flex:1;border:1px solid #e2e8f0;border-radius:6px;padding:5px 8px;font-size:12px;font-family:monospace;outline:none;"
                       oninput="syncBgHex(this.value)">
              </div>
              <button onclick="confirmBgColor()" style="width:100%;background:#4f46e5;color:#fff;border:none;border-radius:8px;padding:7px 0;font-size:12px;font-weight:700;cursor:pointer;">✓ Áp dụng</button>
            </div>
          </div>
          <!-- Image insert -->
          <label style="background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap;">
            📷 Chèn ảnh
            <input type="file" id="img-upload-input" accept="image/*" style="display:none;" onchange="insertImageFromFile(this)">
          </label>
          <div style="display:flex;gap:2px;background:rgba(255,255,255,.12);border-radius:6px;padding:2px;">
            <button id="undo-btn" onclick="undo()" title="Hoàn tác (Ctrl+Z)" style="background:none;border:none;color:#fff;width:26px;height:26px;border-radius:4px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;opacity:.5;" disabled>↩</button>
            <button id="redo-btn" onclick="redo()" title="Làm lại (Ctrl+Y)" style="background:none;border:none;color:#fff;width:26px;height:26px;border-radius:4px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;opacity:.5;" disabled>↪</button>
          </div>
          <!-- Insert component -->
          <div style="position:relative;">
            <button onclick="toggleInsertPanel()" style="background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap;">➕ Thêm</button>
            <div id="insert-panel" style="display:none;position:absolute;right:0;top:calc(100%+6px);z-index:10050;background:#fff;border:1px solid #e2e8f0;border-radius:16px;box-shadow:0 12px 32px rgba(0,0,0,.18);padding:10px;min-width:220px;max-height:500px;overflow-y:auto;">
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.07em;padding:0 4px 8px;">Văn bản & hình dạng</div>
              <button onclick="insertComponent('text')"     class="ins-btn"><span>𝐓</span> Hộp văn bản</button>
              <button onclick="insertComponent('rect')"     class="ins-btn"><span>▭</span> Hình chữ nhật</button>
              <button onclick="insertComponent('ellipse')"  class="ins-btn"><span>⬭</span> Hình ellipse</button>
              <button onclick="insertComponent('divider')"  class="ins-btn"><span>─</span> Đường kẻ</button>
              <button onclick="insertComponent('arrow')"    class="ins-btn"><span>→</span> Mũi tên</button>
              <button onclick="document.getElementById('insert-panel').style.display='none';openIconPicker('insert')" class="ins-btn"><span>★</span> Icon</button>
              <div style="border-top:1px solid #f1f5f9;margin:6px 0 4px;"></div>
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.07em;padding:0 4px 8px;">Nội dung nổi bật</div>
              <button onclick="insertComponent('stat')"     class="ins-btn"><span>42</span> Số liệu / KPI</button>
              <button onclick="insertComponent('quote')"    class="ins-btn"><span>"</span> Trích dẫn</button>
              <button onclick="insertComponent('callout')"  class="ins-btn"><span>💡</span> Callout box</button>
              <button onclick="insertComponent('progress')" class="ins-btn"><span>▓</span> Thanh tiến trình</button>
              <div style="border-top:1px solid #f1f5f9;margin:6px 0 4px;"></div>
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.07em;padding:0 4px 8px;">Biểu đồ & dữ liệu</div>
              <button onclick="insertComponent('chart_bar')"    class="ins-btn"><span>📊</span> Biểu đồ cột</button>
              <button onclick="insertComponent('chart_donut')"  class="ins-btn"><span>🍩</span> Biểu đồ tròn</button>
              <button onclick="insertComponent('table')"         class="ins-btn"><span>⊞</span> Bảng</button>
              <div style="border-top:1px solid #f1f5f9;margin:6px 0 4px;"></div>
              <button onclick="insertComponent('video')" class="ins-btn"><span>▶</span> Video (URL)</button>
              <label class="ins-btn" style="cursor:pointer;">
                <span>🖼️</span> Chèn ảnh
                <input type="file" accept="image/*" style="display:none;" onchange="insertImageFromFile(this);document.getElementById('insert-panel').style.display='none';">
              </label>
            </div>
            <style>.ins-btn{display:flex;align-items:center;gap:8px;width:100%;padding:7px 8px;border:none;background:none;cursor:pointer;border-radius:8px;font-size:12px;color:#1e293b;text-align:left;}.ins-btn:hover{background:#f1f5f9;}.ins-btn span{font-size:15px;width:20px;text-align:center;flex-shrink:0;}</style>
          </div>
          <!-- Z-order controls -->
          <div style="display:flex;gap:2px;background:rgba(255,255,255,.12);border-radius:6px;padding:2px;" id="zorder-btns" style="display:none;">
            <button onclick="zOrder('front')" title="Lên trên cùng (Ctrl+Shift+↑)" style="background:none;border:none;color:#fff;width:28px;height:26px;border-radius:4px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='none'">⬆</button>
            <button onclick="zOrder('forward')" title="Lên một lớp (Ctrl+↑)" style="background:none;border:none;color:#fff;width:28px;height:26px;border-radius:4px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='none'">↑</button>
            <button onclick="zOrder('backward')" title="Xuống một lớp (Ctrl+↓)" style="background:none;border:none;color:#fff;width:28px;height:26px;border-radius:4px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='none'">↓</button>
            <button onclick="zOrder('back')" title="Xuống dưới cùng (Ctrl+Shift+↓)" style="background:none;border:none;color:#fff;width:28px;height:26px;border-radius:4px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;" onmouseover="this.style.background='rgba(255,255,255,.2)'" onmouseout="this.style.background='none'">⬇</button>
          </div>
          <!-- Align tools -->
          <div style="position:relative;" id="align-btn-wrap">
            <button onclick="toggleAlignPanel()" style="background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap;display:inline-flex;align-items:center;gap:4px;">⊞ Căn chỉnh</button>
            <div id="align-panel" style="display:none;position:absolute;right:0;top:calc(100% + 6px);z-index:10050;background:#1e293b;border-radius:12px;padding:8px;box-shadow:0 12px 32px rgba(0,0,0,.4);min-width:160px;">
              <div style="font-size:9px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px;padding:0 4px;">Căn theo cạnh slide</div>
              <button onclick="alignEls('left')"   style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">⬅ Canh trái</button>
              <button onclick="alignEls('hcenter')" style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">↔ Canh giữa (ngang)</button>
              <button onclick="alignEls('right')"  style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">➡ Canh phải</button>
              <button onclick="alignEls('top')"    style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">⬆ Canh trên</button>
              <button onclick="alignEls('vcenter')" style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">↕ Canh giữa (dọc)</button>
              <button onclick="alignEls('bottom')" style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">⬇ Canh dưới</button>
              <div style="border-top:1px solid #334155;margin:4px 0;"></div>
              <button onclick="alignEls('distribute-h')" style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">⇹ Phân phối đều (ngang)</button>
              <button onclick="alignEls('distribute-v')" style="display:flex;align-items:center;gap:8px;width:100%;padding:5px 8px;border:none;background:none;color:#e2e8f0;cursor:pointer;border-radius:6px;font-size:11px;" onmouseover="this.style.background='#334155'" onmouseout="this.style.background='none'">⇳ Phân phối đều (dọc)</button>
            </div>
          </div>
          <button onclick="toggleWysiwyg()" style="background:rgba(255,255,255,.2);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;">Thoát</button>
        </div>


        <!-- Video URL input modal -->
        <div id="video-url-modal" style="display:none;position:fixed;inset:0;z-index:20000;background:rgba(0,0,0,.5);align-items:center;justify-content:center;">
          <div style="background:#fff;border-radius:18px;padding:28px 32px;max-width:480px;width:92%;box-shadow:0 20px 60px rgba(0,0,0,.25);">
            <div style="font-size:18px;font-weight:700;color:#1e293b;margin-bottom:6px;">▶ Chèn video</div>
            <div style="font-size:13px;color:#64748b;margin-bottom:18px;">Hỗ trợ: YouTube, Vimeo, Google Drive, hoặc link .mp4 trực tiếp</div>
            <input id="video-url-input" type="url" placeholder="https://youtube.com/watch?v=... hoặc https://vimeo.com/..."
