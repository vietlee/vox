    function confirmVideoUrl() {
      var url = (document.getElementById('video-url-input').value || '').trim();
      document.getElementById('video-url-modal').style.display = 'none';
      if (!url) return;
      saveHistorySnapshot();
      var sl = slides[current];
      if (!sl) return;
      var uid = 'el_' + Date.now();
      /* coordinates in inches: slide = 10 × 5.625" */
      var el = { id: uid, type: 'video', x: 0.8, y: 0.8, w: 8.4, h: 4.2, z: 10,
                 src: url, content: url, style: { borderRadius: 10 } };
      if (!sl.elements) sl.elements = [];
      sl.elements.push(el);
      if (!editorMode) editorMode = true;
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      var newDom = stage && stage.querySelector('[data-ei="'+uid+'"]');
      if (newDom) {
        clearSelection();
        newDom.classList.add('sel-el');
        newDom.style.outlineColor = '#1e3a5f';
