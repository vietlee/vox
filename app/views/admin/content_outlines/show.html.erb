              <div style="font-size:9px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;">Màu chữ</div>
              <div id="tt-swatches" style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px;"></div>
              <div style="display:flex;gap:6px;align-items:center;">
                <input type="color" id="tt-color" style="width:32px;height:28px;border:1px solid #e2e8f0;border-radius:5px;cursor:pointer;padding:2px;" oninput="var h=document.getElementById('tt-hex');if(h)h.value=this.value;document.getElementById('tt-color-bar').style.background=this.value;">
                <input type="text" id="tt-hex" placeholder="#ffffff" maxlength="7" style="flex:1;border:1px solid #e2e8f0;border-radius:5px;padding:4px 6px;font-size:11px;font-family:monospace;outline:none;color:#1e293b;" oninput="if(/^#[0-9A-Fa-f]{6}$/.test(this.value)){document.getElementById('tt-color').value=this.value;document.getElementById('tt-color-bar').style.background=this.value;}">
                <button onclick="confirmTxtColor()" style="background:#4f46e5;color:#fff;border:none;border-radius:6px;padding:4px 10px;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;">Áp dụng</button>
              </div>
            </div>
