<% content_for :title, @outline.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @outline.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "outline" => "📋 Dàn ý", "slide" => "🖥️ Slide", "slide_script" => "🖥️ Slide", "lesson_plan" => "📚 Kế hoạch buổi học" }[@outline.output_type] %></span>
      <% if @outline.subject.present? %><span>· <%= @outline.subject %></span><% end %>
      <span>· <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @outline.pptx_file.attached? %>
      <%= link_to rails_blob_path(@outline.pptx_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Tải PPTX
      <% end %>
    <% end %>
    <button type="button" id="regenerate-btn"
        onclick="handleRegenerate()"
        class="flex items-center gap-1.5 px-3 py-2 bg-violet-50 hover:bg-violet-100 text-violet-700 text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Tạo lại (5 credits)
    </button>
  </div>
</div>

<% if @outline.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url: status_content_outline_path(@outline, format: :json),
        message: "AI đang tạo #{@outline.output_type == 'slide' ? 'slide' : 'nội dung'}...",
        submessage: "Đừng tắt trang này." %>
<% elsif @outline.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">⚠️</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2">Có lỗi xảy ra khi tạo nội dung</h3>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "mt-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer" do %>
      Thử lại
    <% end %>
  </div>
<% elsif @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.include?("slide-deck-root") %>
  <!-- Slide viewer + editor layout -->
  <div id="slide-editor-layout" style="display:flex;gap:16px;align-items:flex-start;">

    <!-- LEFT: slide viewer -->
    <div id="slide-viewer-col" style="flex:1;min-width:0;">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="border-b border-slate-100 px-4 py-2 flex items-center justify-between">
          <div class="flex items-center gap-3 flex-wrap">
            <span class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">🖥️ Slide</span>
            <div id="slide-dots" class="flex gap-1"></div>
          </div>
          <div class="flex items-center gap-2">
            <button onclick="toggleEditor()"
                    id="editor-toggle-btn"
                    class="text-[12px] text-indigo-600 hover:text-indigo-700 px-3 py-1 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors border-0 cursor-pointer font-semibold">
              ✨ Sửa bằng AI
            </button>
            <button onclick="enterFullscreen()"
                    class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
              ⛶ Toàn màn hình
            </button>
          </div>
        </div>

        <div style="position:relative; padding-bottom:56.25%; background:#0f172a; overflow:hidden;">
          <div id="slide-viewer" style="position:absolute; inset:0; overflow:hidden;"></div>
          <!-- image overlay (absolute over slide content) -->
          <div id="slide-image-overlay" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;"></div>
        </div>

        <div class="border-t border-slate-100 px-5 py-2.5 flex items-center justify-between bg-slate-50">
          <button onclick="prevSlide()" style="border:1px solid #e2e8f0;"
                  class="px-4 py-2 bg-white rounded-xl text-[13px] font-semibold text-slate-600 hover:bg-slate-100 transition-colors cursor-pointer shadow-sm">← Trước</button>
          <span id="slide-counter" class="text-[12px] text-slate-500 font-semibold"></span>
          <button onclick="nextSlide()"
                  class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-xl text-[13px] font-bold text-white transition-colors border-0 cursor-pointer shadow-sm">Tiếp →</button>
        </div>
        <div id="slide-note" class="hidden border-t border-slate-100 px-5 py-3 bg-amber-50">
          <div class="text-[10px] font-bold text-amber-600 uppercase tracking-wide mb-1">💬 Ghi chú người trình bày</div>
          <p id="slide-note-text" class="text-[13px] text-amber-800 leading-relaxed"></p>
        </div>
      </div>
    </div><!-- end slide-viewer-col -->

    <!-- RIGHT: AI edit panel (hidden by default) -->
    <div id="slide-editor-panel" style="display:none; width:360px; flex-shrink:0; position:sticky; top:80px; align-self:flex-start;">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
          <div class="text-[13px] font-bold text-slate-700">✨ Chỉnh sửa bằng AI</div>
          <button onclick="toggleEditor()"
                  class="px-2 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-500 text-[12px] rounded-lg border-0 cursor-pointer">✕</button>
        </div>

        <div id="ai-edit-body" class="p-4 space-y-3">
          <p class="text-[12px] text-slate-500 leading-relaxed">
            Mô tả thay đổi bạn muốn. AI sẽ chỉnh sửa nội dung và tạo lại slide.
          </p>

          <textarea id="ai-edit-input" rows="10"
                    placeholder="VD:&#10;• Đổi tiêu đề slide 1&#10;• Thêm slide về đội ngũ&#10;• Bỏ slide cuối&#10;• Thêm ảnh sản phẩm vào slide 3..."
                    class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[13px] focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none resize-none"></textarea>

          <!-- File attachment -->
          <div>
            <label class="flex items-center gap-2 cursor-pointer text-[12px] text-slate-500 hover:text-indigo-600 transition-colors">
              <input type="file" id="ai-edit-files" accept="image/*" multiple class="hidden" onchange="previewEditFiles(this)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
              Đính kèm ảnh
            </label>
            <div id="ai-edit-previews" class="flex flex-wrap gap-2 mt-2"></div>
          </div>

          <button onclick="submitAiEdit()" id="ai-edit-btn"
                  class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
            ✨ Áp dụng thay đổi
          </button>

          <div id="ai-edit-history" class="space-y-2 pt-2 border-t border-slate-100 hidden">
            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Lịch sử chỉnh sửa</div>
            <div id="ai-edit-history-list" class="space-y-1"></div>
          </div>
        </div>

        <!-- Loading overlay inside panel -->
        <div id="ai-edit-loading" class="hidden">
          <div class="p-6 flex flex-col items-center justify-center gap-3">
            <div style="width:40px;height:40px;border:3px solid #c7d2fe;border-top-color:#4f46e5;border-radius:50%;animation:aispin 0.8s linear infinite;"></div>
            <div class="text-[13px] font-semibold text-indigo-600">AI đang chỉnh sửa...</div>
            <p class="text-[11px] text-slate-400 text-center">Đang phân tích yêu cầu và tạo lại slide. Quá trình này mất khoảng 30-60 giây.</p>
          </div>
        </div>
      </div>
    </div><!-- end editor panel -->

  </div><!-- end slide-editor-layout -->

  <div id="slide-data" class="hidden"><%= raw @outline.content %></div>

  <style>
    #slide-viewer * { box-sizing:border-box; }
    @keyframes sIn { from{opacity:0;transform:translateX(28px)} to{opacity:1;transform:translateX(0)} }
    @keyframes fUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    .s-in { animation:sIn .38s cubic-bezier(.22,.68,0,1.2) forwards; }
    .f-up { animation:fUp .3s ease both; }
    @keyframes aispin { to { transform:rotate(360deg); } }
  </style>

  <script>
  (function() {
    var el = document.getElementById('slide-data').querySelector('#slide-deck-root');
    var slides = JSON.parse(el.dataset.slides || '[]');
    var current = 0, total = slides.length;

    var useImageMode = false;

    /* ─────────────────────────────────────────────────────────────────
       SVG DEFS shared across themes  (blur filter for glow blobs)
    ───────────────────────────────────────────────────────────────── */
    var DEFS = '<defs>' +
      '<filter id="blur60" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="60"/></filter>' +
      '<filter id="blur40" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="40"/></filter>' +
      '<filter id="blur80" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="80"/></filter>' +
      '<filter id="blur100" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="100"/></filter>' +
      '<filter id="glow"   x="-40%" y="-40%" width="180%" height="180%">' +
        '<feGaussianBlur stdDeviation="8" result="blur"/>' +
        '<feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>' +
      '</filter>' +
      '<filter id="glow-strong" x="-60%" y="-60%" width="220%" height="220%">' +
        '<feGaussianBlur stdDeviation="16" result="blur"/>' +
        '<feMerge><feMergeNode in="blur"/><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>' +
      '</filter>' +
      /* dot grid */ '<pattern id="dots" width="32" height="32" patternUnits="userSpaceOnUse">' +
        '<circle cx="2" cy="2" r="1.2" fill="rgba(255,255,255,0.12)"/>' +
      '</pattern>' +
      /* fine grid */ '<pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">' +
        '<path d="M60,0 L0,0 0,60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>' +
      '</pattern>' +
      /* blueprint grid */ '<pattern id="blueprint-grid" width="40" height="40" patternUnits="userSpaceOnUse">' +
        '<path d="M40,0 L0,0 0,40" fill="none" stroke="rgba(100,180,255,0.15)" stroke-width="0.8"/>' +
        '<path d="M0,20 L40,20 M20,0 L20,40" fill="none" stroke="rgba(100,180,255,0.06)" stroke-width="0.5"/>' +
      '</pattern>' +
      /* scanlines */ '<pattern id="scanlines" width="1" height="4" patternUnits="userSpaceOnUse">' +
        '<rect width="1" height="2" fill="rgba(0,0,0,0.18)"/>' +
      '</pattern>' +
      /* memphis dots */ '<pattern id="memphis-dots" width="24" height="24" patternUnits="userSpaceOnUse">' +
        '<circle cx="12" cy="12" r="2.5" fill="rgba(0,0,0,0.07)"/>' +
      '</pattern>' +
      /* diagonal hatch */ '<pattern id="hatch" width="10" height="10" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">' +
        '<line x1="0" y1="0" x2="0" y2="10" stroke="rgba(0,0,0,0.06)" stroke-width="3"/>' +
      '</pattern>' +
      /* iridescent gradient */ '<linearGradient id="holo1" x1="0%" y1="0%" x2="100%" y2="100%">' +
        '<stop offset="0%"   stop-color="#ff6ef7"/>' +
        '<stop offset="25%"  stop-color="#7ef7ff"/>' +
        '<stop offset="50%"  stop-color="#7fffb2"/>' +
        '<stop offset="75%"  stop-color="#ffe57e"/>' +
        '<stop offset="100%" stop-color="#ff7eb3"/>' +
      '</linearGradient>' +
      '<linearGradient id="gold-grad" x1="0%" y1="0%" x2="100%" y2="100%">' +
        '<stop offset="0%"   stop-color="#f5c842"/>' +
        '<stop offset="40%"  stop-color="#fff8dc"/>' +
        '<stop offset="100%" stop-color="#c8960c"/>' +
      '</linearGradient>' +
      '<linearGradient id="sunset-grad" x1="0%" y1="0%" x2="100%" y2="100%">' +
        '<stop offset="0%"   stop-color="#f97316"/>' +
        '<stop offset="40%"  stop-color="#ec4899"/>' +
        '<stop offset="100%" stop-color="#8b5cf6"/>' +
      '</linearGradient>' +
      /* fine grid old compat */ '<pattern id="grid-old" width="60" height="60" patternUnits="userSpaceOnUse">' +
        '<path d="M60,0 L0,0 0,60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>' +
      '</pattern>' +
    '</defs>';

    /* ─────────────────────────────────────────────────────────────────
       6 MODERN THEMES
    ───────────────────────────────────────────────────────────────── */
    /* ═══════════════════════════════════════════════════════════════════
       PPTX-ACCURATE HTML RENDERER
       All coordinates match generate_pptx.py exactly.
       PPTX canvas: 10" × 5.625" → percentages: x%=in/10*100, y%=in/5.625*100
    ═══════════════════════════════════════════════════════════════════ */

    /* Coordinate helpers: inches → percentage of slide */
    function X(inches) { return (inches / 10 * 100).toFixed(2) + '%'; }
    function Y(inches) { return (inches / 5.625 * 100).toFixed(2) + '%'; }
    function W(inches) { return (inches / 10 * 100).toFixed(2) + '%'; }
    function H(inches) { return (inches / 5.625 * 100).toFixed(2) + '%'; }

    /* Icon SVG paths */
    var ICON_SVGS = {
      search:    '<circle cx="10" cy="10" r="6" stroke="white" stroke-width="2" fill="none"/><line x1="14.5" y1="14.5" x2="20" y2="20" stroke="white" stroke-width="2" stroke-linecap="round"/>',
      filter:    '<path d="M3 5h18M7 10h10M11 15h2" stroke="white" stroke-width="2" stroke-linecap="round"/>',
      store:     '<path d="M3 9l2-5h14l2 5M3 9h18v10a1 1 0 01-1 1H4a1 1 0 01-1-1V9z" stroke="white" stroke-width="2" fill="none"/><rect x="9" y="13" width="6" height="7" rx="1" stroke="white" stroke-width="1.5" fill="none"/>',
      check:     '<path d="M4 12l6 6L20 6" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
      clock:     '<circle cx="12" cy="12" r="9" stroke="white" stroke-width="2" fill="none"/><path d="M12 7v5l3 3" stroke="white" stroke-width="2" stroke-linecap="round"/>',
      person:    '<circle cx="12" cy="7" r="4" stroke="white" stroke-width="2" fill="none"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="white" stroke-width="2" fill="none"/>',
      people:    '<circle cx="8" cy="8" r="3" stroke="white" stroke-width="1.8" fill="none"/><circle cx="16" cy="8" r="3" stroke="white" stroke-width="1.8" fill="none"/><path d="M2 20c0-3 2.7-5 6-5s6 2 6 5M10 20c0-3 2.7-5 6-5s6 2 6 5" stroke="white" stroke-width="1.8" fill="none"/>',
      rocket:    '<path d="M12 2c0 0 4 3 4 9v1l2 3H6l2-3v-1c0-6 4-9 4-9z" stroke="white" stroke-width="1.8" fill="none"/><path d="M9 20h6M10 15h4" stroke="white" stroke-width="1.8" stroke-linecap="round"/>',
      code:      '<path d="M8 6L3 12l5 6M16 6l5 6-5 6" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
      chart:     '<path d="M3 20V10l4-4 4 4 4-6 4 4v12H3z" stroke="white" stroke-width="2" stroke-linejoin="round" fill="none"/>',
      money:     '<circle cx="12" cy="12" r="9" stroke="white" stroke-width="2" fill="none"/><path d="M12 7v10M9 9.5h4.5a1.5 1.5 0 010 3H10a1.5 1.5 0 000 3H15" stroke="white" stroke-width="1.8" stroke-linecap="round"/>',
      percent:   '<path d="M19 5L5 19M7 7a2 2 0 100-4 2 2 0 000 4zM17 21a2 2 0 100-4 2 2 0 000 4z" stroke="white" stroke-width="2" fill="none"/>',
      megaphone: '<path d="M19 10l2-2v8l-2-2M3 8h12l4-4v16l-4-4H3a1 1 0 01-1-1V9a1 1 0 011-1zM7 16v3" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>',
      crown:     '<path d="M3 16L5 8l4 4 3-7 3 7 4-4 2 8H3z" stroke="white" stroke-width="2" stroke-linejoin="round" fill="none"/><path d="M3 19h18" stroke="white" stroke-width="2"/>',
      lightbulb: '<path d="M9 21h6M12 3a6 6 0 014.5 10c.4.5.5.9.5 1.5V18a1 1 0 01-1 1H9a1 1 0 01-1-1v-3.5c0-.6.1-1 .5-1.5A6 6 0 0112 3z" stroke="white" stroke-width="2" fill="none"/>',
      shield:    '<path d="M12 2l8 3v6c0 4.5-3 8.5-8 11C7 19.5 4 15.5 4 11V5l8-3z" stroke="white" stroke-width="2" fill="none"/><path d="M8 12l3 3 5-5" stroke="white" stroke-width="1.8" stroke-linecap="round"/>',
      star:      '<path d="M12 2l3 6.3H22l-5.7 4.1 2.2 6.5L12 15l-6.5 3.9 2.2-6.5L2 8.3h7z" stroke="white" stroke-width="2" fill="none" stroke-linejoin="round"/>',
      heart:     '<path d="M20.8 4.6a5.5 5.5 0 00-7.8 0L12 5.6l-1-1a5.5 5.5 0 00-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 000-7.8z" stroke="white" stroke-width="2" fill="none"/>',
      globe:     '<circle cx="12" cy="12" r="9" stroke="white" stroke-width="2" fill="none"/><path d="M12 3c-3 4-3 14 0 18M12 3c3 4 3 14 0 18M3 12h18M4.2 7.5h15.6M4.2 16.5h15.6" stroke="white" stroke-width="1.5"/>',
      target:    '<circle cx="12" cy="12" r="9" stroke="white" stroke-width="2" fill="none"/><circle cx="12" cy="12" r="5" stroke="white" stroke-width="1.8" fill="none"/><circle cx="12" cy="12" r="1.5" fill="white"/>',
      handshake: '<path d="M9 12l3 3 3-3M9 7l3 3 3-3M3 12c0 5 4 9 9 9s9-4 9-9V7L12 3 3 7v5z" stroke="white" stroke-width="1.8" fill="none" stroke-linejoin="round"/>',
      leaf:      '<path d="M21 3s-9 0-12 9c-1.5 4.5 1 9 3 12M9 21c3-7 9-9 12-9" stroke="white" stroke-width="2" stroke-linecap="round" fill="none"/><path d="M9 21L3 15" stroke="white" stroke-width="2" stroke-linecap="round"/>',
      phone:     '<path d="M6 2h12a1 1 0 011 1v18a1 1 0 01-1 1H6a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="white" stroke-width="2" fill="none"/><circle cx="12" cy="17" r="1" fill="white"/>',
      truck:     '<path d="M1 3h15v12H1zM16 8h4l3 4v4h-7V8zM5.5 19a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM18.5 19a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" stroke="white" stroke-width="1.8" fill="none"/>',
      'default': '<circle cx="12" cy="12" r="9" stroke="white" stroke-width="2" fill="none"/><path d="M12 8v4l3 3" stroke="white" stroke-width="2" stroke-linecap="round"/>',
    };

    function iconSvg(name) {
      var d = ICON_SVGS[name] || ICON_SVGS['default'];
      return '<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" xmlns="http://www.w3.org/2000/svg">' + d + '</svg>';
    }

    var ICON_KEYWORDS = {
      search:    ['tìm','search','lọc','phát hiện'],
      filter:    ['bộ lọc','filter','phân loại','sàng lọc'],
      store:     ['cửa hàng','store','shop','restaurant'],
      check:     ['kiểm','xác minh','verify','đạt chuẩn','chất lượng','đảm bảo'],
      clock:     ['thời gian','phút','giờ','time'],
      person:    ['người','khách','user','cá nhân','founder','CEO'],
      people:    ['cộng đồng','nhóm','team','đội','community','người dùng'],
      rocket:    ['tăng trưởng','phát triển','growth','launch','mở rộng','scale'],
      code:      ['công nghệ','tech','AI','app','ứng dụng','phần mềm','platform'],
      chart:     ['doanh thu','revenue','số liệu','KPI','metric','thống kê'],
      money:     ['vốn','đầu tư','tiền','USD','fund','tài chính','chi phí','hoa hồng','phí'],
      percent:   ['tỷ lệ','%','phần trăm','rate','margin','lợi nhuận'],
      megaphone: ['marketing','quảng cáo','truyền thông','ads','kênh'],
      crown:     ['premium','VIP','cao cấp','hàng đầu','leader','dẫn đầu'],
      lightbulb: ['giải pháp','ý tưởng','idea','solution','sáng tạo','đổi mới'],
      shield:    ['bảo vệ','an toàn','security','trust','uy tín','tin cậy'],
      star:      ['đánh giá','review','rating','nổi bật'],
      heart:     ['yêu thích','sức khỏe','health','thuần chay','vegan'],
