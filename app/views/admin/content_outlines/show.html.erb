                <button onclick="copyShareUrl()" id="share-copy-btn" style="background:var(--vox-accent);color:#fff;border:none;border-radius:8px;padding:7px 14px;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap;flex-shrink:0;">Sao chép</button>
