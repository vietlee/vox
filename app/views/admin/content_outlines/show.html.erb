    window.toggleLinkPanel = toggleLinkPanel;
    window.applyLink = applyLink;
    window.removeLink = removeLink;

    function confirmTxtColor() {
      var hex = document.getElementById('tt-hex');
      var ci  = document.getElementById('tt-color');
      var color = (hex && /^#[0-9A-Fa-f]{6}$/.test(hex.value)) ? hex.value : (ci ? ci.value : null);
      if (!color) return;
      document.getElementById('tt-color-bar').style.background = color;
      applyTextProp('color', color);
      var panel = document.getElementById('tt-color-panel');
      if (panel) panel.style.display = 'none';
