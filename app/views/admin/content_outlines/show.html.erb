<% content_for :title, @outline.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @outline.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "outline" => "📋 Dàn ý", "slide" => "🖥️ Slide", "slide_script" => "🖥️ Slide", "lesson_plan" => "📚 Kế hoạch buổi học" }[@outline.output_type] %></span>
      <% if @outline.subject.present? %><span>· <%= @outline.subject %></span><% end %>
      <span>· <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @outline.pptx_file.attached? %>
      <%= link_to rails_blob_path(@outline.pptx_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Tải PPTX
      <% end %>
    <% end %>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "flex items-center gap-1.5 px-3 py-2 bg-violet-50 hover:bg-violet-100 text-violet-700 text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Tạo lại
    <% end %>
  </div>
</div>

<% if @outline.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url: status_content_outline_path(@outline, format: :json),
        message: "AI đang tạo #{@outline.output_type == 'slide' ? 'slide' : 'nội dung'}...",
        submessage: "Đừng tắt trang này." %>
<% elsif @outline.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">⚠️</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2">Có lỗi xảy ra khi tạo nội dung</h3>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "mt-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer" do %>
      Thử lại
    <% end %>
  </div>
<% elsif @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.include?("slide-deck-root") %>
  <!-- Slide viewer -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="border-b border-slate-100 px-5 py-2.5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">🖥️ Slide thuyết trình</span>
        <!-- Progress dots -->
        <div id="slide-dots" class="flex gap-1"></div>
      </div>
      <button onclick="enterFullscreen()"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        ⛶ Toàn màn hình
      </button>
    </div>

    <!-- 16:9 aspect ratio wrapper -->
    <div style="position:relative; padding-bottom:56.25%; background:#0f172a; overflow:hidden;">
      <div id="slide-viewer" style="position:absolute; inset:0; overflow:hidden;"></div>
    </div>

    <div class="border-t border-slate-100 px-5 py-2.5 flex items-center justify-between bg-slate-50">
      <button onclick="prevSlide()"
              style="border:1px solid #e2e8f0;"
              class="px-4 py-2 bg-white rounded-xl text-[13px] font-semibold text-slate-600 hover:bg-slate-100 transition-colors cursor-pointer shadow-sm">
        ← Trước
      </button>
      <span id="slide-counter" class="text-[12px] text-slate-500 font-semibold"></span>
      <button onclick="nextSlide()"
              class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-xl text-[13px] font-bold text-white transition-colors border-0 cursor-pointer shadow-sm">
        Tiếp →
      </button>
    </div>
    <div id="slide-note" class="hidden border-t border-slate-100 px-5 py-3 bg-amber-50">
      <div class="text-[10px] font-bold text-amber-600 uppercase tracking-wide mb-1">💬 Ghi chú người trình bày</div>
      <p id="slide-note-text" class="text-[13px] text-amber-800 leading-relaxed"></p>
    </div>
  </div>

  <div id="slide-data" class="hidden"><%= raw @outline.content %></div>

  <style>
    #slide-viewer * { box-sizing:border-box; }
    @keyframes sIn  { from{opacity:0;transform:translateX(20px)} to{opacity:1;transform:translateX(0)} }
    @keyframes fUp  { from{opacity:0;transform:translateY(12px)} to{opacity:1;transform:translateY(0)} }
    .s-in  { animation:sIn  0.35s ease forwards; }
    .f-up  { animation:fUp  0.28s ease both; }
  </style>

  <script>
  (function() {
    var el = document.getElementById('slide-data').querySelector('#slide-deck-root');
    var slides = JSON.parse(el.dataset.slides || '[]');
    var current = 0, total = slides.length;

    /* ── 6 full design themes ─────────────────────────────────────────── */
    var THEMES = [
      /* 0 · INDIGO CORPORATE — diagonal split + circles */
      {
        name:'corporate',
        coverBg: function() {
          return '<rect width="1280" height="720" fill="#1e1b4b"/>' +
            '<polygon points="0,0 780,0 560,720 0,720" fill="#312e81"/>' +
            '<circle cx="1150" cy="100" r="220" fill="#4338ca" opacity=".35"/>' +
            '<circle cx="1050" cy="620" r="140" fill="#6366f1" opacity=".2"/>' +
            '<rect x="0" y="0" width="7" height="720" fill="#818cf8"/>' +
            '<rect x="0" y="0" width="1280" height="5" fill="#818cf8"/>';
        },
        contentBg: function() {
          return '<rect width="1280" height="720" fill="#0f0e2a"/>' +
            '<rect x="0" y="0" width="320" height="720" fill="#1e1b4b"/>' +
            '<circle cx="320" cy="360" r="80" fill="#312e81" opacity=".6"/>' +
            '<rect x="0" y="0" width="7" height="720" fill="#818cf8"/>';
        },
        accent:'#a5b4fc', text:'#fff', sub:'rgba(255,255,255,0.65)',
        card:'rgba(129,140,248,0.12)', cardBorder:'#6366f1', num:'#818cf8',
        titleX: 370, titleW: 860, bullX: 370, bullW: 860
      },
      /* 1 · OCEAN BLUE — wave shape */
      {
        name:'ocean',
        coverBg: function() {
          return '<rect width="1280" height="720" fill="#0c1445"/>' +
            '<path d="M0,400 Q320,320 640,400 Q960,480 1280,380 L1280,720 L0,720 Z" fill="#1e3a5f"/>' +
            '<circle cx="200" cy="180" r="180" fill="#1d4ed8" opacity=".25"/>' +
            '<circle cx="1100" cy="500" r="140" fill="#0ea5e9" opacity=".18"/>' +
            '<rect x="0" y="0" width="1280" height="5" fill="#38bdf8"/>' +
            '<rect x="0" y="715" width="1280" height="5" fill="#38bdf8"/>';
        },
        contentBg: function() {
          return '<rect width="1280" height="720" fill="#071528"/>' +
            '<path d="M0,580 Q640,500 1280,580 L1280,720 L0,720 Z" fill="#0c1f3f"/>' +
            '<rect x="0" y="0" width="1280" height="6" fill="#38bdf8"/>';
        },
        accent:'#7dd3fc', text:'#fff', sub:'rgba(255,255,255,0.6)',
        card:'rgba(56,189,248,0.1)', cardBorder:'#0ea5e9', num:'#38bdf8',
        titleX: 80, titleW: 1120, bullX: 80, bullW: 1120
      },
      /* 2 · EMERALD NATURE — leaf/organic curves */
      {
        name:'nature',
        coverBg: function() {
          return '<rect width="1280" height="720" fill="#052e16"/>' +
            '<ellipse cx="1100" cy="80" rx="320" ry="200" fill="#065f46" opacity=".7"/>' +
            '<ellipse cx="200" cy="640" rx="260" ry="160" fill="#064e3b" opacity=".8"/>' +
            '<path d="M0,0 Q200,200 0,400" stroke="#10b981" stroke-width="3" fill="none" opacity=".4"/>' +
            '<path d="M1280,720 Q1080,520 1280,320" stroke="#10b981" stroke-width="3" fill="none" opacity=".4"/>' +
            '<rect x="0" y="0" width="1280" height="5" fill="#34d399"/>';
        },
        contentBg: function() {
          return '<rect width="1280" height="720" fill="#021a0e"/>' +
            '<rect x="0" y="0" width="280" height="720" fill="#052e16"/>' +
            '<ellipse cx="280" cy="720" rx="200" ry="200" fill="#064e3b" opacity=".5"/>' +
            '<rect x="0" y="0" width="6" height="720" fill="#34d399"/>';
        },
        accent:'#6ee7b7', text:'#fff', sub:'rgba(255,255,255,0.6)',
        card:'rgba(52,211,153,0.1)', cardBorder:'#10b981', num:'#34d399',
        titleX: 340, titleW: 900, bullX: 340, bullW: 900
      },
      /* 3 · SUNSET — diagonal warm split */
      {
        name:'sunset',
        coverBg: function() {
          return '<rect width="1280" height="720" fill="#1c0a00"/>' +
            '<polygon points="1280,0 1280,720 400,720" fill="#7c2d12"/>' +
            '<polygon points="1280,0 900,0 1280,300" fill="#b45309" opacity=".6"/>' +
            '<circle cx="120" cy="100" r="160" fill="#92400e" opacity=".3"/>' +
            '<rect x="0" y="715" width="1280" height="5" fill="#fb923c"/>' +
            '<rect x="0" y="0" width="1280" height="5" fill="#f97316"/>';
        },
        contentBg: function() {
          return '<rect width="1280" height="720" fill="#1c0a00"/>' +
            '<polygon points="1280,0 1280,720 900,720" fill="#7c2d12" opacity=".8"/>' +
            '<rect x="0" y="0" width="1280" height="5" fill="#fb923c"/>';
        },
        accent:'#fdba74', text:'#fff', sub:'rgba(255,255,255,0.6)',
        card:'rgba(251,146,60,0.1)', cardBorder:'#f97316', num:'#fdba74',
        titleX: 80, titleW: 780, bullX: 80, bullW: 780
      },
      /* 4 · VIOLET CREATIVE — random circles/blobs */
      {
        name:'creative',
        coverBg: function() {
          return '<rect width="1280" height="720" fill="#1a0533"/>' +
            '<circle cx="640" cy="360" r="380" fill="#4c1d95" opacity=".4"/>' +
            '<circle cx="200" cy="600" r="200" fill="#7c3aed" opacity=".25"/>' +
            '<circle cx="1100" cy="120" r="240" fill="#6d28d9" opacity=".3"/>' +
            '<circle cx="950" cy="580" r="120" fill="#a855f7" opacity=".2"/>' +
            '<rect x="0" y="0" width="1280" height="4" fill="#c084fc"/>' +
            '<rect x="0" y="716" width="1280" height="4" fill="#c084fc"/>';
        },
        contentBg: function() {
          return '<rect width="1280" height="720" fill="#120224"/>' +
            '<circle cx="1200" cy="100" r="200" fill="#4c1d95" opacity=".3"/>' +
            '<circle cx="100" cy="620" r="150" fill="#7c3aed" opacity=".2"/>' +
            '<rect x="0" y="0" width="1280" height="5" fill="#c084fc"/>';
        },
        accent:'#d8b4fe', text:'#fff', sub:'rgba(255,255,255,0.65)',
        card:'rgba(192,132,252,0.12)', cardBorder:'#a855f7', num:'#c084fc',
        titleX: 80, titleW: 1120, bullX: 80, bullW: 1120
      },
      /* 5 · SLATE MINIMAL — clean lines, light left panel */
      {
        name:'minimal',
        coverBg: function() {
          return '<rect width="1280" height="720" fill="#f8fafc"/>' +
            '<rect x="0" y="0" width="440" height="720" fill="#0f172a"/>' +
            '<rect x="440" y="0" width="4" height="720" fill="#6366f1"/>' +
            '<circle cx="220" cy="360" r="160" fill="#1e293b" opacity=".5"/>' +
            '<rect x="0" y="0" width="4" height="720" fill="#6366f1"/>';
        },
        contentBg: function() {
          return '<rect width="1280" height="720" fill="#f1f5f9"/>' +
            '<rect x="0" y="0" width="8" height="720" fill="#6366f1"/>' +
            '<rect x="0" y="0" width="1280" height="72" fill="#fff"/>' +
            '<rect x="0" y="72" width="1280" height="2" fill="#e2e8f0"/>';
        },
        accent:'#6366f1', text:'#1e293b', sub:'#475569',
        coverText:'#fff', coverSub:'rgba(255,255,255,0.7)',
        card:'rgba(99,102,241,0.08)', cardBorder:'#6366f1', num:'#6366f1',
        titleX: 500, titleW: 720, bullX: 60, bullW: 1160,
        light: true
      },
    ];

    function T(i) { return THEMES[i % THEMES.length]; }

    /* ── SVG background wrapper ─────────────────────────────────────── */
    function svgBg(innerSvg) {
      return '<svg style="position:absolute;inset:0;width:100%;height:100%;" viewBox="0 0 1280 720" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">' + innerSvg + '</svg>';
    }

    /* ── Cover slide ────────────────────────────────────────────────── */
    function renderCover(s, t) {
      var isLight = t.name === 'minimal';
      var tColor  = isLight ? (t.coverText || '#fff') : t.text;
      var sColor  = isLight ? (t.coverSub  || t.sub)  : t.sub;
      var tx = t.name === 'minimal' ? 500 : 100;
      var tw = t.name === 'minimal' ? 720 : 1080;

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(t.coverBg()) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;' +
          'padding:6% ' + Math.round(tx/12.8) + '% 6% ' + Math.round(tx/12.8) + '%;' +
          (t.name==='minimal' ? 'margin-left:36%;' : '') + '">' +
          '<div style="font-size:11px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:18px;opacity:.9;">01 / ' + String(total).padStart(2,'0') + '</div>' +
          '<div style="font-size:clamp(20px,3.6vw,44px);font-weight:900;color:' + tColor + ';line-height:1.15;margin-bottom:22px;text-shadow:0 2px 16px rgba(0,0,0,.3);">' + s.title + '</div>' +
          '<div style="width:56px;height:4px;border-radius:2px;background:' + t.accent + ';margin-bottom:20px;"></div>' +
          (s.bullets.length ? '<div style="font-size:clamp(12px,1.5vw,17px);color:' + sColor + ';line-height:1.8;">' + s.bullets.map(function(b){ return '· ' + b; }).join('<br>') + '</div>' : '') +
        '</div>' +
      '</div>';
    }

    /* ── Content slide ──────────────────────────────────────────────── */
    function renderContent(s, idx, t) {
      var isLight = t.light;
      var tColor  = isLight ? t.text : '#fff';
      var leftPad = t.name === 'corporate' || t.name === 'nature' ? '27%' : '5%';

      var bulletsHtml = s.bullets.map(function(b, bi) {
        return '<div class="f-up" style="display:flex;align-items:flex-start;gap:14px;padding:11px 16px;' +
          'background:' + t.card + ';border-radius:10px;border-left:3px solid ' + t.cardBorder + ';' +
          'animation-delay:' + (bi*0.08) + 's;margin-bottom:8px;">' +
          '<span style="font-size:12px;font-weight:900;color:' + t.num + ';flex-shrink:0;min-width:22px;margin-top:2px;">' + String(bi+1).padStart(2,'0') + '</span>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.35vw,15px);line-height:1.6;">' + b + '</span>' +
        '</div>';
      }).join('');

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(t.contentBg()) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:0 4% 3% ' + leftPad + ';">' +
          /* header row */
          '<div style="height:72px;display:flex;align-items:center;gap:14px;">' +
            '<span style="background:' + t.accent + ';color:#0f172a;font-size:11px;font-weight:900;padding:4px 12px;border-radius:20px;letter-spacing:1px;flex-shrink:0;">' + String(idx+1).padStart(2,'0') + ' / ' + String(total).padStart(2,'0') + '</span>' +
            '<h2 style="color:' + tColor + ';font-size:clamp(15px,2vw,24px);font-weight:800;margin:0;line-height:1.25;">' + s.title + '</h2>' +
          '</div>' +
          /* bullets */
          '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + bulletsHtml + '</div>' +
        '</div>' +
      '</div>';
    }

    /* ── Summary slide ──────────────────────────────────────────────── */
    function renderSummary(s, t) {
      var icons = ['✅','💡','🎯','📌','⭐','🔑','🚀'];
      var isLight = t.light;
      var tColor = isLight ? t.text : '#fff';

      var bulletsHtml = s.bullets.map(function(b, bi) {
        return '<div class="f-up" style="display:flex;align-items:center;gap:12px;padding:10px 16px;' +
          'background:' + t.card + ';border-radius:10px;animation-delay:' + (bi*0.08) + 's;margin-bottom:8px;">' +
          '<span style="font-size:18px;flex-shrink:0;">' + (icons[bi]||'▸') + '</span>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.3vw,14px);line-height:1.55;">' + b + '</span>' +
        '</div>';
      }).join('');

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(t.coverBg()) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5% 8%;text-align:center;">' +
          '<div style="font-size:11px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:14px;">Tóm tắt · ' + String(total).padStart(2,'0') + ' / ' + String(total).padStart(2,'0') + '</div>' +
          '<h2 style="color:' + (t.name==='minimal'?t.coverText||'#fff':tColor) + ';font-size:clamp(18px,2.6vw,34px);font-weight:900;margin:0 0 16px;line-height:1.2;">' + s.title + '</h2>' +
          '<div style="width:50px;height:4px;background:' + t.accent + ';border-radius:2px;margin-bottom:24px;"></div>' +
          '<div style="width:100%;max-width:680px;text-align:left;">' + bulletsHtml + '</div>' +
        '</div>' +
      '</div>';
    }

    /* ── Theme picker UI ────────────────────────────────────────────── */
    var pickerHtml = THEMES.map(function(t, i) {
      var labels = {corporate:'🏢 Corporate', ocean:'🌊 Ocean', nature:'🌿 Nature', sunset:'🌅 Sunset', creative:'✨ Creative', minimal:'⬜ Minimal'};
      return '<button onclick="setTheme(' + i + ')" id="theme-btn-' + i + '" ' +
        'style="padding:5px 12px;border-radius:20px;font-size:11px;font-weight:700;border:2px solid transparent;cursor:pointer;transition:all .15s;background:#f1f5f9;color:#475569;">' +
        (labels[t.name]||t.name) + '</button>';
    }).join('');
    document.getElementById('slide-dots').insertAdjacentHTML('beforebegin',
      '<div id="theme-picker" style="display:flex;gap:6px;flex-wrap:wrap;">' + pickerHtml + '</div>'
    );

    var activeThemeIdx = 0;
    window.setTheme = function(i) {
      activeThemeIdx = i;
      document.querySelectorAll('[id^="theme-btn-"]').forEach(function(b,j){
        b.style.background = j===i ? '#6366f1' : '#f1f5f9';
        b.style.color      = j===i ? '#fff'    : '#475569';
        b.style.borderColor= j===i ? '#6366f1' : 'transparent';
      });
      render();
    };
    setTheme(0);

    /* ── Render ─────────────────────────────────────────────────────── */
    function render() {
      if (!slides.length) return;
      var s = slides[current];
      var t = THEMES[activeThemeIdx];
      var isFirst = current === 0, isLast = current === total - 1;

      var html = isFirst ? renderCover(s, t) : isLast ? renderSummary(s, t) : renderContent(s, current, t);
      document.getElementById('slide-viewer').innerHTML = html;
      document.getElementById('slide-counter').textContent = (current+1) + ' / ' + total;

      var dots = document.getElementById('slide-dots');
      dots.innerHTML = slides.map(function(_, i) {
        return '<div style="width:' + (i===current?'18px':'6px') + ';height:6px;border-radius:3px;background:' + (i===current?'#6366f1':'#cbd5e1') + ';transition:all .2s;"></div>';
      }).join('');

      var noteEl = document.getElementById('slide-note');
      if (s.note) { document.getElementById('slide-note-text').textContent = s.note; noteEl.classList.remove('hidden'); }
      else { noteEl.classList.add('hidden'); }
    }

    window.prevSlide = function() { if (current > 0) { current--; render(); } };
    window.nextSlide = function() { if (current < total-1) { current++; render(); } };
    window.enterFullscreen = function() {
      var w = document.getElementById('slide-viewer').parentElement;
      (w.requestFullscreen || w.webkitRequestFullscreen || function(){}).call(w);
    };

    document.addEventListener('keydown', function(e) {
      if (e.key==='ArrowRight'||e.key==='ArrowDown') nextSlide();
      if (e.key==='ArrowLeft' ||e.key==='ArrowUp')   prevSlide();
    });
    var tx = null;
    document.getElementById('slide-viewer').addEventListener('touchstart', function(e){ tx = e.touches[0].clientX; });
    document.getElementById('slide-viewer').addEventListener('touchend', function(e){
      if (!tx) return;
      var dx = e.changedTouches[0].clientX - tx;
      if (dx < -40) nextSlide(); else if (dx > 40) prevSlide();
      tx = null;
    });

    render();
  })();
  </script>

<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nội dung được tạo bởi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='Đã sao chép!'; setTimeout(()=>this.textContent='Sao chép',2000)})"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        Sao chép
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>
