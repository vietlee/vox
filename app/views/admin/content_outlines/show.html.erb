    function layoutAgenda(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b, i) { var p = b.split('::'); return { num: p[0]||String(i+1).padStart(2,'0'), title: (p[1]||b).trim(), desc: (p[2]||'').trim() }; });
      }
      items = items.slice(0, 8);
