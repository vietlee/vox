<% content_for :title, @outline.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @outline.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "outline" => "📋 Dàn ý", "slide" => "🖥️ Slide", "slide_script" => "🖥️ Slide", "lesson_plan" => "📚 Kế hoạch buổi học" }[@outline.output_type] %></span>
      <% if @outline.subject.present? %><span>· <%= @outline.subject %></span><% end %>
      <span>· <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @outline.pptx_file.attached? %>
      <%= link_to rails_blob_path(@outline.pptx_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Tải PPTX
      <% end %>
    <% end %>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "flex items-center gap-1.5 px-3 py-2 bg-violet-50 hover:bg-violet-100 text-violet-700 text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Tạo lại
    <% end %>
  </div>
</div>

<% if @outline.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url: status_content_outline_path(@outline, format: :json),
        message: "AI đang tạo #{@outline.output_type == 'slide' ? 'slide' : 'nội dung'}...",
        submessage: "Đừng tắt trang này." %>
<% elsif @outline.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">⚠️</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2">Có lỗi xảy ra khi tạo nội dung</h3>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "mt-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer" do %>
      Thử lại
    <% end %>
  </div>
<% elsif @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.include?("slide-deck-root") %>
  <!-- Slide viewer -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="border-b border-slate-100 px-5 py-2.5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">🖥️ Slide thuyết trình</span>
        <!-- Progress dots -->
        <div id="slide-dots" class="flex gap-1"></div>
      </div>
      <button onclick="enterFullscreen()"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        ⛶ Toàn màn hình
      </button>
    </div>

    <!-- 16:9 aspect ratio wrapper -->
    <div style="position:relative; padding-bottom:56.25%; background:#0f172a; overflow:hidden;">
      <div id="slide-viewer" style="position:absolute; inset:0; overflow:hidden;"></div>
    </div>

    <div class="border-t border-slate-100 px-5 py-2.5 flex items-center justify-between bg-slate-50">
      <button onclick="prevSlide()"
              style="border:1px solid #e2e8f0;"
              class="px-4 py-2 bg-white rounded-xl text-[13px] font-semibold text-slate-600 hover:bg-slate-100 transition-colors cursor-pointer shadow-sm">
        ← Trước
      </button>
      <span id="slide-counter" class="text-[12px] text-slate-500 font-semibold"></span>
      <button onclick="nextSlide()"
              class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-xl text-[13px] font-bold text-white transition-colors border-0 cursor-pointer shadow-sm">
        Tiếp →
      </button>
    </div>
    <div id="slide-note" class="hidden border-t border-slate-100 px-5 py-3 bg-amber-50">
      <div class="text-[10px] font-bold text-amber-600 uppercase tracking-wide mb-1">💬 Ghi chú người trình bày</div>
      <p id="slide-note-text" class="text-[13px] text-amber-800 leading-relaxed"></p>
    </div>
  </div>

  <div id="slide-data" class="hidden"><%= raw @outline.content %></div>

  <style>
    #slide-viewer * { box-sizing:border-box; }
    @keyframes sIn { from{opacity:0;transform:translateX(28px)} to{opacity:1;transform:translateX(0)} }
    @keyframes fUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    .s-in { animation:sIn .38s cubic-bezier(.22,.68,0,1.2) forwards; }
    .f-up { animation:fUp .3s ease both; }
  </style>

  <script>
  (function() {
    var el = document.getElementById('slide-data').querySelector('#slide-deck-root');
    var slides = JSON.parse(el.dataset.slides || '[]');
    var current = 0, total = slides.length;

    /* ─────────────────────────────────────────────────────────────────
       SVG DEFS shared across themes  (blur filter for glow blobs)
    ───────────────────────────────────────────────────────────────── */
    var DEFS = '<defs>' +
      '<filter id="blur60" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="60"/></filter>' +
      '<filter id="blur40" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="40"/></filter>' +
      '<filter id="blur80" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="80"/></filter>' +
      '<filter id="blur100" x="-60%" y="-60%" width="220%" height="220%"><feGaussianBlur stdDeviation="100"/></filter>' +
      '<filter id="glow"   x="-40%" y="-40%" width="180%" height="180%">' +
        '<feGaussianBlur stdDeviation="8" result="blur"/>' +
        '<feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>' +
      '</filter>' +
      '<filter id="glow-strong" x="-60%" y="-60%" width="220%" height="220%">' +
        '<feGaussianBlur stdDeviation="16" result="blur"/>' +
        '<feMerge><feMergeNode in="blur"/><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>' +
      '</filter>' +
      /* dot grid */ '<pattern id="dots" width="32" height="32" patternUnits="userSpaceOnUse">' +
        '<circle cx="2" cy="2" r="1.2" fill="rgba(255,255,255,0.12)"/>' +
      '</pattern>' +
      /* fine grid */ '<pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">' +
        '<path d="M60,0 L0,0 0,60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>' +
      '</pattern>' +
      /* blueprint grid */ '<pattern id="blueprint-grid" width="40" height="40" patternUnits="userSpaceOnUse">' +
        '<path d="M40,0 L0,0 0,40" fill="none" stroke="rgba(100,180,255,0.15)" stroke-width="0.8"/>' +
        '<path d="M0,20 L40,20 M20,0 L20,40" fill="none" stroke="rgba(100,180,255,0.06)" stroke-width="0.5"/>' +
      '</pattern>' +
      /* scanlines */ '<pattern id="scanlines" width="1" height="4" patternUnits="userSpaceOnUse">' +
        '<rect width="1" height="2" fill="rgba(0,0,0,0.18)"/>' +
      '</pattern>' +
      /* memphis dots */ '<pattern id="memphis-dots" width="24" height="24" patternUnits="userSpaceOnUse">' +
        '<circle cx="12" cy="12" r="2.5" fill="rgba(0,0,0,0.07)"/>' +
      '</pattern>' +
      /* diagonal hatch */ '<pattern id="hatch" width="10" height="10" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">' +
        '<line x1="0" y1="0" x2="0" y2="10" stroke="rgba(0,0,0,0.06)" stroke-width="3"/>' +
      '</pattern>' +
      /* iridescent gradient */ '<linearGradient id="holo1" x1="0%" y1="0%" x2="100%" y2="100%">' +
        '<stop offset="0%"   stop-color="#ff6ef7"/>' +
        '<stop offset="25%"  stop-color="#7ef7ff"/>' +
        '<stop offset="50%"  stop-color="#7fffb2"/>' +
        '<stop offset="75%"  stop-color="#ffe57e"/>' +
        '<stop offset="100%" stop-color="#ff7eb3"/>' +
      '</linearGradient>' +
      '<linearGradient id="gold-grad" x1="0%" y1="0%" x2="100%" y2="100%">' +
        '<stop offset="0%"   stop-color="#f5c842"/>' +
        '<stop offset="40%"  stop-color="#fff8dc"/>' +
        '<stop offset="100%" stop-color="#c8960c"/>' +
      '</linearGradient>' +
      '<linearGradient id="sunset-grad" x1="0%" y1="0%" x2="100%" y2="100%">' +
        '<stop offset="0%"   stop-color="#f97316"/>' +
        '<stop offset="40%"  stop-color="#ec4899"/>' +
        '<stop offset="100%" stop-color="#8b5cf6"/>' +
      '</linearGradient>' +
      /* fine grid old compat */ '<pattern id="grid-old" width="60" height="60" patternUnits="userSpaceOnUse">' +
        '<path d="M60,0 L0,0 0,60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>' +
      '</pattern>' +
    '</defs>';

    /* ─────────────────────────────────────────────────────────────────
       6 MODERN THEMES
    ───────────────────────────────────────────────────────────────── */
    var THEMES = [

      /* ── 0  AURORA MESH ── soft glow blobs on deep navy ── */
      {
        label: '🌌 Aurora',
        accent: '#e879f9', accentAlt: '#67e8f9', num: '#e879f9',
        text: '#fff', sub: 'rgba(255,255,255,.65)',
        glass: 'rgba(255,255,255,0.07)', glassBorder: 'rgba(255,255,255,0.15)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#06071a"/>' +
            /* mesh blobs */
            '<ellipse cx="200"  cy="160"  rx="340" ry="280" fill="#7c3aed" filter="url(#blur80)" opacity=".7"/>' +
            '<ellipse cx="1100" cy="560"  rx="380" ry="300" fill="#0891b2" filter="url(#blur80)" opacity=".65"/>' +
            '<ellipse cx="780"  cy="80"   rx="260" ry="200" fill="#db2777" filter="url(#blur60)" opacity=".55"/>' +
            '<ellipse cx="400"  cy="650"  rx="200" ry="160" fill="#4f46e5" filter="url(#blur60)" opacity=".5"/>' +
            '<rect width="1280" height="720" fill="url(#dots)"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#06071a"/>' +
            '<ellipse cx="120"  cy="100"  rx="250" ry="200" fill="#7c3aed" filter="url(#blur60)" opacity=".6"/>' +
            '<ellipse cx="1180" cy="620"  rx="280" ry="220" fill="#0891b2" filter="url(#blur60)" opacity=".5"/>' +
            '<rect width="1280" height="720" fill="url(#dots)"/>' +
            /* header glass bar */
            '<rect x="0" y="0" width="1280" height="76" fill="rgba(255,255,255,0.04)"/>' +
            '<rect x="0" y="76" width="1280" height="1" fill="rgba(255,255,255,0.1)"/>';
        },
        coverLayout: 'center',
      },

      /* ── 1  NEON GRID ── dark bg, cyan/green neon with grid ── */
      {
        label: '⚡ Neon',
        accent: '#00f5c4', accentAlt: '#b9ff66', num: '#00f5c4',
        text: '#fff', sub: 'rgba(255,255,255,.6)',
        glass: 'rgba(0,245,196,0.07)', glassBorder: 'rgba(0,245,196,0.25)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#050d0a"/>' +
            '<rect width="1280" height="720" fill="url(#grid)"/>' +
            /* neon glow orbs */
            '<circle cx="140"  cy="360" r="200" fill="#00f5c4" filter="url(#blur80)" opacity=".25"/>' +
            '<circle cx="1140" cy="360" r="200" fill="#b9ff66" filter="url(#blur80)" opacity=".2"/>' +
            '<circle cx="640"  cy="700" r="180" fill="#00f5c4" filter="url(#blur60)" opacity=".15"/>' +
            /* neon horizontal lines */
            '<line x1="0" y1="2"   x2="1280" y2="2"   stroke="#00f5c4" stroke-width="2" opacity=".8" filter="url(#glow)"/>' +
            '<line x1="0" y1="718" x2="1280" y2="718" stroke="#00f5c4" stroke-width="2" opacity=".8" filter="url(#glow)"/>' +
            /* vertical accent */
            '<line x1="100" y1="0" x2="100" y2="720" stroke="#00f5c4" stroke-width="1" opacity=".2"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#050d0a"/>' +
            '<rect width="1280" height="720" fill="url(#grid)"/>' +
            '<circle cx="640" cy="-100" r="300" fill="#00f5c4" filter="url(#blur80)" opacity=".18"/>' +
            '<line x1="0" y1="76" x2="1280" y2="76" stroke="#00f5c4" stroke-width="1.5" opacity=".6" filter="url(#glow)"/>' +
            '<line x1="0" y1="2"  x2="1280" y2="2"  stroke="#00f5c4" stroke-width="2"   opacity=".9" filter="url(#glow)"/>';
        },
        coverLayout: 'center',
      },

      /* ── 2  GLASS VIOLET ── vivid purple gradient + glassmorphism ── */
      {
        label: '💎 Glass',
        accent: '#fff', accentAlt: '#f0abfc', num: '#f0abfc',
        text: '#fff', sub: 'rgba(255,255,255,.7)',
        glass: 'rgba(255,255,255,0.12)', glassBorder: 'rgba(255,255,255,0.25)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#3b0764"/>' +
            /* gradient fill via radial blobs */
            '<circle cx="0"    cy="0"   r="500" fill="#7e22ce" filter="url(#blur80)" opacity=".9"/>' +
            '<circle cx="1280" cy="720" r="500" fill="#1d4ed8" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="640"  cy="360" r="300" fill="#a21caf" filter="url(#blur80)" opacity=".4"/>' +
            /* glass card outline on cover */
            '<rect x="80" y="160" width="560" height="400" rx="24" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#3b0764"/>' +
            '<circle cx="0"    cy="0"   r="400" fill="#7e22ce" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="1280" cy="720" r="400" fill="#1d4ed8" filter="url(#blur80)" opacity=".7"/>' +
            '<rect x="0" y="0" width="1280" height="78" fill="rgba(255,255,255,0.08)"/>' +
            '<rect x="0" y="78" width="1280" height="1" fill="rgba(255,255,255,0.18)"/>';
        },
        coverLayout: 'left-card',
      },

      /* ── 3  BOLD INK ── near-black, huge faded watermark text, warm accent ── */
      {
        label: '🖤 Bold',
        accent: '#facc15', accentAlt: '#fb923c', num: '#facc15',
        text: '#fff', sub: 'rgba(255,255,255,.55)',
        glass: 'rgba(250,204,21,0.08)', glassBorder: 'rgba(250,204,21,0.3)',
        coverBg: function(title) {
          var safe = (title || '').replace(/[<>&"]/g,'').substring(0,18).toUpperCase();
          return DEFS +
            '<rect width="1280" height="720" fill="#0a0a0a"/>' +
            /* big watermark word */
            '<text x="640" y="480" text-anchor="middle" font-size="320" font-weight="900" fill="#1a1a1a" font-family="system-ui,sans-serif" letter-spacing="-10">' + safe + '</text>' +
            /* diagonal accent stripe */
            '<polygon points="900,0 1280,0 1280,200 980,0" fill="#facc15" opacity=".08"/>' +
            '<polygon points="960,0 1280,0 1280,80"  fill="#facc15" opacity=".15"/>' +
            '<line x1="0" y1="0" x2="0" y2="720" stroke="#facc15" stroke-width="6"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#0a0a0a"/>' +
            '<rect x="0" y="0" width="6" height="720" fill="#facc15"/>' +
            '<rect x="0" y="0" width="1280" height="76" fill="#111"/>' +
            '<rect x="0" y="76" width="1280" height="1" fill="#222"/>';
        },
        coverLayout: 'left',
        coverWatermark: true,
      },

      /* ── 4  CORAL DUSK ── warm gradient, fluid curves, clean modern ── */
      {
        label: '🌇 Coral',
        accent: '#fda4af', accentAlt: '#fed7aa', num: '#fb7185',
        text: '#fff', sub: 'rgba(255,255,255,.65)',
        glass: 'rgba(255,255,255,0.1)', glassBorder: 'rgba(255,200,180,0.3)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#881337"/>' +
            '<circle cx="0"    cy="0"   r="500" fill="#be123c" filter="url(#blur80)" opacity=".9"/>' +
            '<circle cx="1280" cy="720" r="400" fill="#c2410c" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="800"  cy="200" r="300" fill="#e11d48" filter="url(#blur60)" opacity=".4"/>' +
            /* fluid curve */
            '<path d="M0,500 C320,420 640,580 1280,460 L1280,720 L0,720 Z" fill="rgba(0,0,0,0.2)"/>' +
            '<path d="M0,540 C400,460 840,580 1280,500 L1280,720 L0,720 Z" fill="rgba(0,0,0,0.15)"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#881337"/>' +
            '<circle cx="0"    cy="0"   r="350" fill="#be123c" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="1280" cy="720" r="300" fill="#c2410c" filter="url(#blur80)" opacity=".7"/>' +
            '<rect x="0" y="0" width="1280" height="76" fill="rgba(0,0,0,0.2)"/>' +
            '<rect x="0" y="76" width="1280" height="1" fill="rgba(255,255,255,0.15)"/>';
        },
        coverLayout: 'center',
      },

      /* ── 5  PURE LIGHT ── white, editorial, modern minimal ── */
      {
        label: '☀️ Light',
        accent: '#6366f1', accentAlt: '#ec4899', num: '#6366f1',
        text: '#0f172a', sub: '#64748b',
        glass: 'rgba(99,102,241,0.06)', glassBorder: 'rgba(99,102,241,0.2)',
        light: true,
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#fff"/>' +
            '<rect x="0" y="0" width="420" height="720" fill="#f8faff"/>' +
            '<rect x="420" y="0" width="2" height="720" fill="#e0e7ff"/>' +
            '<rect x="0" y="0" width="420" height="6" fill="#6366f1"/>' +
            '<circle cx="210" cy="480" r="280" fill="#eef2ff" opacity=".8"/>' +
            '<circle cx="210" cy="480" r="140" fill="#e0e7ff" opacity=".5"/>' +
            '<circle cx="210" cy="480" r="60"  fill="#c7d2fe" opacity=".4"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#fff"/>' +
            '<rect x="0" y="0" width="1280" height="76" fill="#f8faff"/>' +
            '<rect x="0" y="76" width="1280" height="2" fill="#e0e7ff"/>' +
            '<rect x="0" y="0" width="4" height="76" fill="#6366f1"/>';
        },
        coverLayout: 'left-panel',
      },

      /* ── 6  HOLOGRAPHIC ── iridescent mesh, white glassy ── */
      {
        label: '🌈 Holo',
        accent: '#a855f7', accentAlt: '#06b6d4', num: '#a855f7',
        text: '#0f172a', sub: '#334155',
        glass: 'rgba(255,255,255,0.55)', glassBorder: 'rgba(255,255,255,0.8)',
        numBg: '#a855f7', numColor: '#fff',
        cardStyle: 'background:rgba(255,255,255,0.55);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,0.8);border-radius:14px;',
        light: true,
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#fff"/>' +
            /* large iridescent blobs */
            '<ellipse cx="200"  cy="200"  rx="420" ry="320" fill="#f0abfc" filter="url(#blur100)" opacity=".55"/>' +
            '<ellipse cx="1100" cy="500"  rx="400" ry="300" fill="#67e8f9" filter="url(#blur100)" opacity=".5"/>' +
            '<ellipse cx="640"  cy="100"  rx="300" ry="200" fill="#fde68a" filter="url(#blur80)"  opacity=".4"/>' +
            '<ellipse cx="900"  cy="650"  rx="280" ry="200" fill="#86efac" filter="url(#blur80)"  opacity=".4"/>' +
            '<ellipse cx="100"  cy="600"  rx="220" ry="180" fill="#c4b5fd" filter="url(#blur80)"  opacity=".45"/>' +
            /* shimmer overlay */
            '<rect width="1280" height="720" fill="url(#holo1)" opacity=".06"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#f8faff"/>' +
            '<ellipse cx="100"  cy="100"  rx="300" ry="240" fill="#f0abfc" filter="url(#blur80)" opacity=".45"/>' +
            '<ellipse cx="1200" cy="620"  rx="280" ry="220" fill="#67e8f9" filter="url(#blur80)" opacity=".4"/>' +
            '<ellipse cx="700"  cy="760"  rx="300" ry="180" fill="#fde68a" filter="url(#blur80)" opacity=".3"/>' +
            '<rect width="1280" height="720" fill="rgba(255,255,255,0.3)"/>' +
            '<rect x="0" y="0" width="1280" height="76" fill="rgba(255,255,255,0.6)"/>' +
            '<rect x="0" y="76" width="1280" height="1.5" fill="rgba(168,85,247,0.3)"/>';
        },
        coverLayout: 'center',
      },

      /* ── 7  NEOBRUTALISM ── flat yellow, thick black borders, offset shadows ── */
      {
        label: '💥 Neo',
