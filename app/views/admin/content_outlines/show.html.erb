            <style>@keyframes spin{to{transform:rotate(360deg)}}</style>
            <!-- Confirm sub-dialog (replaces browser confirm()) -->
            <div id="share-confirm" style="display:none;position:absolute;inset:0;background:rgba(15,23,42,.75);border-radius:18px;z-index:10;align-items:center;justify-content:center;pointer-events:none;">
              <div style="background:#0f172a;border:1px solid #334155;border-radius:14px;padding:24px 22px;max-width:300px;width:90%;text-align:center;">
                <div id="share-confirm-title" style="font-size:14px;font-weight:700;color:#fff;margin-bottom:8px;"></div>
                <div id="share-confirm-body" style="font-size:12px;color:#94a3b8;line-height:1.5;margin-bottom:20px;"></div>
                <div style="display:flex;gap:10px;justify-content:center;">
                  <button id="share-confirm-cancel" style="background:#334155;color:#cbd5e1;border:none;border-radius:9px;padding:8px 20px;font-size:13px;font-weight:600;cursor:pointer;">Huỷ</button>
                  <button id="share-confirm-ok" style="background:#1e3a5f;color:#fff;border:none;border-radius:9px;padding:8px 20px;font-size:13px;font-weight:700;cursor:pointer;">Xác nhận</button>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div id="dup-slide-modal" style="display:none;position:fixed;inset:0;z-index:20000;background:rgba(0,0,0,.5);align-items:center;justify-content:center;">
