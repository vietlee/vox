            </button>
            <div id="tt-bg-panel" style="display:none;position:absolute;right:0;top:calc(100%+6px);z-index:10200;background:#1e293b;border-radius:12px;padding:10px;box-shadow:0 8px 28px rgba(0,0,0,.45);min-width:200px;">
              <div style="font-size:9px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:7px;">Nền block</div>
