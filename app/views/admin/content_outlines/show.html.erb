      var cols = 2;
      var rows = Math.ceil(n / cols);
      var gapX = 3, gapY = 3.56;
      var colW = 43.5;
      var cardH = rows === 1 ? 49.78 : 27.56;
      var html = '';
      items.forEach(function(it, i) {
        var ac = accents[i % accents.length];
        var bg = cbgs[i % cbgs.length];
        var ic = pickIcon((it.title||'') + ' ' + (it.bullets||[]).join(' '), it.icon);
        var col = i % cols, row = Math.floor(i / cols);
