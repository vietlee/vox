                <div style="display:flex;gap:8px;">
                  <button id="share-copy-qr-btn" onclick="copyQrImage(document.getElementById('share-qr-img'), this)" style="background:#334155;color:#cbd5e1;border:none;border-radius:8px;padding:6px 12px;font-size:11px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:5px;white-space:nowrap;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>Copy QR
                  </button>
                  <button onclick="downloadQrImage()" style="background:#334155;color:#cbd5e1;border:none;border-radius:8px;padding:6px 12px;font-size:11px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:5px;white-space:nowrap;">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Tải QR
                  </button>
                </div>
              </div>
              <div style="display:flex;gap:8px;border-top:1px solid #334155;padding-top:14px;">
                <button onclick="regenerateShareLink()" id="share-regen-btn" style="flex:1;background:#334155;border:none;color:#cbd5e1;border-radius:10px;padding:9px;font-size:12px;font-weight:600;cursor:pointer;">🔄 Tạo link mới</button>
                <button onclick="revokeShareLink()" style="background:#7f1d1d;border:none;color:#fca5a5;border-radius:10px;padding:9px 14px;font-size:12px;font-weight:600;cursor:pointer;">🚫 Thu hồi</button>
                <button onclick="closeShareDialog()" style="background:#1e293b;border:1px solid #334155;color:#94a3b8;border-radius:10px;padding:9px 14px;font-size:12px;cursor:pointer;">Đóng</button>
              </div>
            </div>
            <!-- Loading / auto-creating -->
            <div id="share-loading" style="display:<%= @outline.share_token.present? ? 'none' : 'block' %>;text-align:center;padding:24px 0;">
