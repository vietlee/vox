    /* ═══════════════════════════════════════════════════════════════════
       COVER — absolute positioning matching generate_pptx.py exactly
       PPTX: LM=0.60", CW=8.80", SW=10.00", SH=5.625"
    ═══════════════════════════════════════════════════════════════════ */
    function renderCover(s, t) {
      var sty = s.style || {};
      var coverStyle = sty.cover_style || 'left';
      var isDark = (sty.bg || 'dark') === 'dark';
      var cat = sty.category || '';
      var ic = pickIcon((s.title||'') + ' ' + (s.subtitle||''), sty.icon);

      var bg = isDark ? t.cover_bg : t.content_bg;
      var titleColor = isDark ? '#fff' : t.primary_dk;
      var subColor = isDark ? t.primary_xl : '#5B6478';
      var iconBg = isDark ? t.primary_lt : t.primary_xl;
      var bulletColor = isDark ? '#fff' : t.primary_dk;
      var bulletSep = isDark ? t.primary_xl : '#5B6478';

      /* SVG background with decorative circles */
      var bgSvg = DEFS + '<rect width="1280" height="720" fill="' + bg + '"/>';
      if (isDark && coverStyle !== 'minimal') {
        bgSvg += '<circle cx="1280" cy="128" r="374" fill="' + t.primary + '" opacity=".45"/>';
        bgSvg += '<circle cx="1296" cy="576" r="216" fill="' + t.primary_dk + '" opacity=".7"/>';
      }

      var els = '';

      function bulletBar() {
        if (!s.bullets || !s.bullets.length) return '';
        var align = coverStyle === 'centered' ? 'center' : 'left';
        var bx = coverStyle === 'centered' ? X(1.5) : X(0.90);
        var bw = coverStyle === 'centered' ? W(7.0) : W(6.0);
        var barHtml = coverStyle !== 'centered'
          ? '<div style="position:absolute;left:' + X(0.70) + ';top:' + Y(4.55) + ';width:3px;height:' + H(0.40) + ';background:' + (isDark?'#fff':t.primary_dk) + ';border-radius:2px;"></div>' : '';
        var parts = s.bullets.slice(0,3).map(function(bt, bi) {
          var sep = bi > 0 ? '<span style="color:' + bulletSep + ';margin:0 8px;">·</span>' : '';
          return sep + '<span style="font-weight:' + (bi===0?'700':'400') + ';color:' + bulletColor + ';">' + bt + '</span>';
        }).join('');
        return barHtml + '<div style="position:absolute;left:' + bx + ';top:' + Y(4.55) + ';width:' + bw + ';height:' + H(0.40) + ';display:flex;align-items:center;justify-content:' + (align==='center'?'center':'flex-start') + ';font-size:clamp(10px,1.2vw,13px);font-family:Calibri,sans-serif;z-index:2;">' + parts + '</div>';
      }

      if (coverStyle === 'centered') {
        /* Icon centered */
        var iconSz = 9.78; /* 1.10" as % of 10" width ≈ 11% but let's use height-relative */
        els += '<div style="position:absolute;left:50%;top:' + Y(0.50) + ';transform:translateX(-50%);width:' + W(1.10) + ';height:0;padding-bottom:' + H(1.10) + ';border-radius:18%;background:' + iconBg + ';z-index:2;">' +
          '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:50%;height:50%;">' + iconSvg(ic) + '</div></div>';
        if (cat) els += '<div style="position:absolute;left:' + X(0.50) + ';top:' + Y(1.80) + ';width:' + W(9.0) + ';font-size:clamp(9px,1.1vw,12px);font-weight:700;color:' + t.accent + ';text-align:center;letter-spacing:2px;z-index:2;">' + cat + '</div>';
        var tY = cat ? Y(2.10) : Y(1.80);
        els += '<div style="position:absolute;left:' + X(0.50) + ';top:' + tY + ';width:' + W(9.0) + ';height:' + H(1.30) + ';display:flex;align-items:flex-start;justify-content:center;z-index:2;">' +
          '<span style="font-size:clamp(24px,4vw,44px);font-weight:900;color:' + titleColor + ';text-align:center;line-height:1.1;font-family:Calibri,sans-serif;">' + s.title + '</span></div>';
        if (s.subtitle) els += '<div style="position:absolute;left:' + X(1.0) + ';top:' + Y(3.30) + ';width:' + W(8.0) + ';font-size:clamp(12px,1.5vw,18px);color:' + subColor + ';text-align:center;z-index:2;">' + s.subtitle + '</div>';
        els += bulletBar();

      } else if (coverStyle === 'minimal') {
        els += '<div style="position:absolute;left:' + X(0.80) + ';top:' + Y(1.20) + ';width:' + W(8.0) + ';height:' + H(1.80) + ';display:flex;align-items:flex-start;z-index:2;">' +
          '<span style="font-size:clamp(24px,4vw,44px);font-weight:900;color:' + titleColor + ';line-height:1.1;font-family:Calibri,sans-serif;">' + s.title + '</span></div>';
        if (s.subtitle) els += '<div style="position:absolute;left:' + X(0.80) + ';top:' + Y(3.10) + ';width:' + W(7.0) + ';font-size:clamp(12px,1.5vw,18px);color:' + subColor + ';z-index:2;">' + s.subtitle + '</div>';
        if (cat) els += '<div style="position:absolute;left:' + X(0.80) + ';top:' + Y(4.20) + ';font-size:clamp(9px,1.1vw,12px);font-weight:700;color:' + t.accent + ';letter-spacing:2px;z-index:2;">' + cat + '</div>';
        els += bulletBar();

      } else {
        /* LEFT (default) */
        els += '<div style="position:absolute;left:' + X(0.70) + ';top:' + Y(0.65) + ';width:' + W(0.90) + ';height:0;padding-bottom:' + H(0.90) + ';border-radius:15%;background:' + iconBg + ';z-index:2;">' +
          '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:50%;height:50%;">' + iconSvg(ic) + '</div></div>';
        if (cat) els += '<div style="position:absolute;left:' + X(0.70) + ';top:' + Y(1.75) + ';width:' + W(3.0) + ';font-size:clamp(9px,1.1vw,12px);font-weight:700;color:' + t.accent + ';letter-spacing:1px;z-index:2;">' + cat + '</div>';
        var tY2 = cat ? Y(2.05) : Y(1.75);
        els += '<div style="position:absolute;left:' + X(0.65) + ';top:' + tY2 + ';width:' + W(7.50) + ';height:' + H(1.30) + ';display:flex;align-items:flex-start;z-index:2;">' +
          '<span style="font-size:clamp(24px,4vw,44px);font-weight:900;color:' + titleColor + ';line-height:1.1;font-family:Calibri,sans-serif;">' + s.title + '</span></div>';
        if (s.subtitle) els += '<div style="position:absolute;left:' + X(0.68) + ';top:' + Y(3.25) + ';width:' + W(7.20) + ';font-size:clamp(12px,1.5vw,18px);color:' + subColor + ';z-index:2;">' + s.subtitle + '</div>';
        els += bulletBar();
      }

      /* footer */
      if (s.footer) els += '<div style="position:absolute;left:' + X(0.65) + ';top:' + Y(5.625 - 0.48) + ';width:' + W(7.0) + ';font-size:clamp(8px,1vw,10px);color:' + (isDark ? t.primary_lt : '#5B6478') + ';z-index:2;">' + s.footer + '</div>';

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) + els + '</div>';
    }

    /* ═══════════════════════════════════════════════════════════════════
       CONTENT SLIDE HEADER — matching _setup_content_slide in PPTX
       White bg, centered category at y=0.35", title at y=0.68"
    ═══════════════════════════════════════════════════════════════════ */
    function contentHeader(s, t) {
      var sty = s.style || {};
      var cat = sty.category || '';
      var accents = t.card_icons;
      var html = '';
      if (cat) html += '<div style="position:absolute;left:0;top:' + Y(0.35) + ';width:100%;height:' + H(0.30) + ';display:flex;align-items:center;justify-content:center;font-size:clamp(9px,1.1vw,12px);font-weight:700;color:' + accents[0] + ';letter-spacing:3px;text-transform:uppercase;z-index:2;">' + cat.toUpperCase() + '</div>';
      html += '<div style="position:absolute;left:0;top:' + Y(0.68) + ';width:100%;height:' + H(0.55) + ';display:flex;align-items:center;justify-content:center;z-index:2;">' +
        '<span style="font-size:clamp(14px,1.8vw,22px);font-weight:800;color:#1F2A44;text-align:center;font-family:Calibri,sans-serif;">' + s.title + '</span></div>';
      return html;
    }

    /* ═══════════════════════════════════════════════════════════════════
       LAYOUT FUNCTIONS — use absolute positioning matching PPTX inches
       Content area starts at y=1.70" (30.22%), left margin 0.60" (6%)
       Content width (CW) = 8.80" (88%), bottom at ~5.12" (91%)
    ═══════════════════════════════════════════════════════════════════ */
    var LM = 6;       /* left margin % */
    var CW = 88;      /* content width % */
    var CT = 30.22;   /* content top % (y=1.70") */
    var CB = 91.11;   /* content bottom % (y=5.12") */

    function layoutBullets(s, t) {
      var b_items = s.bullet_items || [];
      var bullets = s.bullets || [];
      var accents = t.card_icons;
      var cbgs = t.card_bgs;
      var html = '';

      if (b_items.length === 3) {
        var gap = 3;
        var colW = 28;
        b_items.forEach(function(it, i) {
          var ac = accents[i % accents.length];
          var bg = cbgs[i % cbgs.length];
          var ic = pickIcon((it.title||'') + ' ' + (it.desc||''), it.icon);
          var x = LM + i * (colW + gap);
          var cardH = s.note ? 37.33 : 45.33;
          html += '<div class="f-up" style="position:absolute;left:' + x + '%;top:' + (CT+1.78) + '%;width:' + colW + '%;height:' + cardH + '%;border-radius:8px;background:' + bg + ';animation-delay:' + (i*0.08) + 's;z-index:2;">' +
            '<div style="display:flex;flex-direction:column;align-items:center;padding-top:10%;text-align:center;height:100%;box-sizing:border-box;">' +
              iconCircle(ic, ac, 44) +
              '<div style="font-size:clamp(10px,1.2vw,13px);font-weight:700;color:#1F2A44;margin-top:8%;line-height:1.2;">' + (it.title||'') + '</div>' +
              (it.desc ? '<div style="font-size:clamp(8px,1vw,10px);color:#5B6478;line-height:1.5;margin-top:4%;padding:0 8%;">' + it.desc + '</div>' : '') +
            '</div>' +
          '</div>';
        });
      } else if (b_items.length >= 2) {
        var n = Math.min(b_items.length, 6);
        var availH = (s.note ? 77.33 : CB) - CT - 2.67;
        var rowH = Math.min(15.11, availH / n);
        b_items.slice(0,6).forEach(function(it, i) {
          var ac = accents[i % accents.length];
          var ic = pickIcon((it.title||'') + ' ' + (it.desc||''), it.icon);
          var y = CT + 2.67 + i * rowH;
          html += '<div class="f-up" style="position:absolute;left:' + LM + '%;top:' + y + '%;width:' + CW + '%;display:flex;align-items:flex-start;gap:12px;animation-delay:' + (i*0.07) + 's;z-index:2;">' +
            iconCircle(ic, ac, 38) +
            '<div style="flex:1;">' +
              '<div style="font-size:clamp(10px,1.2vw,13px);font-weight:700;color:#1F2A44;line-height:1.2;">' + (it.title||'') + '</div>' +
              (it.desc ? '<div style="font-size:clamp(8px,1vw,10px);color:#5B6478;line-height:1.5;margin-top:2px;">' + it.desc + '</div>' : '') +
            '</div>' +
          '</div>';
        });
      } else if (bullets.length && bullets.length <= 3) {
        var n2 = bullets.length;
        var gap2 = 2;
        var cw2 = (CW - gap2 * (n2-1)) / n2;
        bullets.slice(0,n2).forEach(function(b, i) {
          var ac = accents[i % accents.length];
          var ic = pickIcon(b);
          var x2 = LM + 2.5 + i * (cw2 + gap2);
          html += '<div class="f-up" style="position:absolute;left:' + x2 + '%;top:' + (CT+10) + '%;width:' + (cw2-5) + '%;z-index:2;display:flex;flex-direction:column;align-items:center;text-align:center;animation-delay:' + (i*0.08) + 's;">' +
            '<div style="margin-bottom:8px;">' + iconCircle(ic, ac, 40) + '</div>' +
            '<div style="font-size:clamp(11px,1.3vw,14.5px);font-weight:700;color:' + t.primary_dk + ';line-height:1.3;">' + b + '</div>' +
          '</div>';
        });
      } else {
        var rowH2 = 11.56;
        bullets.slice(0,8).forEach(function(b, i) {
          var ac = accents[i % accents.length];
          var ic = pickIcon(b);
          var y2 = CT + i * rowH2;
          if (y2 + 8.89 > CB) return;
          html += '<div class="f-up" style="position:absolute;left:' + (LM+1.6) + '%;top:' + (y2+1.78) + '%;display:flex;align-items:center;gap:10px;z-index:2;animation-delay:' + (i*0.07) + 's;">' +
            iconCircle(ic, ac, 32) +
            '<span style="font-size:clamp(10px,1.2vw,13px);font-weight:700;color:' + t.primary_dk + ';">' + b + '</span>' +
          '</div>';
        });
      }
      return html;
    }

    function layoutStats(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) { var p = b.split('::'); return { value: (p[0]||'').trim(), label: (p[1]||b).trim() }; });
      }
      var n = Math.min(items.length, 4);
      var accents = t.card_icons;
      var html = '';
      /* 2x2 grid */
      var gapX = 1.5, gapY = 2.67;
      var cols = n <= 2 ? n : 2;
      var cardW2 = (CW - gapX * (cols-1)) / cols;
      var rows = Math.ceil(n / cols);
      var cardH2 = rows === 1 ? 35.56 : 24;
      items.slice(0,4).forEach(function(it, i) {
        var ac = accents[i % accents.length];
        var col = i % cols, row = Math.floor(i / cols);
        var x = LM + col * (cardW2 + gapX);
        var y = CT + row * (cardH2 + gapY);
        html += '<div class="f-up" style="position:absolute;left:' + x + '%;top:' + y + '%;width:' + cardW2 + '%;height:' + cardH2 + '%;border-radius:8px;background:' + t.primary_dk + ';overflow:hidden;z-index:2;animation-delay:' + (i*0.08) + 's;">' +
          '<div style="position:absolute;left:0;top:0;bottom:0;width:6px;background:' + ac + ';"></div>' +
          '<div style="padding:6% 8% 6% 10%;">' +
            '<div style="font-size:clamp(18px,2.5vw,' + (String(it.value||'').length > 6 ? '28' : '34') + 'px);font-weight:900;color:#fff;line-height:1;">' + (it.value||'—') + '</div>' +
            '<div style="font-size:clamp(8px,0.9vw,10px);color:' + t.primary_xl + ';margin-top:6%;line-height:1.4;">' + (it.label||'') + '</div>' +
          '</div></div>';
      });
      return html;
    }

    function layoutChart(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) { var p = b.split('::'); return { value: parseInt(p[0])||0, label: (p[1]||b).trim() }; });
      }
      items = items.slice(0, 8);
      var maxVal = Math.max.apply(null, items.map(function(i){ return i.value||0; })) || 1;
      var accents = t.card_icons;
      var n = items.length;
      var availH = CB - CT;
      var barH = Math.min(availH / n - 1, 6);
      var html = '';
      items.forEach(function(it, i) {
        var pct = Math.round(((it.value||0) / maxVal) * 100);
        var ac = accents[i % accents.length];
        var y = CT + i * (barH + 2);
        html += '<div class="f-up" style="position:absolute;left:' + LM + '%;top:' + y + '%;width:' + CW + '%;height:' + barH + '%;display:flex;align-items:center;gap:1.5%;z-index:2;animation-delay:' + (i*0.06) + 's;">' +
          '<div style="width:12%;text-align:right;font-size:clamp(8px,1vw,12px);font-weight:600;color:#1F2A44;flex-shrink:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + it.label + '</div>' +
          '<div style="flex:1;height:70%;background:#F1F5F9;border-radius:14px;overflow:hidden;">' +
            '<div style="width:' + pct + '%;height:100%;background:' + ac + ';border-radius:14px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;">' +
              '<span style="font-size:clamp(8px,0.9vw,10px);font-weight:800;color:#fff;">' + (it.value||0) + '</span></div></div>' +
        '</div>';
      });
      return html;
    }

    function layoutDonut(s, t) {
      var items = s.items || [];
      items = items.slice(0, 6);
      var accents = t.card_icons;
      var total_val = items.reduce(function(sum, it) {
        return sum + (typeof it.value === 'string' ? parseInt(it.value)||0 : (it.value||0));
      }, 0) || 1;
      var r = 80, cx = 100, cy = 100, circumference = 2 * Math.PI * r;
      var offset = 0;
      var slices = items.map(function(it, i) {
        var v = typeof it.value === 'string' ? parseInt(it.value)||0 : (it.value||0);
        var pct = v / total_val;
        var dash = pct * circumference;
        var ac = accents[i % accents.length];
        var rot = -90 + offset * 360;
        offset += pct;
        return '<circle cx="' + cx + '" cy="' + cy + '" r="' + r + '" fill="none" stroke="' + ac + '" stroke-width="36" stroke-dasharray="' + dash.toFixed(1) + ' ' + circumference.toFixed(1) + '" stroke-dashoffset="0" transform="rotate(' + rot.toFixed(1) + ' ' + cx + ' ' + cy + ')"/>';
      }).join('');
      var html = '<div style="position:absolute;left:5%;top:' + (CT-1.78) + '%;width:45%;height:' + (CB-CT+10) + '%;z-index:2;display:flex;align-items:center;justify-content:center;">' +
        '<svg viewBox="0 0 200 200" style="width:80%;max-height:90%;">' +
          '<circle cx="100" cy="100" r="80" fill="none" stroke="#F1F5F9" stroke-width="36"/>' + slices +
          (s.center_text ? '<text x="100" y="96" text-anchor="middle" font-size="22" font-weight="900" fill="#1F2A44">' + s.center_text + '</text>' : '') +
          (s.center_sub ? '<text x="100" y="114" text-anchor="middle" font-size="11" fill="#5B6478">' + s.center_sub + '</text>' : '') +
        '</svg></div>';
      var legendTop = CT - 0.89;
      var itemH = Math.min(14.58, (CB - legendTop) / items.length);
      items.forEach(function(it, i) {
        var ac = accents[i % accents.length];
        var v = typeof it.value === 'string' ? parseInt(it.value)||0 : (it.value||0);
        var pctVal = Math.round(v / total_val * 100);
        var ic = pickIcon(it.label||'');
        var y = legendTop + i * itemH;
        html += '<div class="f-up" style="position:absolute;left:53.5%;top:' + y + '%;display:flex;align-items:center;gap:8px;z-index:2;animation-delay:' + (i*0.07) + 's;">' +
          iconCircle(ic, ac, 36) +
          '<div>' +
            '<div style="font-size:clamp(9px,1.1vw,11.5px);font-weight:700;color:#1F2A44;">' + (it.label||'') + '</div>' +
            '<div style="font-size:clamp(8px,0.9vw,10px);color:#5B6478;">' + pctVal + '%' + (it.detail ? '  ·  ' + it.detail : '') + '</div>' +
          '</div></div>';
      });
      return html;
    }

    function layoutTwoCol(s, t) {
      var col1 = (s.col1 || []).slice();
      var col2 = (s.col2 || []).slice();
      if (!col1.length && s.bullets) {
        s.bullets.forEach(function(b, i) {
          var text = b.replace(/^COL[12]:\s*/,'');
          if (i % 2 === 0) col1.push(text); else col2.push(text);
        });
      }
      var accents = t.card_icons;
      var colW = (CW - 3) / 2;
      var rowH = 15.11;
      var html = '';
      [col1, col2].forEach(function(items, ci) {
        items.slice(0,5).forEach(function(item, i) {
          var ac = accents[(ci * 5 + i) % accents.length];
          var ic = pickIcon(item);
          var x = LM + 1.5 + ci * (colW + 3);
          var y = CT + i * rowH;
          html += '<div class="f-up" style="position:absolute;left:' + x + '%;top:' + (y+2.13) + '%;display:flex;align-items:center;gap:8px;z-index:2;animation-delay:' + ((ci*5+i)*0.06) + 's;">' +
            iconCircle(ic, ac, 32) +
            '<span style="font-size:clamp(9px,1vw,11px);color:#1F2A44;line-height:1.5;max-width:' + (colW-8) + '%;">' + item + '</span>' +
          '</div>';
        });
      });
      return html;
    }

