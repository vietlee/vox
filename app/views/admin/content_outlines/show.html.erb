              '<div style="width:20px;height:5px;border-radius:3px;background:' + t.accentAlt + ';opacity:.7;"></div>' +
            '</div>' +
            (s.bullets.length ? '<div style="font-size:clamp(13px,1.5vw,17px);color:' + coverSub2 + ';line-height:1.85;max-width:600px;">' + s.bullets.map(function(b){ return '· ' + b; }).join('<br>') + '</div>' : '') +
          '</div>';

      } else {
        /* center — Aurora, Neon, Coral */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:8% 10%;text-align:center;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:22px;opacity:.9;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(24px,4.2vw,52px);font-weight:900;color:#fff;line-height:1.1;margin-bottom:22px;max-width:860px;">' + s.title + '</div>' +
            '<div style="width:52px;height:4px;border-radius:3px;background:' + t.accent + ';margin-bottom:22px;"></div>' +
            (s.bullets.length
              ? '<div style="font-size:clamp(13px,1.5vw,17px);color:rgba(255,255,255,.65);line-height:1.85;max-width:700px;">' +
                  s.bullets.map(function(b){ return b; }).join('&ensp;·&ensp;') + '</div>'
              : '') +
          '</div>';
      }

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) + contentHtml + '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       CONTENT — shared header helper
    ───────────────────────────────────────────────────────────────── */
    function slideHeader(s, idx, t) {
      var tColor = t.light ? t.text : '#fff';
      var badgeColor = t.numColor || (t.light ? '#fff' : '#0a0a0a');
      return '<div style="height:72px;display:flex;align-items:center;gap:14px;flex-shrink:0;">' +
        '<span style="background:' + t.accent + ';color:' + badgeColor + ';' +
          'font-size:10px;font-weight:900;padding:5px 13px;border-radius:20px;letter-spacing:1px;flex-shrink:0;">' +
          String(idx+1).padStart(2,'0') + ' / ' + String(total).padStart(2,'0') +
        '</span>' +
        '<h2 style="color:' + tColor + ';font-size:clamp(15px,2vw,25px);font-weight:800;margin:0;line-height:1.2;">' + s.title + '</h2>' +
      '</div>';
    }

    function slideWrap(bgSvg, inner) {
      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:0 5% 3%;">' +
          inner +
        '</div>' +
      '</div>';
    }

    /* ── LAYOUT: bullets ── */
    function layoutBullets(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var numBg    = t.numBg    || t.accent;
      var numColor = t.numColor || (t.light ? '#fff' : '#0a0a0a');
      var defaultCard = 'background:' + t.glass + ';border:1px solid ' + t.glassBorder + ';border-radius:14px;' + (t.light ? '' : 'backdrop-filter:blur(8px);');
      var cardCss  = t.cardStyle || defaultCard;
      var bullets = (s.bullets || []).slice(0, 5);
      var html = bullets.map(function(b, bi) {
        return '<div class="f-up" style="display:flex;align-items:flex-start;gap:14px;padding:11px 18px 11px 14px;' + cardCss + 'animation-delay:' + (bi*0.08) + 's;margin-bottom:8px;">' +
          '<div style="min-width:28px;height:28px;border-radius:8px;background:' + numBg + ';color:' + numColor + ';' +
            (t.numBorderColor ? 'border:1.5px solid ' + t.numBorderColor + ';background:transparent;' : '') +
            'display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;flex-shrink:0;margin-top:1px;">' +
            String(bi+1).padStart(2,'0') +
          '</div>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.3vw,15px);line-height:1.65;">' + b + '</span>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + html + '</div>';
    }

    /* ── LAYOUT: stats — 4 KPI cards in 2×2 grid ── */
    function layoutStats(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var items  = s.items || [];
      // Fallback: parse bullets as "value :: label" if items missing
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { value: (p[0]||'').trim(), label: (p[1]||b).trim() };
        });
      }
      items = items.slice(0, 4);
      var cols = items.length <= 3 ? items.length : 2;
      var cards = items.map(function(it, i) {
        var delay = (i * 0.1).toFixed(1);
        return '<div class="f-up" style="' +
          'background:' + t.glass + ';border:1px solid ' + t.glassBorder + ';border-radius:18px;' +
          (t.light ? '' : 'backdrop-filter:blur(10px);') +
          'padding:22px 18px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;' +
          'animation-delay:' + delay + 's;">' +
          '<div style="font-size:clamp(28px,3.8vw,52px);font-weight:900;color:' + t.accent + ';line-height:1;letter-spacing:-1px;margin-bottom:8px;">' + (it.value||'—') + '</div>' +
          '<div style="font-size:clamp(11px,1.2vw,13px);color:' + tColor + ';opacity:.85;font-weight:600;line-height:1.4;max-width:140px;">' + (it.label||'') + '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:center;">' +
        '<div style="display:grid;grid-template-columns:repeat(' + cols + ',1fr);gap:16px;width:100%;">' + cards + '</div>' +
      '</div>';
    }

    /* multi-accent palette */
    var ACCENTS = ['#0099CC','#FF8C42','#7C3AED','#00B074','#F59E0B','#EF4444'];
    function ac(i) { return ACCENTS[i % ACCENTS.length]; }
    /* lighter tint for bg */
    function acTint(hex, a) { return hex + Math.round(a*255).toString(16).padStart(2,'0'); }

    /* ── LAYOUT: bullets — premium list with left accent bars ── */
    function layoutBullets(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var subClr = t.light ? '#475569' : 'rgba(255,255,255,.7)';
      var bullets = s.bullets || [];
      if (!bullets.length) return '';
      var rows = bullets.map(function(b, i) {
        var color = ac(i);
        var num   = String(i+1).padStart(2,'0');
        return '<div class="f-up" style="display:flex;align-items:flex-start;gap:14px;padding:11px 16px;margin-bottom:8px;' +
          'border-radius:12px;border-left:3px solid ' + color + ';' +
          'background:' + (t.light ? 'rgba(0,0,0,.03)' : 'rgba(255,255,255,.06)') + ';' +
          'animation-delay:' + (i*0.08) + 's;">' +
          '<span style="font-size:10px;font-weight:900;color:' + color + ';letter-spacing:1px;min-width:22px;margin-top:1px;flex-shrink:0;">' + num + '</span>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.3vw,15px);line-height:1.65;font-weight:500;">' + b + '</span>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + rows + '</div>';
    }

    /* ── LAYOUT: stats — big KPI cards in a row ── */
    function layoutStats(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var subClr = t.light ? '#64748b' : 'rgba(255,255,255,.6)';
      var items  = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { value: (p[0]||'').trim(), label: (p[1]||b).trim() };
        });
      }
      items = items.slice(0, 4);
      var cards = items.map(function(it, i) {
        var color = ac(i);
        var bgs   = t.light ? '#fff' : 'rgba(255,255,255,.07)';
        var bdr   = t.light ? '#e2e8f0' : 'rgba(255,255,255,.12)';
        return '<div class="f-up" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;' +
          'padding:20px 12px;border-radius:18px;border:1px solid ' + bdr + ';background:' + bgs + ';' +
          'position:relative;overflow:hidden;animation-delay:' + (i*0.1) + 's;">' +
          /* subtle top accent */
          '<div style="position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,' + color + ',' + ac(i+1) + ');"></div>' +
          /* glow circle behind number */
          '<div style="position:absolute;width:100px;height:100px;border-radius:50%;background:' + color + ';opacity:.08;top:50%;left:50%;transform:translate(-50%,-50%);"></div>' +
          '<div style="font-size:clamp(28px,4vw,52px);font-weight:900;color:' + color + ';line-height:1;margin-bottom:10px;letter-spacing:-1px;">' + it.value + '</div>' +
          '<div style="width:32px;height:2px;background:' + color + ';border-radius:2px;margin-bottom:8px;opacity:.6;"></div>' +
          '<div style="font-size:clamp(10px,1.1vw,13px);color:' + subClr + ';line-height:1.4;font-weight:600;max-width:110px;">' + it.label + '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:center;">' +
        '<div style="display:flex;gap:12px;width:100%;">' + cards + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: chart — layered bar chart with value labels ── */
    function layoutChart(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var subClr = t.light ? '#64748b' : 'rgba(255,255,255,.55)';
      var items  = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { value: parseInt(p[0])||0, label: (p[1]||b).trim() };
        });
      }
      items = items.slice(0, 6);
      var maxVal = Math.max.apply(null, items.map(function(i){ return i.value||0; })) || 1;
      var bars = items.map(function(it, i) {
        var pct   = Math.round(((it.value||0) / maxVal) * 100);
        var color = ac(i);
        var delay = (i * 0.1).toFixed(2);
        return '<div class="f-up" style="display:flex;align-items:center;gap:14px;margin-bottom:12px;animation-delay:' + delay + 's;">' +
          '<div style="width:96px;text-align:right;color:' + tColor + ';font-size:clamp(10px,1.1vw,12.5px);font-weight:600;flex-shrink:0;line-height:1.3;">' + it.label + '</div>' +
          '<div style="flex:1;height:28px;background:' + (t.light ? 'rgba(0,0,0,.06)' : 'rgba(255,255,255,.08)') + ';border-radius:20px;overflow:hidden;position:relative;">' +
            '<div style="position:absolute;left:0;top:0;bottom:0;width:' + pct + '%;' +
              'background:linear-gradient(90deg,' + color + 'cc,' + color + ');' +
              'border-radius:20px;display:flex;align-items:center;justify-content:flex-end;padding-right:10px;">' +
              '<span style="font-size:10px;font-weight:800;color:#fff;white-space:nowrap;">' + (it.value||0) + (it.value <= 100 ? '%' : '') + '</span>' +
            '</div>' +
          '</div>' +
          '<div style="width:36px;text-align:left;color:' + color + ';font-size:clamp(11px,1.2vw,13px);font-weight:900;flex-shrink:0;">' + pct + '%</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;padding:0 4px;">' + bars + '</div>';
    }

    /* ── LAYOUT: two-col — split comparison with header badges ── */
    function layoutTwoCol(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var subClr = t.light ? '#475569' : 'rgba(255,255,255,.8)';
      var headers = s.headers || ['', ''];
      var col1 = (s.col1 || []).slice();
      var col2 = (s.col2 || []).slice();
      if (!col1.length && s.bullets) {
        var bArr = s.bullets.filter(function(b){ return !b.startsWith('HEADERS:'); });
        bArr.forEach(function(b, i) {
          var text = b.replace(/^COL[12]:\s*/,'');
          if (i % 2 === 0) col1.push(text); else col2.push(text);
        });
      }
      var c1 = t.accent, c2 = t.accentAlt || ac(1);
      if (t.light) { c2 = '#6366f1'; }
      function colHtml(items, color, label) {
        var hdr = label ? '<div style="display:inline-flex;align-items:center;gap:6px;background:' + color + ';color:#fff;font-size:11px;font-weight:800;letter-spacing:1px;text-transform:uppercase;padding:5px 12px;border-radius:20px;margin-bottom:10px;">' + label + '</div>' : '';
        var rows = items.map(function(item, i) {
          return '<div class="f-up" style="display:flex;align-items:flex-start;gap:10px;padding:9px 14px;margin-bottom:6px;' +
            'background:' + (t.light ? '#f8fafc' : 'rgba(255,255,255,.05)') + ';border-left:2px solid ' + color + ';border-radius:0 10px 10px 0;' +
            'animation-delay:' + (i*0.07) + 's;">' +
            '<span style="color:' + subClr + ';font-size:clamp(11px,1.2vw,13px);line-height:1.6;">' + item + '</span>' +
          '</div>';
        }).join('');
        return '<div>' + hdr + rows + '</div>';
      }
      return '<div style="flex:1;display:flex;gap:20px;align-items:stretch;">' +
        '<div style="flex:1;">' + colHtml(col1, c1, headers[0]) + '</div>' +
        '<div style="width:1px;background:' + (t.light ? '#e2e8f0' : 'rgba(255,255,255,.12)') + ';"></div>' +
        '<div style="flex:1;">' + colHtml(col2, c2, headers[1]) + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: timeline — horizontal steps with progress connector ── */
    function layoutTimeline(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var subClr = t.light ? '#64748b' : 'rgba(255,255,255,.65)';
      var items  = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { step: (p[0]||'').trim(), desc: (p[1]||'').trim() };
        });
      }
      items = items.slice(0, 5);
      var cards = items.map(function(it, i) {
        var color = ac(i);
        var isLast = i === items.length - 1;
        return '<div class="f-up" style="flex:1;display:flex;flex-direction:column;align-items:center;text-align:center;position:relative;animation-delay:' + (i*0.12) + 's;padding:0 6px;">' +
          /* connector */
          (!isLast ? '<div style="position:absolute;top:24px;left:calc(50% + 24px);right:calc(-50% + 24px);height:2px;background:linear-gradient(90deg,' + color + '55,' + ac(i+1) + '55);z-index:0;"></div>' : '') +
          /* icon circle with gradient */
          '<div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,' + color + ',' + ac(i+1) + ');' +
            'display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:900;color:#fff;' +
            'position:relative;z-index:1;flex-shrink:0;margin-bottom:12px;' +
            'box-shadow:0 4px 16px ' + color + '55;">' + String(i+1) +
          '</div>' +
          /* step badge */
          '<div style="font-size:clamp(10px,1.1vw,12px);font-weight:800;color:' + color + ';letter-spacing:.5px;text-transform:uppercase;margin-bottom:5px;">' + it.step + '</div>' +
          /* desc */
          '<div style="font-size:clamp(9.5px,1vw,12px);color:' + subClr + ';line-height:1.55;padding:0 4px;">' + it.desc + '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:flex-start;padding-top:20px;">' +
        '<div style="display:flex;gap:4px;width:100%;align-items:flex-start;">' + cards + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: pillars — 3-4 cards with gradient header + bullets ── */
    function layoutPillars(s, t) {
      var subClr  = t.light ? '#374151' : 'rgba(255,255,255,.75)';
      var items   = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { title: (p[0]||'').trim(), bullets: (p[1]||'').split('|').map(function(x){return x.trim();}).filter(Boolean) };
        });
      }
      items = items.slice(0, 4);
      var cols = items.map(function(it, i) {
        var c1 = ac(i), c2 = ac(i+1);
        return '<div class="f-up" style="flex:1;display:flex;flex-direction:column;border-radius:18px;overflow:hidden;' +
          'box-shadow:0 4px 20px rgba(0,0,0,.18);animation-delay:' + (i*0.1) + 's;">' +
          /* gradient header */
          '<div style="background:linear-gradient(135deg,' + c1 + ',' + c2 + ');padding:16px 16px 14px;">' +
            '<div style="font-size:clamp(11px,1.3vw,15px);font-weight:900;color:#fff;line-height:1.2;letter-spacing:.2px;">' + it.title + '</div>' +
          '</div>' +
          /* body */
          '<div style="flex:1;padding:12px 16px 16px;background:' + (t.light ? '#fff' : 'rgba(255,255,255,.07)') + ';">' +
            it.bullets.map(function(b, bi) {
              return '<div style="display:flex;align-items:flex-start;gap:8px;margin-bottom:7px;">' +
                '<div style="width:4px;height:4px;border-radius:50%;background:' + c1 + ';margin-top:6px;flex-shrink:0;"></div>' +
                '<span style="color:' + subClr + ';font-size:clamp(9.5px,1.05vw,12px);line-height:1.55;">' + b + '</span>' +
              '</div>';
            }).join('') +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:stretch;gap:12px;">' + cols + '</div>';
    }

    /* ── LAYOUT: agenda — 2-col grid with big numbered badges ── */
    function layoutAgenda(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var subClr = t.light ? '#64748b' : 'rgba(255,255,255,.6)';
      var items  = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b, i) {
          var p = b.split('::');
          return { num: p[0]||String(i+1).padStart(2,'0'), title: (p[1]||b).trim(), desc: (p[2]||'').trim() };
        });
      }
      items = items.slice(0, 8);
      var cards = items.map(function(it, i) {
        var color = ac(i);
        var bgs   = t.light ? '#fff' : 'rgba(255,255,255,.07)';
        var bdr   = t.light ? 'rgba(0,0,0,.06)' : 'rgba(255,255,255,.1)';
        return '<div class="f-up" style="display:flex;align-items:center;gap:14px;padding:12px 16px;' +
          'background:' + bgs + ';border:1px solid ' + bdr + ';border-radius:14px;' +
          'box-shadow:0 2px 8px rgba(0,0,0,.06);animation-delay:' + (i*0.07) + 's;">' +
          /* big badge */
          '<div style="width:40px;height:40px;border-radius:12px;flex-shrink:0;' +
            'background:linear-gradient(135deg,' + color + 'dd,' + color + ');' +
            'display:flex;align-items:center;justify-content:center;' +
            'box-shadow:0 4px 12px ' + color + '55;">' +
            '<span style="font-size:13px;font-weight:900;color:#fff;">' + it.num.toString().replace(/^\d+\s*/,'').substring(0,2) || it.num + '</span>' +
          '</div>' +
          '<div style="min-width:0;flex:1;">' +
            '<div style="font-size:clamp(11px,1.25vw,14px);font-weight:700;color:' + tColor + ';line-height:1.3;margin-bottom:3px;">' + it.title + '</div>' +
            (it.desc ? '<div style="font-size:clamp(9px,.95vw,11px);color:' + subClr + ';line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;">' + it.desc + '</div>' : '') +
          '</div>' +
          /* arrow indicator */
          '<div style="width:20px;height:20px;border-radius:50%;background:' + color + '22;display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
            '<svg width="8" height="8" viewBox="0 0 8 8"><path d="M2 1l4 3-4 3" fill="none" stroke="' + color + '" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:center;">' +
        '<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:8px;width:100%;">' + cards + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: roles — full-height cards with gradient header + responsibility list ── */
    function layoutRoles(s, t) {
      var subClr = t.light ? '#374151' : 'rgba(255,255,255,.78)';
      var items  = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::');
          var krs = (p[2]||'').split('|').map(function(x){return x.trim();}).filter(Boolean);
          return { role: (p[0]||'').trim(), type: (p[1]||'').trim(), bullets: krs };
        });
      }
      items = items.slice(0, 3);
      var cols = items.map(function(it, i) {
        var c1 = ac(i), c2 = ac(i+2);
        return '<div class="f-up" style="flex:1;display:flex;flex-direction:column;border-radius:18px;overflow:hidden;' +
          'box-shadow:0 6px 24px rgba(0,0,0,.2);animation-delay:' + (i*0.1) + 's;">' +
          /* gradient header */
          '<div style="background:linear-gradient(145deg,' + c1 + ',' + c2 + ');padding:18px 18px 14px;">' +
            '<div style="display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.2);' +
              'border-radius:20px;padding:3px 10px 3px 6px;margin-bottom:8px;">' +
              '<div style="width:6px;height:6px;border-radius:50%;background:#fff;"></div>' +
              '<span style="font-size:9px;font-weight:800;color:rgba(255,255,255,.9);text-transform:uppercase;letter-spacing:1px;">' + it.type + '</span>' +
            '</div>' +
            '<div style="font-size:clamp(13px,1.5vw,17px);font-weight:900;color:#fff;line-height:1.2;">' + it.role + '</div>' +
          '</div>' +
          /* body */
          '<div style="flex:1;padding:14px 18px;background:' + (t.light ? '#fff' : 'rgba(255,255,255,.06)') + ';">' +
            '<div style="font-size:9px;font-weight:800;color:' + c1 + ';letter-spacing:1.5px;text-transform:uppercase;margin-bottom:10px;opacity:.9;">TRÁCH NHIỆM</div>' +
            it.bullets.map(function(b) {
              return '<div style="display:flex;align-items:flex-start;gap:8px;margin-bottom:7px;">' +
                '<div style="width:16px;height:16px;border-radius:50%;background:' + c1 + '18;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">' +
                  '<svg width="7" height="7" viewBox="0 0 7 7"><path d="M1 3.5l2 2 3-3" fill="none" stroke="' + c1 + '" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
                '</div>' +
                '<span style="color:' + subClr + ';font-size:clamp(9.5px,1.05vw,12px);line-height:1.55;">' + b + '</span>' +
              '</div>';
            }).join('') +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:stretch;gap:14px;">' + cols + '</div>';
    }

    /* ── LAYOUT: okr — objective rows with gradient badge + KR chips ── */
    function layoutOkr(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var subClr = t.light ? '#475569' : 'rgba(255,255,255,.7)';
      var items  = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::');
          var krs = (p[1]||'').split('|').map(function(x){return x.trim();}).filter(Boolean);
          return { objective: (p[0]||'').trim(), krs: krs };
        });
      }
      items = items.slice(0, 4);
      var rows = items.map(function(it, i) {
        var c1 = ac(i), c2 = ac(i+1);
        var bgs = t.light ? '#fff' : 'rgba(255,255,255,.06)';
        var bdr = t.light ? 'rgba(0,0,0,.06)' : 'rgba(255,255,255,.1)';
        var label = it.objective.match(/^[Oo]\d+/) ? it.objective.match(/^[Oo]\d+/)[0].toUpperCase() : 'O' + (i+1);
        var title = it.objective.replace(/^[Oo]\d+\s*[-–—]?\s*/,'');
        return '<div class="f-up" style="display:flex;align-items:stretch;gap:0;border-radius:14px;overflow:hidden;' +
          'border:1px solid ' + bdr + ';margin-bottom:9px;box-shadow:0 2px 12px rgba(0,0,0,.07);animation-delay:' + (i*0.09) + 's;">' +
          /* gradient left badge */
          '<div style="width:56px;background:linear-gradient(180deg,' + c1 + ',' + c2 + ');display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;padding:8px 4px;">' +
            '<div style="font-size:10px;font-weight:900;color:rgba(255,255,255,.6);letter-spacing:1px;">' + label.replace(/\d+/,'') + '</div>' +
            '<div style="font-size:20px;font-weight:900;color:#fff;line-height:1;">' + (label.match(/\d+/)||[''])[0] + '</div>' +
          '</div>' +
          /* content */
          '<div style="background:' + bgs + ';padding:10px 16px;flex:1;">' +
            '<div style="font-size:clamp(11px,1.25vw,14px);font-weight:700;color:' + tColor + ';margin-bottom:7px;">' + title + '</div>' +
            '<div style="display:flex;flex-wrap:wrap;gap:5px;">' +
              it.krs.map(function(kr, ki) {
                return '<span style="display:inline-flex;align-items:center;gap:4px;background:' + c1 + '12;border:1px solid ' + c1 + '30;' +
                  'border-radius:20px;padding:3px 9px;font-size:clamp(8px,.9vw,10.5px);color:' + (t.light ? '#1e293b' : tColor) + ';line-height:1.3;">· ' + kr + '</span>';
              }).join('') +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + rows + '</div>';
    }

    /* ── LAYOUT: principles — icon/color title + description list ── */
    function layoutPrinciples(s, t) {
      var subClr = t.light ? '#374151' : 'rgba(255,255,255,.75)';
      var items  = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { title: (p[0]||'').trim(), desc: (p[1]||'').trim() };
        });
      }
      items = items.slice(0, 6);
      var half = Math.ceil(items.length / 2);
      var col1 = items.slice(0, half);
      var col2 = items.slice(half);
      /* icon shapes cycle: circle, square, diamond, triangle stub */
      var ICONS = ['◆','▲','●','■','★','◉'];
      function colHtml(arr, offset) {
        return arr.map(function(it, i) {
          var color = ac(i + offset);
          var bgs   = t.light ? '#fff' : 'rgba(255,255,255,.05)';
          var bdr   = t.light ? 'rgba(0,0,0,.06)' : 'rgba(255,255,255,.1)';
          return '<div class="f-up" style="display:flex;align-items:flex-start;gap:12px;padding:12px 16px;' +
            'background:' + bgs + ';border:1px solid ' + bdr + ';border-radius:14px;margin-bottom:9px;' +
            'box-shadow:0 2px 10px rgba(0,0,0,.05);animation-delay:' + ((i+offset)*0.08) + 's;">' +
            /* icon badge */
            '<div style="width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,' + color + 'cc,' + color + ');' +
              'display:flex;align-items:center;justify-content:center;flex-shrink:0;' +
              'box-shadow:0 3px 8px ' + color + '44;">' +
              '<span style="font-size:12px;color:#fff;">' + ICONS[(i+offset) % ICONS.length] + '</span>' +
            '</div>' +
            '<div style="flex:1;min-width:0;">' +
              '<div style="font-size:clamp(11px,1.2vw,13.5px);font-weight:800;color:' + color + ';margin-bottom:4px;line-height:1.2;">' + it.title + '</div>' +
              '<div style="font-size:clamp(9.5px,1vw,11.5px);color:' + subClr + ';line-height:1.6;">' + it.desc + '</div>' +
            '</div>' +
          '</div>';
        }).join('');
      }
      return '<div style="flex:1;display:flex;gap:14px;">' +
        '<div style="flex:1;">' + colHtml(col1, 0) + '</div>' +
        '<div style="flex:1;">' + colHtml(col2, half) + '</div>' +
      '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       CONTENT — dispatch to layout
    ───────────────────────────────────────────────────────────────── */
    function renderContent(s, idx, t) {
      var bodyHtml;
      var layout = s.layout || 'bullets';
      switch (layout) {
        case 'stats':      bodyHtml = layoutStats(s, t);      break;
        case 'chart':      bodyHtml = layoutChart(s, t);      break;
        case 'two-col':    bodyHtml = layoutTwoCol(s, t);     break;
        case 'timeline':   bodyHtml = layoutTimeline(s, t);   break;
        case 'pillars':    bodyHtml = layoutPillars(s, t);    break;
        case 'agenda':     bodyHtml = layoutAgenda(s, t);     break;
        case 'roles':      bodyHtml = layoutRoles(s, t);      break;
        case 'okr':        bodyHtml = layoutOkr(s, t);        break;
        case 'principles': bodyHtml = layoutPrinciples(s, t); break;
        default:           bodyHtml = layoutBullets(s, t);    break;
      }
      return slideWrap(t.contentBg(), slideHeader(s, idx, t) + bodyHtml);
    }

    /* ─────────────────────────────────────────────────────────────────
       SUMMARY
    ───────────────────────────────────────────────────────────────── */
    function renderSummary(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var icons  = ['✅','💡','🎯','📌','⭐','🔑','🚀','🏆'];

      var bulletsHtml = s.bullets.map(function(b, bi) {
        return '<div class="f-up" style="display:flex;align-items:center;gap:13px;padding:11px 18px;' +
          'background:' + t.glass + ';border:1px solid ' + t.glassBorder + ';border-radius:12px;' +
          (t.light ? '' : 'backdrop-filter:blur(8px);') +
          'animation-delay:' + (bi*0.09) + 's;margin-bottom:8px;">' +
          '<span style="font-size:20px;flex-shrink:0;">' + (icons[bi]||'▸') + '</span>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.3vw,14px);line-height:1.6;">' + b + '</span>' +
        '</div>';
      }).join('');

      var bgSvg = typeof t.coverBg === 'function' ? t.coverBg(s.title) : t.coverBg;

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5% 9%;text-align:center;">' +
          '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:14px;opacity:.85;">Tóm tắt</div>' +
          '<h2 style="color:' + (t.light?t.text:'#fff') + ';font-size:clamp(18px,2.8vw,36px);font-weight:900;margin:0 0 14px;line-height:1.15;">' + s.title + '</h2>' +
          '<div style="width:44px;height:4px;background:' + t.accent + ';border-radius:2px;margin-bottom:22px;"></div>' +
          '<div style="width:100%;max-width:700px;text-align:left;">' + bulletsHtml + '</div>' +
        '</div>' +
      '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       THEME PICKER — color swatches
    ───────────────────────────────────────────────────────────────── */
    var swatchColors = ['#1e1b4b','#7c3aed','#00f5c4','#a21caf','#facc15','#be123c','#6366f1','#c026d3','#faff00','#1e3a5f','#f0abfc','#f97316','#d4a757','#1a1100','#ff006e','#f5d0fe','#4ade80','#1B4332','#1E3A5F','#31308C','#7F1D1D','#13474E','#78350F','#1E293B'];
    var pickerHtml = THEMES.map(function(t, i) {
      return '<button onclick="setTheme(' + i + ')" id="theme-btn-' + i + '" title="' + t.label + '" ' +
        'style="width:28px;height:28px;border-radius:50%;border:3px solid transparent;cursor:pointer;' +
        'background:' + swatchColors[i] + ';transition:all .15s;flex-shrink:0;" />';
    }).join('');
    document.getElementById('slide-dots').insertAdjacentHTML('beforebegin',
      '<div id="theme-picker" style="display:flex;align-items:center;gap:6px;">' +
        '<span style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:2px;margin-right:2px;">Theme</span>' +
        pickerHtml +
      '</div>'
    );

    var AI_THEME_MAP = {
      green:  17, // P-Green
      blue:   18, // P-Blue
      purple: 19, // P-Purple
      red:    20, // P-Red
      teal:   21, // P-Teal
      amber:  22, // P-Amber
      slate:  23, // P-Slate
    };
    var aiTheme = el.dataset.theme || '';
    var activeThemeIdx = (aiTheme && AI_THEME_MAP[aiTheme] != null) ? AI_THEME_MAP[aiTheme] : 0;
    window.setTheme = function(i) {
      activeThemeIdx = i;
      document.querySelectorAll('[id^="theme-btn-"]').forEach(function(b, j) {
        b.style.borderColor = j === i ? '#fff' : 'transparent';
        b.style.transform   = j === i ? 'scale(1.2)' : 'scale(1)';
        b.style.boxShadow   = j === i ? '0 0 0 2px #6366f1' : 'none';
      });
      render();
    };
    setTheme(activeThemeIdx);

    if (useImageMode) {
      var tp = document.getElementById('theme-picker');
      if (tp) tp.style.display = 'none';
    }

    /* ─────────────────────────────────────────────────────────────────
       RENDER
    ───────────────────────────────────────────────────────────────── */
    function render() {
      if (!slides.length) return;
      var s = slides[current];
      var t = THEMES[activeThemeIdx];
      var isFirst = current === 0, isLast = current === total - 1;

      if (useImageMode && slideImageUrls[current]) {
        document.getElementById('slide-viewer').innerHTML =
          '<div class="s-in" style="position:absolute;inset:0;">' +
            '<img src="' + slideImageUrls[current] + '" style="width:100%;height:100%;object-fit:contain;background:#0f172a;">' +
          '</div>';
      } else {
        document.getElementById('slide-viewer').innerHTML =
          isFirst ? renderCover(s, t) :
          isLast  ? renderSummary(s, t) :
                    renderContent(s, current, t);
      }

      document.getElementById('slide-counter').textContent = (current+1) + ' / ' + total;

      /* progress dots */
      var dotTotal = useImageMode ? slideImageUrls.length : slides.length;
      document.getElementById('slide-dots').innerHTML = Array.from({length: dotTotal}, function(_, i) {
        return '<div style="width:' + (i===current?'18px':'5px') + ';height:5px;border-radius:3px;' +
          'background:' + (i===current?'#6366f1':'#cbd5e1') + ';transition:all .25s;"></div>';
      }).join('');

      var noteEl = document.getElementById('slide-note');
      if (s && s.note) { document.getElementById('slide-note-text').textContent = s.note; noteEl.classList.remove('hidden'); }
      else { noteEl.classList.add('hidden'); }
    }

    var navTotal = useImageMode ? slideImageUrls.length : total;
    window.prevSlide = function() { if (current > 0) { current--; render(); } };
    window.nextSlide = function() { if (current < navTotal-1) { current++; render(); } };
    window.enterFullscreen = function() {
      var w = document.getElementById('slide-viewer').parentElement;
      (w.requestFullscreen || w.webkitRequestFullscreen || function(){}).call(w);
    };
    document.addEventListener('keydown', function(e) {
      var tag = document.activeElement && document.activeElement.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
      if (e.key==='ArrowRight'||e.key==='ArrowDown') nextSlide();
      if (e.key==='ArrowLeft' ||e.key==='ArrowUp')   prevSlide();
    });
    var tx = null;
    document.getElementById('slide-viewer').addEventListener('touchstart', function(e){ tx = e.touches[0].clientX; });
    document.getElementById('slide-viewer').addEventListener('touchend',   function(e){
      if (!tx) return;
      var dx = e.changedTouches[0].clientX - tx;
      if (dx < -40) nextSlide(); else if (dx > 40) prevSlide();
      tx = null;
    });

    render();

    /* ─────────────────────────────────────────────────────────────────
       IMAGE OVERLAY
    ───────────────────────────────────────────────────────────────── */
    function renderImageOverlay() {
      var overlay = document.getElementById('slide-image-overlay');
      if (!overlay) return;
      var s = slides[current];
      var img = s && s.image;
      if (!img || !img.dataUrl) { overlay.innerHTML = ''; return; }
      var x = img.x != null ? img.x : 30;
      var y = img.y != null ? img.y : 10;
      var w = img.w != null ? img.w : 35;
      overlay.style.pointerEvents = 'none';
      overlay.innerHTML = '<img src="' + img.dataUrl + '" style="position:absolute;left:' + x + '%;top:' + y + '%;width:' + w + '%;max-height:85%;object-fit:contain;pointer-events:none;border-radius:8px;box-shadow:0 4px 24px rgba(0,0,0,0.3);">';
    }

    /* ─────────────────────────────────────────────────────────────────
       FONT SCALE + FAMILY OVERRIDE
    ───────────────────────────────────────────────────────────────── */
    function applyFontOverrides() {
      var s = slides[current];
      if (!s) return;
      var viewer = document.getElementById('slide-viewer');
      if (!viewer) return;
      var scale = (s.fontScale || 100) / 100;
      var family = s.fontFamily || '';
      viewer.style.fontSize = (scale !== 1) ? (scale * 100) + '%' : '';
      viewer.style.fontFamily = family || '';
    }

    /* ─────────────────────────────────────────────────────────────────
       EDITOR PANEL LOGIC
    ───────────────────────────────────────────────────────────────── */
    var editorOpen = false;

    window.toggleEditor = function() {
      editorOpen = !editorOpen;
      document.getElementById('slide-editor-panel').style.display = editorOpen ? 'block' : 'none';
      var btn = document.getElementById('editor-toggle-btn');
      if (btn) {
        btn.textContent = editorOpen ? '✕ Đóng' : '✨ Sửa bằng AI';
        btn.classList.toggle('bg-indigo-50', !editorOpen);
        btn.classList.toggle('bg-slate-100', editorOpen);
      }
    };

    window.refreshEditor = function() {
      var s = slides[current];
      if (!s) return;

      document.getElementById('editor-slide-label').textContent = 'Slide ' + (current+1) + ' / ' + total;
      document.getElementById('edit-title').value = s.title || '';
      document.getElementById('edit-layout').value = s.layout || 'bullets';
      document.getElementById('edit-note').value = s.note || '';

      /* font */
      var scale = s.fontScale || 100;
      document.getElementById('font-scale').value = scale;
      document.getElementById('font-scale-val').textContent = scale + '%';
      document.getElementById('font-family').value = s.fontFamily || '';

      /* image controls */
      var img = s.image;
      var imgCtrl = document.getElementById('img-controls');
      if (img && img.dataUrl) {
        imgCtrl.classList.remove('hidden');
        document.getElementById('img-x').value = img.x || 30;
        document.getElementById('img-y').value = img.y || 10;
        document.getElementById('img-w').value = img.w || 35;
        document.getElementById('img-x-val').textContent = (img.x||30) + '%';
        document.getElementById('img-y-val').textContent = (img.y||10) + '%';
        document.getElementById('img-w-val').textContent = (img.w||35) + '%';
        document.getElementById('img-upload-label').textContent = '✓ Đã có ảnh — chọn ảnh mới';
      } else {
        imgCtrl.classList.add('hidden');
        document.getElementById('img-upload-label').textContent = 'Chọn hoặc kéo ảnh vào đây';
      }

      /* items list */
      renderItemsList(s);
    };

    function renderItemsList(s) {
      var container = document.getElementById('edit-items-list');
      container.innerHTML = '';
      var items = getDisplayItems(s);
      items.forEach(function(text, idx) {
        var row = document.createElement('div');
        row.className = 'item-row';
        row.draggable = true;
        row.dataset.idx = idx;
        row.style.cssText = 'display:flex;align-items:center;gap:6px;padding:4px 6px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;cursor:grab;';
        row.innerHTML =
          '<span style="font-size:14px;color:#94a3b8;cursor:grab;flex-shrink:0;">⠿</span>' +
          '<textarea rows="2" style="flex:1;font-size:11px;border:none;background:transparent;resize:none;outline:none;line-height:1.4;padding:0;" ' +
            'oninput="updateItem(' + idx + ', this.value)">' + escHtml(text) + '</textarea>' +
          '<button onclick="removeItem(' + idx + ')" style="font-size:14px;color:#cbd5e1;border:0;background:0;cursor:pointer;flex-shrink:0;padding:0 2px;" title="Xóa">×</button>';

        /* drag & drop */
        row.addEventListener('dragstart', function(e) { e.dataTransfer.setData('text/plain', idx); this.style.opacity = '.4'; });
        row.addEventListener('dragend',   function() { this.style.opacity = '1'; });
        row.addEventListener('dragover',  function(e) { e.preventDefault(); this.style.background = '#eef2ff'; });
        row.addEventListener('dragleave', function() { this.style.background = '#f8fafc'; });
        row.addEventListener('drop',      function(e) {
          e.preventDefault(); this.style.background = '#f8fafc';
          var fromIdx = parseInt(e.dataTransfer.getData('text/plain'));
          var toIdx   = parseInt(this.dataset.idx);
          if (fromIdx === toIdx) return;
          reorderItem(fromIdx, toIdx);
        });

        container.appendChild(row);
      });
    }

    function getDisplayItems(s) {
      if (s.bullets && s.bullets.length) return s.bullets;
      if (s.items && s.items.length) {
        return s.items.map(function(it) {
          if (typeof it === 'string') return it;
          if (it.value != null && it.label != null) return it.value + ' :: ' + it.label;
          if (it.step) return it.step + ' :: ' + (it.desc||'');
          if (it.title && it.bullets) return it.title + ' :: ' + it.bullets.join(' | ');
          if (it.title && it.desc)    return it.title + ' :: ' + it.desc;
          if (it.num)  return it.num + ' :: ' + it.title + (it.desc ? ' :: '+it.desc : '');
          if (it.role) return it.role + ' :: ' + (it.type||'') + ' :: ' + (it.bullets||[]).join(' | ');
          if (it.objective) return it.objective + ' :: ' + (it.krs||[]).join(' | ');
          return JSON.stringify(it);
        });
      }
      return [];
    }

    function escHtml(str) { return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    window.updateItem = function(idx, val) {
      var s = slides[current];
      if (s.bullets && s.bullets.length) { s.bullets[idx] = val; }
      else if (s.items && s.items.length) {
        var it = s.items[idx];
        if (typeof it === 'string') { s.items[idx] = val; return; }
        if (!s.bullets) s.bullets = [];
        s.bullets[idx] = val;
      }
      /* no realtime render — update on Save only */
    };

    window.removeItem = function(idx) {
      var s = slides[current];
      if (s.bullets) s.bullets.splice(idx, 1);
      if (s.items)   s.items.splice(idx, 1);
      refreshEditor(); /* rebuild item list only, no slide re-render */
    };

    window.reorderItem = function(fromIdx, toIdx) {
      var s = slides[current];
      function move(arr) {
        if (!arr || !arr.length) return;
        var item = arr.splice(fromIdx, 1)[0];
        arr.splice(toIdx, 0, item);
      }
      move(s.bullets); move(s.items);
      refreshEditor();
    };

    window.addItemToSlide = function() {
      var s = slides[current];
      if (!s.bullets) s.bullets = [];
      s.bullets.push('Nội dung mới...');
      refreshEditor();
    };

    window.updateCurrentSlide = function(key, val) {
      slides[current][key] = val;
      /* layout change: re-render preview immediately so user sees layout change */
      if (key === 'layout') { render(); }
    };

    /* Font controls — store values, apply preview only on Save */
    window.updateFontScale = function(val) {
      slides[current].fontScale = parseInt(val);
      document.getElementById('font-scale-val').textContent = val + '%';
      /* light preview: just scale the viewer div, no full re-render */
      var viewer = document.getElementById('slide-viewer');
      if (viewer) viewer.style.fontSize = (parseInt(val)/100*100) + '%';
    };
    window.updateFontFamily = function(val) {
      slides[current].fontFamily = val;
      var viewer = document.getElementById('slide-viewer');
      if (viewer) viewer.style.fontFamily = val || '';
    };

    /* Image controls — realtime overlay preview is OK (no re-render needed) */
    window.handleImageUpload = function(input) {
      var file = input.files[0]; if (!file) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        if (!slides[current].image) slides[current].image = {};
        slides[current].image.dataUrl = e.target.result;
        slides[current].image.x = 30;
        slides[current].image.y = 10;
        slides[current].image.w = 35;
        renderImageOverlay();
        refreshEditor();
      };
      reader.readAsDataURL(file);
    };

    window.updateImagePos = function() {
      var s = slides[current];
      if (!s.image) s.image = {};
      var x = parseInt(document.getElementById('img-x').value);
      var y = parseInt(document.getElementById('img-y').value);
      var w = parseInt(document.getElementById('img-w').value);
      s.image.x = x; s.image.y = y; s.image.w = w;
      document.getElementById('img-x-val').textContent = x + '%';
      document.getElementById('img-y-val').textContent = y + '%';
      document.getElementById('img-w-val').textContent = w + '%';
      renderImageOverlay(); /* overlay only, slide content untouched */
    };

    window.removeImage = function() {
      if (slides[current].image) delete slides[current].image;
      document.getElementById('slide-image-overlay').innerHTML = '';
      refreshEditor();
    };

    /* Save */
    window.saveSlides = function() {
      /* flush any pending item edits from textareas into slides data */
      var textareas = document.querySelectorAll('#edit-items-list textarea');
      var s = slides[current];
      if (textareas.length) {
        var vals = Array.from(textareas).map(function(ta) { return ta.value; });
        s.bullets = vals;
        /* clear s.items so layout functions use s.bullets */
        delete s.items;
      }
      /* flush title + note from inputs */
      var titleIn = document.getElementById('edit-title');
      if (titleIn) s.title = titleIn.value;
      var noteIn = document.getElementById('edit-note');
      if (noteIn) s.note = noteIn.value;

      /* re-render slide with updated data */
      render();

      /* then persist to server */
      var btn = document.getElementById('save-slides-btn');
      btn.disabled = true; btn.textContent = '...';
      var token = document.querySelector('meta[name="csrf-token"]').content;
      fetch('<%= update_slides_content_outline_path(@outline) %>', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token, 'Accept': 'application/json' },
        body: JSON.stringify({ slide_json: JSON.stringify(slides) })
      }).then(function(r){ return r.json(); }).then(function(data) {
        btn.disabled = false; btn.textContent = '💾 Lưu';
        var st = document.getElementById('save-status');
        if (data.ok) { st.textContent = '✓ Đã lưu!'; st.classList.remove('hidden'); setTimeout(function(){ st.classList.add('hidden'); }, 2000); }
        else { st.textContent = '❌ ' + (data.error||'Lỗi'); st.classList.remove('hidden'); }
      }).catch(function() { btn.disabled = false; btn.textContent = '💾 Lưu'; });
    };

    /* Override render to also apply font + image overlays */
    var _origRender = render;
    render = function() {
      _origRender();
      applyFontOverrides();
      renderImageOverlay();
      if (editorOpen) refreshEditor();
    };

    render();

    var _editFiles = [];

    window.previewEditFiles = function(input) {
      var container = document.getElementById('ai-edit-previews');
      Array.from(input.files).forEach(function(f) {
        _editFiles.push(f);
        var idx = _editFiles.length - 1;
        var wrap = document.createElement('div');
        wrap.style.cssText = 'position:relative;width:64px;height:64px;border-radius:8px;overflow:hidden;border:1px solid #e2e8f0;';
        wrap.id = 'ef-' + idx;
        var img = document.createElement('img');
        img.src = URL.createObjectURL(f);
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
        var rm = document.createElement('button');
        rm.innerHTML = '✕';
        rm.style.cssText = 'position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;background:#ef4444;color:#fff;border:0;cursor:pointer;font-size:10px;line-height:18px;text-align:center;padding:0;';
        rm.onclick = function() { _editFiles[idx] = null; wrap.remove(); };
        wrap.appendChild(img); wrap.appendChild(rm);
        container.appendChild(wrap);
      });
      input.value = '';
    };

    window.submitAiEdit = function() {
      var input = document.getElementById('ai-edit-input');
      var prompt = input.value.trim();
      if (!prompt) return;

      document.getElementById('ai-edit-body').classList.add('hidden');
      document.getElementById('ai-edit-loading').classList.remove('hidden');

      var fd = new FormData();
      fd.append('edit_prompt', prompt);
      _editFiles.forEach(function(f) { if (f) fd.append('images[]', f); });

      fetch('<%= ai_edit_content_outline_path(@outline) %>', {
        method: 'POST',
        headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
        body: fd
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.poll_url) {
          var poll = setInterval(function() {
            fetch(data.poll_url).then(function(r) { return r.json(); }).then(function(s) {
              if (!s.pending) { clearInterval(poll); location.reload(); }
            });
          }, 3000);
        } else {
          document.getElementById('ai-edit-loading').classList.add('hidden');
          document.getElementById('ai-edit-body').classList.remove('hidden');
          alert(data.error || 'Lỗi');
        }
      });
    };

    document.getElementById('ai-edit-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) submitAiEdit();
    });
  })();
  </script>

<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nội dung được tạo bởi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='Đã sao chép!'; setTimeout(()=>this.textContent='Sao chép',2000)})"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        Sao chép
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>
