            <span style="font-size:12px;font-weight:700;color:#e2e8f0;">▰ Sửa thanh tiến độ</span>
            <button onclick="closeProgressEditor()" style="background:none;border:none;color:#94a3b8;cursor:pointer;font-size:16px;padding:0;line-height:1;">×</button>
          </div>
