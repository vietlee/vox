      var thickness = Math.max(2, Math.round(PX(s.strokeWidth||0.03)));
      if (style === 'dots') {
        return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+(cy - thickness/2)+'px;width:'+w+'px;height:'+thickness+'px;z-index:'+z+';background:radial-gradient(circle, '+accent+' 40%, transparent 40%) 0/'+thickness*2.5+'px '+thickness+'px;"></div>';
      } else if (style === 'gradient') {
        return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+(cy - thickness/2)+'px;width:'+w+'px;height:'+thickness+'px;z-index:'+z+';background:linear-gradient(to right, transparent, '+accent+', transparent);"></div>';
      } else {
        return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+(cy - thickness/2)+'px;width:'+w+'px;height:'+thickness+'px;z-index:'+z+';background:'+accent+';border-radius:99px;"></div>';
      }
    }

    function renderArrow(el, x, y, w, h, z, si, attrs) {
      var s = el.style || {};
      var t = deck.theme || {};
      var color = s.stroke || t.accent || '#6366f1';
      var sw = Math.max(2, Math.round(h * 0.08));
      var ah = Math.round(h * 0.5);
      var aw = Math.round(ah * 0.7);
      var mx = w - aw, my = Math.round(h/2);
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+w+'px;height:'+h+'px;z-index:'+z+';overflow:visible;">' +
        '<svg width="'+w+'" height="'+h+'" viewBox="0 0 '+w+' '+h+'" overflow="visible">' +
          '<line x1="0" y1="'+my+'" x2="'+mx+'" y2="'+my+'" stroke="'+color+'" stroke-width="'+sw+'" stroke-linecap="round"/>' +
          '<polygon points="'+mx+','+(my-ah/2)+' '+(w)+','+my+' '+mx+','+(my+ah/2)+'" fill="'+color+'"/>' +
        '</svg>' +
        '</div>';
    }

    function toEmbedUrl(url) {
      url = (url || '').trim();
      /* YouTube */
      var yt = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
      if (yt) return 'https://www.youtube.com/embed/' + yt[1] + '?rel=0&modestbranding=1';
      /* Vimeo */
      var vm = url.match(/vimeo\.com\/(\d+)/);
      if (vm) return 'https://player.vimeo.com/video/' + vm[1] + '?byline=0&portrait=0';
      /* Google Drive preview */
      var gd = url.match(/drive\.google\.com\/file\/d\/([^/]+)/);
      if (gd) return 'https://drive.google.com/file/d/' + gd[1] + '/preview';
      /* Direct video (mp4 etc.) — wrap in a data: iframe */
      if (/\.(mp4|webm|ogg)(\?|$)/i.test(url)) return '__direct__' + url;
      return url; /* assume already embeddable */
    }

    function renderVideo(el, x, y, w, h, z, si, attrs) {
      var src = el.src || el.content || '';
      var embed = toEmbedUrl(src);
      var r = (el.style && el.style.borderRadius) || 10;
      var inner;
      if (embed.startsWith('__direct__')) {
        var directSrc = embed.slice(10);
        inner = '<video src="'+escHtml(directSrc)+'" controls style="width:100%;height:100%;object-fit:contain;border-radius:'+r+'px;display:block;"></video>';
      } else if (embed) {
        inner = '<iframe src="'+escHtml(embed)+'" frameborder="0" allowfullscreen allow="autoplay; encrypted-media; picture-in-picture" style="width:100%;height:100%;border-radius:'+r+'px;display:block;border:none;"></iframe>';
      } else {
        inner = '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:#94a3b8;gap:8px;"><svg viewBox="0 0 24 24" width="40" height="40" fill="none" stroke="#cbd5e1" stroke-width="1.5"><path d="M15 10l4.55-2.27A1 1 0 0121 8.7v6.6a1 1 0 01-1.45.89L15 14M5 8h7a2 2 0 012 2v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4a2 2 0 012-2z"/></svg><span style="font-size:13px;font-family:Inter,sans-serif;">Nhập URL video</span></div>';
      }
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+w+'px;height:'+h+'px;z-index:'+z+';border-radius:'+r+'px;overflow:hidden;background:#000;">'+inner+'</div>';
    }

    function renderBarChart(el, x, y, w, h, z, si, attrs) {
      var data = (el.chart && el.chart.data) || [];
      if (!data.length) return '';
      var t = deck.theme || {};
      var accent = t.accent || '#6366f1';
      var colors = t.card_icons || [accent, t.primary_dk || '#4338CA', t.primary || '#6366f1'];
      var maxVal = Math.max.apply(null, data.map(function(d){return parseFloat(d.value)||0;})) || 1;
      var padTop = 24;  /* value labels */
      var padBot = 28;  /* x-axis labels */
      var padLeft = 38; /* y-axis labels */
      var padRight = 8;
      var chartW = w - padLeft - padRight;
      var chartH = h - padTop - padBot;
      var n = data.length;
      var svgContent = '';

      /* ── Y-axis grid lines + labels (4 ticks) ── */
      var ticks = 4;
      for (var ti = 0; ti <= ticks; ti++) {
        var tickVal = maxVal * ti / ticks;
        var tickY = padTop + chartH - Math.round((tickVal / maxVal) * chartH);
        var tickLabel = tickVal % 1 === 0 ? String(Math.round(tickVal)) : tickVal.toFixed(1);
        /* horizontal grid line */
        svgContent += '<line x1="'+padLeft+'" y1="'+tickY+'" x2="'+(padLeft+chartW)+'" y2="'+tickY+'" stroke="#E2E8F0" stroke-width="'+(ti===0?1.5:0.8)+'"/>';
        /* y-axis label */
        svgContent += '<text x="'+(padLeft-5)+'" y="'+(tickY+4)+'" text-anchor="end" font-size="9" fill="#94A3B8" font-family="Inter,sans-serif">'+escHtml(tickLabel)+'</text>';
      }

      /* ── Vertical axis line ── */
      svgContent += '<line x1="'+padLeft+'" y1="'+padTop+'" x2="'+padLeft+'" y2="'+(padTop+chartH)+'" stroke="#CBD5E1" stroke-width="1.5"/>';

      /* ── Bars ── */
      var barW = Math.max(8, Math.floor((chartW * 0.75) / n));
      var gap = Math.floor((chartW - barW * n) / (n + 1));
      gap = Math.max(3, gap);
      data.forEach(function(d, i) {
        var val = parseFloat(d.value) || 0;
        var barH = Math.max(2, Math.round((val / maxVal) * chartH));
        var bx = padLeft + gap + i * (barW + gap);
        var by = padTop + chartH - barH;
        var c = colors[i % colors.length];
        var rx = Math.min(4, barW / 3);
        svgContent += '<rect x="'+bx+'" y="'+by+'" width="'+barW+'" height="'+barH+'" rx="'+rx+'" fill="'+c+'"/>';
        /* value label on top */
        var rawVal = parseFloat(d.value) || 0;
        var valStr = rawVal % 1 === 0 ? String(Math.round(rawVal)) : rawVal.toFixed(1);
        svgContent += '<text x="'+(bx+barW/2)+'" y="'+(by-5)+'" text-anchor="middle" font-size="10" font-weight="700" fill="'+c+'" font-family="Inter,sans-serif">'+escHtml(valStr)+'</text>';
        /* x-axis tick */
        svgContent += '<line x1="'+(bx+barW/2)+'" y1="'+(padTop+chartH)+'" x2="'+(bx+barW/2)+'" y2="'+(padTop+chartH+4)+'" stroke="#CBD5E1" stroke-width="1"/>';
        /* x-axis label */
        var lbl = String(d.label||'').substring(0,8);
        svgContent += '<text x="'+(bx+barW/2)+'" y="'+(padTop+chartH+padBot*0.70)+'" text-anchor="middle" font-size="10" fill="#64748B" font-family="Inter,sans-serif">'+escHtml(lbl)+'</text>';
      });
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+w+'px;height:'+h+'px;z-index:'+z+';"><svg width="'+w+'" height="'+h+'" viewBox="0 0 '+w+' '+h+'">'+svgContent+'</svg></div>';
    }

    function renderDonutChart(el, x, y, w, h, z, si, attrs) {
      var data = (el.chart && el.chart.data) || [];
      if (!data.length) return '';
      var t = deck.theme || {};
      var colors = t.card_icons || ['#6366f1','#8b5cf6','#a78bfa'];
      var total_val = data.reduce(function(s,d){return s+(d.value||0);},0) || 1;
      var label_parts = ((el.chart && el.chart.label) || '').split('|');
      var center_text = label_parts[0] || '';
      var center_sub = label_parts[1] || '';
      var sz = Math.min(w, h);
      var r = sz * 0.38, cx = sz/2, cy = sz/2;
      var circ = 2 * Math.PI * r;
      var offset = 0, slices = '';
      data.forEach(function(d, i) {
        var pct = (d.value||0) / total_val;
        var dash = pct * circ;
        var c = colors[i % colors.length];
        var rot = -90 + offset * 360;
        slices += '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="'+c+'" stroke-width="'+Math.round(r*0.40)+'" stroke-dasharray="'+dash.toFixed(1)+' '+circ.toFixed(1)+'" stroke-dashoffset="0" transform="rotate('+rot.toFixed(1)+' '+cx+' '+cy+')"/>';
        offset += pct;
      });
      var fs_main = Math.round(sz * 0.09);
      var fs_sub = Math.round(sz * 0.055);
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+sz+'px;height:'+sz+'px;z-index:'+z+';"><svg viewBox="0 0 '+sz+' '+sz+'" width="'+sz+'" height="'+sz+'">'+
             '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="#F1F5F9" stroke-width="'+Math.round(r*0.40)+'"/>'+slices+
             (center_text?'<text x="'+cx+'" y="'+(cy-fs_sub*0.5)+'" text-anchor="middle" font-size="'+fs_main+'" font-weight="900" fill="#1F2A44" font-family="Nunito,sans-serif">'+center_text+'</text>':'')+
             (center_sub?'<text x="'+cx+'" y="'+(cy+fs_main*0.7)+'" text-anchor="middle" font-size="'+fs_sub+'" fill="#94A3B8" font-family="Inter,sans-serif">'+center_sub+'</text>':'')+
             '</svg></div>';
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ─── Render slide ─── */
    function renderSlide(idx) {
      var s = slides[idx];
      if (!s) return '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#94A3B8;">Không có slide</div>';
      var bg = s.background || { type:'solid', color:'#ffffff' };
      var bgCss = bg.type === 'gradient' ?
        'background:' + bg.value + ';' :
        'background:' + (bg.color||'#fff') + ';';
      var els = (s.elements || []).sort(function(a,b){return (a.z||2)-(b.z||2);});
      var content = els.map(function(e){ return renderEl(e, idx); }).join('');
      return '<div style="position:absolute;inset:0;' + bgCss + '">' + content + '</div>';
    }

    /* ─── Canvas scale ─── */
    function rescaleCanvas() {
      var viewer = document.getElementById('slide-viewer');
      var stage  = document.getElementById('slide-stage');
      if (!viewer || !stage) return;
      var wrap = viewer.parentElement;
      var vw = wrap ? wrap.clientWidth : viewer.clientWidth;
      if (!vw) return;
      /* Always fill full width — no side bars ever */
      var scale = vw / 1280;
      var scaledH = Math.round(720 * scale);
      if (wrap) { wrap.style.paddingBottom = '0'; wrap.style.height = scaledH + 'px'; }
      stage.style.transformOrigin = 'top left';
      stage.style.transform = 'scale(' + scale + ')';
      stage.style.position = 'absolute';
      stage.style.left = '0';
      stage.style.top  = '0';
      stage.style.margin = '0';
      /* Keep thumbnail panel same height as slide */
      var panel = document.getElementById('slide-panel');
      if (panel) panel.style.maxHeight = scaledH + 'px';
    }

    /* ─── Navigation ─── */
    function goToSlide(idx) {
      current = Math.max(0, Math.min(idx, total - 1));
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      updateDots();
      updateCounter();
      rescaleCanvas();
      if (editorMode) { attachEditorHandlers(); syncBgPicker(); }
    }

    function prevSlide() { goToSlide(current - 1); }
    function nextSlide() { goToSlide(current + 1); }

    function updateDots() {
      var dotsEl = document.getElementById('slide-dots');
      if (!dotsEl) return;
      var html = '';
      for (var i = 0; i < total; i++) {
        var active = i === current;
        html += '<button onclick="goToSlide('+i+')" style="width:'+(active?'20':'7')+'px;height:7px;border-radius:99px;border:none;cursor:pointer;transition:all .2s;background:'+(active?'#6366f1':'#cbd5e1')+'"></button>';
      }
      dotsEl.innerHTML = html;
    }

    function updateCounter() {
      var el2 = document.getElementById('slide-counter');
      if (el2) el2.textContent = 'Slide ' + (current + 1) + ' / ' + total;
    }

    /* ─── WYSIWYG Editor ─── */
    function toggleWysiwyg() {
      editorMode = !editorMode;
      var btn = document.getElementById('wysiwyg-btn');
      var bar = document.getElementById('wysiwyg-bar');
      var stage = document.getElementById('slide-stage');
      if (btn) {
        btn.style.background = editorMode ? '#ede9fe' : '';
        btn.style.color = editorMode ? '#6d28d9' : '';
        btn.style.fontWeight = editorMode ? '700' : '';
      }
      if (bar) bar.style.display = editorMode ? 'flex' : 'none';
      if (editorMode) syncBgPicker();
      if (stage) {
        stage.style.cursor = editorMode ? 'default' : 'default';
        if (editorMode) attachEditorHandlers();
        else {
          clearSelection();
          /* strip all editor inline styles left on elements */
          stage.querySelectorAll('.slide-el').forEach(function(el) {
            el.style.outline = '';
            el.style.outlineColor = '';
            el.style.cursor = '';
            el.onmouseenter = null;
            el.onmouseleave = null;
          });
        }
      }
    }

    function toggleAiPanel() {
      var panel = document.getElementById('slide-editor-panel');
      if (!panel) return;
      var isOpen = panel.style.display !== 'none';
      panel.style.display = isOpen ? 'none' : 'block';
      var btn = document.getElementById('ai-panel-btn');
      if (btn) {
        btn.style.background = isOpen ? '' : '#eef2ff';
        btn.style.color = isOpen ? '' : '#4338ca';
      }
    }

    /* keep toggleEditor as alias for AI panel (used by old inline onclick) */
    function toggleEditor() { toggleAiPanel(); }

    /* ─── Marquee (rubber-band) selection ─── */
    var _marquee = null;
    function _startMarquee(e) {
      if (!editorMode) return;
      if (e.button !== 0) return;
      if (e.target.closest('.slide-el') || e.target.closest('.sel-handle')) return;
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      clearSelection();
      var sr = stage.getBoundingClientRect();
      var scale = sr.width / 1280;
      var x0 = (e.clientX - sr.left) / scale;
      var y0 = (e.clientY - sr.top)  / scale;
      var box = document.createElement('div');
      box.id = 'marquee-box';
      box.style.cssText = 'position:absolute;border:1.5px dashed #6366f1;background:rgba(99,102,241,.08);pointer-events:none;z-index:9999;left:'+x0+'px;top:'+y0+'px;width:0;height:0;';
      stage.appendChild(box);
      _marquee = { x0:x0, y0:y0, box:box, sr:sr, scale:scale };
      document.addEventListener('mousemove', _onMarqueeMove);
      document.addEventListener('mouseup',   _onMarqueeEnd);
      e.preventDefault();
    }
    function _onMarqueeMove(e) {
      if (!_marquee) return;
      var sr = _marquee.sr; var sc = _marquee.scale;
      var x1 = (e.clientX - sr.left) / sc;
      var y1 = (e.clientY - sr.top)  / sc;
      var left = Math.min(_marquee.x0, x1), top = Math.min(_marquee.y0, y1);
      var w = Math.abs(x1 - _marquee.x0), h = Math.abs(y1 - _marquee.y0);
      _marquee.box.style.left = left+'px'; _marquee.box.style.top = top+'px';
      _marquee.box.style.width = w+'px';   _marquee.box.style.height = h+'px';
      /* Live highlight elements inside marquee */
      var stage = document.getElementById('slide-stage');
      var mr = {left:left, top:top, right:left+w, bottom:top+h};
      stage.querySelectorAll('.slide-el').forEach(function(el) {
        var l = parseInt(el.style.left)||0, t = parseInt(el.style.top)||0;
        var ew = parseInt(el.style.width)||0, eh = parseInt(el.style.height)||0;
        var inside = ew > 0 && eh > 0 && l+ew > mr.left && l < mr.right && t+eh > mr.top && t < mr.bottom;
        el.classList.toggle('sel-el', inside);
      });
    }
    function _onMarqueeEnd(e) {
      document.removeEventListener('mousemove', _onMarqueeMove);
      document.removeEventListener('mouseup',   _onMarqueeEnd);
      if (!_marquee) return;
      var box = _marquee.box;
      var mw = parseFloat(box.style.width), mh = parseFloat(box.style.height);
      box.remove(); _marquee = null;
      if (mw < 4 && mh < 4) return;
      /* Collect highlighted elements */
      var stage = document.getElementById('slide-stage');
      var hit = [];
      stage.querySelectorAll('.sel-el').forEach(function(el){ hit.push(el.dataset.ei); });
      document.querySelectorAll('.sel-handle').forEach(function(h){ h.remove(); });
      if (hit.length === 0) return;
      selectedElIds = hit; selectedElId = hit[hit.length-1];
      if (hit.length === 1) {
        var dom = stage.querySelector('[data-ei="'+hit[0]+'"]');
        if (dom) { addResizeHandles(dom); showBgOnlyToolbar(dom); }
      }
      /* Don't start drag here — user clicks+drags to move after selection */
    }

    function attachEditorHandlers() {
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      stage.removeEventListener('mousedown', _startMarquee);
      stage.addEventListener('mousedown', _startMarquee);
      /* Click on empty slide area → deselect */
      stage.onclick = function(e) {
        if (!editorMode) return;
        if (!e.target.closest('.slide-el') && !e.target.closest('.sel-handle')) {
          clearSelection();
        }
      };
      stage.querySelectorAll('.slide-el').forEach(function(domEl) {
        domEl.style.cursor = 'move';
        domEl.style.outline = '1px dashed transparent';
        domEl.style.transition = 'outline-color .1s';
        domEl.onmouseenter = function() {
          if (editorMode && domEl !== document.querySelector('.sel-el'))
            domEl.style.outlineColor = 'rgba(99,102,241,.4)';
        };
        domEl.onmouseleave = function() {
          if (!domEl.classList.contains('sel-el'))
            domEl.style.outlineColor = 'transparent';
        };
        /* remove old listeners before re-adding */
        domEl.removeEventListener('mousedown', startMove);
        domEl.removeEventListener('dblclick', startTextEdit);
        domEl.removeEventListener('dblclick', startChartEdit);
        domEl.removeEventListener('dblclick', startIconEdit);
        domEl.removeEventListener('dblclick', startVideoEdit);
        domEl.addEventListener('mousedown', startMove);
        var domElId = domEl.getAttribute('data-ei');
        var sl = slides[current];
        var domElData = sl ? (sl.elements||[]).find(function(e){return e.id===domElId;}) : null;
        var elType = domElData ? domElData.type : '';
        if (elType === 'chart_donut' || elType === 'chart_bar') {
          domEl.addEventListener('dblclick', startChartEdit);
        } else if (elType === 'icon') {
          domEl.addEventListener('dblclick', startIconEdit);
        } else if (elType === 'video') {
          domEl.addEventListener('dblclick', startVideoEdit);
        } else {
          domEl.addEventListener('dblclick', startTextEdit);
        }
      });
    }

    function clearSelection() {
      selectedElId = null;
      selectedElIds = [];
      document.querySelectorAll('.sel-el').forEach(function(e){ e.classList.remove('sel-el'); e.style.outlineColor = 'transparent'; });
      document.querySelectorAll('.sel-handle').forEach(function(e){ e.remove(); });
      hideTextToolbar();
      hideElBgBar();
      var ce = document.getElementById('chart-editor');
      if (ce) ce.style.display = 'none';
      var pp = document.getElementById('pos-panel');
      if (pp) pp.style.display = 'none';
    }

    var _dragState = null;
    function startMove(e) {
      if (!editorMode) return;
      e.preventDefault();
      var domEl = e.currentTarget;
      var ei = domEl.dataset.ei;

      /* Ctrl/Cmd+click → toggle this element in multi-selection */
      if (e.ctrlKey || e.metaKey) {
        if (selectedElIds.indexOf(ei) >= 0) {
          selectedElIds = selectedElIds.filter(function(id){ return id !== ei; });
          domEl.classList.remove('sel-el');
        } else {
          selectedElIds.push(ei);
          if (selectedElId && selectedElIds.indexOf(selectedElId) < 0) selectedElIds.push(selectedElId);
          domEl.classList.add('sel-el');
        }
        /* remove resize handles when multi-select */
        document.querySelectorAll('.sel-handle').forEach(function(h){ h.remove(); });
        hideTextToolbar();
        selectedElId = selectedElIds[selectedElIds.length - 1] || null;
        /* start drag for multi */
        if (selectedElIds.length > 0) _startMultiDrag(e);
        return;
      }

      /* If clicking an already-selected element in multi-select → drag the group */
      if (selectedElIds.length > 1 && selectedElIds.indexOf(ei) >= 0) {
        _startMultiDrag(e);
        return;
      }

      /* Regular click → single select */
      clearSelection();
      domEl.classList.add('sel-el');
      selectedElId = ei;
      selectedElIds = [ei];
      addResizeHandles(domEl);
      var si2 = parseInt(domEl.dataset.si);
      var elData2 = slides[si2] && slides[si2].elements.find(function(el2){ return el2.id === ei; });
      if (elData2 && elData2.type === 'text') {
        showTextToolbar(domEl);
      } else {
        /* Show toolbar with only the Nền button for non-text elements */
        hideTextToolbar();
        showBgOnlyToolbar(domEl);
      }

      var stage = document.getElementById('slide-stage');
      var rect = stage.getBoundingClientRect();
      var scale = rect.width / 1280;
      _dragState = { domEl:domEl, startX:e.clientX, startY:e.clientY, startL:parseInt(domEl.style.left)||0, startT:parseInt(domEl.style.top)||0, scale:scale, mode:'move' };
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
    }

    function _startMultiDrag(e) {
      var stage = document.getElementById('slide-stage');
      var rect = stage.getBoundingClientRect();
      var scale = rect.width / 1280;
      /* capture initial positions for all selected elements */
      var els = [];
      selectedElIds.forEach(function(id) {
        var dom = stage.querySelector('[data-ei="'+id+'"]');
        if (dom) els.push({ dom:dom, startL:parseInt(dom.style.left)||0, startT:parseInt(dom.style.top)||0 });
      });
      _dragState = { multi:true, els:els, startX:e.clientX, startY:e.clientY, scale:scale, mode:'move' };
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
    }

    function addResizeHandles(domEl) {
      document.querySelectorAll('.sel-handle').forEach(function(e){e.remove();});
      var positions = [
        {cursor:'nw-resize',left:'-4px',top:'-4px',mode:'nw'},
        {cursor:'n-resize', left:'calc(50% - 4px)',top:'-4px',mode:'n'},
        {cursor:'ne-resize',right:'-4px',top:'-4px',mode:'ne'},
        {cursor:'e-resize', right:'-4px',top:'calc(50% - 4px)',mode:'e'},
        {cursor:'se-resize',right:'-4px',bottom:'-4px',mode:'se'},
        {cursor:'s-resize', left:'calc(50% - 4px)',bottom:'-4px',mode:'s'},
        {cursor:'sw-resize',left:'-4px',bottom:'-4px',mode:'sw'},
        {cursor:'w-resize', left:'-4px',top:'calc(50% - 4px)',mode:'w'}
      ];
      positions.forEach(function(p) {
        var h = document.createElement('div');
        h.className = 'sel-handle';
        h.dataset.mode = p.mode;
        h.style.cursor = p.cursor;
        if (p.left)   h.style.left   = p.left;
        if (p.right)  h.style.right  = p.right;
        if (p.top)    h.style.top    = p.top;
        if (p.bottom) h.style.bottom = p.bottom;
        h.addEventListener('mousedown', startResize);
        domEl.appendChild(h);
      });
    }

    function startResize(e) {
      e.preventDefault(); e.stopPropagation();
      var handle = e.currentTarget;
      var domEl = handle.parentElement;
      var stage = document.getElementById('slide-stage');
      var rect = stage.getBoundingClientRect();
      var scale = rect.width / 1280;
      _dragState = {
        domEl:domEl, startX:e.clientX, startY:e.clientY,
        startL:parseInt(domEl.style.left)||0, startT:parseInt(domEl.style.top)||0,
        startW:domEl.offsetWidth, startH:domEl.offsetHeight,
        scale:scale, mode:handle.dataset.mode
      };
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
    }

    function onDragMove(e) {
      if (!_dragState) return;
      var dx = (e.clientX - _dragState.startX) / _dragState.scale;
      var dy = (e.clientY - _dragState.startY) / _dragState.scale;
      var d = _dragState, mode = d.mode;
      /* Multi-element drag */
      if (d.multi && mode === 'move') {
        d.els.forEach(function(item) {
          item.dom.style.left = Math.round(item.startL + dx) + 'px';
          item.dom.style.top  = Math.round(item.startT + dy) + 'px';
        });
        return;
      }
      var el2 = d.domEl;
      if (mode === 'move') {
        el2.style.left = Math.round(d.startL + dx) + 'px';
        el2.style.top  = Math.round(d.startT + dy) + 'px';
      } else {
        var newL = d.startL, newT = d.startT, newW = d.startW, newH = d.startH;
        if (mode.includes('e'))  newW = Math.max(32, d.startW + dx);
        if (mode.includes('s'))  newH = Math.max(16, d.startH + dy);
        if (mode.includes('w')) { newL = d.startL + dx; newW = Math.max(32, d.startW - dx); }
        if (mode.includes('n')) { newT = d.startT + dy; newH = Math.max(16, d.startH - dy); }
        el2.style.left   = Math.round(newL) + 'px';
        el2.style.top    = Math.round(newT) + 'px';
        el2.style.width  = Math.round(newW) + 'px';
        el2.style.height = Math.round(newH) + 'px';
      }
    }

    function onDragEnd() {
      if (!_dragState) return;
      document.removeEventListener('mousemove', onDragMove);
      document.removeEventListener('mouseup', onDragEnd);
      /* Sync back to deck schema */
      syncDomToSchema();
      _dragState = null;
      saveHistorySnapshot();
      scheduleSave();
      setTimeout(updatePosPanel, 0);
    }

    function syncDomToSchema() {
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      stage.querySelectorAll('.slide-el').forEach(function(domEl) {
        var si = parseInt(domEl.dataset.si);
        var ei = domEl.dataset.ei;
        if (isNaN(si) || !ei || !slides[si]) return;
        var elData = slides[si].elements.find(function(e){ return e.id === ei; });
        if (!elData) return;
        /* Convert px back to inches */
        elData.x = parseFloat(domEl.style.left) / 128;
        elData.y = parseFloat(domEl.style.top)  / 128;
        elData.w = domEl.offsetWidth / 128;
        elData.h = domEl.offsetHeight / 128;
      });
    }

    function startIconEdit(e) {
      if (!editorMode) return;
      e.stopPropagation();
      var domEl = e.currentTarget;
      var elId = domEl.getAttribute('data-ei');
      if (elId) openIconPicker('change', elId);
    }

    function startChartEdit(e) {
      if (!editorMode) return;
      e.stopPropagation();
      var domEl = e.currentTarget;
      var elId = domEl.getAttribute('data-ei');
      if (elId) openChartEditor(elId);
    }

    function startTextEdit(e) {
      if (!editorMode) return;
      var domEl = e.currentTarget;
      if (domEl.dataset.type !== 'text' && !domEl.classList.contains('slide-el')) return;
      var span = domEl.querySelector('span');
      if (!span) return;
      e.preventDefault();
      span.contentEditable = 'true';
      span.focus();
      var range = document.createRange();
      range.selectNodeContents(span);
      window.getSelection().removeAllRanges();
      window.getSelection().addRange(range);
      span.addEventListener('blur', function() {
        span.contentEditable = 'false';
        /* Sync text back */
        var si = parseInt(domEl.dataset.si);
        var ei = domEl.dataset.ei;
        if (!isNaN(si) && ei && slides[si]) {
          var elData = slides[si].elements.find(function(e2){ return e2.id === ei; });
          if (elData) { elData.content = span.textContent; saveHistorySnapshot(); scheduleSave(); }
        }
      }, { once: true });
    }

    /* ─── Text format toolbar ─── */
    var _selectedTextEl = null;

    function showTextToolbar(domEl) {
      _selectedTextEl = domEl;
      /* Restore all toolbar children (might have been hidden by showBgOnlyToolbar) */
      var tbR = document.getElementById('txt-toolbar');
      if (tbR) Array.from(tbR.children).forEach(function(c){
        if (c.id === 'tt-dims' || c.id === 'tt-zorder') c.style.display = 'flex';
        else if (['tt-chart-edit','tt-sep-chart','tt-icon-edit','tt-sep-icon'].indexOf(c.id) >= 0) c.style.display = 'none';
        else c.style.display = '';
      });
      var si = parseInt(domEl.dataset.si);
      var ei = domEl.dataset.ei;
      var elData = slides[si] && slides[si].elements.find(function(e){ return e.id === ei; });
      var s = (elData && elData.style) || {};
      /* populate controls */
      var tb = document.getElementById('txt-toolbar');
      var sz  = document.getElementById('tt-size');
      var col = document.getElementById('tt-color');
      var bold = document.getElementById('tt-bold');
      var ital = document.getElementById('tt-italic');
      var undr = document.getElementById('tt-under');
      var strk = document.getElementById('tt-strike');
      var colorBar = document.getElementById('tt-color-bar');
      var hexInp = document.getElementById('tt-hex');
      /* font label */
      var fontLbl = document.getElementById('tt-family-label');
      if (fontLbl) fontLbl.textContent = (s.fontFamily||'Inter').replace(',sans-serif','');
      if (sz)  { var ptVal = s.fontSize || 12; sz.value = ptVal; }
      if (col) { col.value = s.color || '#1F2A44'; }
      if (colorBar) colorBar.style.background = s.color || '#1F2A44';
      if (hexInp) hexInp.value = s.color || '#1F2A44';
      if (bold) bold.classList.toggle('tt-on', (s.fontWeight||400) >= 700);
      if (ital) ital.classList.toggle('tt-on', s.fontStyle === 'italic');
      if (undr) undr.classList.toggle('tt-on', s.textDecoration === 'underline');
      if (strk) strk.classList.toggle('tt-on', s.textDecoration === 'line-through');
      /* sync align buttons */
      ['tt-al','tt-ac','tt-ar'].forEach(function(id){ var b=document.getElementById(id); if(b)b.classList.remove('tt-on'); });
      var alignMap = {left:'tt-al',center:'tt-ac',right:'tt-ar'};
      var ab = document.getElementById(alignMap[s.align||'left']);
      if (ab) ab.classList.add('tt-on');
      /* sync list buttons */
      ['tt-ul','tt-ol'].forEach(function(id){ var b=document.getElementById(id); if(b)b.classList.remove('tt-on'); });
      if (s.listType) { var lb=document.getElementById('tt-'+s.listType); if(lb)lb.classList.add('tt-on'); }
      /* position near element */
      var stageEl = document.getElementById('slide-stage');
      var rect = domEl.getBoundingClientRect();
      tb.style.display = 'flex';
      tb.style.left = Math.max(8, rect.left) + 'px';
      tb.style.top  = (rect.top - 50) + 'px';
      if (parseFloat(tb.style.top) < 8) tb.style.top = (rect.bottom + 6) + 'px';
      showElBgBar(domEl);
      setTimeout(updatePosPanel, 0);
    }

    function hideTextToolbar() {
      var tb = document.getElementById('txt-toolbar');
      if (tb) tb.style.display = 'none';
      _selectedTextEl = null;
      hideElBgBar();
    }

    function showBgOnlyToolbar(domEl) {
      showElBgBar(domEl);
      var tb = document.getElementById('txt-toolbar');
      if (!tb) return;
      var rect = domEl.getBoundingClientRect();
      var si2 = parseInt(domEl.dataset.si);
      var ei2 = domEl.dataset.ei;
      var elData2 = slides[si2] && (slides[si2].elements||[]).find(function(e){ return e.id === ei2; });
      var elType = elData2 ? elData2.type : '';
      var isChart = elType.indexOf('chart') === 0;
      var isIcon  = elType === 'icon';
      var SHOW = {'tt-bg-wrap':1,'tt-sep-bg':1,'tt-sep-dims':1,'tt-dims':1,'tt-sep-z':1,'tt-zorder':1};
      if (isChart) { SHOW['tt-sep-chart'] = 1; SHOW['tt-chart-edit'] = 1; }
      if (isIcon)  { SHOW['tt-sep-icon']  = 1; SHOW['tt-icon-edit']  = 1; }
      /* Store element id on action buttons so onclick doesn't rely on global */
      var chartBtn = document.getElementById('tt-chart-edit');
      var iconBtn  = document.getElementById('tt-icon-edit');
      if (chartBtn) chartBtn.dataset.elid = ei2;
      if (iconBtn)  iconBtn.dataset.elid  = ei2;
      Array.from(tb.children).forEach(function(c){
        var flex = ['tt-dims','tt-zorder','tt-chart-edit','tt-icon-edit'];
        if (flex.indexOf(c.id) >= 0) c.style.display = SHOW[c.id] ? 'flex' : 'none';
        else c.style.display = SHOW[c.id] ? '' : 'none';
      });
      tb.style.display = 'flex';
      /* Clamp left so toolbar never overflows right edge of viewport */
      var tbW = tb.offsetWidth || 520;
      var leftPos = Math.max(8, rect.left);
      if (leftPos + tbW > window.innerWidth - 8) leftPos = Math.max(8, window.innerWidth - tbW - 8);
      tb.style.left = leftPos + 'px';
      tb.style.top  = (rect.top - 50) + 'px';
      if (parseFloat(tb.style.top) < 8) tb.style.top = (rect.bottom + 6) + 'px';
      setTimeout(updatePosPanel, 0);
    }

    /* ─── Element background bar ─── */
    var EL_BG_PRESETS = [
      '#ffffff','#f1f5f9','#e2e8f0','#1e293b','#0f172a',
      '#dbeafe','#1d4ed8','#dcfce7','#16a34a','#fef9c3',
      '#f59e0b','#fee2e2','#dc2626','#fae8ff','#7c3aed'
    ];

    function showElBgBar(domEl) {
      /* Build swatches in the toolbar dropdown (once) */
      var sw = document.getElementById('tt-bg-swatches');
      if (sw && sw.childElementCount === 0) {
        EL_BG_PRESETS.forEach(function(hex) {
          var s = document.createElement('div');
          s.title = hex;
          s.style.cssText = 'width:18px;height:18px;border-radius:4px;background:'+hex+';border:1.5px solid rgba(255,255,255,.2);cursor:pointer;flex-shrink:0;';
          s.onclick = function(){
            applyElBg(hex);
            var prev = document.getElementById('tt-bg-preview');
            if (prev) prev.style.background = hex;
            document.getElementById('tt-bg-panel').style.display = 'none';
          };
          sw.appendChild(s);
        });
      }
      /* Sync color picker to current element bg */
      var si = parseInt(domEl.dataset.si);
      var ei = domEl.dataset.ei;
      var elData = slides[si] && slides[si].elements.find(function(e){ return e.id === ei; });
      var curBg = (elData && elData.style && elData.style.backgroundColor) || '';
      var ci = document.getElementById('tt-bg-color-input');
      if (ci && curBg && curBg !== 'transparent') ci.value = curBg;
      var prev = document.getElementById('tt-bg-preview');
      if (prev) prev.style.background = (curBg && curBg !== 'transparent') ? curBg : '#ffffff';
      /* Show the bg button in the toolbar */
      var btn = document.getElementById('tt-bg-wrap');
      if (btn) btn.style.display = 'flex';
    }

    function hideElBgBar() {
      var panel = document.getElementById('tt-bg-panel');
      if (panel) panel.style.display = 'none';
    }

    function toggleElBgDropdown() {
      var panel = document.getElementById('tt-bg-panel');
      if (!panel) return;
      panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
    }
    window.toggleElBgDropdown = toggleElBgDropdown;

    function applyElBg(color) {
      if (!selectedElId) return;
      saveHistorySnapshot();
      var stage = document.getElementById('slide-stage');
      var domEl = stage && stage.querySelector('[data-ei="'+selectedElId+'"]');
      if (!domEl) return;
      var si = parseInt(domEl.dataset.si);
      var elData = slides[si] && slides[si].elements.find(function(e){ return e.id === selectedElId; });
      if (!elData) return;
      if (!elData.style) elData.style = {};
      elData.style.backgroundColor = color;
      /* apply directly to DOM without full re-render */
      domEl.style.backgroundColor = color === 'transparent' ? '' : color;
      /* also update the wrapper div background if card element */
      var inner = domEl.querySelector('.card-el, .card-inner, div');
      if (inner) inner.style.backgroundColor = color === 'transparent' ? '' : color;
      scheduleSave();
      /* update toolbar preview dot */
      var ci = document.getElementById('tt-bg-color-input');
      if (ci && color !== 'transparent') ci.value = color;
      var prev = document.getElementById('tt-bg-preview');
      if (prev) prev.style.background = color === 'transparent' ? 'url("data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAgAAAAICAYAAADED76LAAAAHklEQVQoU2NkYGD4z8BQDwAEgAF/QualIQAAAABJRU5ErkJggg==")' : color;
    }
    window.applyElBg = applyElBg;

    /* ─── Chart editor ─── */
    var _chartEditorElId = null;

    function openChartEditor(elId) {
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      var elData = null;
      var sl = slides[current];
      if (sl) { elData = (sl.elements||[]).find(function(e){return e.id===elId;}); }
      if (!elData || !elData.chart) return;

      _chartEditorElId = elId;
      var chart = elData.chart;
      var isDonut = elData.type === 'chart_donut';

      // Center text fields (donut only)
      var centerDiv = document.getElementById('chart-editor-center');
      if (centerDiv) centerDiv.style.display = isDonut ? 'block' : 'none';
      if (isDonut) {
        var parts = (chart.label || '').split('|');
        document.getElementById('ce-center-main').value = parts[0] || '';
        document.getElementById('ce-center-sub').value = parts[1] || '';
      }

      // Data rows
      var rowsEl = document.getElementById('ce-rows');
      rowsEl.innerHTML = '';
      (chart.data || []).forEach(function(d, i) {
        rowsEl.appendChild(ceRowHtml(d.value, d.label, i));
      });

      // Position near the element
      var domEl = stage.querySelector('[data-ei="'+elId+'"]');
      var rect = domEl ? domEl.getBoundingClientRect() : stage.getBoundingClientRect();
      var panel = document.getElementById('chart-editor');
      panel.style.display = 'block';
      var pw = 340, ph = 400;
      var left = rect.right + 12;
      var top = rect.top;
      if (left + pw > window.innerWidth - 8) left = rect.left - pw - 12;
      if (top + ph > window.innerHeight - 8) top = window.innerHeight - ph - 8;
      panel.style.left = Math.max(4, left) + 'px';
      panel.style.top = Math.max(4, top) + 'px';
    }

    function ceRowHtml(val, lbl, idx) {
      var row = document.createElement('div');
      row.style.cssText = 'display:flex;gap:5px;align-items:center;';
      row.innerHTML = '<input type="text" placeholder="Giá trị" value="'+escHtml(String(val||''))+'" style="flex:1;min-width:0;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#fff;font-size:12px;padding:5px 7px;outline:none;">' +
        '<input type="text" placeholder="Nhãn" value="'+escHtml(String(lbl||''))+'" style="flex:1.5;min-width:0;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#fff;font-size:12px;padding:5px 7px;outline:none;">' +
        '<button onclick="event.stopPropagation();this.parentNode.remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:15px;padding:0 2px;flex-shrink:0;">×</button>';
      return row;
    }

    function ceAddRow() {
      var rowsEl = document.getElementById('ce-rows');
      var newRow = ceRowHtml('', '', rowsEl.children.length);
      rowsEl.appendChild(newRow);
      newRow.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      var firstInput = newRow.querySelector('input');
      if (firstInput) firstInput.focus();
    }

    function applyChartEdit() {
      if (!_chartEditorElId) return;
      var sl = slides[current];
      if (!sl) return;
      var elData = (sl.elements||[]).find(function(e){return e.id===_chartEditorElId;});
      if (!elData || !elData.chart) return;

      saveHistorySnapshot();

      // Collect rows
      var rowsEl = document.getElementById('ce-rows');
      var newData = [];
      Array.from(rowsEl.children).forEach(function(row) {
        var inputs = row.querySelectorAll('input');
        var val = inputs[0] ? inputs[0].value.trim() : '';
        var lbl = inputs[1] ? inputs[1].value.trim() : '';
        if (val !== '' || lbl !== '') newData.push({ value: isNaN(parseFloat(val)) ? val : parseFloat(val), label: lbl });
      });
      elData.chart.data = newData;

      // Center label (donut)
      if (elData.type === 'chart_donut') {
        var main = document.getElementById('ce-center-main').value.trim();
        var sub = document.getElementById('ce-center-sub').value.trim();
        elData.chart.label = sub ? main + '|' + sub : main;
      }

      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      renderThumbnails();
      autoSave();
      /* Keep popup open — only close via the × button */
    }

    function closeChartEditor() {
      var panel = document.getElementById('chart-editor');
      if (panel) panel.style.display = 'none';
      _chartEditorElId = null;
    }

