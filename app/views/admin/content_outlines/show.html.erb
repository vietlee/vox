        accent: '#4ade80', accentAlt: '#86efac', num: '#4ade80',
        text: '#fff', sub: 'rgba(200,255,220,0.6)',
        glass: 'rgba(74,222,128,0.08)', glassBorder: 'rgba(74,222,128,0.25)',
        numBg: '#052e16', numColor: '#4ade80',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#010d06"/>' +
            /* moonlight glow top center */
            '<ellipse cx="640" cy="-80" rx="400" ry="300" fill="#4ade80" filter="url(#blur100)" opacity=".2"/>' +
            '<ellipse cx="640" cy="-60" rx="200" ry="200" fill="#bbf7d0" filter="url(#blur80)"  opacity=".12"/>' +
            /* deep forest ground */
            '<ellipse cx="640" cy="820" rx="800" ry="300" fill="#052e16" filter="url(#blur60)" opacity=".9"/>' +
            '<ellipse cx="100" cy="600" rx="200" ry="300" fill="#064e3b" filter="url(#blur60)" opacity=".7"/>' +
            '<ellipse cx="1180" cy="580" rx="200" ry="300" fill="#064e3b" filter="url(#blur60)" opacity=".7"/>' +
            /* tree silhouette paths */
            '<path d="M100,720 L160,400 L200,500 L240,350 L280,450 L320,720 Z" fill="#052e16" opacity=".8"/>' +
            '<path d="M960,720 L1020,380 L1060,480 L1100,330 L1140,440 L1180,720 Z" fill="#052e16" opacity=".8"/>' +
            /* stars */
            '<circle cx="300"  cy="80"  r="1.5" fill="#fff" opacity=".6"/>' +
            '<circle cx="450"  cy="50"  r="1"   fill="#fff" opacity=".5"/>' +
            '<circle cx="600"  cy="90"  r="1.5" fill="#fff" opacity=".7"/>' +
            '<circle cx="750"  cy="40"  r="1"   fill="#fff" opacity=".5"/>' +
            '<circle cx="900"  cy="70"  r="1.5" fill="#fff" opacity=".6"/>' +
            '<circle cx="1050" cy="55"  r="1"   fill="#fff" opacity=".4"/>' +
            '<circle cx="200"  cy="160" r="1"   fill="#fff" opacity=".4"/>' +
            '<circle cx="1100" cy="140" r="1.5" fill="#fff" opacity=".5"/>' +
            /* accent line */
            '<rect x="0" y="0" width="1280" height="2" fill="#4ade80" opacity=".6"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#010d06"/>' +
            '<ellipse cx="640" cy="-120" rx="350" ry="280" fill="#4ade80" filter="url(#blur100)" opacity=".15"/>' +
            '<ellipse cx="0"   cy="720"  rx="200" ry="200" fill="#064e3b" filter="url(#blur60)"  opacity=".7"/>' +
            '<ellipse cx="1280" cy="720" rx="200" ry="200" fill="#064e3b" filter="url(#blur60)"  opacity=".7"/>' +
            /* star dots */
            '<circle cx="900" cy="40"  r="1.2" fill="#fff" opacity=".5"/>' +
            '<circle cx="1100" cy="30" r="1"   fill="#fff" opacity=".4"/>' +
            '<rect x="0" y="0"   width="1280" height="76" fill="rgba(1,13,6,0.8)"/>' +
            '<rect x="0" y="0"   width="1280" height="2"  fill="#4ade80" opacity=".7"/>' +
            '<rect x="0" y="76"  width="1280" height="1"  fill="rgba(74,222,128,0.2)"/>';
        },
        coverLayout: 'center',
      },

    ]; /* end THEMES */

    /* ─────────────────────────────────────────────────────────────────
       SVG wrapper
    ───────────────────────────────────────────────────────────────── */
    function svgBg(inner) {
      return '<svg style="position:absolute;inset:0;width:100%;height:100%;" viewBox="0 0 1280 720" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">' + inner + '</svg>';
    }

    /* ─────────────────────────────────────────────────────────────────
       COVER
    ───────────────────────────────────────────────────────────────── */
    function renderCover(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var sColor = t.light ? t.sub  : 'rgba(255,255,255,.65)';
      var layout = t.coverLayout || 'center';

      var bgSvg  = typeof t.coverBg === 'function'
        ? t.coverBg(s.title)
        : t.coverBg;

      var contentHtml;
      if (layout === 'left-panel') {
        /* Light theme: text on right side of left panel */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8% 7% 8% 37%;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:20px;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(22px,3.8vw,48px);font-weight:900;color:' + tColor + ';line-height:1.1;margin-bottom:24px;">' + s.title + '</div>' +
            '<div style="width:48px;height:5px;border-radius:3px;background:' + t.accent + ';margin-bottom:22px;"></div>' +
            (s.bullets.length ? '<div style="font-size:clamp(13px,1.5vw,17px);color:' + sColor + ';line-height:1.85;">' + s.bullets.map(function(b){ return b; }).join('<br>') + '</div>' : '') +
          '</div>';

        /* Left panel decorative text */
        var shortTitle = s.title.substring(0,2).toUpperCase();
        contentHtml +=
          '<div style="position:absolute;left:0;top:0;width:420px;height:100%;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;">' +
            '<div style="font-size:72px;font-weight:900;color:' + t.accent + ';opacity:.15;letter-spacing:-4px;">' + shortTitle + '</div>' +
          '</div>';

      } else if (layout === 'left-card') {
        /* Glass theme: content inside left glass card */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;align-items:center;padding:0 7%;">' +
            '<div style="max-width:52%;background:rgba(255,255,255,0.1);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.2);border-radius:24px;padding:40px 44px;">' +
              '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:rgba(255,255,255,.6);text-transform:uppercase;margin-bottom:20px;">01 / ' + String(total).padStart(2,'0') + '</div>' +
              '<div style="font-size:clamp(20px,3.2vw,40px);font-weight:900;color:#fff;line-height:1.15;margin-bottom:20px;">' + s.title + '</div>' +
              '<div style="width:44px;height:4px;border-radius:2px;background:' + t.accentAlt + ';margin-bottom:18px;"></div>' +
              (s.bullets.length ? '<div style="font-size:clamp(12px,1.4vw,16px);color:rgba(255,255,255,.72);line-height:1.8;">' + s.bullets.map(function(b){ return '· ' + b; }).join('<br>') + '</div>' : '') +
            '</div>' +
          '</div>';

      } else if (layout === 'left') {
        var coverTxt = (t.name === 'neo' || t.coverBranding) ? t.text : '#fff';
        var coverSub2 = (t.name === 'neo' || t.coverBranding) ? 'rgba(0,0,0,0.6)' : 'rgba(255,255,255,.58)';
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8% 5% 8% 8%;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:24px;opacity:.9;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(28px,5vw,64px);font-weight:900;color:' + coverTxt + ';line-height:1.05;margin-bottom:24px;max-width:700px;">' + s.title + '</div>' +
            '<div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">' +
              '<div style="width:48px;height:5px;border-radius:3px;background:' + t.accent + ';"></div>' +
              '<div style="width:20px;height:5px;border-radius:3px;background:' + t.accentAlt + ';opacity:.7;"></div>' +
            '</div>' +
            (s.bullets.length ? '<div style="font-size:clamp(13px,1.5vw,17px);color:' + coverSub2 + ';line-height:1.85;max-width:600px;">' + s.bullets.map(function(b){ return '· ' + b; }).join('<br>') + '</div>' : '') +
          '</div>';

      } else {
        /* center — Aurora, Neon, Coral */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:8% 10%;text-align:center;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:22px;opacity:.9;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(24px,4.2vw,52px);font-weight:900;color:#fff;line-height:1.1;margin-bottom:22px;max-width:860px;">' + s.title + '</div>' +
            '<div style="width:52px;height:4px;border-radius:3px;background:' + t.accent + ';margin-bottom:22px;"></div>' +
            (s.bullets.length
              ? '<div style="font-size:clamp(13px,1.5vw,17px);color:rgba(255,255,255,.65);line-height:1.85;max-width:700px;">' +
                  s.bullets.map(function(b){ return b; }).join('&ensp;·&ensp;') + '</div>'
              : '') +
          '</div>';
      }

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) + contentHtml + '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       CONTENT
    ───────────────────────────────────────────────────────────────── */
    function renderContent(s, idx, t) {
      var tColor = t.light ? t.text : '#fff';
      var numBg    = t.numBg    || (t.light ? t.accent : t.accent);
      var numColor = t.numColor || (t.light ? '#fff'   : '#0a0a0a');
      var defaultCard = 'background:' + t.glass + ';border:1px solid ' + t.glassBorder + ';border-radius:14px;' + (t.light ? '' : 'backdrop-filter:blur(8px);');
      var cardCss  = t.cardStyle || defaultCard;

      var bulletsHtml = s.bullets.map(function(b, bi) {
        return '<div class="f-up" style="' +
          'display:flex;align-items:flex-start;gap:14px;' +
          'padding:12px 18px 12px 16px;' +
          cardCss +
          'animation-delay:' + (bi*0.09) + 's;' +
          'margin-bottom:9px;">' +
          '<div style="min-width:28px;height:28px;border-radius:8px;' +
            'background:' + numBg + ';color:' + numColor + ';' +
            (t.numBorderColor ? 'border:1.5px solid ' + t.numBorderColor + ';background:transparent;' : '') +
            'display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;flex-shrink:0;margin-top:1px;">' +
            String(bi+1).padStart(2,'0') +
          '</div>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.35vw,15px);line-height:1.65;">' + b + '</span>' +
        '</div>';
      }).join('');

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(t.contentBg()) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:0 5% 3%;">' +
          /* ─ header ─ */
          '<div style="height:76px;display:flex;align-items:center;gap:14px;">' +
            '<span style="background:' + t.accent + ';' +
              'color:' + (t.numColor || (t.light ? '#fff' : '#0a0a0a')) + ';' +
              'font-size:10px;font-weight:900;padding:5px 13px;border-radius:20px;letter-spacing:1px;flex-shrink:0;">' +
              String(idx+1).padStart(2,'0') + ' / ' + String(total).padStart(2,'0') +
            '</span>' +
            '<h2 style="color:' + tColor + ';font-size:clamp(16px,2.1vw,26px);font-weight:800;margin:0;line-height:1.2;">' + s.title + '</h2>' +
          '</div>' +
          /* ─ bullets ─ */
          '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + bulletsHtml + '</div>' +
        '</div>' +
      '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       SUMMARY
    ───────────────────────────────────────────────────────────────── */
    function renderSummary(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var icons  = ['✅','💡','🎯','📌','⭐','🔑','🚀','🏆'];

      var bulletsHtml = s.bullets.map(function(b, bi) {
        return '<div class="f-up" style="display:flex;align-items:center;gap:13px;padding:11px 18px;' +
          'background:' + t.glass + ';border:1px solid ' + t.glassBorder + ';border-radius:12px;' +
          (t.light ? '' : 'backdrop-filter:blur(8px);') +
          'animation-delay:' + (bi*0.09) + 's;margin-bottom:8px;">' +
          '<span style="font-size:20px;flex-shrink:0;">' + (icons[bi]||'▸') + '</span>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.3vw,14px);line-height:1.6;">' + b + '</span>' +
        '</div>';
      }).join('');

      var bgSvg = typeof t.coverBg === 'function' ? t.coverBg(s.title) : t.coverBg;

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5% 9%;text-align:center;">' +
          '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:14px;opacity:.85;">Tóm tắt</div>' +
          '<h2 style="color:' + (t.light?t.text:'#fff') + ';font-size:clamp(18px,2.8vw,36px);font-weight:900;margin:0 0 14px;line-height:1.15;">' + s.title + '</h2>' +
          '<div style="width:44px;height:4px;background:' + t.accent + ';border-radius:2px;margin-bottom:22px;"></div>' +
          '<div style="width:100%;max-width:700px;text-align:left;">' + bulletsHtml + '</div>' +
        '</div>' +
      '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       THEME PICKER — color swatches
    ───────────────────────────────────────────────────────────────── */
    var swatchColors = ['#7c3aed','#00f5c4','#a21caf','#facc15','#be123c','#6366f1','#c026d3','#faff00','#1e3a5f','#f0abfc','#f97316','#d4a757','#1a1100','#ff006e','#f5d0fe','#4ade80'];
    var pickerHtml = THEMES.map(function(t, i) {
      return '<button onclick="setTheme(' + i + ')" id="theme-btn-' + i + '" title="' + t.label + '" ' +
        'style="width:28px;height:28px;border-radius:50%;border:3px solid transparent;cursor:pointer;' +
        'background:' + swatchColors[i] + ';transition:all .15s;flex-shrink:0;" />';
    }).join('');
    document.getElementById('slide-dots').insertAdjacentHTML('beforebegin',
      '<div id="theme-picker" style="display:flex;align-items:center;gap:6px;">' +
        '<span style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:2px;margin-right:2px;">Theme</span>' +
        pickerHtml +
      '</div>'
    );

    var activeThemeIdx = 0;
    window.setTheme = function(i) {
      activeThemeIdx = i;
      document.querySelectorAll('[id^="theme-btn-"]').forEach(function(b, j) {
        b.style.borderColor = j === i ? '#fff' : 'transparent';
        b.style.transform   = j === i ? 'scale(1.2)' : 'scale(1)';
        b.style.boxShadow   = j === i ? '0 0 0 2px #6366f1' : 'none';
      });
      render();
    };
    setTheme(0);

    /* ─────────────────────────────────────────────────────────────────
       RENDER
    ───────────────────────────────────────────────────────────────── */
    function render() {
      if (!slides.length) return;
      var s = slides[current];
      var t = THEMES[activeThemeIdx];
      var isFirst = current === 0, isLast = current === total - 1;

      document.getElementById('slide-viewer').innerHTML =
        isFirst ? renderCover(s, t) :
        isLast  ? renderSummary(s, t) :
                  renderContent(s, current, t);

      document.getElementById('slide-counter').textContent = (current+1) + ' / ' + total;

      /* progress dots */
      document.getElementById('slide-dots').innerHTML = slides.map(function(_, i) {
        return '<div style="width:' + (i===current?'18px':'5px') + ';height:5px;border-radius:3px;' +
          'background:' + (i===current?'#6366f1':'#cbd5e1') + ';transition:all .25s;"></div>';
      }).join('');

      var noteEl = document.getElementById('slide-note');
      if (s.note) { document.getElementById('slide-note-text').textContent = s.note; noteEl.classList.remove('hidden'); }
      else { noteEl.classList.add('hidden'); }
    }

    window.prevSlide = function() { if (current > 0) { current--; render(); } };
    window.nextSlide = function() { if (current < total-1) { current++; render(); } };
    window.enterFullscreen = function() {
      var w = document.getElementById('slide-viewer').parentElement;
      (w.requestFullscreen || w.webkitRequestFullscreen || function(){}).call(w);
    };
    document.addEventListener('keydown', function(e) {
      if (e.key==='ArrowRight'||e.key==='ArrowDown') nextSlide();
      if (e.key==='ArrowLeft' ||e.key==='ArrowUp')   prevSlide();
    });
    var tx = null;
    document.getElementById('slide-viewer').addEventListener('touchstart', function(e){ tx = e.touches[0].clientX; });
    document.getElementById('slide-viewer').addEventListener('touchend',   function(e){
      if (!tx) return;
      var dx = e.changedTouches[0].clientX - tx;
      if (dx < -40) nextSlide(); else if (dx > 40) prevSlide();
      tx = null;
    });

    render();
  })();
  </script>

<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nội dung được tạo bởi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='Đã sao chép!'; setTimeout(()=>this.textContent='Sao chép',2000)})"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        Sao chép
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>
