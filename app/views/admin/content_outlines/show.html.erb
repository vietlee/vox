<% content_for :title, @outline.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @outline.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "outline" => "рҹ“Ӣ DГ n ГҪ", "slide" => "рҹ–ҘпёҸ Slide", "slide_script" => "рҹ–ҘпёҸ Slide", "lesson_plan" => "рҹ“ҡ Kбәҝ hoбәЎch buб»•i hб»Қc" }[@outline.output_type] %></span>
      <% if @outline.subject.present? %><span>В· <%= @outline.subject %></span><% end %>
      <span>В· <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @outline.pptx_file.attached? %>
      <%= link_to rails_blob_path(@outline.pptx_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        TбәЈi PPTX
      <% end %>
    <% end %>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "flex items-center gap-1.5 px-3 py-2 bg-violet-50 hover:bg-violet-100 text-violet-700 text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      TбәЎo lбәЎi
    <% end %>
  </div>
</div>

<% if @outline.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url: status_content_outline_path(@outline, format: :json),
        message: "AI Д‘ang tбәЎo #{@outline.output_type == 'slide' ? 'slide' : 'nб»ҷi dung'}...",
        submessage: "Дҗб»«ng tбәҜt trang nГ y." %>
<% elsif @outline.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">вҡ пёҸ</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2">CГі lб»—i xбәЈy ra khi tбәЎo nб»ҷi dung</h3>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "mt-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer" do %>
      Thб»ӯ lбәЎi
    <% end %>
  </div>
<% elsif @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.include?("slide-deck-root") %>
  <!-- Slide viewer -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="border-b border-slate-100 px-5 py-2.5 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">рҹ–ҘпёҸ Slide thuyбәҝt trГ¬nh</span>
        <!-- Progress dots -->
        <div id="slide-dots" class="flex gap-1"></div>
      </div>
      <button onclick="enterFullscreen()"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        вӣ¶ ToГ n mГ n hГ¬nh
      </button>
    </div>

    <!-- 16:9 aspect ratio wrapper -->
    <div style="position:relative; padding-bottom:56.25%; background:#0f172a; overflow:hidden;">
      <div id="slide-viewer" style="position:absolute; inset:0; overflow:hidden;"></div>
    </div>

    <div class="border-t border-slate-100 px-5 py-2.5 flex items-center justify-between bg-slate-50">
      <button onclick="prevSlide()"
              style="border:1px solid #e2e8f0;"
              class="px-4 py-2 bg-white rounded-xl text-[13px] font-semibold text-slate-600 hover:bg-slate-100 transition-colors cursor-pointer shadow-sm">
        вҶҗ TrЖ°б»ӣc
      </button>
      <span id="slide-counter" class="text-[12px] text-slate-500 font-semibold"></span>
      <button onclick="nextSlide()"
              class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-xl text-[13px] font-bold text-white transition-colors border-0 cursor-pointer shadow-sm">
        Tiбәҝp вҶ’
      </button>
    </div>
    <div id="slide-note" class="hidden border-t border-slate-100 px-5 py-3 bg-amber-50">
      <div class="text-[10px] font-bold text-amber-600 uppercase tracking-wide mb-1">рҹ’¬ Ghi chГә ngЖ°б»қi trГ¬nh bГ y</div>
      <p id="slide-note-text" class="text-[13px] text-amber-800 leading-relaxed"></p>
    </div>
  </div>

  <div id="slide-data" class="hidden"><%= raw @outline.content %></div>

  <style>
    #slide-viewer * { box-sizing:border-box; }
    @keyframes sIn { from{opacity:0;transform:translateX(28px)} to{opacity:1;transform:translateX(0)} }
    @keyframes fUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    .s-in { animation:sIn .38s cubic-bezier(.22,.68,0,1.2) forwards; }
    .f-up { animation:fUp .3s ease both; }
  </style>

  <script>
  (function() {
    var el = document.getElementById('slide-data').querySelector('#slide-deck-root');
    var slides = JSON.parse(el.dataset.slides || '[]');
    var current = 0, total = slides.length;

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       SVG DEFS shared across themes  (blur filter for glow blobs)
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    var DEFS = '<defs>' +
      '<filter id="blur60" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="60"/></filter>' +
      '<filter id="blur40" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="40"/></filter>' +
      '<filter id="blur80" x="-50%" y="-50%" width="200%" height="200%"><feGaussianBlur stdDeviation="80"/></filter>' +
      '<filter id="glow"   x="-40%" y="-40%" width="180%" height="180%">' +
        '<feGaussianBlur stdDeviation="8" result="blur"/>' +
        '<feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>' +
      '</filter>' +
      /* dot grid pattern */ '<pattern id="dots" width="32" height="32" patternUnits="userSpaceOnUse">' +
        '<circle cx="2" cy="2" r="1.2" fill="rgba(255,255,255,0.12)"/>' +
      '</pattern>' +
      /* fine grid */ '<pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">' +
        '<path d="M60,0 L0,0 0,60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="1"/>' +
      '</pattern>' +
    '</defs>';

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       6 MODERN THEMES
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    var THEMES = [

      /* в”Җв”Җ 0  AURORA MESH в”Җв”Җ soft glow blobs on deep navy в”Җв”Җ */
      {
        label: 'рҹҢҢ Aurora',
        accent: '#e879f9', accentAlt: '#67e8f9', num: '#e879f9',
        text: '#fff', sub: 'rgba(255,255,255,.65)',
        glass: 'rgba(255,255,255,0.07)', glassBorder: 'rgba(255,255,255,0.15)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#06071a"/>' +
            /* mesh blobs */
            '<ellipse cx="200"  cy="160"  rx="340" ry="280" fill="#7c3aed" filter="url(#blur80)" opacity=".7"/>' +
            '<ellipse cx="1100" cy="560"  rx="380" ry="300" fill="#0891b2" filter="url(#blur80)" opacity=".65"/>' +
            '<ellipse cx="780"  cy="80"   rx="260" ry="200" fill="#db2777" filter="url(#blur60)" opacity=".55"/>' +
            '<ellipse cx="400"  cy="650"  rx="200" ry="160" fill="#4f46e5" filter="url(#blur60)" opacity=".5"/>' +
            '<rect width="1280" height="720" fill="url(#dots)"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#06071a"/>' +
            '<ellipse cx="120"  cy="100"  rx="250" ry="200" fill="#7c3aed" filter="url(#blur60)" opacity=".6"/>' +
            '<ellipse cx="1180" cy="620"  rx="280" ry="220" fill="#0891b2" filter="url(#blur60)" opacity=".5"/>' +
            '<rect width="1280" height="720" fill="url(#dots)"/>' +
            /* header glass bar */
            '<rect x="0" y="0" width="1280" height="76" fill="rgba(255,255,255,0.04)"/>' +
            '<rect x="0" y="76" width="1280" height="1" fill="rgba(255,255,255,0.1)"/>';
        },
        coverLayout: 'center',
      },

      /* в”Җв”Җ 1  NEON GRID в”Җв”Җ dark bg, cyan/green neon with grid в”Җв”Җ */
      {
        label: 'вҡЎ Neon',
        accent: '#00f5c4', accentAlt: '#b9ff66', num: '#00f5c4',
        text: '#fff', sub: 'rgba(255,255,255,.6)',
        glass: 'rgba(0,245,196,0.07)', glassBorder: 'rgba(0,245,196,0.25)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#050d0a"/>' +
            '<rect width="1280" height="720" fill="url(#grid)"/>' +
            /* neon glow orbs */
            '<circle cx="140"  cy="360" r="200" fill="#00f5c4" filter="url(#blur80)" opacity=".25"/>' +
            '<circle cx="1140" cy="360" r="200" fill="#b9ff66" filter="url(#blur80)" opacity=".2"/>' +
            '<circle cx="640"  cy="700" r="180" fill="#00f5c4" filter="url(#blur60)" opacity=".15"/>' +
            /* neon horizontal lines */
            '<line x1="0" y1="2"   x2="1280" y2="2"   stroke="#00f5c4" stroke-width="2" opacity=".8" filter="url(#glow)"/>' +
            '<line x1="0" y1="718" x2="1280" y2="718" stroke="#00f5c4" stroke-width="2" opacity=".8" filter="url(#glow)"/>' +
            /* vertical accent */
            '<line x1="100" y1="0" x2="100" y2="720" stroke="#00f5c4" stroke-width="1" opacity=".2"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#050d0a"/>' +
            '<rect width="1280" height="720" fill="url(#grid)"/>' +
            '<circle cx="640" cy="-100" r="300" fill="#00f5c4" filter="url(#blur80)" opacity=".18"/>' +
            '<line x1="0" y1="76" x2="1280" y2="76" stroke="#00f5c4" stroke-width="1.5" opacity=".6" filter="url(#glow)"/>' +
            '<line x1="0" y1="2"  x2="1280" y2="2"  stroke="#00f5c4" stroke-width="2"   opacity=".9" filter="url(#glow)"/>';
        },
        coverLayout: 'center',
      },

      /* в”Җв”Җ 2  GLASS VIOLET в”Җв”Җ vivid purple gradient + glassmorphism в”Җв”Җ */
      {
        label: 'рҹ’Һ Glass',
        accent: '#fff', accentAlt: '#f0abfc', num: '#f0abfc',
        text: '#fff', sub: 'rgba(255,255,255,.7)',
        glass: 'rgba(255,255,255,0.12)', glassBorder: 'rgba(255,255,255,0.25)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#3b0764"/>' +
            /* gradient fill via radial blobs */
            '<circle cx="0"    cy="0"   r="500" fill="#7e22ce" filter="url(#blur80)" opacity=".9"/>' +
            '<circle cx="1280" cy="720" r="500" fill="#1d4ed8" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="640"  cy="360" r="300" fill="#a21caf" filter="url(#blur80)" opacity=".4"/>' +
            /* glass card outline on cover */
            '<rect x="80" y="160" width="560" height="400" rx="24" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#3b0764"/>' +
            '<circle cx="0"    cy="0"   r="400" fill="#7e22ce" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="1280" cy="720" r="400" fill="#1d4ed8" filter="url(#blur80)" opacity=".7"/>' +
            '<rect x="0" y="0" width="1280" height="78" fill="rgba(255,255,255,0.08)"/>' +
            '<rect x="0" y="78" width="1280" height="1" fill="rgba(255,255,255,0.18)"/>';
        },
        coverLayout: 'left-card',
      },

      /* в”Җв”Җ 3  BOLD INK в”Җв”Җ near-black, huge faded watermark text, warm accent в”Җв”Җ */
      {
        label: 'рҹ–Ө Bold',
        accent: '#facc15', accentAlt: '#fb923c', num: '#facc15',
        text: '#fff', sub: 'rgba(255,255,255,.55)',
        glass: 'rgba(250,204,21,0.08)', glassBorder: 'rgba(250,204,21,0.3)',
        coverBg: function(title) {
          var safe = (title || '').replace(/[<>&"]/g,'').substring(0,18).toUpperCase();
          return DEFS +
            '<rect width="1280" height="720" fill="#0a0a0a"/>' +
            /* big watermark word */
            '<text x="640" y="480" text-anchor="middle" font-size="320" font-weight="900" fill="#1a1a1a" font-family="system-ui,sans-serif" letter-spacing="-10">' + safe + '</text>' +
            /* diagonal accent stripe */
            '<polygon points="900,0 1280,0 1280,200 980,0" fill="#facc15" opacity=".08"/>' +
            '<polygon points="960,0 1280,0 1280,80"  fill="#facc15" opacity=".15"/>' +
            '<line x1="0" y1="0" x2="0" y2="720" stroke="#facc15" stroke-width="6"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#0a0a0a"/>' +
            '<rect x="0" y="0" width="6" height="720" fill="#facc15"/>' +
            '<rect x="0" y="0" width="1280" height="76" fill="#111"/>' +
            '<rect x="0" y="76" width="1280" height="1" fill="#222"/>';
        },
        coverLayout: 'left',
        coverWatermark: true,
      },

      /* в”Җв”Җ 4  CORAL DUSK в”Җв”Җ warm gradient, fluid curves, clean modern в”Җв”Җ */
      {
        label: 'рҹҢҮ Coral',
        accent: '#fda4af', accentAlt: '#fed7aa', num: '#fb7185',
        text: '#fff', sub: 'rgba(255,255,255,.65)',
        glass: 'rgba(255,255,255,0.1)', glassBorder: 'rgba(255,200,180,0.3)',
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#881337"/>' +
            '<circle cx="0"    cy="0"   r="500" fill="#be123c" filter="url(#blur80)" opacity=".9"/>' +
            '<circle cx="1280" cy="720" r="400" fill="#c2410c" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="800"  cy="200" r="300" fill="#e11d48" filter="url(#blur60)" opacity=".4"/>' +
            /* fluid curve */
            '<path d="M0,500 C320,420 640,580 1280,460 L1280,720 L0,720 Z" fill="rgba(0,0,0,0.2)"/>' +
            '<path d="M0,540 C400,460 840,580 1280,500 L1280,720 L0,720 Z" fill="rgba(0,0,0,0.15)"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#881337"/>' +
            '<circle cx="0"    cy="0"   r="350" fill="#be123c" filter="url(#blur80)" opacity=".8"/>' +
            '<circle cx="1280" cy="720" r="300" fill="#c2410c" filter="url(#blur80)" opacity=".7"/>' +
            '<rect x="0" y="0" width="1280" height="76" fill="rgba(0,0,0,0.2)"/>' +
            '<rect x="0" y="76" width="1280" height="1" fill="rgba(255,255,255,0.15)"/>';
        },
        coverLayout: 'center',
      },

      /* в”Җв”Җ 5  PURE LIGHT в”Җв”Җ white, editorial, modern minimal в”Җв”Җ */
      {
        label: 'вҳҖпёҸ Light',
        accent: '#6366f1', accentAlt: '#ec4899', num: '#6366f1',
        text: '#0f172a', sub: '#64748b',
        glass: 'rgba(99,102,241,0.06)', glassBorder: 'rgba(99,102,241,0.2)',
        light: true,
        coverBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#fff"/>' +
            /* subtle colored strips top-left */
            '<rect x="0" y="0" width="420" height="720" fill="#f8faff"/>' +
            '<rect x="420" y="0" width="2" height="720" fill="#e0e7ff"/>' +
            /* accent bar top */
            '<rect x="0" y="0" width="420" height="6" fill="#6366f1"/>' +
            /* decorative circles on left panel */
            '<circle cx="210" cy="480" r="280" fill="#eef2ff" opacity=".8"/>' +
            '<circle cx="210" cy="480" r="140" fill="#e0e7ff" opacity=".5"/>' +
            '<circle cx="210" cy="480" r="60"  fill="#c7d2fe" opacity=".4"/>';
        },
        contentBg: function() {
          return DEFS +
            '<rect width="1280" height="720" fill="#fff"/>' +
            /* thin top bar */
            '<rect x="0" y="0" width="1280" height="76" fill="#f8faff"/>' +
            '<rect x="0" y="76" width="1280" height="2" fill="#e0e7ff"/>' +
            '<rect x="0" y="0" width="4" height="76" fill="#6366f1"/>';
        },
        coverLayout: 'left-panel',
      },

    ]; /* end THEMES */

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       SVG wrapper
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    function svgBg(inner) {
      return '<svg style="position:absolute;inset:0;width:100%;height:100%;" viewBox="0 0 1280 720" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">' + inner + '</svg>';
    }

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       COVER
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    function renderCover(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var sColor = t.light ? t.sub  : 'rgba(255,255,255,.65)';
      var layout = t.coverLayout || 'center';

      var bgSvg  = typeof t.coverBg === 'function'
        ? t.coverBg(s.title)
        : t.coverBg;

      var contentHtml;
      if (layout === 'left-panel') {
        /* Light theme: text on right side of left panel */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8% 7% 8% 37%;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:20px;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(22px,3.8vw,48px);font-weight:900;color:' + tColor + ';line-height:1.1;margin-bottom:24px;">' + s.title + '</div>' +
            '<div style="width:48px;height:5px;border-radius:3px;background:' + t.accent + ';margin-bottom:22px;"></div>' +
            (s.bullets.length ? '<div style="font-size:clamp(13px,1.5vw,17px);color:' + sColor + ';line-height:1.85;">' + s.bullets.map(function(b){ return b; }).join('<br>') + '</div>' : '') +
          '</div>';

        /* Left panel decorative text */
        var shortTitle = s.title.substring(0,2).toUpperCase();
        contentHtml +=
          '<div style="position:absolute;left:0;top:0;width:420px;height:100%;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;">' +
            '<div style="font-size:72px;font-weight:900;color:' + t.accent + ';opacity:.15;letter-spacing:-4px;">' + shortTitle + '</div>' +
          '</div>';

      } else if (layout === 'left-card') {
        /* Glass theme: content inside left glass card */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;align-items:center;padding:0 7%;">' +
            '<div style="max-width:52%;background:rgba(255,255,255,0.1);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,0.2);border-radius:24px;padding:40px 44px;">' +
              '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:rgba(255,255,255,.6);text-transform:uppercase;margin-bottom:20px;">01 / ' + String(total).padStart(2,'0') + '</div>' +
              '<div style="font-size:clamp(20px,3.2vw,40px);font-weight:900;color:#fff;line-height:1.15;margin-bottom:20px;">' + s.title + '</div>' +
              '<div style="width:44px;height:4px;border-radius:2px;background:' + t.accentAlt + ';margin-bottom:18px;"></div>' +
              (s.bullets.length ? '<div style="font-size:clamp(12px,1.4vw,16px);color:rgba(255,255,255,.72);line-height:1.8;">' + s.bullets.map(function(b){ return 'В· ' + b; }).join('<br>') + '</div>' : '') +
            '</div>' +
          '</div>';

      } else if (layout === 'left') {
        /* Bold theme: left-aligned, no glass card */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8% 5% 8% 8%;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:24px;opacity:.9;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(28px,5vw,64px);font-weight:900;color:#fff;line-height:1.05;margin-bottom:24px;max-width:700px;">' + s.title + '</div>' +
            '<div style="display:flex;align-items:center;gap:16px;margin-bottom:28px;">' +
              '<div style="width:48px;height:5px;border-radius:3px;background:' + t.accent + ';"></div>' +
              '<div style="width:20px;height:5px;border-radius:3px;background:' + t.accentAlt + ';opacity:.7;"></div>' +
            '</div>' +
            (s.bullets.length ? '<div style="font-size:clamp(13px,1.5vw,17px);color:rgba(255,255,255,.58);line-height:1.85;max-width:600px;">' + s.bullets.map(function(b){ return 'В· ' + b; }).join('<br>') + '</div>' : '') +
          '</div>';

      } else {
        /* center вҖ” Aurora, Neon, Coral */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:8% 10%;text-align:center;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:22px;opacity:.9;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(24px,4.2vw,52px);font-weight:900;color:#fff;line-height:1.1;margin-bottom:22px;max-width:860px;">' + s.title + '</div>' +
            '<div style="width:52px;height:4px;border-radius:3px;background:' + t.accent + ';margin-bottom:22px;"></div>' +
            (s.bullets.length
              ? '<div style="font-size:clamp(13px,1.5vw,17px);color:rgba(255,255,255,.65);line-height:1.85;max-width:700px;">' +
                  s.bullets.map(function(b){ return b; }).join('&ensp;В·&ensp;') + '</div>'
              : '') +
          '</div>';
      }

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) + contentHtml + '</div>';
    }

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       CONTENT
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    function renderContent(s, idx, t) {
      var tColor = t.light ? t.text : '#fff';

      var bulletsHtml = s.bullets.map(function(b, bi) {
        return '<div class="f-up" style="' +
          'display:flex;align-items:flex-start;gap:14px;' +
          'padding:12px 18px 12px 16px;' +
          'background:' + t.glass + ';' +
          'border:1px solid ' + t.glassBorder + ';' +
          'border-radius:14px;' +
          (t.light ? '' : 'backdrop-filter:blur(8px);') +
          'animation-delay:' + (bi*0.09) + 's;' +
          'margin-bottom:9px;">' +
          /* Number chip */
          '<div style="min-width:28px;height:28px;border-radius:8px;background:' + t.accent + ';' +
            (t.light ? 'color:#fff;' : 'color:#0a0a0a;') +
            'display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:900;flex-shrink:0;margin-top:1px;">' +
            String(bi+1).padStart(2,'0') +
          '</div>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.35vw,15px);line-height:1.65;">' + b + '</span>' +
        '</div>';
      }).join('');

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(t.contentBg()) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:0 5% 3%;">' +
          /* в”Җ header в”Җ */
          '<div style="height:76px;display:flex;align-items:center;gap:14px;">' +
            '<span style="background:' + t.accent + ';' +
              (t.light ? 'color:#fff;' : 'color:#0a0a0a;') +
              'font-size:10px;font-weight:900;padding:5px 13px;border-radius:20px;letter-spacing:1px;flex-shrink:0;">' +
              String(idx+1).padStart(2,'0') + ' / ' + String(total).padStart(2,'0') +
            '</span>' +
            '<h2 style="color:' + tColor + ';font-size:clamp(16px,2.1vw,26px);font-weight:800;margin:0;line-height:1.2;">' + s.title + '</h2>' +
          '</div>' +
          /* в”Җ bullets в”Җ */
          '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + bulletsHtml + '</div>' +
        '</div>' +
      '</div>';
    }

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       SUMMARY
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    function renderSummary(s, t) {
      var tColor = t.light ? t.text : '#fff';
      var icons  = ['вң…','рҹ’Ў','рҹҺҜ','рҹ“Ң','вӯҗ','рҹ”‘','рҹҡҖ','рҹҸҶ'];

      var bulletsHtml = s.bullets.map(function(b, bi) {
        return '<div class="f-up" style="display:flex;align-items:center;gap:13px;padding:11px 18px;' +
          'background:' + t.glass + ';border:1px solid ' + t.glassBorder + ';border-radius:12px;' +
          (t.light ? '' : 'backdrop-filter:blur(8px);') +
          'animation-delay:' + (bi*0.09) + 's;margin-bottom:8px;">' +
          '<span style="font-size:20px;flex-shrink:0;">' + (icons[bi]||'в–ё') + '</span>' +
          '<span style="color:' + tColor + ';font-size:clamp(12px,1.3vw,14px);line-height:1.6;">' + b + '</span>' +
        '</div>';
      }).join('');

      var bgSvg = typeof t.coverBg === 'function' ? t.coverBg(s.title) : t.coverBg;

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5% 9%;text-align:center;">' +
          '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:14px;opacity:.85;">TГіm tбәҜt</div>' +
          '<h2 style="color:' + (t.light?t.text:'#fff') + ';font-size:clamp(18px,2.8vw,36px);font-weight:900;margin:0 0 14px;line-height:1.15;">' + s.title + '</h2>' +
          '<div style="width:44px;height:4px;background:' + t.accent + ';border-radius:2px;margin-bottom:22px;"></div>' +
          '<div style="width:100%;max-width:700px;text-align:left;">' + bulletsHtml + '</div>' +
        '</div>' +
      '</div>';
    }

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       THEME PICKER вҖ” color swatches
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    var swatchColors = ['#7c3aed','#00f5c4','#a21caf','#facc15','#be123c','#6366f1'];
    var pickerHtml = THEMES.map(function(t, i) {
      return '<button onclick="setTheme(' + i + ')" id="theme-btn-' + i + '" title="' + t.label + '" ' +
        'style="width:28px;height:28px;border-radius:50%;border:3px solid transparent;cursor:pointer;' +
        'background:' + swatchColors[i] + ';transition:all .15s;flex-shrink:0;" />';
    }).join('');
    document.getElementById('slide-dots').insertAdjacentHTML('beforebegin',
      '<div id="theme-picker" style="display:flex;align-items:center;gap:6px;">' +
        '<span style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:2px;margin-right:2px;">Theme</span>' +
        pickerHtml +
      '</div>'
    );

    var activeThemeIdx = 0;
    window.setTheme = function(i) {
      activeThemeIdx = i;
      document.querySelectorAll('[id^="theme-btn-"]').forEach(function(b, j) {
        b.style.borderColor = j === i ? '#fff' : 'transparent';
        b.style.transform   = j === i ? 'scale(1.2)' : 'scale(1)';
        b.style.boxShadow   = j === i ? '0 0 0 2px #6366f1' : 'none';
      });
      render();
    };
    setTheme(0);

    /* в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
       RENDER
    в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */
    function render() {
      if (!slides.length) return;
      var s = slides[current];
      var t = THEMES[activeThemeIdx];
      var isFirst = current === 0, isLast = current === total - 1;

      document.getElementById('slide-viewer').innerHTML =
        isFirst ? renderCover(s, t) :
        isLast  ? renderSummary(s, t) :
                  renderContent(s, current, t);

      document.getElementById('slide-counter').textContent = (current+1) + ' / ' + total;

      /* progress dots */
      document.getElementById('slide-dots').innerHTML = slides.map(function(_, i) {
        return '<div style="width:' + (i===current?'18px':'5px') + ';height:5px;border-radius:3px;' +
          'background:' + (i===current?'#6366f1':'#cbd5e1') + ';transition:all .25s;"></div>';
      }).join('');

      var noteEl = document.getElementById('slide-note');
      if (s.note) { document.getElementById('slide-note-text').textContent = s.note; noteEl.classList.remove('hidden'); }
      else { noteEl.classList.add('hidden'); }
    }

    window.prevSlide = function() { if (current > 0) { current--; render(); } };
    window.nextSlide = function() { if (current < total-1) { current++; render(); } };
    window.enterFullscreen = function() {
      var w = document.getElementById('slide-viewer').parentElement;
      (w.requestFullscreen || w.webkitRequestFullscreen || function(){}).call(w);
    };
    document.addEventListener('keydown', function(e) {
      if (e.key==='ArrowRight'||e.key==='ArrowDown') nextSlide();
      if (e.key==='ArrowLeft' ||e.key==='ArrowUp')   prevSlide();
    });
    var tx = null;
    document.getElementById('slide-viewer').addEventListener('touchstart', function(e){ tx = e.touches[0].clientX; });
    document.getElementById('slide-viewer').addEventListener('touchend',   function(e){
      if (!tx) return;
      var dx = e.changedTouches[0].clientX - tx;
      if (dx < -40) nextSlide(); else if (dx > 40) prevSlide();
      tx = null;
    });

    render();
  })();
  </script>

<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nб»ҷi dung Д‘Ж°б»Јc tбәЎo bб»ҹi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='ДҗГЈ sao chГ©p!'; setTimeout(()=>this.textContent='Sao chГ©p',2000)})"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        Sao chГ©p
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>
