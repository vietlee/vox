                <input type="color" id="tt-bg-color-input" style="width:28px;height:26px;border:none;border-radius:4px;cursor:pointer;padding:1px;background:none;" oninput="applyElBg(this.value);document.getElementById('tt-bg-preview').style.background=this.value;">
                <button onclick="applyElBg('transparent');document.getElementById('tt-bg-panel').style.display='none';" title="Trong suốt"
