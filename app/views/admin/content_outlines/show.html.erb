    /* ── LAYOUT: bullets ── */
    function layoutBullets(s, t) {
      var b_items = s.bullet_items || [];
      var bullets = s.bullets || [];
      var n = b_items.length || bullets.length;
      var accents = t.card_icons;
      var cbgs = t.card_bgs;

      if (b_items.length === 3) {
        /* 3-column pastel cards with icon circle */
        var cards = b_items.map(function(it, i) {
          var ac = accents[i % accents.length];
          var bg = cbgs[i % cbgs.length];
          var ic = pickIcon((it.title||'') + ' ' + (it.desc||''), it.icon);
          return '<div class="f-up" style="flex:1;border-radius:12px;background:' + bg + ';padding:18px 16px;display:flex;flex-direction:column;align-items:center;text-align:center;animation-delay:' + (i*0.08) + 's;">' +
            iconCircle(ic, ac, 44) +
            '<div style="font-size:13px;font-weight:700;color:#1F2A44;margin-top:12px;margin-bottom:6px;">' + (it.title||'') + '</div>' +
            (it.desc ? '<div style="font-size:10px;color:#5B6478;line-height:1.5;">' + it.desc + '</div>' : '') +
          '</div>';
        }).join('');
        return '<div style="flex:1;display:flex;align-items:center;">' +
          '<div style="display:flex;gap:12px;width:100%;">' + cards + '</div></div>';

      } else if (b_items.length >= 2) {
        /* stacked list with icon circle left */
        var rows = b_items.slice(0,6).map(function(it, i) {
          var ac = accents[i % accents.length];
          var ic = pickIcon((it.title||'') + ' ' + (it.desc||''), it.icon);
          return '<div class="f-up" style="display:flex;align-items:flex-start;gap:14px;margin-bottom:10px;animation-delay:' + (i*0.07) + 's;">' +
            iconCircle(ic, ac, 40) +
            '<div style="flex:1;padding-top:2px;">' +
              '<div style="font-size:13px;font-weight:700;color:#1F2A44;margin-bottom:2px;">' + (it.title||'') + '</div>' +
              (it.desc ? '<div style="font-size:10px;color:#5B6478;line-height:1.5;">' + it.desc + '</div>' : '') +
            '</div>' +
          '</div>';
        }).join('');
        return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + rows + '</div>';

      } else if (bullets.length && bullets.length <= 3) {
        /* 3-col simple bullet text */
        var cols = bullets.slice(0,3).map(function(b, i) {
          var ac = accents[i % accents.length];
          var ic = pickIcon(b);
          return '<div class="f-up" style="flex:1;text-align:center;padding:0 8px;animation-delay:' + (i*0.08) + 's;">' +
            '<div style="display:flex;justify-content:center;margin-bottom:10px;">' + iconCircle(ic, ac, 40) + '</div>' +
            '<div style="font-size:14px;font-weight:700;color:#1F2A44;line-height:1.4;">' + b + '</div>' +
          '</div>';
        }).join('');
        return '<div style="flex:1;display:flex;align-items:center;">' +
          '<div style="display:flex;gap:16px;width:100%;">' + cols + '</div></div>';

      } else {
        /* stacked bullets */
        var rows2 = (bullets.length ? bullets : []).slice(0,8).map(function(b, i) {
          var ac = accents[i % accents.length];
          var ic = pickIcon(b);
          return '<div class="f-up" style="display:flex;align-items:center;gap:12px;margin-bottom:9px;animation-delay:' + (i*0.07) + 's;">' +
            iconCircle(ic, ac, 34) +
            '<span style="font-size:13px;font-weight:600;color:#1F2A44;line-height:1.5;">' + b + '</span>' +
          '</div>';
        }).join('');
        return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + rows2 + '</div>';
      }
    }

    /* ── LAYOUT: stats ── */
    function layoutStats(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { value: (p[0]||'').trim(), label: (p[1]||b).trim() };
        });
      }
      items = items.slice(0, 4);
      var n = items.length;
      var accents = t.card_icons;

      var gridCols = n <= 3 ? n : 2;
      var cards = items.map(function(it, i) {
        var ac = accents[i % accents.length];
        var val = it.value || '—';
        var vsz = val.length > 6 ? 'clamp(22px,3vw,34px)' : 'clamp(26px,3.5vw,44px)';
        return '<div class="f-up" style="border-radius:10px;background:' + t.primary_dk + ';padding:16px 18px;overflow:hidden;position:relative;animation-delay:' + (i*0.08) + 's;">' +
          '<div style="position:absolute;left:0;top:0;bottom:0;width:6px;background:' + ac + ';border-radius:10px 0 0 10px;"></div>' +
          '<div style="padding-left:14px;">' +
            '<div style="font-size:' + vsz + ';font-weight:900;color:#fff;line-height:1;margin-bottom:8px;">' + val + '</div>' +
            '<div style="font-size:10px;color:' + t.primary_xl + ';line-height:1.4;">' + (it.label||'') + '</div>' +
          '</div>' +
        '</div>';
      }).join('');

      return '<div style="flex:1;display:flex;align-items:center;">' +
        '<div style="display:grid;grid-template-columns:repeat(' + gridCols + ',1fr);gap:12px;width:100%;">' + cards + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: chart ── */
    function layoutChart(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { value: parseInt(p[0])||0, label: (p[1]||b).trim() };
        });
      }
      items = items.slice(0, 8);
      var maxVal = Math.max.apply(null, items.map(function(i){ return i.value||0; })) || 1;
      var accents = t.card_icons;
      var bars = items.map(function(it, i) {
        var pct = Math.round(((it.value||0) / maxVal) * 100);
        var ac = accents[i % accents.length];
        return '<div class="f-up" style="display:flex;align-items:center;gap:12px;margin-bottom:10px;animation-delay:' + (i*0.07) + 's;">' +
          '<div style="width:100px;text-align:right;font-size:11px;font-weight:600;color:#1F2A44;flex-shrink:0;">' + it.label + '</div>' +
          '<div style="flex:1;height:26px;background:#F1F5F9;border-radius:6px;overflow:hidden;">' +
            '<div style="width:' + pct + '%;height:100%;background:' + ac + ';border-radius:6px;display:flex;align-items:center;justify-content:flex-end;padding-right:8px;">' +
              '<span style="font-size:10px;font-weight:800;color:#fff;">' + (it.value||0) + '</span>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + bars + '</div>';
    }

    /* ── LAYOUT: donut ── */
    function layoutDonut(s, t) {
      var items = s.items || [];
      items = items.slice(0, 6);
      var accents = t.card_icons;
      var total_val = items.reduce(function(sum, it) {
        var v = typeof it.value === 'string' ? parseInt(it.value)||0 : (it.value||0);
        return sum + v;
      }, 0) || 1;

      /* Simple SVG donut */
      var r = 80, cx = 100, cy = 100, circumference = 2 * Math.PI * r;
      var offset = 0;
      var slices = items.map(function(it, i) {
        var v = typeof it.value === 'string' ? parseInt(it.value)||0 : (it.value||0);
        var pct = v / total_val;
        var dash = pct * circumference;
        var ac = accents[i % accents.length];
        var rot = -90 + offset * 360;
        offset += pct;
        return '<circle cx="' + cx + '" cy="' + cy + '" r="' + r + '" fill="none" stroke="' + ac + '" stroke-width="36"' +
          ' stroke-dasharray="' + dash.toFixed(1) + ' ' + circumference.toFixed(1) + '"' +
          ' stroke-dashoffset="0"' +
          ' transform="rotate(' + rot.toFixed(1) + ' ' + cx + ' ' + cy + ')"/>';
      }).join('');
      var donutSvg = '<svg viewBox="0 0 200 200" style="width:180px;height:180px;flex-shrink:0;">' +
        '<circle cx="' + cx + '" cy="' + cy + '" r="' + r + '" fill="none" stroke="#F1F5F9" stroke-width="36"/>' +
        slices +
        (s.center_text ? '<text x="100" y="96" text-anchor="middle" font-size="22" font-weight="900" fill="#1F2A44">' + s.center_text + '</text>' : '') +
        (s.center_sub ? '<text x="100" y="114" text-anchor="middle" font-size="11" fill="#5B6478">' + s.center_sub + '</text>' : '') +
      '</svg>';

      var legend = items.map(function(it, i) {
        var ac = accents[i % accents.length];
        var v = typeof it.value === 'string' ? parseInt(it.value)||0 : (it.value||0);
        var pct = Math.round(v / total_val * 100);
        var ic = pickIcon(it.label||'');
        return '<div class="f-up" style="display:flex;align-items:center;gap:10px;margin-bottom:10px;animation-delay:' + (i*0.07) + 's;">' +
          iconCircle(ic, ac, 36) +
          '<div>' +
            '<div style="font-size:12px;font-weight:700;color:#1F2A44;">' + (it.label||'') + '</div>' +
            '<div style="font-size:10px;color:#5B6478;">' + pct + '%' + (it.detail ? '  ·  ' + it.detail : '') + '</div>' +
          '</div>' +
        '</div>';
      }).join('');

      return '<div style="flex:1;display:flex;align-items:center;gap:20px;">' +
        donutSvg +
        '<div style="flex:1;">' + legend + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: two-col ── */
    function layoutTwoCol(s, t) {
      var col1 = (s.col1 || []);
      var col2 = (s.col2 || []);
      if (!col1.length && s.bullets) {
        s.bullets.forEach(function(b, i) {
          var text = b.replace(/^COL[12]:\s*/,'');
          if (i % 2 === 0) col1.push(text); else col2.push(text);
        });
      }
      var accents = t.card_icons;

      function colHtml(items, offset) {
        return items.slice(0,5).map(function(item, i) {
          var ac = accents[(offset + i) % accents.length];
          var ic = pickIcon(item);
          return '<div class="f-up" style="display:flex;align-items:center;gap:10px;margin-bottom:8px;animation-delay:' + ((offset+i)*0.07) + 's;">' +
            iconCircle(ic, ac, 34) +
            '<span style="font-size:11px;color:#1F2A44;line-height:1.5;">' + item + '</span>' +
          '</div>';
        }).join('');
      }

      return '<div style="flex:1;display:flex;gap:20px;align-items:flex-start;">' +
        '<div style="flex:1;">' + colHtml(col1, 0) + '</div>' +
        '<div style="width:1px;background:#E2E8F0;margin-top:4px;margin-bottom:4px;"></div>' +
        '<div style="flex:1;">' + colHtml(col2, 5) + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: timeline ── */
    function layoutTimeline(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { step: (p[0]||'').trim(), desc: (p[1]||'').trim() };
        });
      }
      items = items.slice(0, 5);
      var accents = t.card_icons;
      var cards = items.map(function(it, i) {
        var ac = accents[i % accents.length];
        return '<div class="f-up" style="flex:1;border-radius:10px;background:#fff;border:1px solid #E2E8F0;overflow:hidden;position:relative;animation-delay:' + (i*0.09) + 's;">' +
          '<div style="height:4px;background:' + ac + ';"></div>' +
          '<div style="padding:12px 10px;text-align:center;">' +
            '<div style="width:32px;height:32px;border-radius:50%;background:' + ac + ';display:flex;align-items:center;justify-content:center;margin:0 auto 8px;">' +
              '<span style="font-size:13px;font-weight:900;color:#fff;">' + (i+1) + '</span>' +
            '</div>' +
            '<div style="font-size:11px;font-weight:700;color:' + ac + ';margin-bottom:5px;">' + (it.step||'') + '</div>' +
            '<div style="font-size:9.5px;color:#5B6478;line-height:1.5;">' + (it.desc||'') + '</div>' +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:flex-start;padding-top:14px;">' +
        '<div style="display:flex;gap:8px;width:100%;">' + cards + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: pillars ── */
    function layoutPillars(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { title: (p[0]||'').trim(), bullets: (p[1]||'').split('|').map(function(x){return x.trim();}).filter(Boolean) };
        });
      }
      items = items.slice(0, 4);
      var accents = t.card_icons;
      var cbgs = t.card_bgs;
      var cards = items.map(function(it, i) {
        var ac = accents[i % accents.length];
        var bg = cbgs[i % cbgs.length];
        var ic = pickIcon((it.title||'') + ' ' + (it.bullets||[]).join(' '), it.icon);
        var desc = (it.bullets||[]).slice(0,3).join(' ');
        return '<div class="f-up" style="border-radius:12px;background:' + bg + ';padding:16px;display:flex;flex-direction:row;align-items:flex-start;gap:12px;animation-delay:' + (i*0.08) + 's;">' +
          iconCircle(ic, ac, 44) +
          '<div style="flex:1;">' +
            '<div style="font-size:13px;font-weight:700;color:#1F2A44;margin-bottom:5px;">' + (it.title||'') + '</div>' +
            (desc ? '<div style="font-size:10px;color:#5B6478;line-height:1.5;">' + desc + '</div>' : '') +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;align-items:center;">' +
        '<div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px;width:100%;">' + cards + '</div>' +
      '</div>';
    }

    /* ── LAYOUT: agenda ── */
    function layoutAgenda(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b, i) {
          var p = b.split('::');
          return { num: String(i+1), title: (p[0]||b).trim(), desc: (p[1]||'').trim() };
        });
      }
      items = items.slice(0, 8);
      var accents = t.card_icons;
      var rows = items.map(function(it, i) {
        var ac = accents[i % accents.length];
        return '<div class="f-up" style="display:flex;align-items:center;gap:14px;padding:10px 14px;border-radius:10px;background:#fff;border:1px solid #E2E8F0;margin-bottom:6px;animation-delay:' + (i*0.07) + 's;">' +
          '<div style="width:32px;height:32px;border-radius:50%;background:' + ac + ';display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
            '<span style="font-size:12px;font-weight:900;color:#fff;">' + (it.num||i+1) + '</span>' +
          '</div>' +
          '<div style="flex:1;min-width:0;">' +
            '<div style="font-size:12px;font-weight:700;color:' + t.primary_dk + ';">' + it.title + '</div>' +
            (it.desc ? '<div style="font-size:9px;color:#5B6478;margin-top:1px;">' + it.desc + '</div>' : '') +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + rows + '</div>';
    }

    /* ── LAYOUT: roles ── */
    function layoutRoles(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::');
          return { role: (p[0]||'').trim(), type: (p[1]||'').trim(), bullets: (p[2]||'').split('|').map(function(x){return x.trim();}).filter(Boolean) };
        });
      }
      items = items.slice(0, 3);
      var accents = t.card_icons;
      var cols = items.map(function(it, i) {
        var ac = accents[i % accents.length];
        var bio = (it.bullets||[]).slice(0,3).join(' ');
        return '<div class="f-up" style="flex:1;border-radius:12px;background:#fff;border:1px solid #E2E8F0;overflow:hidden;animation-delay:' + (i*0.09) + 's;">' +
          '<div style="height:6px;background:' + ac + ';"></div>' +
          '<div style="padding:16px;text-align:center;">' +
            '<div style="width:64px;height:64px;border-radius:50%;background:' + t.primary_xl + ';margin:0 auto 10px;display:flex;align-items:center;justify-content:center;">' +
              '<div style="width:34px;height:34px;">' + iconSvg('person') + '</div>' +
            '</div>' +
            '<div style="font-size:14px;font-weight:800;color:#1F2A44;margin-bottom:4px;">' + (it.role||'') + '</div>' +
            (it.type ? '<div style="font-size:10px;font-weight:700;color:' + ac + ';margin-bottom:8px;">' + it.type + '</div>' : '') +
            '<div style="width:40px;height:1px;background:#E2E8F0;margin:0 auto 8px;"></div>' +
            (bio ? '<div style="font-size:10px;color:#5B6478;line-height:1.5;">' + bio + '</div>' : '') +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;gap:12px;">' + cols + '</div>';
    }

    /* ── LAYOUT: okr ── */
    function layoutOkr(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::');
          return { objective: (p[0]||'').trim(), krs: (p[1]||'').split('|').map(function(x){return x.trim();}).filter(Boolean) };
        });
      }
      items = items.slice(0, 5);
      var accents = t.card_icons;
      var rows = items.map(function(it, i) {
        var ac = accents[i % accents.length];
        return '<div class="f-up" style="display:flex;align-items:stretch;border-radius:10px;background:#fff;border:1px solid #E2E8F0;overflow:hidden;margin-bottom:8px;animation-delay:' + (i*0.08) + 's;">' +
          '<div style="width:5px;background:' + ac + ';flex-shrink:0;"></div>' +
          '<div style="padding:10px 14px;flex:1;">' +
            '<div style="font-size:11px;font-weight:700;color:' + ac + ';margin-bottom:6px;">' + it.objective + '</div>' +
            '<div style="display:flex;flex-wrap:wrap;gap:5px;">' +
              (it.krs||[]).slice(0,3).map(function(kr) {
                return '<span style="background:' + ac + '15;border:1px solid ' + ac + '30;border-radius:20px;padding:2px 8px;font-size:9px;color:#1F2A44;">✓ ' + kr + '</span>';
              }).join('') +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
      return '<div style="flex:1;display:flex;flex-direction:column;justify-content:center;">' + rows + '</div>';
    }

    /* ── LAYOUT: principles ── */
    function layoutPrinciples(s, t) {
      var items = s.items || [];
      if (!items.length && s.bullets) {
        items = s.bullets.map(function(b) {
          var p = b.split('::'); return { title: (p[0]||'').trim(), desc: (p[1]||'').trim() };
        });
      }
      items = items.slice(0, 6);
      var accents = t.card_icons;
      var half = Math.ceil(items.length / 2);

      function colHtml(arr, offset) {
        return arr.map(function(it, i) {
          var ac = accents[(i+offset) % accents.length];
          var ic = pickIcon(typeof it === 'string' ? it : (it.title||''));
          return '<div class="f-up" style="display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;animation-delay:' + ((i+offset)*0.07) + 's;">' +
            iconCircle(ic, ac, 34) +
            '<div style="flex:1;">' +
              '<div style="font-size:13px;font-weight:700;color:#1F2A44;margin-bottom:3px;">' + (it.title||it) + '</div>' +
              (it.desc ? '<div style="font-size:10px;color:#5B6478;line-height:1.5;">' + it.desc + '</div>' : '') +
            '</div>' +
          '</div>';
        }).join('');
      }

      return '<div style="flex:1;display:flex;gap:16px;">' +
        '<div style="flex:1;">' + colHtml(items.slice(0,half), 0) + '</div>' +
        '<div style="flex:1;">' + colHtml(items.slice(half), half) + '</div>' +
      '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       CONTENT — dispatch to layout
    ───────────────────────────────────────────────────────────────── */
    function renderContent(s, idx, t) {
      var bodyHtml;
      var layout = s.layout || 'bullets';
      switch (layout) {
        case 'stats':      bodyHtml = layoutStats(s, t);      break;
        case 'chart':      bodyHtml = layoutChart(s, t);      break;
        case 'donut':      bodyHtml = layoutDonut(s, t);      break;
        case 'two-col':
        case 'two_col':    bodyHtml = layoutTwoCol(s, t);     break;
        case 'timeline':   bodyHtml = layoutTimeline(s, t);   break;
        case 'pillars':    bodyHtml = layoutPillars(s, t);    break;
        case 'agenda':     bodyHtml = layoutAgenda(s, t);     break;
        case 'roles':      bodyHtml = layoutRoles(s, t);      break;
        case 'okr':        bodyHtml = layoutOkr(s, t);        break;
        case 'principles': bodyHtml = layoutPrinciples(s, t); break;
        default:           bodyHtml = layoutBullets(s, t);    break;
      }

      /* insight bar */
      var note = s.note || '';
      var noteHtml = '';
      if (note) {
        var noteBg = t.card_bgs[0] || '#E8F8F1';
        noteHtml = '<div style="margin-top:6px;border-radius:8px;background:' + noteBg + ';padding:8px 14px;flex-shrink:0;">' +
          '<span style="font-size:11px;font-weight:700;color:#1F2A44;">' + note + '</span></div>';
      }

      var pageNum = '<div style="position:absolute;right:5%;bottom:10px;font-size:9px;color:#94A3B8;">' +
        String(idx+1).padStart(2,'0') + ' / ' + String(total).padStart(2,'0') + '</div>';

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(typeof t.contentBg === 'function' ? t.contentBg() : t.contentBg) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:0 5% 2%;">' +
          slideHeader(s, idx, t) + bodyHtml + noteHtml +
        '</div>' +
        pageNum +
      '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       SUMMARY — 3 styles matching PPTX
    ───────────────────────────────────────────────────────────────── */
    function renderSummary(s, t) {
      var style = s.style || {};
      var sumStyle = style.summary_style || 'cta';
      var iconHint = style.icon || '';
      var ic = pickIcon((s.title||'') + ' ' + (s.subtitle||''), iconHint);

      var bgSvg = DEFS + '<rect width="1280" height="720" fill="' + t.cover_bg + '"/>' +
        '<circle cx="100" cy="720" r="360" fill="' + t.primary + '" opacity=".35"/>' +
        '<circle cx="1280" cy="43" r="244" fill="' + t.primary_dk + '" opacity=".5"/>';

      var contentHtml;

      if (sumStyle === 'quote') {
        var bulletsQ = (s.bullets||[]).slice(0,4);
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:6% 10%;text-align:center;">' +
            '<div style="font-size:80px;font-weight:900;color:' + t.primary_lt + ';line-height:0.8;margin-bottom:8px;">"</div>' +
            '<h2 class="f-up" style="color:#fff;font-size:clamp(20px,2.8vw,34px);font-weight:900;margin:0 0 16px;line-height:1.2;">' + s.title + '</h2>' +
            '<div style="width:80px;height:3px;background:' + t.accent + ';border-radius:2px;margin:0 auto 18px;"></div>' +
            (bulletsQ.length ? '<p class="f-up" style="color:' + t.primary_xl + ';font-size:14px;animation-delay:.1s;">' + bulletsQ.join('   |   ') + '</p>' : '') +
          '</div>';

      } else if (sumStyle === 'minimal') {
        var bulletsM = (s.bullets||[]).slice(0,3);
        var iconBgM = t.primary;
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8% 7%;">' +
            '<div style="width:64px;height:64px;border-radius:14px;background:' + iconBgM + ';display:flex;align-items:center;justify-content:center;margin-bottom:16px;">' +
              '<div style="width:36px;height:36px;">' + iconSvg(ic) + '</div>' +
            '</div>' +
            '<h2 class="f-up" style="color:#fff;font-size:clamp(24px,3.6vw,42px);font-weight:900;margin:0 0 16px;line-height:1.1;">' + s.title + '</h2>' +
            bulletsM.map(function(b, bi) {
              return '<p class="f-up" style="color:' + t.primary_xl + ';font-size:13px;margin:0 0 8px;animation-delay:' + ((bi+1)*0.07) + 's;">' + b + '</p>';
            }).join('') +
          '</div>';

      } else {
        /* cta (default) */
        var bullets = s.bullets || [];
        var cta = bullets[0] || '';
        var contacts = bullets.slice(1,4);
        var iconBg = t.primary;
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:5% 8%;text-align:center;">' +
            '<div class="f-up" style="width:72px;height:72px;border-radius:16px;background:' + iconBg + ';display:flex;align-items:center;justify-content:center;margin-bottom:16px;">' +
              '<div style="width:40px;height:40px;">' + iconSvg(ic) + '</div>' +
            '</div>' +
            '<h2 class="f-up" style="color:#fff;font-size:clamp(22px,3vw,36px);font-weight:900;margin:0 0 18px;max-width:760px;line-height:1.2;animation-delay:.07s;">' + s.title + '</h2>' +
            (cta ? '<div class="f-up" style="background:' + t.accent + ';border-radius:12px;padding:13px 40px;font-size:16px;font-weight:800;color:#fff;margin-bottom:18px;animation-delay:.12s;">' + cta + '</div>' : '') +
            (contacts.length ? '<p class="f-up" style="color:' + t.primary_xl + ';font-size:13px;animation-delay:.17s;">' + contacts.join('   |   ') + '</p>' : '') +
          '</div>';
      }

      if (s.footer) {
        contentHtml += '<div style="position:absolute;bottom:18px;left:8%;right:8%;z-index:3;text-align:center;">' +
          '<span style="color:' + t.primary_lt + ';font-size:12px;">' + s.footer + '</span></div>';
      }

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) + contentHtml + '</div>';
    }

    /* ─────────────────────────────────────────────────────────────────
       THEME PICKER — 13 color swatches
    ───────────────────────────────────────────────────────────────── */
    var pickerHtml = THEMES.map(function(th, i) {
      return '<button onclick="setTheme(' + i + ')" id="theme-btn-' + i + '" title="' + th.label + '" ' +
        'style="width:28px;height:28px;border-radius:50%;border:3px solid transparent;cursor:pointer;' +
        'background:' + th.cover_bg + ';transition:all .15s;flex-shrink:0;" />';
    }).join('');
    document.getElementById('slide-dots').insertAdjacentHTML('beforebegin',
      '<div id="theme-picker" style="display:flex;align-items:center;gap:6px;">' +
        '<span style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:2px;margin-right:2px;">Theme</span>' +
        pickerHtml +
      '</div>'
    );

    /* Map theme name from data-theme attribute to index */
    var AI_THEME_MAP = {};
    THEMES.forEach(function(th, i) { AI_THEME_MAP[th.name] = i; });
    var aiTheme = el.dataset.theme || '';
    var activeThemeIdx = (aiTheme && AI_THEME_MAP[aiTheme] != null) ? AI_THEME_MAP[aiTheme] : 1; /* default blue */
    window.setTheme = function(i) {
      activeThemeIdx = i;
      document.querySelectorAll('[id^="theme-btn-"]').forEach(function(b, j) {
        b.style.borderColor = j === i ? '#fff' : 'transparent';
        b.style.transform   = j === i ? 'scale(1.2)' : 'scale(1)';
        b.style.boxShadow   = j === i ? '0 0 0 2px #6366f1' : 'none';
      });
      render();
    };
    setTheme(activeThemeIdx);


    /* ─────────────────────────────────────────────────────────────────
       RENDER
    ───────────────────────────────────────────────────────────────── */
    function render() {
      if (!slides.length) return;
      var s = slides[current];
      var t = THEMES[activeThemeIdx];
      var isFirst = current === 0, isLast = current === total - 1;

      if (useImageMode && slideImageUrls[current]) {
        document.getElementById('slide-viewer').innerHTML =
          '<div class="s-in" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#0f172a;">' +
            '<div style="position:absolute;color:#475569;font-size:13px;">Đang tải...</div>' +
            '<img src="' + slideImageUrls[current] + '" style="max-width:100%;max-height:100%;object-fit:contain;image-rendering:auto;opacity:0;transition:opacity .2s;" onload="this.style.opacity=1;this.previousSibling.style.display=\'none\'" onerror="this.alt=\'Slide ' + (current+1) + '\'">' +
          '</div>';
        // Preload adjacent slides
        [current-1, current+1, current+2].forEach(function(idx) {
          if (idx >= 0 && idx < slideImageUrls.length) { var p = new Image(); p.src = slideImageUrls[idx]; }
        });
      } else {
        document.getElementById('slide-viewer').innerHTML =
          isFirst ? renderCover(s, t) :
          isLast  ? renderSummary(s, t) :
                    renderContent(s, current, t);
      }

      document.getElementById('slide-counter').textContent = (current+1) + ' / ' + total;

      /* progress dots */
      var dotTotal = useImageMode ? slideImageUrls.length : slides.length;
      document.getElementById('slide-dots').innerHTML = Array.from({length: dotTotal}, function(_, i) {
        return '<div style="width:' + (i===current?'18px':'5px') + ';height:5px;border-radius:3px;' +
          'background:' + (i===current?'#6366f1':'#cbd5e1') + ';transition:all .25s;"></div>';
      }).join('');

      var noteEl = document.getElementById('slide-note');
      if (s && s.note) { document.getElementById('slide-note-text').textContent = s.note; noteEl.classList.remove('hidden'); }
      else { noteEl.classList.add('hidden'); }
    }

    var navTotal = useImageMode ? slideImageUrls.length : total;
    window.prevSlide = function() { if (current > 0) { current--; render(); } };
    window.nextSlide = function() { if (current < navTotal-1) { current++; render(); } };
    window.enterFullscreen = function() {
      var w = document.getElementById('slide-viewer').parentElement;
      (w.requestFullscreen || w.webkitRequestFullscreen || function(){}).call(w);
    };
    document.addEventListener('keydown', function(e) {
      var tag = document.activeElement && document.activeElement.tagName;
      if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return;
      if (e.key==='ArrowRight'||e.key==='ArrowDown') nextSlide();
      if (e.key==='ArrowLeft' ||e.key==='ArrowUp')   prevSlide();
    });
    var tx = null;
    document.getElementById('slide-viewer').addEventListener('touchstart', function(e){ tx = e.touches[0].clientX; });
    document.getElementById('slide-viewer').addEventListener('touchend',   function(e){
      if (!tx) return;
      var dx = e.changedTouches[0].clientX - tx;
      if (dx < -40) nextSlide(); else if (dx > 40) prevSlide();
      tx = null;
    });

    render();

    /* ─────────────────────────────────────────────────────────────────
       IMAGE OVERLAY
    ───────────────────────────────────────────────────────────────── */
    function renderImageOverlay() {
      var overlay = document.getElementById('slide-image-overlay');
      if (!overlay) return;
      var s = slides[current];
      var img = s && s.image;
      if (!img || !img.dataUrl) { overlay.innerHTML = ''; return; }
      var x = img.x != null ? img.x : 30;
      var y = img.y != null ? img.y : 10;
      var w = img.w != null ? img.w : 35;
      overlay.style.pointerEvents = 'none';
      overlay.innerHTML = '<img src="' + img.dataUrl + '" style="position:absolute;left:' + x + '%;top:' + y + '%;width:' + w + '%;max-height:85%;object-fit:contain;pointer-events:none;border-radius:8px;box-shadow:0 4px 24px rgba(0,0,0,0.3);">';
    }

    /* ─────────────────────────────────────────────────────────────────
       FONT SCALE + FAMILY OVERRIDE
    ───────────────────────────────────────────────────────────────── */
    function applyFontOverrides() {
      var s = slides[current];
      if (!s) return;
      var viewer = document.getElementById('slide-viewer');
      if (!viewer) return;
      var scale = (s.fontScale || 100) / 100;
      var family = s.fontFamily || '';
      viewer.style.fontSize = (scale !== 1) ? (scale * 100) + '%' : '';
      viewer.style.fontFamily = family || '';
    }

    /* ─────────────────────────────────────────────────────────────────
       EDITOR PANEL LOGIC
    ───────────────────────────────────────────────────────────────── */
    var editorOpen = false;

    window.toggleEditor = function() {
      editorOpen = !editorOpen;
      document.getElementById('slide-editor-panel').style.display = editorOpen ? 'block' : 'none';
      var btn = document.getElementById('editor-toggle-btn');
      if (btn) {
        btn.textContent = editorOpen ? '✕ Đóng' : '✨ Sửa bằng AI';
        btn.classList.toggle('bg-indigo-50', !editorOpen);
        btn.classList.toggle('bg-slate-100', editorOpen);
      }
    };

    window.refreshEditor = function() {
      var s = slides[current];
      if (!s) return;

      document.getElementById('editor-slide-label').textContent = 'Slide ' + (current+1) + ' / ' + total;
      document.getElementById('edit-title').value = s.title || '';
      document.getElementById('edit-layout').value = s.layout || 'bullets';
      document.getElementById('edit-note').value = s.note || '';

      /* font */
      var scale = s.fontScale || 100;
      document.getElementById('font-scale').value = scale;
      document.getElementById('font-scale-val').textContent = scale + '%';
      document.getElementById('font-family').value = s.fontFamily || '';

      /* image controls */
      var img = s.image;
      var imgCtrl = document.getElementById('img-controls');
      if (img && img.dataUrl) {
        imgCtrl.classList.remove('hidden');
        document.getElementById('img-x').value = img.x || 30;
        document.getElementById('img-y').value = img.y || 10;
        document.getElementById('img-w').value = img.w || 35;
        document.getElementById('img-x-val').textContent = (img.x||30) + '%';
        document.getElementById('img-y-val').textContent = (img.y||10) + '%';
        document.getElementById('img-w-val').textContent = (img.w||35) + '%';
        document.getElementById('img-upload-label').textContent = '✓ Đã có ảnh — chọn ảnh mới';
      } else {
        imgCtrl.classList.add('hidden');
        document.getElementById('img-upload-label').textContent = 'Chọn hoặc kéo ảnh vào đây';
      }

      /* items list */
      renderItemsList(s);
    };

    function renderItemsList(s) {
      var container = document.getElementById('edit-items-list');
      container.innerHTML = '';
      var items = getDisplayItems(s);
      items.forEach(function(text, idx) {
        var row = document.createElement('div');
        row.className = 'item-row';
        row.draggable = true;
        row.dataset.idx = idx;
        row.style.cssText = 'display:flex;align-items:center;gap:6px;padding:4px 6px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;cursor:grab;';
        row.innerHTML =
          '<span style="font-size:14px;color:#94a3b8;cursor:grab;flex-shrink:0;">⠿</span>' +
          '<textarea rows="2" style="flex:1;font-size:11px;border:none;background:transparent;resize:none;outline:none;line-height:1.4;padding:0;" ' +
            'oninput="updateItem(' + idx + ', this.value)">' + escHtml(text) + '</textarea>' +
          '<button onclick="removeItem(' + idx + ')" style="font-size:14px;color:#cbd5e1;border:0;background:0;cursor:pointer;flex-shrink:0;padding:0 2px;" title="Xóa">×</button>';

        /* drag & drop */
        row.addEventListener('dragstart', function(e) { e.dataTransfer.setData('text/plain', idx); this.style.opacity = '.4'; });
        row.addEventListener('dragend',   function() { this.style.opacity = '1'; });
        row.addEventListener('dragover',  function(e) { e.preventDefault(); this.style.background = '#eef2ff'; });
        row.addEventListener('dragleave', function() { this.style.background = '#f8fafc'; });
        row.addEventListener('drop',      function(e) {
          e.preventDefault(); this.style.background = '#f8fafc';
          var fromIdx = parseInt(e.dataTransfer.getData('text/plain'));
          var toIdx   = parseInt(this.dataset.idx);
          if (fromIdx === toIdx) return;
          reorderItem(fromIdx, toIdx);
        });

        container.appendChild(row);
      });
    }

    function getDisplayItems(s) {
      if (s.bullets && s.bullets.length) return s.bullets;
      if (s.items && s.items.length) {
        return s.items.map(function(it) {
          if (typeof it === 'string') return it;
          if (it.value != null && it.label != null) return it.value + ' :: ' + it.label;
          if (it.step) return it.step + ' :: ' + (it.desc||'');
          if (it.title && it.bullets) return it.title + ' :: ' + it.bullets.join(' | ');
          if (it.title && it.desc)    return it.title + ' :: ' + it.desc;
          if (it.num)  return it.num + ' :: ' + it.title + (it.desc ? ' :: '+it.desc : '');
          if (it.role) return it.role + ' :: ' + (it.type||'') + ' :: ' + (it.bullets||[]).join(' | ');
          if (it.objective) return it.objective + ' :: ' + (it.krs||[]).join(' | ');
          return JSON.stringify(it);
        });
      }
      return [];
    }

    function escHtml(str) { return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

    window.updateItem = function(idx, val) {
      var s = slides[current];
      if (s.bullets && s.bullets.length) { s.bullets[idx] = val; }
      else if (s.items && s.items.length) {
        var it = s.items[idx];
        if (typeof it === 'string') { s.items[idx] = val; return; }
        if (!s.bullets) s.bullets = [];
        s.bullets[idx] = val;
      }
      /* no realtime render — update on Save only */
    };

    window.removeItem = function(idx) {
      var s = slides[current];
      if (s.bullets) s.bullets.splice(idx, 1);
      if (s.items)   s.items.splice(idx, 1);
      refreshEditor(); /* rebuild item list only, no slide re-render */
    };

    window.reorderItem = function(fromIdx, toIdx) {
      var s = slides[current];
      function move(arr) {
        if (!arr || !arr.length) return;
        var item = arr.splice(fromIdx, 1)[0];
        arr.splice(toIdx, 0, item);
      }
      move(s.bullets); move(s.items);
      refreshEditor();
    };

    window.addItemToSlide = function() {
      var s = slides[current];
      if (!s.bullets) s.bullets = [];
      s.bullets.push('Nội dung mới...');
      refreshEditor();
    };

    window.updateCurrentSlide = function(key, val) {
      slides[current][key] = val;
      /* layout change: re-render preview immediately so user sees layout change */
      if (key === 'layout') { render(); }
    };

    /* Font controls — store values, apply preview only on Save */
    window.updateFontScale = function(val) {
      slides[current].fontScale = parseInt(val);
      document.getElementById('font-scale-val').textContent = val + '%';
      /* light preview: just scale the viewer div, no full re-render */
      var viewer = document.getElementById('slide-viewer');
      if (viewer) viewer.style.fontSize = (parseInt(val)/100*100) + '%';
    };
    window.updateFontFamily = function(val) {
      slides[current].fontFamily = val;
      var viewer = document.getElementById('slide-viewer');
      if (viewer) viewer.style.fontFamily = val || '';
    };

    /* Image controls — realtime overlay preview is OK (no re-render needed) */
    window.handleImageUpload = function(input) {
      var file = input.files[0]; if (!file) return;
      var reader = new FileReader();
      reader.onload = function(e) {
        if (!slides[current].image) slides[current].image = {};
        slides[current].image.dataUrl = e.target.result;
        slides[current].image.x = 30;
        slides[current].image.y = 10;
        slides[current].image.w = 35;
        renderImageOverlay();
        refreshEditor();
      };
      reader.readAsDataURL(file);
    };

    window.updateImagePos = function() {
      var s = slides[current];
      if (!s.image) s.image = {};
      var x = parseInt(document.getElementById('img-x').value);
      var y = parseInt(document.getElementById('img-y').value);
      var w = parseInt(document.getElementById('img-w').value);
      s.image.x = x; s.image.y = y; s.image.w = w;
      document.getElementById('img-x-val').textContent = x + '%';
      document.getElementById('img-y-val').textContent = y + '%';
      document.getElementById('img-w-val').textContent = w + '%';
      renderImageOverlay(); /* overlay only, slide content untouched */
    };

    window.removeImage = function() {
      if (slides[current].image) delete slides[current].image;
      document.getElementById('slide-image-overlay').innerHTML = '';
      refreshEditor();
    };

    /* Save */
    window.saveSlides = function() {
      /* flush any pending item edits from textareas into slides data */
      var textareas = document.querySelectorAll('#edit-items-list textarea');
      var s = slides[current];
      if (textareas.length) {
        var vals = Array.from(textareas).map(function(ta) { return ta.value; });
        s.bullets = vals;
        /* clear s.items so layout functions use s.bullets */
        delete s.items;
      }
      /* flush title + note from inputs */
      var titleIn = document.getElementById('edit-title');
      if (titleIn) s.title = titleIn.value;
      var noteIn = document.getElementById('edit-note');
      if (noteIn) s.note = noteIn.value;

      /* re-render slide with updated data */
      render();

      /* then persist to server */
      var btn = document.getElementById('save-slides-btn');
      btn.disabled = true; btn.textContent = '...';
      var token = document.querySelector('meta[name="csrf-token"]').content;
      fetch('<%= update_slides_content_outline_path(@outline) %>', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token, 'Accept': 'application/json' },
        body: JSON.stringify({ slide_json: JSON.stringify(slides) })
      }).then(function(r){ return r.json(); }).then(function(data) {
        btn.disabled = false; btn.textContent = '💾 Lưu';
        var st = document.getElementById('save-status');
        if (data.ok) { st.textContent = '✓ Đã lưu!'; st.classList.remove('hidden'); setTimeout(function(){ st.classList.add('hidden'); }, 2000); }
        else { st.textContent = '❌ ' + (data.error||'Lỗi'); st.classList.remove('hidden'); }
      }).catch(function() { btn.disabled = false; btn.textContent = '💾 Lưu'; });
    };

    /* Override render to also apply font + image overlays */
    var _origRender = render;
    render = function() {
      _origRender();
      applyFontOverrides();
      renderImageOverlay();
      if (editorOpen) refreshEditor();
    };

    render();

    // Preload first 3 slides on page load
    if (useImageMode) {
      slideImageUrls.forEach(function(url) { var p = new Image(); p.src = url; });
    }

    var _editFiles = [];

    window.previewEditFiles = function(input) {
      var container = document.getElementById('ai-edit-previews');
      Array.from(input.files).forEach(function(f) {
        _editFiles.push(f);
        var idx = _editFiles.length - 1;
        var wrap = document.createElement('div');
        wrap.style.cssText = 'position:relative;width:64px;height:64px;border-radius:8px;overflow:hidden;border:1px solid #e2e8f0;';
        wrap.id = 'ef-' + idx;
        var img = document.createElement('img');
        img.src = URL.createObjectURL(f);
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;';
        var rm = document.createElement('button');
        rm.innerHTML = '✕';
        rm.style.cssText = 'position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;background:#ef4444;color:#fff;border:0;cursor:pointer;font-size:10px;line-height:18px;text-align:center;padding:0;';
        rm.onclick = function() { _editFiles[idx] = null; wrap.remove(); };
        wrap.appendChild(img); wrap.appendChild(rm);
        container.appendChild(wrap);
      });
      input.value = '';
    };

    window.submitAiEdit = function() {
      var input = document.getElementById('ai-edit-input');
      var prompt = input.value.trim();
      if (!prompt) return;

      document.getElementById('ai-edit-body').classList.add('hidden');
      document.getElementById('ai-edit-loading').classList.remove('hidden');

      var fd = new FormData();
      fd.append('edit_prompt', prompt);
      _editFiles.forEach(function(f) { if (f) fd.append('images[]', f); });

      fetch('<%= ai_edit_content_outline_path(@outline) %>', {
        method: 'POST',
        headers: { 'X-CSRF-Token': document.querySelector('meta[name=csrf-token]').content },
        body: fd
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.poll_url) {
          var poll = setInterval(function() {
            fetch(data.poll_url).then(function(r) { return r.json(); }).then(function(s) {
              if (!s.pending) { clearInterval(poll); location.reload(); }
            });
          }, 3000);
        } else {
          document.getElementById('ai-edit-loading').classList.add('hidden');
          document.getElementById('ai-edit-body').classList.remove('hidden');
          alert(data.error || 'Lỗi');
        }
      });
    };

    document.getElementById('ai-edit-input').addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && (e.metaKey || e.ctrlKey)) submitAiEdit();
    });
  })();
  </script>

<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nội dung được tạo bởi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='Đã sao chép!'; setTimeout(()=>this.textContent='Sao chép',2000)})"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        Sao chép
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>

<script>
function handleRegenerate() {
  var btn = document.getElementById('regenerate-btn');
  if (btn.disabled) return;
  btn.disabled = true;
  btn.style.opacity = '0.5';

  // Show overlay immediately
  var overlay = document.createElement('div');
  overlay.id = 'ai-gen-overlay';
  overlay.style.cssText = 'display:flex;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;background:rgba(15,23,42,0.65);backdrop-filter:blur(4px);';
  overlay.innerHTML = '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.22);max-width:320px;width:90%;"><div id="ai-gen-ring-container"></div><p style="font-size:11px;color:#94A3B8;margin:12px 0 0;">Đừng tắt trang này.</p></div>';
  document.body.appendChild(overlay);

  var phases = ["AI đang tạo <%= @outline.output_type == 'slide' ? 'slide' : 'nội dung' %>...","Đang phân tích...","Đang tạo nội dung...","Đang hoàn thiện..."];
  buildGenRing(phases);

  // Fire AJAX
  var token = document.querySelector('meta[name="csrf-token"]').content;
  var pollUrl = '<%= status_content_outline_path(@outline, format: :json) %>';
  fetch('<%= regenerate_content_outline_path(@outline) %>', {
    method: 'POST',
    headers: { 'Accept': 'application/json', 'X-CSRF-Token': token, 'X-Requested-With': 'XMLHttpRequest' }
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      startGenPolling(data.poll_url || pollUrl);
    })
    .catch(function() { startGenPolling(pollUrl); });
}

function buildGenRing(phases) {
  var totalPhases = phases.length;
  var phase = 0, pct = 0;
  document.getElementById('ai-gen-ring-container').innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
      '<span id="ai-gen-pct" style="font-size:13px;font-weight:800;color:#7c3aed;letter-spacing:-0.3px;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#ede9fe" stroke-width="6"/>',
          '<circle id="ai-gen-arc" cx="44" cy="44" r="38" stroke="#7c3aed" stroke-width="6" stroke-linecap="round" stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
          '<svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="36" height="36" rx="9" fill="#1A6BFF"/><polygon points="10,24 6,31 16,24" fill="white"/><rect x="6" y="6" width="24" height="19" rx="5" fill="white"/><rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/><rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/><rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/></svg>',
        '</div>',
      '</div>',
      '<p id="ai-gen-phase" style="font-size:12px;font-weight:600;color:#6366f1;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');
  var ring = document.getElementById('ai-gen-arc');
  var pctEl = document.getElementById('ai-gen-pct');
  var phEl = document.getElementById('ai-gen-phase');
  var milestones = phases.map(function(_,i){return Math.round(((i+1)/totalPhases)*85);});
  var timer = setInterval(function(){
    var target = milestones[phase]||85;
    pct = Math.min(pct+1, target);
    ring.style.strokeDashoffset = 238.8*(1-pct/100);
    pctEl.textContent = Math.round(pct)+'%';
    if(pct>=(milestones[phase]||85) && phase<totalPhases-1){phase++;phEl.textContent=phases[phase];}
    if(pct>=85 && phase>=totalPhases-1){clearInterval(timer);timer=setInterval(function(){if(pct>=98){clearInterval(timer);return;}pct=Math.min(pct+0.4,98);ring.style.strokeDashoffset=238.8*(1-pct/100);pctEl.textContent=Math.round(pct)+'%';},3000);}
  },300);
}

function startGenPolling(pollUrl) {
  function poll() {
    fetch(pollUrl, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r){return r.json();})
      .then(function(data){
        if(data.failed){
          document.getElementById('ai-gen-overlay').innerHTML =
            '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;max-width:320px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.22);">'+
            '<div style="font-size:2rem;margin-bottom:12px;">⚠️</div>'+
            '<p style="font-size:14px;color:#ef4444;margin:0 0 16px;">Có lỗi xảy ra. Vui lòng thử lại.</p>'+
            '<button onclick="location.reload()" style="padding:8px 20px;background:#6366f1;color:#fff;border:0;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Tải lại</button></div>';
        } else if(data.pending) { setTimeout(poll,2500); }
        else { location.reload(); }
      })
      .catch(function(){setTimeout(poll,3000);});
  }
  setTimeout(poll,1500);
}
</script>
<style>@keyframes vox-pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(0.88);opacity:0.75;}}</style>
