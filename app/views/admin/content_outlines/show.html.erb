    /* Toggle a text prop (bold, italic, underline) and update button state */
    /* ─── Font dropdown with search ─── */
    var ALL_FONTS = [
      'Inter','Nunito','Roboto','Open Sans','Lato','Montserrat','Poppins','Raleway',
      'Oswald','Barlow','DM Sans','Figtree','Outfit','Plus Jakarta Sans','Quicksand',
      'Sora','Exo 2','Kanit','Rubik','Lexend',
      'Merriweather','Playfair Display','Lora','EB Garamond','Cormorant','Libre Baskerville',
      'Crimson Text','PT Serif','Vollkorn','Bitter',
      'Georgia','Arial','Helvetica Neue','Times New Roman','Courier New','Trebuchet MS',
      'Tahoma','Verdana','Impact','Comic Sans MS'
    ];
    var _fontDropOpen = false;

    function buildFontList(filter) {
      var list = document.getElementById('tt-font-list');
      if (!list) return;
      list.innerHTML = '';
      var cur = (document.getElementById('tt-family-label') || {}).textContent;
      if (cur) cur = cur.trim();
      var filtered = filter ? ALL_FONTS.filter(function(f){ return f.toLowerCase().indexOf(filter.toLowerCase()) >= 0; }) : ALL_FONTS;
      if (!filtered.length) {
        list.innerHTML = '<div style="padding:6px 8px;font-size:11px;color:#64748b;">Không tìm thấy</div>';
        return;
      }
      filtered.forEach(function(font) {
        var isActive = font === cur;
        var item = document.createElement('div');
        item.innerHTML = '<span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">' + font + '</span>' +
          (isActive ? '<span style="color:#a5b4fc;font-size:10px;">✓</span>' : '');
        item.style.cssText = 'display:flex;align-items:center;gap:4px;padding:5px 8px;border-radius:6px;cursor:pointer;font-size:12px;color:#e2e8f0;font-family:Inter,system-ui,sans-serif;' +
          (isActive ? 'background:#162c47;' : '');
        item.onmouseenter = function(){ if(!isActive) item.style.background='#334155'; };
        item.onmouseleave = function(){ if(!isActive) item.style.background= isActive?'#162c47':''; };
        item.onclick = function(e) { e.stopPropagation(); selectFont(font); };
        list.appendChild(item);
      });
    }

    function selectFont(font) {
