<% content_for :title, @outline.title %>
<% if @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.to_s.include?("slide-deck-root") %>
  <% content_for :main_class, "flex-1 overflow-y-auto flex flex-col p-6 gap-0" %>
<% end %>

<div class="flex items-center gap-3 mb-4 flex-shrink-0">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @outline.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "outline" => "📋 Dàn ý", "slide" => "🖥️ Slide", "slide_script" => "🖥️ Slide", "lesson_plan" => "📚 Kế hoạch buổi học" }[@outline.output_type] %></span>
      <% if @outline.subject.present? %><span>· <%= @outline.subject %></span><% end %>
      <span>· <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @outline.pptx_file.attached? %>
      <%= link_to rails_blob_path(@outline.pptx_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Tải PPTX
      <% end %>
    <% end %>
    <button type="button" id="regenerate-btn"
        onclick="handleRegenerate()"
        class="flex items-center gap-1.5 px-3 py-2 bg-violet-50 hover:bg-[#1e3a5f] hover:text-white text-violet-700 text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Tạo lại (5 credits)
    </button>
  </div>
</div>

<% if @outline.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url: status_content_outline_path(@outline, format: :json),
        message: "AI đang tạo #{@outline.output_type == 'slide' ? 'slide' : 'nội dung'}...",
        submessage: "Đừng tắt trang này." %>
<% elsif @outline.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">⚠️</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2">Có lỗi xảy ra khi tạo nội dung</h3>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "mt-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer" do %>
      Thử lại
    <% end %>
  </div>
<% elsif @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.include?("slide-deck-root") %>
  <!-- Slide viewer + editor layout -->
  <div id="slide-editor-layout" style="display:flex;gap:12px;align-items:flex-start;flex:1;min-height:0;">

    <!-- SLIDE PANEL: thumbnail sidebar -->
    <div id="slide-panel" style="width:160px;flex-shrink:0;background:#f8fafc;border-radius:16px;border:1px solid #e2e8f0;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);display:flex;flex-direction:column;position:sticky;top:0;max-height:100vh;">
      <div style="padding:8px 10px 6px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;">
        <span style="font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.07em;">Slides</span>
        <button onclick="addBlankSlide()" title="Thêm slide mới" style="background:#1e3a5f;border:none;color:#fff;border-radius:6px;width:22px;height:22px;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;padding:0;line-height:1;">+</button>
      </div>
      <div id="slide-thumb-list" style="display:flex;flex-direction:column;gap:6px;padding:8px;overflow-y:auto;flex:1;"></div>
    </div>

    <!-- CENTER: slide viewer -->
    <div id="slide-viewer-col" style="flex:1;min-width:0;overflow-y:auto;align-self:flex-start;width:100%;">
      <div class="bg-white rounded-2xl shadow-sm">
        <div class="border-b border-slate-100 px-4 py-2 flex items-center justify-between">
          <div class="flex items-center gap-3 flex-wrap">
            <span class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">🖥️ Slide</span>
            <div id="slide-dots" class="flex gap-1"></div>
          </div>
          <div class="flex items-center gap-2">
            <!-- WYSIWYG drag-edit toggle -->
            <button onclick="toggleWysiwyg()"
                    id="wysiwyg-btn"
                    title="Kéo thả chỉnh sửa trực tiếp trên slide"
                    class="text-[12px] text-slate-600 hover:text-white px-3 py-1 bg-slate-50 hover:bg-[#1e3a5f] rounded-lg transition-colors border-0 cursor-pointer font-medium">
              ✏️ Sửa trực tiếp
            </button>
            <!-- AI edit panel toggle -->
            <button onclick="toggleAiPanel()"
                    id="ai-panel-btn"
                    class="text-[12px] text-indigo-600 hover:text-white px-3 py-1 bg-indigo-50 hover:bg-[#1e3a5f] rounded-lg transition-colors border-0 cursor-pointer font-semibold">
              ✨ Sửa bằng AI
            </button>
            <button onclick="enterFullscreen()"
                    class="text-[12px] text-slate-500 hover:text-white px-3 py-1 bg-slate-50 hover:bg-[#1e3a5f] rounded-lg transition-colors border-0 cursor-pointer">
              ⛶ Toàn màn hình
            </button>
            <button onclick="openShareDialog()"
                    class="text-[12px] text-slate-500 hover:text-white px-3 py-1 bg-slate-50 hover:bg-[#1e3a5f] rounded-lg transition-colors border-0 cursor-pointer">
              🔗 Chia sẻ
            </button>
          </div>
        </div>

        <!-- WYSIWYG mode bar -->
        <div id="wysiwyg-bar" style="display:none;background:var(--vox-accent-dk);color:#fff;padding:5px 12px;font-size:11px;font-weight:600;align-items:center;gap:8px;flex-wrap:wrap;">
          <span style="flex:1;min-width:160px;">✏️ Kéo di chuyển · Kéo góc resize · Double-click sửa text/biểu đồ</span>
          <!-- Slide background color panel -->
          <div style="position:relative;">
            <button id="bg-btn" onclick="toggleBgPanel()" style="background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;">
              🪣 Màu nền
              <span id="bg-preview" style="width:14px;height:14px;border-radius:3px;background:#fff;border:1px solid rgba(255,255,255,.4);display:inline-block;flex-shrink:0;"></span>
            </button>
            <div id="bg-panel" style="display:none;position:absolute;left:0;top:calc(100% + 6px);z-index:10001;background:#fff;color:#1e293b;border:1px solid #e2e8f0;border-radius:14px;box-shadow:0 12px 32px rgba(0,0,0,.18);padding:14px;width:260px;">
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;">Màu có sẵn</div>
              <div id="bg-swatches" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px;"></div>
              <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px;">Tuỳ chỉnh</div>
              <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px;">
                <input type="color" id="bg-color-input" style="width:36px;height:32px;border:1px solid #e2e8f0;border-radius:6px;cursor:pointer;padding:2px;" title="Chọn màu tuỳ chỉnh" oninput="var h=document.getElementById('bg-hex-input');if(h)h.value=this.value;updateBgPreview(this.value);">
                <input type="text" id="bg-hex-input" placeholder="#ffffff" maxlength="7"
                       style="flex:1;border:1px solid #e2e8f0;border-radius:6px;padding:5px 8px;font-size:12px;font-family:monospace;outline:none;"
                       oninput="syncBgHex(this.value)">
              </div>
              <button onclick="confirmBgColor()" style="width:100%;background:var(--vox-accent-dk);color:#fff;border:none;border-radius:8px;padding:7px 0;font-size:12px;font-weight:700;cursor:pointer;">✓ Áp dụng</button>
            </div>
          </div>
          <!-- Image insert -->
          <label style="background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap;">
            📷 Chèn ảnh
            <input type="file" id="img-upload-input" accept="image/*" style="display:none;" onchange="insertImageFromFile(this)">
          </label>
          <div style="display:flex;gap:2px;background:rgba(255,255,255,.12);border-radius:6px;padding:2px;">
            <button id="undo-btn" onclick="undo()" title="Hoàn tác (Ctrl+Z)" style="background:none;border:none;color:#fff;width:26px;height:26px;border-radius:4px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;opacity:.5;" disabled>↩</button>
            <button id="redo-btn" onclick="redo()" title="Làm lại (Ctrl+Y)" style="background:none;border:none;color:#fff;width:26px;height:26px;border-radius:4px;cursor:pointer;font-size:14px;display:flex;align-items:center;justify-content:center;opacity:.5;" disabled>↪</button>
          </div>
          <!-- Insert component -->
          <div style="position:relative;">
            <button onclick="toggleInsertPanel()" style="background:rgba(255,255,255,.18);border:none;color:#fff;padding:3px 10px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;white-space:nowrap;">➕ Thêm</button>
            <div id="insert-panel" style="display:none;position:absolute;right:0;top:calc(100%+6px);z-index:10050;background:#fff;border:1px solid #e2e8f0;border-radius:16px;box-shadow:0 12px 32px rgba(0,0,0,.18);padding:14px 12px;width:340px;max-height:560px;overflow-y:auto;">

              <!-- Text & Media -->
              <div class="ins-section-title">Văn bản & Media</div>
              <div class="ins-list">
                <button onclick="insertComponent('text')" class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="1" y="1" width="16" height="16" rx="3" fill="none" stroke="#1e3a5f" stroke-width="1.5"/><text x="9" y="13" text-anchor="middle" font-size="10" font-weight="700" fill="#1e3a5f" font-family="sans-serif">T</text></svg><span>Hộp văn bản</span></button>
                <label class="ins-row" style="cursor:pointer;"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="1" y="3" width="16" height="12" rx="2" fill="#f1f5f9" stroke="#94a3b8" stroke-width="1.2"/><circle cx="6" cy="7" r="2" fill="#fbbf24"/><polyline points="1,15 6,9 10,13 13,10 17,15" fill="none" stroke="#1e3a5f" stroke-width="1.2"/></svg><span>Chèn ảnh</span><input type="file" accept="image/*" style="display:none;" onchange="insertImageFromFile(this);document.getElementById('insert-panel').style.display='none';"></label>
                <button onclick="document.getElementById('insert-panel').style.display='none';openIconPicker('insert')" class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="9" cy="9" r="8" fill="#1e3a5f"/><polygon points="9,4 10.5,7.5 14,7.5 11.5,9.8 12.5,13 9,11 5.5,13 6.5,9.8 4,7.5 7.5,7.5" fill="#fff"/></svg><span>Icon</span></button>
                <button onclick="insertComponent('video')" class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="1" y="3" width="12" height="12" rx="2" fill="#f1f5f9" stroke="#94a3b8" stroke-width="1.2"/><polygon points="17,9 13,6 13,12" fill="#1e3a5f"/></svg><span>Video (URL)</span></button>
              </div>

              <!-- Shapes grid -->
              <div class="ins-section-title" style="margin-top:10px;">Hình dạng</div>
              <div class="ins-grid">
                <button onclick="insertComponent('rect')"       class="ins-shape" title="Hình chữ nhật"><svg width="30" height="24" viewBox="0 0 30 24"><rect x="2" y="4" width="26" height="16" rx="2" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('rect_round')" class="ins-shape" title="Bo góc lớn"><svg width="30" height="24" viewBox="0 0 30 24"><rect x="2" y="4" width="26" height="16" rx="8" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('circle')"     class="ins-shape" title="Hình tròn"><svg width="30" height="24" viewBox="0 0 30 24"><circle cx="15" cy="12" r="10" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('ellipse')"    class="ins-shape" title="Hình ellipse"><svg width="30" height="24" viewBox="0 0 30 24"><ellipse cx="15" cy="12" rx="13" ry="8" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('triangle')"   class="ins-shape" title="Tam giác"><svg width="30" height="24" viewBox="0 0 30 24"><polygon points="15,3 28,21 2,21" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('diamond')"    class="ins-shape" title="Hình thoi"><svg width="30" height="24" viewBox="0 0 30 24"><polygon points="15,2 28,12 15,22 2,12" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('hexagon')"    class="ins-shape" title="Lục giác"><svg width="30" height="24" viewBox="0 0 30 24"><polygon points="15,2 27,8 27,16 15,22 3,16 3,8" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('pentagon')"   class="ins-shape" title="Ngũ giác"><svg width="30" height="24" viewBox="0 0 30 24"><polygon points="15,2 28,10 23,22 7,22 2,10" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('star')"       class="ins-shape" title="Ngôi sao"><svg width="30" height="24" viewBox="0 0 30 24"><polygon points="15,2 18,9 26,9 20,14 22,22 15,17 8,22 10,14 4,9 12,9" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('parallelogram')" class="ins-shape" title="Hình bình hành"><svg width="30" height="24" viewBox="0 0 30 24"><polygon points="8,4 28,4 22,20 2,20" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
                <button onclick="insertComponent('trapezoid')"  class="ins-shape" title="Hình thang"><svg width="30" height="24" viewBox="0 0 30 24"><polygon points="7,4 23,4 28,20 2,20" fill="#e0e7ff" stroke="#1e3a5f" stroke-width="1.5"/></svg></button>
              </div>

              <!-- Lines & Arrows -->
              <div class="ins-section-title" style="margin-top:10px;">Đường kẻ & Mũi tên</div>
              <div class="ins-grid">
                <button onclick="insertComponent('divider')"    class="ins-shape" title="Đường thẳng"><svg width="30" height="24" viewBox="0 0 30 24"><line x1="2" y1="12" x2="28" y2="12" stroke="#1e3a5f" stroke-width="2" stroke-linecap="round"/></svg></button>
                <button onclick="insertComponent('divider_dots')" class="ins-shape" title="Đường chấm"><svg width="30" height="24" viewBox="0 0 30 24"><line x1="2" y1="12" x2="28" y2="12" stroke="#1e3a5f" stroke-width="2" stroke-dasharray="3 4" stroke-linecap="round"/></svg></button>
                <button onclick="insertComponent('divider_gradient')" class="ins-shape" title="Đường gradient"><svg width="30" height="24" viewBox="0 0 30 24"><defs><linearGradient id="lg1" x1="0" x2="1"><stop offset="0" stop-color="#1e3a5f" stop-opacity="0"/><stop offset="0.5" stop-color="#1e3a5f"/><stop offset="1" stop-color="#1e3a5f" stop-opacity="0"/></linearGradient></defs><line x1="2" y1="12" x2="28" y2="12" stroke="url(#lg1)" stroke-width="2.5" stroke-linecap="round"/></svg></button>
                <button onclick="insertComponent('arrow')"      class="ins-shape" title="Mũi tên phải"><svg width="30" height="24" viewBox="0 0 30 24"><line x1="2" y1="12" x2="20" y2="12" stroke="#1e3a5f" stroke-width="2" stroke-linecap="round"/><polygon points="20,7 28,12 20,17" fill="#1e3a5f"/></svg></button>
                <button onclick="insertComponent('arrow_dbl')"  class="ins-shape" title="Mũi tên 2 chiều"><svg width="30" height="24" viewBox="0 0 30 24"><line x1="10" y1="12" x2="20" y2="12" stroke="#1e3a5f" stroke-width="2"/><polygon points="10,7 2,12 10,17" fill="#1e3a5f"/><polygon points="20,7 28,12 20,17" fill="#1e3a5f"/></svg></button>
                <button onclick="insertComponent('arrow_down')" class="ins-shape" title="Mũi tên xuống"><svg width="30" height="24" viewBox="0 0 30 24"><line x1="15" y1="2" x2="15" y2="18" stroke="#1e3a5f" stroke-width="2" stroke-linecap="round"/><polygon points="10,16 15,22 20,16" fill="#1e3a5f"/></svg></button>
              </div>

              <!-- Content blocks -->
              <div class="ins-section-title" style="margin-top:10px;">Khối nội dung</div>
              <div class="ins-list">
                <button onclick="insertComponent('stat')"     class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="1" y="1" width="16" height="16" rx="3" fill="#d9e5f1"/><text x="9" y="12" text-anchor="middle" font-size="9" font-weight="800" fill="#1e3a5f" font-family="sans-serif">42</text></svg><span>Số liệu / KPI</span></button>
                <button onclick="insertComponent('progress')" class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="1" y="7" width="16" height="4" rx="2" fill="#e2e8f0"/><rect x="1" y="7" width="10" height="4" rx="2" fill="#1e3a5f"/></svg><span>Thanh tiến trình</span></button>
                <button onclick="insertComponent('callout')"  class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="1" y="2" width="16" height="11" rx="3" fill="#d9e5f1" stroke="#1e3a5f" stroke-width="1"/><polygon points="4,13 2,17 8,13" fill="#d9e5f1" stroke="#1e3a5f" stroke-width="1"/></svg><span>Callout box</span></button>
                <button onclick="insertComponent('quote')"    class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><text x="2" y="14" font-size="16" fill="#1e3a5f" font-family="Georgia,serif">"</text></svg><span>Trích dẫn</span></button>
              </div>

              <!-- Charts -->
              <div class="ins-section-title" style="margin-top:10px;">Biểu đồ & Dữ liệu</div>
              <div class="ins-list">
                <button onclick="insertComponent('chart_bar')"   class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="2" y="10" width="3" height="7" fill="#1e3a5f"/><rect x="7" y="6" width="3" height="11" fill="#818cf8"/><rect x="12" y="8" width="3" height="9" fill="#a5b4fc"/></svg><span>Biểu đồ cột</span></button>
                <button onclick="insertComponent('chart_line')"  class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><polyline points="2,14 6,8 10,11 14,4 16,6" fill="none" stroke="#1e3a5f" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"/><circle cx="2" cy="14" r="1.5" fill="#1e3a5f"/><circle cx="6" cy="8" r="1.5" fill="#1e3a5f"/><circle cx="10" cy="11" r="1.5" fill="#1e3a5f"/><circle cx="14" cy="4" r="1.5" fill="#1e3a5f"/></svg><span>Biểu đồ đường</span></button>
                <button onclick="insertComponent('chart_donut')" class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><circle cx="9" cy="9" r="7" fill="none" stroke="#e2e8f0" stroke-width="4"/><circle cx="9" cy="9" r="7" fill="none" stroke="#1e3a5f" stroke-width="4" stroke-dasharray="28 16" stroke-dashoffset="7"/></svg><span>Biểu đồ tròn</span></button>
                <button onclick="insertComponent('table')"       class="ins-row"><svg width="18" height="18" viewBox="0 0 18 18"><rect x="1" y="1" width="16" height="16" rx="2" fill="none" stroke="#94a3b8" stroke-width="1"/><rect x="1" y="1" width="16" height="5" rx="2" fill="#1e3a5f"/><line x1="7" y1="1" x2="7" y2="17" stroke="#e2e8f0" stroke-width="0.8"/><line x1="12" y1="1" x2="12" y2="17" stroke="#e2e8f0" stroke-width="0.8"/><line x1="1" y1="9" x2="17" y2="9" stroke="#e2e8f0" stroke-width="0.8"/><line x1="1" y1="13" x2="17" y2="13" stroke="#e2e8f0" stroke-width="0.8"/></svg><span>Bảng</span></button>
              </div>

            </div>
            <style>
              .ins-section-title{font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.07em;padding:0 4px 7px;}
              .ins-list{display:flex;flex-direction:column;gap:1px;}
              .ins-row{display:flex;align-items:center;gap:9px;width:100%;padding:6px 8px;border:none;background:none;cursor:pointer;border-radius:8px;font-size:12px;color:#1e293b;text-align:left;}
              .ins-row:hover{background:#f1f5f9;}
              .ins-row svg{flex-shrink:0;}
              .ins-row span{flex:1;}
              .ins-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:4px;}
              .ins-shape{display:flex;align-items:center;justify-content:center;padding:5px 2px;border:1px solid transparent;background:none;border-radius:8px;cursor:pointer;}
              .ins-shape:hover{background:#f1f5f9;border-color:#e2e8f0;}
            </style>
          </div>
