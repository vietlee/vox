    /* Double-click video element to change URL */
    /* ─── Table editor ─── */
    var _tableEditEl = null;

    function startTableEdit(e) {
      if (!editorMode) return;
      e.stopPropagation();
      var domEl = e.currentTarget;
      var elId = domEl.getAttribute('data-ei');
      var sl = slides[current];
      var elData = sl && (sl.elements||[]).find(function(el){return el.id===elId;});
      if (!elData) return;
      _tableEditEl = elData;
      renderTableEditorGrid();
      var panel = document.getElementById('table-editor');
      var rect = domEl.getBoundingClientRect();
      panel.style.display = 'block';
      panel.style.left = Math.min(rect.left, window.innerWidth - 540) + 'px';
      panel.style.top  = Math.max(10, rect.top - 20) + 'px';
    }

    function renderTableEditorGrid() {
      if (!_tableEditEl) return;
      var rows = _tableEditEl.table || [];
      var t = deck.theme || {};
      var accent = (_tableEditEl.style||{}).accentColor || t.accent || '#1e3a5f';
      var html = '<table style="border-collapse:collapse;min-width:100%;table-layout:auto;">';
      rows.forEach(function(row, ri) {
        var isHeader = ri === 0;
        html += '<tr>';
        row.forEach(function(cell, ci) {
          html += '<td style="padding:2px;">' +
            '<input type="text" value="'+cell.replace(/"/g,'&quot;')+'" ' +
            'data-r="'+ri+'" data-c="'+ci+'" ' +
            'style="width:100%;min-width:80px;box-sizing:border-box;background:'+(isHeader?accent+'33':'#0f172a')+';' +
            'border:1px solid #334155;border-radius:5px;color:#f1f5f9;font-size:11px;' +
            'padding:5px 7px;outline:none;font-weight:'+(isHeader?'700':'400')+';" ' +
            'oninput="tableUpdateCell(this)"/>' +
            '</td>';
        });
        html += '</tr>';
      });
      html += '</table>';
      document.getElementById('table-editor-grid').innerHTML = html;
    }

    function tableUpdateCell(inp) {
      if (!_tableEditEl) return;
      var r = parseInt(inp.dataset.r), c = parseInt(inp.dataset.c);
      if (!_tableEditEl.table[r]) return;
      _tableEditEl.table[r][c] = inp.value;
      /* Re-render slide immediately so changes are visible */
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      scheduleSave();
    }

    function _scrollTableGrid(toEnd, toRight) {
      var g = document.getElementById('table-editor-grid');
      if (!g) return;
      if (toEnd)   g.scrollTop  = g.scrollHeight;
      if (toRight) g.scrollLeft = g.scrollWidth;
    }

    function tableAddRow() {
      if (!_tableEditEl) return;
      var cols = (_tableEditEl.table[0]||[]).length || 2;
      var newRow = []; for (var i=0;i<cols;i++) newRow.push('');
      _tableEditEl.table.push(newRow);
      renderTableEditorGrid();
      _scrollTableGrid(true, false);
      /* Focus first cell of new row */
      var g = document.getElementById('table-editor-grid');
      var lastRow = g && g.querySelectorAll('tr');
      if (lastRow && lastRow.length) { var inp = lastRow[lastRow.length-1].querySelector('input'); if (inp) inp.focus(); }
      applyTableEdit(true);
    }

    function tableDelRow() {
      if (!_tableEditEl || _tableEditEl.table.length <= 1) return;
      _tableEditEl.table.pop();
      renderTableEditorGrid();
      applyTableEdit(true);
    }

    function tableAddCol() {
      if (!_tableEditEl) return;
      _tableEditEl.table.forEach(function(row){ row.push(''); });
      renderTableEditorGrid();
      _scrollTableGrid(false, true);
      /* Focus new col header cell */
      var g = document.getElementById('table-editor-grid');
      var firstRow = g && g.querySelector('tr');
      if (firstRow) { var inputs = firstRow.querySelectorAll('input'); if (inputs.length) inputs[inputs.length-1].focus(); }
      applyTableEdit(true);
    }

    function tableDelCol() {
      if (!_tableEditEl) return;
      var minCols = _tableEditEl.table.reduce(function(m,r){return Math.min(m,r.length);}, 99);
      if (minCols <= 1) return;
      _tableEditEl.table.forEach(function(row){ row.pop(); });
      renderTableEditorGrid();
      applyTableEdit(true);
    }

    function applyTableEdit(keepOpen) {
      if (!_tableEditEl) return;
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      renderThumbnails();
      scheduleSave();
      if (!keepOpen) closeTableEditor();
    }

    function closeTableEditor() {
      document.getElementById('table-editor').style.display = 'none';
      _tableEditEl = null;
    }

    /* Toolbar quick-action helpers (no double-click needed) */
    function _ttTableApply() {
      var el = window._ttTableEl; if (!el) return;
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      renderThumbnails(); scheduleSave();
    }
    function ttTableAddRow() {
      var el = window._ttTableEl; if (!el) return;
      var cols = (el.table[0]||[]).length || 2;
      var row = []; for (var i=0;i<cols;i++) row.push('');
      el.table.push(row); _ttTableApply();
    }
    function ttTableDelRow() {
      var el = window._ttTableEl; if (!el || el.table.length <= 1) return;
      el.table.pop(); _ttTableApply();
    }
    function ttTableAddCol() {
      var el = window._ttTableEl; if (!el) return;
      el.table.forEach(function(r){ r.push(''); }); _ttTableApply();
    }
    function ttTableDelCol() {
      var el = window._ttTableEl; if (!el) return;
      var minC = el.table.reduce(function(m,r){return Math.min(m,r.length);},99);
      if (minC <= 1) return;
      el.table.forEach(function(r){ r.pop(); }); _ttTableApply();
    }
    function ttTableOpenEdit() {
      /* Open the full table editor panel */
      var el = window._ttTableEl; if (!el) return;
      _tableEditEl = el;
      renderTableEditorGrid();
      var tb = document.getElementById('txt-toolbar');
      var panel = document.getElementById('table-editor');
      panel.style.display = 'block';
      var rect = tb ? tb.getBoundingClientRect() : {left:100,bottom:60};
      panel.style.left = Math.min(rect.left, window.innerWidth - 540) + 'px';
      panel.style.top  = (rect.bottom + 8) + 'px';
    }
    window.ttTableOpenEdit  = ttTableOpenEdit;
    window.tableAddRow      = tableAddRow;
    window.tableDelRow      = tableDelRow;
    window.tableAddCol      = tableAddCol;
    window.tableDelCol      = tableDelCol;
    window.applyTableEdit   = applyTableEdit;
    window.closeTableEditor = closeTableEditor;
    window.tableUpdateCell  = tableUpdateCell;

    function startVideoEdit(e) {
      if (!editorMode) return;
      e.stopPropagation();
      var domEl = e.currentTarget;
      var elId = domEl.getAttribute('data-ei');
      var sl = slides[current];
      var elData = sl ? (sl.elements||[]).find(function(e){ return e.id===elId; }) : null;
      if (!elData) return;
      var modal = document.getElementById('video-url-modal');
      var inp = document.getElementById('video-url-input');
      inp.value = elData.src || elData.content || '';
      /* Reuse modal — on confirm, update existing element */
      inp.dataset.editId = elId;
      modal.style.display = 'flex';
      setTimeout(function(){ inp.focus(); inp.select(); }, 50);
      /* Override confirm to update instead of insert */
      window._videoEditId = elId;
    }

    /* Patch confirmVideoUrl to handle edit mode */
    var _origConfirmVideoUrl = confirmVideoUrl;
    confirmVideoUrl = function() {
      var url = (document.getElementById('video-url-input').value || '').trim();
      document.getElementById('video-url-modal').style.display = 'none';
      if (!url) return;
      var editId = window._videoEditId;
      window._videoEditId = null;
      if (editId) {
        var sl = slides[current];
        var elData = sl ? (sl.elements||[]).find(function(e){ return e.id===editId; }) : null;
        if (elData) {
          saveHistorySnapshot();
          elData.src = url; elData.content = url;
          var stage = document.getElementById('slide-stage');
          if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
          if (editorMode) attachEditorHandlers();
          renderThumbnails(); autoSave();
        }
        return;
      }
      _origConfirmVideoUrl();
    };
    window.confirmVideoUrl = confirmVideoUrl;

    window.toggleInsertPanel = toggleInsertPanel;
    window.insertComponent = insertComponent;

    /* ═══════════════════════════════════════════════════
       DUPLICATE SLIDE
    ═══════════════════════════════════════════════════ */
    var _dupSlideIdx = null;
    function duplicateSlide(idx) {
      if (idx === undefined) idx = current;
      _dupSlideIdx = idx;
      var modal = document.getElementById('dup-slide-modal');
      if (modal) { modal.style.display = 'flex'; }
    }
    /* ─── Share dialog ─── */
    var _shareUrl = '<%= @outline.share_token.present? ? public_slide_url(@outline.share_token) : "" %>';
    function openShareDialog() {
      var m = document.getElementById('share-modal');
      if (!m) return;
      m.style.display = 'flex';
      /* Auto-create link+QR if not yet generated */
      if (!_shareUrl) generateShareLink();
    }
    function closeShareDialog() {
      var m = document.getElementById('share-modal');
      if (m) m.style.display = 'none';
    }
    var _shareQrImageUrl = '<%= @share_qr ? qr_image_url(token: @share_qr.token) : "" %>';
    function _shareLoading(on) {
      var loading = document.getElementById('share-loading');
      var active  = document.getElementById('share-active');
      if (on) { if(loading)loading.style.display='block'; if(active)active.style.display='none'; }
      else { if(loading)loading.style.display='none'; }
    }
    function _shareSetActive(data) {
      _shareUrl = data.url;
      _shareQrImageUrl = data.qr_image_url || '';
      var inp = document.getElementById('share-url-input');
      if (inp) inp.value = _shareUrl;
      /* Update QR image */
      var qrImg = document.getElementById('share-qr-img');
      if (qrImg && _shareQrImageUrl) qrImg.src = _shareQrImageUrl + '?t=' + Date.now();
      var qrSection = document.getElementById('share-qr-section');
      if (qrSection) qrSection.style.display = _shareQrImageUrl ? 'flex' : 'none';
      document.getElementById('share-active').style.display = 'block';
      applyThemeAccent();
    }
    function _shareSetInactive() {
      _shareUrl = ''; _shareQrImageUrl = '';
      var active = document.getElementById('share-active');
      if (active) active.style.display = 'none';
      /* Immediately re-generate a new link after revoking */
      generateShareLink();
    }
    function _sharePost(path) {
      return fetch(path, { method:'POST', headers:{ 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content, 'Accept':'application/json' } }).then(function(r){return r.json();});
    }
    function generateShareLink() {
      _shareLoading(true);
      _sharePost('<%= toggle_share_content_outline_path(@outline) %>').then(function(data) {
        _shareLoading(false);
        if (data.ok) _shareSetActive(data); else alert('Lỗi: '+(data.error||'unknown'));
      }).catch(function(e){ _shareLoading(false); alert('Lỗi: '+e); });
    }
    /* Custom confirm dialog */
    function shareConfirm(title, body, dangerOk, cb) {
      var el = document.getElementById('share-confirm');
      if (!el) { if (confirm(body)) cb(); return; }
      document.getElementById('share-confirm-title').textContent = title;
      document.getElementById('share-confirm-body').textContent  = body;
      var okBtn = document.getElementById('share-confirm-ok');
      okBtn.style.background = dangerOk ? '#dc2626' : '#1e3a5f';
      el.style.display = 'flex';
      el.style.pointerEvents = 'all';
      function cleanup() { el.style.display = 'none'; el.style.pointerEvents = 'none'; okBtn.onclick = null; document.getElementById('share-confirm-cancel').onclick = null; }
      okBtn.onclick = function() { cleanup(); cb(); };
      document.getElementById('share-confirm-cancel').onclick = cleanup;
    }

    function revokeShareLink() {
      shareConfirm('Thu hồi link chia sẻ?', 'Link hiện tại sẽ bị xoá, người đang có link không truy cập được nữa. Một link mới sẽ được tạo ngay.', true, function() {
        _shareLoading(true);
        _sharePost('<%= revoke_share_content_outline_path(@outline) %>').then(function(data) {
          _shareLoading(false);
          if (data.ok) _shareSetInactive(); else showToast('Lỗi: '+(data.error||'unknown'));
        }).catch(function(e){ _shareLoading(false); showToast('Lỗi: '+e); });
      });
    }
    function regenerateShareLink() {
      shareConfirm('Tạo link mới?', 'Link cũ sẽ bị vô hiệu ngay lập tức. Một link & QR mới sẽ được tạo.', false, function() {
        _shareLoading(true);
        _sharePost('<%= regenerate_share_content_outline_path(@outline) %>').then(function(data) {
          _shareLoading(false);
          if (data.ok) _shareSetActive(data); else showToast('Lỗi: '+(data.error||'unknown'));
        }).catch(function(e){ _shareLoading(false); showToast('Lỗi: '+e); });
      });
    }
    function _setCopied(btn, originalHtml) {
      var origBg    = btn.style.background || '';
      var origDisplay = btn.style.display || '';
      btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Đã sao chép';
      btn.style.background = '#16a34a';
      btn.style.display = 'inline-flex';
      btn.style.alignItems = 'center';
      btn.style.gap = '5px';
      btn.style.whiteSpace = 'nowrap';
      setTimeout(function(){
        btn.innerHTML = originalHtml;
        btn.style.background = origBg;
        btn.style.display = origDisplay;
        btn.style.alignItems = '';
        btn.style.gap = '';
        btn.style.whiteSpace = '';
      }, 5000);
    }
    function downloadQrImage() {
      var src = _shareQrImageUrl || (document.getElementById('share-qr-img')||{}).src;
      if (!src) return;
      var a = document.createElement('a'); a.href = src; a.download = 'qrcode-slide.png'; a.click();
    }
    window.downloadQrImage = downloadQrImage;
    window.revokeShareLink = revokeShareLink;
    window.regenerateShareLink = regenerateShareLink;
    function copyShareUrl() {
      if (!_shareUrl) return;
      var btn = document.getElementById('share-copy-btn');
      var origHtml = btn ? btn.innerHTML : '';
      navigator.clipboard.writeText(_shareUrl).then(function() {
        if (btn) _setCopied(btn, origHtml);
      });
    }
    window.openShareDialog = openShareDialog;
    window.closeShareDialog = closeShareDialog;
    window.generateShareLink = generateShareLink;
    window.copyShareUrl = copyShareUrl;

    function cancelDupSlide() {
      var modal = document.getElementById('dup-slide-modal');
      if (modal) modal.style.display = 'none';
      _dupSlideIdx = null;
    }
    function confirmDupSlide() {
      var modal = document.getElementById('dup-slide-modal');
      if (modal) modal.style.display = 'none';
      var idx = (_dupSlideIdx !== null) ? _dupSlideIdx : current;
      _dupSlideIdx = null;
      saveHistorySnapshot();
      var src = slides[idx];
      var copy = JSON.parse(JSON.stringify(src));
      var ts = Date.now();
      copy.id = 'slide_dup_' + ts;
      (copy.elements || []).forEach(function(el, i) { el.id = 'el_dup_' + ts + '_' + i; });
      slides.splice(idx + 1, 0, copy);
      total = slides.length;
      deck.slides = slides;
      autoSave();
      goToSlide(idx + 1);
      renderThumbnails();
    }
    window.duplicateSlide = duplicateSlide;
    window.cancelDupSlide = cancelDupSlide;
    window.confirmDupSlide = confirmDupSlide;

    /* ═══════════════════════════════════════════════════
       COPY / PASTE / DUPLICATE ELEMENT
    ═══════════════════════════════════════════════════ */
    var _clipboard = null;

    function copySelectedEl() {
      if (!selectedElId) { showToast('Chưa chọn element'); return; }
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (el) {
        _clipboard = JSON.parse(JSON.stringify(el));
        showToast('Đã copy: ' + (el.type || 'element'));
      } else {
        showToast('Không tìm thấy element (id=' + selectedElId + ')');
      }
    }

    function pasteEl() {
      if (!editorMode) return;
      if (!_clipboard) { showToast('Chưa copy element nào'); return; }
      saveHistorySnapshot();
      var sl = slides[current];
      if (!sl) return;
      var copy = JSON.parse(JSON.stringify(_clipboard));
      copy.id = 'el_paste_' + Date.now();
      copy.x = Math.min((copy.x || 0) + 0.2, 9.5);
      copy.y = Math.min((copy.y || 0) + 0.2, 5.0);
      if (!sl.elements) sl.elements = [];
      sl.elements.push(copy);
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      renderThumbnails();
      autoSave();
      /* select the pasted element */
      selectedElId = copy.id;
      selectedElIds = [copy.id];
      var domEl = document.querySelector('[data-ei="'+copy.id+'"]');
      if (domEl) {
        domEl.classList.add('sel-el');
        domEl.style.outlineColor = _accentDk();
        addResizeHandles(domEl);
        var si2 = parseInt(domEl.dataset.si);
        var elData2 = slides[si2] && (slides[si2].elements||[]).find(function(e2){ return e2.id === copy.id; });
        if (elData2 && elData2.type === 'text') showTextToolbar(domEl);
        else showBgOnlyToolbar(domEl);
      }
    }

    function duplicateSelectedEl() {
      if (!selectedElId || !editorMode) return;
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (!el) return;
      _clipboard = JSON.parse(JSON.stringify(el));
      pasteEl();
    }

    /* ═══════════════════════════════════════════════════
       Z-ORDER
    ═══════════════════════════════════════════════════ */
    function zOrder(dir) {
      if (!selectedElId) return;
      var sl = slides[current];
      if (!sl || !sl.elements) return;
      saveHistorySnapshot();
      var els = sl.elements;
      var zVals = els.map(function(e){ return e.z || 1; });
      var minZ = Math.min.apply(null, zVals);
      var maxZ = Math.max.apply(null, zVals);
      var el = els.find(function(e){ return e.id === selectedElId; });
      if (!el) return;
      var curZ = el.z || 1;
      if (dir === 'front')   { el.z = maxZ + 1; }
      else if (dir === 'back')    { el.z = Math.max(0, minZ - 1); }
      else if (dir === 'forward') { el.z = curZ + 1; }
      else if (dir === 'backward'){ el.z = Math.max(0, curZ - 1); }
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      /* re-select with handles */
      selectedElId = el.id;
      var domEl2 = stage && stage.querySelector('[data-ei="'+el.id+'"]');
      if (domEl2) {
        domEl2.classList.add('sel-el');
        if (typeof addResizeHandles === 'function') addResizeHandles(domEl2);
      }
      autoSave();
    }
    window.zOrder = zOrder;

    /* ═══════════════════════════════════════════════════
       ALIGN TOOLS
    ═══════════════════════════════════════════════════ */
    function toggleAlignPanel() {
      var p = document.getElementById('align-panel');
      if (p) p.style.display = p.style.display === 'none' ? 'block' : 'none';
    }
    function alignEls(dir) {
      document.getElementById('align-panel').style.display = 'none';
      var sl = slides[current];
      if (!sl || !sl.elements) return;
      /* collect IDs to align: multi-select or single */
      var ids = selectedElIds.length > 1 ? selectedElIds : (selectedElId ? [selectedElId] : []);
      if (!ids.length) return;
      saveHistorySnapshot();
      var targets = sl.elements.filter(function(e){ return ids.indexOf(e.id) !== -1; });
      /* Slide dimensions in inches: 10 × 5.625 */
      var SW = 10, SH = 5.625;
      if (dir === 'left') {
        targets.forEach(function(e){ e.x = 0; });
      } else if (dir === 'right') {
        targets.forEach(function(e){ e.x = +(SW - (e.w || 0)).toFixed(4); });
      } else if (dir === 'hcenter') {
        targets.forEach(function(e){ e.x = +((SW - (e.w || 0)) / 2).toFixed(4); });
      } else if (dir === 'top') {
        targets.forEach(function(e){ e.y = 0; });
      } else if (dir === 'bottom') {
        targets.forEach(function(e){ e.y = +(SH - (e.h || 0)).toFixed(4); });
      } else if (dir === 'vcenter') {
        targets.forEach(function(e){ e.y = +((SH - (e.h || 0)) / 2).toFixed(4); });
      } else if (dir === 'distribute-h' && targets.length >= 2) {
        targets.sort(function(a,b){ return a.x - b.x; });
        var x0 = targets[0].x, x1 = targets[targets.length-1].x;
        var gap = (x1 - x0) / (targets.length - 1);
        targets.forEach(function(e, i){ e.x = +(x0 + gap * i).toFixed(4); });
      } else if (dir === 'distribute-v' && targets.length >= 2) {
        targets.sort(function(a,b){ return a.y - b.y; });
        var y0 = targets[0].y, y1 = targets[targets.length-1].y;
        var gap = (y1 - y0) / (targets.length - 1);
        targets.forEach(function(e, i){ e.y = +(y0 + gap * i).toFixed(4); });
      }
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      renderThumbnails();
      autoSave();
    }
    window.toggleAlignPanel = toggleAlignPanel;
    window.alignEls = alignEls;

    /* ═══════════════════════════════════════════════════
       POSITION / SIZE PANEL
    ═══════════════════════════════════════════════════ */
    function updatePosPanel() {
      /* Keep legacy pos-panel hidden — values now live in the unified toolbar */
      var panel = document.getElementById('pos-panel');
      if (panel) panel.style.display = 'none';
      if (!editorMode || !selectedElId) return;
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (!el) return;
      var tw = document.getElementById('tt-w');
      var th = document.getElementById('tt-h');
      var top = document.getElementById('tt-op');
      if (tw) tw.value = Math.round(el.w || 0);
      if (th) th.value = Math.round(el.h || 0);
      var op = Math.round(((el.style && el.style.opacity !== undefined) ? el.style.opacity : 1) * 100);
      if (top) top.value = op;
    }
    function setPosVal(prop, val) {
      if (!selectedElId) return;
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (!el) return;
      val = parseFloat(val);
      if (isNaN(val)) return;
      if (prop === 'opacity') {
        if (!el.style) el.style = {};
        el.style.opacity = Math.max(0, Math.min(1, val));
      } else {
        el[prop] = val;
      }
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      /* re-select */
      selectedElId = el.id;
      var domEl = document.querySelector('[data-ei="'+el.id+'"]');
      if (domEl) { domEl.classList.add('sel-el'); }
      renderThumbnails();
      scheduleSave();
    }
    window.setPosVal = setPosVal;

    /* ─── Toast helper ─── */
    function showToast(msg) {
      var t = document.createElement('div');
      t.textContent = msg;
      t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:8px 18px;border-radius:20px;font-size:12px;font-weight:600;z-index:99999;opacity:0;transition:opacity .25s;pointer-events:none;';
      document.body.appendChild(t);
      setTimeout(function(){ t.style.opacity='1'; }, 10);
      setTimeout(function(){ t.style.opacity='0'; setTimeout(function(){ t.remove(); }, 300); }, 1800);
    }

    /* ═══════════════════════════════════════════════════
       ICON PICKER
    ═══════════════════════════════════════════════════ */
    var _iconPickerMode = 'insert'; // 'insert' | 'change'
    var _iconPickerElId = null;

    function buildIconGrid(filter) {
      var grid = document.getElementById('icon-grid');
      if (!grid) return;
      /* Merge regular + brand icon names */
      var brandNames = Object.keys(BRAND_ICONS).map(function(k){ return k.replace('_brand',''); });
      var allNames = Object.keys(ICONS).concat(brandNames.filter(function(n){ return !ICONS[n]; }));
      var names = allNames;
      if (filter) {
        filter = filter.toLowerCase();
        names = names.filter(function(n){ return n.indexOf(filter) !== -1; });
      }
      var html = '';
      var t = deck.theme || {};
      var accent = t.accent || '#1e3a5f';
      names.forEach(function(name) {
        var isBrand = !!(BRAND_ICONS[name+'_brand'] || BRAND_ICONS[name]);
        var svgInner = isBrand
          ? '<svg viewBox="0 0 24 24" width="20" height="20" fill="#94a3b8"><path d="'+(BRAND_ICONS[name+'_brand']||BRAND_ICONS[name])+'"/></svg>'
          : '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="'+(ICONS[name]||ICONS['star'])+'"/></svg>';
        html += '<button onclick="pickIcon(\''+name+'\')" title="'+name+'" '+
          'style="background:#0f172a;border:1px solid #1e293b;border-radius:8px;padding:5px;cursor:pointer;display:flex;align-items:center;justify-content:center;aspect-ratio:1;transition:background .1s;" '+
          'onmouseover="this.style.background=\'#334155\';this.style.borderColor=\''+accent+'\'" onmouseout="this.style.background=\'#0f172a\';this.style.borderColor=\'#1e293b\'">' +
          svgInner + '</button>';
      });
      grid.innerHTML = html || '<div style="color:#475569;font-size:11px;padding:10px;text-align:center;">Không tìm thấy</div>';
    }

    function filterIcons(val) { buildIconGrid(val); }

    function openIconPicker(mode, elId) {
      _iconPickerMode = mode || 'insert';
      _iconPickerElId = elId || null;
      var hint = document.getElementById('icon-picker-hint');
      if (hint) hint.textContent = mode === 'change' ? 'Click icon để thay đổi' : 'Click icon để chèn vào slide';
      document.getElementById('icon-search').value = '';
      buildIconGrid('');
      var panel = document.getElementById('icon-picker');
      panel.style.display = 'block';
      panel.style.right = '';
      panel.style.transform = '';
      var panelW = 320, panelH = 380;
      var vw = window.innerWidth, vh = window.innerHeight;
      var left, top;
      /* When changing icon via toolbar, anchor near the toolbar button */
      var toolbarBtn = mode === 'change' && document.getElementById('tt-icon-edit');
      if (toolbarBtn) {
        var r = toolbarBtn.getBoundingClientRect();
        left = r.left;
        top  = r.bottom + 8;
        if (left + panelW > vw - 8) left = Math.max(8, vw - panelW - 8);
        if (top + panelH > vh - 8)  top  = Math.max(8, r.top - panelH - 8);
      } else {
        left = vw - panelW - 20;
        top = Math.round((vh - panelH) / 2);
      }
      panel.style.left = left + 'px';
      panel.style.top  = top  + 'px';
    }

    function closeIconPicker() {
      var panel = document.getElementById('icon-picker');
      if (panel) panel.style.display = 'none';
      _iconPickerElId = null;
    }

    function pickIcon(name) {
      if (_iconPickerMode === 'change' && _iconPickerElId) {
        /* Change existing icon element */
        var sl = slides[current];
        if (!sl) { closeIconPicker(); return; }
        var elData = (sl.elements||[]).find(function(e){ return e.id === _iconPickerElId; });
        if (elData) {
          saveHistorySnapshot();
          elData.icon = name;
          var stage = document.getElementById('slide-stage');
          if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
          if (editorMode) attachEditorHandlers();
          renderThumbnails();
          autoSave();
        }
      } else {
        /* Insert new icon element */
        saveHistorySnapshot();
        var sl = slides[current];
        if (!sl) { closeIconPicker(); return; }
        var uid = 'el_' + Date.now();
        var t = deck.theme || {};
        var accent = t.accent || '#1e3a5f';
        var el = { id: uid, type: 'icon', x: 4.5, y: 2.0, w: 1.0, h: 1.0, z: 10,
                   icon: name,
                   style: { fill: '#fff', bgColor: accent, borderRadius: '50%' } };
        if (!sl.elements) sl.elements = [];
        sl.elements.push(el);
        if (!editorMode) { editorMode = true; var _st = document.getElementById('slide-stage'); if (_st) _st.classList.add('editor-mode'); }
        var stage = document.getElementById('slide-stage');
        if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
        if (editorMode) attachEditorHandlers();
        /* auto-select new icon */
        var newDom = stage && stage.querySelector('[data-ei="'+uid+'"]');
        if (newDom) { clearSelection(); newDom.classList.add('sel-el'); newDom.style.outlineColor = '#1e3a5f'; selectedElId = uid; selectedElIds = [uid]; addResizeHandles(newDom); showBgOnlyToolbar(newDom); }
        renderThumbnails();
        autoSave();
      }
      closeIconPicker();
    }

    window.openIconPicker = openIconPicker;
    window.closeIconPicker = closeIconPicker;
    window.filterIcons = filterIcons;
    window.pickIcon = pickIcon;

    /* Close icon picker on outside click */
    document.addEventListener('click', function(e) {
      var p = document.getElementById('icon-picker');
      if (p && p.style.display !== 'none' && !p.contains(e.target)) {
        /* allow clicks on the insert panel or toolbar (which opens the picker) */
        var ip = document.getElementById('insert-panel');
        if (ip && ip.contains(e.target)) return;
        if (e.target.closest('#txt-toolbar')) return;
        closeIconPicker();
      }
    });

    /* Close insert panel on outside click */
    document.addEventListener('click', function(e) {
      var p = document.getElementById('insert-panel');
      if (p && p.style.display !== 'none') {
        var btn = p.previousElementSibling;
        if (!p.contains(e.target) && btn && !btn.contains(e.target)) {
          p.style.display = 'none';
        }
      }
    });

    /* ── Draggable panels ──────────────────────────────────────────────── */
    function makeDraggable(panelId, handleId) {
      var panel = document.getElementById(panelId);
      var handle = document.getElementById(handleId);
      if (!panel || !handle) return;
      var ox = 0, oy = 0, px = 0, py = 0;
      handle.addEventListener('mousedown', function(e) {
        if (e.button !== 0) return;
        e.preventDefault();
        e.stopPropagation();
        var r = panel.getBoundingClientRect();
        px = r.left; py = r.top;
        ox = e.clientX; oy = e.clientY;
        handle.style.cursor = 'grabbing';
        function onMove(ev) {
          var dx = ev.clientX - ox, dy = ev.clientY - oy;
          var newL = Math.max(0, Math.min(window.innerWidth  - r.width,  px + dx));
          var newT = Math.max(0, Math.min(window.innerHeight - r.height, py + dy));
          panel.style.left = newL + 'px';
          panel.style.top  = newT + 'px';
          panel.style.right = '';
          panel.style.transform = '';
        }
        function onUp() {
          handle.style.cursor = 'grab';
          document.removeEventListener('mousemove', onMove);
          document.removeEventListener('mouseup', onUp);
        }
        document.addEventListener('mousemove', onMove);
        document.addEventListener('mouseup', onUp);
      });
    }
    makeDraggable('txt-toolbar',    'txt-toolbar-handle');
    makeDraggable('icon-picker',    'icon-picker-header');
    makeDraggable('chart-editor',   'chart-editor-header');
    makeDraggable('table-editor',   'table-editor-header');

    saveHistorySnapshot();
    goToSlide(current); /* current already set from URL hash #sN */

    /* ResizeObserver on the column: fires whenever its width changes
       (sidebar toggle, window resize) — no timing guesswork */
    var _viewerCol = document.getElementById('slide-viewer-col');
    if (_viewerCol && window.ResizeObserver) {
      new ResizeObserver(function(){ rescaleCanvas(); }).observe(_viewerCol);
    }
    window.addEventListener('resize', rescaleCanvas);

  })();
  </script>


<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nội dung được tạo bởi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='Đã sao chép!'; setTimeout(()=>this.textContent='Sao chép',2000)})"
              class="text-[12px] text-slate-500 hover:text-white px-3 py-1 bg-slate-50 hover:bg-[#1e3a5f] rounded-lg transition-colors border-0 cursor-pointer">
        Sao chép
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>

<script>
function handleRegenerate() {
  var btn = document.getElementById('regenerate-btn');
  if (btn.disabled) return;
  btn.disabled = true;
  btn.style.opacity = '0.5';

  // Show overlay immediately
  var overlay = document.createElement('div');
  overlay.id = 'ai-gen-overlay';
  overlay.style.cssText = 'display:flex;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;background:rgba(15,23,42,0.65);backdrop-filter:blur(4px);';
  overlay.innerHTML = '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.22);max-width:320px;width:90%;"><div id="ai-gen-ring-container"></div><p style="font-size:11px;color:#94A3B8;margin:12px 0 0;">Đừng tắt trang này.</p></div>';
  document.body.appendChild(overlay);

  var phases = ["AI đang tạo <%= @outline.output_type == 'slide' ? 'slide' : 'nội dung' %>...","Đang phân tích...","Đang tạo nội dung...","Đang hoàn thiện..."];
  buildGenRing(phases);

  // Fire AJAX
  var token = document.querySelector('meta[name="csrf-token"]').content;
  var pollUrl = '<%= status_content_outline_path(@outline, format: :json) %>';
  fetch('<%= regenerate_content_outline_path(@outline) %>', {
    method: 'POST',
    headers: { 'Accept': 'application/json', 'X-CSRF-Token': token, 'X-Requested-With': 'XMLHttpRequest' }
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      startGenPolling(data.poll_url || pollUrl);
    })
    .catch(function() { startGenPolling(pollUrl); });
}

function buildGenRing(phases) {
  var totalPhases = phases.length;
  var phase = 0, pct = 0;
  document.getElementById('ai-gen-ring-container').innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
      '<span id="ai-gen-pct" style="font-size:13px;font-weight:800;color:#1e3a5f;letter-spacing:-0.3px;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#d9e5f1" stroke-width="6"/>',
          '<circle id="ai-gen-arc" cx="44" cy="44" r="38" stroke="#1e3a5f" stroke-width="6" stroke-linecap="round" stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
          '<svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="36" height="36" rx="9" fill="#1A6BFF"/><polygon points="10,24 6,31 16,24" fill="white"/><rect x="6" y="6" width="24" height="19" rx="5" fill="white"/><rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/><rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/><rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/></svg>',
        '</div>',
      '</div>',
      '<p id="ai-gen-phase" style="font-size:12px;font-weight:600;color:#1e3a5f;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');
  var ring = document.getElementById('ai-gen-arc');
  var pctEl = document.getElementById('ai-gen-pct');
  var phEl = document.getElementById('ai-gen-phase');
  var milestones = phases.map(function(_,i){return Math.round(((i+1)/totalPhases)*85);});
  var timer = setInterval(function(){
    var target = milestones[phase]||85;
    pct = Math.min(pct+1, target);
    ring.style.strokeDashoffset = 238.8*(1-pct/100);
    pctEl.textContent = Math.round(pct)+'%';
    if(pct>=(milestones[phase]||85) && phase<totalPhases-1){phase++;phEl.textContent=phases[phase];}
    if(pct>=85 && phase>=totalPhases-1){clearInterval(timer);timer=setInterval(function(){if(pct>=98){clearInterval(timer);return;}pct=Math.min(pct+0.4,98);ring.style.strokeDashoffset=238.8*(1-pct/100);pctEl.textContent=Math.round(pct)+'%';},3000);}
  },300);
}

function startGenPolling(pollUrl) {
  function poll() {
    fetch(pollUrl, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r){return r.json();})
      .then(function(data){
        if(data.failed){
          document.getElementById('ai-gen-overlay').innerHTML =
            '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;max-width:320px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.22);">'+
            '<div style="font-size:2rem;margin-bottom:12px;">⚠️</div>'+
            '<p style="font-size:14px;color:#ef4444;margin:0 0 16px;">Có lỗi xảy ra. Vui lòng thử lại.</p>'+
            '<button onclick="location.reload()" style="padding:8px 20px;background:#1e3a5f;color:#fff;border:0;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Tải lại</button></div>';
        } else if(data.pending) { setTimeout(poll,2500); }
        else { location.reload(); }
      })
      .catch(function(){setTimeout(poll,3000);});
  }
  setTimeout(poll,1500);
}
</script>
<style>@keyframes vox-pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(0.88);opacity:0.75;}}</style>
