            <input id="ce-center-sub" type="text" placeholder="Nhãn phụ (vd: CO2 tương đương)" style="width:100%;box-sizing:border-box;background:#0f172a;border:1px solid #334155;border-radius:7px;color:#fff;font-size:12px;padding:6px 8px;outline:none;">
          </div>
