    var slides = deck.slides || [];
    var theme  = deck.theme  || {};
    var _hashSlide = parseInt((location.hash || '').replace('#s', '')) || 0;
    var current = Math.max(0, Math.min(_hashSlide, (slides.length || 1) - 1));
    var total = slides.length;
    var editorMode = false;  /* wysiwyg mode flag */
    var selectedElId = null;
