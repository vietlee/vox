                    onblur="this.style.borderColor='#e2e8f0';this.style.background='#fafafa';"></textarea>

          <!-- File attachment -->
          <div>
            <label style="display:inline-flex; align-items:center; gap:6px; cursor:pointer; font-size:12px; color:#64748b; padding:6px 10px; border:1px dashed #cbd5e1; border-radius:8px; background:#f8fafc; transition:all .15s;"
