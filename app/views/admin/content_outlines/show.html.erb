          var rAnchor = r + strokeW/2 + 22;
          var x1 = cx + rOuter * Math.cos(midAngle);
          var y1 = cy + rOuter * Math.sin(midAngle);
          var x2 = cx + rLabel * Math.cos(midAngle);
          var y2 = cy + rLabel * Math.sin(midAngle);
          var xa = cx + rAnchor * Math.cos(midAngle);
          var ya = cy + rAnchor * Math.sin(midAngle);
          var anchor = Math.cos(midAngle) > 0.1 ? 'start' : Math.cos(midAngle) < -0.1 ? 'end' : 'middle';
          var pctStr = Math.round(pct*1000)/10 + '%';
          var fs = Math.max(9, Math.round(sz * 0.052));
          pctLabels += '<line x1="'+x1.toFixed(1)+'" y1="'+y1.toFixed(1)+'" x2="'+x2.toFixed(1)+'" y2="'+y2.toFixed(1)+'" stroke="'+c+'" stroke-width="1.2"/>';
          pctLabels += '<text x="'+xa.toFixed(1)+'" y="'+(ya+fs*0.36).toFixed(1)+'" text-anchor="'+anchor+'" font-size="'+fs+'" font-weight="700" fill="'+c+'" font-family="Inter,sans-serif">'+pctStr+'</text>';
        }
        offset += pct;
      });
      var fs_main = Math.round(sz * 0.09);
      var fs_sub = Math.round(sz * 0.052);
      var svgPart = '<svg viewBox="0 0 '+sz+' '+sz+'" width="'+sz+'px" height="'+sz+'px" style="flex-shrink:0;overflow:visible;" preserveAspectRatio="xMidYMid meet">'+
        '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="#E2E8F0" stroke-width="'+strokeW+'"/>'+
        slices + pctLabels +
        (center_text?'<text x="'+cx+'" y="'+(cy - fs_sub*0.4)+'" text-anchor="middle" font-size="'+fs_main+'" font-weight="900" fill="#1F2A44" font-family="Nunito,sans-serif">'+escHtml(center_text)+'</text>':'')+
        (center_sub?'<text x="'+cx+'" y="'+(cy + fs_main*0.75)+'" text-anchor="middle" font-size="'+fs_sub+'" fill="#94A3B8" font-family="Inter,sans-serif">'+escHtml(center_sub)+'</text>':'')+
        '</svg>';
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+w+'px;height:'+h+'px;z-index:'+z+';display:flex;align-items:center;justify-content:center;">'+svgPart+'</div>';
    }

    function escHtml(str) {
      return String(str)
        .replace(/\s*\[icon=[a-z_]+\]/gi, '')  /* strip leftover [icon=xxx] placeholders */
        .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ─── Render slide ─── */
    function renderSlide(idx) {
      var s = slides[idx];
      if (!s) return '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#94A3B8;">Không có slide</div>';
      var bg = s.background || { type:'solid', color:'#ffffff' };
      var bgCss = bg.type === 'gradient' ?
        'background:' + bg.value + ';' :
        'background:' + (bg.color||'#fff') + ';';
      var els = (s.elements || []).sort(function(a,b){return (a.z||2)-(b.z||2);});
      var content = els.map(function(e){ return renderEl(e, idx); }).join('');
      return '<div style="position:absolute;inset:0;' + bgCss + '">' + content + '</div>';
    }

    /* ─── Canvas scale ─── */
    var _inFullscreen = false;
    function rescaleCanvas() {
      if (_inFullscreen) return;
      var viewer = document.getElementById('slide-viewer');
      var stage  = document.getElementById('slide-stage');
      if (!viewer || !stage) return;
      var wrap = document.getElementById('slide-wrap');
      if (!wrap) return;
      /* Width-based scaling like PowerPoint — fill editor width, scroll vertically if needed */
      var viewerCol = document.getElementById('slide-viewer-col');
      var vw = viewerCol ? viewerCol.clientWidth : (wrap.clientWidth || 0);
      if (!vw) return;
      var scale   = vw / 1280;
      var scaledH = Math.round(720 * scale);
      wrap.style.paddingBottom = '0';
      wrap.style.width  = '100%';
      wrap.style.height = scaledH + 'px';
      wrap.style.margin = '0';
      stage.style.transformOrigin = 'top left';
      stage.style.transform = 'scale(' + scale + ')';
      stage.style.position  = 'absolute';
      stage.style.left = '0';
      stage.style.top  = '0';
      stage.style.margin = '0';
    }

    /* ─── Navigation ─── */
    function commitActiveTextEdit() {
      var active = document.querySelector('span[contenteditable="true"]');
      if (active) active.blur();
    }
    function goToSlide(idx) {
      commitActiveTextEdit();
      current = Math.max(0, Math.min(idx, total - 1));
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      updateDots();
      updateCounter();
      rescaleCanvas();
      if (editorMode) { attachEditorHandlers(); syncBgPicker(); }
      /* persist slide index in URL hash so refresh restores position */
      window.history.replaceState(null, '', location.pathname + location.search + '#s' + current);
      /* sync wrapper + viewer bg to slide bg → no visible gap at any edge */
      var sl = slides[current];
      var slBg = sl && sl.background;
      var bgVal = slBg ? (slBg.type === 'gradient' ? slBg.value : (slBg.color || '#fff')) : '#fff';
      var slideWrap = document.getElementById('slide-wrap');
      if (slideWrap) { slideWrap.style.background = '#000'; }
      if (stage) stage.style.background = bgVal;
    }

    function prevSlide() { goToSlide(current - 1); }
    function nextSlide() { goToSlide(current + 1); }

    function updateDots() {
      var dotsEl = document.getElementById('slide-dots');
      if (!dotsEl) return;
      var html = '';
      for (var i = 0; i < total; i++) {
        var active = i === current;
        html += '<button onclick="goToSlide('+i+')" style="width:'+(active?'20':'7')+'px;height:7px;border-radius:99px;border:none;cursor:pointer;transition:all .2s;background:'+(active?_accent():'#cbd5e1')+'"></button>';
      }
      dotsEl.innerHTML = html;
    }

    function updateCounter() {
      var el2 = document.getElementById('slide-counter');
      if (el2) el2.textContent = 'Slide ' + (current + 1) + ' / ' + total;
    }

    /* ─── WYSIWYG Editor ─── */
    function toggleWysiwyg() {
      editorMode = !editorMode;
      var btn = document.getElementById('wysiwyg-btn');
      var bar = document.getElementById('wysiwyg-bar');
      var stage = document.getElementById('slide-stage');
      if (stage) stage.classList.toggle('editor-mode', editorMode);
      if (btn) {
        btn.style.background = editorMode ? '#d9e5f1' : '';
        btn.style.color = editorMode ? '#6d28d9' : '';
        btn.style.fontWeight = editorMode ? '700' : '';
      }
      if (bar) bar.style.display = editorMode ? 'flex' : 'none';
      if (editorMode) syncBgPicker();
      if (stage) {
        stage.style.cursor = editorMode ? 'default' : 'default';
        if (editorMode) attachEditorHandlers();
        else {
          clearSelection();
          /* strip all editor inline styles left on elements */
          stage.querySelectorAll('.slide-el').forEach(function(el) {
            el.style.outline = '';
            el.style.outlineColor = '';
            el.style.cursor = '';
            el.onmouseenter = null;
            el.onmouseleave = null;
          });
        }
      }
    }

    function toggleAiPanel() {
      var panel = document.getElementById('slide-editor-panel');
      if (!panel) return;
      var isOpen = panel.style.display !== 'none';
      panel.style.display = isOpen ? 'none' : 'flex';
      var btn = document.getElementById('ai-panel-btn');
      if (btn) {
        btn.style.background = isOpen ? '' : '#eef2ff';
        btn.style.color = isOpen ? '' : '#162c47';
      }
    }

    /* keep toggleEditor as alias for AI panel (used by old inline onclick) */
    function toggleEditor() { toggleAiPanel(); }

    /* ─── AI edit submit ─── */
    function submitAiEdit() {
      var prompt = (document.getElementById('ai-edit-input').value || '').trim();
      if (!prompt) { document.getElementById('ai-edit-input').focus(); return; }
      var btn = document.getElementById('ai-edit-btn');
      var body = document.getElementById('ai-edit-body');
      var loading = document.getElementById('ai-edit-loading');
      btn.disabled = true;
      if (body) body.style.display = 'none';
      if (loading) loading.style.display = 'block';
      var formData = new FormData();
      formData.append('edit_prompt', prompt);
      formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);
      _getEditFiles().forEach(function(f){ formData.append('images[]', f); });
      fetch('<%= ai_edit_content_outline_path(@outline) %>', {
        method: 'POST', headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }, body: formData
      }).then(function(r){ return r.json(); })
        .then(function(data) {
          if (data.error) { showAiEditError(data.error); return; }
          if (data.pending) pollAiEditStatus('<%= status_content_outline_path(@outline, format: :json) %>');
        })
        .catch(function(e){ showAiEditError(e.message); });
    }

    function pollAiEditStatus(url) {
      fetch(url, { headers: { 'Accept': 'application/json' } })
        .then(function(r){ return r.json(); })
        .then(function(data) {
          if (data.failed) { showAiEditError('AI gặp lỗi khi chỉnh sửa. Vui lòng thử lại.'); return; }
          if (data.pending) { setTimeout(function(){ pollAiEditStatus(url); }, 2500); return; }
          // Done — update slides in-place without closing the panel
          if (data.deck_json) {
            try {
              var newDeck = JSON.parse(data.deck_json);
              deck = newDeck;
              slides = deck.slides || [];
              applyThemeAccent();
              var stage = document.getElementById('slide-stage');
              if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
              renderThumbnails();
              saveHistorySnapshot();
              _editFileList = [];
              _renderEditPreviews();
              var body = document.getElementById('ai-edit-body');
              var loading = document.getElementById('ai-edit-loading');
              var btn = document.getElementById('ai-edit-btn');
              if (loading) loading.style.display = 'none';
              if (body) body.style.display = 'flex';
              if (btn) btn.disabled = false;
              var promptEl = document.getElementById('ai-edit-prompt');
              if (promptEl) promptEl.value = '';
              showToast('✨ AI đã chỉnh sửa xong!');
            } catch(e) { window.location.reload(); }
          } else {
            window.location.reload();
          }
        })
        .catch(function(){ setTimeout(function(){ pollAiEditStatus(url); }, 3000); });
    }

    function showAiEditError(msg) {
      var btn = document.getElementById('ai-edit-btn');
      var body = document.getElementById('ai-edit-body');
      var loading = document.getElementById('ai-edit-loading');
      if (btn) btn.disabled = false;
      if (body) body.style.display = 'flex';
      if (loading) loading.style.display = 'none';
      alert(msg);
    }

    var _editFileList = [];

    function previewEditFiles(input) {
      Array.from(input.files).forEach(function(f) { _editFileList.push(f); });
      input.value = '';
      _renderEditPreviews();
    }

    function _renderEditPreviews() {
      var wrap = document.getElementById('ai-edit-previews');
      if (!wrap) return;
      wrap.innerHTML = '';
      _editFileList.forEach(function(f, i) {
        var url = URL.createObjectURL(f);
        var outer = document.createElement('div');
        outer.style.cssText = 'position:relative;display:inline-block;';
        var img = document.createElement('img');
        img.src = url;
        img.style.cssText = 'width:56px;height:56px;object-fit:contain;border-radius:6px;border:1px solid #e2e8f0;display:block;background:#f8fafc;';
        var btn = document.createElement('button');
        btn.textContent = '✕';
        btn.title = 'Xóa ảnh';
        btn.style.cssText = 'position:absolute;top:-5px;right:-5px;width:16px;height:16px;border-radius:50%;background:#ef4444;color:#fff;border:none;cursor:pointer;font-size:9px;line-height:16px;padding:0;display:flex;align-items:center;justify-content:center;';
        btn.onclick = (function(idx){ return function(e){ e.preventDefault(); _editFileList.splice(idx,1); _renderEditPreviews(); }; })(i);
        outer.appendChild(img);
        outer.appendChild(btn);
        wrap.appendChild(outer);
      });
    }

    function _getEditFiles() { return _editFileList; }
    window.submitAiEdit = submitAiEdit;
    window.previewEditFiles = previewEditFiles;

    /* ─── Marquee (rubber-band) selection ─── */
    var _marquee = null;

    function _stageScale() {
      var stage = document.getElementById('slide-stage');
      if (!stage) return 1;
      var sr = stage.getBoundingClientRect();
      /* sr.width is visual (post-transform). stage logical width is always 1280. */
      return sr.width / 1280;
    }

    function _clientToStage(clientX, clientY) {
      var stage = document.getElementById('slide-stage');
      if (!stage) return {x:0,y:0};
      var sr = stage.getBoundingClientRect();
      var sc = sr.width / 1280;
      return { x: (clientX - sr.left) / sc, y: (clientY - sr.top) / sc };
    }

    function _startMarquee(e) {
      if (!editorMode) return;
      if (e.button !== 0) return;
      if (e.target.closest('.slide-el') || e.target.closest('.sel-handle')) return;
      var pt = _clientToStage(e.clientX, e.clientY);
      /* Marquee box lives in stage-space (1280×720 coords) */
      var box = document.createElement('div');
      box.id = 'marquee-box';
      box.style.cssText = 'position:absolute;border:1.5px dashed #1e3a5f;background:rgba(99,102,241,.07);pointer-events:none;z-index:9999;box-sizing:border-box;';
      box.style.left = pt.x + 'px'; box.style.top = pt.y + 'px';
      box.style.width = '0'; box.style.height = '0';
      _marquee = { x0: pt.x, y0: pt.y, box: box, started: false };
      document.addEventListener('mousemove', _onMarqueeMove, { passive: true });
      document.addEventListener('mouseup',   _onMarqueeEnd);
      e.preventDefault();
    }

    function _onMarqueeMove(e) {
      if (!_marquee) return;
      var pt = _clientToStage(e.clientX, e.clientY);
      var x0 = _marquee.x0, y0 = _marquee.y0;
      var left = Math.min(x0, pt.x), top = Math.min(y0, pt.y);
      var mw   = Math.abs(pt.x - x0),  mh = Math.abs(pt.y - y0);
      if (!_marquee.started) {
        if (mw < 5 && mh < 5) return;
        _marquee.started = true;
        clearSelection();
        var stage = document.getElementById('slide-stage');
        if (stage) stage.appendChild(_marquee.box);
      }
      _marquee.box.style.left   = left + 'px';
      _marquee.box.style.top    = top  + 'px';
      _marquee.box.style.width  = mw   + 'px';
      _marquee.box.style.height = mh   + 'px';
      /* Highlight elements whose bounding box overlaps the marquee */
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      var mr = { l: left, t: top, r: left + mw, b: top + mh };
      stage.querySelectorAll('.slide-el').forEach(function(el) {
        var el_l = parseFloat(el.style.left)  || 0;
        var el_t = parseFloat(el.style.top)   || 0;
        var el_w = parseFloat(el.style.width) || 0;
        var el_h = parseFloat(el.style.height)|| 0;
        var hit = el_w > 0 && el_h > 0 &&
                  el_l < mr.r && el_l + el_w > mr.l &&
                  el_t < mr.b && el_t + el_h > mr.t;
        el.style.outlineColor = hit ? _accentDk() : 'transparent';
        el.classList.toggle('sel-el', hit);
      });
    }

    function _onMarqueeEnd(e) {
      document.removeEventListener('mousemove', _onMarqueeMove);
      document.removeEventListener('mouseup',   _onMarqueeEnd);
      if (!_marquee) return;
      var started = _marquee.started;
      if (_marquee.box.parentNode) _marquee.box.remove();
      _marquee = null;
      if (!started) { clearSelection(); return; }
      /* Collect elements that are still highlighted */
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      var hit = [];
      stage.querySelectorAll('.sel-el').forEach(function(el) {
        if (el.dataset.ei) hit.push(el.dataset.ei);
      });
      document.querySelectorAll('.sel-handle').forEach(function(h){ h.remove(); });
      if (!hit.length) { clearSelection(); return; }
      selectedElIds = hit; selectedElId = hit[hit.length - 1];
      hit.forEach(function(id) {
        var dom = stage.querySelector('[data-ei="'+id+'"]');
        if (dom) { dom.classList.add('sel-el'); dom.style.outlineColor = '#1e3a5f'; }
      });
      if (hit.length === 1) {
        var dom = stage.querySelector('[data-ei="'+hit[0]+'"]');
        if (dom) { addResizeHandles(dom); showBgOnlyToolbar(dom); }
      }
      /* One-time capture listener to swallow the click that follows mouseup */
      stage.addEventListener('click', function swallow(ev) {
        ev.stopImmediatePropagation();
        stage.removeEventListener('click', swallow, true);
      }, { capture: true, once: true });
    }

    function attachEditorHandlers() {
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      stage.removeEventListener('mousedown', _startMarquee);
      stage.addEventListener('mousedown', _startMarquee);
      /* Click on empty slide area → deselect */
      stage.onclick = function(e) {
        if (!editorMode) return;
        if (!e.target.closest('.slide-el') && !e.target.closest('.sel-handle')) {
          clearSelection();
        }
      };
      stage.querySelectorAll('.slide-el').forEach(function(domEl) {
        domEl.style.cursor = 'move';
        domEl.style.outline = '1px dashed transparent';
        domEl.style.transition = 'outline-color .1s';
        domEl.onmouseenter = function() {
          if (editorMode && domEl !== document.querySelector('.sel-el'))
            domEl.style.outlineColor = 'rgba(99,102,241,.4)';
        };
        domEl.onmouseleave = function() {
          if (!domEl.classList.contains('sel-el'))
            domEl.style.outlineColor = 'transparent';
        };
        /* remove old listeners before re-adding */
        domEl.removeEventListener('mousedown', startMove);
        domEl.removeEventListener('dblclick', startTextEdit);
        domEl.removeEventListener('dblclick', startChartEdit);
        domEl.removeEventListener('dblclick', startIconEdit);
        domEl.removeEventListener('dblclick', startVideoEdit);
        domEl.removeEventListener('dblclick', startTableEdit);
        domEl.removeEventListener('dblclick', startProgressEdit);
        domEl.addEventListener('mousedown', startMove);
        var domElId = domEl.getAttribute('data-ei');
        var sl = slides[current];
        var domElData = sl ? (sl.elements||[]).find(function(e){return e.id===domElId;}) : null;
        var elType = domElData ? domElData.type : '';
        if (elType === 'chart_donut' || elType === 'chart_bar' || elType === 'chart_line') {
          domEl.addEventListener('dblclick', startChartEdit);
        } else if (elType === 'icon') {
          domEl.addEventListener('dblclick', startIconEdit);
        } else if (elType === 'video') {
          domEl.addEventListener('dblclick', startVideoEdit);
        } else if (elType === 'table') {
          /* table editing via toolbar */
        } else if (elType === 'progress') {
          domEl.addEventListener('dblclick', startProgressEdit);
        } else {
          domEl.addEventListener('dblclick', startTextEdit);
        }
      });
    }

    function clearSelection() {
      /* Commit + clear any active text caret */
      var activeSpan = document.querySelector('span[contenteditable="true"]');
      if (activeSpan) {
        activeSpan.contentEditable = 'false';
        var sel = window.getSelection(); if (sel) sel.removeAllRanges();
      }
      selectedElId = null;
      selectedElIds = [];
      document.querySelectorAll('.sel-el').forEach(function(e){ e.classList.remove('sel-el'); e.style.outlineColor = 'transparent'; });
      document.querySelectorAll('.sel-handle').forEach(function(e){ e.remove(); });
      hideTextToolbar();
      hideElBgBar();
      var ce = document.getElementById('chart-editor');
      if (ce) ce.style.display = 'none';
      var pp = document.getElementById('pos-panel');
      if (pp) pp.style.display = 'none';
    }

    var _dragState = null;
    function startMove(e) {
      if (!editorMode) return;
      /* Commit any active text edit before switching element */
      var activeSpan = document.querySelector('span[contenteditable="true"]');
      if (activeSpan) {
        activeSpan.contentEditable = 'false';
        var sel = window.getSelection(); if (sel) sel.removeAllRanges();
      }
      e.preventDefault();
      var domEl = e.currentTarget;
      var ei = domEl.dataset.ei;

      /* Ctrl/Cmd+click → toggle this element in multi-selection */
      if (e.ctrlKey || e.metaKey) {
        if (selectedElIds.indexOf(ei) >= 0) {
          selectedElIds = selectedElIds.filter(function(id){ return id !== ei; });
          domEl.classList.remove('sel-el');
        } else {
          selectedElIds.push(ei);
          if (selectedElId && selectedElIds.indexOf(selectedElId) < 0) selectedElIds.push(selectedElId);
          domEl.classList.add('sel-el');
          domEl.style.outlineColor = _accentDk();
        }
        /* remove resize handles when multi-select */
        document.querySelectorAll('.sel-handle').forEach(function(h){ h.remove(); });
        hideTextToolbar();
        selectedElId = selectedElIds[selectedElIds.length - 1] || null;
        /* start drag for multi */
        if (selectedElIds.length > 0) _startMultiDrag(e);
        return;
      }

      /* If clicking an already-selected element in multi-select → drag the group */
      if (selectedElIds.length > 1 && selectedElIds.indexOf(ei) >= 0) {
        _startMultiDrag(e);
        return;
      }

      /* Regular click → single select */
      clearSelection();
      domEl.classList.add('sel-el');
      domEl.style.outlineColor = _accentDk(); /* override inline transparent set by attachEditorHandlers */
      selectedElId = ei;
      selectedElIds = [ei];
      addResizeHandles(domEl);
      var si2 = parseInt(domEl.dataset.si);
      var elData2 = slides[si2] && slides[si2].elements.find(function(el2){ return el2.id === ei; });
      if (elData2 && elData2.type === 'text') {
        showTextToolbar(domEl);
      } else {
        /* Show toolbar with only the Nền button for non-text elements */
        hideTextToolbar();
        showBgOnlyToolbar(domEl);
      }

      var stage = document.getElementById('slide-stage');
      var rect = stage.getBoundingClientRect();
      var scale = rect.width / 1280;
      _dragState = { domEl:domEl, startX:e.clientX, startY:e.clientY, startL:parseInt(domEl.style.left)||0, startT:parseInt(domEl.style.top)||0, scale:scale, mode:'move' };
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
    }

    function _startMultiDrag(e) {
      var stage = document.getElementById('slide-stage');
      var rect = stage.getBoundingClientRect();
      var scale = rect.width / 1280;
      /* capture initial positions for all selected elements */
      var els = [];
      selectedElIds.forEach(function(id) {
        var dom = stage.querySelector('[data-ei="'+id+'"]');
        if (dom) els.push({ dom:dom, startL:parseInt(dom.style.left)||0, startT:parseInt(dom.style.top)||0 });
      });
      _dragState = { multi:true, els:els, startX:e.clientX, startY:e.clientY, scale:scale, mode:'move' };
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
    }

    function addResizeHandles(domEl) {
      document.querySelectorAll('.sel-handle').forEach(function(e){e.remove();});
      var positions = [
        {cursor:'nw-resize',left:'-4px',top:'-4px',mode:'nw'},
        {cursor:'n-resize', left:'calc(50% - 4px)',top:'-4px',mode:'n'},
        {cursor:'ne-resize',right:'-4px',top:'-4px',mode:'ne'},
        {cursor:'e-resize', right:'-4px',top:'calc(50% - 4px)',mode:'e'},
        {cursor:'se-resize',right:'-4px',bottom:'-4px',mode:'se'},
        {cursor:'s-resize', left:'calc(50% - 4px)',bottom:'-4px',mode:'s'},
