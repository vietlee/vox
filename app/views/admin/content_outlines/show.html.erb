    /* ═══════════════════════════════════════════════════
       SLIDE PANEL – thumbnails, add, delete
    ═══════════════════════════════════════════════════ */

    var _thumbDragSrc = null;

    function renderThumbnails() {
      var list = document.getElementById('slide-thumb-list');
      if (!list) return;
      var scale = (152 / 1280).toFixed(4);
      var thumbH = Math.round(152 * 9/16);
      var html = '';
      for (var i = 0; i < slides.length; i++) {
        var active = i === current;
        html += '<div class="slide-thumb-wrap" data-idx="'+i+'" draggable="true"' +
          ' onclick="goToSlide('+i+')"' +
          ' onmouseover="this.querySelector(\'.thumb-actions\').style.opacity=\'1\'" onmouseout="this.querySelector(\'.thumb-actions\').style.opacity=\'0\'"' +
          ' style="position:relative;cursor:grab;border-radius:8px;overflow:hidden;width:152px;flex-shrink:0;box-shadow:'+(active?'inset 0 0 0 3px #1e3a5f, 0 4px 16px rgba(99,102,241,.35)':'0 1px 4px rgba(0,0,0,.10)')+';background:#fff;transition:box-shadow .15s;margin-bottom:2px;'+(active?'transform:scale(1.03);z-index:2;':'')+'">' +
          '<div style="font-size:9px;font-weight:800;padding:4px 7px;'+(active?'background:#1e3a5f;color:#fff;':'background:#f8fafc;color:#94a3b8;border-bottom:1px solid #e2e8f0;')+'">'+(i+1)+'</div>' +
          '<div style="width:152px;height:'+thumbH+'px;overflow:hidden;position:relative;background:#fff;transform:translateZ(0);">' +
            '<div style="position:absolute;top:0;left:0;width:1280px;height:720px;transform-origin:top left;transform:scale('+scale+');pointer-events:none;">' +
              renderSlide(i) +
            '</div>' +
          '</div>' +
          '<div class="thumb-actions" style="position:absolute;bottom:5px;right:4px;display:flex;flex-direction:row;gap:3px;opacity:0;transition:opacity .15s;z-index:5;">' +
            '<button onclick="event.stopPropagation();duplicateSlide('+i+')" title="Nhân đôi"' +
              ' style="background:rgba(99,102,241,.9);border:none;color:#fff;border-radius:5px;width:20px;height:20px;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.3);line-height:1;">⧉</button>' +
            '<button onclick="event.stopPropagation();askDeleteSlide('+i+')" title="Xoá slide"' +
              ' style="background:rgba(239,68,68,.9);border:none;color:#fff;border-radius:5px;width:20px;height:20px;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.3);">×</button>' +
          '</div>' +
        '</div>';
      }
      list.innerHTML = html;
      /* apply pending images */
      list.querySelectorAll('img[data-pending-src]').forEach(function(img) {
        var src = window._imgSrcMap && window._imgSrcMap[img.id];
        if (src) { img.src = src; img.removeAttribute('data-pending-src'); }
      });
      /* Drag-to-reorder events */
      list.querySelectorAll('.slide-thumb-wrap').forEach(function(wrap) {
        wrap.addEventListener('dragstart', function(e) {
          _thumbDragSrc = parseInt(wrap.getAttribute('data-idx'));
          e.dataTransfer.effectAllowed = 'move';
          wrap.style.opacity = '0.4';
        });
        wrap.addEventListener('dragend', function() {
          wrap.style.opacity = '1';
          list.querySelectorAll('.slide-thumb-wrap').forEach(function(w){ w.style.borderColor = w.getAttribute('data-idx') == current ? '#1e3a5f' : 'transparent'; w.style.boxShadow=''; });
        });
        wrap.addEventListener('dragover', function(e) {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          var overIdx = parseInt(wrap.getAttribute('data-idx'));
          list.querySelectorAll('.slide-thumb-wrap').forEach(function(w){ w.style.boxShadow = ''; });
          if (overIdx !== _thumbDragSrc) wrap.style.boxShadow = '0 0 0 2px #1e3a5f';
        });
        wrap.addEventListener('drop', function(e) {
          e.preventDefault();
          var toIdx = parseInt(wrap.getAttribute('data-idx'));
          if (_thumbDragSrc === null || _thumbDragSrc === toIdx) return;
          saveHistorySnapshot();
          var moved = slides.splice(_thumbDragSrc, 1)[0];
          slides.splice(toIdx, 0, moved);
          deck.slides = slides;
          var newCurrent = toIdx;
          if (_thumbDragSrc === current) newCurrent = toIdx;
          else if (_thumbDragSrc < current && toIdx >= current) newCurrent = current - 1;
          else if (_thumbDragSrc > current && toIdx <= current) newCurrent = current + 1;
          current = Math.max(0, Math.min(newCurrent, slides.length - 1));
          total = slides.length;
          autoSave();
          var stage = document.getElementById('slide-stage');
          if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
          updateDots(); updateCounter();
          renderThumbnails();
        });
      });
    }

    /* Patch goToSlide to also refresh thumbnails */
    var _origGoToSlide = goToSlide;
    goToSlide = function(idx) {
      _origGoToSlide(idx);
      renderThumbnails();
      /* scroll active thumb into view */
      var list = document.getElementById('slide-thumb-list');
      if (list) {
        var active = list.querySelector('[data-idx="'+current+'"]');
        if (active) active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }
    };
    window.goToSlide = goToSlide;

    /* ── Add blank slide ── */
    function addBlankSlide() {
      saveHistorySnapshot();
      var newId = 'slide_' + Date.now();
      var t = deck.theme || {};
      var newSlide = {
        id: newId,
        background: { type: 'solid', color: '#ffffff' },
        elements: [
          { id: newId+'_title', type: 'text', x: 0.6, y: 0.6, w: 8.8, h: 0.9, z: 1,
            content: 'Tiêu đề slide mới',
            style: { fontSize: 40, fontWeight: 700, color: t.primary_dk || '#1e293b', align: 'center', fontFamily: 'Nunito' } },
          { id: newId+'_sub', type: 'text', x: 1.2, y: 1.7, w: 7.6, h: 0.6, z: 1,
            content: 'Nội dung',
            style: { fontSize: 20, fontWeight: 400, color: '#64748b', align: 'center', fontFamily: 'Inter' } }
        ],
        raw: { layout: 'blank', title: 'Slide mới' },
        note: ''
      };
      slides.push(newSlide);
      total = slides.length;
      deck.slides = slides;
      autoSave();
      goToSlide(slides.length - 1);
    }
    window.addBlankSlide = addBlankSlide;

    /* ── Delete slide ── */
    var _pendingDeleteIdx = null;
    function askDeleteSlide(idx) {
      if (slides.length <= 1) { alert('Không thể xoá slide cuối cùng.'); return; }
      _pendingDeleteIdx = idx;
      var modal = document.getElementById('delete-slide-modal');
      var desc = document.getElementById('delete-slide-desc');
      if (desc) desc.textContent = 'Slide ' + (idx + 1) + ' sẽ bị xoá vĩnh viễn.';
      if (modal) modal.style.display = 'flex';
    }
    function cancelDeleteSlide() {
      _pendingDeleteIdx = null;
      var modal = document.getElementById('delete-slide-modal');
      if (modal) modal.style.display = 'none';
    }
    function confirmDeleteSlide() {
      if (_pendingDeleteIdx === null) return;
      saveHistorySnapshot();
      slides.splice(_pendingDeleteIdx, 1);
      total = slides.length;
      deck.slides = slides;
      var modal = document.getElementById('delete-slide-modal');
      if (modal) modal.style.display = 'none';
      autoSave();
      goToSlide(Math.min(_pendingDeleteIdx, slides.length - 1));
      _pendingDeleteIdx = null;
    }
    window.askDeleteSlide = askDeleteSlide;
    window.cancelDeleteSlide = cancelDeleteSlide;
    window.confirmDeleteSlide = confirmDeleteSlide;

    /* ── Insert component ── */
    function toggleInsertPanel() {
      var p = document.getElementById('insert-panel');
      if (p) p.style.display = p.style.display === 'none' ? 'block' : 'none';
