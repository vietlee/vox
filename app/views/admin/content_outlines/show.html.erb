              <button onclick="cancelDeleteSlide()" style="flex:1;background:#f1f5f9;border:none;color:#64748b;border-radius:10px;padding:10px;font-size:13px;font-weight:600;cursor:pointer;">Huỷ</button>
              <button onclick="confirmDeleteSlide()" style="flex:1;background:#ef4444;border:none;color:#fff;border-radius:10px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">Xoá</button>
