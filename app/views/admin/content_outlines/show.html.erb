<% content_for :title, @outline.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate"><%= @outline.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= { "outline" => "📋 Dàn ý", "slide" => "🖥️ Slide", "slide_script" => "🖥️ Slide", "lesson_plan" => "📚 Kế hoạch buổi học" }[@outline.output_type] %></span>
      <% if @outline.subject.present? %><span>· <%= @outline.subject %></span><% end %>
      <span>· <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <% if @outline.pptx_file.attached? %>
      <%= link_to rails_blob_path(@outline.pptx_file, disposition: "attachment"),
          class: "flex items-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Tải PPTX
      <% end %>
    <% end %>
    <button type="button" id="regenerate-btn"
        onclick="handleRegenerate()"
        class="flex items-center gap-1.5 px-3 py-2 bg-violet-50 hover:bg-violet-100 text-violet-700 text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
      Tạo lại (5 credits)
    </button>
  </div>
</div>

<% if @outline.pending? %>
  <%= render "admin/shared/ai_generating_overlay",
        poll_url: status_content_outline_path(@outline, format: :json),
        message: "AI đang tạo #{@outline.output_type == 'slide' ? 'slide' : 'nội dung'}...",
        submessage: "Đừng tắt trang này." %>
<% elsif @outline.failed? %>
  <div class="bg-red-50 border border-red-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">⚠️</div>
    <h3 class="text-[15px] font-bold text-red-700 mb-2">Có lỗi xảy ra khi tạo nội dung</h3>
    <%= button_to regenerate_content_outline_path(@outline), method: :post,
        class: "mt-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer" do %>
      Thử lại
    <% end %>
  </div>
<% elsif @outline.output_type.in?(["slide", "slide_script"]) && @outline.content.include?("slide-deck-root") %>
  <!-- Slide viewer + editor layout -->
  <div id="slide-editor-layout" style="display:flex;gap:16px;align-items:flex-start;">

    <!-- LEFT: slide viewer -->
    <div id="slide-viewer-col" style="flex:1;min-width:0;">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="border-b border-slate-100 px-4 py-2 flex items-center justify-between">
          <div class="flex items-center gap-3 flex-wrap">
            <span class="text-[11px] text-slate-400 font-bold uppercase tracking-widest">🖥️ Slide</span>
            <div id="slide-dots" class="flex gap-1"></div>
          </div>
          <div class="flex items-center gap-2">
            <!-- WYSIWYG drag-edit toggle -->
            <button onclick="toggleWysiwyg()"
                    id="wysiwyg-btn"
                    title="Kéo thả chỉnh sửa trực tiếp trên slide"
                    class="text-[12px] text-slate-600 hover:text-violet-700 px-3 py-1 bg-slate-50 hover:bg-violet-50 rounded-lg transition-colors border-0 cursor-pointer font-medium">
              ✏️ Sửa trực tiếp
            </button>
            <!-- AI edit panel toggle -->
            <button onclick="toggleAiPanel()"
                    id="ai-panel-btn"
                    class="text-[12px] text-indigo-600 hover:text-indigo-700 px-3 py-1 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition-colors border-0 cursor-pointer font-semibold">
              ✨ Sửa bằng AI
            </button>
            <div style="position:relative;display:inline-block;">
              <button onclick="toggleThemeMenu(this)"
                      id="theme-btn"
                      class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
                🎨 Đổi màu
              </button>
              <div id="theme-menu" style="display:none;position:absolute;right:0;top:calc(100% + 4px);z-index:999;background:#fff;border:1px solid #e2e8f0;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.12);padding:8px;min-width:200px;">
                <div style="font-size:10px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.05em;padding:2px 8px 6px;">Chọn theme màu</div>
                <% [["green","#064E3B","#10B981"],["blue","#1E3A5F","#3B82F6"],["purple","#3B0764","#A855F7"],
                    ["red","#7F1D1D","#EF4444"],["teal","#134E4A","#0D9488"],["amber","#78350F","#F59E0B"],
                    ["slate","#0F172A","#64748B"],["earth","#3B1F0A","#92400E"],["coral","#7F1D1D","#F43F5E"],
                    ["ocean","#0C4A6E","#0369A1"],["berry","#500724","#DB2777"],["midnight","#0F0B2A","#4F46E5"]
                ].each do |name, dark, accent| %>
                  <button onclick="applyTheme('<%= name %>')"
                          style="display:flex;align-items:center;gap:8px;width:100%;padding:6px 8px;border:none;background:none;cursor:pointer;border-radius:8px;text-align:left;"
                          onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='none'">
                    <span style="width:14px;height:14px;border-radius:50%;background:<%= dark %>;flex-shrink:0;"></span>
                    <span style="width:14px;height:14px;border-radius:50%;background:<%= accent %>;flex-shrink:0;margin-left:-8px;border:2px solid #fff;"></span>
                    <span style="font-size:12px;font-weight:500;color:#374151;text-transform:capitalize;margin-left:2px;"><%= name %></span>
                  </button>
                <% end %>
              </div>
            </div>
            <button onclick="enterFullscreen()"
                    class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
              ⛶ Toàn màn hình
            </button>
          </div>
        </div>

        <!-- WYSIWYG mode bar -->
        <div id="wysiwyg-bar" style="display:none;background:#4f46e5;color:#fff;padding:5px 16px;font-size:11px;font-weight:600;display:none;align-items:center;justify-content:space-between;">
          <span>✏️ Chế độ sửa trực tiếp — Kéo để di chuyển · Kéo góc để resize · Double-click để sửa text</span>
          <button onclick="toggleWysiwyg()" style="background:rgba(255,255,255,.2);border:none;color:#fff;padding:2px 10px;border-radius:6px;cursor:pointer;font-size:11px;">Thoát</button>
        </div>
        <div style="position:relative; padding-bottom:56.25%; background:#0f172a; overflow:hidden;">
          <div id="slide-viewer" style="position:absolute; inset:0; overflow:hidden;"></div>
          <!-- image overlay (absolute over slide content) -->
          <div id="slide-image-overlay" style="position:absolute;inset:0;pointer-events:none;overflow:hidden;"></div>
        </div>

        <div class="border-t border-slate-100 px-5 py-2.5 flex items-center justify-between bg-slate-50">
          <button onclick="prevSlide()" style="border:1px solid #e2e8f0;"
                  class="px-4 py-2 bg-white rounded-xl text-[13px] font-semibold text-slate-600 hover:bg-slate-100 transition-colors cursor-pointer shadow-sm">← Trước</button>
          <span id="slide-counter" class="text-[12px] text-slate-500 font-semibold"></span>
          <button onclick="nextSlide()"
                  class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 rounded-xl text-[13px] font-bold text-white transition-colors border-0 cursor-pointer shadow-sm">Tiếp →</button>
        </div>
        <div id="slide-note" class="hidden border-t border-slate-100 px-5 py-3 bg-amber-50">
          <div class="text-[10px] font-bold text-amber-600 uppercase tracking-wide mb-1">💬 Ghi chú người trình bày</div>
          <p id="slide-note-text" class="text-[13px] text-amber-800 leading-relaxed"></p>
        </div>
      </div>
    </div><!-- end slide-viewer-col -->

    <!-- RIGHT: AI edit panel (hidden by default) -->
    <div id="slide-editor-panel" style="display:none; width:360px; flex-shrink:0; position:sticky; top:80px; align-self:flex-start;">
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
        <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
          <div class="text-[13px] font-bold text-slate-700">✨ Chỉnh sửa bằng AI</div>
          <button onclick="toggleAiPanel()"
                  class="px-2 py-1.5 bg-slate-100 hover:bg-slate-200 text-slate-500 text-[12px] rounded-lg border-0 cursor-pointer">✕</button>
        </div>

        <div id="ai-edit-body" class="p-4 space-y-3">
          <p class="text-[12px] text-slate-500 leading-relaxed">
            Mô tả thay đổi bạn muốn. AI sẽ chỉnh sửa nội dung và tạo lại slide.
          </p>

          <textarea id="ai-edit-input" rows="10"
                    placeholder="VD:&#10;• Đổi tiêu đề slide 1&#10;• Thêm slide về đội ngũ&#10;• Bỏ slide cuối&#10;• Thêm ảnh sản phẩm vào slide 3..."
                    class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[13px] focus:border-indigo-400 focus:ring-2 focus:ring-indigo-100 outline-none resize-none"></textarea>

          <!-- File attachment -->
          <div>
            <label class="flex items-center gap-2 cursor-pointer text-[12px] text-slate-500 hover:text-indigo-600 transition-colors">
              <input type="file" id="ai-edit-files" accept="image/*" multiple class="hidden" onchange="previewEditFiles(this)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"/></svg>
              Đính kèm ảnh
            </label>
            <div id="ai-edit-previews" class="flex flex-wrap gap-2 mt-2"></div>
          </div>

          <button onclick="submitAiEdit()" id="ai-edit-btn"
                  class="w-full py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
            ✨ Áp dụng thay đổi
          </button>

          <div id="ai-edit-history" class="space-y-2 pt-2 border-t border-slate-100 hidden">
            <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wide">Lịch sử chỉnh sửa</div>
            <div id="ai-edit-history-list" class="space-y-1"></div>
          </div>
        </div>

        <!-- Loading overlay inside panel -->
        <div id="ai-edit-loading" class="hidden">
          <div class="p-6 flex flex-col items-center justify-center gap-3">
            <div style="width:40px;height:40px;border:3px solid #c7d2fe;border-top-color:#4f46e5;border-radius:50%;animation:aispin 0.8s linear infinite;"></div>
            <div class="text-[13px] font-semibold text-indigo-600">AI đang chỉnh sửa...</div>
            <p class="text-[11px] text-slate-400 text-center">Đang phân tích yêu cầu và tạo lại slide. Quá trình này mất khoảng 30-60 giây.</p>
          </div>
        </div>
      </div>
    </div><!-- end editor panel -->

  </div><!-- end slide-editor-layout -->

  <div id="slide-data" class="hidden"><%= raw @outline.content %></div>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    #slide-viewer { font-family:'Nunito','Inter',sans-serif; }
    #slide-stage { position:absolute; width:1280px; height:720px; overflow:hidden; transform-origin:top left; }
    #slide-stage * { box-sizing:border-box; }
    .sel-el { outline:2px solid #6366f1; outline-offset:1px; cursor:move; }
    .sel-handle { position:absolute; width:8px; height:8px; background:#6366f1; border:2px solid #fff;
                  border-radius:2px; z-index:9999; pointer-events:all; }
    @keyframes aispin { to { transform:rotate(360deg); } }
  </style>

  <script>
  (function() {
    /* ─── Data ─── */
    var el = document.getElementById('slide-data').querySelector('#slide-deck-root');
    var deck;
    try { deck = JSON.parse(el.dataset.deck || '{}'); } catch(e) { deck = {}; }
    var slides = deck.slides || [];
    var theme  = deck.theme  || {};
    var current = 0, total = slides.length;
    var editorMode = false;  /* wysiwyg mode flag */
    var selectedElId = null;
    var history = [], historyIdx = -1;
    var saveTimer = null;
    var SAVE_URL = '<%= update_slides_content_outline_path(@outline) %>';
    var CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]')?.content || '';

    /* ─── Constants (matching Ruby compiler: SW=10, SH=5.625, PX=×128) ─── */
    var SW = 10.0, SH = 5.625;
    var PX = function(inch) { return Math.round(inch * 128); };
    var PT = function(pt)   { return Math.round(pt * 128 / 72); };

    /* ─── Icons ─── */
    var ICONS = {
      star:"M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
      check:"M20 6L9 17l-5-5",rocket:"M4.5 16.5c-1.5 1.5-1.5 3 0 4.5 1.5 1.5 3 1.5 4.5 0l10-10C21 9 21 3 19 2S9 3 4.5 16.5zM15 9a1 1 0 100-2 1 1 0 000 2z",
      chart:"M18 20V10M12 20V4M6 20v-6",money:"M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6",
      person:"M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z",
      people:"M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75",
      leaf:"M17 8C8 10 5.9 16.17 3.82 19 2 16 2 13 2 11 2 5 7 3 12 3s9 2 9 9c0 2-2 4-4 4",
      lightbulb:"M9 21h6M12 3C8.69 3 6 5.69 6 9c0 2.12 1.1 3.99 2.78 5.08L9 17h6l.22-2.92A6 6 0 1012 3z",
      shield:"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
      target:"M12 22a10 10 0 100-20 10 10 0 000 20zM12 18a6 6 0 100-12 6 6 0 000 12zM12 14a2 2 0 100-4 2 2 0 000 4z",
      crown:"M2 20h20M5 20V8l7-5 7 5v12",handshake:"M12 7l4 2v5l-4 2-4-2V9l4-2zM3 12l4-2M17 10l4 2M7 17l2-1M17 17l-2-1",
      globe:"M12 22a10 10 0 100-20 10 10 0 000 20zM2 12h20M12 2a15 15 0 010 20M12 2a15 15 0 000 20",
      megaphone:"M11 5.89L2 9v6l9 3.11M11 5.89V19.1M11 5.89L22 3v18l-11-3.1",
      search:"M11 19a8 8 0 100-16 8 8 0 000 16zM21 21l-4.35-4.35",
      code:"M16 18l6-6-6-6M8 6l-6 6 6 6",clock:"M12 22a10 10 0 100-20 10 10 0 000 20zM12 6v6l4 2",
      store:"M3 9l1-5h16l1 5v1a2 2 0 01-2 2H5a2 2 0 01-2-2V9zM8 22V12h8v10",
      percent:"M19 5L5 19M5.5 5.5A.5.5 0 015 5a.5.5 0 010 1 .5.5 0 010-1zM19.5 19.5a.5.5 0 01-.5-.5.5.5 0 010 1 .5.5 0 010-1z",
      heart:"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z",
      truck:"M1 3h15v13H1zM16 8h4l3 3v5h-7V8zM5.5 19a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM18.5 19a1.5 1.5 0 100-3 1.5 1.5 0 000 3z",
      phone:"M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"
    };

    function iconSvg(name, size, color) {
      var d = ICONS[name] || ICONS['star'];
      return '<svg viewBox="0 0 24 24" width="'+size+'" height="'+size+'" fill="none" stroke="'+color+'" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="'+d+'"/></svg>';
    }

    /* ─── Render element (inch coords → px via ×128) ─── */
    function renderEl(el, si) {
      if (!el) return '';
      var x = PX(el.x||0), y = PX(el.y||0), w = PX(el.w||1), h = PX(el.h||0.5);
      var z = el.z !== undefined ? el.z : 2;
      var s = el.style || {};
      var base = 'position:absolute;left:'+x+'px;top:'+y+'px;width:'+w+'px;height:'+h+'px;z-index:'+z+';overflow:hidden;';
      var attrs = 'data-si="'+si+'" data-ei="'+el.id+'"';

      switch(el.type) {
        case 'text': {
          var fs = PT(s.fontSize||12);
          var css = base +
            'font-family:'+(s.fontFamily==='Nunito'?'Nunito,sans-serif':'Inter,sans-serif')+';'+
            'font-size:'+fs+'px;font-weight:'+(s.fontWeight||400)+';'+
            'color:'+(s.color||'#1F2A44')+';text-align:'+(s.align||'left')+';'+
            'line-height:'+(s.lineHeight||1.4)+';'+
            (s.textTransform?'text-transform:'+s.textTransform+';':'')+
            (s.letterSpacing?'letter-spacing:'+s.letterSpacing+'px;':'')+
            (s.fontStyle?'font-style:'+s.fontStyle+';':'')+
            'padding:0;margin:0;display:flex;';
          /* vertical align: center when element is roughly square (icon numbers) or explicit */
          var isSquare = Math.abs(w - h) < 8;
          var valign = s.valign === 'center' || isSquare ? 'center' : 'flex-start';
          css += 'align-items:'+valign+';';
          var halign = s.align==='center'?'center':s.align==='right'?'flex-end':'flex-start';
          css += 'justify-content:'+halign+';';
          return '<div class="slide-el" '+attrs+' style="'+css+'">' +
                 '<span style="display:block;width:100%;line-height:1;">'+escHtml(el.content||'')+'</span></div>';
        }
        case 'rect': {
          var fill = s.fill||'#E8F0FF';
          var r = s.borderRadius||0;
          var op = s.opacity!==undefined?s.opacity:1;
          var border = s.stroke ? 'border:'+PX(s.strokeWidth||0.02)+'px solid '+s.stroke+';' : '';
          return '<div class="slide-el" '+attrs+' style="'+base+'background:'+fill+';border-radius:'+(typeof r==='string'?r:r+'px')+';opacity:'+op+';'+border+'"></div>';
        }
        case 'ellipse': {
          var fill = s.fill||'#6366f1';
          var op = s.opacity!==undefined?s.opacity:1;
          return '<div class="slide-el" '+attrs+' style="'+base+'background:'+fill+';border-radius:50%;opacity:'+op+';"></div>';
        }
        case 'line': {
          var color = s.stroke||'#6366f1';
          var sw2 = PX(s.strokeWidth||0.03);
          return '<div class="slide-el" '+attrs+' style="'+base+'background:'+color+';height:'+sw2+'px;"></div>';
        }
        case 'icon': {
          var bg = s.bgColor||s.fill||'#6366f1';
          var ic = s.color||'#fff';
          var r = s.borderRadius||'50%';
          var icon = el.icon||'star';
          var iconW = Math.round(w*0.55);
          return '<div class="slide-el" '+attrs+' style="'+base+'background:'+bg+';border-radius:'+r+';display:flex;align-items:center;justify-content:center;">'+
                 iconSvg(icon, iconW, ic)+'</div>';
        }
        case 'chart_bar': {
          return renderBarChart(el, x, y, w, h, z, si, attrs);
        }
        case 'chart_donut': {
          return renderDonutChart(el, x, y, w, h, z, si, attrs);
        }
        default: return '';
      }
    }

    function renderBarChart(el, x, y, w, h, z, si, attrs) {
      var data = (el.chart && el.chart.data) || [];
      if (!data.length) return '';
      var t = deck.theme || {};
      var accent = t.accent || '#6366f1';
      var colors = t.card_icons || [accent, t.primary_dk || '#4338CA', t.primary || '#6366f1'];
      var maxVal = Math.max.apply(null, data.map(function(d){return parseFloat(d.value)||0;})) || 1;
      var padTop = 22; /* room for value labels */
      var padBot = 22; /* room for x-axis labels */
      var barArea_h = h - padTop - padBot;
      var n = data.length;
      var barW = Math.max(10, Math.floor((w * 0.8) / n));
      var totalBarW = barW * n;
      var gap = Math.floor((w - totalBarW) / (n + 1));
      gap = Math.max(4, gap);
      var svgContent = '';
      /* grid line at top */
      svgContent += '<line x1="0" y1="'+padTop+'" x2="'+w+'" y2="'+padTop+'" stroke="#F1F5F9" stroke-width="1"/>';
      data.forEach(function(d, i) {
        var val = parseFloat(d.value) || 0;
        var barH = Math.round((val / maxVal) * barArea_h);
        var bx = gap + i * (barW + gap);
        var by = padTop + barArea_h - barH;
        var c = colors[i % colors.length];
        /* bar with rounded top */
        var rx = Math.min(4, barW / 3);
        svgContent += '<rect x="'+bx+'" y="'+by+'" width="'+barW+'" height="'+barH+'" rx="'+rx+'" fill="'+c+'"/>';
        /* value label on top */
        var valStr = String(d.value||'');
        svgContent += '<text x="'+(bx+barW/2)+'" y="'+(by-5)+'" text-anchor="middle" font-size="11" font-weight="700" fill="'+c+'" font-family="Inter,sans-serif">'+escHtml(valStr)+'</text>';
        /* x-axis label */
        var lbl = String(d.label||'').substring(0,8);
        svgContent += '<text x="'+(bx+barW/2)+'" y="'+(padTop+barArea_h+padBot*0.72)+'" text-anchor="middle" font-size="10" fill="#94A3B8" font-family="Inter,sans-serif">'+escHtml(lbl)+'</text>';
      });
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+w+'px;height:'+h+'px;z-index:'+z+';"><svg width="'+w+'" height="'+h+'" viewBox="0 0 '+w+' '+h+'">'+svgContent+'</svg></div>';
    }

    function renderDonutChart(el, x, y, w, h, z, si, attrs) {
      var data = (el.chart && el.chart.data) || [];
      if (!data.length) return '';
      var t = deck.theme || {};
      var colors = t.card_icons || ['#6366f1','#8b5cf6','#a78bfa'];
      var total_val = data.reduce(function(s,d){return s+(d.value||0);},0) || 1;
      var label_parts = ((el.chart && el.chart.label) || '').split('|');
      var center_text = label_parts[0] || '';
      var center_sub = label_parts[1] || '';
      var sz = Math.min(w, h);
      var r = sz * 0.38, cx = sz/2, cy = sz/2;
      var circ = 2 * Math.PI * r;
      var offset = 0, slices = '';
      data.forEach(function(d, i) {
        var pct = (d.value||0) / total_val;
        var dash = pct * circ;
        var c = colors[i % colors.length];
        var rot = -90 + offset * 360;
        slices += '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="'+c+'" stroke-width="'+Math.round(r*0.40)+'" stroke-dasharray="'+dash.toFixed(1)+' '+circ.toFixed(1)+'" stroke-dashoffset="0" transform="rotate('+rot.toFixed(1)+' '+cx+' '+cy+')"/>';
        offset += pct;
      });
      var fs_main = Math.round(sz * 0.09);
      var fs_sub = Math.round(sz * 0.055);
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+sz+'px;height:'+sz+'px;z-index:'+z+';"><svg viewBox="0 0 '+sz+' '+sz+'" width="'+sz+'" height="'+sz+'">'+
             '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="#F1F5F9" stroke-width="'+Math.round(r*0.40)+'"/>'+slices+
             (center_text?'<text x="'+cx+'" y="'+(cy-fs_sub*0.5)+'" text-anchor="middle" font-size="'+fs_main+'" font-weight="900" fill="#1F2A44" font-family="Nunito,sans-serif">'+center_text+'</text>':'')+
             (center_sub?'<text x="'+cx+'" y="'+(cy+fs_main*0.7)+'" text-anchor="middle" font-size="'+fs_sub+'" fill="#94A3B8" font-family="Inter,sans-serif">'+center_sub+'</text>':'')+
             '</svg></div>';
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    /* ─── Render slide ─── */
    function renderSlide(idx) {
      var s = slides[idx];
      if (!s) return '<div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;color:#94A3B8;">Không có slide</div>';
      var bg = s.background || { type:'solid', color:'#ffffff' };
      var bgCss = bg.type === 'gradient' ?
        'background:' + bg.value + ';' :
        'background:' + (bg.color||'#fff') + ';';
      var els = (s.elements || []).sort(function(a,b){return (a.z||2)-(b.z||2);});
      var content = els.map(function(e){ return renderEl(e, idx); }).join('');
      return '<div style="position:absolute;inset:0;' + bgCss + '">' + content + '</div>';
    }

    /* ─── Canvas scale ─── */
    function rescaleCanvas() {
      var viewer = document.getElementById('slide-viewer');
      var stage  = document.getElementById('slide-stage');
      if (!viewer || !stage) return;
      var vw = viewer.clientWidth, vh = viewer.clientHeight;
      if (!vw || !vh) return;
      var scaleW = vw / 1280;
      var scaleH = vh / 720;
      var scale = Math.min(scaleW, scaleH);
      var scaledW = Math.round(1280 * scale);
      var scaledH = Math.round(720 * scale);
      var ml = Math.round((vw - scaledW) / 2);
      var mt = Math.round((vh - scaledH) / 2);
      stage.style.transformOrigin = 'top left';
      stage.style.transform = 'scale(' + scale + ')';
      stage.style.position = 'absolute';
      stage.style.left = ml + 'px';
      stage.style.top  = Math.max(0, mt) + 'px';
      stage.style.margin = '0';
    }

    /* ─── Navigation ─── */
    function goToSlide(idx) {
      current = Math.max(0, Math.min(idx, total - 1));
      var stage = document.getElementById('slide-stage');
      if (stage) stage.innerHTML = renderSlide(current);
      updateDots();
      updateCounter();
      rescaleCanvas();
      if (editorMode) attachEditorHandlers();
    }

    function prevSlide() { goToSlide(current - 1); }
    function nextSlide() { goToSlide(current + 1); }

    function updateDots() {
      var dotsEl = document.getElementById('slide-dots');
      if (!dotsEl) return;
      var html = '';
      for (var i = 0; i < total; i++) {
        var active = i === current;
        html += '<button onclick="goToSlide('+i+')" style="width:'+(active?'20':'7')+'px;height:7px;border-radius:99px;border:none;cursor:pointer;transition:all .2s;background:'+(active?'#6366f1':'#cbd5e1')+'"></button>';
      }
      dotsEl.innerHTML = html;
    }

    function updateCounter() {
      var el2 = document.getElementById('slide-counter');
      if (el2) el2.textContent = 'Slide ' + (current + 1) + ' / ' + total;
    }

    /* ─── WYSIWYG Editor ─── */
    function toggleWysiwyg() {
      editorMode = !editorMode;
      var btn = document.getElementById('wysiwyg-btn');
      var bar = document.getElementById('wysiwyg-bar');
      var stage = document.getElementById('slide-stage');
      if (btn) {
        btn.style.background = editorMode ? '#ede9fe' : '';
        btn.style.color = editorMode ? '#6d28d9' : '';
        btn.style.fontWeight = editorMode ? '700' : '';
      }
      if (bar) bar.style.display = editorMode ? 'flex' : 'none';
      if (stage) {
        stage.style.cursor = editorMode ? 'default' : 'default';
        if (editorMode) attachEditorHandlers();
        else clearSelection();
      }
    }

    function toggleAiPanel() {
      var panel = document.getElementById('slide-editor-panel');
      if (!panel) return;
      var isOpen = panel.style.display !== 'none';
      panel.style.display = isOpen ? 'none' : 'block';
      var btn = document.getElementById('ai-panel-btn');
      if (btn) {
        btn.style.background = isOpen ? '' : '#eef2ff';
        btn.style.color = isOpen ? '' : '#4338ca';
      }
    }

    /* keep toggleEditor as alias for AI panel (used by old inline onclick) */
    function toggleEditor() { toggleAiPanel(); }

    function attachEditorHandlers() {
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      stage.querySelectorAll('.slide-el').forEach(function(domEl) {
        domEl.style.cursor = 'move';
        domEl.style.outline = '1px dashed transparent';
        domEl.style.transition = 'outline-color .1s';
        domEl.onmouseenter = function() {
          if (editorMode && domEl !== document.querySelector('.sel-el'))
            domEl.style.outlineColor = 'rgba(99,102,241,.4)';
        };
        domEl.onmouseleave = function() {
          if (!domEl.classList.contains('sel-el'))
            domEl.style.outlineColor = 'transparent';
        };
        /* remove old listeners before re-adding */
        domEl.removeEventListener('mousedown', startMove);
        domEl.removeEventListener('dblclick', startTextEdit);
        domEl.addEventListener('mousedown', startMove);
        domEl.addEventListener('dblclick', startTextEdit);
      });
    }

    function clearSelection() {
      selectedElId = null;
      document.querySelectorAll('.sel-el').forEach(function(e){ e.classList.remove('sel-el'); });
      document.querySelectorAll('.sel-handle').forEach(function(e){ e.remove(); });
    }

    var _dragState = null;
    function startMove(e) {
      if (!editorMode) return;
      e.preventDefault();
      var domEl = e.currentTarget;
      clearSelection();
      domEl.classList.add('sel-el');
      selectedElId = domEl.dataset.ei;
      addResizeHandles(domEl);
      var stage = document.getElementById('slide-stage');
      var rect = stage.getBoundingClientRect();
      var scale = rect.width / 1280;
      var startX = e.clientX, startY = e.clientY;
      var startL = parseInt(domEl.style.left) || 0;
      var startT = parseInt(domEl.style.top)  || 0;
      _dragState = { domEl:domEl, startX:startX, startY:startY, startL:startL, startT:startT, scale:scale, mode:'move' };
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
    }

    function addResizeHandles(domEl) {
      document.querySelectorAll('.sel-handle').forEach(function(e){e.remove();});
      var positions = [
        {cursor:'nw-resize',left:'-4px',top:'-4px',mode:'nw'},
        {cursor:'n-resize', left:'calc(50% - 4px)',top:'-4px',mode:'n'},
        {cursor:'ne-resize',right:'-4px',top:'-4px',mode:'ne'},
        {cursor:'e-resize', right:'-4px',top:'calc(50% - 4px)',mode:'e'},
        {cursor:'se-resize',right:'-4px',bottom:'-4px',mode:'se'},
        {cursor:'s-resize', left:'calc(50% - 4px)',bottom:'-4px',mode:'s'},
        {cursor:'sw-resize',left:'-4px',bottom:'-4px',mode:'sw'},
        {cursor:'w-resize', left:'-4px',top:'calc(50% - 4px)',mode:'w'}
      ];
      positions.forEach(function(p) {
        var h = document.createElement('div');
        h.className = 'sel-handle';
        h.dataset.mode = p.mode;
        h.style.cursor = p.cursor;
        if (p.left)   h.style.left   = p.left;
        if (p.right)  h.style.right  = p.right;
        if (p.top)    h.style.top    = p.top;
        if (p.bottom) h.style.bottom = p.bottom;
        h.addEventListener('mousedown', startResize);
        domEl.appendChild(h);
      });
    }

    function startResize(e) {
      e.preventDefault(); e.stopPropagation();
      var handle = e.currentTarget;
      var domEl = handle.parentElement;
      var stage = document.getElementById('slide-stage');
      var rect = stage.getBoundingClientRect();
      var scale = rect.width / 1280;
      _dragState = {
        domEl:domEl, startX:e.clientX, startY:e.clientY,
        startL:parseInt(domEl.style.left)||0, startT:parseInt(domEl.style.top)||0,
        startW:domEl.offsetWidth, startH:domEl.offsetHeight,
        scale:scale, mode:handle.dataset.mode
      };
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
    }

    function onDragMove(e) {
      if (!_dragState) return;
      var dx = (e.clientX - _dragState.startX) / _dragState.scale;
      var dy = (e.clientY - _dragState.startY) / _dragState.scale;
      var d = _dragState, el2 = d.domEl, mode = d.mode;
      if (mode === 'move') {
        el2.style.left = Math.round(d.startL + dx) + 'px';
        el2.style.top  = Math.round(d.startT + dy) + 'px';
      } else {
        var newL = d.startL, newT = d.startT, newW = d.startW, newH = d.startH;
        if (mode.includes('e'))  newW = Math.max(32, d.startW + dx);
        if (mode.includes('s'))  newH = Math.max(16, d.startH + dy);
        if (mode.includes('w')) { newL = d.startL + dx; newW = Math.max(32, d.startW - dx); }
        if (mode.includes('n')) { newT = d.startT + dy; newH = Math.max(16, d.startH - dy); }
        el2.style.left   = Math.round(newL) + 'px';
        el2.style.top    = Math.round(newT) + 'px';
        el2.style.width  = Math.round(newW) + 'px';
        el2.style.height = Math.round(newH) + 'px';
      }
    }

    function onDragEnd() {
      if (!_dragState) return;
      document.removeEventListener('mousemove', onDragMove);
      document.removeEventListener('mouseup', onDragEnd);
      /* Sync back to deck schema */
      syncDomToSchema();
      _dragState = null;
      scheduleSave();
    }

    function syncDomToSchema() {
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      stage.querySelectorAll('.slide-el').forEach(function(domEl) {
        var si = parseInt(domEl.dataset.si);
        var ei = domEl.dataset.ei;
        if (isNaN(si) || !ei || !slides[si]) return;
        var elData = slides[si].elements.find(function(e){ return e.id === ei; });
        if (!elData) return;
        /* Convert px back to inches */
        elData.x = parseFloat(domEl.style.left) / 128;
        elData.y = parseFloat(domEl.style.top)  / 128;
        elData.w = domEl.offsetWidth / 128;
        elData.h = domEl.offsetHeight / 128;
      });
    }

    function startTextEdit(e) {
      if (!editorMode) return;
      var domEl = e.currentTarget;
      if (domEl.dataset.type !== 'text' && !domEl.classList.contains('slide-el')) return;
      var span = domEl.querySelector('span');
      if (!span) return;
      e.preventDefault();
      span.contentEditable = 'true';
      span.focus();
      var range = document.createRange();
      range.selectNodeContents(span);
      window.getSelection().removeAllRanges();
      window.getSelection().addRange(range);
      span.addEventListener('blur', function() {
        span.contentEditable = 'false';
        /* Sync text back */
        var si = parseInt(domEl.dataset.si);
        var ei = domEl.dataset.ei;
        if (!isNaN(si) && ei && slides[si]) {
          var elData = slides[si].elements.find(function(e2){ return e2.id === ei; });
          if (elData) { elData.content = span.textContent; scheduleSave(); }
        }
      }, { once: true });
    }

    /* ─── Auto-save ─── */
    function scheduleSave() {
      if (saveTimer) clearTimeout(saveTimer);
      saveTimer = setTimeout(saveDeck, 1200);
    }

    function saveDeck() {
      var body = new URLSearchParams();
      body.append('deck_json', JSON.stringify(deck));
      body.append('authenticity_token', CSRF_TOKEN);
      fetch(SAVE_URL, { method:'PATCH', body:body })
        .then(function(r){ if (!r.ok) console.warn('[VOX] Save failed'); })
        .catch(function(err){ console.error('[VOX] Save error:', err); });
    }

    /* ─── Undo/Redo ─── */
    function saveHistorySnapshot() {
      history = history.slice(0, historyIdx + 1);
      history.push(JSON.stringify(deck));
      historyIdx = history.length - 1;
    }
    function undo() { if (historyIdx > 0) { historyIdx--; deck = JSON.parse(history[historyIdx]); slides = deck.slides || []; goToSlide(current); } }
    function redo() { if (historyIdx < history.length - 1) { historyIdx++; deck = JSON.parse(history[historyIdx]); slides = deck.slides || []; goToSlide(current); } }

    /* ─── Keyboard ─── */
    document.addEventListener('keydown', function(e) {
      if (e.target && (e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.isContentEditable)) return;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); nextSlide(); }
      if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); prevSlide(); }
      if ((e.ctrlKey||e.metaKey) && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }
      if ((e.ctrlKey||e.metaKey) && (e.key === 'y' || (e.key==='z'&&e.shiftKey))) { e.preventDefault(); redo(); }
    });

    /* ─── Fullscreen ─── */
    function enterFullscreen() {
      var viewer = document.querySelector('.relative.bg-\\[\\#0f172a\\]') || document.getElementById('slide-viewer').parentElement;
      if (viewer && viewer.requestFullscreen) viewer.requestFullscreen();
      else if (document.getElementById('slide-viewer').requestFullscreen) document.getElementById('slide-viewer').requestFullscreen();
    }

    /* ─── Regenerate polling ─── */
    function handleRegenerate() {
      if (!confirm('Tạo lại slide? Nội dung hiện tại sẽ bị thay thế.')) return;
      var btn = document.getElementById('regenerate-btn');
      if (btn) btn.disabled = true;
      fetch('<%= regenerate_content_outline_path(@outline) %>', {
        method:'POST',
        headers:{'X-CSRF-Token':CSRF_TOKEN,'Accept':'application/json'}
      }).then(function(r){return r.json();}).then(function(data){
        if (data.pending) pollStatus('<%= status_content_outline_path(@outline, format: :json) %>');
      }).catch(console.error);
    }

    function pollStatus(url) {
      setTimeout(function() {
        fetch(url).then(function(r){return r.json();}).then(function(d){
          if (!d.pending && !d.failed) { window.location.reload(); }
          else if (d.failed) { alert('Có lỗi xảy ra khi tạo lại.'); }
          else { pollStatus(url); }
        }).catch(function(){ setTimeout(function(){ pollStatus(url); }, 3000); });
      }, 2500);
    }

    /* ─── Init ─── */
    var viewer = document.getElementById('slide-viewer');
    if (viewer && !document.getElementById('slide-stage')) {
      var stageDiv = document.createElement('div');
      stageDiv.id = 'slide-stage';
      viewer.appendChild(stageDiv);
    }
    /* DO NOT set display:flex on viewer — it would cause flex-shrink on stage */
    viewer.style.background = '#0f172a';
    viewer.style.overflow = 'hidden';

    /* ─── Theme switcher ─── */
    var THEMES = {
      green:{cover_bg:"#064E3B",primary:"#10B981",primary_dk:"#065F46",primary_lt:"#D1FAE5",primary_xl:"#ECFDF5",accent:"#10B981",card_bgs:["#E8F5F0","#D1F5E0","#C8F5D4"],card_icons:["#10B981","#047857","#065F46"],text_light:"#A7F3D0"},
      blue:{cover_bg:"#1E3A5F",primary:"#3B82F6",primary_dk:"#2563EB",primary_lt:"#BFDBFE",primary_xl:"#EFF6FF",accent:"#3B82F6",card_bgs:["#EFF6FF","#DBEAFE","#E0EDFF"],card_icons:["#3B82F6","#2563EB","#1D4ED8"],text_light:"#BFDBFE"},
      purple:{cover_bg:"#3B0764",primary:"#A855F7",primary_dk:"#7E22CE",primary_lt:"#E9D5FF",primary_xl:"#F5F3FF",accent:"#A855F7",card_bgs:["#F5F3FF","#EDE9FE","#E9D5FF"],card_icons:["#9333EA","#7E22CE","#6B21A8"],text_light:"#DDD6FE"},
      red:{cover_bg:"#7F1D1D",primary:"#EF4444",primary_dk:"#DC2626",primary_lt:"#FCA5A5",primary_xl:"#FEF2F2",accent:"#F97316",card_bgs:["#FFF7ED","#FFEDD5","#FDE8D8"],card_icons:["#EF4444","#DC2626","#B91C1C"],text_light:"#FCA5A5"},
      teal:{cover_bg:"#134E4A",primary:"#0D9488",primary_dk:"#0F766E",primary_lt:"#99F6E4",primary_xl:"#F0FDFA",accent:"#14B8A6",card_bgs:["#F0FDFA","#CCFBF1","#C7F5EE"],card_icons:["#0D9488","#0F766E","#115E59"],text_light:"#99F6E4"},
      amber:{cover_bg:"#78350F",primary:"#F59E0B",primary_dk:"#D97706",primary_lt:"#FDE68A",primary_xl:"#FFFBEB",accent:"#F59E0B",card_bgs:["#FFFBEB","#FEF3C7","#FDE68A"],card_icons:["#F59E0B","#D97706","#B45309"],text_light:"#FDE68A"},
      slate:{cover_bg:"#0F172A",primary:"#64748B",primary_dk:"#475569",primary_lt:"#CBD5E1",primary_xl:"#F8FAFC",accent:"#6366F1",card_bgs:["#F8FAFC","#F1F5F9","#E9EEF4"],card_icons:["#6366F1","#4F46E5","#4338CA"],text_light:"#E2E8F0"},
      earth:{cover_bg:"#3B1F0A",primary:"#92400E",primary_dk:"#78350F",primary_lt:"#FDE68A",primary_xl:"#FFFBEB",accent:"#D97706",card_bgs:["#FFFBEB","#FEF3C7","#FDE68A"],card_icons:["#92400E","#78350F","#6B3B1F"],text_light:"#FDE68A"},
      coral:{cover_bg:"#7F1D1D",primary:"#F43F5E",primary_dk:"#E11D48",primary_lt:"#FECDD3",primary_xl:"#FFF1F2",accent:"#FB7185",card_bgs:["#FFF1F2","#FFE4E6","#FECDD3"],card_icons:["#F43F5E","#E11D48","#BE123C"],text_light:"#FCA5AF"},
      ocean:{cover_bg:"#0C4A6E",primary:"#0369A1",primary_dk:"#075985",primary_lt:"#BAE6FD",primary_xl:"#F0F9FF",accent:"#0EA5E9",card_bgs:["#F0F9FF","#E0F2FE","#BAE6FD"],card_icons:["#0369A1","#075985","#0C4A6E"],text_light:"#BAE6FD"},
      berry:{cover_bg:"#500724",primary:"#DB2777",primary_dk:"#BE185D",primary_lt:"#F9A8D4",primary_xl:"#FDF2F8",accent:"#EC4899",card_bgs:["#FDF2F8","#FCE7F3","#FBCFE8"],card_icons:["#DB2777","#BE185D","#9D174D"],text_light:"#F9A8D4"},
      midnight:{cover_bg:"#0F0B2A",primary:"#4F46E5",primary_dk:"#3730A3",primary_lt:"#C7D2FE",primary_xl:"#EEF2FF",accent:"#818CF8",card_bgs:["#EEF2FF","#E0E7FF","#D4DBFF"],card_icons:["#4F46E5","#3730A3","#312E81"],text_light:"#C7D2FE"}
    };

    function toggleThemeMenu(btn) {
      var menu = document.getElementById('theme-menu');
      menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
      document.addEventListener('click', function closeMenu(e) {
        if (!btn.parentElement.contains(e.target)) {
          menu.style.display = 'none';
          document.removeEventListener('click', closeMenu);
        }
      });
    }

    function applyTheme(name) {
      if (!THEMES[name]) return;
      document.getElementById('theme-menu').style.display = 'none';

      /* Show spinner on current slide */
      var stage = document.getElementById('slide-stage');
      if (stage) stage.style.opacity = '0.4';

      var body = new URLSearchParams();
      body.append('theme', name);
      body.append('authenticity_token', CSRF_TOKEN);

      var themeBtn = document.getElementById('theme-btn');
      if (themeBtn) { themeBtn.textContent = '⏳'; themeBtn.disabled = true; }

      fetch('<%= change_theme_content_outline_path(@outline) %>', {
        method: 'PATCH', body: body
      }).then(function(r) {
          if (!r.ok) return r.text().then(function(t){ throw new Error('HTTP '+r.status+': '+t); });
          return r.json();
        })
        .then(function(data) {
          if (data.deck) {
            deck = data.deck;
            slides = deck.slides || [];
            theme = deck.theme || {};
            total = slides.length;
            saveHistorySnapshot();
          } else if (data.error) {
            alert('Lỗi đổi màu: ' + data.error);
          }
          if (stage) stage.style.opacity = '1';
          if (themeBtn) { themeBtn.textContent = '🎨 Đổi màu'; themeBtn.disabled = false; }
          goToSlide(Math.min(current, slides.length - 1));
        })
        .catch(function(err) {
          console.error('[VOX] change_theme error:', err);
          alert('Lỗi đổi màu: ' + err.message);
          if (stage) stage.style.opacity = '1';
          if (themeBtn) { themeBtn.textContent = '🎨 Đổi màu'; themeBtn.disabled = false; }
        });
    }

    window.applyTheme = applyTheme;
    window.toggleThemeMenu = toggleThemeMenu;
    window.toggleWysiwyg = toggleWysiwyg;
    window.toggleAiPanel = toggleAiPanel;
    window.toggleEditor = toggleEditor;
    window.prevSlide = prevSlide;
    window.nextSlide = nextSlide;
    window.goToSlide = goToSlide;
    window.enterFullscreen = enterFullscreen;
    window.handleRegenerate = handleRegenerate;

    saveHistorySnapshot();
    goToSlide(0);
    window.addEventListener('resize', rescaleCanvas);

  })();
  </script>


<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nội dung được tạo bởi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='Đã sao chép!'; setTimeout(()=>this.textContent='Sao chép',2000)})"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        Sao chép
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>

<script>
function handleRegenerate() {
  var btn = document.getElementById('regenerate-btn');
  if (btn.disabled) return;
  btn.disabled = true;
  btn.style.opacity = '0.5';

  // Show overlay immediately
  var overlay = document.createElement('div');
  overlay.id = 'ai-gen-overlay';
  overlay.style.cssText = 'display:flex;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;background:rgba(15,23,42,0.65);backdrop-filter:blur(4px);';
  overlay.innerHTML = '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.22);max-width:320px;width:90%;"><div id="ai-gen-ring-container"></div><p style="font-size:11px;color:#94A3B8;margin:12px 0 0;">Đừng tắt trang này.</p></div>';
  document.body.appendChild(overlay);

  var phases = ["AI đang tạo <%= @outline.output_type == 'slide' ? 'slide' : 'nội dung' %>...","Đang phân tích...","Đang tạo nội dung...","Đang hoàn thiện..."];
  buildGenRing(phases);

  // Fire AJAX
  var token = document.querySelector('meta[name="csrf-token"]').content;
  var pollUrl = '<%= status_content_outline_path(@outline, format: :json) %>';
  fetch('<%= regenerate_content_outline_path(@outline) %>', {
    method: 'POST',
    headers: { 'Accept': 'application/json', 'X-CSRF-Token': token, 'X-Requested-With': 'XMLHttpRequest' }
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      startGenPolling(data.poll_url || pollUrl);
    })
    .catch(function() { startGenPolling(pollUrl); });
}

function buildGenRing(phases) {
  var totalPhases = phases.length;
  var phase = 0, pct = 0;
  document.getElementById('ai-gen-ring-container').innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
      '<span id="ai-gen-pct" style="font-size:13px;font-weight:800;color:#7c3aed;letter-spacing:-0.3px;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#ede9fe" stroke-width="6"/>',
          '<circle id="ai-gen-arc" cx="44" cy="44" r="38" stroke="#7c3aed" stroke-width="6" stroke-linecap="round" stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
          '<svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="36" height="36" rx="9" fill="#1A6BFF"/><polygon points="10,24 6,31 16,24" fill="white"/><rect x="6" y="6" width="24" height="19" rx="5" fill="white"/><rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/><rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/><rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/></svg>',
        '</div>',
      '</div>',
      '<p id="ai-gen-phase" style="font-size:12px;font-weight:600;color:#6366f1;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');
  var ring = document.getElementById('ai-gen-arc');
  var pctEl = document.getElementById('ai-gen-pct');
  var phEl = document.getElementById('ai-gen-phase');
  var milestones = phases.map(function(_,i){return Math.round(((i+1)/totalPhases)*85);});
  var timer = setInterval(function(){
    var target = milestones[phase]||85;
    pct = Math.min(pct+1, target);
    ring.style.strokeDashoffset = 238.8*(1-pct/100);
    pctEl.textContent = Math.round(pct)+'%';
    if(pct>=(milestones[phase]||85) && phase<totalPhases-1){phase++;phEl.textContent=phases[phase];}
    if(pct>=85 && phase>=totalPhases-1){clearInterval(timer);timer=setInterval(function(){if(pct>=98){clearInterval(timer);return;}pct=Math.min(pct+0.4,98);ring.style.strokeDashoffset=238.8*(1-pct/100);pctEl.textContent=Math.round(pct)+'%';},3000);}
  },300);
}

function startGenPolling(pollUrl) {
  function poll() {
    fetch(pollUrl, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r){return r.json();})
      .then(function(data){
        if(data.failed){
          document.getElementById('ai-gen-overlay').innerHTML =
            '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;max-width:320px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.22);">'+
            '<div style="font-size:2rem;margin-bottom:12px;">⚠️</div>'+
            '<p style="font-size:14px;color:#ef4444;margin:0 0 16px;">Có lỗi xảy ra. Vui lòng thử lại.</p>'+
            '<button onclick="location.reload()" style="padding:8px 20px;background:#6366f1;color:#fff;border:0;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Tải lại</button></div>';
        } else if(data.pending) { setTimeout(poll,2500); }
        else { location.reload(); }
      })
      .catch(function(){setTimeout(poll,3000);});
  }
  setTimeout(poll,1500);
}
</script>
<style>@keyframes vox-pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(0.88);opacity:0.75;}}</style>
