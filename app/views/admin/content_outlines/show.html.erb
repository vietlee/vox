    function toggleThemeMenu(btn) {
      var menu = document.getElementById('theme-menu');
      menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
      document.addEventListener('click', function closeMenu(e) {
        if (!btn.parentElement.contains(e.target)) {
          menu.style.display = 'none';
          document.removeEventListener('click', closeMenu);
        }
      });
    }

    function applyTheme(name) {
      if (!name) return;
      document.getElementById('theme-menu').style.display = 'none';

      /* Show spinner on current slide */
      var stage = document.getElementById('slide-stage');
      if (stage) stage.style.opacity = '0.4';

      var body = new URLSearchParams();
      body.append('theme', name);
      body.append('authenticity_token', CSRF_TOKEN);

      var themeBtn = document.getElementById('theme-btn');
      if (themeBtn) { themeBtn.textContent = '⏳'; themeBtn.disabled = true; }

      fetch('<%= change_theme_content_outline_path(@outline) %>', {
        method: 'PATCH', body: body
      }).then(function(r) {
          if (!r.ok) throw new Error('Lỗi server (HTTP ' + r.status + ')');
          return r.json();
        })
        .then(function(data) {
          if (data.deck) {
            deck = data.deck;
            slides = deck.slides || [];
            theme = deck.theme || {};
            total = slides.length;
            saveHistorySnapshot();
          } else if (data.error) {
            alert('Lỗi đổi màu: ' + data.error);
          }
          if (stage) stage.style.opacity = '1';
          if (themeBtn) { themeBtn.textContent = '🖌️ Đổi theme'; themeBtn.disabled = false; }
          goToSlide(Math.min(current, slides.length - 1));
          renderThumbnails();
        })
        .catch(function(err) {
          console.error('[VOX] change_theme error:', err);
          alert('Lỗi đổi màu: ' + err.message);
          if (stage) stage.style.opacity = '1';
          if (themeBtn) { themeBtn.textContent = '🖌️ Đổi theme'; themeBtn.disabled = false; }
        });
    }

    function recompileCurrentTheme() {
      var currentTheme = (deck.theme && deck.theme.name) || 'blue';
      applyTheme(currentTheme);
    }
    window.recompileCurrentTheme = recompileCurrentTheme;

    window.applyTheme = applyTheme;
    window.toggleThemeMenu = toggleThemeMenu;
    window.toggleWysiwyg = toggleWysiwyg;
    window.toggleAiPanel = toggleAiPanel;
    window.toggleEditor = toggleEditor;
    window.prevSlide = prevSlide;
    window.nextSlide = nextSlide;
    window.goToSlide = goToSlide;
    window.enterFullscreen = enterFullscreen;
    window.handleRegenerate = handleRegenerate;
    window.insertImageFromFile = insertImageFromFile;
    window.applySlideBackground = applySlideBackground;
    window.applyTextProp = applyTextProp;
    window.ttToggle = ttToggle;
    window.ttAlign = ttAlign;
    window.toggleTxtColorPanel = toggleTxtColorPanel;
    window.confirmTxtColor = confirmTxtColor;
    window.toggleBgPanel = toggleBgPanel;
    window.confirmBgColor = confirmBgColor;
    window.syncBgHex = syncBgHex;
    window.updateBgPreview = updateBgPreview;

    /* ═══════════════════════════════════════════════════
       SLIDE PANEL – thumbnails, add, delete
    ═══════════════════════════════════════════════════ */

    var _thumbDragSrc = null;

    function renderThumbnails() {
      var list = document.getElementById('slide-thumb-list');
      if (!list) return;
      var scale = (152 / 1280).toFixed(4);
      var thumbH = Math.round(152 * 9/16);
      var html = '';
      for (var i = 0; i < slides.length; i++) {
        var active = i === current;
        html += '<div class="slide-thumb-wrap" data-idx="'+i+'" draggable="true"' +
          ' onclick="goToSlide('+i+')"' +
          ' onmouseover="this.querySelector(\'.thumb-actions\').style.opacity=\'1\'" onmouseout="this.querySelector(\'.thumb-actions\').style.opacity=\'0\'"' +
          ' style="position:relative;cursor:grab;border-radius:8px;overflow:hidden;width:152px;flex-shrink:0;box-shadow:'+(active?'inset 0 0 0 3px #6366f1, 0 4px 16px rgba(99,102,241,.35)':'0 1px 4px rgba(0,0,0,.10)')+';background:#fff;transition:box-shadow .15s;margin-bottom:2px;'+(active?'transform:scale(1.03);z-index:2;':'')+'">' +
          '<div style="font-size:9px;font-weight:800;padding:4px 7px;'+(active?'background:#6366f1;color:#fff;':'background:#f8fafc;color:#94a3b8;border-bottom:1px solid #e2e8f0;')+'">'+(i+1)+'</div>' +
          '<div style="width:152px;height:'+thumbH+'px;overflow:hidden;position:relative;background:#fff;transform:translateZ(0);">' +
            '<div style="position:absolute;top:0;left:0;width:1280px;height:720px;transform-origin:top left;transform:scale('+scale+');pointer-events:none;">' +
              renderSlide(i) +
            '</div>' +
          '</div>' +
          '<div class="thumb-actions" style="position:absolute;bottom:5px;right:4px;display:flex;flex-direction:row;gap:3px;opacity:0;transition:opacity .15s;z-index:5;">' +
            '<button onclick="event.stopPropagation();duplicateSlide('+i+')" title="Nhân đôi"' +
              ' style="background:rgba(99,102,241,.9);border:none;color:#fff;border-radius:5px;width:20px;height:20px;cursor:pointer;font-size:11px;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.3);line-height:1;">⧉</button>' +
            '<button onclick="event.stopPropagation();askDeleteSlide('+i+')" title="Xoá slide"' +
              ' style="background:rgba(239,68,68,.9);border:none;color:#fff;border-radius:5px;width:20px;height:20px;cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 4px rgba(0,0,0,.3);">×</button>' +
          '</div>' +
        '</div>';
      }
      list.innerHTML = html;
      /* apply pending images */
      list.querySelectorAll('img[data-pending-src]').forEach(function(img) {
        var src = window._imgSrcMap && window._imgSrcMap[img.id];
        if (src) { img.src = src; img.removeAttribute('data-pending-src'); }
      });
      /* Drag-to-reorder events */
      list.querySelectorAll('.slide-thumb-wrap').forEach(function(wrap) {
        wrap.addEventListener('dragstart', function(e) {
          _thumbDragSrc = parseInt(wrap.getAttribute('data-idx'));
          e.dataTransfer.effectAllowed = 'move';
          wrap.style.opacity = '0.4';
        });
        wrap.addEventListener('dragend', function() {
          wrap.style.opacity = '1';
          list.querySelectorAll('.slide-thumb-wrap').forEach(function(w){ w.style.borderColor = w.getAttribute('data-idx') == current ? '#6366f1' : 'transparent'; w.style.boxShadow=''; });
        });
        wrap.addEventListener('dragover', function(e) {
          e.preventDefault();
          e.dataTransfer.dropEffect = 'move';
          var overIdx = parseInt(wrap.getAttribute('data-idx'));
          list.querySelectorAll('.slide-thumb-wrap').forEach(function(w){ w.style.boxShadow = ''; });
          if (overIdx !== _thumbDragSrc) wrap.style.boxShadow = '0 0 0 2px #6366f1';
        });
        wrap.addEventListener('drop', function(e) {
          e.preventDefault();
          var toIdx = parseInt(wrap.getAttribute('data-idx'));
          if (_thumbDragSrc === null || _thumbDragSrc === toIdx) return;
          saveHistorySnapshot();
          var moved = slides.splice(_thumbDragSrc, 1)[0];
          slides.splice(toIdx, 0, moved);
          deck.slides = slides;
          var newCurrent = toIdx;
          if (_thumbDragSrc === current) newCurrent = toIdx;
          else if (_thumbDragSrc < current && toIdx >= current) newCurrent = current - 1;
          else if (_thumbDragSrc > current && toIdx <= current) newCurrent = current + 1;
          current = Math.max(0, Math.min(newCurrent, slides.length - 1));
          total = slides.length;
          autoSave();
          var stage = document.getElementById('slide-stage');
          if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
          updateDots(); updateCounter();
          renderThumbnails();
        });
      });
    }

    /* Patch goToSlide to also refresh thumbnails */
    var _origGoToSlide = goToSlide;
    goToSlide = function(idx) {
      _origGoToSlide(idx);
      renderThumbnails();
      /* scroll active thumb into view */
      var list = document.getElementById('slide-thumb-list');
      if (list) {
        var active = list.querySelector('[data-idx="'+current+'"]');
        if (active) active.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
      }
    };
    window.goToSlide = goToSlide;

    /* ── Add blank slide ── */
    function addBlankSlide() {
      saveHistorySnapshot();
      var newId = 'slide_' + Date.now();
      var t = deck.theme || {};
      var newSlide = {
        id: newId,
        background: { type: 'solid', color: '#ffffff' },
        elements: [
          { id: newId+'_title', type: 'text', x: 80, y: 80, w: 1120, h: 80, z: 1,
            content: 'Tiêu đề slide mới',
            style: { fontSize: 40, fontWeight: 700, color: t.primary_dk || '#1e293b', textAlign: 'center', fontFamily: 'Nunito' } },
          { id: newId+'_sub', type: 'text', x: 160, y: 180, w: 960, h: 50, z: 1,
            content: 'Nội dung',
            style: { fontSize: 20, fontWeight: 400, color: '#64748b', textAlign: 'center', fontFamily: 'Inter' } }
        ],
        raw: { layout: 'blank', title: 'Slide mới' },
        note: ''
      };
      slides.push(newSlide);
      total = slides.length;
      deck.slides = slides;
      autoSave();
      goToSlide(slides.length - 1);
    }
    window.addBlankSlide = addBlankSlide;

    /* ── Delete slide ── */
    var _pendingDeleteIdx = null;
    function askDeleteSlide(idx) {
      if (slides.length <= 1) { alert('Không thể xoá slide cuối cùng.'); return; }
      _pendingDeleteIdx = idx;
      var modal = document.getElementById('delete-slide-modal');
      var desc = document.getElementById('delete-slide-desc');
      if (desc) desc.textContent = 'Slide ' + (idx + 1) + ' sẽ bị xoá vĩnh viễn.';
      if (modal) modal.style.display = 'flex';
    }
    function cancelDeleteSlide() {
      _pendingDeleteIdx = null;
      var modal = document.getElementById('delete-slide-modal');
      if (modal) modal.style.display = 'none';
    }
    function confirmDeleteSlide() {
      if (_pendingDeleteIdx === null) return;
      saveHistorySnapshot();
      slides.splice(_pendingDeleteIdx, 1);
      total = slides.length;
      deck.slides = slides;
      var modal = document.getElementById('delete-slide-modal');
      if (modal) modal.style.display = 'none';
      autoSave();
      goToSlide(Math.min(_pendingDeleteIdx, slides.length - 1));
      _pendingDeleteIdx = null;
    }
    window.askDeleteSlide = askDeleteSlide;
    window.cancelDeleteSlide = cancelDeleteSlide;
    window.confirmDeleteSlide = confirmDeleteSlide;

    /* ── Insert component ── */
    function toggleInsertPanel() {
      var p = document.getElementById('insert-panel');
      if (p) p.style.display = p.style.display === 'none' ? 'block' : 'none';
    }
    function insertComponent(type) {
      document.getElementById('insert-panel').style.display = 'none';
      saveHistorySnapshot();
      var sl = slides[current];
      if (!sl) return;
      var uid = 'el_' + Date.now();
      var t = deck.theme || {};
      var accent = t.accent || '#6366f1';
      var el;
      if (type === 'text') {
        el = { id: uid, type: 'text', x: 200, y: 200, w: 600, h: 80, z: 10,
               content: 'Văn bản mới',
               style: { fontSize: 20, fontWeight: 400, color: '#1e293b', textAlign: 'left', fontFamily: 'Inter' } };
      } else if (type === 'rect') {
        el = { id: uid, type: 'rect', x: 200, y: 200, w: 400, h: 200, z: 10,
               style: { fill: accent, opacity: 1, radius: 12 } };
      } else if (type === 'icon') {
        el = { id: uid, type: 'icon', x: 300, y: 220, w: 120, h: 120, z: 10,
               content: 'star',
               style: { fill: '#fff', bg: accent, radius: '50%' } };
      } else if (type === 'chart_bar') {
        el = { id: uid, type: 'chart_bar', x: 160, y: 160, w: 800, h: 400, z: 10,
               chart: { data: [
                 { value: 42, label: 'A' }, { value: 67, label: 'B' },
                 { value: 31, label: 'C' }, { value: 55, label: 'D' }
               ] } };
      } else if (type === 'chart_donut') {
        el = { id: uid, type: 'chart_donut', x: 240, y: 120, w: 480, h: 480, z: 10,
               chart: { label: '75%|Hoàn thành',
                 data: [{ value: 75, label: 'Đạt' }, { value: 25, label: 'Còn lại' }] } };
      } else if (type === 'ellipse') {
        el = { id: uid, type: 'ellipse', x: 300, y: 180, w: 300, h: 200, z: 10,
               style: { fill: accent, opacity: 0.85 } };
      } else if (type === 'divider') {
        el = { id: uid, type: 'divider', x: 100, y: 340, w: 1080, h: 30, z: 10,
               style: { stroke: accent, strokeWidth: 0.03, dividerStyle: 'gradient' } };
      } else if (type === 'arrow') {
        el = { id: uid, type: 'arrow', x: 200, y: 300, w: 400, h: 60, z: 10,
               style: { stroke: accent, strokeWidth: 0.04 } };
      } else if (type === 'stat') {
        el = { id: uid, type: 'stat', x: 200, y: 160, w: 320, h: 220, z: 10,
               content: '87%|Tỉ lệ thành công|+12% so với năm ngoái',
               style: { accentColor: accent, color: '#1F2A44', borderRadius: 16, backgroundColor: accent+'15' } };
      } else if (type === 'quote') {
        el = { id: uid, type: 'quote', x: 160, y: 160, w: 900, h: 240, z: 10,
               content: 'Nhập nội dung trích dẫn vào đây...|— Tác giả',
               style: { accentColor: accent, color: '#1F2A44' } };
      } else if (type === 'callout') {
        el = { id: uid, type: 'callout', x: 160, y: 200, w: 900, h: 160, z: 10,
               content: 'info|Tiêu đề callout|Nội dung chi tiết của callout box. Dùng để highlight thông tin quan trọng.',
               style: { accentColor: accent } };
      } else if (type === 'progress') {
        el = { id: uid, type: 'progress', x: 200, y: 260, w: 800, h: 80, z: 10,
               content: 'Hoàn thành dự án|72|72%',
               style: { accentColor: accent, color: '#1F2A44' } };
      } else if (type === 'table') {
        el = { id: uid, type: 'table', x: 100, y: 140, w: 1080, h: 360, z: 10,
               table: [
                 ['Danh mục', 'Quý 1', 'Quý 2', 'Quý 3'],
                 ['Doanh thu', '1.2 tỷ', '1.5 tỷ', '1.8 tỷ'],
                 ['Chi phí',  '0.8 tỷ', '0.9 tỷ', '1.0 tỷ'],
                 ['Lợi nhuận','0.4 tỷ', '0.6 tỷ', '0.8 tỷ']
               ],
               style: { accentColor: accent } };
      } else if (type === 'video') {
        /* Open URL modal instead of inserting immediately */
        var modal = document.getElementById('video-url-modal');
        var inp = document.getElementById('video-url-input');
        if (modal) { inp.value = ''; modal.style.display = 'flex'; setTimeout(function(){ inp.focus(); }, 50); }
        return;
      }
      if (!el) return;
      if (!sl.elements) sl.elements = [];
      sl.elements.push(el);
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      renderThumbnails();
      autoSave();
    }
    function confirmVideoUrl() {
      var url = (document.getElementById('video-url-input').value || '').trim();
      document.getElementById('video-url-modal').style.display = 'none';
      if (!url) return;
      saveHistorySnapshot();
      var sl = slides[current];
      if (!sl) return;
      var uid = 'el_' + Date.now();
      var el = { id: uid, type: 'video', x: 160, y: 100, w: 960, h: 540, z: 10,
                 src: url, content: url, style: { borderRadius: 10 } };
      if (!sl.elements) sl.elements = [];
      sl.elements.push(el);
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      renderThumbnails();
      autoSave();
    }
    window.confirmVideoUrl = confirmVideoUrl;

    /* Double-click video element to change URL */
    function startVideoEdit(e) {
      if (!editorMode) return;
      e.stopPropagation();
      var domEl = e.currentTarget;
      var elId = domEl.getAttribute('data-ei');
      var sl = slides[current];
      var elData = sl ? (sl.elements||[]).find(function(e){ return e.id===elId; }) : null;
      if (!elData) return;
      var modal = document.getElementById('video-url-modal');
      var inp = document.getElementById('video-url-input');
      inp.value = elData.src || elData.content || '';
      /* Reuse modal — on confirm, update existing element */
      inp.dataset.editId = elId;
      modal.style.display = 'flex';
      setTimeout(function(){ inp.focus(); inp.select(); }, 50);
      /* Override confirm to update instead of insert */
      window._videoEditId = elId;
    }

    /* Patch confirmVideoUrl to handle edit mode */
    var _origConfirmVideoUrl = confirmVideoUrl;
    confirmVideoUrl = function() {
      var url = (document.getElementById('video-url-input').value || '').trim();
      document.getElementById('video-url-modal').style.display = 'none';
      if (!url) return;
      var editId = window._videoEditId;
      window._videoEditId = null;
      if (editId) {
        var sl = slides[current];
        var elData = sl ? (sl.elements||[]).find(function(e){ return e.id===editId; }) : null;
        if (elData) {
          saveHistorySnapshot();
          elData.src = url; elData.content = url;
          var stage = document.getElementById('slide-stage');
          if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
          if (editorMode) attachEditorHandlers();
          renderThumbnails(); autoSave();
        }
        return;
      }
      _origConfirmVideoUrl();
    };
    window.confirmVideoUrl = confirmVideoUrl;

    window.toggleInsertPanel = toggleInsertPanel;
    window.insertComponent = insertComponent;

    /* ═══════════════════════════════════════════════════
       DUPLICATE SLIDE
    ═══════════════════════════════════════════════════ */
    var _dupSlideIdx = null;
    function duplicateSlide(idx) {
      if (idx === undefined) idx = current;
      _dupSlideIdx = idx;
      var modal = document.getElementById('dup-slide-modal');
      if (modal) { modal.style.display = 'flex'; }
    }
    function cancelDupSlide() {
      var modal = document.getElementById('dup-slide-modal');
      if (modal) modal.style.display = 'none';
      _dupSlideIdx = null;
    }
    function confirmDupSlide() {
      var modal = document.getElementById('dup-slide-modal');
      if (modal) modal.style.display = 'none';
      var idx = (_dupSlideIdx !== null) ? _dupSlideIdx : current;
      _dupSlideIdx = null;
      saveHistorySnapshot();
      var src = slides[idx];
      var copy = JSON.parse(JSON.stringify(src));
      var ts = Date.now();
      copy.id = 'slide_dup_' + ts;
      (copy.elements || []).forEach(function(el, i) { el.id = 'el_dup_' + ts + '_' + i; });
      slides.splice(idx + 1, 0, copy);
      total = slides.length;
      deck.slides = slides;
      autoSave();
      goToSlide(idx + 1);
      renderThumbnails();
    }
    window.duplicateSlide = duplicateSlide;
    window.cancelDupSlide = cancelDupSlide;
    window.confirmDupSlide = confirmDupSlide;

    /* ═══════════════════════════════════════════════════
       COPY / PASTE / DUPLICATE ELEMENT
    ═══════════════════════════════════════════════════ */
    var _clipboard = null;

    function copySelectedEl() {
      if (!selectedElId) return;
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (el) {
        _clipboard = JSON.parse(JSON.stringify(el));
        /* show brief toast */
        showToast('Đã copy element');
      }
    }

    function pasteEl() {
      if (!_clipboard || !editorMode) return;
      saveHistorySnapshot();
      var sl = slides[current];
      if (!sl) return;
      var copy = JSON.parse(JSON.stringify(_clipboard));
      copy.id = 'el_paste_' + Date.now();
      copy.x = (copy.x || 0) + 20;
      copy.y = (copy.y || 0) + 20;
      if (!sl.elements) sl.elements = [];
      sl.elements.push(copy);
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      renderThumbnails();
      autoSave();
      /* select the pasted element */
      selectedElId = copy.id;
      var domEl = document.querySelector('[data-ei="'+copy.id+'"]');
      if (domEl) { domEl.classList.add('sel-el'); showTextToolbar(domEl); }
    }

    function duplicateSelectedEl() {
      if (!selectedElId || !editorMode) return;
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (!el) return;
      _clipboard = JSON.parse(JSON.stringify(el));
      pasteEl();
    }

    /* ═══════════════════════════════════════════════════
       Z-ORDER
    ═══════════════════════════════════════════════════ */
    function zOrder(dir) {
      if (!selectedElId) return;
      var sl = slides[current];
      if (!sl || !sl.elements) return;
      saveHistorySnapshot();
      var els = sl.elements;
      var zVals = els.map(function(e){ return e.z || 1; });
      var minZ = Math.min.apply(null, zVals);
      var maxZ = Math.max.apply(null, zVals);
      var el = els.find(function(e){ return e.id === selectedElId; });
      if (!el) return;
      var curZ = el.z || 1;
      if (dir === 'front')   { el.z = maxZ + 1; }
      else if (dir === 'back')    { el.z = Math.max(0, minZ - 1); }
      else if (dir === 'forward') { el.z = curZ + 1; }
      else if (dir === 'backward'){ el.z = Math.max(0, curZ - 1); }
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      /* re-select */
      selectedElId = el.id;
      var domEl = document.querySelector('[data-ei="'+el.id+'"]');
      if (domEl) { domEl.classList.add('sel-el'); }
      autoSave();
    }
    window.zOrder = zOrder;

    /* ═══════════════════════════════════════════════════
       ALIGN TOOLS
    ═══════════════════════════════════════════════════ */
    function toggleAlignPanel() {
      var p = document.getElementById('align-panel');
      if (p) p.style.display = p.style.display === 'none' ? 'block' : 'none';
    }
    function alignEls(dir) {
      document.getElementById('align-panel').style.display = 'none';
      var sl = slides[current];
      if (!sl || !sl.elements) return;
      /* collect IDs to align: multi-select or single */
      var ids = selectedElIds.length > 1 ? selectedElIds : (selectedElId ? [selectedElId] : []);
      if (!ids.length) return;
      saveHistorySnapshot();
      var targets = sl.elements.filter(function(e){ return ids.indexOf(e.id) !== -1; });
      var SW_px = 1280, SH_px = 720;
      if (dir === 'left') {
        targets.forEach(function(e){ e.x = 0; });
      } else if (dir === 'right') {
        targets.forEach(function(e){ e.x = SW_px - (e.w || 0); });
      } else if (dir === 'hcenter') {
        targets.forEach(function(e){ e.x = Math.round((SW_px - (e.w || 0)) / 2); });
      } else if (dir === 'top') {
        targets.forEach(function(e){ e.y = 0; });
      } else if (dir === 'bottom') {
        targets.forEach(function(e){ e.y = SH_px - (e.h || 0); });
      } else if (dir === 'vcenter') {
        targets.forEach(function(e){ e.y = Math.round((SH_px - (e.h || 0)) / 2); });
      } else if (dir === 'distribute-h' && targets.length >= 2) {
        targets.sort(function(a,b){ return a.x - b.x; });
        var x0 = targets[0].x, x1 = targets[targets.length-1].x;
        var gap = (x1 - x0) / (targets.length - 1);
        targets.forEach(function(e, i){ e.x = Math.round(x0 + gap * i); });
      } else if (dir === 'distribute-v' && targets.length >= 2) {
        targets.sort(function(a,b){ return a.y - b.y; });
        var y0 = targets[0].y, y1 = targets[targets.length-1].y;
        var gap = (y1 - y0) / (targets.length - 1);
        targets.forEach(function(e, i){ e.y = Math.round(y0 + gap * i); });
      }
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      renderThumbnails();
      autoSave();
    }
    window.toggleAlignPanel = toggleAlignPanel;
    window.alignEls = alignEls;

    /* ═══════════════════════════════════════════════════
       POSITION / SIZE PANEL
    ═══════════════════════════════════════════════════ */
    function updatePosPanel() {
      /* Keep legacy pos-panel hidden — values now live in the unified toolbar */
      var panel = document.getElementById('pos-panel');
      if (panel) panel.style.display = 'none';
      if (!editorMode || !selectedElId) return;
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (!el) return;
      var tw = document.getElementById('tt-w');
      var th = document.getElementById('tt-h');
      var top = document.getElementById('tt-op');
      if (tw) tw.value = Math.round(el.w || 0);
      if (th) th.value = Math.round(el.h || 0);
      var op = Math.round(((el.style && el.style.opacity !== undefined) ? el.style.opacity : 1) * 100);
      if (top) top.value = op;
    }
    function setPosVal(prop, val) {
      if (!selectedElId) return;
      var sl = slides[current];
      var el = sl ? (sl.elements||[]).find(function(e){ return e.id === selectedElId; }) : null;
      if (!el) return;
      val = parseFloat(val);
      if (isNaN(val)) return;
      if (prop === 'opacity') {
        if (!el.style) el.style = {};
        el.style.opacity = Math.max(0, Math.min(1, val));
      } else {
        el[prop] = val;
      }
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      attachEditorHandlers();
      /* re-select */
      selectedElId = el.id;
      var domEl = document.querySelector('[data-ei="'+el.id+'"]');
      if (domEl) { domEl.classList.add('sel-el'); }
      renderThumbnails();
      scheduleSave();
    }
    window.setPosVal = setPosVal;

    /* ─── Toast helper ─── */
    function showToast(msg) {
      var t = document.createElement('div');
      t.textContent = msg;
      t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:#1e293b;color:#fff;padding:8px 18px;border-radius:20px;font-size:12px;font-weight:600;z-index:99999;opacity:0;transition:opacity .25s;pointer-events:none;';
      document.body.appendChild(t);
      setTimeout(function(){ t.style.opacity='1'; }, 10);
      setTimeout(function(){ t.style.opacity='0'; setTimeout(function(){ t.remove(); }, 300); }, 1800);
    }

    /* ═══════════════════════════════════════════════════
       ICON PICKER
    ═══════════════════════════════════════════════════ */
    var _iconPickerMode = 'insert'; // 'insert' | 'change'
    var _iconPickerElId = null;

    function buildIconGrid(filter) {
      var grid = document.getElementById('icon-grid');
      if (!grid) return;
      var names = Object.keys(ICONS);
      if (filter) {
        filter = filter.toLowerCase();
        names = names.filter(function(n){ return n.indexOf(filter) !== -1; });
      }
      var html = '';
      var t = deck.theme || {};
      var accent = t.accent || '#6366f1';
      names.forEach(function(name) {
        var d = ICONS[name];
        html += '<button onclick="pickIcon(\''+name+'\')" title="'+name+'" '+
          'style="background:#0f172a;border:1px solid #1e293b;border-radius:8px;padding:5px;cursor:pointer;display:flex;align-items:center;justify-content:center;aspect-ratio:1;transition:background .1s;" '+
          'onmouseover="this.style.background=\'#334155\';this.style.borderColor=\''+accent+'\'" onmouseout="this.style.background=\'#0f172a\';this.style.borderColor=\'#1e293b\'">' +
          '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="'+d+'"/></svg>' +
          '</button>';
      });
      grid.innerHTML = html || '<div style="color:#475569;font-size:11px;padding:10px;text-align:center;">Không tìm thấy</div>';
    }

    function filterIcons(val) { buildIconGrid(val); }

    function openIconPicker(mode, elId) {
      _iconPickerMode = mode || 'insert';
      _iconPickerElId = elId || null;
      var hint = document.getElementById('icon-picker-hint');
      if (hint) hint.textContent = mode === 'change' ? 'Click icon để thay đổi' : 'Click icon để chèn vào slide';
      document.getElementById('icon-search').value = '';
      buildIconGrid('');
      var panel = document.getElementById('icon-picker');
      panel.style.display = 'block';
      panel.style.right = '';
      panel.style.transform = '';
      /* Position near the selected element without covering it */
      var anchorEl = elId && document.querySelector('.slide-el[data-ei="'+elId+'"]');
      var panelW = 320, panelH = 380;
      var vw = window.innerWidth, vh = window.innerHeight;
      var left, top;
      if (anchorEl) {
        var r = anchorEl.getBoundingClientRect();
        /* Prefer right of element, fall back to left */
        if (r.right + 12 + panelW <= vw - 8) {
          left = r.right + 12;
        } else {
          left = Math.max(8, r.left - panelW - 12);
        }
        /* Align top with element, clamp to viewport */
        top = Math.min(r.top, vh - panelH - 8);
        top = Math.max(8, top);
      } else {
        left = vw - panelW - 20;
        top = Math.round((vh - panelH) / 2);
      }
      panel.style.left = left + 'px';
      panel.style.top  = top  + 'px';
    }

    function closeIconPicker() {
      var panel = document.getElementById('icon-picker');
      if (panel) panel.style.display = 'none';
      _iconPickerElId = null;
    }

    function pickIcon(name) {
      if (_iconPickerMode === 'change' && _iconPickerElId) {
        /* Change existing icon element */
        var sl = slides[current];
        if (!sl) { closeIconPicker(); return; }
        var elData = (sl.elements||[]).find(function(e){ return e.id === _iconPickerElId; });
        if (elData) {
          saveHistorySnapshot();
          elData.icon = name;
          var stage = document.getElementById('slide-stage');
          if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
          if (editorMode) attachEditorHandlers();
          renderThumbnails();
          autoSave();
        }
      } else {
        /* Insert new icon element */
        saveHistorySnapshot();
        var sl = slides[current];
        if (!sl) { closeIconPicker(); return; }
        var uid = 'el_' + Date.now();
        var t = deck.theme || {};
        var accent = t.accent || '#6366f1';
        var el = { id: uid, type: 'icon', x: 300, y: 220, w: 120, h: 120, z: 10,
                   content: name,
                   style: { fill: '#fff', bg: accent, radius: '50%' } };
        if (!sl.elements) sl.elements = [];
        sl.elements.push(el);
        var stage = document.getElementById('slide-stage');
        if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
        if (editorMode) attachEditorHandlers();
        renderThumbnails();
        autoSave();
      }
      closeIconPicker();
    }

    window.openIconPicker = openIconPicker;
    window.closeIconPicker = closeIconPicker;
    window.filterIcons = filterIcons;
    window.pickIcon = pickIcon;

    /* Close icon picker on outside click */
    document.addEventListener('click', function(e) {
      var p = document.getElementById('icon-picker');
      if (p && p.style.display !== 'none' && !p.contains(e.target)) {
        /* allow clicks on the insert panel or toolbar (which opens the picker) */
        var ip = document.getElementById('insert-panel');
        if (ip && ip.contains(e.target)) return;
        if (e.target.closest('#txt-toolbar')) return;
        closeIconPicker();
      }
    });

    /* Close insert panel on outside click */
    document.addEventListener('click', function(e) {
      var p = document.getElementById('insert-panel');
      if (p && p.style.display !== 'none') {
        var btn = p.previousElementSibling;
        if (!p.contains(e.target) && btn && !btn.contains(e.target)) {
          p.style.display = 'none';
        }
      }
    });

    saveHistorySnapshot();
    goToSlide(0);

    /* ResizeObserver on the column: fires whenever its width changes
       (sidebar toggle, window resize) — no timing guesswork */
    var _viewerCol = document.getElementById('slide-viewer-col');
    if (_viewerCol && window.ResizeObserver) {
      new ResizeObserver(function(){ rescaleCanvas(); }).observe(_viewerCol);
    }
    window.addEventListener('resize', rescaleCanvas);

  })();
  </script>


<% else %>
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm">
    <div class="border-b border-slate-100 px-6 py-3 flex items-center justify-between">
      <span class="text-[12px] text-slate-400 font-semibold uppercase tracking-wide">Nội dung được tạo bởi AI</span>
      <button onclick="navigator.clipboard.writeText(document.getElementById('outline-content').innerText).then(()=>{this.textContent='Đã sao chép!'; setTimeout(()=>this.textContent='Sao chép',2000)})"
              class="text-[12px] text-slate-500 hover:text-indigo-600 px-3 py-1 bg-slate-50 hover:bg-indigo-50 rounded-lg transition-colors border-0 cursor-pointer">
        Sao chép
      </button>
    </div>
    <div id="outline-content" class="px-6 py-5 prose prose-slate max-w-none text-[14px] leading-relaxed">
      <%= raw @outline.content %>
    </div>
  </div>
<% end %>

<script>
function handleRegenerate() {
  var btn = document.getElementById('regenerate-btn');
  if (btn.disabled) return;
  btn.disabled = true;
  btn.style.opacity = '0.5';

  // Show overlay immediately
  var overlay = document.createElement('div');
  overlay.id = 'ai-gen-overlay';
  overlay.style.cssText = 'display:flex;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;background:rgba(15,23,42,0.65);backdrop-filter:blur(4px);';
  overlay.innerHTML = '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.22);max-width:320px;width:90%;"><div id="ai-gen-ring-container"></div><p style="font-size:11px;color:#94A3B8;margin:12px 0 0;">Đừng tắt trang này.</p></div>';
  document.body.appendChild(overlay);

  var phases = ["AI đang tạo <%= @outline.output_type == 'slide' ? 'slide' : 'nội dung' %>...","Đang phân tích...","Đang tạo nội dung...","Đang hoàn thiện..."];
  buildGenRing(phases);

  // Fire AJAX
  var token = document.querySelector('meta[name="csrf-token"]').content;
  var pollUrl = '<%= status_content_outline_path(@outline, format: :json) %>';
  fetch('<%= regenerate_content_outline_path(@outline) %>', {
    method: 'POST',
    headers: { 'Accept': 'application/json', 'X-CSRF-Token': token, 'X-Requested-With': 'XMLHttpRequest' }
  }).then(function(r) { return r.json(); })
    .then(function(data) {
      startGenPolling(data.poll_url || pollUrl);
    })
    .catch(function() { startGenPolling(pollUrl); });
}

function buildGenRing(phases) {
  var totalPhases = phases.length;
  var phase = 0, pct = 0;
  document.getElementById('ai-gen-ring-container').innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
      '<span id="ai-gen-pct" style="font-size:13px;font-weight:800;color:#7c3aed;letter-spacing:-0.3px;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#ede9fe" stroke-width="6"/>',
          '<circle id="ai-gen-arc" cx="44" cy="44" r="38" stroke="#7c3aed" stroke-width="6" stroke-linecap="round" stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
          '<svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg"><rect x="0" y="0" width="36" height="36" rx="9" fill="#1A6BFF"/><polygon points="10,24 6,31 16,24" fill="white"/><rect x="6" y="6" width="24" height="19" rx="5" fill="white"/><rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/><rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/><rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/></svg>',
        '</div>',
      '</div>',
      '<p id="ai-gen-phase" style="font-size:12px;font-weight:600;color:#6366f1;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');
  var ring = document.getElementById('ai-gen-arc');
  var pctEl = document.getElementById('ai-gen-pct');
  var phEl = document.getElementById('ai-gen-phase');
  var milestones = phases.map(function(_,i){return Math.round(((i+1)/totalPhases)*85);});
  var timer = setInterval(function(){
    var target = milestones[phase]||85;
    pct = Math.min(pct+1, target);
    ring.style.strokeDashoffset = 238.8*(1-pct/100);
    pctEl.textContent = Math.round(pct)+'%';
    if(pct>=(milestones[phase]||85) && phase<totalPhases-1){phase++;phEl.textContent=phases[phase];}
    if(pct>=85 && phase>=totalPhases-1){clearInterval(timer);timer=setInterval(function(){if(pct>=98){clearInterval(timer);return;}pct=Math.min(pct+0.4,98);ring.style.strokeDashoffset=238.8*(1-pct/100);pctEl.textContent=Math.round(pct)+'%';},3000);}
  },300);
}

function startGenPolling(pollUrl) {
  function poll() {
    fetch(pollUrl, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r){return r.json();})
      .then(function(data){
        if(data.failed){
          document.getElementById('ai-gen-overlay').innerHTML =
            '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;max-width:320px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.22);">'+
            '<div style="font-size:2rem;margin-bottom:12px;">⚠️</div>'+
            '<p style="font-size:14px;color:#ef4444;margin:0 0 16px;">Có lỗi xảy ra. Vui lòng thử lại.</p>'+
            '<button onclick="location.reload()" style="padding:8px 20px;background:#6366f1;color:#fff;border:0;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Tải lại</button></div>';
        } else if(data.pending) { setTimeout(poll,2500); }
        else { location.reload(); }
      })
      .catch(function(){setTimeout(poll,3000);});
  }
  setTimeout(poll,1500);
}
</script>
<style>@keyframes vox-pulse{0%,100%{transform:scale(1);opacity:1;}50%{transform:scale(0.88);opacity:0.75;}}</style>
