<% content_for :title, @outline.title %>

<div class="p-6 max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%= link_to "← Danh sách", content_outlines_path, class: "text-[13px] text-slate-500 hover:text-slate-700" %>
      <h1 class="text-[20px] font-extrabold text-slate-900 mt-1"><%= @outline.title %></h1>
      <div class="text-[12px] text-slate-500 mt-0.5">
        <%= { "outline" => "📋 Dàn ý", "slide_script" => "🖥️ Script Slide", "lesson_plan" => "📚 Kế hoạch buổi học" }[@outline.output_type] %>
        <% if @outline.subject.present? %> · <%= @outline.subject %><% end %>
        · <%= @outline.created_at.strftime("%d/%m/%Y %H:%M") %>
      </div>
    </div>
    <%= button_to regenerate_content_outline_path(@outline), method: :post, class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-lg border-0 cursor-pointer" do %>
      🔄 Tạo lại
    <% end %>
  </div>

  <% if @outline.pending? %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-6 text-center">
      <div class="text-3xl mb-2">⏳</div>
      <p class="text-[14px] text-amber-800 font-semibold">AI đang tạo nội dung...</p>
      <p class="text-[12px] text-amber-700 mt-1">Tải lại trang sau vài giây</p>
      <meta http-equiv="refresh" content="3">
    </div>
  <% elsif @outline.failed? %>
    <div class="bg-red-50 border border-red-200 rounded-xl p-6 text-center">
      <p class="text-[14px] text-red-700 font-semibold">Có lỗi xảy ra khi tạo nội dung.</p>
      <%= button_to regenerate_content_outline_path(@outline), method: :post, class: "mt-3 px-4 py-2 bg-red-600 text-white text-[13px] font-bold rounded-lg border-0 cursor-pointer" do %>Thử lại<% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
      <div class="prose max-w-none text-[14px]">
        <%= raw @outline.content %>
      </div>
    </div>
  <% end %>
</div>
