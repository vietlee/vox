          <div style="margin-top:10px;font-size:10px;color:#475569;text-align:center;" id="icon-picker-hint">Click icon để chèn · Double-click icon trên slide để đổi</div>
        </div>

        <!-- Position/Size panel (shown when element selected in edit mode) -->
        <div id="pos-panel" style="display:none;position:fixed;z-index:10050;background:#1e293b;border-radius:12px;padding:10px 12px;box-shadow:0 8px 28px rgba(0,0,0,.40);min-width:200px;">
          <div style="font-size:9px;color:#94a3b8;font-weight:700;text-transform:uppercase;letter-spacing:.07em;margin-bottom:8px;">Vị trí & Kích thước</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">
            <div><div style="font-size:9px;color:#64748b;margin-bottom:2px;">X</div><input id="pp-x" type="number" oninput="setPosVal('x',this.value)" style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:5px;color:#fff;font-size:11px;padding:4px 6px;outline:none;box-sizing:border-box;"></div>
            <div><div style="font-size:9px;color:#64748b;margin-bottom:2px;">Y</div><input id="pp-y" type="number" oninput="setPosVal('y',this.value)" style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:5px;color:#fff;font-size:11px;padding:4px 6px;outline:none;box-sizing:border-box;"></div>
            <div><div style="font-size:9px;color:#64748b;margin-bottom:2px;">W</div><input id="pp-w" type="number" oninput="setPosVal('w',this.value)" style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:5px;color:#fff;font-size:11px;padding:4px 6px;outline:none;box-sizing:border-box;"></div>
            <div><div style="font-size:9px;color:#64748b;margin-bottom:2px;">H</div><input id="pp-h" type="number" oninput="setPosVal('h',this.value)" style="width:100%;background:#0f172a;border:1px solid #334155;border-radius:5px;color:#fff;font-size:11px;padding:4px 6px;outline:none;box-sizing:border-box;"></div>
          </div>
          <div style="margin-top:8px;display:flex;gap:6px;">
            <div style="flex:1;"><div style="font-size:9px;color:#64748b;margin-bottom:2px;">Opacity</div>
              <input id="pp-opacity" type="range" min="0" max="100" step="1" oninput="setPosVal('opacity',this.value/100);document.getElementById('pp-opacity-val').textContent=this.value+'%'" style="width:100%;cursor:pointer;accent-color:#6366f1;"></div>
            <div style="font-size:10px;color:#e2e8f0;margin-top:12px;min-width:28px;text-align:right;" id="pp-opacity-val">100%</div>
          </div>
        </div>

        <!-- Chart editor panel (shown on double-click of chart element in edit mode) -->
        <div id="chart-editor" style="display:none;position:fixed;z-index:10100;background:#1e293b;border-radius:14px;padding:14px 16px;box-shadow:0 12px 40px rgba(0,0,0,.55);min-width:280px;max-width:340px;">
