              <button onclick="cancelDupSlide()" style="flex:1;background:#f1f5f9;border:none;color:#64748b;border-radius:10px;padding:10px;font-size:13px;font-weight:600;cursor:pointer;">Huỷ</button>
              <button onclick="confirmDupSlide()" style="flex:1;background:#1e3a5f;border:none;color:#fff;border-radius:10px;padding:10px;font-size:13px;font-weight:700;cursor:pointer;">Nhân đôi</button>
            </div>
          </div>
        </div>

        <div id="delete-slide-modal" style="display:none;position:fixed;inset:0;z-index:20000;background:rgba(0,0,0,.5);align-items:center;justify-content:center;">
