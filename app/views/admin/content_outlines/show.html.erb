    var _csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var CSRF_TOKEN = _csrfMeta ? _csrfMeta.content : '';

    /* ─── Theme accent → CSS variable ─── */
    function _hexLuminance(hex) {
      var c = hex.replace('#','');
      if (c.length === 3) c = c[0]+c[0]+c[1]+c[1]+c[2]+c[2];
      var r = parseInt(c.substr(0,2),16)/255, g = parseInt(c.substr(2,2),16)/255, b = parseInt(c.substr(4,2),16)/255;
      var toLinear = function(x){ return x<=0.03928?x/12.92:Math.pow((x+0.055)/1.055,2.4); };
      return 0.2126*toLinear(r)+0.7152*toLinear(g)+0.0722*toLinear(b);
    }
    function _darken(hex, amt) {
      var c = hex.replace('#','');
      if (c.length === 3) c = c[0]+c[0]+c[1]+c[1]+c[2]+c[2];
      var r = Math.max(0,parseInt(c.substr(0,2),16)-amt);
      var g = Math.max(0,parseInt(c.substr(2,2),16)-amt);
      var b = Math.max(0,parseInt(c.substr(4,2),16)-amt);
      return '#'+[r,g,b].map(function(v){return ('0'+v.toString(16)).slice(-2);}).join('');
