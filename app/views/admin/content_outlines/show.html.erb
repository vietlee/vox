    /* ─── Chart editor ─── */
    var _chartEditorElId = null;

    function openChartEditor(elId) {
      var stage = document.getElementById('slide-stage');
      if (!stage) return;
      var elData = null;
      var sl = slides[current];
      if (sl) { elData = (sl.elements||[]).find(function(e){return e.id===elId;}); }
      if (!elData || !elData.chart) return;

      _chartEditorElId = elId;
      var chart = elData.chart;
      var isDonut = elData.type === 'chart_donut';
      var isBar   = elData.type === 'chart_bar';
      var isLine  = elData.type === 'chart_line';

      // Chart type switcher (bar/line only)
      var typeDiv = document.getElementById('chart-editor-type');
      if (typeDiv) typeDiv.style.display = (isBar || isLine) ? 'block' : 'none';
      if (isBar || isLine) {
        var curType = isLine ? 'line' : 'bar';
        ['bar','line'].forEach(function(tp) {
          var btn = document.getElementById('ce-type-'+tp);
          if (btn) { btn.style.background = curType===tp ? '#1e3a5f' : '#0f172a'; btn.style.color = curType===tp ? '#fff' : '#94a3b8'; }
        });
      }

      // Center text fields (donut only)
      var centerDiv = document.getElementById('chart-editor-center');
      if (centerDiv) centerDiv.style.display = isDonut ? 'block' : 'none';
      if (isDonut) {
        var parts = (chart.label || '').split('|');
        document.getElementById('ce-center-main').value = parts[0] || '';
        document.getElementById('ce-center-sub').value = parts[1] || '';
      }

      // Color slots
      var t2 = deck.theme || {};
      var DONUT_PALETTE = ['#f97316','#3b82f6','#22c55e','#a855f7','#ef4444','#06b6d4','#f59e0b','#ec4899'];
      var rawDef = t2.card_icons || DONUT_PALETTE;
      var allSameDef = rawDef.length > 0 && rawDef.every(function(c){ return c === rawDef[0]; });
      var defaultColors = (isDonut && allSameDef) ? DONUT_PALETTE : rawDef;
      var needN = Math.max(isDonut ? (chart.data||[]).length : 3, (chart.data||[]).length);
      var existingColors = chart.colors && chart.colors.length > 0 ? chart.colors.slice() : null;
      var chartColors = existingColors || defaultColors.slice(0, needN);
      /* Expand if not enough colors */
      while (chartColors.length < needN) chartColors.push(DONUT_PALETTE[chartColors.length % DONUT_PALETTE.length]);
      var CE_PRESETS = [
        '#ef4444','#f97316','#f59e0b','#22c55e','#10b981','#06b6d4','#3b82f6',
        '#1e3a5f','#8b5cf6','#ec4899','#ffffff','#cbd5e1','#64748b','#1e293b',
      ];
      var colorsEl = document.getElementById('ce-colors');
      colorsEl.innerHTML = '';

      // Preset swatches row
      var presetRow = document.createElement('div');
      presetRow.style.cssText = 'display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;';
      CE_PRESETS.forEach(function(hex) {
        var s = document.createElement('div');
        var dark = parseInt(hex.slice(1,3),16)*299+parseInt(hex.slice(3,5),16)*587+parseInt(hex.slice(5,7),16)*114 < 128000;
        s.style.cssText = 'width:20px;height:20px;border-radius:4px;background:'+hex+';cursor:pointer;border:1.5px solid '+(dark?'rgba(255,255,255,.15)':'rgba(0,0,0,.15)')+';flex-shrink:0;transition:transform .1s;';
        s.title = hex;
        s.addEventListener('mouseenter', function(){ s.style.transform='scale(1.2)'; });
        s.addEventListener('mouseleave', function(){ s.style.transform=''; });
        s.addEventListener('click', function() { chartColors.push(hex); renderSlots(); });
        presetRow.appendChild(s);
      });
      colorsEl.appendChild(presetRow);

      // Color slot chips with native color picker
      var slotRow = document.createElement('div');
      slotRow.style.cssText = 'display:flex;flex-wrap:wrap;gap:5px;';
      colorsEl.appendChild(slotRow);

      function renderSlots() {
        slotRow.innerHTML = '';
        chartColors.forEach(function(c, i) {
          var wrap = document.createElement('div');
          wrap.style.cssText = 'display:flex;align-items:center;gap:2px;';
          var inp = document.createElement('input');
          inp.type = 'color';
          inp.value = c;
          inp.dataset.idx = i;
          inp.style.cssText = 'width:28px;height:28px;border:2px solid #334155;border-radius:6px;cursor:pointer;padding:1px;background:none;';
          inp.title = c;
          inp.addEventListener('input', function() { chartColors[parseInt(this.dataset.idx)] = this.value; });
          var del = document.createElement('button');
          del.textContent = '×';
          del.style.cssText = 'background:none;border:none;color:#ef4444;cursor:pointer;font-size:13px;padding:0;line-height:1;';
          del.addEventListener('click', function(ev) { ev.stopPropagation(); chartColors.splice(i,1); renderSlots(); });
          wrap.appendChild(inp);
          if (chartColors.length > 1) wrap.appendChild(del);
          slotRow.appendChild(wrap);
        });
        var addBtn = document.createElement('button');
        addBtn.textContent = '+';
        addBtn.title = 'Thêm màu';
        addBtn.style.cssText = 'width:28px;height:28px;border:1px dashed #475569;border-radius:6px;background:none;color:#94a3b8;cursor:pointer;font-size:16px;line-height:1;';
        addBtn.addEventListener('click', function(ev) { ev.stopPropagation(); chartColors.push('#1e3a5f'); renderSlots(); });
        slotRow.appendChild(addBtn);
      }

      renderSlots();
      colorsEl._getColors = function() { return chartColors; };

      // Data rows
      var rowsEl = document.getElementById('ce-rows');
      rowsEl.innerHTML = '';
      (chart.data || []).forEach(function(d, i) {
        rowsEl.appendChild(ceRowHtml(d.value, d.label, i));
      });

      // Position near the element
      var domEl = stage.querySelector('[data-ei="'+elId+'"]');
      var rect = domEl ? domEl.getBoundingClientRect() : stage.getBoundingClientRect();
      var panel = document.getElementById('chart-editor');
      panel.style.display = 'block';
      var pw = 340, ph = 400;
      var left = rect.right + 12;
      var top = rect.top;
      if (left + pw > window.innerWidth - 8) left = rect.left - pw - 12;
      if (top + ph > window.innerHeight - 8) top = window.innerHeight - ph - 8;
      panel.style.left = Math.max(4, left) + 'px';
      panel.style.top = Math.max(4, top) + 'px';
    }

    function ceRowHtml(val, lbl, idx) {
      var row = document.createElement('div');
      row.style.cssText = 'display:flex;gap:5px;align-items:center;';
      row.innerHTML = '<input type="text" placeholder="Giá trị" value="'+escHtml(String(val||''))+'" style="flex:1;min-width:0;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#fff;font-size:12px;padding:5px 7px;outline:none;">' +
        '<input type="text" placeholder="Nhãn" value="'+escHtml(String(lbl||''))+'" style="flex:1.5;min-width:0;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#fff;font-size:12px;padding:5px 7px;outline:none;">' +
        '<button onclick="event.stopPropagation();this.parentNode.remove()" style="background:none;border:none;color:#ef4444;cursor:pointer;font-size:15px;padding:0 2px;flex-shrink:0;">×</button>';
      return row;
    }

    function ceAddRow() {
      var rowsEl = document.getElementById('ce-rows');
      var newRow = ceRowHtml('', '', rowsEl.children.length);
      rowsEl.appendChild(newRow);
      newRow.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      var firstInput = newRow.querySelector('input');
      if (firstInput) firstInput.focus();
    }

    function applyChartEdit() {
      if (!_chartEditorElId) return;
      var sl = slides[current];
      if (!sl) return;
      var elData = (sl.elements||[]).find(function(e){return e.id===_chartEditorElId;});
      if (!elData || !elData.chart) return;

      saveHistorySnapshot();

      // Collect rows
      var rowsEl = document.getElementById('ce-rows');
      var newData = [];
      Array.from(rowsEl.children).forEach(function(row) {
        var inputs = row.querySelectorAll('input');
        var val = inputs[0] ? inputs[0].value.trim() : '';
        var lbl = inputs[1] ? inputs[1].value.trim() : '';
        if (val !== '' || lbl !== '') newData.push({ value: isNaN(parseFloat(val)) ? val : parseFloat(val), label: lbl });
      });
      elData.chart.data = newData;

      // Save colors
      var colorsEl = document.getElementById('ce-colors');
      if (colorsEl && colorsEl._getColors) elData.chart.colors = colorsEl._getColors();

      // Center label (donut)
      if (elData.type === 'chart_donut') {
        var main = document.getElementById('ce-center-main').value.trim();
        var sub = document.getElementById('ce-center-sub').value.trim();
        elData.chart.label = sub ? main + '|' + sub : main;
      }

      // Apply pending chart type change (bar ↔ line)
      if (window._pendingChartType && (elData.type === 'chart_bar' || elData.type === 'chart_line')) {
        elData.type = 'chart_' + window._pendingChartType;
        window._pendingChartType = null;
      }

      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      renderThumbnails();
      autoSave();
      /* Keep popup open — only close via the × button */
    }

