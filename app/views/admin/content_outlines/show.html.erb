            </label>
            <div id="ai-edit-previews" style="display:flex; flex-wrap:wrap; gap:6px; margin-top:8px;"></div>
          </div>

          <button onclick="submitAiEdit()" id="ai-edit-btn"
                  style="width:100%; padding:11px 0; background:linear-gradient(135deg,#1e3a5f,#8b5cf6); color:#fff; font-size:13px; font-weight:700; border:none; border-radius:10px; cursor:pointer; letter-spacing:0.01em;">
            ✨ Áp dụng thay đổi
          </button>

          <div id="ai-edit-history" style="display:none; padding-top:12px; border-top:1px solid #f1f5f9;">
            <div style="font-size:10px; font-weight:700; color:#94a3b8; text-transform:uppercase; letter-spacing:.07em; margin-bottom:6px;">Lịch sử chỉnh sửa</div>
            <div id="ai-edit-history-list" style="display:flex; flex-direction:column; gap:4px;"></div>
          </div>
        </div>

