    function toggleLinkPanel() {
      var panel = document.getElementById('tt-link-panel');
      var btn   = document.getElementById('tt-link-btn');
      if (!panel) return;
      var open = panel.style.display === 'none';
      panel.style.display = open ? 'block' : 'none';
      if (open) {
        var br = btn.getBoundingClientRect();
        panel.style.top  = (br.bottom + 6) + 'px';
        panel.style.left = Math.max(8, Math.min(br.left, window.innerWidth - 272)) + 'px';
        /* Pre-fill existing link */
        if (_selectedTextEl) {
          var ei = _selectedTextEl.dataset.ei;
          var si = parseInt(_selectedTextEl.dataset.si);
          var elData = slides[si] && slides[si].elements.find(function(e){ return e.id === ei; });
          var inp = document.getElementById('tt-link-input');
          if (inp && elData) inp.value = (elData.style && elData.style.link) || '';
        }
        setTimeout(function(){ var i = document.getElementById('tt-link-input'); if(i) i.focus(); }, 50);
      }
