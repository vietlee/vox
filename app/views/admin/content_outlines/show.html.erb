  <style>
    #slide-viewer { font-family:'Nunito','Inter',sans-serif; }
    #slide-stage { position:absolute; width:1280px; height:720px; overflow:hidden; transform-origin:top left; }
    /* Fullscreen: slide-wrap fills browser fullscreen area */
    #slide-wrap:fullscreen,
    #slide-wrap:-webkit-full-screen {
      width: 100% !important;
      height: 100% !important;
      overflow: hidden;
      /* background is set dynamically by goToSlide to match slide color */
    }
    #slide-wrap:fullscreen #slide-viewer,
    #slide-wrap:-webkit-full-screen #slide-viewer {
      position: absolute;
      inset: 0;
      overflow: hidden;
    }
    #slide-stage * { box-sizing:border-box; }
    #slide-stage img { border:none !important; outline:none !important; display:block; }
    /* Block iframe/video from stealing mouse events in editor mode */
    #slide-stage.editor-mode iframe,
    #slide-stage.editor-mode video { pointer-events: none !important; }
    #slide-stage.editor-mode .slide-el[data-type="progress"] span { cursor: text; }
    #slide-stage.editor-mode .slide-el[data-type="callout"] span,
    #slide-stage.editor-mode .slide-el[data-type="callout"] div[style*="font-size"] { cursor: text; }
    #slide-stage.editor-mode .slide-el[data-type="quote"] span { cursor: text; }
    :root { --vox-accent: #1e3a5f; --vox-accent-dk: #1e3a5f; }
    .sel-el { outline:1px dashed var(--vox-accent-dk); outline-offset:1px; cursor:move; }
    [contenteditable]:focus { outline:none !important; box-shadow:none !important; }
    .slide-el { overflow:hidden; min-width:0 !important; min-height:0 !important; }
    .slide-el.sel-el { overflow:visible !important; }
    .snap-guide { position:absolute; background:#f43f5e; pointer-events:none; z-index:99999; opacity:.85; }
    .snap-guide.h { height:1px; left:0; right:0; }
    .snap-guide.v { width:1px; top:0; bottom:0; }
    #txt-toolbar button.tt-on { background:var(--vox-accent) !important; }
    #txt-toolbar { user-select:none; }
    .sel-handle { position:absolute; width:8px; height:8px; background:var(--vox-accent); border:2px solid #fff;
                  border-radius:2px; z-index:9999; pointer-events:all; }
    @keyframes aispin { to { transform:rotate(360deg); } }
  </style>

