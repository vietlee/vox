        d = Math.abs(rawT + h - yl);
        if (d < dyMin) { dyMin = d; snapT = yl - h; snapYPos = yl; }
        d = Math.abs(rawT + h / 2 - yl);
        if (d < dyMin) { dyMin = d; snapT = yl - h / 2; snapYPos = yl; }
