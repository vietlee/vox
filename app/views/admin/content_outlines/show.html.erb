              '</div>' : '') +
          '</div>';
      }

      if (s.footer) {
        contentHtml += '<div style="position:absolute;bottom:20px;left:7%;right:7%;z-index:3;">' +
          '<span style="color:' + t.primary_lt + ';font-size:10px;">' + s.footer + '</span></div>';
      }

      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(fullBg) + contentHtml + '</div>';
    }

