        /* Light theme: text on right side of left panel */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8% 7% 8% 37%;">' +
            '<div style="font-size:10px;font-weight:800;letter-spacing:4px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:20px;">01 / ' + String(total).padStart(2,'0') + '</div>' +
            '<div style="font-size:clamp(22px,3.8vw,48px);font-weight:900;color:' + tColor + ';line-height:1.1;margin-bottom:24px;">' + s.title + '</div>' +
            '<div style="width:48px;height:5px;border-radius:3px;background:' + t.accent + ';margin-bottom:22px;"></div>' +
            (s.bullets.length ? '<div style="font-size:clamp(13px,1.5vw,17px);color:' + sColor + ';line-height:1.85;">' + s.bullets.map(function(b){ return b; }).join('<br>') + '</div>' : '') +
          '</div>';

        /* Left panel decorative text */
        var shortTitle = s.title.substring(0,2).toUpperCase();
        contentHtml +=
          '<div style="position:absolute;left:0;top:0;width:420px;height:100%;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;">' +
            '<div style="font-size:72px;font-weight:900;color:' + t.accent + ';opacity:.15;letter-spacing:-4px;">' + shortTitle + '</div>' +
          '</div>';

      } else if (layout === 'left-card') {
        /* Glass theme: content inside left glass card */
