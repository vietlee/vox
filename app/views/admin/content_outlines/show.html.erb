          <div id="ce-rows" style="display:flex;flex-direction:column;gap:5px;max-height:220px;overflow-y:auto;"></div>
          <button onclick="ceAddRow()" style="margin-top:8px;width:100%;background:#334155;border:none;color:#94a3b8;border-radius:7px;padding:5px;font-size:11px;cursor:pointer;">+ Thêm dòng</button>
          <div style="display:flex;gap:8px;margin-top:12px;">
            <button onclick="applyChartEdit()" style="flex:1;background:#6366f1;border:none;color:#fff;border-radius:8px;padding:7px;font-size:12px;font-weight:700;cursor:pointer;">✓ Áp dụng</button>
            <button onclick="closeChartEditor()" style="flex:1;background:#334155;border:none;color:#94a3b8;border-radius:8px;padding:7px;font-size:12px;cursor:pointer;">Huỷ</button>
          </div>
        </div>

        <!-- Floating text format toolbar (shown when text element selected) -->
        <div id="txt-toolbar" style="display:none;position:fixed;z-index:10000;background:#1e293b;border-radius:12px;padding:5px 8px;box-shadow:0 8px 28px rgba(0,0,0,.40);align-items:center;gap:3px;flex-wrap:nowrap;">
          <!-- Font family — custom searchable dropdown -->
          <div style="position:relative;" id="tt-family-wrap">
            <button id="tt-family-btn" onclick="toggleFontDropdown()" style="font-size:11px;padding:2px 6px;border-radius:5px;border:none;background:#334155;color:#fff;cursor:pointer;min-width:90px;max-width:110px;display:flex;align-items:center;justify-content:space-between;gap:4px;height:26px;">
              <span id="tt-family-label" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">Inter</span>
              <svg width="8" height="8" viewBox="0 0 8 8" fill="none"><path d="M1 2.5L4 5.5L7 2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            </button>
            <div id="tt-font-dropdown" style="display:none;position:absolute;left:0;top:calc(100%+4px);z-index:10200;background:#1e293b;border:1px solid #334155;border-radius:10px;padding:6px;width:180px;box-shadow:0 8px 24px rgba(0,0,0,.5);">
              <input id="tt-font-search" type="text" placeholder="Tìm font..." oninput="filterFonts(this.value)" style="width:100%;box-sizing:border-box;background:#0f172a;border:1px solid #334155;border-radius:6px;color:#fff;font-size:11px;padding:4px 8px;outline:none;margin-bottom:5px;">
              <div id="tt-font-list" style="max-height:220px;overflow-y:auto;display:flex;flex-direction:column;gap:1px;"></div>
            </div>
          </div>
          <!-- Font size -->
          <select id="tt-size" onchange="applyTextProp('fontSize',parseFloat(this.value))" title="Cỡ chữ" style="font-size:11px;padding:2px 4px;border-radius:5px;border:none;background:#334155;color:#fff;cursor:pointer;width:54px;">
            <% [7,8,9,10,11,12,14,16,18,20,24,28,32,36,40,44,48,56,64,72].each do |sz| %>
            <option value="<%= sz %>"><%= sz %>pt</option>
            <% end %>
          </select>
          <div style="width:1px;height:20px;background:#475569;margin:0 2px;flex-shrink:0;"></div>
          <!-- B I U S -->
          <button id="tt-bold"   onclick="ttToggle('tt-bold','fontWeight',700,400)"      title="Đậm (B)"       style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-weight:900;">B</button>
          <button id="tt-italic" onclick="ttToggle('tt-italic','fontStyle','italic','normal')" title="Nghiêng (I)" style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-style:italic;">I</button>
          <button id="tt-under"  onclick="ttToggle('tt-under','textDecoration','underline','none')" title="Gạch chân (U)" style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;text-decoration:underline;">U</button>
          <button id="tt-strike" onclick="ttToggle('tt-strike','textDecoration','line-through','none')" title="Gạch ngang" style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;text-decoration:line-through;font-size:11px;"><s>S</s></button>
          <div style="width:1px;height:20px;background:#475569;margin:0 2px;flex-shrink:0;"></div>
          <!-- Align -->
          <button id="tt-al" onclick="ttAlign('left')"    title="Canh trái"   style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="2" width="12" height="1.5" rx=".5" fill="currentColor"/><rect x="1" y="5.5" width="8" height="1.5" rx=".5" fill="currentColor"/><rect x="1" y="9" width="10" height="1.5" rx=".5" fill="currentColor"/></svg></button>
          <button id="tt-ac" onclick="ttAlign('center')"  title="Canh giữa"   style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="2" width="12" height="1.5" rx=".5" fill="currentColor"/><rect x="3" y="5.5" width="8" height="1.5" rx=".5" fill="currentColor"/><rect x="2" y="9" width="10" height="1.5" rx=".5" fill="currentColor"/></svg></button>
          <button id="tt-ar" onclick="ttAlign('right')"   title="Canh phải"   style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="1" y="2" width="12" height="1.5" rx=".5" fill="currentColor"/><rect x="5" y="5.5" width="8" height="1.5" rx=".5" fill="currentColor"/><rect x="3" y="9" width="10" height="1.5" rx=".5" fill="currentColor"/></svg></button>
          <div style="width:1px;height:20px;background:#475569;margin:0 2px;flex-shrink:0;"></div>
          <!-- List: UL / OL -->
          <button id="tt-ul" onclick="ttList('ul')" title="Danh sách dấu chấm" style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="2" cy="3.5" r="1.2" fill="currentColor"/><rect x="5" y="2.75" width="8" height="1.5" rx=".5" fill="currentColor"/><circle cx="2" cy="7" r="1.2" fill="currentColor"/><rect x="5" y="6.25" width="8" height="1.5" rx=".5" fill="currentColor"/><circle cx="2" cy="10.5" r="1.2" fill="currentColor"/><rect x="5" y="9.75" width="8" height="1.5" rx=".5" fill="currentColor"/></svg>
          </button>
          <button id="tt-ol" onclick="ttList('ol')" title="Danh sách số thứ tự" style="background:#334155;color:#fff;border:none;border-radius:5px;width:28px;height:28px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
