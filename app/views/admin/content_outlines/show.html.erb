    /* ─── List formatting ─── */
    function ttList(type) {
      if (!_selectedTextEl) return;
      saveHistorySnapshot();
      var si = parseInt(_selectedTextEl.dataset.si);
      var ei = _selectedTextEl.dataset.ei;
      var elData = slides[si] && slides[si].elements.find(function(e){ return e.id === ei; });
      if (!elData) return;
      var current = elData.style && elData.style.listType;
      var next = (current === type) ? null : type; /* toggle off if same */
      if (!elData.style) elData.style = {};
      elData.style.listType = next;
      /* transform content: add/remove list markers */
      var lines = (elData.content || '').split('\n');
      if (next === 'ul') {
        lines = lines.map(function(l){ return l.replace(/^(\d+\.\s*|•\s*|-\s*)/, '').trim(); }).map(function(l){ return '• ' + l; });
      } else if (next === 'ol') {
        lines = lines.map(function(l){ return l.replace(/^(\d+\.\s*|•\s*|-\s*)/, '').trim(); }).map(function(l, i){ return (i+1)+'. '+l; });
      } else {
        lines = lines.map(function(l){ return l.replace(/^(\d+\.\s*|•\s*|-\s*)/, '').trim(); });
      }
      elData.content = lines.join('\n');
      /* update list button states */
      ['tt-ul','tt-ol'].forEach(function(id){ var b=document.getElementById(id); if(b)b.classList.remove('tt-on'); });
      if (next) { var ab = document.getElementById('tt-'+next); if (ab) ab.classList.add('tt-on'); }
      /* re-render */
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(si); applyPendingImages(); }
      if (editorMode) {
        attachEditorHandlers();
        var newDom = stage && stage.querySelector('[data-ei="'+ei+'"]');
        if (newDom) { newDom.classList.add('sel-el'); addResizeHandles(newDom); showTextToolbar(newDom); _selectedTextEl = newDom; }
      }
      scheduleSave();
    }
    window.ttList = window.ttList || ttList;

    function ttToggle(btnId, prop, onVal, offVal) {
      var btn = document.getElementById(btnId);
      var isOn = btn && btn.classList.contains('tt-on');
      if (btn) btn.classList.toggle('tt-on', !isOn);
      applyTextProp(prop, isOn ? offVal : onVal);
    }

    /* Align button group */
    function ttAlign(dir) {
      ['tt-al','tt-ac','tt-ar'].forEach(function(id){ var b=document.getElementById(id); if(b)b.classList.remove('tt-on'); });
      var map = {left:'tt-al',center:'tt-ac',right:'tt-ar'};
      var ab = document.getElementById(map[dir]); if (ab) ab.classList.add('tt-on');
      applyTextProp('align', dir);
    }

    /* Text color panel */
    var TXT_COLOR_PRESETS = [
      '#FFFFFF','#F1F5F9','#CBD5E1','#94A3B8','#475569','#1E293B','#000000',
      '#EF4444','#F97316','#F59E0B','#22C55E','#06B6D4','#3B82F6','#8B5CF6',
      '#FCA5A5','#FDE68A','#BBF7D0','#BAE6FD','#DDD6FE','#FBCFE8','#FED7AA',
      '#DC2626','#D97706','#15803D','#0369A1','#6D28D9','#BE185D','#C2410C',
    ];

    function renderTxtSwatches() {
      var cont = document.getElementById('tt-swatches');
      if (!cont || cont.childElementCount > 0) return;
      TXT_COLOR_PRESETS.forEach(function(hex) {
        var s = document.createElement('div');
        var dark = parseInt(hex.slice(1,3),16)*299+parseInt(hex.slice(3,5),16)*587+parseInt(hex.slice(5,7),16)*114 < 128000;
        s.style.cssText = 'width:22px;height:22px;border-radius:5px;background:'+hex+
          ';cursor:pointer;border:1.5px solid '+(dark?'rgba(255,255,255,.2)':'rgba(0,0,0,.12)')+
          ';flex-shrink:0;transition:transform .1s;';
        s.title = hex;
        s.addEventListener('mouseenter', function(){ s.style.transform='scale(1.2)'; });
        s.addEventListener('mouseleave', function(){ s.style.transform=''; });
        s.addEventListener('click', function() {
          document.getElementById('tt-color').value = hex;
          document.getElementById('tt-hex').value = hex;
          document.getElementById('tt-color-bar').style.background = hex;
          /* highlight */
          cont.querySelectorAll('div').forEach(function(d){ d.style.outline=''; });
          s.style.outline = '2px solid #6366f1';
        });
        cont.appendChild(s);
      });
    }

    function toggleTxtColorPanel() {
      var panel = document.getElementById('tt-color-panel');
      if (!panel) return;
      var isOpen = panel.style.display !== 'none';
      panel.style.display = isOpen ? 'none' : 'block';
      if (!isOpen) {
        renderTxtSwatches();
        setTimeout(function() {
          document.addEventListener('click', function closeTxt(e) {
            var btn = document.getElementById('tt-color-btn');
            if (!panel.contains(e.target) && !(btn && btn.contains(e.target))) {
              panel.style.display = 'none';
              document.removeEventListener('click', closeTxt);
            }
          });
        }, 0);
      }
    }

    function confirmTxtColor() {
      var hex = document.getElementById('tt-hex');
      var ci  = document.getElementById('tt-color');
      var color = (hex && /^#[0-9A-Fa-f]{6}$/.test(hex.value)) ? hex.value : (ci ? ci.value : null);
      if (!color) return;
      document.getElementById('tt-color-bar').style.background = color;
      applyTextProp('color', color);
      var panel = document.getElementById('tt-color-panel');
      if (panel) panel.style.display = 'none';
    }

    function applyTextProp(prop, value) {
      if (!_selectedTextEl) return;
      saveHistorySnapshot();
      var si = parseInt(_selectedTextEl.dataset.si);
      var ei = _selectedTextEl.dataset.ei;
      var elData = slides[si] && slides[si].elements.find(function(e){ return e.id === ei; });
      if (!elData) return;
      if (!elData.style) elData.style = {};
      elData.style[prop] = value;
      /* re-render this slide to reflect change */
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(si); applyPendingImages(); }
      if (editorMode) {
        attachEditorHandlers();
        /* re-select the element */
        var newDom = stage && stage.querySelector('[data-ei="'+ei+'"]');
        if (newDom) { newDom.classList.add('sel-el'); addResizeHandles(newDom); showTextToolbar(newDom); _selectedTextEl = newDom; }
      }
      scheduleSave();
    }

    /* ─── Image upload + insert ─── */
    /* ─── Background color panel ─── */
    var BG_PRESETS = [
      {name:'Trắng',      hex:'#FFFFFF'}, {name:'Trắng kem',   hex:'#F8FAFC'},
      {name:'Xám nhạt',   hex:'#F1F5F9'}, {name:'Xám',         hex:'#E2E8F0'},
      {name:'Xám đậm',    hex:'#64748B'}, {name:'Than',        hex:'#1E293B'},
      {name:'Đen',        hex:'#0F172A'}, {name:'Xanh dương',  hex:'#1E3A5F'},
      {name:'Xanh sáng',  hex:'#DBEAFE'}, {name:'Cobalt',      hex:'#1D4ED8'},
      {name:'Lam đậm',    hex:'#0C4A6E'}, {name:'Teal',        hex:'#134E4A'},
      {name:'Xanh lá',    hex:'#064E3B'}, {name:'Xanh mint',   hex:'#D1FAE5'},
      {name:'Tím',        hex:'#3B0764'}, {name:'Tím nhạt',    hex:'#EDE9FE'},
      {name:'Hồng',       hex:'#500724'}, {name:'Hồng nhạt',   hex:'#FCE7F3'},
      {name:'Đỏ đậm',     hex:'#7F1D1D'}, {name:'Cam đất',     hex:'#78350F'},
      {name:'Vàng nhạt',  hex:'#FEF3C7'}, {name:'Vàng gold',   hex:'#451A03'},
      {name:'Đen đêm',    hex:'#020617'}, {name:'Indigo',      hex:'#312E81'},
    ];

    function renderBgSwatches() {
      var cont = document.getElementById('bg-swatches');
      if (!cont || cont.childElementCount > 0) return;
      BG_PRESETS.forEach(function(p) {
        var s = document.createElement('div');
        var isDark = isColorDark(p.hex);
        s.title = p.name + ' · ' + p.hex;
        s.style.cssText = 'width:26px;height:26px;border-radius:6px;background:'+p.hex+
          ';cursor:pointer;border:2px solid '+(isDark?'rgba(255,255,255,.15)':'rgba(0,0,0,.12)')+
          ';transition:transform .1s,box-shadow .1s;flex-shrink:0;position:relative;';
        s.addEventListener('mouseenter', function() {
          s.style.transform='scale(1.25)';s.style.boxShadow='0 3px 10px rgba(0,0,0,.25)';s.style.zIndex='5';
          showSwatchTip(s, p.name, p.hex);
        });
        s.addEventListener('mouseleave', function() {
          s.style.transform='';s.style.boxShadow='';s.style.zIndex='';hideSwatchTip();
        });
        s.addEventListener('click', function() { selectBgPreset(p.hex); });
        cont.appendChild(s);
      });
    }

    var _tipEl = null;
    function showSwatchTip(el, name, hex) {
      hideSwatchTip();
      _tipEl = document.createElement('div');
      _tipEl.style.cssText='position:fixed;z-index:10999;background:#1e293b;color:#fff;font-size:10px;padding:4px 8px;border-radius:6px;pointer-events:none;white-space:nowrap;';
      _tipEl.textContent = name + ' · ' + hex;
      document.body.appendChild(_tipEl);
      var r = el.getBoundingClientRect();
      _tipEl.style.left = (r.left + r.width/2 - _tipEl.offsetWidth/2) + 'px';
      _tipEl.style.top  = (r.top - 30) + 'px';
    }
    function hideSwatchTip() { if (_tipEl) { _tipEl.remove(); _tipEl = null; } }

    function isColorDark(hex) {
      var r=parseInt(hex.slice(1,3),16), g=parseInt(hex.slice(3,5),16), b=parseInt(hex.slice(5,7),16);
      return (r*299+g*587+b*114)/1000 < 128;
    }

    function selectBgPreset(hex) {
      var ci = document.getElementById('bg-color-input');
      var hi = document.getElementById('bg-hex-input');
      if (ci) ci.value = hex;
      if (hi) hi.value = hex;
      updateBgPreview(hex);
      /* highlight selected swatch */
      document.querySelectorAll('#bg-swatches div').forEach(function(s){
        s.style.borderColor = s.title.includes(hex) ? '#4f46e5' : (isColorDark(s.style.background||'#fff')?'rgba(255,255,255,.15)':'rgba(0,0,0,.12)');
        s.style.borderWidth = s.title.includes(hex) ? '2.5px' : '2px';
      });
    }

    function syncBgHex(val) {
      if (/^#[0-9A-Fa-f]{6}$/.test(val)) {
        var ci = document.getElementById('bg-color-input');
        if (ci) ci.value = val;
        updateBgPreview(val);
      }
    }

    function updateBgPreview(hex) {
      var prev = document.getElementById('bg-preview');
      if (prev) prev.style.background = hex;
    }

    function confirmBgColor() {
      var ci = document.getElementById('bg-color-input');
      var hi = document.getElementById('bg-hex-input');
      var color = (hi && /^#[0-9A-Fa-f]{6}$/.test(hi.value)) ? hi.value : (ci ? ci.value : null);
      if (!color || !slides[current]) return;
      saveHistorySnapshot();
      slides[current].background = { type: 'solid', color: color };
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      scheduleSave();
      document.getElementById('bg-panel').style.display = 'none';
    }

    function toggleBgPanel() {
      var panel = document.getElementById('bg-panel');
      if (!panel) return;
      var isOpen = panel.style.display !== 'none';
      panel.style.display = isOpen ? 'none' : 'block';
      if (!isOpen) {
        renderBgSwatches();
        syncBgPicker();
        /* close on outside click */
        setTimeout(function() {
          document.addEventListener('click', function closeBg(e) {
            if (!document.getElementById('bg-panel').contains(e.target) &&
                !document.getElementById('bg-btn').contains(e.target)) {
              document.getElementById('bg-panel').style.display = 'none';
              document.removeEventListener('click', closeBg);
            }
          });
        }, 0);
      }
    }

    /* Change background color of current slide */
    function applySlideBackground(color) {
      if (!slides[current]) return;
      saveHistorySnapshot();
      slides[current].background = { type: 'solid', color: color };
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      scheduleSave();
    }

    /* Sync color picker + hex input + preview to current slide's background */
    function syncBgPicker() {
      if (!slides[current]) return;
      var bg = slides[current].background;
      var color = (bg && bg.type === 'solid' && bg.color) ? bg.color : '#FFFFFF';
      var ci = document.getElementById('bg-color-input');
      var hi = document.getElementById('bg-hex-input');
      if (ci) ci.value = color;
      if (hi) hi.value = color;
      updateBgPreview(color);
    }

    /* Apply img src after innerHTML set (avoids data-URL parsing issues in innerHTML) */
    function applyPendingImages() {
      if (!window._imgSrcMap) window._imgSrcMap = {};
      /* Rebuild map from current slides data so it's always up-to-date */
      slides.forEach(function(sl) {
        (sl.elements || []).forEach(function(el) {
          if (el.type === 'image' && el.src) {
            window._imgSrcMap['vox-img-' + el.id] = el.src;
          }
        });
      });
      document.querySelectorAll('img[data-pending-src]').forEach(function(img) {
        var src = window._imgSrcMap[img.id];
        if (src) { img.src = src; img.removeAttribute('data-pending-src'); }
      });
    }

    function insertImageFromFile(input) {
      var file = input && input.files && input.files[0];
      if (!file) return;
      /* Use createObjectURL for immediate display; also read dataURL for persistence */
      var blobUrl = URL.createObjectURL(file);
      var newEl = {
        id: 'img_' + Date.now(),
        type: 'image',
        x: 2.0, y: 1.5, w: 5.0, h: 3.0, z: 5,
        blobUrl: blobUrl,
        src: blobUrl,
        style: {}
      };
      if (!slides[current]) return;
      saveHistorySnapshot();
      slides[current].elements.push(newEl);
      var stage = document.getElementById('slide-stage');
      if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
      if (editorMode) attachEditorHandlers();
      /* Also read dataURL for saving (blob URLs don't persist across sessions) */
      var reader = new FileReader();
      reader.onload = function(ev) {
        newEl.src = ev.target.result;
        newEl.blobUrl = undefined;
        if (window._imgSrcMap) window._imgSrcMap['vox-img-' + newEl.id] = ev.target.result;
        scheduleSave();
      };
      reader.readAsDataURL(file);
      input.value = '';
    }

    /* ─── Auto-save ─── */
    function autoSave() { scheduleSave(); }
    function scheduleSave() {
      if (saveTimer) clearTimeout(saveTimer);
      saveTimer = setTimeout(saveDeck, 1200);
    }

    function saveDeck() {
      var body = new URLSearchParams();
      body.append('deck_json', JSON.stringify(deck));
      body.append('authenticity_token', CSRF_TOKEN);
      fetch(SAVE_URL, { method:'PATCH', body:body })
        .then(function(r){ if (!r.ok) console.warn('[VOX] Save failed'); })
        .catch(function(err){ console.error('[VOX] Save error:', err); });
    }

    /* ─── Undo/Redo ─── */
    function saveHistorySnapshot() {
      history = history.slice(0, historyIdx + 1);
      history.push(JSON.stringify(deck));
      if (history.length > 50) { history.shift(); } else { historyIdx = history.length - 1; }
      updateUndoRedoBtns();
    }
    function updateUndoRedoBtns() {
      var u = document.getElementById('undo-btn'), r = document.getElementById('redo-btn');
      if (u) { var can = historyIdx > 0; u.disabled = !can; u.style.opacity = can ? '1' : '.35'; u.style.cursor = can ? 'pointer' : 'default'; }
      if (r) { var can2 = historyIdx < history.length - 1; r.disabled = !can2; r.style.opacity = can2 ? '1' : '.35'; r.style.cursor = can2 ? 'pointer' : 'default'; }
    }
    function undo() {
      if (historyIdx <= 0) return;
      historyIdx--;
      deck = JSON.parse(history[historyIdx]);
      slides = deck.slides || [];
      goToSlide(current);
      updateUndoRedoBtns();
    }
    function redo() {
      if (historyIdx >= history.length - 1) return;
      historyIdx++;
      deck = JSON.parse(history[historyIdx]);
      slides = deck.slides || [];
      goToSlide(current);
      updateUndoRedoBtns();
    }

    /* ─── Keyboard ─── */
    /* Click outside selected element → deselect */
    document.addEventListener('click', function(e) {
      if (!editorMode) return;
      var hasSelection = selectedElId || selectedElIds.length > 0;
      if (!hasSelection) return;
      /* ignore clicks inside any toolbar or floating panel */
      if (e.target.closest('#txt-toolbar, #chart-editor, #bg-panel, #align-panel, #wysiwyg-bar, #pos-panel, #tt-color-panel, #tt-bg-panel, #icon-picker')) return;
      var alp = document.getElementById('align-panel');
      if (alp) alp.style.display = 'none';
      /* ignore clicks directly on a .slide-el (startMove handles those) */
      if (e.target.closest('.slide-el') || e.target.closest('.sel-handle')) return;
      clearSelection();
    });

    document.addEventListener('keydown', function(e) {
      if (e.target && (e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.isContentEditable)) return;
      if ((e.key === 'Delete' || e.key === 'Backspace') && editorMode && selectedElId) {
        e.preventDefault();
        var sl = slides[current];
        if (sl) {
          saveHistorySnapshot();
          sl.elements = sl.elements.filter(function(el) { return el.id !== selectedElId; });
          selectedElId = null;
          hideTextToolbar();
          var stage = document.getElementById('slide-stage');
          if (stage) { stage.innerHTML = renderSlide(current); applyPendingImages(); }
          attachEditorHandlers();
          scheduleSave();
        }
        return;
      }
      if (editorMode && selectedElId) return; /* don't navigate when element selected */
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); nextSlide(); }
      if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); prevSlide(); }
      if ((e.ctrlKey||e.metaKey) && e.key === 'z' && !e.shiftKey) { e.preventDefault(); undo(); }
      if ((e.ctrlKey||e.metaKey) && (e.key === 'y' || (e.key==='z'&&e.shiftKey))) { e.preventDefault(); redo(); }
      if ((e.ctrlKey||e.metaKey) && e.key === 'c' && editorMode && selectedElId) { e.preventDefault(); copySelectedEl(); }
      if ((e.ctrlKey||e.metaKey) && e.key === 'v' && editorMode) { e.preventDefault(); pasteEl(); }
      if ((e.ctrlKey||e.metaKey) && e.key === 'd' && editorMode && selectedElId) { e.preventDefault(); duplicateSelectedEl(); }
      if ((e.ctrlKey||e.metaKey) && e.shiftKey && e.key === 'ArrowUp' && editorMode && selectedElId) { e.preventDefault(); zOrder('front'); }
      if ((e.ctrlKey||e.metaKey) && e.shiftKey && e.key === 'ArrowDown' && editorMode && selectedElId) { e.preventDefault(); zOrder('back'); }
      if ((e.ctrlKey||e.metaKey) && !e.shiftKey && e.key === 'ArrowUp' && editorMode && selectedElId) { e.preventDefault(); zOrder('forward'); }
      if ((e.ctrlKey||e.metaKey) && !e.shiftKey && e.key === 'ArrowDown' && editorMode && selectedElId) { e.preventDefault(); zOrder('backward'); }
    });

    /* ─── Fullscreen ─── */
    function enterFullscreen() {
      var wrap = document.getElementById('slide-viewer').parentElement;
      var el = wrap || document.getElementById('slide-viewer');
      if (el.requestFullscreen) el.requestFullscreen();
      else if (el.webkitRequestFullscreen) el.webkitRequestFullscreen();
    }

    /* Rescale when entering/exiting fullscreen */
    document.addEventListener('fullscreenchange', function() {
      var fs = document.fullscreenElement;
      var wrap = document.getElementById('slide-viewer') && document.getElementById('slide-viewer').parentElement;
      if (!wrap) return;
      if (fs) {
        /* fullscreen: always fill full width, no side bars */
        var sw = screen.width, sh = screen.height;
        var scale = sw / 1280;
        var scaledH = Math.round(720 * scale);
        var stage = document.getElementById('slide-stage');
        if (stage) {
          stage.style.transformOrigin = 'top left';
          stage.style.transform = 'scale(' + scale + ')';
          stage.style.left = '0';
          stage.style.top  = Math.max(0, Math.round((sh - scaledH) / 2)) + 'px';
        }
        wrap.style.height = sh + 'px';
      } else {
        rescaleCanvas();
      }
    });

    /* ─── Regenerate polling ─── */
    function handleRegenerate() {
      if (!confirm('Tạo lại slide? Nội dung hiện tại sẽ bị thay thế.')) return;
      var btn = document.getElementById('regenerate-btn');
      if (btn) btn.disabled = true;
      fetch('<%= regenerate_content_outline_path(@outline) %>', {
        method:'POST',
        headers:{'X-CSRF-Token':CSRF_TOKEN,'Accept':'application/json'}
      }).then(function(r){return r.json();}).then(function(data){
        if (data.pending) pollStatus('<%= status_content_outline_path(@outline, format: :json) %>');
      }).catch(console.error);
    }

    function pollStatus(url) {
      setTimeout(function() {
        fetch(url).then(function(r){return r.json();}).then(function(d){
          if (!d.pending && !d.failed) { window.location.reload(); }
          else if (d.failed) { alert('Có lỗi xảy ra khi tạo lại.'); }
          else { pollStatus(url); }
        }).catch(function(){ setTimeout(function(){ pollStatus(url); }, 3000); });
      }, 2500);
    }

    /* ─── Init ─── */
    var viewer = document.getElementById('slide-viewer');
    if (viewer && !document.getElementById('slide-stage')) {
      var stageDiv = document.createElement('div');
      stageDiv.id = 'slide-stage';
      viewer.appendChild(stageDiv);
    }
    /* DO NOT set display:flex on viewer — it would cause flex-shrink on stage */
    viewer.style.background = '#0f172a';
    viewer.style.overflow = 'hidden';

    /* ─── Theme switcher ─── */
    var THEMES = {
      green:    {primary:"#10B981",primary_dk:"#065F46",primary_lt:"#D1FAE5",accent:"#34D399",card_bgs:["#E8F5F0","#D1F5E0","#C8F5D4"],card_icons:["#10B981","#047857","#065F46"],card_style:"flat"},
      blue:     {primary:"#2563EB",primary_dk:"#1E40AF",primary_lt:"#DBEAFE",accent:"#60A5FA",card_bgs:["#EFF6FF","#DBEAFE","#E0EDFF"],card_icons:["#3B82F6","#2563EB","#1D4ED8"],card_style:"shadow"},
      purple:   {primary:"#9333EA",primary_dk:"#7E22CE",primary_lt:"#EDE9FE",accent:"#C084FC",card_bgs:["#F5F3FF","#EDE9FE","#E9D5FF"],card_icons:["#9333EA","#7E22CE","#6B21A8"],card_style:"glass"},
      red:      {primary:"#EF4444",primary_dk:"#DC2626",primary_lt:"#FEE2E2",accent:"#FB923C",card_bgs:["#FFF7ED","#FEE2E2","#FFE4D6"],card_icons:["#EF4444","#DC2626","#B91C1C"],card_style:"bold"},
