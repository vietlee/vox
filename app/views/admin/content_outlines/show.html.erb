    function slideHeader(s, idx, t) {
      var cat = (s.style||{}).category || '';
      return '<div style="height:76px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;padding-top:4px;">' +
        (cat ? '<div style="font-size:10px;font-weight:800;color:' + t.card_icons[0] + ';letter-spacing:3px;text-transform:uppercase;margin-bottom:3px;">' + cat + '</div>' : '') +
        '<h2 style="color:#1F2A44;font-size:clamp(14px,1.8vw,22px);font-weight:800;margin:0;line-height:1.2;text-align:center;">' + s.title + '</h2>' +
      '</div>';
    }

    function slideWrap(bgSvg, inner) {
      return '<div class="s-in" style="position:absolute;inset:0;overflow:hidden;">' +
        svgBg(bgSvg) +
        '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;padding:0 5% 2%;">' +
          inner +
        '</div>' +
      '</div>';
