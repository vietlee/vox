    function applyLink() {
      var url = (document.getElementById('tt-link-input') || {}).value.trim();
      if (!url) return;
      if (!/^https?:\/\//i.test(url)) url = 'https://' + url;
      applyTextProp('link', url);
      var lBtn = document.getElementById('tt-link-btn');
      if (lBtn) { lBtn.style.background = '#1e3a5f'; }
      document.getElementById('tt-link-panel').style.display = 'none';
    }

    function removeLink() {
      applyTextProp('link', null);
      var lBtn = document.getElementById('tt-link-btn');
      if (lBtn) { lBtn.style.background = '#334155'; }
      document.getElementById('tt-link-panel').style.display = 'none';
