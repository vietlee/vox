    ───────────────────────────────────────────────────────────────── */
    function renderCover(s, t) {
      var style = (s.style || {});
      var coverStyle = style.cover_style || 'left';
      var cat     = style.category || '';
      var iconHint = style.icon || '';
      var ic = pickIcon((s.title||'') + ' ' + (s.subtitle||''), iconHint);

      var bgSvg = typeof t.coverBg === 'function' ? t.coverBg(s.title) : t.coverBg;

      /* decorative circles on cover */
      var decor = '<circle cx="1280" cy="143" r="366" fill="' + t.primary + '" opacity=".55"/>' +
                  '<circle cx="1280" cy="648" r="216" fill="' + t.primary_dk + '" opacity=".7"/>';
      var fullBg = DEFS + '<rect width="1280" height="720" fill="' + t.cover_bg + '"/>' + decor;

      var iconBgColor = t.primary_lt;
      var iconCircleHtml = '<div style="width:96px;height:96px;border-radius:18px;background:' + iconBgColor + ';display:flex;align-items:center;justify-content:center;overflow:hidden;">' +
        '<div style="width:50px;height:50px;">' + iconSvg(ic) + '</div>' +
      '</div>';

      var contentHtml;

      if (coverStyle === 'centered') {
        /* centered: icon top-center, category, title, subtitle, bullets centered */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6% 8%;text-align:center;">' +
            '<div class="f-up" style="margin-bottom:14px;">' + iconCircleHtml + '</div>' +
            (cat ? '<div class="f-up" style="font-size:12px;font-weight:800;letter-spacing:2px;color:' + t.accent + ';text-transform:uppercase;margin-bottom:10px;animation-delay:.05s;">' + cat + '</div>' : '') +
            '<h1 class="f-up" style="color:#fff;font-size:clamp(26px,4vw,56px);font-weight:900;line-height:1.1;margin:0 0 14px;max-width:800px;animation-delay:.1s;">' + s.title + '</h1>' +
            (s.subtitle ? '<p class="f-up" style="color:' + t.primary_xl + ';font-size:clamp(13px,1.5vw,18px);margin:0 0 16px;max-width:640px;animation-delay:.15s;">' + s.subtitle + '</p>' : '') +
            (s.bullets && s.bullets.length ?
              '<p class="f-up" style="color:#fff;font-size:13px;font-weight:500;margin:0;animation-delay:.2s;">' +
                s.bullets.slice(0,3).join(' &nbsp;·&nbsp; ') + '</p>' : '') +
          '</div>';

      } else if (coverStyle === 'minimal') {
        /* minimal: title left-large, subtitle, category, bullets */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:8% 7%;">' +
            '<h1 class="f-up" style="color:#fff;font-size:clamp(30px,5vw,64px);font-weight:900;line-height:1.05;margin:0 0 20px;max-width:760px;">' + s.title + '</h1>' +
            (s.subtitle ? '<p class="f-up" style="color:' + t.primary_xl + ';font-size:clamp(13px,1.5vw,18px);margin:0 0 14px;animation-delay:.05s;">' + s.subtitle + '</p>' : '') +
            (cat ? '<div class="f-up" style="font-size:12px;font-weight:800;color:' + t.accent + ';text-transform:uppercase;letter-spacing:2px;margin-bottom:10px;animation-delay:.1s;">' + cat + '</div>' : '') +
            (s.bullets && s.bullets.length ?
              '<p class="f-up" style="color:' + t.primary_xl + ';font-size:13px;margin:0;animation-delay:.12s;">' +
                s.bullets.slice(0,3).join(' &nbsp;·&nbsp; ') + '</p>' : '') +
          '</div>';

      } else {
        /* left (default): icon top-left in rounded rect, category, large title, subtitle, bullets */
        contentHtml =
          '<div style="position:relative;z-index:2;height:100%;display:flex;flex-direction:column;justify-content:center;padding:6% 6% 6% 7%;">' +
            '<div class="f-up" style="margin-bottom:14px;">' + iconCircleHtml + '</div>' +
            (cat ? '<div class="f-up" style="font-size:12px;font-weight:800;color:' + t.accent + ';text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;animation-delay:.05s;">' + cat + '</div>' : '') +
            '<h1 class="f-up" style="color:#fff;font-size:clamp(24px,4.2vw,56px);font-weight:900;line-height:1.05;margin:0 0 16px;max-width:780px;animation-delay:.1s;">' + s.title + '</h1>' +
