            <div>
              <div style="font-size:10px;color:#94a3b8;font-weight:600;margin-bottom:4px;text-transform:uppercase;letter-spacing:.05em;">Phần trăm (0–100)</div>
              <input id="pe-pct" type="number" min="0" max="100" placeholder="72" style="width:100%;box-sizing:border-box;background:#0f172a;border:1px solid #334155;border-radius:7px;color:#fff;font-size:12px;padding:6px 8px;outline:none;" oninput="previewProgressEdit()">
