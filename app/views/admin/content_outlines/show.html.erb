            '<div style="width:36px;height:1px;background:' + t.primary_xl + ';margin-bottom:5%;"></div>' +
            '<div style="font-size:clamp(8px,0.9vw,10px);color:#1F2A44;line-height:1.5;">' + (it.bullets||[]).slice(0,3).join('. ') + '</div>' +
          '</div></div>';
