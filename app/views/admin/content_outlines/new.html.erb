<% content_for :title, "Tạo nội dung mới" %>

<div class="p-6 max-w-2xl mx-auto">
  <div class="mb-6">
    <%= link_to "← Quay lại", content_outlines_path, class: "text-[13px] text-slate-500 hover:text-slate-700" %>
    <h1 class="text-[20px] font-extrabold text-slate-900 mt-2">✍️ Tạo nội dung AI</h1>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
    <%= form_with model: @outline, url: content_outlines_path do |f| %>
      <div class="space-y-5">
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Tiêu đề / Chủ đề *</label>
          <%= f.text_field :title, placeholder: "VD: Phương trình bậc hai, Marketing Digital, Lịch sử Việt Nam...", required: true, class: "w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Môn học / Lĩnh vực</label>
          <%= f.text_field :subject, placeholder: "VD: Toán, Marketing, Lịch sử...", class: "w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Loại nội dung *</label>
          <div class="grid grid-cols-3 gap-3">
            <% [["outline","📋","Dàn ý"],["slide_script","🖥️","Script Slide"],["lesson_plan","📚","Kế hoạch buổi học"]].each do |val, icon, label| %>
              <label class="cursor-pointer">
                <%= f.radio_button :output_type, val, class: "hidden peer" %>
                <div class="border-2 border-slate-200 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 rounded-xl p-3 text-center transition-colors hover:border-slate-300">
                  <div class="text-2xl mb-1"><%= icon %></div>
                  <div class="text-[12px] font-semibold text-slate-700"><%= label %></div>
                </div>
              </label>
            <% end %>
          </div>
        </div>
        <div>
          <label class="block text-[11px] font-bold text-slate-700 uppercase tracking-wide mb-1.5">Yêu cầu bổ sung</label>
          <%= f.text_area :prompt_input, placeholder: "VD: Phù hợp cho người mới bắt đầu, có ví dụ thực tế, tập trung vào ứng dụng...", rows: 3, class: "w-full px-4 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none" %>
        </div>
        <div class="pt-2">
          <div class="flex items-center gap-2 text-[12px] text-amber-700 bg-amber-50 px-4 py-2.5 rounded-lg mb-4">
            ⚡ Sử dụng <strong>~5 AI Credits</strong> để tạo nội dung này
          </div>
          <%= f.submit "✨ Tạo nội dung với AI", class: "w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-[14px] font-bold rounded-xl transition-colors cursor-pointer border-0" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
