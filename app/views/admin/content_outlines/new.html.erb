<% content_for :title, "Tạo nội dung mới" %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">✍️ Tạo nội dung AI</h1>
</div>

<div class="max-w-xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @outline, url: content_outlines_path, local: true, id: "co-form" do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Tiêu đề / Chủ đề *</label>
        <%= f.text_field :title, required: true, placeholder: "VD: Phương trình bậc hai, Marketing Digital, Lịch sử VN...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Môn học / Lĩnh vực</label>
        <%= f.text_field :subject, placeholder: "VD: Toán, Marketing, Lịch sử...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-2 uppercase tracking-wide">Loại nội dung *</label>
        <div class="grid grid-cols-3 gap-2">
          <% [["outline","📋","Dàn ý"],["slide","🖥️","Slide"],["lesson_plan","📚","Kế hoạch buổi học"]].each_with_index do |(val, icon, label), i| %>
            <label class="cursor-pointer">
              <%= f.radio_button :output_type, val, class: "hidden peer", checked: i == 0 %>
              <div class="border-2 border-slate-200 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 rounded-xl p-3 text-center transition-all hover:border-slate-300">
                <div class="text-2xl mb-1"><%= icon %></div>
                <div class="text-[12px] font-semibold text-slate-700"><%= label %></div>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Yêu cầu bổ sung</label>
        <%= f.text_area :prompt_input, rows: 3,
            placeholder: "VD: Phù hợp người mới bắt đầu, có ví dụ thực tế, tập trung ứng dụng...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none resize-none" %>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 flex items-center gap-2 text-[13px] text-amber-700">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Sử dụng <strong class="mx-1">5 AI Credits</strong> để tạo nội dung
      </div>

      <div id="co-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-[13px] rounded-xl px-4 py-3"></div>

      <div class="flex gap-2 pt-1">
        <button type="button" id="ai-submit-btn" onclick="runCoGenerate()"
                class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors border-0">
          ✨ Tạo với AI
        </button>
        <%= link_to "Hủy", content_outlines_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>

<!-- Loading overlay -->
<div id="co-overlay" class="fixed inset-0 z-50 flex flex-col items-center justify-center"
     style="display:none; background:rgba(15,23,42,0.85); backdrop-filter:blur(6px);">
  <div class="relative mb-8">
    <svg class="w-24 h-24" viewBox="0 0 96 96">
      <circle cx="48" cy="48" r="40" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="6"/>
      <circle cx="48" cy="48" r="40" fill="none" stroke="url(#coGrad)" stroke-width="6"
              stroke-linecap="round" stroke-dasharray="251.2" stroke-dashoffset="188.4"
              style="transform-origin:center;transform:rotate(-90deg)">
        <animateTransform attributeName="transform" type="rotate"
          from="-90 48 48" to="270 48 48" dur="1.4s" repeatCount="indefinite"/>
      </circle>
      <defs>
        <linearGradient id="coGrad" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#818cf8"/>
          <stop offset="100%" stop-color="#38bdf8"/>
        </linearGradient>
      </defs>
    </svg>
    <div class="absolute inset-0 flex items-center justify-center text-3xl">✨</div>
  </div>
  <h2 id="co-overlay-msg" class="text-white text-[18px] font-bold mb-2 text-center px-6">AI đang tạo nội dung...</h2>
  <p class="text-slate-300 text-[13px]">Đừng tắt trang này.</p>
  <div class="flex gap-1.5 mt-6">
    <% 5.times do |i| %>
      <div class="w-2 h-2 rounded-full bg-indigo-400" style="animation:aiPulse 1.4s ease-in-out <%= i*0.2 %>s infinite;"></div>
    <% end %>
  </div>
</div>

<style>@keyframes aiPulse{0%,100%{opacity:.3;transform:scale(.85)}50%{opacity:1;transform:scale(1.15)}}</style>

<script>
var _coPollUrl = null;

async function runCoGenerate() {
  var form = document.getElementById('co-form');
  var title = form.querySelector('[name="content_outline[title]"]').value.trim();
  if (!title) { form.querySelector('[name="content_outline[title]"]').focus(); return; }

  var type = form.querySelector('[name="content_outline[output_type]"]:checked')?.value;
  var labels = { slide: 'slide PowerPoint', lesson_plan: 'kế hoạch buổi học', outline: 'dàn ý' };
  document.getElementById('co-overlay-msg').textContent = 'AI đang tạo ' + (labels[type] || 'nội dung') + '...';

  document.getElementById('co-error').classList.add('hidden');
  document.getElementById('ai-submit-btn').disabled = true;
  document.getElementById('co-overlay').style.display = 'flex';

  var formData = new FormData(form);
  formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

  try {
    var res = await fetch('<%= content_outlines_path %>', {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    });
    var data = await res.json();

    if (data.error) {
      showError(data.error);
    } else if (data.pending) {
      _coPollUrl = data.poll_url;
      setTimeout(function() { pollCoStatus(data.poll_url, data.show_url); }, 2000);
    } else {
      window.location.href = data.show_url || '<%= content_outlines_path %>';
    }
  } catch(e) {
    showError(e.message);
  }
}

function pollCoStatus(pollUrl, showUrl) {
  fetch(pollUrl, { headers: { 'Accept': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.failed) {
        showError('AI gặp lỗi khi tạo nội dung. Vui lòng thử lại.');
      } else if (data.pending) {
        setTimeout(function() { pollCoStatus(pollUrl, showUrl); }, 2500);
      } else {
        window.location.href = showUrl;
      }
    })
    .catch(function() {
      setTimeout(function() { pollCoStatus(pollUrl, showUrl); }, 3000);
    });
}

function showError(msg) {
  document.getElementById('co-overlay').style.display = 'none';
  document.getElementById('ai-submit-btn').disabled = false;
  var el = document.getElementById('co-error');
  el.textContent = msg;
  el.classList.remove('hidden');
}

// Cleanup on Turbo navigate away
document.addEventListener('turbo:before-cache', function() {
  document.getElementById('co-overlay').style.display = 'none';
  document.getElementById('ai-submit-btn').disabled = false;
});
</script>
