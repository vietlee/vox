<% content_for :title, "Tạo nội dung mới" %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">✍️ Tạo nội dung AI</h1>
</div>

<div class="max-w-xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @outline, url: content_outlines_path, local: true, id: "co-form" do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Tiêu đề / Chủ đề *</label>
        <%= f.text_field :title, required: true, placeholder: "VD: Phương trình bậc hai, Marketing Digital, Lịch sử VN...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Môn học / Lĩnh vực</label>
        <%= f.text_field :subject, placeholder: "VD: Toán, Marketing, Lịch sử...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-2 uppercase tracking-wide">Loại nội dung *</label>
        <div class="grid grid-cols-3 gap-2">
          <% [["outline","📋","Dàn ý"],["slide","🖥️","Slide"],["lesson_plan","📚","Kế hoạch buổi học"]].each_with_index do |(val, icon, label), i| %>
            <label class="cursor-pointer">
              <%= f.radio_button :output_type, val, class: "hidden peer", checked: i == 0 %>
              <div class="border-2 border-slate-200 peer-checked:border-indigo-500 peer-checked:bg-indigo-50 rounded-xl p-3 text-center transition-all hover:border-slate-300">
                <div class="text-2xl mb-1"><%= icon %></div>
                <div class="text-[12px] font-semibold text-slate-700"><%= label %></div>
              </div>
            </label>
          <% end %>
        </div>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Yêu cầu bổ sung</label>
        <%= f.text_area :prompt_input, rows: 3,
            placeholder: "VD: Phù hợp người mới bắt đầu, có ví dụ thực tế, tập trung ứng dụng...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none resize-none" %>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 flex items-center gap-2 text-[13px] text-amber-700">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Sử dụng <strong class="mx-1">5 AI Credits</strong> để tạo nội dung
      </div>

      <div id="co-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-[13px] rounded-xl px-4 py-3"></div>

      <div class="flex gap-2 pt-1">
        <button type="button" id="ai-submit-btn" onclick="runCoGenerate()"
                class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors border-0">
          ✨ Tạo với AI
        </button>
        <%= link_to "Hủy", content_outlines_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>

<!-- Loading overlay — same style as quiz_sets -->
<div id="co-overlay"
     style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center;
            background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center;
              box-shadow:0 20px 60px rgba(0,0,0,0.22); max-width:320px; width:90%;">
    <div id="co-ring-container"></div>
    <p style="font-size:11px; color:#94A3B8; margin:12px 0 0;">Đừng tắt trang này.</p>
  </div>
</div>

<div id="co-error-box" style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center; background:rgba(15,23,42,0.65);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center; max-width:320px; width:90%;">
    <div style="font-size:2rem; margin-bottom:12px;">⚠️</div>
    <p id="co-error-msg" style="font-size:14px; color:#ef4444; margin:0 0 16px;"></p>
    <button onclick="document.getElementById('co-error-box').style.display='none'; document.getElementById('ai-submit-btn').disabled=false;"
            style="padding:8px 20px; background:#6366f1; color:#fff; border:0; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer;">
      Đóng
    </button>
  </div>
</div>

<style>
@keyframes vox-pulse {
  0%,100% { transform:scale(1); opacity:1; }
  50%      { transform:scale(0.88); opacity:0.75; }
}
</style>

<script>
var CO_PHASES_BY_TYPE = {
  slide:       ['Đang phân tích chủ đề...', 'Đang tạo cấu trúc slide...', 'Đang viết nội dung...', 'Đang tạo file PowerPoint...', 'Đang hoàn thiện...'],
  lesson_plan: ['Đang phân tích chủ đề...', 'Đang thiết kế cấu trúc...', 'Đang viết nội dung...', 'Đang hoàn thiện...'],
  outline:     ['Đang phân tích chủ đề...', 'Đang tạo dàn ý...', 'Đang hoàn thiện...']
};

var _coRingCtrl = null;

function makeCoProgressRing(phases) {
  var cid = 'co-ring-container';
  var totalPhases = phases.length;
  var phase = 0, pct = 0, timer = null;
  document.getElementById(cid).innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
      '<span id="co-ring-pct" style="font-size:13px;font-weight:800;color:#7c3aed;letter-spacing:-0.3px;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#ede9fe" stroke-width="6"/>',
          '<circle id="co-ring-arc" cx="44" cy="44" r="38" stroke="#7c3aed" stroke-width="6" stroke-linecap="round"',
            'stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
          '<svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">',
            '<rect x="0" y="0" width="36" height="36" rx="9" fill="#1A6BFF"/>',
            '<polygon points="10,24 6,31 16,24" fill="white"/>',
            '<rect x="6" y="6" width="24" height="19" rx="5" fill="white"/>',
            '<rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/>',
            '<rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/>',
            '<rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/>',
          '</svg>',
        '</div>',
      '</div>',
      '<p id="co-ring-phase" style="font-size:12px;font-weight:600;color:#6366f1;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');

  var ring  = document.getElementById('co-ring-arc');
  var pctEl = document.getElementById('co-ring-pct');
  var phEl  = document.getElementById('co-ring-phase');
  var milestones = phases.map(function(_, i) { return Math.round(((i + 1) / totalPhases) * 85); });

  function setProgress(p) {
    ring.style.strokeDashoffset = 238.8 * (1 - p / 100);
    pctEl.textContent = Math.round(p) + '%';
  }

  timer = setInterval(function() {
    var target = milestones[phase] || 85;
    pct = Math.min(pct + 1, target);
    setProgress(pct);
    if (pct >= (milestones[phase] || 85) && phase < totalPhases - 1) {
      phase++;
      phEl.textContent = phases[phase];
    }
    if (pct >= 85 && phase >= totalPhases - 1) {
      clearInterval(timer);
      timer = setInterval(function() {
        if (pct >= 98) { clearInterval(timer); return; }
        pct = Math.min(pct + 0.4, 98);
        setProgress(pct);
      }, 3000);
    }
  }, 300);

  return {
    finish: function() { clearInterval(timer); ring.style.strokeDashoffset = '0'; pctEl.textContent = '100%'; }
  };
}

async function runCoGenerate() {
  var form = document.getElementById('co-form');
  var title = form.querySelector('[name="content_outline[title]"]').value.trim();
  if (!title) { form.querySelector('[name="content_outline[title]"]').focus(); return; }

  var type = form.querySelector('[name="content_outline[output_type]"]:checked')?.value || 'outline';
  var phases = CO_PHASES_BY_TYPE[type] || CO_PHASES_BY_TYPE.outline;

  document.getElementById('ai-submit-btn').disabled = true;
  document.getElementById('co-overlay').style.display = 'flex';
  _coRingCtrl = makeCoProgressRing(phases);

  var formData = new FormData(form);
  formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

  try {
    var res = await fetch('<%= content_outlines_path %>', {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    });
    var data = await res.json();
    if (data.error) {
      document.getElementById('ai-submit-btn').disabled = false;
      if (handleAiError(data, res)) return;
      showCoError(data.error); return;
    }
    if (data.pending) {
      setTimeout(function() { pollCoStatus(data.poll_url, data.show_url); }, 2000);
    } else {
      if (_coRingCtrl) _coRingCtrl.finish();
      window.location.href = data.show_url;
    }
  } catch(e) {
    showCoError(e.message);
  }
}

function pollCoStatus(pollUrl, showUrl) {
  fetch(pollUrl, { headers: { 'Accept': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.failed) {
        showCoError('AI gặp lỗi khi tạo nội dung. Vui lòng thử lại.');
      } else if (data.pending) {
        setTimeout(function() { pollCoStatus(pollUrl, showUrl); }, 2500);
      } else {
        if (_coRingCtrl) _coRingCtrl.finish();
        setTimeout(function() { window.location.href = showUrl; }, 400);
      }
    })
    .catch(function() { setTimeout(function() { pollCoStatus(pollUrl, showUrl); }, 3000); });
}

function showCoError(msg) {
  document.getElementById('co-overlay').style.display = 'none';
  document.getElementById('ai-submit-btn').disabled = false;
  document.getElementById('co-error-msg').textContent = msg;
  document.getElementById('co-error-box').style.display = 'flex';
}

document.addEventListener('turbo:before-cache', function() {
  document.getElementById('co-overlay').style.display = 'none';
  document.getElementById('ai-submit-btn').disabled = false;
});
</script>
