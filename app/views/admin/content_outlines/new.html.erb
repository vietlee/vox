<% content_for :title, t("content_outline.new_title") %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">🖥️ <%= t("content_outline.new_title") %></h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @outline, url: content_outlines_path, local: true, id: "co-form" do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Tiêu đề / Chủ đề *</label>
        <%= f.text_field :title, required: true,
            placeholder: "VD: Phương trình bậc hai, Marketing Digital, Lịch sử VN...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Lĩnh vực / Ngành</label>
        <%= f.text_field :subject,
            placeholder: "VD: Marketing, Công nghệ, Tài chính, Y tế...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>

      <%= f.hidden_field :output_type, value: "slide" %>

      <!-- File upload -->
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">
          Tài liệu tham khảo <span class="text-slate-400 font-normal normal-case">(tuỳ chọn — PDF, DOCX, TXT)</span>
        </label>
        <div id="co-file-drop"
             onclick="document.getElementById('co-file-input').click()"
             style="border:1.5px dashed #b3cbe3;border-radius:12px;padding:18px 20px;cursor:pointer;display:flex;align-items:center;gap:12px;background:#f8fbff;transition:border-color .2s,background .2s;">
          <svg width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="#4a80a8" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1M12 12V3m0 0l-3 3m3-3l3 3"/></svg>
          <div>
            <p id="co-file-label" style="font-size:13px;font-weight:600;color:#1e3a5f;margin:0;">Chọn hoặc kéo thả file</p>
            <p style="font-size:11px;color:#94a3b8;margin:2px 0 0;">AI sẽ đọc tài liệu và dùng nội dung để tạo slide chính xác hơn</p>
          </div>
          <input type="file" id="co-file-input" accept=".pdf,.docx,.doc,.txt" style="display:none">
        </div>
        <div id="co-file-status" style="display:none;margin-top:8px;font-size:12px;color:#64748b;display:flex;align-items:center;gap:6px;"></div>
        <%= f.hidden_field :source_document_text, id: "co-doc-text-hidden" %>
      </div>

      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide">Mong muốn của bạn</label>
        <!-- Hidden field that gets submitted -->
        <%= f.hidden_field :prompt_input, id: "prompt_input_hidden" %>
        <!-- Quill editor wrapper — toolbar + editor as one unified box -->
        <div id="prompt-quill-wrap" style="border:1px solid #e2e8f0;border-radius:12px;overflow:hidden;background:#fff;">
          <div id="prompt-quill-editor" style="min-height:200px;font-size:14px;"></div>
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-xl px-4 py-3 flex items-center gap-2 text-[13px] text-amber-700">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Sử dụng <strong class="mx-1">5 AI Credits</strong> để tạo nội dung
      </div>

      <div id="co-error" class="hidden bg-red-50 border border-red-200 text-red-700 text-[13px] rounded-xl px-4 py-3"></div>

      <div class="flex gap-2 pt-1">
        <button type="button" id="ai-submit-btn" onclick="runCoGenerate()"
                class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors border-0">
          ✨ Tạo với AI
        </button>
        <%= link_to "Hủy", content_outlines_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>

<!-- Meta-analysis overlay — shown while suggest_meta AI call runs -->
<div id="co-meta-overlay"
     style="display:none; position:fixed; inset:0; z-index:9998; align-items:center; justify-content:center;
            background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);">
  <div style="background:#fff; border-radius:20px; padding:36px 44px; text-align:center;
              box-shadow:0 20px 60px rgba(0,0,0,0.22); max-width:300px; width:90%;">
    <div style="margin-bottom:18px;">
      <svg width="48" height="48" viewBox="0 0 48 48" fill="none" style="display:inline-block;">
        <circle cx="24" cy="24" r="22" stroke="#e2e8f0" stroke-width="4"/>
        <circle cx="24" cy="24" r="22" stroke="#1e3a5f" stroke-width="4"
                stroke-dasharray="138" stroke-dashoffset="100"
                style="transform-origin:center;animation:co-spin 1.2s linear infinite;"/>
      </svg>
    </div>
    <p style="font-size:15px;font-weight:700;color:#1e3a5f;margin:0 0 6px;">Đang phân tích tài liệu...</p>
    <p style="font-size:12px;color:#94a3b8;margin:0;">AI đang đề xuất tiêu đề và lĩnh vực phù hợp</p>
  </div>
</div>

<!-- Loading overlay — same style as quiz_sets -->
<div id="co-overlay"
     style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center;
            background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center;
              box-shadow:0 20px 60px rgba(0,0,0,0.22); max-width:320px; width:90%; position:relative;">
    <button onclick="coMinimize()" title="Thu nhỏ — tiếp tục làm việc khác" data-navy-hover="1"
            style="position:absolute;top:12px;right:12px;display:flex;align-items:center;gap:5px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:5px 11px;font-size:11px;font-weight:700;cursor:pointer;color:#1e3a5f;transition:background .15s,border-color .15s;"
            onmouseenter="this.style.background='#e8f0f8';this.style.borderColor='#b3cbe3'" onmouseleave="this.style.background='#fff';this.style.borderColor='#e2e8f0'">
      <svg width="12" height="3" viewBox="0 0 12 3" fill="none"><rect y="0.5" width="12" height="2" rx="1" fill="#1e3a5f"/></svg>
      Thu nhỏ
    </button>
    <div id="co-ring-container"></div>
    <p style="font-size:11px; color:#94A3B8; margin:12px 0 0;">Nhấn <strong style="color:#1e3a5f">Thu nhỏ</strong> để tiếp tục làm việc.</p>
  </div>
</div>

<div id="co-error-box" style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center; background:rgba(15,23,42,0.65);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center; max-width:320px; width:90%;">
    <div style="font-size:2rem; margin-bottom:12px;">⚠️</div>
    <p id="co-error-msg" style="font-size:14px; color:#ef4444; margin:0 0 16px;"></p>
    <button onclick="document.getElementById('co-error-box').style.display='none'; document.getElementById('ai-submit-btn').disabled=false;"
            style="padding:8px 20px; background:#1e3a5f; color:#fff; border:0; border-radius:10px; font-size:13px; font-weight:700; cursor:pointer;">
      Đóng
    </button>
  </div>
</div>

<style>
@keyframes vox-pulse {
  0%,100% { transform:scale(1); opacity:1; }
  50%      { transform:scale(0.88); opacity:0.75; }
}
@keyframes co-spin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* Quill: merge toolbar + editor into one box */
#prompt-quill-wrap .ql-toolbar {
  border: none;
  border-bottom: 1px solid #e2e8f0;
  border-radius: 0;
  background: #f8fafc;
  padding: 6px 10px;
}
#prompt-quill-wrap .ql-container {
  border: none;
  border-radius: 0;
  font-size: 14px;
  font-family: inherit;
}
#prompt-quill-wrap .ql-editor {
  min-height: 200px;
  padding: 12px 14px;
  color: #334155;
  line-height: 1.7;
}
#prompt-quill-wrap .ql-editor.ql-blank::before {
  color: #94a3b8;
  font-style: normal;
  font-size: 13px;
  line-height: 1.7;
  white-space: pre-wrap;
}
/* Focus ring on wrapper */
#prompt-quill-wrap:focus-within {
  border-color: #1e3a5f;
  box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
</style>

<script>
var CO_SLIDE_PHASES = ['Đang phân tích chủ đề...', 'Đang tạo cấu trúc slide...', 'Đang viết nội dung...', 'Đang tạo file PowerPoint...', 'Đang hoàn thiện...'];

var _coRingCtrl = null;

function makeCoProgressRing(phases) {
  var cid = 'co-ring-container';
  var totalPhases = phases.length;
  var phase = 0, pct = 0, timer = null;
  document.getElementById(cid).innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
      '<span id="co-ring-pct" style="font-size:13px;font-weight:800;color:#1e3a5f;letter-spacing:-0.3px;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#d9e5f1" stroke-width="6"/>',
          '<circle id="co-ring-arc" cx="44" cy="44" r="38" stroke="#1e3a5f" stroke-width="6" stroke-linecap="round"',
            'stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
          '<img src="/icon-mark.svg" width="40" height="40" alt="VOX" style="display:block;">',
        '</div>',
      '</div>',
      '<p id="co-ring-phase" style="font-size:12px;font-weight:600;color:#1e3a5f;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');

  var ring  = document.getElementById('co-ring-arc');
  var pctEl = document.getElementById('co-ring-pct');
  var phEl  = document.getElementById('co-ring-phase');
  var milestones = phases.map(function(_, i) { return Math.round(((i + 1) / totalPhases) * 85); });

  function setProgress(p) {
    ring.style.strokeDashoffset = 238.8 * (1 - p / 100);
    pctEl.textContent = Math.round(p) + '%';
  }

  timer = setInterval(function() {
    var target = milestones[phase] || 85;
    pct = Math.min(pct + 1, target);
    setProgress(pct);
    if (pct >= (milestones[phase] || 85) && phase < totalPhases - 1) {
      phase++;
      phEl.textContent = phases[phase];
    }
    if (pct >= 85 && phase >= totalPhases - 1) {
      clearInterval(timer);
      timer = setInterval(function() {
        if (pct >= 98) { clearInterval(timer); return; }
        pct = Math.min(pct + 0.4, 98);
        setProgress(pct);
      }, 3000);
    }
  }, 300);

  return {
    finish:     function() { clearInterval(timer); ring.style.strokeDashoffset = '0'; pctEl.textContent = '100%'; },
    currentPct: function() { return Math.round(pct); }
  };
}

async function runCoGenerate() {
  var form = document.getElementById('co-form');
  var title = form.querySelector('[name="content_outline[title]"]').value.trim();
  if (!title) { markFieldError(form.querySelector('[name="content_outline[title]"]')); return; }

  var phases = CO_SLIDE_PHASES;

  document.getElementById('ai-submit-btn').disabled = true;
  document.getElementById('co-overlay').style.display = 'flex';
  _coRingCtrl = makeCoProgressRing(phases);

  var formData = new FormData(form);
  formData.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

  try {
    var res = await fetch('<%= content_outlines_path %>', {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: formData
    });
    var data = await res.json();
    if (data.error) {
      document.getElementById('ai-submit-btn').disabled = false;
      if (handleAiError(data, res)) return;
      showCoError(data.error); return;
    }
    if (data.pending) {
      setTimeout(function() { pollCoStatus(data.poll_url, data.show_url); }, 2000);
    } else {
      if (_coRingCtrl) _coRingCtrl.finish();
      window.location.href = data.show_url;
    }
  } catch(e) {
    showCoError(e.message);
  }
}

var _coPollUrl = null, _coShowUrl = null;

function pollCoStatus(pollUrl, showUrl) {
  _coPollUrl = pollUrl; _coShowUrl = showUrl;
  var overlay = document.getElementById('co-overlay');
  if (overlay && overlay.style.display === 'none') return; // minimized
  fetch(pollUrl, { headers: { 'Accept': 'application/json' } })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.failed) {
        showCoError('AI gặp lỗi khi tạo nội dung. Vui lòng thử lại.');
      } else if (data.pending) {
        setTimeout(function() { pollCoStatus(pollUrl, showUrl); }, 2500);
      } else {
        if (_coRingCtrl) _coRingCtrl.finish();
        setTimeout(function() { window.location.href = showUrl; }, 400);
      }
    })
    .catch(function() { setTimeout(function() { pollCoStatus(pollUrl, showUrl); }, 3000); });
}

function coMinimize() {
  document.getElementById('co-overlay').style.display = 'none';
  if (window.VoxTaskManager && _coPollUrl) {
    var titleVal = document.querySelector('[name="content_outline[title]"]');
    VoxTaskManager.add({
      id:           'co-new',
      icon:         '✍️',
      label:        'Tạo Slide AI',
      title:        titleVal ? titleVal.value : 'Slide mới',
      poll_url:     _coPollUrl,
      redirect_url: _coShowUrl,
      pct:          _coRingCtrl ? _coRingCtrl.currentPct() : 0
    });
  }
}

function showCoError(msg) {
  document.getElementById('co-overlay').style.display = 'none';
  document.getElementById('ai-submit-btn').disabled = false;
  document.getElementById('co-error-msg').textContent = msg;
  document.getElementById('co-error-box').style.display = 'flex';
}

document.addEventListener('turbo:before-cache', function() {
  document.getElementById('co-overlay').style.display = 'none';
  document.getElementById('ai-submit-btn').disabled = false;
});

// Init Quill for prompt_input
(function initPromptQuill() {
  var PLACEHOLDER = 'Ví dụ: Tôi muốn tạo 1 bộ slide khoảng 10 trang để thuyết trình cho nhóm sales về chiến lược Q3.\nNgười xem là nhân viên kinh doanh, cần ngắn gọn và thực chiến.\nNhấn mạnh vào số liệu và action steps cụ thể.\nTone năng lượng, tránh học thuật.';

  function waitForQuill(cb) {
    if (typeof Quill !== 'undefined') { cb(); }
    else { setTimeout(function() { waitForQuill(cb); }, 80); }
  }

  waitForQuill(function() {
    var q = new Quill('#prompt-quill-editor', {
      theme: 'snow',
      placeholder: PLACEHOLDER,
      modules: {
        toolbar: [
          ['bold', 'italic', 'underline'],
          [{ list: 'ordered' }, { list: 'bullet' }],
          ['clean']
        ]
      }
    });

    // Pre-fill from suggested_prompt URL param (e.g. from document summary shortcut)
    var suggestedPrompt = <%= raw params[:suggested_prompt].to_s.to_json %>;
    var titleField   = document.querySelector('[name="content_outline[title]"]');
    var subjectField = document.querySelector('[name="content_outline[subject]"]');

    if (suggestedPrompt) {
      q.setText(suggestedPrompt);
      document.getElementById('prompt_input_hidden').value = q.root.innerHTML;

      // AI auto-suggest title + subject if not already filled
      var needsMeta = !titleField.value.trim() || !subjectField.value.trim();
      if (needsMeta) {
        var csrf = document.querySelector('meta[name="csrf-token"]').content;
        var fd = new FormData();
        fd.append('content', suggestedPrompt);
        fd.append('authenticity_token', csrf);

        // Show full-screen analysis overlay
        var metaOverlay = document.getElementById('co-meta-overlay');
        if (metaOverlay) metaOverlay.style.display = 'flex';

        fetch('<%= ai_suggest_meta_path %>', { method: 'POST', body: fd })
          .then(function(r) { return r.json(); })
          .then(function(d) {
            if (d.title   && !titleField.value.trim())   titleField.value   = d.title;
            if (d.subject && !subjectField.value.trim()) subjectField.value = d.subject;
          })
          .catch(function() {})
          .finally(function() {
            if (metaOverlay) metaOverlay.style.display = 'none';
          });
      }
    }

    // Sync to hidden field on every change
    q.on('text-change', function() {
      document.getElementById('prompt_input_hidden').value = q.root.innerHTML;
    });

    // Also sync before form submit
    var form = document.getElementById('co-form');
    form.addEventListener('submit', function() {
      document.getElementById('prompt_input_hidden').value = q.root.innerHTML;
    });
  });
})();

// ── File upload & extract ──────────────────────────────────────────────────
(function() {
  var fileInput  = document.getElementById('co-file-input');
  var dropZone   = document.getElementById('co-file-drop');
  var fileLabel  = document.getElementById('co-file-label');
  var statusEl   = document.getElementById('co-file-status');
  var hiddenText = document.getElementById('co-doc-text-hidden');

  function setStatus(icon, msg, color) {
    statusEl.innerHTML = '<span>'+icon+'</span><span style="color:'+color+'">'+msg+'</span>';
    statusEl.style.display = 'flex';
  }

  function handleFile(file) {
    if (!file) return;
    var allowed = ['.pdf','.docx','.doc','.txt'];
    var ext = file.name.slice(file.name.lastIndexOf('.')).toLowerCase();
    if (!allowed.includes(ext)) {
      setStatus('⚠️', 'Chỉ hỗ trợ PDF, DOCX, DOC, TXT', '#ef4444'); return;
    }
    fileLabel.textContent = '📄 ' + file.name;
    setStatus('⏳', 'Đang đọc tài liệu...', '#64748b');

    var fd = new FormData();
    fd.append('file', file);
    fd.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

    fetch('<%= extract_text_content_outlines_path %>', { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.error) { setStatus('❌', data.error, '#ef4444'); hiddenText.value = ''; return; }
        hiddenText.value = data.text;
        setStatus('✅', 'Đã đọc xong — AI sẽ dùng nội dung này khi tạo slide', '#16a34a');
        dropZone.style.borderColor = '#22c55e';
        dropZone.style.background  = '#f0fdf4';
      })
      .catch(function() { setStatus('❌', 'Lỗi khi đọc file, thử lại', '#ef4444'); });
  }

  fileInput.addEventListener('change', function() { handleFile(this.files[0]); });

  dropZone.addEventListener('dragover', function(e) {
    e.preventDefault(); dropZone.style.borderColor = '#1e3a5f'; dropZone.style.background = '#eef3f9';
  });
  dropZone.addEventListener('dragleave', function() {
    dropZone.style.borderColor = '#b3cbe3'; dropZone.style.background = '#f8fbff';
  });
  dropZone.addEventListener('drop', function(e) {
    e.preventDefault();
    dropZone.style.borderColor = '#b3cbe3'; dropZone.style.background = '#f8fbff';
    handleFile(e.dataTransfer.files[0]);
  });
})();
</script>
