<% content_for :title, t("content_outline.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-center justify-between mb-4">
    <div class="flex items-center gap-3">
      <%= render "admin/shared/back_btn" %>
      <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[28px] bg-slate-100 shrink-0">🖥️</div>
      <div>
        <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight"><%= t("content_outline.title") %></h1>
        <p class="text-[13px] font-medium text-slate-600 mt-0.5"><%= t("content_outline.subtitle") %></p>
      </div>
    </div>
    <%= link_to new_content_outline_path, class: "inline-flex items-center gap-1.5 px-4 py-2 rounded-xl text-[13px] font-bold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <%= t("content_outline.new") %>
    <% end %>
  </div>
</div>

<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <%= form_with url: content_outlines_path, method: :get, data: { turbo_action: "replace" }, class: "relative flex-1 max-w-sm" do |f| %>
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/></svg>
        <%= f.text_field :q, value: params[:q], placeholder: t("content_outline.search_placeholder"),
            class: "w-full pl-8 pr-3 py-1.5 text-[13px] border border-slate-200 rounded-lg focus:border-indigo-400 outline-none bg-white",
            oninput: "clearTimeout(this._t);this._t=setTimeout(()=>this.closest('form').requestSubmit(),300)" %>
      <% end %>
      <span class="text-[11px] text-slate-400 ml-auto"><%= t("content_outline.count_label", count: @outlines.count) %></span>
    </div>

    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @outlines.any? %>
        <table class="w-full border-collapse">
          <thead>
            <tr class="border-b border-slate-200" style="position:sticky;top:0;z-index:1;background:rgba(248,250,252,0.97);">
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("content_outline.th_title") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("content_outline.th_type") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("content_outline.th_status") %></th>
              <th class="text-left text-[11px] font-semibold text-slate-500 uppercase tracking-[0.5px] px-4 py-2.5"><%= t("content_outline.th_created") %></th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody>
            <tr id="co-no-results" class="hidden">
              <td colspan="5" class="px-4 py-10 text-center text-[13px] text-slate-400">Không tìm thấy kết quả</td>
            </tr>
            <% @outlines.each do |o| %>
              <% type_label = {"outline"=>"📋 Dàn ý","slide"=>"🖥️ Slide","slide_script"=>"🖥️ Slide","lesson_plan"=>"📚 Kế hoạch"}[o.output_type] || "📄 Nội dung" %>
              <tr class="co-row border-b border-slate-200 hover:bg-white/70 transition-colors"
                  data-title="<%= o.title.downcase %>">
                <td class="px-4 py-3">
                  <%= link_to o.title, content_outline_path(o),
                      class: "text-[13px] font-semibold text-slate-800 hover:text-indigo-600 transition-colors" %>
                </td>
                <td class="px-4 py-3 text-[12px] text-slate-500"><%= type_label %></td>
                <td class="px-4 py-3">
                  <% if o.done? %>
                    <span class="text-[11px] font-bold text-emerald-600"><%= t("content_outline.status_done") %></span>
                  <% elsif o.pending? %>
                    <span class="text-[11px] font-semibold text-amber-500"><%= t("content_outline.status_generating") %></span>
                  <% else %>
                    <span class="text-[11px] font-semibold text-red-500"><%= t("content_outline.status_failed") %></span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-[12px] text-slate-400"><%= o.created_at.strftime("%d/%m %H:%M") %></td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-1 justify-end">
                    <%= link_to content_outline_path(o),
                        class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-slate-200 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-slate-500 hover:text-white text-[12px] font-semibold rounded-lg transition-colors" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                      <%= t("content_outline.btn_view") %>
                    <% end %>
                    <%= button_to regenerate_content_outline_path(o), method: :post,
                        class: "inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-slate-200 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-slate-500 hover:text-white text-[12px] font-semibold rounded-lg transition-colors cursor-pointer" do %>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                      <%= t("content_outline.btn_recreate") %>
                    <% end %>
                    <button type="button" onclick="confirmDelete('<%= content_outline_path(o) %>', '<%= j o.title %>')"
                            class="inline-flex items-center gap-1 px-2.5 py-1.5 bg-white border border-red-100 hover:border-[#1e3a5f] hover:bg-[#1e3a5f] text-red-400 hover:text-white text-[12px] font-semibold rounded-lg transition-colors cursor-pointer">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      <%= t("content_outline.btn_delete") %>
                    </button>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="py-20 text-center">
          <div class="text-5xl mb-4">✍️</div>
          <h3 class="text-[15px] font-bold text-slate-700 mb-2"><%= t("content_outline.empty_title") %></h3>
          <p class="text-[13px] text-slate-400 mb-5"><%= t("content_outline.empty_desc") %></p>
          <%= link_to t("content_outline.create_first"), new_content_outline_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Delete modal -->
<div id="co-delete-modal" style="display:none; position:fixed; inset:0; z-index:60; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.5);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.18); width:100%; max-width:380px; padding:28px 24px;">
    <div style="width:48px; height:48px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg style="width:24px;height:24px;" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 style="font-size:16px; font-weight:800; color:#1E293B; text-align:center; margin:0 0 8px;"><%= t("content_outline.confirm_delete_title") %></h3>
    <p id="co-delete-desc" style="font-size:13px; color:#64748B; text-align:center; margin:0 0 20px;"></p>
    <div style="display:flex; gap:8px;">
      <button id="co-delete-btn" onclick="executeDelete()"
              style="flex:1; padding:11px; background:#EF4444; color:#fff; font-weight:700; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;"><%= t("common.delete") %></button>
      <button onclick="document.getElementById('co-delete-modal').style.display='none'"
              style="flex:1; padding:11px; background:#F1F5F9; color:#475569; font-weight:600; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;"><%= t("common.cancel") %></button>
    </div>
  </div>
</div>

<script>
let _coDeletePath = null;
function confirmDelete(path, title) {
  _coDeletePath = path;
  document.getElementById('co-delete-desc').textContent = 'Bạn sắp xóa "' + title + '". Hành động này không thể hoàn tác.';
  document.getElementById('co-delete-modal').style.display = 'flex';
}
function executeDelete() {
  if (!_coDeletePath) return;
  const btn = document.getElementById('co-delete-btn'); btn.disabled = true; btn.textContent = '...';
  const f = document.createElement('form'); f.method = 'POST'; f.action = _coDeletePath;
  const m = document.createElement('input'); m.type='hidden'; m.name='_method'; m.value='delete';
  const c = document.createElement('input'); c.type='hidden'; c.name='authenticity_token'; c.value=document.querySelector('meta[name="csrf-token"]').content;
  f.appendChild(m); f.appendChild(c); document.body.appendChild(f); f.submit();
}
function filterRows(input, rowClass, noResultId) {
  var q = input.value.toLowerCase();
  var rows = document.querySelectorAll('.' + rowClass);
  var found = 0;
  rows.forEach(function(r) { var show = !q || (r.dataset.title||'').includes(q); r.style.display = show ? '' : 'none'; if(show) found++; });
  document.getElementById(noResultId).classList.toggle('hidden', found > 0 || !q);
}
</script>
