<% content_for :title, "Tạo nội dung AI" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-[22px] font-extrabold text-slate-900">✍️ Tạo nội dung AI</h1>
    <p class="text-[13px] text-slate-500 mt-0.5">Tạo dàn ý, script slide, kế hoạch buổi học với AI</p>
  </div>
  <%= link_to new_content_outline_path, class: "flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
    Tạo nội dung mới
  <% end %>
</div>

<% if flash[:notice] %>
  <div class="mb-4 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 text-[13px] font-semibold flex items-center gap-2">
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    <%= flash[:notice] %>
  </div>
<% end %>

<% if @outlines.empty? %>
  <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
    <div class="text-5xl mb-4">✍️</div>
    <h3 class="text-[16px] font-bold text-slate-700 mb-2">Chưa có nội dung nào</h3>
    <p class="text-[13px] text-slate-400 mb-6">Tạo dàn ý, slide, kế hoạch buổi học nhanh chóng với AI</p>
    <%= link_to "Tạo nội dung đầu tiên", new_content_outline_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" %>
  </div>
<% else %>
  <div class="space-y-3">
    <% @outlines.each do |o| %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-4 flex items-center gap-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 <%= o.done? ? 'bg-indigo-50' : o.pending? ? 'bg-amber-50' : 'bg-red-50' %>">
          <span class="text-xl"><%= { "outline" => "📋", "slide_script" => "🖥️", "lesson_plan" => "📚" }[o.output_type] || "📄" %></span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-0.5 flex-wrap">
            <%= link_to o.title, content_outline_path(o), class: "text-[14px] font-bold text-slate-900 hover:text-indigo-600 truncate transition-colors" %>
            <% if o.done? %>
              <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-emerald-100 text-emerald-700">Hoàn thành</span>
            <% elsif o.pending? %>
              <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-amber-100 text-amber-700">Đang tạo...</span>
            <% else %>
              <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-red-100 text-red-600">Thất bại</span>
            <% end %>
          </div>
          <div class="flex items-center gap-3 text-[12px] text-slate-400">
            <span><%= { "outline" => "📋 Dàn ý", "slide_script" => "🖥️ Script Slide", "lesson_plan" => "📚 Kế hoạch" }[o.output_type] || "Nội dung" %></span>
            <% if o.subject.present? %><span>· <%= o.subject %></span><% end %>
            <span>· <%= o.created_at.strftime("%d/%m/%Y") %></span>
          </div>
        </div>
        <div class="flex items-center gap-1 flex-shrink-0">
          <%= link_to content_outline_path(o), title: "Xem nội dung",
              class: "p-2 text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition-colors" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          <% end %>
          <%= button_to regenerate_content_outline_path(o), method: :post, title: "Tạo lại",
              class: "p-2 text-slate-400 hover:text-violet-600 hover:bg-violet-50 rounded-lg transition-colors border-0 bg-transparent cursor-pointer" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          <% end %>
          <button type="button" onclick="confirmDeleteOutline('<%= content_outline_path(o) %>', '<%= j o.title %>')"
                  class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors border-0 bg-transparent cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<!-- Delete confirm modal -->
<div id="outline-delete-modal" style="display:none; position:fixed; inset:0; z-index:60; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.5);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.18); width:100%; max-width:380px; padding:28px 24px;">
    <div style="width:48px; height:48px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg style="width:24px;height:24px;" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 style="font-size:16px; font-weight:800; color:#1E293B; text-align:center; margin:0 0 8px;">Xóa nội dung?</h3>
    <p id="outline-delete-desc" style="font-size:13px; color:#64748B; text-align:center; margin:0 0 20px;"></p>
    <div style="display:flex; gap:8px;">
      <button id="outline-delete-btn" onclick="executeDeleteOutline()"
              style="flex:1; padding:11px; background:#EF4444; color:#fff; font-weight:700; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Xóa</button>
      <button onclick="document.getElementById('outline-delete-modal').style.display='none'"
              style="flex:1; padding:11px; background:#F1F5F9; color:#475569; font-weight:600; font-size:13px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">Hủy</button>
    </div>
  </div>
</div>

<script>
let _outlineDeletePath = null;
function confirmDeleteOutline(path, title) {
  _outlineDeletePath = path;
  document.getElementById('outline-delete-desc').textContent = 'Bạn sắp xóa "' + title + '". Hành động này không thể hoàn tác.';
  document.getElementById('outline-delete-modal').style.display = 'flex';
}
function executeDeleteOutline() {
  if (!_outlineDeletePath) return;
  const btn = document.getElementById('outline-delete-btn');
  btn.disabled = true; btn.textContent = '...';
  const form = document.createElement('form');
  form.method = 'POST'; form.action = _outlineDeletePath;
  const m = document.createElement('input'); m.type='hidden'; m.name='_method'; m.value='delete';
  const c = document.createElement('input'); c.type='hidden'; c.name='authenticity_token'; c.value=document.querySelector('meta[name="csrf-token"]').content;
  form.appendChild(m); form.appendChild(c);
  document.body.appendChild(form); form.submit();
}
</script>
