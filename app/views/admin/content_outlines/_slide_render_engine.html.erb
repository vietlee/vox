      areaPath += ' L '+pts[pts.length-1].x+','+baseY+' Z';
      svgContent += '<path d="'+areaPath+'" fill="'+accent+'" opacity="0.08"/>';
      /* Line */
      var linePath = pts.map(function(p,i){ return (i===0?'M ':'L ')+p.x.toFixed(1)+' '+p.y.toFixed(1); }).join(' ');
