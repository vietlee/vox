      var circ = 2 * Math.PI * r;
      var strokeW = Math.round(r * 0.42);
      var offset = 0, slices = '', pctLabels = '';
      var pcts = [];
      data.forEach(function(d, i) {
        var pct = (parseFloat(d.value)||0) / total_val;
        pcts.push(pct);
        var dash = pct * circ;
        var c = colors[i % colors.length];
        var rot = -90 + offset * 360;
        slices += '<circle cx="'+cx+'" cy="'+cy+'" r="'+r+'" fill="none" stroke="'+c+'"'+
          ' stroke-width="'+strokeW+'" stroke-dasharray="'+dash.toFixed(1)+' '+circ.toFixed(1)+'"'+
          ' stroke-dashoffset="0" transform="rotate('+rot.toFixed(1)+' '+cx+' '+cy+')"/>';
