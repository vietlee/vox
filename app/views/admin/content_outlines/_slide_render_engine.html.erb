      }
      /* Axes */
      svgContent += '<line x1="'+padLeft+'" y1="'+padTop+'" x2="'+padLeft+'" y2="'+(padTop+chartH)+'" stroke="#CBD5E1" stroke-width="1"/>';
      svgContent += '<line x1="'+padLeft+'" y1="'+(padTop+chartH)+'" x2="'+(padLeft+chartW)+'" y2="'+(padTop+chartH)+'" stroke="#CBD5E1" stroke-width="1"/>';
