        svgContent += '<text x="'+(padLeft + chartW)+'" y="'+(padTop + chartH + 22)+'" text-anchor="end" font-size="8.5" fill="#94A3B8" font-family="Inter,sans-serif" font-style="italic">'+escHtml(xLabel)+'</text>';
      }

      /* ── Bars ── */
      var barW = Math.max(8, Math.floor((chartW * 0.75) / n));
