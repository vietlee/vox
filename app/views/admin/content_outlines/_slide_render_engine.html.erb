          var xa = cx + rAnchor * Math.cos(midAngle);
          var ya = cy + rAnchor * Math.sin(midAngle);
          var anchor = Math.cos(midAngle) > 0.1 ? 'start' : Math.cos(midAngle) < -0.1 ? 'end' : 'middle';
          var pctStr = Math.round(pct*1000)/10 + '%';
          var fs = Math.max(9, Math.round(sz * 0.052));
