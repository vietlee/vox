        svgContent += '<text x="'+p.x.toFixed(1)+'" y="'+(p.y-8).toFixed(1)+'" text-anchor="middle" font-size="9" font-weight="700" fill="'+accent+'" font-family="Inter,sans-serif">'+valStr+'</text>';
        /* X-axis label */
        var lx = padLeft + (n > 1 ? i / (n-1) : 0.5) * chartW;
        svgContent += '<text x="'+lx.toFixed(1)+'" y="'+(padTop+chartH+14)+'" text-anchor="middle" font-size="9" fill="#64748B" font-family="Inter,sans-serif">'+escHtml(data[i].label||'')+'</text>';
      });
      /* Axis labels */
      if (yLabel) svgContent += '<text x="'+padLeft+'" y="'+(padTop-8)+'" text-anchor="start" font-size="8.5" fill="#94A3B8" font-family="Inter,sans-serif" font-style="italic">'+escHtml(yLabel)+'</text>';
      if (xLabel) svgContent += '<text x="'+(padLeft+chartW)+'" y="'+(padTop+chartH+26)+'" text-anchor="end" font-size="8.5" fill="#94A3B8" font-family="Inter,sans-serif" font-style="italic">'+escHtml(xLabel)+'</text>';
