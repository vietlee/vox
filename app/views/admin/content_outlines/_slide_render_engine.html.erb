        (center_sub?'<text x="'+cx+'" y="'+(cy + fs_main*0.75)+'" text-anchor="middle" font-size="'+fs_sub+'" fill="#94A3B8" font-family="Inter,sans-serif">'+escHtml(center_sub)+'</text>':'')+
        '</svg>';
      return '<div class="slide-el" '+attrs+' style="position:absolute;left:'+x+'px;top:'+y+'px;width:'+w+'px;height:'+h+'px;z-index:'+z+';display:flex;align-items:center;justify-content:center;">'+svgPart+'</div>';
