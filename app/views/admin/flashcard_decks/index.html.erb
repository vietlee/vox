<% content_for :title, "Flashcards" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-[22px] font-extrabold text-slate-900">🃏 Flashcards</h1>
    <p class="text-[13px] text-slate-500 mt-0.5">Học và ghi nhớ với spaced repetition — ôn đúng lúc, nhớ lâu hơn</p>
  </div>
  <%= link_to new_flashcard_deck_path, class: "flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
    Tạo bộ thẻ
  <% end %>
</div>

<% if flash[:notice] %>
  <div class="mb-4 px-4 py-3 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 text-[13px] font-semibold flex items-center gap-2">
    <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    <%= flash[:notice] %>
  </div>
<% end %>

<% if @decks.empty? %>
  <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
    <div class="text-5xl mb-4">🃏</div>
    <h3 class="text-[16px] font-bold text-slate-700 mb-2">Chưa có bộ thẻ nào</h3>
    <p class="text-[13px] text-slate-400 mb-6">Tạo flashcard và ôn luyện theo phương pháp spaced repetition khoa học</p>
    <%= link_to "Tạo bộ thẻ đầu tiên", new_flashcard_deck_path, class: "inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" %>
  </div>
<% else %>
  <div class="grid grid-cols-3 gap-4">
    <% @decks.each do |deck| %>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 flex flex-col">
        <div class="flex items-start justify-between mb-3">
          <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-xl">🃏</div>
          <% if deck.ai_generated? %>
            <span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-violet-100 text-violet-700">✨ AI</span>
          <% end %>
        </div>
        <div class="text-[14px] font-bold text-slate-900 mb-0.5 line-clamp-2"><%= deck.title %></div>
        <div class="text-[12px] text-slate-400 mb-4">
          <%= deck.subject.presence || "Tổng hợp" %> · <%= deck.flashcards.count %> thẻ
        </div>
        <div class="mt-auto flex gap-2">
          <%= link_to study_flashcard_deck_path(deck), class: "flex-1 text-center px-3 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[12px] font-bold rounded-xl transition-colors" do %>
            📚 Học ngay
          <% end %>
          <%= link_to flashcard_deck_path(deck), class: "px-3 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[12px] font-semibold rounded-xl transition-colors" do %>
            Xem
          <% end %>
          <button type="button" onclick="confirmDeleteDeck('<%= flashcard_deck_path(deck) %>', '<%= j deck.title %>')"
                  class="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-colors border-0 bg-transparent cursor-pointer">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          </button>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<div id="deck-delete-modal" style="display:none; position:fixed; inset:0; z-index:60; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.5);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 40px rgba(0,0,0,0.18); width:100%; max-width:380px; padding:28px 24px;">
    <div style="width:48px; height:48px; border-radius:50%; background:#FEE2E2; display:flex; align-items:center; justify-content:center; margin:0 auto 16px;">
      <svg style="width:24px;height:24px;" fill="none" stroke="#EF4444" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </div>
    <h3 style="font-size:16px;font-weight:800;color:#1E293B;text-align:center;margin:0 0 8px;">Xóa bộ thẻ?</h3>
    <p id="deck-delete-desc" style="font-size:13px;color:#64748B;text-align:center;margin:0 0 20px;"></p>
    <div style="display:flex;gap:8px;">
      <button id="deck-delete-btn" onclick="executeDeleteDeck()" style="flex:1;padding:11px;background:#EF4444;color:#fff;font-weight:700;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;">Xóa</button>
      <button onclick="document.getElementById('deck-delete-modal').style.display='none'" style="flex:1;padding:11px;background:#F1F5F9;color:#475569;font-weight:600;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;">Hủy</button>
    </div>
  </div>
</div>
<script>
let _deckDeletePath = null;
function confirmDeleteDeck(path, title) {
  _deckDeletePath = path;
  document.getElementById('deck-delete-desc').textContent = 'Xóa "' + title + '" và toàn bộ thẻ. Không thể hoàn tác.';
  document.getElementById('deck-delete-modal').style.display = 'flex';
}
function executeDeleteDeck() {
  if (!_deckDeletePath) return;
  const btn = document.getElementById('deck-delete-btn');
  btn.disabled = true; btn.textContent = '...';
  const form = document.createElement('form'); form.method='POST'; form.action=_deckDeletePath;
  const m = document.createElement('input'); m.type='hidden'; m.name='_method'; m.value='delete';
  const c = document.createElement('input'); c.type='hidden'; c.name='authenticity_token'; c.value=document.querySelector('meta[name="csrf-token"]').content;
  form.appendChild(m); form.appendChild(c); document.body.appendChild(form); form.submit();
}
</script>
