<% content_for :title, "#{t('flashcard.edit_title')} – #{@deck.title}" %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">✏️ <%= t("flashcard.edit_title") %></h1>
</div>

<div class="max-w-xl bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @deck, url: flashcard_deck_path(@deck), method: :patch, local: true do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide"><%= t("flashcard.field_title") %> *</label>
        <%= f.text_field :title, required: true,
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide"><%= t("flashcard.field_subject") %></label>
        <%= f.text_field :subject,
            placeholder: t("flashcard.subject_placeholder"),
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div class="flex gap-2 pt-1">
        <%= f.submit t("flashcard.save_changes"), class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors border-0" %>
        <%= link_to t("common.cancel"), flashcard_deck_path(@deck), class: "px-5 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
