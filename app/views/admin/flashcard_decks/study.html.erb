<% content_for :title, "Học: #{@deck.title}" %>

<div class="min-h-screen bg-slate-50 flex flex-col items-center justify-center p-4">
  <div class="w-full max-w-xl">
    <div class="flex items-center justify-between mb-6">
      <%= link_to "← Quay lại", flashcard_deck_path(@deck), class: "text-[13px] text-slate-500 hover:text-slate-700" %>
      <div class="text-[12px] text-slate-500">🃏 <%= @deck.title %> · <span id="card-counter">1</span>/<%= @study_cards.size %></div>
    </div>

    <% if @study_cards.empty? %>
      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-12 text-center">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="text-[18px] font-bold text-slate-900">Bạn đã học xong hôm nay!</h2>
        <p class="text-[13px] text-slate-500 mt-2">Quay lại sau để ôn tiếp theo lịch.</p>
        <%= link_to flashcard_deck_path(@deck), class: "mt-4 inline-block px-6 py-3 bg-indigo-600 text-white text-[13px] font-bold rounded-xl" do %>Xem bộ thẻ<% end %>
      </div>
    <% else %>
      <!-- Flashcard -->
      <div class="relative" style="perspective:1200px">
        <div id="card-container" class="relative cursor-pointer" style="transform-style:preserve-3d;transition:transform 0.5s;height:260px" onclick="flipCard()">
          <!-- Front -->
          <div class="absolute inset-0 bg-white rounded-2xl border border-slate-200 shadow-lg p-8 flex items-center justify-center" style="backface-visibility:hidden">
            <p id="front-text" class="text-[18px] font-semibold text-slate-900 text-center leading-relaxed"></p>
          </div>
          <!-- Back -->
          <div class="absolute inset-0 bg-indigo-50 rounded-2xl border border-indigo-200 shadow-lg p-8 flex items-center justify-center" style="backface-visibility:hidden;transform:rotateY(180deg)">
            <p id="back-text" class="text-[16px] text-slate-700 text-center leading-relaxed"></p>
          </div>
        </div>
      </div>

      <!-- Rating buttons (hidden until flipped) -->
      <div id="rating-btns" class="hidden grid grid-cols-4 gap-2 mt-6">
        <button onclick="rate(0)" class="py-3 bg-red-100 hover:bg-red-200 text-red-700 text-[12px] font-bold rounded-xl border-0 cursor-pointer">
          ❌ Lại<div class="text-[10px] font-normal mt-0.5">&lt;1 min</div>
        </button>
        <button onclick="rate(1)" class="py-3 bg-orange-100 hover:bg-orange-200 text-orange-700 text-[12px] font-bold rounded-xl border-0 cursor-pointer">
          😓 Khó<div class="text-[10px] font-normal mt-0.5">&lt;10 min</div>
        </button>
        <button onclick="rate(2)" class="py-3 bg-blue-100 hover:bg-blue-200 text-blue-700 text-[12px] font-bold rounded-xl border-0 cursor-pointer">
          👍 Ổn<div class="text-[10px] font-normal mt-0.5">~<span id="good-days">1</span> ngày</div>
        </button>
        <button onclick="rate(3)" class="py-3 bg-emerald-100 hover:bg-emerald-200 text-emerald-700 text-[12px] font-bold rounded-xl border-0 cursor-pointer">
          ⭐ Dễ<div class="text-[10px] font-normal mt-0.5">~<span id="easy-days">2</span> ngày</div>
        </button>
      </div>

      <div class="text-center mt-4 text-[12px] text-slate-400">Nhấn thẻ để xem đáp án</div>
    <% end %>
  </div>
</div>

<script>
const cards = <%= raw @study_cards.map { |c| { id: c.id, front: c.front, back: c.back } }.to_json %>;
let current = 0;
let flipped = false;

function showCard(i) {
  if (i >= cards.length) {
    document.querySelector('[style*="perspective"]').innerHTML = '<div class="bg-white rounded-2xl border border-slate-200 shadow-lg p-12 text-center"><div class="text-5xl mb-4">🎉</div><h2 class="text-[18px] font-bold text-slate-900">Hoàn thành phiên học!</h2><a href="<%= flashcard_deck_path(@deck) %>" class="mt-4 inline-block px-6 py-3 bg-indigo-600 text-white text-[13px] font-bold rounded-xl">Xem bộ thẻ</a></div>';
    document.getElementById('rating-btns')?.remove();
    return;
  }
  const card = cards[i];
  document.getElementById('front-text').textContent = card.front;
  document.getElementById('back-text').textContent = card.back;
  document.getElementById('card-counter').textContent = i + 1;
  document.getElementById('card-container').style.transform = 'rotateY(0deg)';
  document.getElementById('rating-btns').classList.add('hidden');
  flipped = false;
}

function flipCard() {
  if (flipped) return;
  flipped = true;
  document.getElementById('card-container').style.transform = 'rotateY(180deg)';
  document.getElementById('rating-btns').classList.remove('hidden');
}

function rate(rating) {
  const card = cards[current];
  fetch('<%= review_flashcard_deck_path(@deck) %>', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content },
    body: JSON.stringify({ card_id: card.id, rating })
  }).then(() => {
    current++;
    showCard(current);
  });
}

showCard(0);
</script>
