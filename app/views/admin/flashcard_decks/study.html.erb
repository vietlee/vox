<% content_for :title, "Học: #{@deck.title}" %>
<% content_for :main_class, 'flex-1 overflow-y-auto bg-slate-50' %>
<meta name="turbo-visit-control" content="reload">

<div class="min-h-full flex flex-col items-center justify-center p-6">
  <div class="w-full max-w-xl">

    <!-- Header -->
    <div class="flex items-center gap-4 mb-8">
      <%= link_to flashcard_deck_path(@deck),
          class: "flex items-center gap-1.5 text-[13px] font-semibold text-slate-600 hover:text-slate-900 transition-colors flex-shrink-0 bg-white border border-slate-200 rounded-xl px-3 py-2 shadow-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        Quay lại
      <% end %>
      <div class="flex-1 min-w-0">
        <div class="text-[13px] font-bold text-slate-700 truncate"><%= @deck.title %></div>
        <div class="flex items-center gap-2 mt-1.5">
          <div class="flex-1 h-1.5 bg-slate-200 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-1.5 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-full transition-all duration-500" style="width:0%"></div>
          </div>
          <span id="card-counter" class="text-[11px] text-slate-500 font-bold flex-shrink-0 tabular-nums"></span>
        </div>
      </div>
    </div>

    <% if @study_cards.empty? %>
      <div class="bg-white rounded-3xl border border-slate-200 shadow-lg p-14 text-center">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="text-[22px] font-extrabold text-slate-900 mb-2">Học xong hôm nay!</h2>
        <p class="text-[13px] text-slate-500 mb-7">Hệ thống sẽ nhắc bạn ôn lại vào đúng thời điểm tốt nhất.</p>
        <%= link_to "← Xem bộ thẻ", flashcard_deck_path(@deck), class: "inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white text-[14px] font-bold rounded-2xl hover:bg-indigo-700 transition-colors" %>
      </div>
    <% else %>

      <!-- Card area — built entirely by JS -->
      <div id="card-area" class="mb-5"></div>

      <!-- TTS toggle -->
      <div class="flex justify-end mb-2">
        <button id="tts-btn" onclick="toggleTTS()" title="Bật/tắt đọc to"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[12px] font-semibold border transition-all"
                style="border-color:#e2e8f0; color:#64748b; background:#fff;">
          🔊 <span id="tts-label">Đọc to: Tắt</span>
        </button>
      </div>

      <!-- Rating buttons — hidden until flip -->
      <div id="rating-btns" class="mb-4" style="display:none;">
        <div class="grid grid-cols-4 gap-2.5">
          <button onclick="rate(0)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #fca5a5; color:#dc2626;">
            <span style="font-size:24px; margin-bottom:4px;">😵</span>
            <span style="font-size:12px; font-weight:700;">Quên</span>
            <span style="font-size:10px; color:#ef4444; margin-top:2px;">1 phút</span>
          </button>
          <button onclick="rate(1)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #fdba74; color:#ea580c;">
            <span style="font-size:24px; margin-bottom:4px;">😅</span>
            <span style="font-size:12px; font-weight:700;">Khó</span>
            <span style="font-size:10px; color:#f97316; margin-top:2px;">10 phút</span>
          </button>
          <button onclick="rate(2)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #93c5fd; color:#2563eb;">
            <span style="font-size:24px; margin-bottom:4px;">👍</span>
            <span style="font-size:12px; font-weight:700;">Ổn</span>
            <span style="font-size:10px; color:#3b82f6; margin-top:2px;">1 ngày</span>
          </button>
          <button onclick="rate(3)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #6ee7b7; color:#059669;">
            <span style="font-size:24px; margin-bottom:4px;">⭐</span>
            <span style="font-size:12px; font-weight:700;">Dễ</span>
            <span style="font-size:10px; color:#10b981; margin-top:2px;">2 ngày</span>
          </button>
        </div>
      </div>

      <div id="flip-hint" class="text-center">
        <span class="text-[12px] text-slate-400">Nhấn thẻ hoặc <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-[10px] font-mono shadow-sm">Space</kbd> để xem đáp án</span>
      </div>

    <% end %>
  </div>
</div>

<style>
@keyframes fadeInUp {
  from { opacity:0; transform:translateY(12px) scale(0.97); }
  to   { opacity:1; transform:translateY(0)    scale(1); }
}
.card-in { animation: fadeInUp 0.22s ease forwards; }
</style>

<script>
(function() {
  var DECK_REVIEW_PATH = '<%= review_flashcard_deck_path(@deck) %>';
  var DECK_PATH        = '<%= flashcard_deck_path(@deck) %>';
  var CSRF_TOKEN       = document.querySelector('meta[name="csrf-token"]').content;

  var cards = <%= raw @study_cards.map { |c| { id: c.id, front: c.front, back: c.back, image_data: c.image_data } }.to_json %>;
  var current = 0;
  var flipped = false;
  var ttsOn   = false;

  var GRADIENTS = [
    ['#667eea','#764ba2'],
    ['#4facfe','#00f2fe'],
    ['#43e97b','#38f9d7'],
    ['#f093fb','#f5576c'],
    ['#30cfd0','#667eea'],
    ['#a18cd1','#fbc2eb'],
  ];

  /* ── TTS ── */
  var _voices = [];
  function loadVoices() {
    _voices = window.speechSynthesis ? window.speechSynthesis.getVoices() : [];
  }
  if (window.speechSynthesis) {
    loadVoices();
    window.speechSynthesis.onvoiceschanged = loadVoices;
  }

  /* detect language: if ≥ 40% chars are ASCII letters → English */
  function detectLang(text) {
    var ascii = (text.match(/[a-zA-Z]/g) || []).length;
    return (ascii / text.replace(/\s/g,'').length) >= 0.4 ? 'en' : 'vi';
  }

  /* pick best available voice for a lang */
  function pickVoice(lang) {
    var voices = _voices.length ? _voices : (window.speechSynthesis ? window.speechSynthesis.getVoices() : []);
    if (lang === 'en') {
      /* prefer: Google US English > Microsoft > any en-US > any en */
      return voices.find(function(v){ return /google/i.test(v.name) && v.lang === 'en-US'; }) ||
             voices.find(function(v){ return /microsoft/i.test(v.name) && v.lang === 'en-US'; }) ||
             voices.find(function(v){ return v.lang === 'en-US'; }) ||
             voices.find(function(v){ return v.lang.startsWith('en'); }) ||
             null;
    } else {
      /* prefer: Google Vietnamese > any vi-VN > any vi */
      return voices.find(function(v){ return /google/i.test(v.name) && v.lang === 'vi-VN'; }) ||
             voices.find(function(v){ return v.lang === 'vi-VN'; }) ||
             voices.find(function(v){ return v.lang.startsWith('vi'); }) ||
             null;
    }
  }

  window.toggleTTS = function() {
    ttsOn = !ttsOn;
    var btn = document.getElementById('tts-btn');
    var lbl = document.getElementById('tts-label');
    if (ttsOn) {
      btn.style.borderColor = '#6366f1'; btn.style.color = '#4f46e5'; btn.style.background = '#eef2ff';
      lbl.textContent = 'Đọc to: Bật';
    } else {
      window.speechSynthesis && window.speechSynthesis.cancel();
      btn.style.borderColor = '#e2e8f0'; btn.style.color = '#64748b'; btn.style.background = '#fff';
      lbl.textContent = 'Đọc to: Tắt';
    }
  };

  function speak(text) {
    if (!ttsOn || !window.speechSynthesis) return;
    window.speechSynthesis.cancel();
    var lang = detectLang(text);
    var u = new SpeechSynthesisUtterance(text);
    var voice = pickVoice(lang);
    if (voice) u.voice = voice;
    u.lang  = lang === 'en' ? 'en-US' : 'vi-VN';
    u.rate  = lang === 'en' ? 0.92 : 0.85;  /* EN slightly faster, VI slower for clarity */
    u.pitch = 1.05;
    window.speechSynthesis.speak(u);
  }

  function makeCard(card, label, g1, g2, isBack) {
    var text = isBack ? card.back : card.front;
    var div = document.createElement('div');
    div.className = 'card-in';
    div.style.cssText = [
      isBack ? 'background:#fff;border:2px solid ' + g1 + '88' : 'background:linear-gradient(145deg,' + g1 + ',' + g2 + ')',
      'border-radius:28px',
      'overflow:hidden',
      'box-shadow:0 20px 60px ' + g1 + (isBack ? '22' : '55'),
      'display:flex',
      'flex-direction:column',
      'cursor:pointer',
      'user-select:none',
    ].join(';');

    /* header */
    var hdrBg = isBack ? 'rgba(0,0,0,.04)' : 'rgba(0,0,0,.15)';
    var hdrClr = isBack ? g1 : 'rgba(255,255,255,.8)';
    var header = document.createElement('div');
    header.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:13px 20px;border-bottom:1px solid ' + (isBack ? 'rgba(0,0,0,.07)' : 'rgba(255,255,255,.2)') + ';flex-shrink:0;';
    header.innerHTML =
      '<span style="font-size:10px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:' + hdrClr + ';">' + label + '</span>' +
      '<span style="font-size:11px;color:' + hdrClr + ';font-weight:600;opacity:.7;">' + (isBack ? '✓ Đáp án' : (current+1) + ' / ' + cards.length) + '</span>';

    div.appendChild(header);

    /* image — show prominently when present (front face only) */
    if (!isBack && card.image_data) {
      var imgWrap = document.createElement('div');
      imgWrap.style.cssText = 'flex-shrink:0;height:260px;overflow:hidden;position:relative;';
      var img = document.createElement('img');
      img.src = card.image_data;
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
      /* subtle gradient overlay at bottom so text reads on top of image */
      var grad = document.createElement('div');
      grad.style.cssText = 'position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(transparent,rgba(0,0,0,0.55));pointer-events:none;';
      imgWrap.appendChild(img);
      imgWrap.appendChild(grad);
      div.appendChild(imgWrap);
    }

    /* body text */
    var hasImg = !isBack && card.image_data;
    var body = document.createElement('div');
    body.style.cssText = 'flex:1;display:flex;align-items:center;justify-content:center;padding:' + (hasImg ? '16px 24px' : '28px 28px') + ';text-align:center;min-height:' + (hasImg ? '64px' : '200px') + ';';
    var p = document.createElement('p');
    var fs = text.length > 80 ? '15' : text.length > 40 ? '19' : '24';
    p.style.cssText = 'margin:0;font-size:' + fs + 'px;font-weight:700;line-height:1.5;color:' + (isBack ? '#1e293b' : '#fff') + ';';
    p.textContent = text;
    body.appendChild(p);
    div.appendChild(body);

    /* footer hint */
    var footer = document.createElement('div');
    footer.style.cssText = 'text-align:center;padding:10px 20px 16px;font-size:11px;font-weight:500;color:' + (isBack ? '#94a3b8' : 'rgba(255,255,255,.5)') + ';flex-shrink:0;';
    footer.textContent = isBack ? 'Chọn mức độ ghi nhớ bên dưới' : 'Nhấn để xem đáp án';
    div.appendChild(footer);
    return div;
  }

  function showCard(i) {
    var area = document.getElementById('card-area');
    var ratingEl = document.getElementById('rating-btns');
    var hintEl   = document.getElementById('flip-hint');

    if (i >= cards.length) {
      area.innerHTML = '';
      var done = document.createElement('div');
      done.className = 'card-in';
      done.style.cssText = 'background:linear-gradient(135deg,#43e97b,#38f9d7);border-radius:24px;padding:56px 32px;text-align:center;box-shadow:0 20px 60px rgba(67,233,123,0.35);';
      done.innerHTML = '<div style="font-size:52px;margin-bottom:16px;">🎉</div>' +
        '<h2 style="color:#fff;font-size:22px;font-weight:800;margin:0 0 8px;">Hoàn thành phiên học!</h2>' +
        '<p style="color:rgba(255,255,255,0.85);font-size:13px;margin:0 0 24px;">Tuyệt vời! Hệ thống sẽ nhắc ôn vào đúng thời điểm.</p>' +
        '<a href="' + DECK_PATH + '" style="display:inline-block;background:#fff;color:#059669;font-size:13px;font-weight:700;padding:12px 24px;border-radius:16px;text-decoration:none;">← Xem bộ thẻ</a>';
      area.appendChild(done);
      if (ratingEl) ratingEl.style.display = 'none';
      if (hintEl)   hintEl.style.display   = 'none';
      return;
    }

    var card = cards[i];
    var g = GRADIENTS[i % GRADIENTS.length];
    var frontEl = makeCard(card, 'Câu hỏi', g[0], g[1], false);
    frontEl.onclick = function() { flipCard(card, i); };
    speak(card.front);

    area.innerHTML = '';
    area.appendChild(frontEl);

    document.getElementById('card-counter').textContent = (i+1) + ' / ' + cards.length;
    document.getElementById('progress-bar').style.width = (i / cards.length * 100) + '%';
    if (ratingEl) ratingEl.style.display = 'none';
    if (hintEl)   hintEl.style.display   = '';
    flipped = false;
  }

  function flipCard(card, i) {
    if (flipped) return;
    flipped = true;
    var area = document.getElementById('card-area');
    var g = GRADIENTS[(i + 3) % GRADIENTS.length];
    var backEl = makeCard(card, 'Đáp án', g[0], g[1], true);
    speak(card.back);
    backEl.onclick = null;
    area.innerHTML = '';
    area.appendChild(backEl);
    var ratingEl = document.getElementById('rating-btns');
    var hintEl   = document.getElementById('flip-hint');
    if (ratingEl) ratingEl.style.display = '';
    if (hintEl)   hintEl.style.display   = 'none';
  }

  function rate(rating) {
    var card = cards[current];
    fetch(DECK_REVIEW_PATH, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
      body: JSON.stringify({ card_id: card.id, rating: rating })
    }).then(function() { current++; showCard(current); });
  }

  window.rate = rate;

  document.addEventListener('keydown', function(e) {
    if (e.key === ' ' || e.key === 'Enter') {
      e.preventDefault();
      if (!flipped && cards[current]) flipCard(cards[current], current);
    }
    if (e.key === '1') rate(0);
    if (e.key === '2') rate(1);
    if (e.key === '3') rate(2);
    if (e.key === '4') rate(3);
  });

  if (cards.length > 0) showCard(0);
})();
</script>
