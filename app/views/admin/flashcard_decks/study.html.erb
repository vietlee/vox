<% content_for :title, "Hб»Қc: #{@deck.title}" %>
<% content_for :main_class, 'flex-1 overflow-y-auto bg-slate-50' %>
<meta name="turbo-visit-control" content="reload">

<div class="min-h-full flex flex-col items-center justify-center p-6">
  <div class="w-full max-w-xl">

    <!-- Header -->
    <div class="flex items-center gap-4 mb-8">
      <%= link_to flashcard_deck_path(@deck),
          class: "flex items-center gap-1.5 text-[13px] font-semibold text-slate-600 hover:text-slate-900 transition-colors flex-shrink-0 bg-white border border-slate-200 rounded-xl px-3 py-2 shadow-sm" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        Quay lбәЎi
      <% end %>
      <div class="flex-1 min-w-0">
        <div class="text-[13px] font-bold text-slate-700 truncate"><%= @deck.title %></div>
        <div class="flex items-center gap-2 mt-1.5">
          <div class="flex-1 h-1.5 bg-slate-200 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-1.5 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-full transition-all duration-500" style="width:0%"></div>
          </div>
          <span id="card-counter" class="text-[11px] text-slate-500 font-bold flex-shrink-0 tabular-nums"></span>
        </div>
      </div>
    </div>

    <% if @study_cards.empty? %>
      <div class="bg-white rounded-3xl border border-slate-200 shadow-lg p-14 text-center">
        <div class="text-5xl mb-4">рҹҺү</div>
        <h2 class="text-[22px] font-extrabold text-slate-900 mb-2">Hб»Қc xong hГҙm nay!</h2>
        <p class="text-[13px] text-slate-500 mb-7">Hб»Ү thб»‘ng sбәҪ nhбәҜc bбәЎn Гҙn lбәЎi vГ o Д‘Гәng thб»қi Д‘iб»ғm tб»‘t nhбәҘt.</p>
        <%= link_to "вҶҗ Xem bб»ҷ thбә»", flashcard_deck_path(@deck), class: "inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 text-white text-[14px] font-bold rounded-2xl hover:bg-indigo-700 transition-colors" %>
      </div>
    <% else %>

      <!-- Card area вҖ” built entirely by JS -->
      <div id="card-area" class="mb-5"></div>

      <!-- TTS controls -->
      <div class="flex items-center gap-2 justify-end mb-2 flex-wrap">
        <select id="vi-voice-select" title="Giб»Қng tiбәҝng Viб»Үt"
                class="hidden px-2 py-1.5 rounded-xl text-[12px] font-semibold border outline-none"
                style="border-color:#6366f1; color:#4f46e5; background:#eef2ff; max-width:200px;"
                onchange="onVoiceChange()">
        </select>
        <select id="en-voice-select" title="Giб»Қng tiбәҝng Anh"
                class="hidden px-2 py-1.5 rounded-xl text-[12px] font-semibold border outline-none"
                style="border-color:#0284c7; color:#0369a1; background:#e0f2fe; max-width:200px;"
                onchange="onVoiceChange()">
        </select>
        <button id="tts-btn" onclick="toggleTTS()" title="Bбәӯt/tбәҜt Д‘б»Қc to"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-[12px] font-semibold border transition-all flex-shrink-0"
                style="border-color:#e2e8f0; color:#64748b; background:#fff;">
          рҹ”Ҡ <span id="tts-label">Дҗб»Қc to: TбәҜt</span>
        </button>
      </div>

      <!-- Rating buttons вҖ” hidden until flip -->
      <div id="rating-btns" class="mb-4" style="display:none;">
        <div class="grid grid-cols-4 gap-2.5">
          <button onclick="rate(0)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #fca5a5; color:#dc2626;">
            <span style="font-size:24px; margin-bottom:4px;">рҹҳө</span>
            <span style="font-size:12px; font-weight:700;">QuГӘn</span>
            <span style="font-size:10px; color:#ef4444; margin-top:2px;">1 phГәt</span>
          </button>
          <button onclick="rate(1)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #fdba74; color:#ea580c;">
            <span style="font-size:24px; margin-bottom:4px;">рҹҳ…</span>
            <span style="font-size:12px; font-weight:700;">KhГі</span>
            <span style="font-size:10px; color:#f97316; margin-top:2px;">10 phГәt</span>
          </button>
          <button onclick="rate(2)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #93c5fd; color:#2563eb;">
            <span style="font-size:24px; margin-bottom:4px;">рҹ‘Қ</span>
            <span style="font-size:12px; font-weight:700;">б»”n</span>
            <span style="font-size:10px; color:#3b82f6; margin-top:2px;">1 ngГ y</span>
          </button>
          <button onclick="rate(3)" class="flex flex-col items-center py-4 bg-white rounded-2xl cursor-pointer transition-all shadow-sm hover:shadow-md" style="border:2px solid #6ee7b7; color:#059669;">
            <span style="font-size:24px; margin-bottom:4px;">вӯҗ</span>
            <span style="font-size:12px; font-weight:700;">Dб»…</span>
            <span style="font-size:10px; color:#10b981; margin-top:2px;">2 ngГ y</span>
          </button>
        </div>
      </div>

      <div id="flip-hint" class="text-center">
        <span class="text-[12px] text-slate-400">NhбәҘn thбә» hoбә·c <kbd class="px-1.5 py-0.5 bg-white border border-slate-200 rounded text-[10px] font-mono shadow-sm">Space</kbd> Д‘б»ғ xem Д‘ГЎp ГЎn</span>
      </div>

    <% end %>
  </div>
</div>

<style>
@keyframes fadeInUp {
  from { opacity:0; transform:translateY(12px) scale(0.97); }
  to   { opacity:1; transform:translateY(0)    scale(1); }
}
.card-in { animation: fadeInUp 0.22s ease forwards; }
</style>

<script>
(function() {
  var DECK_REVIEW_PATH = '<%= review_flashcard_deck_path(@deck) %>';
  var DECK_PATH        = '<%= flashcard_deck_path(@deck) %>';
  var CSRF_TOKEN       = document.querySelector('meta[name="csrf-token"]').content;

  var cards = <%= raw @study_cards.map { |c| { id: c.id, front: c.front, back: c.back, image_data: c.image_data } }.to_json %>;
  var current = 0;
  var flipped = false;
  var ttsOn   = false;

  var GRADIENTS = [
    ['#667eea','#764ba2'],
    ['#4facfe','#00f2fe'],
    ['#43e97b','#38f9d7'],
    ['#f093fb','#f5576c'],
    ['#30cfd0','#667eea'],
    ['#a18cd1','#fbc2eb'],
  ];

  /* в”Җв”Җ TTS в”Җв”Җ */
  var _allVoices = [];
  var _selectedViVoice = null;  /* SpeechSynthesisVoice object chosen by user */
  var _selectedEnVoice = null;

  /* Vietnamese diacritics вҶ’ vi; pure ASCII letters вҶ’ en; else vi */
  var VI_RE  = /[Г ГЎбәЈГЈбәЎДғбәҜбә·бәұбәібәөГўбәҘбә§бә©бә«бәӯД‘ГЁГ©бә»бәҪбә№ГӘбәҝб»Ғб»ғб»…б»ҮГ¬Гӯб»үД©б»ӢГІГіб»ҸГөб»ҚГҙб»‘б»“б»•б»—б»ҷЖЎб»ӣб»қб»ҹб»Ўб»ЈГ№Гәб»§Е©б»ҘЖ°б»©б»«б»ӯб»Ҝб»ұб»іГҪб»·б»№б»өГҖГҒбәўГғбә ДӮбә®бә¶бә°бәІбәҙГӮбәӨбәҰбәЁбәӘбә¬ДҗГҲГүбәәбәјбәёГҠбәҫб»Җб»Ӯб»„б»ҶГҢГҚб»ҲДЁб»ҠГ’Г“б»ҺГ•б»ҢГ”б»җб»’б»”б»–б»ҳЖ б»ҡб»ңб»һб» б»ўГҷГҡб»ҰЕЁб»ӨЖҜб»Ёб»Әб»¬б»®б»°б»ІГқб»¶б»ёб»ҙ]/;
  var EN_RE  = /^[a-zA-Z0-9\s.,!?;:()\-'"\/\[\]%&@#+*=]+$/;
  function detectLang(text) {
    if (VI_RE.test(text)) return 'vi';
    if (EN_RE.test(text)) return 'en';
    return 'vi';
  }

  function populateVoiceSelects() {
    _allVoices = window.speechSynthesis.getVoices();
    var viVoices = _allVoices.filter(function(v){ return v.lang.startsWith('vi'); });
    var enVoices = _allVoices.filter(function(v){ return v.lang.startsWith('en'); });

    var viSel = document.getElementById('vi-voice-select');
    var enSel = document.getElementById('en-voice-select');

    viSel.innerHTML = '';
    viVoices.forEach(function(v) {
      var opt = document.createElement('option');
      opt.value = v.name;
      opt.textContent = 'рҹҮ»рҹҮі ' + v.name.replace(/Microsoft |Google /,'');
      viSel.appendChild(opt);
    });
    /* auto-pick: prefer Google, then first available */
    var bestVi = viVoices.find(function(v){ return /google/i.test(v.name); }) || viVoices[0];
    if (bestVi) { viSel.value = bestVi.name; _selectedViVoice = bestVi; }

    enSel.innerHTML = '';
    enVoices.forEach(function(v) {
      var opt = document.createElement('option');
      opt.value = v.name;
      opt.textContent = 'рҹҮәрҹҮё ' + v.name.replace(/Microsoft |Google /,'');
      enSel.appendChild(opt);
    });
    var bestEn = enVoices.find(function(v){ return /google/i.test(v.name) && v.lang === 'en-US'; }) ||
                 enVoices.find(function(v){ return v.lang === 'en-US'; }) ||
                 enVoices[0];
    if (bestEn) { enSel.value = bestEn.name; _selectedEnVoice = bestEn; }

    /* show selects only when TTS is on */
    if (ttsOn) {
      if (viVoices.length) viSel.classList.remove('hidden');
      if (enVoices.length) enSel.classList.remove('hidden');
    }
  }

  window.onVoiceChange = function() {
    var viSel = document.getElementById('vi-voice-select');
    var enSel = document.getElementById('en-voice-select');
    _selectedViVoice = _allVoices.find(function(v){ return v.name === viSel.value; }) || null;
    _selectedEnVoice = _allVoices.find(function(v){ return v.name === enSel.value; }) || null;
  };

  if (window.speechSynthesis) {
    /* Chrome loads voices async */
    if (window.speechSynthesis.getVoices().length) populateVoiceSelects();
    window.speechSynthesis.onvoiceschanged = populateVoiceSelects;
  }

  window.toggleTTS = function() {
    ttsOn = !ttsOn;
    var btn   = document.getElementById('tts-btn');
    var lbl   = document.getElementById('tts-label');
    var viSel = document.getElementById('vi-voice-select');
    var enSel = document.getElementById('en-voice-select');
    if (ttsOn) {
      btn.style.borderColor = '#6366f1'; btn.style.color = '#4f46e5'; btn.style.background = '#eef2ff';
      lbl.textContent = 'Дҗб»Қc to: Bбәӯt';
      populateVoiceSelects();
      if (viSel.options.length) viSel.classList.remove('hidden');
      if (enSel.options.length) enSel.classList.remove('hidden');
    } else {
      window.speechSynthesis && window.speechSynthesis.cancel();
      btn.style.borderColor = '#e2e8f0'; btn.style.color = '#64748b'; btn.style.background = '#fff';
      lbl.textContent = 'Дҗб»Қc to: TбәҜt';
      viSel.classList.add('hidden');
      enSel.classList.add('hidden');
    }
  };

  function speak(text) {
    if (!ttsOn || !window.speechSynthesis) return;
    window.speechSynthesis.cancel();
    var lang  = detectLang(text);
    var voice = lang === 'vi' ? _selectedViVoice : _selectedEnVoice;
    var u = new SpeechSynthesisUtterance(text);
    if (voice) { u.voice = voice; u.lang = voice.lang; }
    else        { u.lang  = lang === 'en' ? 'en-US' : 'vi-VN'; }
    u.rate  = lang === 'en' ? 0.88 : 0.84;
    u.pitch = 1.0;
    window.speechSynthesis.speak(u);
  }

  function makeCard(card, label, g1, g2, isBack) {
    var text = isBack ? card.back : card.front;
    var div = document.createElement('div');
    div.className = 'card-in';
    div.style.cssText = [
      isBack ? 'background:#fff;border:2px solid ' + g1 + '88' : 'background:linear-gradient(145deg,' + g1 + ',' + g2 + ')',
      'border-radius:28px',
      'overflow:hidden',
      'box-shadow:0 20px 60px ' + g1 + (isBack ? '22' : '55'),
      'display:flex',
      'flex-direction:column',
      'cursor:pointer',
      'user-select:none',
    ].join(';');

    /* header */
    var hdrBg = isBack ? 'rgba(0,0,0,.04)' : 'rgba(0,0,0,.15)';
    var hdrClr = isBack ? g1 : 'rgba(255,255,255,.8)';
    var header = document.createElement('div');
    header.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:13px 20px;border-bottom:1px solid ' + (isBack ? 'rgba(0,0,0,.07)' : 'rgba(255,255,255,.2)') + ';flex-shrink:0;';
    header.innerHTML =
      '<span style="font-size:10px;font-weight:800;letter-spacing:.1em;text-transform:uppercase;color:' + hdrClr + ';">' + label + '</span>' +
      '<span style="font-size:11px;color:' + hdrClr + ';font-weight:600;opacity:.7;">' + (isBack ? 'вң“ ДҗГЎp ГЎn' : (current+1) + ' / ' + cards.length) + '</span>';

    div.appendChild(header);

    /* image вҖ” show prominently when present (front face only) */
    if (!isBack && card.image_data) {
      var imgWrap = document.createElement('div');
      imgWrap.style.cssText = 'flex-shrink:0;height:260px;overflow:hidden;position:relative;';
      var img = document.createElement('img');
      img.src = card.image_data;
      img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
      /* subtle gradient overlay at bottom so text reads on top of image */
      var grad = document.createElement('div');
      grad.style.cssText = 'position:absolute;bottom:0;left:0;right:0;height:80px;background:linear-gradient(transparent,rgba(0,0,0,0.55));pointer-events:none;';
      imgWrap.appendChild(img);
      imgWrap.appendChild(grad);
      div.appendChild(imgWrap);
    }

    /* body text */
    var hasImg = !isBack && card.image_data;
    var body = document.createElement('div');
    body.style.cssText = 'flex:1;display:flex;align-items:center;justify-content:center;padding:' + (hasImg ? '16px 24px' : '28px 28px') + ';text-align:center;min-height:' + (hasImg ? '64px' : '200px') + ';';
    var p = document.createElement('p');
    var fs = text.length > 80 ? '15' : text.length > 40 ? '19' : '24';
    p.style.cssText = 'margin:0;font-size:' + fs + 'px;font-weight:700;line-height:1.5;color:' + (isBack ? '#1e293b' : '#fff') + ';';
    p.textContent = text;
    body.appendChild(p);
    div.appendChild(body);

    /* footer hint */
    var footer = document.createElement('div');
    footer.style.cssText = 'text-align:center;padding:10px 20px 16px;font-size:11px;font-weight:500;color:' + (isBack ? '#94a3b8' : 'rgba(255,255,255,.5)') + ';flex-shrink:0;';
    footer.textContent = isBack ? 'Chб»Қn mб»©c Д‘б»ҷ ghi nhб»ӣ bГӘn dЖ°б»ӣi' : 'NhбәҘn Д‘б»ғ xem Д‘ГЎp ГЎn';
    div.appendChild(footer);
    return div;
  }

  function showCard(i) {
    var area = document.getElementById('card-area');
    var ratingEl = document.getElementById('rating-btns');
    var hintEl   = document.getElementById('flip-hint');

    if (i >= cards.length) {
      area.innerHTML = '';
      var done = document.createElement('div');
      done.className = 'card-in';
      done.style.cssText = 'background:linear-gradient(135deg,#43e97b,#38f9d7);border-radius:24px;padding:56px 32px;text-align:center;box-shadow:0 20px 60px rgba(67,233,123,0.35);';
      done.innerHTML = '<div style="font-size:52px;margin-bottom:16px;">рҹҺү</div>' +
        '<h2 style="color:#fff;font-size:22px;font-weight:800;margin:0 0 8px;">HoГ n thГ nh phiГӘn hб»Қc!</h2>' +
        '<p style="color:rgba(255,255,255,0.85);font-size:13px;margin:0 0 24px;">Tuyб»Үt vб»қi! Hб»Ү thб»‘ng sбәҪ nhбәҜc Гҙn vГ o Д‘Гәng thб»қi Д‘iб»ғm.</p>' +
        '<a href="' + DECK_PATH + '" style="display:inline-block;background:#fff;color:#059669;font-size:13px;font-weight:700;padding:12px 24px;border-radius:16px;text-decoration:none;">вҶҗ Xem bб»ҷ thбә»</a>';
      area.appendChild(done);
      if (ratingEl) ratingEl.style.display = 'none';
      if (hintEl)   hintEl.style.display   = 'none';
      return;
    }

    var card = cards[i];
    var g = GRADIENTS[i % GRADIENTS.length];
    var frontEl = makeCard(card, 'CГўu hб»Ҹi', g[0], g[1], false);
    frontEl.onclick = function() { flipCard(card, i); };
    speak(card.front);

    area.innerHTML = '';
    area.appendChild(frontEl);

    document.getElementById('card-counter').textContent = (i+1) + ' / ' + cards.length;
    document.getElementById('progress-bar').style.width = (i / cards.length * 100) + '%';
    if (ratingEl) ratingEl.style.display = 'none';
    if (hintEl)   hintEl.style.display   = '';
    flipped = false;
  }

  function flipCard(card, i) {
    if (flipped) return;
    flipped = true;
    var area = document.getElementById('card-area');
    var g = GRADIENTS[(i + 3) % GRADIENTS.length];
    var backEl = makeCard(card, 'ДҗГЎp ГЎn', g[0], g[1], true);
    speak(card.back);
    backEl.onclick = null;
    area.innerHTML = '';
    area.appendChild(backEl);
    var ratingEl = document.getElementById('rating-btns');
    var hintEl   = document.getElementById('flip-hint');
    if (ratingEl) ratingEl.style.display = '';
    if (hintEl)   hintEl.style.display   = 'none';
  }

  function rate(rating) {
    var card = cards[current];
    fetch(DECK_REVIEW_PATH, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF_TOKEN },
      body: JSON.stringify({ card_id: card.id, rating: rating })
    }).then(function() { current++; showCard(current); });
  }

  window.rate = rate;

  document.addEventListener('keydown', function(e) {
    if (e.key === ' ' || e.key === 'Enter') {
      e.preventDefault();
      if (!flipped && cards[current]) flipCard(cards[current], current);
    }
    if (e.key === '1') rate(0);
    if (e.key === '2') rate(1);
    if (e.key === '3') rate(2);
    if (e.key === '4') rate(3);
  });

  if (cards.length > 0) showCard(0);
})();
</script>
