<% content_for :title, t("flashcard.new_title") %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <h1 class="text-[20px] font-extrabold text-slate-900">🃏 <%= t("flashcard.new_title") %></h1>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
  <%= form_with model: @deck, url: flashcard_decks_path, local: true do |f| %>
    <div class="space-y-4">
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide"><%= t("flashcard.field_title") %> *</label>
        <%= f.text_field :title, required: true,
            placeholder: "VD: Từ vựng IELTS, Công thức Toán, Từ khoá Python...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <div>
        <label class="block text-[12px] font-bold text-slate-700 mb-1.5 uppercase tracking-wide"><%= t("flashcard.field_subject") %></label>
        <%= f.text_field :subject,
            placeholder: "VD: Tiếng Anh, Toán, Lập trình...",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 outline-none" %>
      </div>
      <% if params[:source_text].present? %>
        <div id="fc-doc-banner" class="bg-indigo-50 border border-indigo-200 rounded-xl px-4 py-3 text-[12px] text-indigo-700 flex items-center gap-2">
          <svg id="fc-suggest-spinner" class="animate-spin w-3.5 h-3.5 text-indigo-500 shrink-0" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/>
          </svg>
          <span id="fc-suggest-icon" class="hidden">✅</span>
          <span id="fc-suggest-msg">AI đang phân tích tài liệu và đề xuất tiêu đề...</span>
        </div>
        <%= hidden_field_tag "source_text", params[:source_text] %>
      <% end %>
      <div class="flex gap-2 pt-1">
        <%= f.submit t("flashcard.new") + " →", class: "px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl cursor-pointer transition-colors" %>
        <%= link_to t("common.cancel"), flashcard_decks_path, class: "px-5 py-2.5 bg-slate-100 hover:bg-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" %>
      </div>
    </div>
  <% end %>
</div>

<% if params[:source_text].present? %>
<script>
(function() {
  var titleField   = document.querySelector('[name="flashcard_deck[title]"]');
  var subjectField = document.querySelector('[name="flashcard_deck[subject]"]');
  var sourceText   = <%= raw params[:source_text].to_s.to_json %>;

  var spinner = document.getElementById('fc-suggest-spinner');
  var iconEl  = document.getElementById('fc-suggest-icon');
  var msgEl   = document.getElementById('fc-suggest-msg');

  function setDone(msg) {
    if (spinner) spinner.classList.add('hidden');
    if (iconEl)  iconEl.classList.remove('hidden');
    if (msgEl)   msgEl.textContent = msg;
    titleField.placeholder   = 'VD: Từ vựng IELTS, Công thức Toán, Từ khoá Python...';
    subjectField.placeholder = 'VD: Tiếng Anh, Toán, Lập trình...';
  }

  var fd = new FormData();
  fd.append('content', sourceText.slice(0, 3000));
  fd.append('authenticity_token', document.querySelector('meta[name="csrf-token"]').content);

  fetch('<%= ai_suggest_meta_path %>', { method: 'POST', body: fd })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      if (d.title)   titleField.value   = d.title;
      if (d.subject) subjectField.value = d.subject;
      setDone('Đã nhận nội dung tài liệu — AI sẽ tạo flashcard từ tài liệu này sau khi bạn tạo bộ thẻ.');
    })
    .catch(function() {
      setDone('Đã nhận nội dung tài liệu — AI sẽ tạo flashcard từ tài liệu này sau khi bạn tạo bộ thẻ.');
    });
})();
</script>
<% end %>
