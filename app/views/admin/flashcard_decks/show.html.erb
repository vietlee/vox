<% content_for :title, @deck.title %>

<%# overlay rendered at bottom of page %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate">🃏 <%= @deck.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= @deck.subject.presence || "Tổng hợp" %></span>
      <span>· <%= t("flashcard.n_cards_unit", count: @cards.count) %></span>
      <% if @deck.ai_generated? %><span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-violet-100 text-violet-700">✨ AI</span><% end %>
    </div>
  </div>
  <%= link_to edit_flashcard_deck_path(@deck),
      class: "flex items-center gap-1.5 px-3 py-2.5 bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:border-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
    <%= t("flashcard.btn_edit") %>
  <% end %>
  <%= link_to analytics_flashcard_deck_path(@deck),
      class: "flex items-center gap-1.5 px-3 py-2.5 bg-white border border-slate-200 hover:bg-[#1e3a5f] hover:border-[#1e3a5f] hover:text-white text-slate-600 text-[13px] font-semibold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    Analytics
  <% end %>
  <%= link_to study_flashcard_deck_path(@deck), class: "flex items-center gap-1.5 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
    <%= t("flashcard.btn_study") %>
  <% end %>
</div>

<!-- AI Generate -->
<div class="bg-gradient-to-r from-violet-50 to-indigo-50 border border-violet-200 rounded-2xl p-5 mb-5">
  <div class="flex items-center gap-3 mb-3">
    <div class="w-8 h-8 bg-violet-100 rounded-xl flex items-center justify-center shrink-0">
      <svg class="w-4 h-4 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    </div>
    <div>
      <div class="text-[13px] font-bold text-violet-900"><%= t("flashcard.ai_generate_title") %></div>
      <div class="text-[12px] text-violet-700 mt-0.5"><%= t("flashcard.ai_generate_desc", credits: 3) %></div>
    </div>
  </div>
  <%= form_with url: ai_generate_flashcard_deck_path(@deck), method: :post, local: false, id: "ai-gen-form" do %>
    <div class="flex flex-col gap-2">
      <textarea name="topic" rows="2" placeholder="Chủ đề (mặc định: <%= @deck.title %>)"
                class="w-full px-3 py-2.5 border border-violet-200 rounded-xl text-[13px] bg-white focus:border-violet-400 outline-none resize-none leading-relaxed"></textarea>
      <div class="flex gap-2 items-center">
        <div class="flex items-center border border-violet-200 rounded-xl bg-white overflow-hidden">
          <input type="number" name="count" value="10" min="5" max="30"
                 class="w-16 px-3 py-2 text-[13px] border-0 outline-none text-center">
          <span class="pr-3 text-[11px] text-slate-400"><%= t("flashcard.ai_cards_unit") %></span>
        </div>
        <button type="submit" id="ai-gen-btn" class="inline-flex items-center gap-1.5 px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L9.5 9.5 2 12l7.5 2.5L12 22l2.5-7.5L22 12l-7.5-2.5z"/></svg>
          <%= t("flashcard.ai_generate_btn") %>
        </button>
      </div>
    </div>
  <% end %>
</div>

<!-- Card grid -->
<div>
  <div class="flex items-center justify-between mb-3">
    <h3 class="text-[14px] font-bold text-slate-900"><%= t("flashcard.cards_title", count: @cards.count) %></h3>
  </div>
  <% if @cards.empty? %>
    <div class="bg-white rounded-2xl border border-slate-200 p-12 text-center">
      <div class="text-5xl mb-3">🃏</div>
      <p class="text-[13px] text-slate-400"><%= t("flashcard.no_cards") %></p>
    </div>
  <% else %>
    <%
      gradients = [
        'linear-gradient(135deg,#667eea,#764ba2)',
        'linear-gradient(135deg,#4facfe,#00f2fe)',
        'linear-gradient(135deg,#43e97b,#38f9d7)',
        'linear-gradient(135deg,#fa709a,#fee140)',
        'linear-gradient(135deg,#30cfd0,#330867)',
        'linear-gradient(135deg,#f093fb,#f5576c)',
        'linear-gradient(135deg,#ffecd2,#fcb69f)',
        'linear-gradient(135deg,#a1c4fd,#c2e9fb)',
      ]
    %>
    <div class="grid grid-cols-3 gap-4">
      <% @cards.each_with_index do |card, i| %>
        <%
          accent_colors = ['#1e3a5f','#2563eb','#059669','#db2777','#0284c7','#9333ea','#ea580c','#1d4ed8']
          border_colors = ['#4a80a8','#60a5fa','#34d399','#f472b6','#38bdf8','#c084fc','#fb923c','#93c5fd']
          ac = accent_colors[i % 8]
          bc = border_colors[i % 8]
          has_img = card.image_data.present?
        %>
        <div class="group relative" style="perspective:900px;">
          <!-- Action buttons -->
          <div class="absolute top-2 right-2 z-10 flex gap-1 opacity-0 group-hover:opacity-100 transition-all">
            <button type="button" title="Chỉnh sửa thẻ"
                    onclick="event.stopPropagation(); openCardEdit(<%= card.id %>)"
                    class="w-7 h-7 rounded-full bg-white/90 shadow flex items-center justify-center hover:bg-white transition-all"
                    style="border:1px solid #e2e8f0;">
              <svg style="width:13px;height:13px;color:#1e3a5f;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </button>
            <label title="Thêm/đổi ảnh" class="w-7 h-7 rounded-full bg-white/90 shadow flex items-center justify-center cursor-pointer hover:bg-white transition-all"
                   onclick="event.stopPropagation();"
                   style="border:1px solid #e2e8f0;">
              <svg style="width:13px;height:13px;color:#1e3a5f;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              <input type="file" accept="image/*" class="hidden" onchange="uploadCardImage(this, '<%= flashcard_deck_flashcard_path(@deck, card) %>', '<%= dom_id(card) %>')">
            </label>
          </div>

          <div id="<%= dom_id(card) %>" class="relative cursor-pointer card-mini-flip"
               style="transform-style:preserve-3d; -webkit-transform-style:preserve-3d; transition:transform 0.45s ease; height:<%= has_img ? '240px' : '140px' %>;"
               onclick="this.style.transform = this.style.transform.includes('180') ? 'rotateY(0)' : 'rotateY(180deg)'">
            <!-- Front -->
            <div class="absolute inset-0 rounded-2xl flex flex-col overflow-hidden"
                 style="backface-visibility:hidden; -webkit-backface-visibility:hidden; background:<%= gradients[i % gradients.size] %>;">
              <% if has_img %>
                <div class="flex-shrink-0 relative" style="height:160px;overflow:hidden;">
                  <% if card.image_data.to_s.strip.start_with?('<svg') %>
                    <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.15);padding:8px;">
                      <%= raw card.image_data.to_s.gsub(/<\/script>/i, '') %>
                    </div>
                  <% else %>
                    <img src="<%= card.image_data %>" alt="" style="width:100%;height:100%;object-fit:cover;display:block;">
                  <% end %>
                  <div style="position:absolute;bottom:0;left:0;right:0;height:50px;background:linear-gradient(transparent,rgba(0,0,0,0.5));"></div>
                </div>
                <div class="flex-1 flex flex-col items-center justify-center p-3 text-center">
                  <div class="text-[9px] font-bold uppercase tracking-widest text-white/70 mb-1"><%= t("flashcard.card_n", n: i+1) %></div>
                  <p class="text-[12px] font-bold text-white leading-tight line-clamp-2"><%= card.front %></p>
                </div>
              <% else %>
                <div class="flex-1 flex flex-col items-center justify-center p-4 text-center">
                  <div class="text-[9px] font-bold uppercase tracking-widest text-white/70 mb-2"><%= t("flashcard.card_n", n: i+1) %></div>
                  <p class="text-[13px] font-bold text-white leading-tight line-clamp-3"><%= card.front %></p>
                  <div class="mt-2 text-white/40 text-[10px]"><%= t("flashcard.hover_hint") %></div>
                </div>
              <% end %>
            </div>
            <!-- Back -->
            <div class="absolute inset-0 rounded-2xl flex flex-col items-center justify-center p-4 text-center bg-white border-2"
                 style="backface-visibility:hidden; -webkit-backface-visibility:hidden;
                        transform:rotateY(180deg); -webkit-transform:rotateY(180deg);
                        border-color:<%= bc %>;">
              <div class="text-[9px] font-bold uppercase tracking-widest mb-2" style="color:<%= ac %>"><%= t("flashcard.answer_label") %></div>
              <p class="text-[12px] text-slate-700 leading-snug line-clamp-4"><%= card.back %></p>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <p class="text-[11px] text-slate-400 text-center mt-3"><%= t("flashcard.hover_hint") %></p>


    <script>
    var _editCardId = null;
    var _editCardUrls = <%= raw @cards.map { |c| [c.id, flashcard_deck_flashcard_path(@deck, c)] }.to_h.to_json %>;
    var _editCardData = <%= raw @cards.map { |c| [c.id, { front: c.front, back: c.back }] }.to_h.to_json %>;

    function openCardEdit(id) {
      _editCardId = id;
      var data = _editCardData[id] || {};
      document.getElementById('card-edit-front').value = data.front || '';
      document.getElementById('card-edit-back').value  = data.back  || '';
      document.getElementById('card-edit-modal').style.display = 'flex';
      setTimeout(function(){ document.getElementById('card-edit-front').focus(); }, 50);
    }
    function closeCardEdit() {
      document.getElementById('card-edit-modal').style.display = 'none';
      _editCardId = null;
    }
    function saveCardEdit() {
      var front = document.getElementById('card-edit-front').value.trim();
      var back  = document.getElementById('card-edit-back').value.trim();
      if (!front || !back) { alert('Vui lòng điền cả mặt trước và mặt sau.'); return; }
      var url  = _editCardUrls[_editCardId];
      var csrf = document.querySelector('meta[name="csrf-token"]').content;
      fetch(url, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
        body: JSON.stringify({ flashcard: { front: front, back: back } })
      })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.ok) { closeCardEdit(); location.reload(); }
        else alert('Lỗi: ' + (d.error || 'Không thể lưu'));
      })
      .catch(function(e) { alert('Lỗi kết nối: ' + e.message); });
    }
    document.addEventListener('DOMContentLoaded', function() {
      var modal = document.getElementById('card-edit-modal');
      if (modal) modal.addEventListener('click', function(e) { if (e.target === this) closeCardEdit(); });
    });
    // Also handle Turbo navigation
    document.addEventListener('turbo:load', function() {
      var modal = document.getElementById('card-edit-modal');
      if (modal && !modal._hasListener) { modal._hasListener = true; modal.addEventListener('click', function(e) { if (e.target === this) closeCardEdit(); }); }
    });
    window.openCardEdit = openCardEdit;
    window.closeCardEdit = closeCardEdit;
    window.saveCardEdit = saveCardEdit;

    function uploadCardImage(input, patchUrl, cardDomId) {
      var file = input.files[0]; if (!file) return;
      var label = input.closest('label');
      if (label) label.style.opacity = '0.5';

      var img = new Image();
      var reader = new FileReader();
      reader.onload = function(e) {
        img.onload = function() {
          /* resize to max 900×675 JPEG 0.85 — ~150-300KB base64 */
          var maxW = 900, maxH = 675;
          var w = img.width, h = img.height;
          if (w > maxW) { h = Math.round(h * maxW / w); w = maxW; }
          if (h > maxH) { w = Math.round(w * maxH / h); h = maxH; }
          var canvas = document.createElement('canvas');
          canvas.width = w; canvas.height = h;
          canvas.getContext('2d').drawImage(img, 0, 0, w, h);
          var dataUrl = canvas.toDataURL('image/jpeg', 0.85);

          var csrf = document.querySelector('meta[name="csrf-token"]').content;
          fetch(patchUrl, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': csrf },
            body: JSON.stringify({ image_data: dataUrl })
          })
          .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.json();
          })
          .then(function(d) {
            if (d.ok) {
              /* reload page so image renders from DB (avoids complex DOM patching) */
              window.location.reload();
            } else {
              alert('Lỗi lưu ảnh: ' + (d.error || 'unknown'));
              if (label) label.style.opacity = '1';
            }
          })
          .catch(function(err) {
            alert('Lỗi upload ảnh: ' + err.message);
            if (label) label.style.opacity = '1';
          });
        };
        img.src = e.target.result;
      };
      reader.readAsDataURL(file);
    }
    </script>
  <% end %>
</div>

<!-- Card edit modal -->
<div id="card-edit-modal" style="display:none;position:fixed;inset:0;z-index:9998;background:rgba(15,23,42,0.5);backdrop-filter:blur(3px);align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:20px;padding:28px;width:90%;max-width:480px;box-shadow:0 20px 60px rgba(0,0,0,0.2);">
    <h3 style="margin:0 0 20px;font-size:16px;font-weight:800;color:#0f172a;">✏️ Chỉnh sửa thẻ</h3>
    <div style="margin-bottom:14px;">
      <label style="display:block;font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">Mặt trước</label>
      <textarea id="card-edit-front" rows="3" style="width:100%;padding:10px 12px;border:1.5px solid #e2e8f0;border-radius:12px;font-size:14px;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box;" onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'"></textarea>
    </div>
    <div style="margin-bottom:20px;">
      <label style="display:block;font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;">Mặt sau (đáp án)</label>
      <textarea id="card-edit-back" rows="4" style="width:100%;padding:10px 12px;border:1.5px solid #e2e8f0;border-radius:12px;font-size:14px;font-family:inherit;outline:none;resize:vertical;box-sizing:border-box;" onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'"></textarea>
    </div>
    <div style="display:flex;gap:10px;">
      <button onclick="saveCardEdit()" style="flex:1;padding:11px;background:#4f46e5;color:#fff;font-weight:700;font-size:13px;border:none;border-radius:12px;cursor:pointer;">Lưu</button>
      <button onclick="closeCardEdit()" style="flex:1;padding:11px;background:#f1f5f9;color:#475569;font-weight:600;font-size:13px;border:none;border-radius:12px;cursor:pointer;">Hủy</button>
    </div>
  </div>
</div>

<!-- Single overlay — quiz_sets style -->
<div id="fc-overlay"
     style="display:none; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center;
            background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center;
              box-shadow:0 20px 60px rgba(0,0,0,0.22); max-width:320px; width:90%; position:relative;">
    <button onclick="fcMinimize()" title="Thu nhỏ — tiếp tục làm việc khác" data-navy-hover="1"
            style="position:absolute;top:12px;right:12px;display:flex;align-items:center;gap:5px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:5px 11px;font-size:11px;font-weight:700;cursor:pointer;color:#1e3a5f;transition:background .15s,border-color .15s;"
            onmouseenter="this.style.background='#e8f0f8';this.style.borderColor='#b3cbe3'" onmouseleave="this.style.background='#fff';this.style.borderColor='#e2e8f0'">
      <svg width="12" height="3" viewBox="0 0 12 3" fill="none"><rect y="0.5" width="12" height="2" rx="1" fill="#1e3a5f"/></svg>
      Thu nhỏ
    </button>
    <div id="fc-ring-container"></div>
    <p style="font-size:11px; color:#94A3B8; margin:12px 0 0;">Nhấn <strong style="color:#1e3a5f">Thu nhỏ</strong> để tiếp tục làm việc.</p>
  </div>
</div>

<style>
@keyframes vox-fc-pulse { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(0.88);opacity:.75} }
</style>

<script>
var _fcRingCtrl = null;
var FC_PHASES = ['Đang kết nối AI...', 'Đang phân tích chủ đề...', 'Đang tạo flashcard...', 'Đang soạn đáp án...', 'Đang hoàn thiện bộ thẻ...'];
var FC_TASK_META = {
  id:           'fc-<%= @deck.id %>',
  icon:         '🃏',
  label:        'Tạo Flashcard',
  title:        <%= raw @deck.title.to_json %>,
  redirect_url: '<%= flashcard_deck_path(@deck) %>'
};

function fcMinimize() {
  document.getElementById('fc-overlay').style.display = 'none';
  if (window.VoxTaskManager) {
    VoxTaskManager.add(Object.assign({}, FC_TASK_META, {
      poll_url: '<%= ai_status_flashcard_deck_path(@deck, format: :json) %>'
    }));
  }
}

function makeFcProgressRing() {
  var phases = FC_PHASES, totalPhases = phases.length;
  var phase = 0, pct = 0, timer = null;
  document.getElementById('fc-ring-container').innerHTML = [
    '<div style="display:flex;flex-direction:column;align-items:center;gap:8px;padding:8px 0;">',
      '<span id="fc-pct" style="font-size:13px;font-weight:800;color:#1e3a5f;">0%</span>',
      '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
        '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
          '<circle cx="44" cy="44" r="38" stroke="#d9e5f1" stroke-width="6"/>',
          '<circle id="fc-arc" cx="44" cy="44" r="38" stroke="#1e3a5f" stroke-width="6" stroke-linecap="round"',
            ' stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
        '</svg>',
        '<div style="position:relative;z-index:2;animation:vox-fc-pulse 1.6s ease-in-out infinite;">',
          '<svg width="32" height="32" viewBox="0 0 36 36" xmlns="http://www.w3.org/2000/svg">',
            '<rect width="36" height="36" rx="9" fill="#1A6BFF"/>',
            '<polygon points="10,24 6,31 16,24" fill="white"/>',
            '<rect x="6" y="6" width="24" height="19" rx="5" fill="white"/>',
            '<rect x="10" y="11" width="4" height="7" rx="1" fill="#1A6BFF"/>',
            '<rect x="16" y="8" width="4" height="13" rx="1" fill="#1A6BFF"/>',
            '<rect x="23" y="10" width="4" height="9" rx="1" fill="#1A6BFF"/>',
          '</svg>',
        '</div>',
      '</div>',
      '<p id="fc-phase" style="font-size:12px;font-weight:600;color:#1e3a5f;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
    '</div>'
  ].join('');

  var arc   = document.getElementById('fc-arc');
  var pctEl = document.getElementById('fc-pct');
  var phEl  = document.getElementById('fc-phase');
  var milestones = phases.map(function(_, i){ return Math.round(((i+1)/totalPhases)*85); });

  function setProgress(p) {
    arc.style.strokeDashoffset = 238.8 * (1 - p/100);
    pctEl.textContent = Math.round(p) + '%';
  }

  timer = setInterval(function() {
    var target = milestones[phase] || 85;
    pct = Math.min(pct + 1, target);
    setProgress(pct);
    if (pct >= (milestones[phase]||85) && phase < totalPhases-1) { phase++; phEl.textContent = phases[phase]; }
    if (pct >= 85 && phase >= totalPhases-1) {
      clearInterval(timer);
      timer = setInterval(function(){ if(pct>=98){clearInterval(timer);return;} pct=Math.min(pct+0.4,98); setProgress(pct); }, 3000);
    }
  }, 300);

  return { finish: function(){ clearInterval(timer); arc.style.strokeDashoffset='0'; pctEl.textContent='100%'; } };
}

// AJAX submit
var _aiGenForm = document.getElementById('ai-gen-form');
if (_aiGenForm) {
  _aiGenForm.addEventListener('ajax:before', function() {
    document.getElementById('ai-gen-btn').disabled = true;
  });
  _aiGenForm.addEventListener('ajax:success', function(e) {
    var data = e.detail[0]; var resp = e.detail[2];
    if (data.error) {
      document.getElementById('ai-gen-btn').disabled = false;
      if (handleAiError(data, { status: resp.status })) return;
      alert(data.error);
      return;
    }
    document.getElementById('fc-overlay').style.display = 'flex';
    _fcRingCtrl = makeFcProgressRing();
    pollFcStatus(data.poll_url, data.show_url);
  });
  _aiGenForm.addEventListener('ajax:error', function() {
    document.getElementById('ai-gen-btn').disabled = false;
    alert('Có lỗi xảy ra. Vui lòng thử lại.');
  });
}

function pollFcStatus(pollUrl, showUrl) {
  var overlay = document.getElementById('fc-overlay');
  if (overlay && overlay.style.display === 'none') return; // minimized
  fetch(pollUrl, { headers: { 'Accept': 'application/json' } })
    .then(function(r){ return r.json(); })
    .then(function(data) {
      if (!data.pending) {
        if (_fcRingCtrl) _fcRingCtrl.finish();
        setTimeout(function(){ window.location.href = showUrl; }, 400);
      } else {
        setTimeout(function(){ pollFcStatus(pollUrl, showUrl); }, 2500);
      }
    })
    .catch(function(){ setTimeout(function(){ pollFcStatus(pollUrl, showUrl); }, 3000); });
}

// Auto-start polling if page loaded while ai_generating
<% if @deck.ai_generating? %>
(function() {
  // Nếu VoxTaskManager đang track → skip overlay (ví dụ sau khi switch ngôn ngữ)
  try {
    var _t = JSON.parse(localStorage.getItem('vox_active_tasks') || '[]');
    if (_t.some(function(t) { return t.id === FC_TASK_META.id; })) return;
  } catch(e) {}
  document.getElementById('fc-overlay').style.display = 'flex';
  _fcRingCtrl = makeFcProgressRing();
  pollFcStatus('<%= ai_status_flashcard_deck_path(@deck, format: :json) %>', '<%= flashcard_deck_path(@deck) %>');
})();
<% end %>

document.addEventListener('turbo:before-cache', function() {
  document.getElementById('fc-overlay').style.display = 'none';
});
</script>
