<% content_for :title, @deck.title %>
<div class="p-6 max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <%= link_to "← Flashcards", flashcard_decks_path, class: "text-[13px] text-slate-500 hover:text-slate-700" %>
      <h1 class="text-[20px] font-extrabold text-slate-900 mt-1">🃏 <%= @deck.title %></h1>
      <div class="text-[12px] text-slate-500 mt-0.5"><%= @deck.subject.presence || "Tổng hợp" %> · <%= @cards.count %> thẻ</div>
    </div>
    <%= link_to study_flashcard_deck_path(@deck), class: "px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-lg" do %>📚 Học ngay<% end %>
  </div>

  <!-- AI Generate -->
  <div class="bg-purple-50 border border-purple-200 rounded-xl p-4 mb-5">
    <h3 class="text-[12px] font-bold text-purple-800 mb-2">✨ Tạo thẻ bằng AI (3 credits)</h3>
    <%= form_with url: ai_generate_flashcard_deck_path(@deck), method: :post, local: true do %>
      <div class="flex gap-2">
        <input type="text" name="topic" placeholder="Chủ đề (mặc định: <%= @deck.title %>)" class="flex-1 px-3 py-2 border border-purple-200 rounded-lg text-[13px] bg-white focus:border-purple-400 outline-none">
        <input type="number" name="count" value="10" min="5" max="30" class="w-20 px-3 py-2 border border-purple-200 rounded-lg text-[13px] bg-white focus:border-purple-400 outline-none">
        <button type="submit" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white text-[13px] font-bold rounded-lg border-0 cursor-pointer">Tạo</button>
      </div>
    <% end %>
  </div>

  <!-- Card list -->
  <div class="space-y-2">
    <% @cards.each_with_index do |card, i| %>
      <details class="bg-white border border-slate-200 rounded-xl overflow-hidden group">
        <summary class="flex items-center gap-3 p-4 cursor-pointer hover:bg-slate-50 list-none">
          <span class="text-[12px] text-slate-400 w-6 shrink-0"><%= i+1 %></span>
          <span class="flex-1 text-[13px] font-semibold text-slate-900"><%= card.front.truncate(120) %></span>
          <span class="text-slate-400 text-[12px]">Xem đáp án ▾</span>
        </summary>
        <div class="px-4 pb-4 border-t border-slate-100 bg-indigo-50">
          <p class="text-[13px] text-slate-700 mt-3 leading-relaxed"><%= card.back %></p>
        </div>
      </details>
    <% end %>
    <% if @cards.empty? %>
      <div class="text-center py-12 text-slate-400 text-[13px]">Chưa có thẻ nào. Dùng AI để tạo hoặc thêm thủ công.</div>
    <% end %>
  </div>
</div>
