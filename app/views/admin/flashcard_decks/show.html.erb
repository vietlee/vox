<% content_for :title, @deck.title %>

<div class="flex items-center gap-3 mb-6">
  <%= render "admin/shared/back_btn" %>
  <div class="flex-1 min-w-0">
    <h1 class="text-[20px] font-extrabold text-slate-900 truncate">🃏 <%= @deck.title %></h1>
    <div class="flex items-center gap-2 mt-0.5 text-[12px] text-slate-400">
      <span><%= @deck.subject.presence || "Tổng hợp" %></span>
      <span>· <%= @cards.count %> thẻ</span>
      <% if @deck.ai_generated? %><span class="text-[10px] px-1.5 py-0.5 rounded-full font-bold bg-violet-100 text-violet-700">✨ AI</span><% end %>
    </div>
  </div>
  <%= link_to study_flashcard_deck_path(@deck), class: "flex items-center gap-1.5 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[13px] font-bold rounded-xl transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
    Học ngay
  <% end %>
</div>

<!-- AI Generate -->
<div class="bg-gradient-to-r from-violet-50 to-indigo-50 border border-violet-200 rounded-2xl p-5 mb-5">
  <div class="flex items-center gap-3 mb-3">
    <div class="w-8 h-8 bg-violet-100 rounded-xl flex items-center justify-center shrink-0">
      <svg class="w-4 h-4 text-violet-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    </div>
    <div>
      <div class="text-[13px] font-bold text-violet-900">✨ Tạo thẻ bằng AI</div>
      <div class="text-[12px] text-violet-700 mt-0.5">AI tự động tạo flashcard cho chủ đề bạn chọn · <strong>3 credits</strong></div>
    </div>
  </div>
  <%= form_with url: ai_generate_flashcard_deck_path(@deck), method: :post, local: true do %>
    <div class="flex gap-2">
      <input type="text" name="topic" placeholder="Chủ đề (mặc định: <%= @deck.title %>)"
             class="flex-1 px-3 py-2 border border-violet-200 rounded-xl text-[13px] bg-white focus:border-violet-400 outline-none">
      <div class="flex items-center border border-violet-200 rounded-xl bg-white overflow-hidden">
        <input type="number" name="count" value="10" min="5" max="30"
               class="w-16 px-3 py-2 text-[13px] border-0 outline-none text-center">
        <span class="pr-3 text-[11px] text-slate-400">thẻ</span>
      </div>
      <button type="submit" class="px-4 py-2 bg-violet-600 hover:bg-violet-700 text-white text-[13px] font-bold rounded-xl border-0 cursor-pointer transition-colors">Tạo</button>
    </div>
  <% end %>
</div>

<!-- Card list -->
<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
  <div class="px-5 py-4 border-b border-slate-100">
    <h3 class="text-[14px] font-bold text-slate-900">Danh sách thẻ (<%= @cards.count %>)</h3>
  </div>
  <% if @cards.empty? %>
    <div class="p-12 text-center">
      <div class="text-4xl mb-3">🃏</div>
      <p class="text-[13px] text-slate-400">Chưa có thẻ nào. Dùng AI để tạo hoặc thêm thủ công (sắp có).</p>
    </div>
  <% else %>
    <div class="divide-y divide-slate-100">
      <% @cards.each_with_index do |card, i| %>
        <details class="group">
          <summary class="flex items-center gap-3 px-5 py-3.5 cursor-pointer hover:bg-slate-50 list-none">
            <span class="text-[12px] text-slate-400 w-7 shrink-0 font-mono"><%= i+1 %>.</span>
            <span class="flex-1 text-[13px] font-semibold text-slate-900 truncate"><%= card.front.truncate(100) %></span>
            <svg class="w-4 h-4 text-slate-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-5 pb-4 bg-indigo-50 border-t border-indigo-100">
            <div class="text-[11px] font-bold text-indigo-500 uppercase tracking-wide mt-3 mb-1.5">Đáp án</div>
            <p class="text-[13px] text-slate-700 leading-relaxed"><%= card.back %></p>
          </div>
        </details>
      <% end %>
    </div>
  <% end %>
</div>
