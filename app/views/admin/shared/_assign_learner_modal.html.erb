<%# locals: resource_type ("quiz" | "flashcard" | "learning_path"), assign_url, assignments_url, resource_title %>

<!-- Assign Learner Button -->
<button onclick="openAssignLearnerModal()"
        class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-xl text-[13px] font-bold border border-indigo-200 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 transition-colors">
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
  Giao cho Learner
</button>

<!-- Modal Backdrop -->
<div id="assign-learner-modal"
     style="display:none;position:fixed;inset:0;z-index:70;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,0.55);"
     onclick="if(event.target===this)closeAssignLearnerModal()">
  <div style="background:#fff;border-radius:22px;box-shadow:0 8px 48px rgba(0,0,0,0.18);width:100%;max-width:440px;overflow:hidden;">

    <!-- Header -->
    <div style="background:linear-gradient(135deg,#4f46e5,#7c3aed);padding:20px 24px;">
      <h3 style="color:#fff;font-size:16px;font-weight:800;margin:0 0 2px;">Giao cho Learner</h3>
      <p style="color:rgba(255,255,255,0.75);font-size:12px;margin:0;">
        <%= resource_title %>
      </p>
    </div>

    <!-- Tab bar -->
    <div style="display:flex;border-bottom:1px solid #e5e7eb;">
      <button id="alm-tab-assign" onclick="almTab('assign')"
              style="flex:1;padding:10px;font-size:13px;font-weight:700;color:#4f46e5;border-bottom:2px solid #4f46e5;background:none;border-top:none;border-left:none;border-right:none;cursor:pointer;">
        Giao mới
      </button>
      <button id="alm-tab-list" onclick="almTab('list')"
              style="flex:1;padding:10px;font-size:13px;font-weight:600;color:#9ca3af;border-bottom:2px solid transparent;background:none;border-top:none;border-left:none;border-right:none;cursor:pointer;">
        Đã giao
      </button>
    </div>

    <!-- Panel: Giao mới -->
    <div id="alm-panel-assign" style="padding:20px 24px;">
      <%= form_with url: assign_url, method: :post do |f| %>
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px;">Email learner <span style="color:#ef4444;">*</span></label>
          <%= f.email_field :email, required: true, placeholder: "learner@example.com",
              style: "width:100%;box-sizing:border-box;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none;font-family:inherit;",
              onfocus: "this.style.borderColor='#6366f1'", onblur: "this.style.borderColor='#e5e7eb'" %>
          <p style="font-size:11px;color:#9ca3af;margin-top:5px;">Nếu chưa có tài khoản, hệ thống sẽ tự tạo và gửi email mời.</p>
        </div>
        <div style="margin-bottom:14px;">
          <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px;">Tên (tuỳ chọn)</label>
          <%= f.text_field :name, placeholder: "Tên hiển thị",
              style: "width:100%;box-sizing:border-box;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none;font-family:inherit;",
              onfocus: "this.style.borderColor='#6366f1'", onblur: "this.style.borderColor='#e5e7eb'" %>
        </div>
        <% if resource_type == "quiz" || resource_type == "flashcard" %>
        <div style="margin-bottom:18px;">
          <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px;">Hạn hoàn thành (tuỳ chọn)</label>
          <%= f.datetime_local_field :due_at,
              style: "width:100%;box-sizing:border-box;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none;font-family:inherit;",
              onfocus: "this.style.borderColor='#6366f1'", onblur: "this.style.borderColor='#e5e7eb'" %>
        </div>
        <% else %>
        <div style="margin-bottom:18px;">
          <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px;">Hạn hoàn thành (tuỳ chọn)</label>
          <%= f.date_field :due_date,
              style: "width:100%;box-sizing:border-box;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none;font-family:inherit;",
              onfocus: "this.style.borderColor='#6366f1'", onblur: "this.style.borderColor='#e5e7eb'" %>
        </div>
        <% end %>
        <div style="display:flex;gap:8px;">
          <%= f.submit "Giao ngay",
              style: "flex:1;padding:11px;background:linear-gradient(135deg,#4f46e5,#7c3aed);color:#fff;font-weight:700;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;" %>
          <button type="button" onclick="closeAssignLearnerModal()"
                  style="flex:1;padding:11px;background:#f1f5f9;color:#475569;font-weight:600;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;">Huỷ</button>
        </div>
      <% end %>
    </div>

    <!-- Panel: Đã giao -->
    <div id="alm-panel-list" style="display:none;padding:0 0 8px;">
      <div id="alm-list-body" style="max-height:320px;overflow-y:auto;">
        <div style="text-align:center;padding:32px;color:#9ca3af;font-size:13px;">Đang tải...</div>
      </div>
    </div>

  </div>
</div>

<script>
(function() {
  var _assignmentsUrl = "<%= assignments_url %>";

  window.openAssignLearnerModal = function() {
    document.getElementById('assign-learner-modal').style.display = 'flex';
    almTab('assign');
  };
  window.closeAssignLearnerModal = function() {
    document.getElementById('assign-learner-modal').style.display = 'none';
  };
  window.almTab = function(tab) {
    var isAssign = tab === 'assign';
    document.getElementById('alm-panel-assign').style.display = isAssign ? '' : 'none';
    document.getElementById('alm-panel-list').style.display   = isAssign ? 'none' : '';
    var tA = document.getElementById('alm-tab-assign');
    var tL = document.getElementById('alm-tab-list');
    tA.style.color        = isAssign ? '#4f46e5' : '#9ca3af';
    tA.style.borderBottomColor = isAssign ? '#4f46e5' : 'transparent';
    tA.style.fontWeight   = isAssign ? '700' : '600';
    tL.style.color        = !isAssign ? '#4f46e5' : '#9ca3af';
    tL.style.borderBottomColor = !isAssign ? '#4f46e5' : 'transparent';
    tL.style.fontWeight   = !isAssign ? '700' : '600';
    if (!isAssign) loadLearnerList();
  };

  function loadLearnerList() {
    var el = document.getElementById('alm-list-body');
    el.innerHTML = '<div style="text-align:center;padding:32px;color:#9ca3af;font-size:13px;">Đang tải...</div>';
    fetch(_assignmentsUrl, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.length) {
          el.innerHTML = '<div style="text-align:center;padding:32px;color:#9ca3af;font-size:13px;">Chưa có learner nào được giao.</div>';
          return;
        }
        var statusLabel = { pending: '⏳ Chờ', in_progress: '📖 Đang học', completed: '✅ Hoàn thành' };
        el.innerHTML = data.map(function(a) {
          return '<div style="display:flex;align-items:center;gap:10px;padding:10px 20px;border-bottom:1px solid #f3f4f6;">' +
            '<div style="width:34px;height:34px;border-radius:50%;background:linear-gradient(135deg,#6366f1,#7c3aed);display:flex;align-items:center;justify-content:center;flex-shrink:0;">' +
              '<span style="color:#fff;font-size:14px;font-weight:800;">' + (a.name||a.email).charAt(0).toUpperCase() + '</span>' +
            '</div>' +
            '<div style="flex:1;min-width:0;">' +
              '<p style="font-size:13px;font-weight:700;color:#1e293b;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + (a.name||'—') + '</p>' +
              '<p style="font-size:11px;color:#9ca3af;margin:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + a.email + '</p>' +
            '</div>' +
            '<span style="font-size:11px;font-weight:600;white-space:nowrap;">' + (statusLabel[a.status]||a.status) + '</span>' +
          '</div>';
        }).join('');
      })
      .catch(function() {
        el.innerHTML = '<div style="text-align:center;padding:32px;color:#ef4444;font-size:13px;">Lỗi tải danh sách.</div>';
      });
  }
})();
</script>
