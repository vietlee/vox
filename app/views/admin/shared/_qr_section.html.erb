<% qr = resource.qr_code %>
<% if qr %>
  <div class="text-center">
    <div class="inline-block bg-white border border-slate-200 rounded-xl p-3">
      <img src="<%= qr_image_path(qr.token) %>" alt="QR Code" class="w-32 h-32 block rounded-lg">
    </div>
    <p class="text-[11px] text-slate-400 mt-2"><%= qr.scan_count %> scans</p>
    <a href="<%= qr_image_path(qr.token) %>" download="qrcode-<%= qr.token %>.svg"
       class="inline-flex items-center gap-1 mt-2 px-3 py-1 bg-slate-100 text-slate-600 text-[11px] font-semibold rounded hover:bg-slate-200">
      ↓ Download QR
    </a>
  </div>
<% end %>
