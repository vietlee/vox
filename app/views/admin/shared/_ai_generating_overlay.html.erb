<%#
  Renders a full-page loading overlay while an AI job runs in the background.
  Polls `poll_url` every 2.5s; reloads page when done (or shows error).

  Required locals:
    poll_url   - JSON endpoint returning { pending: true } or { pending: false, failed: true/false }
    message    - Main loading message shown as first phase
    submessage - Ignored (kept for backwards compat)
  Optional:
    phases     - Array of phase strings (defaults to [message, ...])
%>
<%
  phases = local_assigns[:phases] ||
    [local_assigns[:message] || "Đang xử lý...",
     "Đang phân tích...",
     "Đang tạo nội dung...",
     "Đang hoàn thiện..."]
%>

<%
  vtask_id       = local_assigns[:vtask_id]
  vtask_label    = local_assigns[:vtask_label]
  vtask_title    = local_assigns[:vtask_title]
  vtask_icon     = local_assigns[:vtask_icon] || '⚙️'
  vtask_redirect = local_assigns[:vtask_redirect]
  can_minimize   = vtask_id.present?
%>
<div id="ai-gen-overlay"
     style="display:flex; position:fixed; inset:0; z-index:9999; align-items:center; justify-content:center;
            background:rgba(15,23,42,0.65); backdrop-filter:blur(4px);">
  <div style="background:#fff; border-radius:20px; padding:32px 40px; text-align:center;
              box-shadow:0 20px 60px rgba(0,0,0,0.22); max-width:320px; width:90%; position:relative;">
    <% if can_minimize %>
      <button onclick="voxMinimizeTask()" title="Thu nhỏ — tiếp tục làm việc khác" data-navy-hover="1"
              style="position:absolute;top:12px;right:12px;display:flex;align-items:center;gap:5px;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:5px 11px;font-size:11px;font-weight:700;cursor:pointer;color:#1e3a5f;transition:background .15s,border-color .15s;"
              onmouseenter="this.style.background='#e8f0f8';this.style.borderColor='#b3cbe3'" onmouseleave="this.style.background='#fff';this.style.borderColor='#e2e8f0'">
        <svg width="12" height="3" viewBox="0 0 12 3" fill="none"><rect y="0.5" width="12" height="2" rx="1" fill="#1e3a5f"/></svg>
        Thu nhỏ
      </button>
    <% end %>
    <div id="ai-gen-ring-container"></div>
    <% if can_minimize %>
      <p style="font-size:11px; color:#94A3B8; margin:12px 0 0;">Nhấn <strong style="color:#1e3a5f">Thu nhỏ</strong> để tiếp tục làm việc.</p>
    <% else %>
      <p style="font-size:11px; color:#94A3B8; margin:12px 0 0;">Đừng tắt trang này.</p>
    <% end %>
  </div>
</div>

<% if can_minimize %>
<script>
window._voxGenTask = {
  id:          <%= raw vtask_id.to_json %>,
  icon:        <%= raw vtask_icon.to_json %>,
  label:       <%= raw vtask_label.to_json %>,
  title:       <%= raw vtask_title.to_s.to_json %>,
  redirect_url:<%= raw vtask_redirect.to_s.to_json %>
};
window.voxMinimizeTask = function() {
  document.getElementById('ai-gen-overlay').style.display = 'none';
  if (window.VoxTaskManager && window._voxGenTask) {
    VoxTaskManager.add(Object.assign({}, window._voxGenTask, { poll_url: window._voxGenPollUrl }));
  }
};
</script>
<% end %>

<style>
@keyframes vox-pulse {
  0%,100% { transform:scale(1); opacity:1; }
  50%      { transform:scale(0.88); opacity:0.75; }
}
@keyframes vox-siri-spin  { to { transform: rotate(360deg); } }
@keyframes vox-siri-spin2 { to { transform: rotate(-360deg); } }
@keyframes vox-siri-glow  {
  0%,100% { box-shadow: 0 0 18px 4px rgba(139,92,246,.65), 0 0 40px 8px rgba(99,102,241,.30); }
  50%     { box-shadow: 0 0 26px 8px rgba(167,139,250,.80), 0 0 56px 14px rgba(236,72,153,.25); }
}
@keyframes vox-siri-blob  {
  0%,100% { border-radius: 60% 40% 55% 45% / 50% 60% 40% 50%; }
  33%     { border-radius: 45% 55% 40% 60% / 60% 40% 55% 45%; }
  66%     { border-radius: 55% 45% 60% 40% / 40% 55% 45% 60%; }
}
</style>

<script>
(function() {
  var AI_GEN_PHASES = <%= raw phases.to_json %>;
  var pollUrl = '<%= j poll_url %>';
  window._voxGenPollUrl = pollUrl;

  /* ── Skip nếu VoxTaskManager đang track task này (vd: sau khi switch ngôn ngữ) ── */
  <% if can_minimize %>
  try {
    var _existing = JSON.parse(localStorage.getItem('vox_active_tasks') || '[]');
    if (_existing.some(function(t) { return t.id === '<%= j vtask_id %>'; })) {
      document.getElementById('ai-gen-overlay').style.display = 'none';
      return; // VoxTaskManager đang poll — không cần overlay
    }
  } catch(e) {}
  <% end %>

  /* ── Progress ring ── */
  (function buildRing() {
    var phases = AI_GEN_PHASES;
    var totalPhases = phases.length;
    var phase = 0, pct = 0, timer = null;
    document.getElementById('ai-gen-ring-container').innerHTML = [
      '<div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:8px 0;gap:8px;">',
        '<span id="ai-gen-pct" style="font-size:13px;font-weight:800;background:linear-gradient(90deg,#6366f1,#a78bfa);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;letter-spacing:-0.3px;">0%</span>',
        '<div style="position:relative;width:88px;height:88px;display:flex;align-items:center;justify-content:center;">',
          '<svg width="88" height="88" viewBox="0 0 88 88" fill="none" style="position:absolute;top:0;left:0;transform:rotate(-90deg);">',
            '<circle cx="44" cy="44" r="38" stroke="#e8e0ff" stroke-width="5"/>',
            '<circle id="ai-gen-arc" cx="44" cy="44" r="38" stroke="url(#siri-arc-grad)" stroke-width="5" stroke-linecap="round" stroke-dasharray="238.8" stroke-dashoffset="238.8" style="transition:stroke-dashoffset 0.6s ease;"/>',
            '<defs><linearGradient id="siri-arc-grad" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#a78bfa"/><stop offset="50%" stop-color="#6366f1"/><stop offset="100%" stop-color="#ec4899"/></linearGradient></defs>',
          '</svg>',
          /* VOX logo (pulsing) */
          '<div style="position:relative;z-index:2;animation:vox-pulse 1.6s ease-in-out infinite;">',
            '<img src="/icon-mark.svg" width="44" height="44" alt="VOX" style="display:block;">',
          '</div>',
        '</div>',
        '<p id="ai-gen-phase" style="font-size:12px;font-weight:600;color:#1e3a5f;text-align:center;max-width:220px;margin:0;">' + phases[0] + '</p>',
      '</div>'
    ].join('');

    var ring  = document.getElementById('ai-gen-arc');
    var pctEl = document.getElementById('ai-gen-pct');
    var phEl  = document.getElementById('ai-gen-phase');
    var milestones = phases.map(function(_, i) { return Math.round(((i + 1) / totalPhases) * 85); });

    function setProgress(p) {
      ring.style.strokeDashoffset = 238.8 * (1 - p / 100);
      pctEl.textContent = Math.round(p) + '%';
    }

    timer = setInterval(function() {
      var target = milestones[phase] || 85;
      pct = Math.min(pct + 1, target);
      setProgress(pct);
      if (pct >= (milestones[phase] || 85) && phase < totalPhases - 1) {
        phase++;
        phEl.textContent = phases[phase];
      }
      if (pct >= 85 && phase >= totalPhases - 1) {
        clearInterval(timer);
        timer = setInterval(function() {
          if (pct >= 98) { clearInterval(timer); return; }
          pct = Math.min(pct + 0.4, 98);
          setProgress(pct);
        }, 3000);
      }
    }, 300);
  })();

  /* ── Polling ── */
  function poll() {
    var overlay = document.getElementById('ai-gen-overlay');
    if (overlay && overlay.style.display === 'none') return; // minimized — VoxTaskManager takes over
    fetch(pollUrl, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.failed) {
          document.getElementById('ai-gen-overlay').innerHTML =
            '<div style="background:#fff;border-radius:20px;padding:32px 40px;text-align:center;max-width:320px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,0.22);">' +
              '<div style="font-size:2rem;margin-bottom:12px;">⚠️</div>' +
              '<p style="font-size:14px;color:#ef4444;margin:0 0 16px;">Có lỗi xảy ra. Vui lòng thử lại.</p>' +
              '<button onclick="location.reload()" style="padding:8px 20px;background:#1e3a5f;color:#fff;border:0;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;">Tải lại</button>' +
            '</div>';
        } else if (data.pending) {
          setTimeout(poll, 2500);
        } else {
          location.reload();
        }
      })
      .catch(function() { setTimeout(poll, 3000); });
  }

  setTimeout(poll, 1500);
})();
</script>
