<% content_for :title, t("audit_log.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>

<!-- ── Page header (always visible) ─────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-0 bg-slate-100">
  <div class="flex items-start justify-between mb-4">
    <div>
      <h1 class="text-[19px] font-extrabold text-slate-900 tracking-tight">📜 <%= t("audit_log.title") %></h1>
      <p class="text-[12px] text-slate-500 mt-0.5"><%= t("audit_log.subtitle", default: "Lịch sử thao tác trong workspace") %></p>
    </div>
  </div>
</div>

<!-- ── Card area (fills remaining height) ───────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-hidden px-6 pt-3 pb-5">
  <div class="rounded-[12px] border overflow-hidden flex flex-col h-full" style="border-color:rgba(99,102,241,0.2); background:rgba(238,242,255,0.5);">

    <!-- Card header -->
    <div class="flex-shrink-0 flex items-center gap-3 px-4 py-3 border-b" style="background:rgba(99,102,241,0.06); border-color:rgba(99,102,241,0.15);">
      <span class="text-[13px] font-semibold text-slate-700">📜 <%= t("audit_log.title") %></span>
      <% if @pagy %>
        <span class="text-[11px] text-slate-400 ml-auto"><%= @pagy.count %> <%= t("audit_log.entries", default: "mục") %></span>
      <% end %>
    </div>

    <!-- Log list (scrollable) -->
    <div class="flex-1 min-h-0 overflow-y-auto">
      <% if @logs.any? %>
        <% tz = current_workspace.timezone.presence || "Asia/Ho_Chi_Minh" %>
        <div class="divide-y divide-indigo-50">
          <% @logs.each do |log| %>
            <% rname = log.resource_name %>
            <div class="flex items-center gap-4 px-5 py-3.5 hover:bg-white/60 transition-colors">
              <!-- Icon -->
              <div class="w-8 h-8 flex items-center justify-center text-[18px] flex-shrink-0">
                <%= log.action_icon %>
              </div>

              <!-- Main content -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-[13px] font-semibold text-slate-800"><%= log.human_action %></span>
                  <% if rname.present? %>
                    <span class="text-[12px] text-slate-300">·</span>
                    <span class="text-[12px] font-medium text-slate-600 truncate max-w-[240px]" title="<%= rname %>"><%= rname %></span>
                  <% end %>
                </div>
                <div class="flex items-center gap-2 mt-0.5">
                  <span class="text-[11px] text-slate-400"><%= log.user&.name || t("audit_log.system") %></span>
                  <span class="text-[10px] text-slate-300">·</span>
                  <span class="text-[11px] text-slate-400"><%= I18n.l(log.created_at.in_time_zone(tz), format: :short) %></span>
                </div>
              </div>

            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-20 text-slate-400">
          <div class="text-4xl mb-3">📜</div>
          <h3 class="text-[15px] font-semibold text-slate-700 mb-1"><%= t("audit_log.empty") %></h3>
        </div>
      <% end %>
    </div><!-- /scrollable -->

    <!-- Pagination (fixed at bottom) -->
    <% if @pagy && @pagy.pages > 1 %>
      <div class="flex-shrink-0 flex items-center justify-between px-4 py-2.5 border-t" style="border-color:rgba(99,102,241,0.12); background:rgba(99,102,241,0.04);">
        <p class="text-[11px] text-slate-500">
          <% from = (@pagy.page - 1) * @pagy.items + 1
             to   = [@pagy.page * @pagy.items, @pagy.count].min %>
          <%= t("audit_log.showing") %> <%= from %>–<%= to %> <%= t("audit_log.of") %> <%= @pagy.count %>
        </p>
        <div class="flex gap-1">
          <% if @pagy.page > 1 %>
            <%= link_to audit_log_path(page: @pagy.page - 1),
                  class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %>
              ← <%= t("audit_log.prev") %>
            <% end %>
          <% end %>
          <% window_start = [1, @pagy.page - 2].max
             window_end   = [window_start + 4, @pagy.pages].min
             window_start = [window_end - 4, 1].max %>
          <% (window_start..window_end).each do |p| %>
            <%= link_to audit_log_path(page: p),
                  class: "px-2.5 py-1 text-[11px] border rounded-md #{p == @pagy.page ? 'bg-slate-600 border-slate-600 text-white font-semibold' : 'border-slate-200 text-slate-600 hover:bg-white bg-white/60'}" do %>
              <%= p %>
            <% end %>
          <% end %>
          <% if @pagy.page < @pagy.pages %>
            <%= link_to audit_log_path(page: @pagy.page + 1),
                  class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md text-slate-600 hover:bg-white bg-white/60" do %>
              <%= t("audit_log.next") %> →
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div><!-- /card -->
</div><!-- /card area -->
