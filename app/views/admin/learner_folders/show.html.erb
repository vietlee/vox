                      onclick="confirmRemoveLearner('<%= remove_learner_learner_folder_path(@folder, learner_id: l.id) %>', '<%= j(l.email) %>')"
                      class="inline-flex items-center gap-1 px-2.5 py-1.5 text-[12px] font-semibold text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 rounded-lg border-0 cursor-pointer transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7a4 4 0 11-8 0 4 4 0 018 0zM9 14a6 6 0 00-6 6v1h12v-1a6 6 0 00-6-6zM21 12h-6"/></svg>
                <%= t("learner_folders.show.remove_btn") %>
              </button>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%# Pagination %>
    <% if @pagy.pages > 1 %>
      <div class="flex items-center justify-between px-5 py-3 border-t border-slate-100 bg-slate-50/60">
        <p class="text-[11px] text-slate-500"><%= @pagy.from %>–<%= @pagy.to %> / <%= @pagy.count %> learners</p>
        <div class="flex items-center gap-1">
          <%= link_to learner_folder_path(@folder, page: @pagy.prev, q: @search_query),
              class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md transition-colors #{@pagy.prev ? 'text-slate-600 hover:bg-white bg-white/60' : 'text-slate-300 pointer-events-none bg-white/30'}" do %>←<% end %>
          <% ([ [@pagy.page-2, 1].max, [@pagy.pages-4, 1].max ].min .. [ [@pagy.page-2, 1].max + 4, @pagy.pages ].min).each do |p| %>
            <%= link_to p, learner_folder_path(@folder, page: p, q: @search_query),
                class: "w-7 h-7 flex items-center justify-center text-[11px] font-semibold rounded-md border transition-colors #{p == @pagy.page ? 'bg-[#1e3a5f] border-[#1e3a5f] text-white' : 'border-slate-200 text-slate-600 hover:bg-white bg-white/60'}" %>
          <% end %>
          <%= link_to learner_folder_path(@folder, page: @pagy.next, q: @search_query),
              class: "px-2.5 py-1 text-[11px] border border-slate-200 rounded-md transition-colors #{@pagy.next ? 'text-slate-600 hover:bg-white bg-white/60' : 'text-slate-300 pointer-events-none bg-white/30'}" do %>→<% end %>
        </div>
      </div>
    <% end %>

  <% end %><%# end @members.any? %>
  <% else %>
    <div class="py-16 text-center">
      <div class="text-5xl mb-3">👤</div>
      <p class="text-[14px] font-bold text-slate-600 mb-1"><%= t("learner_folders.show.empty_title") %></p>
      <p class="text-[13px] text-slate-400"><%= t("learner_folders.show.empty_desc") %></p>
    </div>
  <% end %><%# end @members.any? || @search_query %>
  </div><%# end learner-table-wrapper %>
</div><%# end outer card %>

</div><%# end tab-learners %>

<!-- Add learner modal -->
<div id="add-learner-modal" style="display:none;position:fixed;inset:0;z-index:60;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,0.5);"
     onclick="if(event.target===this)this.style.display='none'">
  <div style="background:#fff;border-radius:20px;box-shadow:0 8px 40px rgba(0,0,0,0.18);width:100%;max-width:400px;padding:28px 24px;">
    <h3 style="font-size:16px;font-weight:800;color:#1e293b;margin:0 0 4px;"><%= t("learner_folders.show.add_modal_title") %></h3>
    <p style="font-size:12px;color:#9ca3af;margin:0 0 20px;"><%= t("learner_folders.show.add_modal_desc") %></p>
    <%= form_with url: add_learner_learner_folder_path(@folder), method: :post do |f| %>
      <div style="margin-bottom:14px;">
        <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;"><%= t("learner_folders.show.email_label") %> <span style="color:#ef4444">*</span></label>
        <%= f.email_field :email, required: true, placeholder: "learner@example.com",
            style: "width:100%;box-sizing:border-box;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none;font-family:inherit;",
            onfocus: "this.style.borderColor='#1e3a5f'", onblur: "this.style.borderColor='#e5e7eb'" %>
      </div>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;"><%= t("learner_folders.show.name_label") %></label>
        <%= f.text_field :name, placeholder: "Nguyễn Văn A",
            style: "width:100%;box-sizing:border-box;padding:10px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none;font-family:inherit;",
            onfocus: "this.style.borderColor='#1e3a5f'", onblur: "this.style.borderColor='#e5e7eb'" %>
      </div>
      <div style="display:flex;gap:8px;">
        <button id="add-learner-btn" type="submit"
                style="flex:1;padding:11px;background:#1e3a5f;color:#fff;font-weight:700;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:8px;">
          <span id="add-learner-btn-text"><%= t("learner_folders.show.add_to_folder_btn") %></span>
          <svg id="add-learner-spinner" style="display:none;width:15px;height:15px;animation:spin .8s linear infinite;" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,0.3)" stroke-width="3"/>
            <path d="M12 2a10 10 0 0 1 10 10" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </button>
        <button type="button" onclick="document.getElementById('add-learner-modal').style.display='none'"
                style="flex:1;padding:11px;background:#f1f5f9;color:#475569;font-weight:600;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;"><%= t("learner_folders.show.cancel") %></button>
      </div>
    <% end %>
  </div>
</div>

<!-- Import modal -->
<div id="import-modal" style="display:none;position:fixed;inset:0;z-index:60;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,0.5);"
     onclick="if(event.target===this)this.style.display='none'">
  <div style="background:#fff;border-radius:20px;box-shadow:0 8px 40px rgba(0,0,0,0.18);width:100%;max-width:440px;padding:28px 24px;">
    <h3 style="font-size:16px;font-weight:800;color:#1e293b;margin:0 0 4px;"><%= t("learner_folders.show.import_modal_title") %></h3>
    <p style="font-size:12px;color:#9ca3af;margin:0 0 16px;"><%= t("learner_folders.show.import_modal_desc").html_safe %></p>

    <div style="background:#f0f4ff;border:1.5px dashed #a5b4fc;border-radius:12px;padding:12px 14px;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
      <svg width="20" height="20" fill="none" stroke="#1e3a5f" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
      <div style="flex:1;">
        <p style="font-size:13px;font-weight:700;color:#1e3a5f;margin:0;"><%= t("learner_folders.show.template_hint_title") %></p>
        <p style="font-size:11px;color:#4f6a8f;margin:2px 0 0;"><%= t("learner_folders.show.template_hint_desc") %></p>
      </div>
      <a href="<%= template_learner_folder_path(@folder) %>"
         style="padding:7px 14px;background:#1e3a5f;color:#fff;font-size:12px;font-weight:700;border-radius:9px;text-decoration:none;white-space:nowrap;">
        <%= t("learner_folders.show.template_btn") %>
      </a>
    </div>

    <%= form_with url: import_learner_folder_path(@folder), method: :post, multipart: true do |f| %>
      <div style="margin-bottom:20px;">
        <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:8px;"><%= t("learner_folders.show.file_label") %> <span style="color:#ef4444">*</span></label>
        <div style="border:2px dashed #e5e7eb;border-radius:12px;padding:20px;text-align:center;cursor:pointer;"
             onclick="document.getElementById('import-file-input').click()"
             ondragover="event.preventDefault();this.style.borderColor='#1e3a5f'"
             ondragleave="this.style.borderColor='#e5e7eb'"
             ondrop="event.preventDefault();handleDrop(event)">
          <div id="file-placeholder">
            <svg width="32" height="32" fill="none" stroke="#9ca3af" viewBox="0 0 24 24" style="margin:0 auto 8px;display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg>
            <p style="font-size:13px;color:#6b7280;font-weight:600;"><%= t("learner_folders.show.drag_drop_hint") %></p>
            <p style="font-size:11px;color:#9ca3af;margin-top:4px;"><%= t("learner_folders.show.file_type_hint") %></p>
          </div>
          <div id="file-selected" style="display:none;">
            <p id="file-name" style="font-size:13px;color:#1e3a5f;font-weight:700;"></p>
          </div>
          <%= f.file_field :file, id: "import-file-input", accept: ".xlsx,.csv",
              style: "display:none;", onchange: "showFileName(this)" %>
        </div>
      </div>
      <div style="display:flex;gap:8px;">
        <button id="import-submit-btn" type="submit"
                style="flex:1;padding:11px;background:#1e3a5f;color:#fff;font-weight:700;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;display:flex;align-items:center;justify-content:center;gap:8px;">
          <span id="import-btn-text"><%= t("learner_folders.show.import_submit_btn") %></span>
          <svg id="import-spinner" style="display:none;width:16px;height:16px;animation:spin .8s linear infinite;" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="rgba(255,255,255,0.3)" stroke-width="3"/>
            <path d="M12 2a10 10 0 0 1 10 10" stroke="#fff" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </button>
        <button type="button" onclick="document.getElementById('import-modal').style.display='none'"
                style="flex:1;padding:11px;background:#f1f5f9;color:#475569;font-weight:600;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;"><%= t("learner_folders.show.cancel") %></button>
      </div>
    <% end %>
  </div>
</div>

<script>
function switchTab(name) {
  ['dashboard','learners'].forEach(function(t) {
    var panel = document.getElementById('tab-' + t);
    var btn   = document.getElementById('tab-btn-' + t);
    if (!panel || !btn) return;
    var active = t === name;
    panel.style.display = active ? '' : 'none';
    btn.style.borderBottom = active ? '2px solid #1e3a5f' : '2px solid transparent';
    btn.style.color        = active ? '#1e3a5f' : '#64748b';
    btn.style.fontWeight   = active ? '700' : '600';
    btn.style.background   = active ? 'white' : '';
  });
}

function showFileName(input) {
  if (input.files && input.files[0]) {
    document.getElementById('file-placeholder').style.display = 'none';
    document.getElementById('file-selected').style.display = 'block';
    document.getElementById('file-name').textContent = '📄 ' + input.files[0].name;
  }
}
function handleDrop(e) {
  var file = e.dataTransfer.files[0];
  if (!file) return;
  var input = document.getElementById('import-file-input');
  var dt = new DataTransfer();
  dt.items.add(file);
  input.files = dt.files;
  showFileName(input);
}

var addForm = document.querySelector('form[action*="add_learner"]');
if (addForm) addForm.addEventListener('submit', function() {
  var btn  = document.getElementById('add-learner-btn');
  var text = document.getElementById('add-learner-btn-text');
  var spin = document.getElementById('add-learner-spinner');
  text.textContent = 'Đang thêm...';
  spin.style.display = 'block';
  btn.disabled = true;
  btn.style.opacity = '0.8';
  btn.style.cursor = 'not-allowed';
});

var importForm = document.querySelector('form[action*="import"]');
if (importForm) importForm.addEventListener('submit', function() {
  var btn  = document.getElementById('import-submit-btn');
  var text = document.getElementById('import-btn-text');
  var spin = document.getElementById('import-spinner');
  text.textContent = 'Đang import...';
  spin.style.display = 'block';
  btn.disabled = true;
  btn.style.opacity = '0.8';
  btn.style.cursor = 'not-allowed';
});

(function() {
  var input = document.getElementById('learner-search-input');
  if (!input) return;
  var timer;
  input.addEventListener('input', function() {
    clearTimeout(timer);
    var q = input.value;
    timer = setTimeout(function() {
      var base = input.dataset.url;
      var url  = q.trim() ? base + '?q=' + encodeURIComponent(q.trim()) : base;
      fetch(url, { headers: { 'Accept': 'text/html', 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.text(); })
        .then(function(html) {
          var parser = new DOMParser();
          var doc    = parser.parseFromString(html, 'text/html');
          var fresh  = doc.getElementById('learner-table-wrapper');
          var target = document.getElementById('learner-table-wrapper');
          if (fresh && target) target.innerHTML = fresh.innerHTML;
          history.replaceState(null, '', url);
        });
    }, 350);
  });
})();
</script>
<style>@keyframes spin{to{transform:rotate(360deg)}}</style>

<!-- Remove learner confirm modal -->
<div id="remove-learner-modal" style="display:none;position:fixed;inset:0;z-index:80;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,0.5);">
  <div style="background:#fff;border-radius:18px;box-shadow:0 8px 40px rgba(0,0,0,0.18);width:100%;max-width:360px;padding:28px 24px;">
