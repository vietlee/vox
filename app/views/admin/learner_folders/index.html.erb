<% content_for :title, t("learner_folders.index.page_title") %>

<div class="flex items-center justify-between mb-6">
  <div class="flex items-center gap-3">
    <%= render "admin/shared/back_btn" %>
    <div>
      <h1 class="text-[20px] font-extrabold text-slate-900">🎓 <%= t("learner_folders.index.page_title") %></h1>
      <p class="text-[13px] text-slate-500 mt-0.5"><%= t("learner_folders.index.subtitle") %></p>
    </div>
  </div>
  <button onclick="document.getElementById('new-folder-modal').style.display='flex'"
          class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-[#1e3a5f] hover:bg-[#16304f] text-white text-[13px] font-bold rounded-xl transition-colors">
    <%= t("learner_folders.index.new_folder_btn") %>
  </button>
</div>

<!-- Stats -->
<div class="grid grid-cols-2 gap-4 mb-6">
  <div class="bg-white border border-slate-200 rounded-2xl p-5 text-center">
    <p class="text-3xl font-black text-[#1e3a5f]"><%= @folders.count %></p>
    <p class="text-[12px] text-slate-400 mt-1 font-semibold"><%= t("learner_folders.index.stat_folders") %></p>
  </div>
  <div class="bg-white border border-slate-200 rounded-2xl p-5 text-center">
    <p class="text-3xl font-black text-emerald-600"><%= @total_learners %></p>
    <p class="text-[12px] text-slate-400 mt-1 font-semibold"><%= t("learner_folders.index.stat_learners") %></p>
  </div>
</div>

<% if @folders.any? %>
  <div class="space-y-3">
    <% @folders.each do |folder| %>
      <div class="bg-white border border-slate-200 hover:border-[#1e3a5f]/30 hover:shadow-sm rounded-2xl p-4 transition-all">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-gradient-to-br from-[#eef3fa] to-[#dce8f5] rounded-xl flex items-center justify-center shrink-0 text-2xl">📁</div>
          <div class="flex-1 min-w-0">
            <%= link_to folder.name, learner_folder_path(folder),
                class: "text-[16px] font-bold text-slate-800 hover:text-[#1e3a5f] transition-colors" %>
            <p class="text-[12px] text-slate-400 mt-0.5">
              <span class="font-semibold text-slate-600"><%= folder.member_count %> learners</span>
              · <%= t("learner_folders.index.created_by", name: folder.created_by.name) %> · <%= folder.created_at.strftime("%d/%m/%Y") %>
            </p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <%= link_to learner_folder_path(folder),
                class: "inline-flex items-center gap-1 px-3 py-1.5 text-[12px] font-semibold bg-[#eef3fa] hover:bg-[#dce8f5] text-[#1e3a5f] rounded-lg transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <%= t("learner_folders.index.view_btn") %>
            <% end %>
            <%= button_to learner_folder_path(folder), method: :delete,
                data: { confirm: t("learner_folders.index.delete_confirm", name: folder.name) },
                class: "inline-flex items-center gap-1 px-3 py-1.5 text-[12px] font-semibold bg-red-50 hover:bg-red-100 text-red-600 rounded-lg transition-colors border-0 cursor-pointer" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <%= t("learner_folders.index.delete_btn") %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-20 bg-white border border-dashed border-slate-300 rounded-2xl">
    <div class="text-6xl mb-4">📁</div>
    <h3 class="text-[15px] font-bold text-slate-700 mb-2"><%= t("learner_folders.index.empty_title") %></h3>
    <p class="text-[13px] text-slate-400 mb-5"><%= t("learner_folders.index.empty_desc") %></p>
    <button onclick="document.getElementById('new-folder-modal').style.display='flex'"
            class="inline-flex items-center gap-1.5 px-5 py-2.5 bg-[#1e3a5f] text-white text-[13px] font-bold rounded-xl">
      <%= t("learner_folders.index.first_folder_btn") %>
    </button>
  </div>
<% end %>

<!-- New folder modal -->
<div id="new-folder-modal" style="display:none;position:fixed;inset:0;z-index:60;align-items:center;justify-content:center;padding:16px;background:rgba(15,23,42,0.5);"
     onclick="if(event.target===this)this.style.display='none'">
  <div style="background:#fff;border-radius:20px;box-shadow:0 8px 40px rgba(0,0,0,0.18);width:100%;max-width:380px;padding:28px 24px;">
    <h3 style="font-size:16px;font-weight:800;color:#1e293b;margin:0 0 16px;"><%= t("learner_folders.index.modal_title") %></h3>
    <%= form_with url: learner_folders_path, method: :post do %>
      <div style="margin-bottom:16px;">
        <label style="display:block;font-size:12px;font-weight:700;color:#374151;margin-bottom:6px;"><%= t("learner_folders.index.folder_name_label") %></label>
        <%= text_field_tag "learner_folder[name]", nil, required: true, placeholder: t("learner_folders.index.folder_name_placeholder"),
            style: "width:100%;box-sizing:border-box;padding:11px 12px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:14px;outline:none;font-family:inherit;",
            onfocus: "this.style.borderColor='#1e3a5f'", onblur: "this.style.borderColor='#e5e7eb'" %>
      </div>
      <div style="display:flex;gap:8px;">
        <%= submit_tag t("learner_folders.index.create_btn"), style: "flex:1;padding:11px;background:#1e3a5f;color:#fff;font-weight:700;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;" %>
        <button type="button" onclick="document.getElementById('new-folder-modal').style.display='none'"
                style="flex:1;padding:11px;background:#f1f5f9;color:#475569;font-weight:600;font-size:13px;border:none;border-radius:12px;cursor:pointer;font-family:inherit;"><%= t("learner_folders.index.cancel") %></button>
      </div>
    <% end %>
  </div>
</div>
