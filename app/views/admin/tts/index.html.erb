<% content_for :title, t("tts.title") %>
<% content_for :main_class, "flex-1 overflow-hidden flex flex-col" %>
<% content_for :breadcrumb do %>
  <span class="text-slate-700 font-medium"><%= t("tts.title") %></span>
<% end %>

<!-- ── Page header ──────────────────────────────────────────────────── -->
<div class="flex-shrink-0 px-6 pt-5 pb-4 bg-slate-100">
  <div class="flex items-start justify-between">
    <div class="flex items-start gap-3">
      <%= render "admin/shared/back_btn" %>
      <div>
        <h1 class="text-[21px] font-extrabold text-slate-900 flex items-center gap-2">
          🎙️ <%= t("tts.title") %>
        </h1>
        <p class="text-[13px] text-slate-500 mt-0.5"><%= t("tts.subtitle") %></p>
      </div>
    </div>
  </div>
</div>

<!-- ── Scrollable content ────────────────────────────────────────────── -->
<div class="flex-1 min-h-0 overflow-y-auto px-6 py-5">

<% if @has_tts %>
  <%# ── MAIN TTS UI ─────────────────────────────────────────────────── %>
  <div data-controller="tts"
       data-tts-voices-url="<%= tts_voices_path %>"
       data-tts-generate-url="<%= tts_generate_path %>"
       data-tts-label-generating="<%= t("tts.generating") %>"
       data-tts-label-generate="🎙️ <%= t("tts.generate_btn") %>"
       data-tts-label-other-voices="<%= t("tts.other_voices") %>">

    <% unless ENV["ELEVENLABS_API_KEY"].present? %>
      <div class="mb-4 p-4 bg-amber-50 border border-amber-200 rounded-xl text-amber-800 text-[13px] flex items-start gap-2">
        ⚠️ <span><%= t("tts.no_key") %></span>
      </div>
    <% end %>

    <div class="grid grid-cols-[2fr_1fr] gap-5 items-start">

      <!-- ── Left: Input + Result ──────────────────────────────────── -->
      <div class="space-y-4">

        <!-- Text Input -->
        <div class="bg-white rounded-xl border border-slate-200 p-5">
          <label class="block text-[12px] font-bold text-slate-600 mb-2 uppercase tracking-wide">
            <%= t("tts.text_label") %>
          </label>
          <textarea
            data-tts-target="text"
            data-action="input->tts#countChars"
            rows="10"
            maxlength="5000"
            placeholder="<%= t("tts.text_placeholder") %>"
            class="w-full px-3 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-[13px] text-slate-800 placeholder-slate-400 resize-y focus:outline-none focus:ring-2 focus:ring-indigo-300 focus:border-indigo-300 transition-colors"
          ></textarea>

          <div class="flex justify-between items-center mt-2">
            <div class="flex items-center gap-3 text-[11px]">
              <span>
                <span data-tts-target="charCount" class="font-mono font-semibold text-slate-600">0</span>
                <span class="text-slate-400"> / 5,000 <%= t("tts.char_count") %></span>
              </span>
              <span class="text-slate-300">|</span>
              <span class="text-slate-400"><%= t("tts.cost_estimate") %>:
                <span data-tts-target="costEstimate" class="font-semibold text-indigo-600">—</span>
              </span>
            </div>
            <div class="w-32 h-1 bg-slate-100 rounded-full overflow-hidden">
              <div data-tts-target="charBar" class="h-full bg-indigo-400 rounded-full transition-all" style="width:0%"></div>
            </div>
          </div>
        </div>

        <!-- Generate Button -->
        <button
          data-tts-target="generateBtn"
          data-action="click->tts#generate"
          class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-[14px] font-bold rounded-xl transition-colors flex items-center justify-center gap-2 shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span data-tts-target="btnLabel">🎙️ <%= t("tts.generate_btn") %></span>
          <svg data-tts-target="spinner" class="hidden w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>

        <!-- Result / Audio Player -->
        <div data-tts-target="result" class="hidden bg-white rounded-xl border border-slate-200 p-5">
          <h3 class="text-[12px] font-bold text-slate-600 mb-3 uppercase tracking-wide"><%= t("tts.result_label") %></h3>
          <audio data-tts-target="player" controls class="w-full rounded-lg" style="height:48px"></audio>
          <div class="mt-3 flex gap-2">
            <a data-tts-target="downloadLink" href="#" download="tts-audio.mp3"
              class="inline-flex items-center gap-1.5 px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 text-[12px] font-semibold rounded-lg transition-colors">
              ⬇️ <%= t("tts.download_btn") %>
            </a>
          </div>
        </div>

        <!-- Error -->
        <div data-tts-target="error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-[13px]"></div>

      </div>

      <!-- ── Right: Settings ─────────────────────────────────────── -->
      <div class="space-y-3">

        <!-- Voice Picker -->
        <div class="bg-white rounded-xl border border-slate-200 p-4">
          <label class="block text-[12px] font-semibold text-slate-500 mb-2"><%= t("tts.voice_label") %></label>
          <select data-tts-target="voiceSelect" data-action="change->tts#voiceChanged"
            class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg text-[13px] text-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition-colors">
            <option value=""><%= t("tts.voice_loading") %></option>
          </select>
          <div data-tts-target="voicePreview" class="hidden mt-3 pt-3 border-t border-slate-100">
            <p class="text-[11px] text-slate-400 mb-1.5"><%= t("tts.preview_label") %></p>
            <audio data-tts-target="previewPlayer" controls class="w-full" style="height:36px"></audio>
          </div>
        </div>

        <!-- Model -->
        <div class="bg-white rounded-xl border border-slate-200 p-4">
          <label class="block text-[12px] font-semibold text-slate-500 mb-2"><%= t("tts.model_label") %></label>
          <select data-tts-target="modelSelect" data-action="change->tts#updateCost"
            class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg text-[13px] text-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition-colors">
            <option value="eleven_turbo_v2_5" selected>⚡ Flash v2.5 — <%= t("tts.model_flash") %></option>
            <option value="eleven_v3">✨ Eleven v3 — <%= t("tts.model_v3") %></option>
            <option value="eleven_multilingual_v2">🎙️ Multilingual v2 — <%= t("tts.model_multilingual") %></option>
          </select>
        </div>

        <!-- Voice Settings — ElevenLabs style -->
        <div class="bg-white rounded-xl border border-slate-200 p-4 space-y-5">

          <!-- Speed -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-[13px] font-semibold text-slate-800"><%= t("tts.speed_label") %></span>
              <span data-tts-target="speedVal" class="text-[12px] font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded-md">1.0x</span>
            </div>
            <input type="range" min="0.7" max="1.2" step="0.05" value="1.0"
              data-tts-target="speed" data-action="input->tts#updateSliders"
              class="w-full accent-slate-800 h-1.5 cursor-pointer">
            <div class="flex justify-between text-[11px] text-slate-400 mt-1.5">
              <span><%= t("tts.speed_slow") %></span>
              <span><%= t("tts.speed_fast") %></span>
            </div>
          </div>

          <hr class="border-slate-100">

          <!-- Stability -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-[13px] font-semibold text-slate-800"><%= t("tts.stability_label") %></span>
              <span data-tts-target="stabilityVal" class="text-[12px] font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded-md">0.50</span>
            </div>
            <input type="range" min="0" max="1" step="0.05" value="0.50"
              data-tts-target="stability" data-action="input->tts#updateSliders"
              class="w-full accent-slate-800 h-1.5 cursor-pointer">
            <div class="flex justify-between text-[11px] text-slate-400 mt-1.5">
              <span><%= t("tts.stability_low") %></span>
              <span><%= t("tts.stability_high") %></span>
            </div>
          </div>

          <hr class="border-slate-100">

          <!-- Similarity -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-[13px] font-semibold text-slate-800"><%= t("tts.similarity_label") %></span>
              <span data-tts-target="similarityVal" class="text-[12px] font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded-md">0.75</span>
            </div>
            <input type="range" min="0" max="1" step="0.05" value="0.75"
              data-tts-target="similarity" data-action="input->tts#updateSliders"
              class="w-full accent-slate-800 h-1.5 cursor-pointer">
            <div class="flex justify-between text-[11px] text-slate-400 mt-1.5">
              <span><%= t("tts.similarity_low") %></span>
              <span><%= t("tts.similarity_high") %></span>
            </div>
          </div>

          <hr class="border-slate-100">

          <!-- Style -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <span class="text-[13px] font-semibold text-slate-800"><%= t("tts.style_label") %></span>
              <span data-tts-target="styleVal" class="text-[12px] font-mono bg-slate-100 text-slate-600 px-2 py-0.5 rounded-md">0.00</span>
            </div>
            <input type="range" min="0" max="1" step="0.05" value="0.00"
              data-tts-target="style" data-action="input->tts#updateSliders"
              class="w-full accent-slate-800 h-1.5 cursor-pointer">
            <div class="flex justify-between text-[11px] text-slate-400 mt-1.5">
              <span><%= t("tts.style_none") %></span>
              <span><%= t("tts.style_exaggerated") %></span>
            </div>
          </div>

        </div>

        <!-- Output Format -->
        <div class="bg-white rounded-xl border border-slate-200 p-4">
          <label class="block text-[12px] font-semibold text-slate-500 mb-2"><%= t("tts.output_format_label") %></label>
          <select data-tts-target="outputFormat"
            class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg text-[13px] text-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-300 transition-colors">
            <option value="mp3_44100_192">MP3 44.1 kHz (192 kbps)</option>
            <option value="mp3_44100_128" selected>MP3 44.1 kHz (128 kbps)</option>
            <option value="mp3_44100_64">MP3 44.1 kHz (64 kbps)</option>
          </select>
        </div>

      </div>
    </div>
  </div>

<% else %>
  <%# ── UPGRADE LANDING PAGE ─────────────────────────────────────────── %>
  <div class="max-w-2xl mx-auto py-10">
    <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">

      <!-- Hero -->
      <div class="bg-gradient-to-br from-indigo-600 to-violet-600 px-8 py-10 text-center text-white">
        <div class="text-5xl mb-4">🎙️</div>
        <h2 class="text-2xl font-extrabold mb-2"><%= t("tts.title") %></h2>
        <p class="text-indigo-200 text-[14px]"><%= t("tts.upgrade_desc") %></p>
      </div>

      <!-- Features -->
      <div class="px-8 py-6">
        <p class="text-[12px] font-bold text-slate-500 uppercase tracking-widest mb-4"><%= t("tts.upgrade_title") %></p>
        <ul class="space-y-3 mb-6">
          <% [:upgrade_feature_1, :upgrade_feature_2, :upgrade_feature_3, :upgrade_feature_4].each do |key| %>
            <li class="flex items-center gap-3 text-[13px] text-slate-700">
              <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center flex-shrink-0 text-[11px] font-bold">✓</span>
              <%= t("tts.#{key}") %>
            </li>
          <% end %>
        </ul>

        <!-- Plan comparison -->
        <div class="grid grid-cols-2 gap-3 mb-6">
          <div class="rounded-xl border-2 border-indigo-500 bg-indigo-50 p-4 text-center">
            <div class="text-[11px] font-bold text-indigo-600 uppercase tracking-wide mb-1">Pro</div>
            <div class="text-xl font-extrabold text-slate-800">190.000₫<span class="text-[12px] font-normal text-slate-400"><%= t("tts.per_month") %></span></div>
            <div class="text-[11px] text-slate-500 mt-1"><%= t("tts.pro_credits") %></div>
          </div>
          <div class="rounded-xl border-2 border-violet-500 bg-violet-50 p-4 text-center">
            <div class="text-[11px] font-bold text-violet-600 uppercase tracking-wide mb-1">Enterprise</div>
            <div class="text-xl font-extrabold text-slate-800">390.000₫<span class="text-[12px] font-normal text-slate-400"><%= t("tts.per_month") %></span></div>
            <div class="text-[11px] text-slate-500 mt-1"><%= t("tts.enterprise_credits") %></div>
          </div>
        </div>

        <%= link_to subscription_path, class: "block w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-[14px] font-bold rounded-xl text-center transition-colors" do %>
          <%= t("tts.upgrade_btn") %> →
        <% end %>
      </div>

    </div>
  </div>
<% end %>

</div>
