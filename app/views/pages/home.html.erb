<% t = ->(k) { t("landing.#{k}") } %>

<style>
* { box-sizing: border-box; }
:root { --navy:#1e3a5f; --navy-md:#2d5f8a; --navy-lt:#4a80a8; }
.gtext { background: linear-gradient(135deg,#4a80a8 0%,#7aaac9 60%,#b3cbe3 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.hero-dark { background:#06101f; position:relative; overflow:hidden; }
.aurora { position:absolute; border-radius:50%; filter:blur(80px); opacity:.3; }
.aurora-1 { width:600px; height:600px; background:radial-gradient(circle,#1e3a5f,transparent 70%); top:-200px; left:-100px; animation:drift1 18s ease-in-out infinite alternate; }
.aurora-2 { width:500px; height:500px; background:radial-gradient(circle,#2d5f8a,transparent 70%); top:0; right:-150px; animation:drift2 14s ease-in-out infinite alternate; }
.aurora-3 { width:400px; height:400px; background:radial-gradient(circle,#0ea5e9,transparent 70%); bottom:-100px; left:30%; animation:drift3 20s ease-in-out infinite alternate; opacity:.15; }
@keyframes drift1 { from{transform:translate(0,0) scale(1);} to{transform:translate(60px,40px) scale(1.15);} }
@keyframes drift2 { from{transform:translate(0,0) scale(1);} to{transform:translate(-40px,60px) scale(1.1);} }
@keyframes drift3 { from{transform:translate(0,0);} to{transform:translate(30px,-30px);} }
.grid-overlay { position:absolute; inset:0; z-index:0; background-image:linear-gradient(rgba(255,255,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(255,255,255,.025) 1px,transparent 1px); background-size:60px 60px; }
.feat-card { transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease; border:1px solid #eef2f7; background:#fff; }
.feat-card:hover { transform:translateY(-6px); box-shadow:0 24px 48px rgba(30,58,95,.12); border-color:rgba(30,58,95,.18); }
.aud-card { transition:transform .25s ease, box-shadow .25s ease; }
.aud-card:hover { transform:translateY(-4px); box-shadow:0 30px 60px rgba(30,58,95,.14); }
@keyframes fadeUp { from{opacity:0;transform:translateY(28px);} to{opacity:1;transform:translateY(0);} }
.fade-up{ animation:fadeUp .7s ease forwards; } .fade-up-2{ animation:fadeUp .7s .12s ease forwards; opacity:0; } .fade-up-3{ animation:fadeUp .7s .24s ease forwards; opacity:0; } .fade-up-4{ animation:fadeUp .7s .38s ease forwards; opacity:0; }
@keyframes pulse-ring { 0%,100%{opacity:.6;transform:scale(1);} 50%{opacity:1;transform:scale(1.04);} }
@keyframes barGrow { from{width:0;} to{width:var(--w);} }
.bar-animate { animation:barGrow 1.4s .8s cubic-bezier(.16,1,.3,1) forwards; width:0; }
.badge-live { display:inline-flex; align-items:center; gap:6px; padding:5px 14px; border-radius:999px; font-size:12px; font-weight:700; background:rgba(74,128,168,.15); border:1px solid rgba(74,128,168,.35); color:#7aaac9; }
</style>

<!-- ═══ NAV ═══ -->
<nav style="position:sticky; top:0; z-index:100; background:rgba(6,16,31,.88); border-bottom:1px solid rgba(255,255,255,.07); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between" style="height:64px;">
    <img src="/vox_logo_white.svg" alt="VOX" style="height:22px;">
    <div class="hidden sm:flex items-center gap-7" style="font-size:14px; font-weight:500; color:rgba(255,255,255,.6);">
      <a href="#features"      onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'"><%= t.("nav.features") %></a>
      <a href="#for-trainers"  onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'"><%= t.("nav.for_trainers") %></a>
      <a href="#for-learners"  onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'"><%= t.("nav.for_learners") %></a>
      <a href="#apps"          onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'">App</a>
      <a href="#pricing"       onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,.6)'"><%= t.("nav.pricing") %></a>
    </div>
    <div class="flex items-center gap-2">
      <div style="display:flex; border-radius:999px; overflow:hidden; border:1px solid rgba(255,255,255,.15); font-size:11px; font-weight:700;">
        <a href="?locale=vi" style="padding:5px 12px; <%= I18n.locale.to_s == 'vi' ? 'background:#1e3a5f; color:#fff;' : 'color:rgba(255,255,255,.5);' %>">VI</a>
        <a href="?locale=en" style="padding:5px 12px; <%= I18n.locale.to_s == 'en' ? 'background:#1e3a5f; color:#fff;' : 'color:rgba(255,255,255,.5);' %>">EN</a>
      </div>
      <%# Single sign-in dropdown (learner / trainer) — shared by mobile & desktop %>
      <style>#signin-menu summary::-webkit-details-marker { display: none; }</style>
      <details id="signin-menu" style="position:relative;">
        <summary style="list-style:none; cursor:pointer; font-size:13px; font-weight:700; color:rgba(255,255,255,.85); padding:8px 14px; border-radius:8px; border:1px solid rgba(255,255,255,.22); white-space:nowrap; display:flex; align-items:center; gap:5px;">
          <%= t.("nav.sign_in") %><span style="font-size:9px; opacity:.6;">▼</span>
        </summary>
        <div style="position:absolute; right:0; top:calc(100% + 8px); min-width:170px; background:#0b1a2e; border:1px solid rgba(255,255,255,.12); border-radius:12px; padding:6px; box-shadow:0 12px 32px rgba(0,0,0,.5); z-index:200;">
          <%= link_to new_learner_session_path, style: "display:block; padding:10px 14px; border-radius:8px; font-size:13px; font-weight:600; color:#fff; text-decoration:none;", onmouseover: "this.style.background='rgba(255,255,255,.08)'", onmouseout: "this.style.background='transparent'" do %>
            <%= t.("nav.role_learner") %><span style="display:block; font-size:11px; font-weight:500; color:rgba(255,255,255,.45);"><%= t.("nav.sign_in_learner") %></span>
          <% end %>
          <%= link_to new_user_session_path, style: "display:block; padding:10px 14px; border-radius:8px; font-size:13px; font-weight:600; color:#fff; text-decoration:none;", onmouseover: "this.style.background='rgba(255,255,255,.08)'", onmouseout: "this.style.background='transparent'" do %>
            <%= t.("nav.role_trainer") %><span style="display:block; font-size:11px; font-weight:500; color:rgba(255,255,255,.45);"><%= t.("nav.sign_in_trainer") %></span>
          <% end %>
        </div>
      </details>
      <script>
        document.addEventListener("click", function(e) {
          var m = document.getElementById("signin-menu");
          if (m && m.open && !m.contains(e.target)) m.removeAttribute("open");
        });
      </script>
      <%= link_to t.("nav.get_started"), new_user_registration_path, class: "hidden sm:inline", style: "font-size:13px; font-weight:700; color:#fff; padding:9px 18px; border-radius:8px; background:linear-gradient(135deg,#1e3a5f,#2d5f8a); box-shadow:0 0 20px rgba(30,58,95,.5);", onmouseover: "this.style.opacity='.88'", onmouseout: "this.style.opacity='1'" %>
    </div>
  </div>
</nav>

<!-- ═══ HERO ═══ -->
<section class="hero-dark" style="display:flex; align-items:center;">
  <div class="aurora aurora-1"></div><div class="aurora aurora-2"></div><div class="aurora aurora-3"></div>
  <div class="grid-overlay"></div>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center relative" style="z-index:1; padding-top:76px; padding-bottom:76px; width:100%;">
    <div class="badge-live fade-up" style="margin-bottom:26px;">
      <span style="width:7px; height:7px; border-radius:50%; background:#22d3ee; animation:pulse-ring 2s infinite;"></span>
      <%= t.("hero.badge") %>
    </div>
    <h1 style="font-size:clamp(36px,7vw,74px); font-weight:900; line-height:1.06; letter-spacing:-0.03em; color:#fff; margin-bottom:22px;" class="fade-up-2">
      <%= t.("hero.title_1") %><br><span class="gtext"><%= t.("hero.title_2") %></span>
    </h1>
    <p style="font-size:clamp(15px,2.5vw,20px); color:rgba(255,255,255,.55); max-width:640px; margin:0 auto 38px; line-height:1.7;" class="fade-up-3">
      <%= t.("hero.subtitle") %>
    </p>
    <div class="fade-up-3" style="display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-bottom:20px;">
      <%= link_to new_user_registration_path, style: "display:inline-flex; align-items:center; gap:8px; padding:14px 28px; font-size:15px; font-weight:700; color:#fff; border-radius:12px; background:linear-gradient(135deg,#1e3a5f,#2d5f8a); box-shadow:0 0 40px rgba(30,58,95,.6); text-decoration:none;", onmouseover: "this.style.transform='scale(1.04)'", onmouseout: "this.style.transform='scale(1)'" do %>
        <%= t.("hero.cta_primary") %>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      <% end %>
      <a href="#features" style="display:inline-flex; align-items:center; gap:8px; padding:14px 28px; font-size:15px; font-weight:600; color:rgba(255,255,255,.8); border-radius:12px; background:rgba(255,255,255,.07); border:1px solid rgba(255,255,255,.13); text-decoration:none;" onmouseover="this.style.background='rgba(255,255,255,.12)'" onmouseout="this.style.background='rgba(255,255,255,.07)'">
        <%= t.("hero.cta_secondary") %>
      </a>
    </div>
    <p class="fade-up-4" style="font-size:13px; color:rgba(255,255,255,.32);">✓ <%= t.("hero.note") %></p>
    <div class="fade-up-4" style="display:flex; align-items:center; justify-content:center; gap:18px; margin-top:14px; flex-wrap:wrap;">
      <span style="font-size:12px; color:rgba(255,255,255,.22); font-weight:600; letter-spacing:.04em; text-transform:uppercase;"><%= t.("hero.platforms") %></span>
      <!-- iOS -->
      <div style="display:flex; align-items:center; gap:6px; padding:5px 14px; border-radius:99px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,.7)"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        <span style="font-size:12px; font-weight:600; color:rgba(255,255,255,.7);">iOS</span>
      </div>
      <!-- Android -->
      <div style="display:flex; align-items:center; gap:6px; padding:5px 14px; border-radius:99px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,.7)"><path d="M17.523 15.341c-.31 0-.56-.25-.56-.56V8.69c0-.31.25-.56.56-.56.31 0 .56.25.56.56v6.09c0 .31-.25.56-.56.56zm-11.046 0c-.31 0-.56-.25-.56-.56V8.69c0-.31.25-.56.56-.56.31 0 .56.25.56.56v6.09c0 .31-.25.56-.56.56zm1.5 3.22c0 .48.39.87.87.87h.78v2.53c0 .44.36.8.8.8s.8-.36.8-.8v-2.53h1.56v2.53c0 .44.36.8.8.8s.8-.36.8-.8v-2.53h.78c.48 0 .87-.39.87-.87V8.69H7.977v9.871zM14.688 3.56l.9-1.56c.05-.09.02-.2-.07-.25-.09-.05-.2-.02-.25.07l-.91 1.58A5.865 5.865 0 0012 3.03c-.82 0-1.6.16-2.31.44l-.91-1.58c-.05-.09-.17-.12-.25-.07-.09.05-.12.17-.07.25l.9 1.56C8.05 4.54 7.1 5.9 7.1 7.5h9.8c0-1.6-.95-2.96-2.21-3.94zM10.1 6.1c-.33 0-.6-.27-.6-.6s.27-.6.6-.6.6.27.6.6-.27.6-.6.6zm3.8 0c-.33 0-.6-.27-.6-.6s.27-.6.6-.6.6.27.6.6-.27.6-.6.6z"/></svg>
        <span style="font-size:12px; font-weight:600; color:rgba(255,255,255,.7);">Android</span>
      </div>
      <!-- Web -->
      <div style="display:flex; align-items:center; gap:6px; padding:5px 14px; border-radius:99px; background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.1);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.7)" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
        <span style="font-size:12px; font-weight:600; color:rgba(255,255,255,.7);">Web</span>
      </div>
    </div>

    <!-- Dual mockup: trainer creates · learner studies -->
    <div class="fade-up-4" style="margin-top:60px; position:relative;">
      <div style="position:absolute; bottom:-40px; left:50%; transform:translateX(-50%); width:70%; height:60px; background:radial-gradient(ellipse,rgba(30,58,95,.5),transparent 70%); filter:blur(20px);"></div>
      <div style="border-radius:16px; overflow:hidden; box-shadow:0 40px 120px rgba(0,0,0,.6), 0 0 0 1px rgba(255,255,255,.08); max-width:820px; margin:0 auto;">
        <div style="background:#111827; padding:12px 16px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,.07);">
          <div style="display:flex; gap:6px;"><div style="width:12px;height:12px;border-radius:50%;background:#ff5f57;"></div><div style="width:12px;height:12px;border-radius:50%;background:#febc2e;"></div><div style="width:12px;height:12px;border-radius:50%;background:#28c840;"></div></div>
          <div style="flex:1; background:rgba(255,255,255,.06); border-radius:6px; padding:5px 12px; font-size:12px; color:rgba(255,255,255,.3); text-align:center;">vox.czin.net</div>
          <div style="display:flex; align-items:center; gap:6px; font-size:11px; font-weight:700; color:#4ade80;"><span style="width:6px;height:6px;border-radius:50%;background:#4ade80;animation:pulse-ring 2s infinite;"></span> AI</div>
        </div>
        <div style="background:#0f172a; padding:22px; display:grid; grid-template-columns:1fr 1fr; gap:14px;" class="hero-mockup-grid">
          <!-- Trainer: AI generation -->
          <div style="background:linear-gradient(135deg,#1e3a5f,#162c47); border-radius:14px; padding:18px; border:1px solid rgba(74,128,168,.3); text-align:left;">
            <div style="font-size:11px; font-weight:700; color:#7aaac9; letter-spacing:.08em; margin-bottom:8px;">✨ <%= t.("trainer.label") %></div>
            <div style="font-size:14px; font-weight:700; color:#fff; margin-bottom:12px; line-height:1.4;"><%= t.("features.ai_create_t") %></div>
            <div style="display:flex; gap:6px; flex-wrap:wrap;">
              <span style="font-size:11px; padding:3px 10px; border-radius:99px; background:rgba(255,255,255,.1); color:rgba(255,255,255,.75);">📋 Quiz</span>
              <span style="font-size:11px; padding:3px 10px; border-radius:99px; background:rgba(255,255,255,.1); color:rgba(255,255,255,.75);">🎴 Flashcard</span>
              <span style="font-size:11px; padding:3px 10px; border-radius:99px; background:rgba(255,255,255,.1); color:rgba(255,255,255,.75);">🗺️ Path</span>
            </div>
            <div style="margin-top:14px; height:6px; background:rgba(255,255,255,.1); border-radius:99px; overflow:hidden;"><div class="bar-animate" style="--w:88%; height:100%; background:linear-gradient(90deg,#4a80a8,#7aaac9); border-radius:99px;"></div></div>
            <div style="font-size:11px; color:rgba(255,255,255,.4); margin-top:6px;">AI · 20 <%= I18n.locale.to_s=='vi' ? 'câu tạo trong 8 giây' : 'questions in 8s' %></div>
          </div>
          <!-- Learner: gamification -->
          <div style="background:rgba(255,255,255,.03); border-radius:14px; padding:18px; border:1px solid rgba(255,255,255,.07); text-align:left;">
            <div style="font-size:11px; font-weight:700; color:#f59e0b; letter-spacing:.08em; margin-bottom:8px;">🎓 <%= t.("learner.label") %></div>
            <div style="display:flex; gap:10px; margin-bottom:12px;">
              <div style="flex:1; background:rgba(249,115,22,.12); border:1px solid rgba(249,115,22,.25); border-radius:10px; padding:10px; text-align:center;"><div style="font-size:18px; font-weight:900; color:#fb923c;">🔥 12</div><div style="font-size:10px; color:rgba(255,255,255,.5);">streak</div></div>
              <div style="flex:1; background:rgba(74,128,168,.12); border:1px solid rgba(74,128,168,.25); border-radius:10px; padding:10px; text-align:center;"><div style="font-size:18px; font-weight:900; color:#7aaac9;">⚡ 840</div><div style="font-size:10px; color:rgba(255,255,255,.5);">XP</div></div>
            </div>
            <div style="font-size:12px; color:rgba(255,255,255,.7); margin-bottom:6px;"><%= I18n.locale.to_s=='vi' ? 'Mục tiêu hôm nay' : "Today's goal" %> · 3/3</div>
            <div style="height:6px; background:rgba(255,255,255,.1); border-radius:99px; overflow:hidden;"><div class="bar-animate" style="--w:100%; height:100%; background:linear-gradient(90deg,#f59e0b,#fbbf24); border-radius:99px;"></div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══ AUDIENCES ═══ -->
<section style="background:#f7fafc; padding:88px 0;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div style="text-align:center; max-width:620px; margin:0 auto 48px;">
      <h2 style="font-size:clamp(26px,4vw,40px); font-weight:900; color:#0f172a; letter-spacing:-0.02em; margin-bottom:12px;"><%= t.("audiences.title") %></h2>
      <p style="font-size:16px; color:#64748b; line-height:1.7;"><%= t.("audiences.subtitle") %></p>
    </div>
    <div style="display:grid; grid-template-columns:1fr; gap:20px;" class="aud-grid">
      <% [
        { id:"for-trainers", key:"trainer", accent:"#1e3a5f", bg:"linear-gradient(160deg,#0e1e30,#182f4a)", dark:true, url:new_user_registration_path, icon:'M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z' },
        { id:"for-learners", key:"learner", accent:"#f59e0b", bg:"#ffffff", dark:false, url:new_learner_session_path, icon:'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z' }
      ].each do |a| %>
        <div id="<%= a[:id] %>" class="aud-card" style="border-radius:22px; padding:34px; background:<%= a[:bg] %>; <%= a[:dark] ? 'border:1px solid rgba(74,128,168,.3);' : 'border:1px solid #e6edf5;' %>">
          <div style="width:52px; height:52px; border-radius:14px; background:<%= a[:dark] ? 'rgba(74,128,168,.2)' : '#f0f6ff' %>; display:flex; align-items:center; justify-content:center; margin-bottom:18px;">
            <svg width="26" height="26" fill="none" stroke="<%= a[:dark] ? '#7aaac9' : a[:accent] %>" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="<%= a[:icon] %>"/></svg>
          </div>
          <p style="font-size:12px; font-weight:800; letter-spacing:.06em; text-transform:uppercase; color:<%= a[:dark] ? '#7aaac9' : a[:accent] %>; margin-bottom:8px;"><%= t.("#{a[:key]}.label") %></p>
          <h3 style="font-size:24px; font-weight:800; letter-spacing:-0.01em; margin-bottom:10px; color:<%= a[:dark] ? '#fff' : '#0f172a' %>;"><%= t.("#{a[:key]}.title") %></h3>
          <p style="font-size:15px; line-height:1.7; margin-bottom:20px; color:<%= a[:dark] ? 'rgba(255,255,255,.6)' : '#64748b' %>;"><%= t.("#{a[:key]}.desc") %></p>
          <div style="display:grid; gap:11px; margin-bottom:26px;">
            <% ["f1","f2","f3","f4"].each do |f| %>
              <div style="display:flex; gap:10px; align-items:flex-start;">
                <svg width="18" height="18" fill="none" stroke="<%= a[:dark] ? '#4ade80' : '#16a34a' %>" stroke-width="2.5" viewBox="0 0 24 24" style="flex-shrink:0; margin-top:1px;"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span style="font-size:14px; line-height:1.5; color:<%= a[:dark] ? 'rgba(255,255,255,.82)' : '#334155' %>;"><%= t.("#{a[:key]}.#{f}") %></span>
              </div>
            <% end %>
          </div>
          <div style="display:flex; flex-direction:column; gap:10px;">
