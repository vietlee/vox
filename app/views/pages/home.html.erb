<%
  vi = I18n.locale.to_s == "vi"
%>

<style>
  .gradient-text { background: linear-gradient(135deg, #4F46E5, #7C3AED, #A855F7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-bg { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); }
  .feature-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .feature-card:hover { transform: translateY(-4px); box-shadow: 0 20px 40px rgba(99,102,241,0.12); }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .float { animation: float 4s ease-in-out infinite; }
  .float-slow { animation: float 6s ease-in-out infinite; }
  @keyframes fadeUp { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:translateY(0); } }
  .fade-up { animation: fadeUp 0.7s ease forwards; }
  .fade-up-2 { animation: fadeUp 0.7s 0.15s ease forwards; opacity: 0; }
  .fade-up-3 { animation: fadeUp 0.7s 0.3s ease forwards; opacity: 0; }
</style>

<!-- ── NAV ─────────────────────────────────────────────────────────────────── -->
<nav class="sticky top-0 z-50 backdrop-blur-md border-b border-slate-100" style="background:rgba(255,255,255,0.9);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-16">
    <img src="/vox_logo.svg" alt="VOX" class="h-6 w-auto">
    <div class="hidden sm:flex items-center gap-6 text-[14px] font-medium text-slate-600">
      <a href="#features" class="hover:text-indigo-600 transition-colors"><%= vi ? "Tính năng" : "Features" %></a>
      <a href="#how-it-works" class="hover:text-indigo-600 transition-colors"><%= vi ? "Cách hoạt động" : "How it works" %></a>
      <a href="#pricing" class="hover:text-indigo-600 transition-colors"><%= vi ? "Giá" : "Pricing" %></a>
    </div>
    <div class="flex items-center gap-2">
      <!-- Language switcher -->
      <div class="flex items-center rounded-full overflow-hidden text-[12px] font-bold mr-1" style="border:1px solid rgba(99,102,241,0.2); background:rgba(255,255,255,0.7);">
        <a href="?locale=vi" class="transition-colors px-3 py-1.5 <%= I18n.locale.to_s == 'vi' ? 'text-white' : 'text-slate-500 hover:text-slate-700' %>" style="<%= I18n.locale.to_s == 'vi' ? 'background:#4F46E5;' : '' %>">VI</a>
        <a href="?locale=en" class="transition-colors px-3 py-1.5 <%= I18n.locale.to_s == 'en' ? 'text-white' : 'text-slate-500 hover:text-slate-700' %>" style="<%= I18n.locale.to_s == 'en' ? 'background:#4F46E5;' : '' %>">EN</a>
      </div>
      <%= link_to new_user_session_path, class: "text-[13px] font-semibold text-slate-600 hover:text-indigo-600 transition-colors px-3 py-2" do %>
        <%= vi ? "Đăng nhập" : "Sign in" %>
      <% end %>
      <%= link_to new_user_registration_path, class: "text-[13px] font-bold text-white px-4 py-2 rounded-lg transition-all hover:opacity-90", style: "background:linear-gradient(135deg,#4F46E5,#7C3AED);" do %>
        <%= vi ? "Dùng thử miễn phí" : "Try for free" %>
      <% end %>
    </div>
  </div>
</nav>

<!-- ── HERO ───────────────────────────────────────────────────────────────── -->
<section class="hero-bg py-20 sm:py-28 overflow-hidden relative">
  <!-- Decorative blobs -->
  <div class="absolute top-10 right-1/4 w-72 h-72 rounded-full opacity-30 float" style="background:radial-gradient(circle,#a5b4fc,transparent 70%);"></div>
  <div class="absolute bottom-10 left-1/4 w-48 h-48 rounded-full opacity-20 float-slow" style="background:radial-gradient(circle,#c084fc,transparent 70%);"></div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center relative">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full mb-6 text-[12px] font-bold text-indigo-700 fade-up" style="background:rgba(99,102,241,0.1); border:1px solid rgba(99,102,241,0.2);">
      <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 animate-pulse inline-block"></span>
      <%= vi ? "🎉 Ra mắt tại Việt Nam" : "🎉 Now live in Vietnam" %>
    </div>

    <h1 class="text-[40px] sm:text-[56px] font-black leading-tight tracking-tight mb-6 fade-up-2">
      <%= vi ? "Thu thập ý kiến\n" : "Engage your audience\n" %>
      <span class="gradient-text"><%= vi ? "theo thời gian thực" : "in real-time" %></span>
    </h1>

    <p class="text-[17px] sm:text-[19px] text-slate-500 leading-relaxed max-w-2xl mx-auto mb-10 fade-up-3">
      <%= vi ? "VOX giúp bạn tạo khảo sát, bình chọn trực tiếp và thu thập phản hồi — tất cả trong vài giây. Hoàn hảo cho hội thảo, lớp học và team của bạn." : "VOX helps you run surveys, live polls, and collect feedback — all in seconds. Perfect for workshops, classrooms, and your team." %>
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center fade-up-3">
      <%= link_to new_user_registration_path, class: "inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[15px] font-bold text-white rounded-xl shadow-lg hover:shadow-xl transition-all hover:scale-105", style: "background:linear-gradient(135deg,#4F46E5,#7C3AED);" do %>
        <%= vi ? "Bắt đầu miễn phí" : "Get started free" %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      <% end %>
      <a href="#how-it-works" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 text-[15px] font-semibold text-slate-700 rounded-xl bg-white border border-slate-200 hover:border-indigo-200 hover:text-indigo-700 transition-all">
        <%= vi ? "Xem demo" : "See demo" %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </a>
    </div>

    <!-- Social proof -->
    <p class="mt-8 text-[13px] text-slate-400 fade-up-3">
      ✓ <%= vi ? "Miễn phí · Không cần thẻ tín dụng · Bắt đầu trong 60 giây" : "Free plan · No credit card · Live in 60 seconds" %>
    </p>
  </div>
</section>

<!-- ── MOCKUP / PREVIEW ───────────────────────────────────────────────────── -->
<section class="py-12 sm:py-16 overflow-hidden" style="background:linear-gradient(180deg,#f0f4ff 0%,#ffffff 100%);">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <!-- Live poll mockup -->
    <div class="rounded-2xl shadow-2xl overflow-hidden border border-indigo-100/50 mx-auto max-w-3xl" style="background:#0F172A;">
      <!-- Presenter bar -->
      <div class="flex items-center justify-between px-5 py-3 border-b border-white/10">
        <img src="/vox_logo.svg" alt="VOX" class="h-5 w-auto opacity-80">
        <div class="flex items-center gap-3">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-400"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
            <div class="w-3 h-3 rounded-full bg-green-400"></div>
          </div>
        </div>
        <div class="text-[12px] font-bold text-white/50 flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span>
          <%= vi ? "TRỰC TIẾP" : "LIVE" %>
        </div>
      </div>
      <!-- Poll content -->
      <div class="px-6 py-8">
        <h3 class="text-[20px] sm:text-[24px] font-extrabold text-white text-center mb-6">
          <%= vi ? "Công cụ nào bạn dùng nhiều nhất?" : "Which tool do you use most?" %>
        </h3>
        <% options = vi ? [["Slack", 42], ["Zoom", 28], ["Teams", 18], ["Email", 12]] : [["Slack", 42], ["Zoom", 28], ["Teams", 18], ["Email", 12]] %>
        <% options.each_with_index do |(label, pct), i| %>
          <% colors = ["from-indigo-500 to-violet-500", "from-violet-500 to-purple-500", "from-purple-500 to-fuchsia-500", "from-fuchsia-500 to-pink-500"] %>
          <div class="mb-3">
            <div class="flex justify-between text-[13px] mb-1.5">
              <span class="font-semibold text-white/90"><%= label %></span>
              <span class="text-white/50 font-bold"><%= pct %>%</span>
            </div>
            <div class="h-3.5 rounded-full overflow-hidden" style="background:rgba(255,255,255,0.1);">
              <div class="h-full rounded-full bg-gradient-to-r <%= colors[i] %> transition-all" style="width:<%= pct %>%;"></div>
            </div>
          </div>
        <% end %>
        <div class="mt-6 flex items-center justify-center gap-2 text-[13px] text-white/40">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          142 <%= vi ? "người tham gia" : "participants" %>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── FEATURES ───────────────────────────────────────────────────────────── -->
<section id="features" class="py-20 sm:py-28 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <h2 class="text-[32px] sm:text-[40px] font-black text-slate-900 mb-4">
        <%= vi ? "Tất cả công cụ bạn cần" : "Everything you need" %>
      </h2>
      <p class="text-[16px] text-slate-500 max-w-xl mx-auto">
        <%= vi ? "Một nền tảng duy nhất để tạo khảo sát, bình chọn trực tiếp và thu thập phản hồi từ khán giả của bạn." : "One platform to create surveys, run live votes, and collect audience feedback." %>
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <%
        features = [
          { icon: "📊", color: "#4F46E5", bg: "#EEF2FF",
            title: vi ? "Khảo sát thông minh" : "Smart Surveys",
            desc:  vi ? "Tạo khảo sát nhiều loại câu hỏi, logic điều kiện, kiểm tra trùng lặp và phân tích AI." : "Multi-type questions, skip logic, duplicate prevention, and AI analysis." },
          { icon: "🗳️", color: "#7C3AED", bg: "#F5F3FF",
            title: vi ? "Bình chọn trực tiếp" : "Live Voting",
            desc:  vi ? "Bình chọn thời gian thực với kết quả cập nhật ngay lập tức. Trình chiếu đẹp cho sự kiện lớn." : "Real-time voting with instant results. Beautiful presenter mode for large events." },
          { icon: "💬", color: "#0EA5E9", bg: "#F0F9FF",
            title: vi ? "Thu thập phản hồi" : "Feedback Collection",
            desc:  vi ? "Bảng phản hồi công khai — người dùng đề xuất, upvote và bình luận theo thời gian thực." : "Public feedback boards — users suggest, upvote, and comment in real-time." },
          { icon: "✨", color: "#D97706", bg: "#FFFBEB",
            title: vi ? "Phân tích AI" : "AI Analysis",
            desc:  vi ? "Tóm tắt kết quả, tạo báo cáo chuyên nghiệp và nhận insight thông minh chỉ với một cú nhấp." : "Summarize results, generate professional reports, and get smart insights in one click." },
          { icon: "📱", color: "#059669", bg: "#F0FDF4",
            title: vi ? "Tối ưu mọi thiết bị" : "Mobile-first",
            desc:  vi ? "Giao diện tối ưu trên điện thoại, máy tính bảng và màn hình lớn. Người tham gia dùng ngay, không cần cài app." : "Perfect on phones, tablets, and large displays. No app download needed for participants." },
          { icon: "🔒", color: "#DC2626", bg: "#FFF1F2",
            title: vi ? "Bảo mật & kiểm soát" : "Secure & Controlled",
            desc:  vi ? "Xác thực danh tính, rate limiting, audit log và quản lý workspace theo nhóm." : "Identity verification, rate limiting, audit logs, and team workspace management." },
        ]
      %>
      <% features.each do |f| %>
        <div class="feature-card rounded-2xl p-6 border border-slate-100" style="background:#FAFAFA;">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-[22px] mb-4" style="background:<%= f[:bg] %>;">
            <%= f[:icon] %>
          </div>
          <h3 class="text-[16px] font-bold text-slate-900 mb-2"><%= f[:title] %></h3>
          <p class="text-[13px] text-slate-500 leading-relaxed"><%= f[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ───────────────────────────────────────────────────────── -->
<section id="how-it-works" class="py-20 sm:py-28" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 60%,#faf5ff 100%);">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <h2 class="text-[32px] sm:text-[40px] font-black text-slate-900 mb-4">
        <%= vi ? "Bắt đầu trong 3 bước" : "Up and running in 3 steps" %>
      </h2>
    </div>
    <div class="grid sm:grid-cols-3 gap-8">
      <%
        steps = [
          { n: "1", title: vi ? "Tạo tài khoản" : "Create account",     desc: vi ? "Đăng ký miễn phí, không cần thẻ tín dụng." : "Sign up free, no credit card required." },
          { n: "2", title: vi ? "Tạo khảo sát / bình chọn" : "Build a survey or vote", desc: vi ? "Dùng trình tạo trực quan hoặc để AI tạo giúp bạn." : "Use the visual builder or let AI generate it for you." },
          { n: "3", title: vi ? "Chia sẻ & thu thập" : "Share & collect", desc: vi ? "Gửi link, quét QR — kết quả cập nhật theo thời gian thực." : "Share a link, scan QR — results update in real-time." },
        ]
      %>
      <% steps.each do |s| %>
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center text-[22px] font-black text-white mx-auto mb-4 shadow-lg" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
            <%= s[:n] %>
          </div>
          <h3 class="text-[16px] font-bold text-slate-900 mb-2"><%= s[:title] %></h3>
          <p class="text-[13px] text-slate-500 leading-relaxed"><%= s[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ── PRICING ────────────────────────────────────────────────────────────── -->
<section id="pricing" class="py-20 sm:py-28 bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <h2 class="text-[32px] sm:text-[40px] font-black text-slate-900 mb-4">
        <%= vi ? "Giá cả minh bạch" : "Simple, transparent pricing" %>
      </h2>
      <p class="text-[16px] text-slate-500">
        <%= vi ? "Bắt đầu miễn phí, nâng cấp khi cần." : "Start free, upgrade when you need to." %>
      </p>
    </div>

    <%
      ai_label   = vi ? "TÍNH NĂNG AI" : "AI FEATURES"
      limit_label = vi ? "GIỚI HẠN" : "LIMITS"
      inf = "∞"
      plans = [
        {
          key: "FREE", highlight: false,
          price: vi ? "Miễn phí" : "Free", period: nil,
          cta: vi ? "Bắt đầu miễn phí" : "Get started",
          limits: [
            [vi ? "Survey tối đa" : "Max surveys",        "3"],
            [vi ? "Vote tối đa" : "Max votes",            "3"],
            [vi ? "Feedback board tối đa" : "Max feedback boards", "10"],
            [vi ? "Supporter tối đa" : "Max supporters",  "0"],
            [vi ? "AI Credits / tháng" : "AI Credits / mo", "20"],
          ],
          ai: [
            [vi ? "AI Survey Builder" : "AI Survey Builder",   false],
            [vi ? "AI Phân tích" : "AI Analysis",              false],
            [vi ? "Tạo báo cáo từ AI" : "AI Report Builder",  false],
            [vi ? "AI Chat với dữ liệu" : "AI Chat",          false],
            [vi ? "AI Kiểm duyệt nội dung" : "AI Moderation", false],
          ]
        },
        {
          key: "PRO", highlight: true,
          price: "290.000 ₫", period: vi ? "/tháng" : "/month",
          cta: vi ? "Dùng thử miễn phí" : "Start free trial",
          limits: [
            [vi ? "Survey tối đa" : "Max surveys",        "20"],
            [vi ? "Vote tối đa" : "Max votes",            "20"],
            [vi ? "Feedback board tối đa" : "Max feedback boards", "20"],
            [vi ? "Supporter tối đa" : "Max supporters",  "10"],
            [vi ? "AI Credits / tháng" : "AI Credits / mo", "500"],
          ],
          ai: [
            [vi ? "AI Survey Builder" : "AI Survey Builder",   true],
            [vi ? "AI Phân tích" : "AI Analysis",              true],
            [vi ? "Tạo báo cáo từ AI" : "AI Report Builder",  true],
            [vi ? "AI Chat với dữ liệu" : "AI Chat",          false],
            [vi ? "AI Kiểm duyệt nội dung" : "AI Moderation", true],
          ]
        },
        {
          key: "ENTERPRISE", highlight: false,
          price: "490.000 ₫", period: vi ? "/tháng" : "/month",
          cta: vi ? "Liên hệ tư vấn" : "Contact sales",
          limits: [
            [vi ? "Survey tối đa" : "Max surveys",        inf],
            [vi ? "Vote tối đa" : "Max votes",            inf],
            [vi ? "Feedback board tối đa" : "Max feedback boards", inf],
            [vi ? "Supporter tối đa" : "Max supporters",  inf],
            [vi ? "AI Credits / tháng" : "AI Credits / mo", "1000"],
          ],
          ai: [
            [vi ? "AI Survey Builder" : "AI Survey Builder",   true],
            [vi ? "AI Phân tích" : "AI Analysis",              true],
            [vi ? "Tạo báo cáo từ AI" : "AI Report Builder",  true],
            [vi ? "AI Chat với dữ liệu" : "AI Chat",          true],
            [vi ? "AI Kiểm duyệt nội dung" : "AI Moderation", true],
          ]
        },
      ]
      badge_colors = { "FREE" => "#6366f1", "PRO" => "#7C3AED", "ENTERPRISE" => "#9333ea" }
      badge_bgs    = { "FREE" => "#eef2ff", "PRO" => "#f5f3ff", "ENTERPRISE" => "#faf5ff" }
    %>

    <div class="grid sm:grid-cols-3 gap-5 items-start">
      <% plans.each do |plan| %>
        <%
          border_style = plan[:highlight] ? "border:2px solid #6366f1;" : "border:1px solid #e2e8f0;"
          bg_style     = plan[:highlight] ? "background:#ffffff;" : "background:#fafafa;"
        %>
        <div class="rounded-2xl p-6 <%= plan[:highlight] ? 'shadow-xl' : '' %>" style="<%= border_style %><%= bg_style %>">
          <!-- Badge + price -->
          <div class="flex items-center justify-between mb-4">
            <span class="text-[11px] font-black px-2.5 py-1 rounded-md tracking-wider" style="color:<%= badge_colors[plan[:key]] %>; background:<%= badge_bgs[plan[:key]] %>;"><%= plan[:key] %></span>
            <% if plan[:highlight] %>
              <span class="text-[11px] font-bold text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-full"><%= vi ? "Phổ biến" : "Popular" %></span>
            <% end %>
          </div>
          <div class="mb-5">
            <div class="text-[30px] font-black text-slate-900 leading-none"><%= plan[:price] %></div>
            <% if plan[:period] %>
              <div class="text-[13px] text-slate-400 mt-1"><%= plan[:period] %></div>
            <% end %>
          </div>

          <!-- Limits -->
          <div class="mb-5">
            <div class="text-[10px] font-black text-slate-400 tracking-widest mb-2"><%= limit_label %></div>
            <div class="space-y-1.5">
              <% plan[:limits].each do |label, val| %>
                <div class="flex items-center justify-between text-[13px]">
                  <span class="text-slate-500"><%= label %></span>
                  <span class="font-bold text-slate-800"><%= val %></span>
                </div>
              <% end %>
            </div>
          </div>

          <!-- AI Features -->
          <div class="mb-6">
            <div class="text-[10px] font-black text-slate-400 tracking-widest mb-2"><%= ai_label %></div>
            <div class="space-y-1.5">
              <% plan[:ai].each do |label, enabled| %>
                <div class="flex items-center gap-2 text-[13px] <%= enabled ? 'text-slate-800' : 'text-slate-350' %>">
                  <% if enabled %>
                    <svg class="w-3.5 h-3.5 text-indigo-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <% else %>
                    <svg class="w-3.5 h-3.5 flex-shrink-0" style="color:#cbd5e1;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% end %>
                  <span style="<%= enabled ? '' : 'color:#94a3b8;' %>"><%= label %></span>
                </div>
              <% end %>
            </div>
          </div>

          <%= link_to new_user_registration_path,
                class: "block text-center py-2.5 px-4 rounded-xl text-[13px] font-bold transition-all #{plan[:highlight] ? 'text-white hover:opacity-90' : 'text-indigo-700 border border-indigo-200 bg-white hover:bg-indigo-50'}",
                style: plan[:highlight] ? 'background:linear-gradient(135deg,#4F46E5,#7C3AED);' : '' do %>
            <%= plan[:cta] %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ── CTA ────────────────────────────────────────────────────────────────── -->
<section class="py-20 sm:py-24" style="background:linear-gradient(135deg,#4F46E5 0%,#7C3AED 50%,#A855F7 100%);">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="text-[32px] sm:text-[44px] font-black text-white mb-4 leading-tight">
      <%= vi ? "Sẵn sàng tạo cuộc thăm dò đầu tiên?" : "Ready to run your first poll?" %>
    </h2>
    <p class="text-[16px] text-white/70 mb-8">
      <%= vi ? "Tham gia cùng hàng trăm nhóm đang sử dụng VOX để tương tác với khán giả của họ." : "Join teams already using VOX to engage their audiences." %>
    </p>
    <%= link_to new_user_registration_path, class: "inline-flex items-center gap-2 px-8 py-4 text-[15px] font-bold text-indigo-700 bg-white rounded-xl shadow-lg hover:shadow-xl hover:scale-105 transition-all" do %>
      <%= vi ? "Bắt đầu miễn phí ngay" : "Start for free today" %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
    <% end %>
  </div>
</section>

<!-- ── FOOTER ─────────────────────────────────────────────────────────────── -->
<footer class="py-8 border-t border-slate-100 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-center gap-3">
    <img src="/vox_logo.svg" alt="VOX" class="h-5 w-auto opacity-60">
    <span class="text-[12px] text-slate-400">© <%= Date.today.year %> VOX · <%= vi ? "Nền tảng Khảo sát & Bình chọn" : "Survey & Voting Platform" %></span>
  </div>
</footer>
