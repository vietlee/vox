          <svg width="16" height="16" viewBox="0 0 24 24" fill="#052e16"><path d="M17.523 15.341c-.31 0-.56-.25-.56-.56V8.69c0-.31.25-.56.56-.56.31 0 .56.25.56.56v6.09c0 .31-.25.56-.56.56zm-11.046 0c-.31 0-.56-.25-.56-.56V8.69c0-.31.25-.56.56-.56.31 0 .56.25.56.56v6.09c0 .31-.25.56-.56.56zm1.5 3.22c0 .48.39.87.87.87h.78v2.53c0 .44.36.8.8.8s.8-.36.8-.8v-2.53h1.56v2.53c0 .44.36.8.8.8s.8-.36.8-.8v-2.53h.78c.48 0 .87-.39.87-.87V8.69H7.977v9.871zM14.688 3.56l.9-1.56c.05-.09.02-.2-.07-.25-.09-.05-.2-.02-.25.07l-.91 1.58A5.865 5.865 0 0012 3.03c-.82 0-1.6.16-2.31.44l-.91-1.58c-.05-.09-.17-.12-.25-.07-.09.05-.12.17-.07.25l.9 1.56C8.05 4.54 7.1 5.9 7.1 7.5h9.8c0-1.6-.95-2.96-2.21-3.94zM10.1 6.1c-.33 0-.6-.27-.6-.6s.27-.6.6-.6.6.27.6.6-.27.6-.6.6zm3.8 0c-.33 0-.6-.27-.6-.6s.27-.6.6-.6.6.27.6.6-.27.6-.6.6z"/></svg>
