<!-- ═══ FEATURES ═══ -->
<section id="features" style="background:#fff; padding:88px 0;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div style="text-align:center; max-width:640px; margin:0 auto 52px;">
      <h2 style="font-size:clamp(26px,4vw,40px); font-weight:900; color:#0f172a; letter-spacing:-0.02em; margin-bottom:12px;"><%= t.("features.title") %></h2>
      <p style="font-size:16px; color:#64748b; line-height:1.7;"><%= t.("features.subtitle") %></p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:18px;">
      <% [
        { k:"ai_create",    c:"#1e3a5f", bg:"#eef3fb", icon:'M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z' },
