    <p style="font-size:17px; color:rgba(255,255,255,.6); margin-bottom:34px; line-height:1.6;"><%= t.("cta.subtitle") %></p>
    <div style="display:flex; flex-wrap:wrap; gap:12px; justify-content:center;">
      <%= link_to t.("cta.button"), new_user_registration_path, style: "display:inline-flex; align-items:center; gap:8px; padding:15px 34px; font-size:16px; font-weight:700; color:#fff; border-radius:12px; background:linear-gradient(135deg,#1e3a5f,#2d5f8a); box-shadow:0 0 50px rgba(30,58,95,.6); text-decoration:none;", onmouseover: "this.style.transform='scale(1.04)'", onmouseout: "this.style.transform='scale(1)'" %>
      <%= link_to t.("learner.cta"), new_learner_session_path, style: "display:inline-flex; align-items:center; gap:8px; padding:15px 34px; font-size:16px; font-weight:600; color:rgba(255,255,255,.85); border-radius:12px; background:rgba(255,255,255,.08); border:1px solid rgba(255,255,255,.15); text-decoration:none;" %>
    </div>
  </div>
</section>

