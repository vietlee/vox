      <!-- Web / PWA -->
      <div style="background:linear-gradient(160deg,#1a2d4a,#0e1e30); border:1px solid rgba(74,128,168,.3); border-radius:22px; padding:32px; display:flex; flex-direction:column; align-items:center; text-align:center; transition:transform .25s ease, border-color .25s ease;" onmouseover="this.style.transform='translateY(-4px)';this.style.borderColor='rgba(74,128,168,.5)'" onmouseout="this.style.transform='none';this.style.borderColor='rgba(74,128,168,.3)'">
