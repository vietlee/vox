<%
  vi = I18n.locale.to_s == "vi"
%>

<style>
/* ── Fonts & base ── */
* { box-sizing: border-box; }

/* ── Gradient text ── */
.gtext { background: linear-gradient(135deg, #818cf8 0%, #a78bfa 50%, #c084fc 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.gtext-gold { background: linear-gradient(135deg, #fbbf24, #f59e0b); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

/* ── Hero dark bg ── */
.hero-dark {
  background: #080B1A;
  position: relative;
  overflow: hidden;
}
/* animated aurora blobs */
.aurora { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.35; }
.aurora-1 { width: 600px; height: 600px; background: radial-gradient(circle, #4338ca, transparent 70%); top: -200px; left: -100px; animation: drift1 18s ease-in-out infinite alternate; }
.aurora-2 { width: 500px; height: 500px; background: radial-gradient(circle, #7c3aed, transparent 70%); top: 0; right: -150px; animation: drift2 14s ease-in-out infinite alternate; }
.aurora-3 { width: 400px; height: 400px; background: radial-gradient(circle, #0ea5e9, transparent 70%); bottom: -100px; left: 30%; animation: drift3 20s ease-in-out infinite alternate; opacity: 0.2; }

@keyframes drift1 { from { transform: translate(0,0) scale(1); } to { transform: translate(60px,40px) scale(1.15); } }
@keyframes drift2 { from { transform: translate(0,0) scale(1); } to { transform: translate(-40px,60px) scale(1.1); } }
@keyframes drift3 { from { transform: translate(0,0); } to { transform: translate(30px,-30px); } }

/* grid overlay */
.grid-overlay {
  position: absolute; inset: 0; z-index: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
}

/* ── Glass card ── */
.glass {
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}
.glass-light {
  background: rgba(255,255,255,0.7);
  border: 1px solid rgba(99,102,241,0.12);
  backdrop-filter: blur(12px);
}

/* ── Feature cards ── */
.feat-card {
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  border: 1px solid #f1f5f9;
  background: #fff;
}
.feat-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 24px 48px rgba(99,102,241,0.13);
  border-color: rgba(99,102,241,0.25);
}

/* ── Pricing card ── */
.price-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
.price-card:hover { transform: translateY(-4px); }
.price-pro {
  background: linear-gradient(160deg, #1e1b4b 0%, #312e81 100%);
  border: 1px solid rgba(129,140,248,0.3);
  box-shadow: 0 32px 64px rgba(79,70,229,0.35), inset 0 1px 0 rgba(255,255,255,0.1);
}

/* ── Animations ── */
@keyframes fadeUp { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:translateY(0); } }
.fade-up   { animation: fadeUp 0.7s ease forwards; }
.fade-up-2 { animation: fadeUp 0.7s 0.15s ease forwards; opacity:0; }
.fade-up-3 { animation: fadeUp 0.7s 0.28s ease forwards; opacity:0; }
.fade-up-4 { animation: fadeUp 0.7s 0.42s ease forwards; opacity:0; }

@keyframes pulse-ring { 0%,100% { opacity:0.6; transform:scale(1); } 50% { opacity:1; transform:scale(1.04); } }
.live-ring { animation: pulse-ring 2s ease-in-out infinite; }

/* ── Bar animate on load ── */
@keyframes barGrow { from { width: 0%; } to { width: var(--w); } }
.bar-animate { animation: barGrow 1.4s 0.8s cubic-bezier(.16,1,.3,1) forwards; width: 0%; }

/* ── Step connector ── */
.step-line::after {
  content: '';
  position: absolute;
  top: 28px; left: calc(50% + 28px);
  width: calc(100% - 56px);
  height: 2px;
  background: linear-gradient(90deg, #6366f1, #a855f7);
  opacity: 0.3;
}

/* ── Badge pill ── */
.badge-live {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 5px 14px; border-radius: 999px;
  font-size: 12px; font-weight: 700; letter-spacing: 0.01em;
  background: rgba(99,102,241,0.15);
  border: 1px solid rgba(129,140,248,0.35);
  color: #a5b4fc;
}
</style>

<!-- ═══════════════════════════════════════════════════════════════════════════
     NAV
════════════════════════════════════════════════════════════════════════════ -->
<nav style="position:sticky; top:0; z-index:100; background:rgba(8,11,26,0.85); border-bottom:1px solid rgba(255,255,255,0.07); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between" style="height:64px;">
    <img src="/vox_logo.svg" alt="VOX" style="height:22px;">

    <div class="hidden sm:flex items-center gap-7" style="font-size:14px; font-weight:500; color:rgba(255,255,255,0.6);">
      <a href="#features"    style="transition:color 0.15s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'"><%= vi ? "Tính năng" : "Features" %></a>
      <a href="#how-it-works" style="transition:color 0.15s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'"><%= vi ? "Cách dùng" : "How it works" %></a>
      <a href="#pricing"     style="transition:color 0.15s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'"><%= vi ? "Giá" : "Pricing" %></a>
    </div>

    <div class="flex items-center gap-2">
      <!-- Language pill -->
      <div style="display:flex; border-radius:999px; overflow:hidden; border:1px solid rgba(255,255,255,0.15); font-size:11px; font-weight:700;">
        <a href="?locale=vi" style="padding:5px 12px; transition:all 0.15s; <%= I18n.locale.to_s == 'vi' ? 'background:#4F46E5; color:#fff;' : 'color:rgba(255,255,255,0.5);' %>">VI</a>
        <a href="?locale=en" style="padding:5px 12px; transition:all 0.15s; <%= I18n.locale.to_s == 'en' ? 'background:#4F46E5; color:#fff;' : 'color:rgba(255,255,255,0.5);' %>">EN</a>
      </div>
      <%= link_to new_user_session_path, style: "font-size:13px; font-weight:600; color:rgba(255,255,255,0.65); padding:8px 14px; transition:color 0.15s;", onmouseover: "this.style.color='#fff'", onmouseout: "this.style.color='rgba(255,255,255,0.65)'" do %>
        <%= vi ? "Đăng nhập" : "Sign in" %>
      <% end %>
      <%= link_to new_user_registration_path, style: "font-size:13px; font-weight:700; color:#fff; padding:9px 18px; border-radius:8px; background:linear-gradient(135deg,#4F46E5,#7C3AED); transition:opacity 0.15s; box-shadow:0 0 20px rgba(99,102,241,0.4);", onmouseover: "this.style.opacity='0.88'", onmouseout: "this.style.opacity='1'" do %>
        <%= vi ? "Dùng thử miễn phí" : "Try for free" %>
      <% end %>
    </div>
  </div>
</nav>

<!-- ═══════════════════════════════════════════════════════════════════════════
     HERO — dark, aurora
════════════════════════════════════════════════════════════════════════════ -->
<section class="hero-dark" style="min-height:92vh; display:flex; align-items:center;">
  <div class="aurora aurora-1"></div>
  <div class="aurora aurora-2"></div>
  <div class="aurora aurora-3"></div>
  <div class="grid-overlay"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center relative" style="z-index:1; padding-top:80px; padding-bottom:80px; width:100%;">

    <!-- Badge -->
    <div class="badge-live fade-up" style="margin-bottom:28px; display:inline-flex;">
      <span style="width:7px; height:7px; border-radius:50%; background:#22d3ee; animation:pulse-ring 2s infinite;"></span>
      <%= vi ? "Nền tảng Survey & Voting thế hệ mới" : "Next-gen Survey & Voting platform" %>
    </div>

    <!-- Headline -->
    <h1 style="font-size:clamp(36px,7vw,76px); font-weight:900; line-height:1.06; letter-spacing:-0.03em; color:#fff; margin-bottom:24px;" class="fade-up-2">
      <%= vi ? "Thu thập ý kiến" : "Engage your audience" %><br>
      <span class="gtext"><%= vi ? "theo thời gian thực" : "in real-time" %></span>
    </h1>

    <!-- Sub -->
    <p style="font-size:clamp(15px,2.5vw,20px); color:rgba(255,255,255,0.55); max-width:600px; margin:0 auto 40px; line-height:1.7;" class="fade-up-3">
      <%= vi ? "VOX giúp bạn tạo khảo sát, bình chọn trực tiếp và thu thập phản hồi — tất cả trong vài giây. Hoàn hảo cho hội thảo, lớp học và team." : "VOX helps you run live surveys, instant polls, and collect feedback — all in seconds. Perfect for workshops, classrooms, and your team." %>
    </p>

    <!-- CTAs -->
    <div class="fade-up-3" style="display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-bottom:48px;">
      <%= link_to new_user_registration_path, style: "display:inline-flex; align-items:center; gap:8px; padding:14px 28px; font-size:15px; font-weight:700; color:#fff; border-radius:12px; background:linear-gradient(135deg,#4F46E5,#7C3AED); box-shadow:0 0 40px rgba(99,102,241,0.5); transition:all 0.2s; text-decoration:none;", onmouseover: "this.style.transform='scale(1.04)'; this.style.boxShadow='0 0 60px rgba(99,102,241,0.65)'", onmouseout: "this.style.transform='scale(1)'; this.style.boxShadow='0 0 40px rgba(99,102,241,0.5)'" do %>
        <%= vi ? "Bắt đầu miễn phí" : "Get started free" %>
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      <% end %>
      <a href="#features" style="display:inline-flex; align-items:center; gap:8px; padding:14px 28px; font-size:15px; font-weight:600; color:rgba(255,255,255,0.8); border-radius:12px; background:rgba(255,255,255,0.07); border:1px solid rgba(255,255,255,0.13); transition:all 0.2s; text-decoration:none;" onmouseover="this.style.background='rgba(255,255,255,0.12)'" onmouseout="this.style.background='rgba(255,255,255,0.07)'">
        <%= vi ? "Khám phá tính năng" : "Explore features" %>
      </a>
    </div>

    <!-- Trust line -->
    <p class="fade-up-4" style="font-size:13px; color:rgba(255,255,255,0.3); letter-spacing:0.01em;">
      ✓ <%= vi ? "Miễn phí · Không cần thẻ tín dụng · Bắt đầu trong 60 giây" : "Free plan · No credit card required · Live in 60 seconds" %>
    </p>

    <!-- ── Product Mockup ── -->
    <div class="fade-up-4" style="margin-top:64px; position:relative;">
      <!-- Glow under -->
      <div style="position:absolute; bottom:-40px; left:50%; transform:translateX(-50%); width:70%; height:60px; background:radial-gradient(ellipse,rgba(99,102,241,0.4),transparent 70%); filter:blur(20px);"></div>

      <!-- Browser chrome -->
      <div style="border-radius:16px; overflow:hidden; box-shadow:0 40px 120px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.08); max-width:780px; margin:0 auto;">
        <!-- Browser bar -->
        <div style="background:#1a1d2e; padding:12px 16px; display:flex; align-items:center; gap:12px; border-bottom:1px solid rgba(255,255,255,0.07);">
          <div style="display:flex; gap:6px;">
            <div style="width:12px;height:12px;border-radius:50%;background:#ff5f57;"></div>
            <div style="width:12px;height:12px;border-radius:50%;background:#febc2e;"></div>
            <div style="width:12px;height:12px;border-radius:50%;background:#28c840;"></div>
          </div>
          <div style="flex:1; background:rgba(255,255,255,0.06); border-radius:6px; padding:5px 12px; font-size:12px; color:rgba(255,255,255,0.3); text-align:center;">vox.czin.net/v/team-meeting/present</div>
          <div style="display:flex; align-items:center; gap:6px; font-size:11px; font-weight:700; color:#4ade80;">
            <span style="width:6px;height:6px;border-radius:50%;background:#4ade80;animation:pulse-ring 2s infinite;"></span>
            LIVE
          </div>
        </div>
        <!-- Presenter content -->
        <div style="background:#0F172A; padding:32px 28px 28px;">
          <h3 style="font-size:clamp(16px,3vw,26px); font-weight:800; color:#fff; text-align:center; margin-bottom:24px; line-height:1.3;">
            <%= vi ? "🏆 Công cụ collaboration nào nhóm bạn yêu thích nhất?" : "🏆 Which collaboration tool does your team prefer?" %>
          </h3>
          <div style="max-width:540px; margin:0 auto;">
            <% [
              [vi ? "Microsoft Teams" : "Microsoft Teams", 44, "from-indigo-500 to-violet-600"],
              [vi ? "Slack" : "Slack",                     31, "from-violet-500 to-purple-600"],
              [vi ? "Google Meet" : "Google Meet",         16, "from-purple-500 to-fuchsia-500"],
              [vi ? "Zoom" : "Zoom",                        9, "from-fuchsia-400 to-pink-500"],
            ].each_with_index do |(label, pct, colors), i| %>
              <div style="margin-bottom:14px;">
                <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:6px;">
                  <span style="font-weight:600; color:rgba(255,255,255,0.85);"><%= label %></span>
                  <span style="font-weight:700; color:rgba(255,255,255,0.45);"><%= pct %>%</span>
                </div>
                <div style="height:10px; border-radius:999px; background:rgba(255,255,255,0.08); overflow:hidden;">
                  <div class="bar-animate" style="--w:<%= pct %>%; height:100%; border-radius:999px; background:linear-gradient(90deg,<%= colors == 'from-indigo-500 to-violet-600' ? '#6366f1,#7c3aed' : colors == 'from-violet-500 to-purple-600' ? '#8b5cf6,#9333ea' : colors == 'from-purple-500 to-fuchsia-500' ? '#a855f7,#d946ef' : '#e879f9,#ec4899' %>);"></div>
                </div>
              </div>
            <% end %>
          </div>
          <div style="display:flex; align-items:center; justify-content:center; gap:20px; margin-top:20px; font-size:12px; color:rgba(255,255,255,0.3);">
            <span style="display:flex; align-items:center; gap:6px;">
              <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              248 <%= vi ? "người tham gia" : "participants" %>
            </span>
            <span>·</span>
            <span><%= vi ? "Đang cập nhật theo thời gian thực" : "Updating in real-time" %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     STATS BAR
════════════════════════════════════════════════════════════════════════════ -->
<div style="background:#fff; border-bottom:1px solid #f1f5f9;">
  <div class="max-w-5xl mx-auto px-4 sm:px-6" style="padding-top:44px; padding-bottom:44px;">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:32px; text-align:center;">
      <% [
        { val: "10+",  label: vi ? "Loại câu hỏi" : "Question types",      icon: "📋", color: "#4F46E5" },
        { val: "Live", label: vi ? "Cập nhật tức thì" : "Instant results",  icon: "⚡", color: "#7C3AED" },
        { val: "AI",   label: vi ? "Tích hợp AI" : "AI-powered",            icon: "✨", color: "#D97706" },
        { val: "SSO",  label: vi ? "Google & Microsoft" : "Google & Microsoft", icon: "🔒", color: "#059669" },
        { val: "CSV",  label: vi ? "Xuất dữ liệu" : "Data export",         icon: "📥", color: "#0EA5E9" },
      ].each do |s| %>
        <div style="display:flex; flex-direction:column; align-items:center; gap:8px;">
          <div style="width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:20px; background:linear-gradient(135deg,<%= s[:color] %>22,<%= s[:color] %>11);">
            <%= s[:icon] %>
          </div>
          <div style="font-size:22px; font-weight:900; color:<%= s[:color] %>; line-height:1; letter-spacing:-0.02em;"><%= s[:val] %></div>
          <div style="font-size:12px; color:#94a3b8; font-weight:500; line-height:1.4;"><%= s[:label] %></div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════
     FEATURES
════════════════════════════════════════════════════════════════════════════ -->
<section id="features" style="padding:96px 0; background:#fafbff;">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div style="text-align:center; margin-bottom:56px;">
      <div style="display:inline-block; font-size:12px; font-weight:700; letter-spacing:0.1em; color:#6366f1; text-transform:uppercase; margin-bottom:12px;"><%= vi ? "Tính năng" : "Features" %></div>
      <h2 style="font-size:clamp(28px,5vw,44px); font-weight:900; color:#0f172a; letter-spacing:-0.02em; margin-bottom:14px; line-height:1.15;">
        <%= vi ? "Tất cả công cụ bạn cần" : "Everything you need" %>
      </h2>
      <p style="font-size:16px; color:#64748b; max-width:520px; margin:0 auto; line-height:1.7;">
        <%= vi ? "Một nền tảng để tạo khảo sát, bình chọn trực tiếp và thu thập phản hồi từ khán giả." : "One platform to run surveys, live polls, and collect feedback from your audience." %>
      </p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(300px,1fr)); gap:20px;">
      <% [
        { icon: "📊", grad: "linear-gradient(135deg,#4F46E5,#6366f1)",
          title: vi ? "Khảo sát thông minh" : "Smart Surveys",
          desc:  vi ? "10+ loại câu hỏi, logic điều kiện skip, chống trùng lặp và phân tích AI tự động." : "10+ question types, conditional skip logic, duplicate prevention, and AI auto-analysis." },
        { icon: "🗳️", grad: "linear-gradient(135deg,#7C3AED,#9333ea)",
          title: vi ? "Bình chọn trực tiếp" : "Live Voting",
          desc:  vi ? "Kết quả cập nhật tức thì qua WebSocket. Màn hình presenter đẹp cho sự kiện lớn." : "Instant results via WebSocket. Beautiful presenter screen for large events." },
        { icon: "💬", grad: "linear-gradient(135deg,#0EA5E9,#06b6d4)",
          title: vi ? "Thu thập phản hồi" : "Feedback Boards",
          desc:  vi ? "Bảng phản hồi công khai — đề xuất, upvote, bình luận theo thời gian thực." : "Public boards — suggestions, upvotes, and comments in real-time." },
        { icon: "✨", grad: "linear-gradient(135deg,#D97706,#f59e0b)",
          title: vi ? "Phân tích AI" : "AI Analysis",
          desc:  vi ? "Tóm tắt kết quả, tạo báo cáo chuyên nghiệp và insight thông minh chỉ một cú nhấp." : "Summarize results, generate pro reports, and get smart insights in one click." },
        { icon: "📱", grad: "linear-gradient(135deg,#059669,#10b981)",
          title: vi ? "Mọi thiết bị" : "Any Device",
          desc:  vi ? "Mobile-first, tối ưu trên điện thoại đến màn hình lớn. Người dùng tham gia không cần cài app." : "Mobile-first, optimised from phone to big screen. Participants join with no app needed." },
        { icon: "🔒", grad: "linear-gradient(135deg,#DC2626,#ef4444)",
          title: vi ? "Bảo mật & kiểm soát" : "Secure & Controlled",
          desc:  vi ? "SSO Google/Microsoft, rate limiting, audit log và quản lý workspace theo nhóm." : "Google/Microsoft SSO, rate limiting, audit logs, and team workspace management." },
      ].each do |f| %>
        <div class="feat-card" style="border-radius:20px; padding:28px;">
          <div style="width:48px; height:48px; border-radius:14px; background:<%= f[:grad] %>; display:flex; align-items:center; justify-content:center; font-size:22px; margin-bottom:18px; box-shadow:0 8px 20px rgba(0,0,0,0.12);">
            <%= f[:icon] %>
          </div>
          <h3 style="font-size:16px; font-weight:700; color:#0f172a; margin-bottom:8px;"><%= f[:title] %></h3>
          <p style="font-size:13px; color:#64748b; line-height:1.7; margin:0;"><%= f[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     HOW IT WORKS
════════════════════════════════════════════════════════════════════════════ -->
<section id="how-it-works" style="padding:96px 0; background:#080B1A; position:relative; overflow:hidden;">
  <div class="aurora" style="width:400px; height:400px; background:radial-gradient(circle,#4338ca,transparent 70%); top:-100px; right:5%; opacity:0.25;"></div>
  <div class="grid-overlay"></div>
  <div class="max-w-5xl mx-auto px-4 sm:px-6" style="position:relative; z-index:1;">
    <div style="text-align:center; margin-bottom:64px;">
      <div style="display:inline-block; font-size:12px; font-weight:700; letter-spacing:0.1em; color:#818cf8; text-transform:uppercase; margin-bottom:12px;"><%= vi ? "Cách dùng" : "How it works" %></div>
      <h2 style="font-size:clamp(28px,5vw,48px); font-weight:900; color:#fff; letter-spacing:-0.02em; line-height:1.15; margin:0;">
        <%= vi ? "Bắt đầu trong 3 bước" : "Up and running in 3 steps" %>
      </h2>
    </div>

    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(260px,1fr)); gap:24px;">
      <% [
        { n: "01", grad: "linear-gradient(135deg,#4F46E5,#6366f1)",
          title: vi ? "Tạo tài khoản" : "Create account",
          desc:  vi ? "Đăng ký miễn phí trong 30 giây. Không cần thẻ tín dụng, không cam kết." : "Sign up free in 30 seconds. No credit card, no commitment.",
          detail: vi ? "✓ Miễn phí mãi mãi  ✓ Bắt đầu ngay" : "✓ Free forever  ✓ Start instantly" },
        { n: "02", grad: "linear-gradient(135deg,#7C3AED,#a855f7)",
          title: vi ? "Xây dựng nội dung" : "Build your content",
          desc:  vi ? "Tạo khảo sát, bình chọn hoặc bảng phản hồi bằng trình kéo-thả trực quan hoặc để AI tạo giúp bạn." : "Create surveys, polls, or feedback boards with the drag-and-drop builder or let AI generate them for you.",
          detail: vi ? "✓ 10+ loại câu hỏi  ✓ AI tạo tự động" : "✓ 10+ question types  ✓ AI generation" },
        { n: "03", grad: "linear-gradient(135deg,#0EA5E9,#06b6d4)",
          title: vi ? "Chia sẻ & thu thập" : "Share & collect",
          desc:  vi ? "Gửi link hoặc để người tham gia quét QR. Kết quả hiển thị ngay lập tức theo thời gian thực trên màn hình của bạn." : "Share a link or let participants scan a QR code. Results appear instantly in real-time on your screen.",
          detail: vi ? "✓ QR code  ✓ Kết quả thời gian thực" : "✓ QR code  ✓ Live results" },
      ].each do |s| %>
        <div style="background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); border-radius:20px; padding:32px; position:relative; overflow:hidden; transition:border-color 0.2s, background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.07)'; this.style.borderColor='rgba(129,140,248,0.3)'" onmouseout="this.style.background='rgba(255,255,255,0.04)'; this.style.borderColor='rgba(255,255,255,0.08)'">
          <!-- Step number watermark -->
          <div style="position:absolute; top:-10px; right:20px; font-size:80px; font-weight:900; color:rgba(255,255,255,0.03); line-height:1; pointer-events:none; user-select:none;"><%= s[:n] %></div>
          <!-- Number badge -->
          <div style="display:inline-flex; align-items:center; justify-content:center; width:40px; height:40px; border-radius:12px; background:<%= s[:grad] %>; font-size:14px; font-weight:900; color:#fff; margin-bottom:20px; box-shadow:0 6px 20px rgba(0,0,0,0.3);">
            <%= s[:n] %>
          </div>
          <h3 style="font-size:20px; font-weight:800; color:#fff; margin-bottom:10px; letter-spacing:-0.01em;"><%= s[:title] %></h3>
          <p style="font-size:14px; color:rgba(255,255,255,0.55); line-height:1.75; margin-bottom:16px;"><%= s[:desc] %></p>
          <div style="font-size:12px; color:rgba(129,140,248,0.8); font-weight:600;"><%= s[:detail] %></div>
        </div>
      <% end %>
    </div>

    <!-- Bottom CTA inside section -->
    <div style="text-align:center; margin-top:52px;">
      <%= link_to new_user_registration_path, style: "display:inline-flex; align-items:center; gap:8px; padding:13px 28px; font-size:14px; font-weight:700; color:#fff; border-radius:10px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.15); text-decoration:none; transition:all 0.2s;", onmouseover: "this.style.background='rgba(255,255,255,0.16)'", onmouseout: "this.style.background='rgba(255,255,255,0.1)'" do %>
        <%= vi ? "Bắt đầu ngay — miễn phí" : "Get started — it's free" %>
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      <% end %>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     PRICING
════════════════════════════════════════════════════════════════════════════ -->
<section id="pricing" style="padding:96px 0; background:#f8faff;">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div style="text-align:center; margin-bottom:56px;">
      <div style="display:inline-block; font-size:12px; font-weight:700; letter-spacing:0.1em; color:#6366f1; text-transform:uppercase; margin-bottom:12px;"><%= vi ? "Giá cả" : "Pricing" %></div>
      <h2 style="font-size:clamp(28px,5vw,44px); font-weight:900; color:#0f172a; letter-spacing:-0.02em; margin-bottom:14px; line-height:1.15;">
        <%= vi ? "Giá cả minh bạch" : "Simple, transparent pricing" %>
      </h2>
      <p style="font-size:16px; color:#64748b;">
        <%= vi ? "Bắt đầu miễn phí, nâng cấp khi cần." : "Start free, upgrade when you need to." %>
      </p>
    </div>

    <%
      ai_label    = vi ? "TÍNH NĂNG AI" : "AI FEATURES"
      limit_label = vi ? "GIỚI HẠN" : "LIMITS"
      inf = "∞"
      plans = [
        {
          key: "FREE", pro: false,
          price: vi ? "Miễn phí" : "Free", period: nil,
          cta: vi ? "Bắt đầu miễn phí" : "Get started",
          limits: [
            [vi ? "Survey tối đa"         : "Max surveys",        "3"],
            [vi ? "Vote tối đa"           : "Max votes",          "3"],
            [vi ? "Feedback board tối đa" : "Max feedback boards","10"],
            [vi ? "Supporter tối đa"      : "Max supporters",     "0"],
            [vi ? "AI Credits / tháng"    : "AI Credits / mo",    "20"],
          ],
          ai: [
            [vi ? "AI Survey Builder"       : "AI Survey Builder",  false],
            [vi ? "AI Phân tích"            : "AI Analysis",        false],
            [vi ? "Tạo báo cáo từ AI"       : "AI Report Builder",  false],
            [vi ? "AI Chat với dữ liệu"     : "AI Chat",            false],
            [vi ? "AI Kiểm duyệt nội dung"  : "AI Moderation",      false],
          ]
        },
        {
          key: "PRO", pro: true,
          price: "290.000 ₫", period: vi ? "/tháng" : "/month",
          cta: vi ? "Dùng thử miễn phí" : "Start free trial",
          limits: [
            [vi ? "Survey tối đa"         : "Max surveys",        "20"],
            [vi ? "Vote tối đa"           : "Max votes",          "20"],
            [vi ? "Feedback board tối đa" : "Max feedback boards","20"],
            [vi ? "Supporter tối đa"      : "Max supporters",     "10"],
            [vi ? "AI Credits / tháng"    : "AI Credits / mo",    "500"],
          ],
          ai: [
            [vi ? "AI Survey Builder"       : "AI Survey Builder",  true],
            [vi ? "AI Phân tích"            : "AI Analysis",        true],
            [vi ? "Tạo báo cáo từ AI"       : "AI Report Builder",  true],
            [vi ? "AI Chat với dữ liệu"     : "AI Chat",            false],
            [vi ? "AI Kiểm duyệt nội dung"  : "AI Moderation",      true],
          ]
        },
        {
          key: "ENTERPRISE", pro: false,
          price: "490.000 ₫", period: vi ? "/tháng" : "/month",
          cta: vi ? "Liên hệ tư vấn" : "Contact sales",
          limits: [
            [vi ? "Survey tối đa"         : "Max surveys",        inf],
            [vi ? "Vote tối đa"           : "Max votes",          inf],
            [vi ? "Feedback board tối đa" : "Max feedback boards",inf],
            [vi ? "Supporter tối đa"      : "Max supporters",     inf],
            [vi ? "AI Credits / tháng"    : "AI Credits / mo",    "1000"],
          ],
          ai: [
            [vi ? "AI Survey Builder"       : "AI Survey Builder",  true],
            [vi ? "AI Phân tích"            : "AI Analysis",        true],
            [vi ? "Tạo báo cáo từ AI"       : "AI Report Builder",  true],
            [vi ? "AI Chat với dữ liệu"     : "AI Chat",            true],
            [vi ? "AI Kiểm duyệt nội dung"  : "AI Moderation",      true],
          ]
        },
      ]
    %>

    <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:20px; align-items:start;">
      <% plans.each do |plan| %>
        <div class="price-card <%= plan[:pro] ? 'price-pro' : '' %>"
             style="border-radius:24px; padding:28px; <%= plan[:pro] ? '' : 'background:#fff; border:1px solid #e2e8f0; box-shadow:0 4px 20px rgba(0,0,0,0.04);' %>">

          <!-- Header -->
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
            <span style="font-size:11px; font-weight:800; letter-spacing:0.1em; padding:4px 10px; border-radius:6px;
              <%= plan[:pro] ? 'background:rgba(129,140,248,0.2); color:#c7d2fe;' : plan[:key] == 'ENTERPRISE' ? 'background:#faf5ff; color:#9333ea;' : 'background:#eef2ff; color:#6366f1;' %>">
              <%= plan[:key] %>
            </span>
            <% if plan[:pro] %>
              <span style="font-size:11px; font-weight:700; color:#fbbf24; background:rgba(251,191,36,0.15); padding:3px 10px; border-radius:999px;">
                ⭐ <%= vi ? "Phổ biến nhất" : "Most popular" %>
              </span>
            <% end %>
          </div>

          <!-- Price -->
          <div style="margin-bottom:24px;">
            <div style="font-size:clamp(24px,4vw,32px); font-weight:900; line-height:1; <%= plan[:pro] ? 'color:#fff;' : 'color:#0f172a;' %>"><%= plan[:price] %></div>
            <% if plan[:period] %>
              <div style="font-size:13px; margin-top:4px; <%= plan[:pro] ? 'color:rgba(199,210,254,0.6);' : 'color:#94a3b8;' %>"><%= plan[:period] %></div>
            <% end %>
          </div>

          <!-- Divider -->
          <div style="height:1px; background:<%= plan[:pro] ? 'rgba(255,255,255,0.1)' : '#f1f5f9' %>; margin-bottom:20px;"></div>

          <!-- Limits -->
          <div style="font-size:10px; font-weight:800; letter-spacing:0.12em; margin-bottom:10px; <%= plan[:pro] ? 'color:rgba(199,210,254,0.5);' : 'color:#94a3b8;' %>"><%= limit_label %></div>
          <div style="margin-bottom:20px;">
            <% plan[:limits].each do |label, val| %>
              <div style="display:flex; justify-content:space-between; align-items:center; font-size:13px; padding:5px 0; border-bottom:1px solid <%= plan[:pro] ? 'rgba(255,255,255,0.06)' : '#f8fafc' %>;">
                <span style="<%= plan[:pro] ? 'color:rgba(199,210,254,0.7);' : 'color:#64748b;' %>"><%= label %></span>
                <span style="font-weight:700; <%= plan[:pro] ? 'color:#c7d2fe;' : 'color:#0f172a;' %>"><%= val %></span>
              </div>
            <% end %>
          </div>

          <!-- AI Features -->
          <div style="font-size:10px; font-weight:800; letter-spacing:0.12em; margin-bottom:10px; <%= plan[:pro] ? 'color:rgba(199,210,254,0.5);' : 'color:#94a3b8;' %>"><%= ai_label %></div>
          <div style="margin-bottom:24px;">
            <% plan[:ai].each do |label, enabled| %>
              <div style="display:flex; align-items:center; gap:8px; font-size:13px; padding:4px 0; <%= enabled ? '' : 'opacity:0.4;' %>">
                <% if enabled %>
                  <svg width="14" height="14" fill="none" stroke="<%= plan[:pro] ? '#a5b4fc' : '#6366f1' %>" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <% else %>
                  <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="color:#cbd5e1;"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                <% end %>
                <span style="<%= plan[:pro] ? 'color:rgba(199,210,254,0.85);' : enabled ? 'color:#374151;' : 'color:#94a3b8;' %>"><%= label %></span>
              </div>
            <% end %>
          </div>

          <!-- CTA -->
          <%= link_to new_user_registration_path,
                style: "display:block; text-align:center; padding:11px 20px; border-radius:12px; font-size:14px; font-weight:700; text-decoration:none; transition:all 0.2s; #{plan[:pro] ? 'background:rgba(255,255,255,0.15); color:#fff; border:1px solid rgba(255,255,255,0.2);' : 'background:#f1f5f9; color:#4F46E5; border:1px solid #e2e8f0;'}",
                onmouseover: plan[:pro] ? "this.style.background='rgba(255,255,255,0.25)'" : "this.style.background='#e0e7ff'; this.style.borderColor='#a5b4fc'",
                onmouseout:  plan[:pro] ? "this.style.background='rgba(255,255,255,0.15)'" : "this.style.background='#f1f5f9'; this.style.borderColor='#e2e8f0'" do %>
            <%= plan[:cta] %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     CTA — dark aurora
════════════════════════════════════════════════════════════════════════════ -->
<section style="padding:96px 0; background:#080B1A; position:relative; overflow:hidden; text-align:center;">
  <div class="aurora" style="width:500px; height:500px; background:radial-gradient(circle,#4338ca,transparent 70%); top:-150px; left:50%; transform:translateX(-50%); opacity:0.4;"></div>
  <div class="grid-overlay"></div>
  <div style="position:relative; z-index:1; max-width:640px; margin:0 auto; padding:0 24px;">
    <h2 style="font-size:clamp(28px,6vw,52px); font-weight:900; color:#fff; letter-spacing:-0.025em; line-height:1.1; margin-bottom:16px;">
      <%= vi ? "Sẵn sàng tạo cuộc\nbình chọn đầu tiên?" : "Ready to run your\nfirst live poll?" %>
    </h2>
    <p style="font-size:16px; color:rgba(255,255,255,0.5); margin-bottom:36px; line-height:1.7;">
      <%= vi ? "Tham gia cùng các nhóm đang sử dụng VOX để tương tác với khán giả theo thời gian thực." : "Join teams already using VOX to engage their audiences in real-time." %>
    </p>
    <%= link_to new_user_registration_path,
          style: "display:inline-flex; align-items:center; gap:10px; padding:16px 36px; font-size:16px; font-weight:700; color:#fff; border-radius:14px; background:linear-gradient(135deg,#4F46E5,#7C3AED); box-shadow:0 0 60px rgba(99,102,241,0.5); text-decoration:none; transition:all 0.2s;",
          onmouseover: "this.style.transform='scale(1.05)'; this.style.boxShadow='0 0 80px rgba(99,102,241,0.7)'",
          onmouseout:  "this.style.transform='scale(1)'; this.style.boxShadow='0 0 60px rgba(99,102,241,0.5)'" do %>
      <%= vi ? "Bắt đầu miễn phí ngay" : "Start for free today" %>
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
    <% end %>
    <p style="font-size:12px; color:rgba(255,255,255,0.25); margin-top:16px;">
      <%= vi ? "Miễn phí · Không cần thẻ tín dụng · Huỷ bất cứ lúc nào" : "Free plan · No credit card · Cancel anytime" %>
    </p>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════════════════
     FOOTER
════════════════════════════════════════════════════════════════════════════ -->
<footer style="padding:28px 24px; border-top:1px solid #f1f5f9; background:#fff; text-align:center;">
  <div style="display:flex; align-items:center; justify-content:center; gap:10px;">
    <img src="/vox_logo.svg" alt="VOX" style="height:18px; opacity:0.55;">
    <span style="font-size:12px; color:#94a3b8;">© <%= Date.today.year %> VOX · <%= vi ? "Nền tảng Khảo sát & Bình chọn" : "Survey & Voting Platform" %></span>
  </div>
</footer>
