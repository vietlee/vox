        { k:"speaking",     c:"#0ea5e9", bg:"#e6f5fd", icon:'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z' },
        { k:"gamification", c:"#f59e0b", bg:"#fef6e7", icon:'M13 10V3L4 14h7v7l9-11h-7z' },
        { k:"study_plan",   c:"#16a34a", bg:"#e9f7ee", icon:'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01' },
        { k:"analytics",    c:"#e11d48", bg:"#fdeaef", icon:'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z' }
      ].each do |f| %>
        <div class="feat-card" style="border-radius:18px; padding:26px;">
          <div style="width:48px; height:48px; border-radius:13px; background:<%= f[:bg] %>; display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
            <svg width="24" height="24" fill="none" stroke="<%= f[:c] %>" stroke-width="1.9" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="<%= f[:icon] %>"/></svg>
          </div>
          <h3 style="font-size:17px; font-weight:800; color:#0f172a; margin-bottom:7px;"><%= t.("features.#{f[:k]}_t") %></h3>
          <p style="font-size:14px; color:#64748b; line-height:1.65;"><%= t.("features.#{f[:k]}_d") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

