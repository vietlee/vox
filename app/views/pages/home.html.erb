<!-- ═══ HOW IT WORKS ═══ -->
<section id="how-it-works" style="background:#06101f; padding:88px 0; position:relative; overflow:hidden;">
  <div class="aurora aurora-2" style="opacity:.18;"></div>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 relative" style="z-index:1;">
    <div style="text-align:center; max-width:600px; margin:0 auto 52px;">
      <h2 style="font-size:clamp(26px,4vw,40px); font-weight:900; color:#fff; letter-spacing:-0.02em; margin-bottom:12px;"><%= t.("how.title") %></h2>
      <p style="font-size:16px; color:rgba(255,255,255,.55); line-height:1.7;"><%= t.("how.subtitle") %></p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:20px;">
      <% ["s1","s2","s3"].each_with_index do |s,i| %>
        <div style="background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.09); border-radius:18px; padding:28px;">
          <div style="width:40px; height:40px; border-radius:11px; background:linear-gradient(135deg,#1e3a5f,#2d5f8a); display:flex; align-items:center; justify-content:center; font-size:17px; font-weight:900; color:#fff; margin-bottom:16px;"><%= i+1 %></div>
          <h3 style="font-size:18px; font-weight:800; color:#fff; margin-bottom:8px;"><%= t.("how.#{s}_t") %></h3>
          <p style="font-size:14px; color:rgba(255,255,255,.55); line-height:1.65;"><%= t.("how.#{s}_d") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ═══ PRICING ═══ -->
<section id="pricing" style="background:#f7fafc; padding:88px 0;">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div style="text-align:center; max-width:600px; margin:0 auto 48px;">
      <h2 style="font-size:clamp(26px,4vw,40px); font-weight:900; color:#0f172a; letter-spacing:-0.02em; margin-bottom:12px;"><%= t.("pricing.title") %></h2>
      <p style="font-size:16px; color:#64748b; line-height:1.7;"><%= t.("pricing.subtitle") %></p>
    </div>
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px; align-items:stretch;">
      <!-- Free -->
      <div style="background:#fff; border:1px solid #e6edf5; border-radius:20px; padding:32px; display:flex; flex-direction:column;">
        <p style="font-size:13px; font-weight:800; letter-spacing:.05em; text-transform:uppercase; color:#64748b;"><%= t.("pricing.free_label") %></p>
        <div style="display:flex; align-items:baseline; gap:4px; margin:10px 0 4px;"><span style="font-size:40px; font-weight:900; color:#0f172a;"><%= t.("pricing.free_price") %></span></div>
        <p style="font-size:14px; color:#94a3b8; margin-bottom:22px;"><%= t.("pricing.free_desc") %></p>
        <div style="display:grid; gap:12px; margin-bottom:26px; flex:1;">
          <% ["free_f1","free_f2","free_f3"].each do |f| %>
            <div style="display:flex; gap:10px; align-items:flex-start;"><svg width="18" height="18" fill="none" stroke="#16a34a" stroke-width="2.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px;"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span style="font-size:14px; color:#334155; line-height:1.5;"><%= t.("pricing.#{f}") %></span></div>
          <% end %>
        </div>
        <%= link_to t.("pricing.free_cta"), new_user_registration_path, style: "text-align:center; font-size:14px; font-weight:700; padding:13px; border-radius:11px; background:#eef3fb; color:#1e3a5f; text-decoration:none;" %>
      </div>
      <!-- Credits (highlighted) -->
      <div style="background:linear-gradient(160deg,#0e1e30,#182f4a); border:1px solid rgba(74,128,168,.35); border-radius:20px; padding:32px; display:flex; flex-direction:column; box-shadow:0 32px 64px rgba(30,58,95,.35);">
        <p style="font-size:13px; font-weight:800; letter-spacing:.05em; text-transform:uppercase; color:#7aaac9;"><%= t.("pricing.credit_label") %></p>
        <div style="display:flex; align-items:baseline; gap:4px; margin:10px 0 4px;"><span style="font-size:40px; font-weight:900; color:#fff;"><%= t.("pricing.credit_price") %></span><span style="font-size:15px; color:rgba(255,255,255,.5);"><%= t.("pricing.credit_unit") %></span></div>
        <p style="font-size:14px; color:rgba(255,255,255,.5); margin-bottom:22px;"><%= t.("pricing.credit_desc") %></p>
        <div style="display:grid; gap:12px; margin-bottom:26px; flex:1;">
          <% ["credit_f1","credit_f2","credit_f3"].each do |f| %>
            <div style="display:flex; gap:10px; align-items:flex-start;"><svg width="18" height="18" fill="none" stroke="#4ade80" stroke-width="2.5" viewBox="0 0 24 24" style="flex-shrink:0;margin-top:1px;"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg><span style="font-size:14px; color:rgba(255,255,255,.82); line-height:1.5;"><%= t.("pricing.#{f}") %></span></div>
          <% end %>
        </div>
        <%= link_to t.("pricing.credit_cta"), new_user_registration_path, style: "text-align:center; font-size:14px; font-weight:700; padding:13px; border-radius:11px; background:#fff; color:#1e3a5f; text-decoration:none;" %>
      </div>
    </div>
  </div>
</section>

<!-- ═══ FINAL CTA ═══ -->
