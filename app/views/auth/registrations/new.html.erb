<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= I18n.locale == :vi ? "Đăng ký" : "Sign Up" %> — VOX</title>
  <%= csrf_meta_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    html, body { margin: 0; padding: 0; background: #0F172A; font-family: 'Inter', sans-serif; min-height: 100vh; }
    * { box-sizing: border-box; }
    input:focus { border-color: #6366f1 !important; box-shadow: 0 0 0 3px rgba(99,102,241,0.2) !important; outline: none; }
    .auth-card-wrap { width: 480px; margin: 0 auto; }
    @media (max-width: 768px) { .auth-card-wrap { width: 100%; } }
    .field-error { display:none; font-size:12px; color:#f87171; margin-top:5px; }
    .field-error.visible { display:block; }
    input.invalid { border-color: rgba(239,68,68,0.6) !important; }
  </style>
</head>
<body>

  <div style="position:fixed; top:16px; right:16px; z-index:999; display:flex; gap:4px; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:10px; padding:4px;">
    <%= link_to request.path + "?locale=vi", style: "display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; #{I18n.locale == :vi ? 'background:#4f46e5; color:#fff;' : 'color:#64748b;'}" do %>🇻🇳 VI<% end %>
    <%= link_to request.path + "?locale=en", style: "display:inline-flex; align-items:center; gap:5px; padding:7px 14px; border-radius:7px; font-size:12px; font-weight:600; text-decoration:none; #{I18n.locale == :en ? 'background:#4f46e5; color:#fff;' : 'color:#64748b;'}" do %>🇬🇧 EN<% end %>
  </div>

  <div style="padding: 56px 16px 48px; margin: 0 auto;">
    <div class="auth-card-wrap">

      <!-- Logo -->
      <div style="text-align:center; margin-bottom:24px;">
        <div style="display:inline-block; filter:drop-shadow(0 8px 28px rgba(26,107,255,0.5));">
          <svg width="72" height="72" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
            <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
            <polygon points="325,84 318,98 338,84" fill="white"/>
            <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
            <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
            <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
            <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
          </svg>
        </div>
        <div style="font-family:system-ui,-apple-system,'Helvetica Neue',Arial,sans-serif; font-size:38px; font-weight:800; letter-spacing:10px; color:#1A6BFF; line-height:1; padding-left:10px; margin-bottom:8px;">VOX</div>
        <p style="font-size:13px; color:#64748b; margin-top:0;">
          <%= I18n.locale == :vi ? "Tạo workspace và bắt đầu ngay — miễn phí" : "Create your workspace and get started — free" %>
        </p>
      </div>

      <!-- Card -->
      <div style="background:#1E293B; border-radius:20px; border:1px solid rgba(255,255,255,0.07); padding:28px; box-shadow:0 24px 60px rgba(0,0,0,0.5);">

        <% if flash[:alert] %>
          <div style="margin-bottom:18px; display:flex; align-items:flex-start; gap:10px; padding:14px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:12px; font-size:13px; color:#f87171; line-height:1.5;">
            <span>⚠</span><span><%= flash[:alert] %></span>
          </div>
        <% end %>

        <%= form_with url: user_registration_path, method: :post, local: true, data: { turbo: false }, html: { novalidate: true, id: "signup-form" } do |f| %>

          <!-- Workspace name -->
          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">
              <%= I18n.locale == :vi ? "Tên Workspace *" : "Workspace Name *" %>
            </label>
            <input type="text" name="workspace_name" id="f_workspace" value="<%= params[:workspace_name] %>"
              placeholder="<%= I18n.locale == :vi ? 'VD: Lớp 10A, Nhóm Marketing, CLB Robotics...' : 'e.g. Class 10A, Marketing Team, Robotics Club...' %>"
              style="display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;">
            <div class="field-error" id="err_workspace"></div>
            <p style="font-size:11px; color:#475569; margin-top:6px;">
              <%= I18n.locale == :vi ? "Không gian làm việc của bạn — có thể là lớp, nhóm, CLB, tổ chức..." : "Your workspace — a class, team, club, organization, or anything." %>
            </p>
          </div>

          <div style="height:1px; background:rgba(255,255,255,0.05); margin:20px 0;"></div>

          <!-- Email -->
          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Email *</label>
            <input type="email" name="email" id="f_email" value="<%= @user&.email %>"
              placeholder="<%= I18n.locale == :vi ? 'ban@congty.com' : 'you@company.com' %>"
              style="display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;">
            <div class="field-error" id="err_email"></div>
          </div>

          <!-- Password -->
          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">
              <%= I18n.locale == :vi ? "Mật khẩu *" : "Password *" %>
            </label>
            <input type="password" name="password" id="f_password"
              placeholder="<%= I18n.locale == :vi ? 'Tối thiểu 8 ký tự' : 'At least 8 characters' %>"
              style="display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;">
            <div class="field-error" id="err_password"></div>
          </div>

          <!-- Password confirmation -->
          <div style="margin-bottom:24px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">
              <%= I18n.locale == :vi ? "Xác nhận mật khẩu *" : "Confirm password *" %>
            </label>
            <input type="password" name="password_confirmation" id="f_password_conf"
              placeholder="<%= I18n.locale == :vi ? 'Nhập lại mật khẩu' : 'Re-enter password' %>"
              style="display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;">
            <div class="field-error" id="err_password_conf"></div>
          </div>

          <!-- Free plan badge -->
          <div style="margin-bottom:20px; padding:12px 14px; background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.2); border-radius:12px; display:flex; align-items:center; gap:10px;">
            <span style="font-size:18px;">🎁</span>
            <div>
              <div style="font-size:12px; font-weight:700; color:#a5b4fc;">
                <%= I18n.locale == :vi ? "Gói Free — Miễn phí mãi mãi" : "Free Plan — Forever free" %>
              </div>
              <div style="font-size:11px; color:#475569; margin-top:2px;">
                <%= I18n.locale == :vi ? "Không giới hạn · #{Subscription.monthly_free_credits} AI Credits miễn phí/tháng" : "Unlimited · #{Subscription.monthly_free_credits} free AI Credits/month" %>
              </div>
            </div>
          </div>

          <button type="submit"
            style="display:block; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:8px; cursor:pointer; font-family:'Inter',sans-serif;">
            <%= I18n.locale == :vi ? "Tạo workspace →" : "Create workspace →" %>
          </button>

        <% end %>

        <!-- Divider -->
        <div style="display:flex; align-items:center; gap:12px; margin:20px 0 0;">
          <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
          <span style="font-size:11px; color:#475569; font-weight:600; text-transform:uppercase; letter-spacing:0.05em;">
            <%= I18n.locale == :vi ? "Hoặc đăng ký với" : "Or sign up with" %>
          </span>
          <div style="flex:1; height:1px; background:rgba(255,255,255,0.07);"></div>
        </div>

        <!-- SSO Buttons -->
        <div style="display:flex; flex-direction:column; gap:10px; margin-top:16px;">
          <%= button_to user_google_oauth2_omniauth_authorize_path(locale: I18n.locale), method: :post,
            data: { turbo: false },
            style: "display:flex; align-items:center; justify-content:center; gap:10px; padding:13px 16px; background:#fff; border:none; border-radius:10px; font-size:14px; font-weight:600; color:#1e293b; cursor:pointer; width:100%; font-family:'Inter',sans-serif;" do %>
            <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.95 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg>
            <%= I18n.locale == :vi ? "Đăng ký với Google" : "Sign up with Google" %>
          <% end %>

          <%= button_to user_entra_id_omniauth_authorize_path(locale: I18n.locale), method: :post,
            data: { turbo: false },
            style: "display:flex; align-items:center; justify-content:center; gap:10px; padding:13px 16px; background:#2f3136; border:1px solid rgba(255,255,255,0.1); border-radius:10px; font-size:14px; font-weight:600; color:#f1f5f9; cursor:pointer; width:100%; font-family:'Inter',sans-serif;" do %>
            <svg width="18" height="18" viewBox="0 0 23 23"><path fill="#f3f3f3" d="M0 0h23v23H0z"/><path fill="#f35325" d="M1 1h10v10H1z"/><path fill="#81bc06" d="M12 1h10v10H12z"/><path fill="#05a6f0" d="M1 12h10v10H1z"/><path fill="#ffba08" d="M12 12h10v10H12z"/></svg>
            <%= I18n.locale == :vi ? "Đăng ký với Microsoft" : "Sign up with Microsoft" %>
          <% end %>
        </div>

      </div>

      <p style="text-align:center; font-size:13px; color:#475569; margin-top:18px;">
        <%= I18n.locale == :vi ? "Đã có tài khoản?" : "Already have an account?" %>
        <%= link_to (I18n.locale == :vi ? "Đăng nhập" : "Sign in"), new_user_session_path, style: "color:#818cf8; font-weight:600; text-decoration:none;" %>
      </p>

    </div>
  </div>

  <script>
    (function() {
      var vi = document.documentElement.lang === 'vi';
      var msgs = {
        required:  vi ? 'Vui lòng điền thông tin này.' : 'Please fill out this field.',
        email:     vi ? 'Vui lòng nhập địa chỉ email hợp lệ.' : 'Please enter a valid email address.',
        minpass:   vi ? 'Mật khẩu phải có ít nhất 8 ký tự.' : 'Password must be at least 8 characters.',
        passconf:  vi ? 'Mật khẩu xác nhận không khớp.' : 'Passwords do not match.'
      };

      function showError(inputId, errId, msg) {
        var input = document.getElementById(inputId);
        var err   = document.getElementById(errId);
        input.classList.add('invalid');
        err.textContent = msg;
        err.classList.add('visible');
      }

      function clearError(inputId, errId) {
        var input = document.getElementById(inputId);
        var err   = document.getElementById(errId);
        input.classList.remove('invalid');
        err.classList.remove('visible');
      }

      ['f_workspace','f_email','f_password','f_password_conf'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', function() { clearError(id, id.replace('f_','err_')); });
      });

      document.getElementById('signup-form').addEventListener('submit', function(e) {
        var valid = true;

        var workspace = document.getElementById('f_workspace');
        if (!workspace.value.trim()) {
          showError('f_workspace', 'err_workspace', msgs.required); valid = false;
        }

        var email = document.getElementById('f_email');
        var emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!email.value.trim()) {
          showError('f_email', 'err_email', msgs.required); valid = false;
        } else if (!emailRe.test(email.value.trim())) {
          showError('f_email', 'err_email', msgs.email); valid = false;
        }

        var pw = document.getElementById('f_password');
        if (!pw.value) {
          showError('f_password', 'err_password', msgs.required); valid = false;
        } else if (pw.value.length < 8) {
          showError('f_password', 'err_password', msgs.minpass); valid = false;
        }

        var pwc = document.getElementById('f_password_conf');
        if (!pwc.value) {
          showError('f_password_conf', 'err_password_conf', msgs.required); valid = false;
        } else if (pwc.value !== pw.value) {
          showError('f_password_conf', 'err_password_conf', msgs.passconf); valid = false;
        }

        if (!valid) e.preventDefault();
      });
    })();
  </script>

</body>
</html>
