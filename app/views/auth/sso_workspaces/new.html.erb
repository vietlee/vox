<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= I18n.locale == :vi ? "Tạo Workspace" : "Create Workspace" %> — VOX</title>
  <%= csrf_meta_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    html, body { margin: 0; padding: 0; background: #0F172A; font-family: 'Inter', sans-serif; min-height: 100vh; }
    * { box-sizing: border-box; }
    input:focus { border-color: #6366f1 !important; box-shadow: 0 0 0 3px rgba(99,102,241,0.2) !important; outline: none; }
    .auth-card-wrap { width: 480px; margin: 0 auto; }
    @media (max-width: 768px) { .auth-card-wrap { width: 100%; } }
  </style>
</head>
<body>

  <div style="padding: 72px 16px 48px;">
    <div class="auth-card-wrap">

      <!-- Logo -->
      <div style="text-align:center; margin-bottom:28px;">
        <div style="display:inline-block; filter:drop-shadow(0 8px 28px rgba(26,107,255,0.5));">
          <svg width="72" height="72" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
            <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
            <polygon points="325,84 318,98 338,84" fill="white"/>
            <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
            <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
            <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
            <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
          </svg>
        </div>
        <div style="font-family:system-ui,-apple-system,sans-serif; font-size:38px; font-weight:800; letter-spacing:10px; color:#1A6BFF; line-height:1; padding-left:10px; margin-bottom:8px;">VOX</div>
      </div>

      <!-- Card -->
      <div style="background:#1E293B; border-radius:20px; border:1px solid rgba(255,255,255,0.07); padding:28px; box-shadow:0 24px 60px rgba(0,0,0,0.5);">

        <!-- User info -->
        <div style="display:flex; align-items:center; gap:12px; padding:14px; background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.15); border-radius:12px; margin-bottom:24px;">
          <div style="width:40px; height:40px; background:#4f46e5; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:16px; font-weight:700; color:#fff; flex-shrink:0;">
            <%= @omniauth_user["name"].to_s.split.map(&:first).join.upcase.first(2) %>
          </div>
          <div>
            <div style="font-size:13px; font-weight:600; color:#f1f5f9;"><%= @omniauth_user["name"] %></div>
            <div style="font-size:12px; color:#64748b;"><%= @omniauth_user["email"] %></div>
          </div>
        </div>

        <h2 style="font-size:18px; font-weight:800; color:#f1f5f9; margin:0 0 6px;">
          <%= I18n.locale == :vi ? "Đặt tên workspace của bạn" : "Name your workspace" %>
        </h2>
        <p style="font-size:13px; color:#64748b; margin:0 0 20px; line-height:1.6;">
          <%= I18n.locale == :vi ? "Workspace là nơi bạn tạo survey, vote, và feedback." : "Your workspace is where you create surveys, votes, and feedback." %>
        </p>

        <% if flash[:alert] %>
          <div style="margin-bottom:16px; padding:12px 14px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:10px; font-size:13px; color:#f87171;">
            ⚠ <%= flash[:alert] %>
          </div>
        <% end %>

        <%= form_with url: sso_workspace_path, method: :post, local: true do %>
          <div style="margin-bottom:20px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">
              <%= I18n.locale == :vi ? "Tên Workspace" : "Workspace Name" %>
            </label>
            <input type="text" name="workspace_name" autofocus
              placeholder="<%= I18n.locale == :vi ? 'Công ty / Tổ chức của bạn' : 'Your company / organization' %>"
              style="display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;">
          </div>

          <div style="margin-bottom:20px; padding:12px 14px; background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.2); border-radius:12px; display:flex; align-items:center; gap:10px;">
            <span style="font-size:18px;">🎁</span>
            <div>
              <div style="font-size:12px; font-weight:700; color:#a5b4fc;"><%= I18n.locale == :vi ? "Gói Free — Miễn phí mãi mãi" : "Free Plan — Forever free" %></div>
              <div style="font-size:11px; color:#475569; margin-top:2px;">
                <%= I18n.locale == :vi ? "Không giới hạn · #{Subscription.monthly_free_credits} AI Credits miễn phí/tháng" : "Unlimited · #{Subscription.monthly_free_credits} free AI Credits/month" %>
              </div>
            </div>
          </div>

          <button type="submit"
            style="display:block; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:8px; cursor:pointer; font-family:'Inter',sans-serif;">
            <%= I18n.locale == :vi ? "Tạo workspace →" : "Create workspace →" %>
          </button>
        <% end %>
      </div>

    </div>
  </div>

</body>
</html>
