<% content_for :title, "Khảo sát đã kết thúc" %>

<style>
  body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100vh; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .fade-in { animation: fadeIn 0.4s ease forwards; }
</style>

<div class="min-h-screen flex flex-col">
  <div class="flex items-center px-6 py-4">
    <span class="text-[17px] font-black tracking-tight" style="background:linear-gradient(135deg,#6366f1,#a855f7);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">VOX</span>
  </div>

  <div class="flex-1 flex items-center justify-center px-4 pb-10">
    <div class="w-full max-w-[480px] fade-in text-center">
      <div class="rounded-2xl py-12 px-8" style="background:rgba(255,255,255,0.85); border:1px solid rgba(99,102,241,0.12); box-shadow:0 8px 32px rgba(99,102,241,0.08); backdrop-filter:blur(12px);">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5"
             style="background:linear-gradient(135deg,#e0e7ff,#f3e8ff);">
          <svg class="w-8 h-8" fill="none" stroke="#6366f1" stroke-width="1.8" viewBox="0 0 24 24">
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path stroke-linecap="round" d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="text-[22px] font-extrabold text-slate-800 mb-2">Khảo sát đã kết thúc</h1>
        <p class="text-[13px] text-slate-400">Khảo sát này hiện không còn nhận câu trả lời.</p>
      </div>
    </div>
  </div>

  <div class="text-center pb-6">
    <span class="text-[11px] text-slate-400">Powered by <strong class="text-slate-500">VOX</strong></span>
  </div>
</div>
