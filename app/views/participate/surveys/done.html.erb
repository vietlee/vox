<% content_for :title, t("participate.survey.thank_you") %>

<style>
  body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100vh; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .fade-in { animation: fadeIn 0.4s ease forwards; }
  .result-bar-bg { background: #eef0ff; border-radius: 6px; height: 8px; overflow: hidden; }
  .result-bar-fill { background: linear-gradient(90deg, #6366f1, #a855f7); border-radius: 6px; height: 100%; transition: width 0.6s ease; }
</style>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%);">


  <div class="flex-1 flex items-center justify-center px-4 pb-10">
    <div class="w-full max-w-[560px] fade-in">

      <!-- Thank you card -->
      <div class="rounded-2xl py-10 px-8 text-center mb-5" style="background:rgba(255,255,255,0.85); border:1px solid rgba(99,102,241,0.15); box-shadow:0 8px 32px rgba(99,102,241,0.08); backdrop-filter:blur(12px);">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5"
             style="background:linear-gradient(135deg,#6366f1,#a855f7);">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <h1 class="text-[24px] font-extrabold text-slate-800 mb-2"><%= t("participate.survey.thank_you") %></h1>
        <p class="text-[14px] text-slate-500 leading-relaxed">
          <%= @survey.thank_you_message.presence || t("participate.survey.thank_you_default") %>
        </p>
      </div>

      <!-- Results section -->
      <% if @survey.show_results? && !@stats.nil? && @stats.any? %>
        <div class="rounded-2xl px-6 py-5" style="background:rgba(255,255,255,0.85); border:1px solid rgba(99,102,241,0.15); box-shadow:0 4px 16px rgba(99,102,241,0.06); backdrop-filter:blur(12px);">
          <h2 class="text-[14px] font-bold text-slate-700 mb-4">📊 <%= t("participate.survey.results_title") %></h2>

          <% @questions.each do |question| %>
            <% stat = @stats[question.id] %>
            <% next unless stat %>

            <div class="mb-6 last:mb-0">
              <p class="text-[13px] font-semibold text-slate-800 mb-3"><%= question.title %></p>

              <% if stat[:type] == :choice %>
                <% total = [stat[:total], 1].max %>
                <% question.question_options.each do |opt| %>
                  <% count = stat[:counts][opt.id.to_s] || 0 %>
                  <% pct = (count * 100.0 / total).round %>
                  <div class="mb-2">
                    <div class="flex justify-between text-[12px] text-slate-600 mb-1">
                      <span><%= opt.label %></span>
                      <span class="font-semibold"><%= pct %>% <span class="text-slate-400 font-normal">(<%= count %>)</span></span>
                    </div>
                    <div class="result-bar-bg">
                      <div class="result-bar-fill" style="width:<%= pct %>%"></div>
                    </div>
                  </div>
                <% end %>

              <% elsif stat[:type] == :text %>
                <div class="space-y-2">
                  <% stat[:recent].each do |txt| %>
                    <div class="bg-slate-50 rounded-lg px-3 py-2 text-[13px] text-slate-700 leading-relaxed">"<%= txt %>"</div>
                  <% end %>
                  <% if stat[:count] > stat[:recent].size %>
                    <p class="text-[12px] text-slate-400 text-center">+ <%= stat[:count] - stat[:recent].size %> <%= t("participate.survey.other_responses") %></p>
                  <% end %>
                </div>

              <% elsif stat[:type] == :numeric %>
                <% max_val = question.rating? ? 5 : (question.nps? ? 10 : (question.settings&.dig("max") || 10).to_i) %>
                <% avg = stat[:avg] || 0 %>
                <% pct = ((avg / max_val.to_f) * 100).round %>
                <div class="flex items-center gap-3">
                  <div class="result-bar-bg flex-1">
                    <div class="result-bar-fill" style="width:<%= pct %>%"></div>
                  </div>
                  <span class="text-[15px] font-bold text-indigo-600 min-w-[48px] text-right">
                    <%= stat[:avg] || "—" %><span class="text-[11px] text-slate-400 font-normal">/<%= max_val %></span>
                  </span>
                </div>
                <p class="text-[11px] text-slate-400 mt-1"><%= stat[:count] %> <%= t("participate.survey.responses_count") %></p>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

    </div>
  </div>

  <div class="text-center pb-6">
    <span class="inline-flex items-center gap-1.5"><img src="/vox_logo.svg" alt="VOX" style="height:18px;width:auto;opacity:0.65;"><span style="font-size:11px;color:#94a3b8;">· Survey &amp; Voting Platform</span></span>
  </div>
</div>
