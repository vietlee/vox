<% content_for :title, @survey.title %>

<style>
  html, body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100%; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
  .q-card { animation: fadeIn 0.35s ease forwards; }
  .opt-label { transition: all 0.15s ease; cursor: pointer; display: flex; align-items: center; gap: 12px; padding: 12px 16px; border-radius: 14px; border: 2px solid #e2e8f0; background: rgba(255,255,255,0.85); }
  .opt-label:hover { border-color: #a5b4fc; background: rgba(238,240,255,0.5); }
  .opt-label:has(input:checked) { border-color: #6366f1; background: rgba(238,240,255,0.9); }
  .opt-dot { flex-shrink:0; width:18px; height:18px; border-radius:50%; border:2px solid #cbd5e1; display:flex; align-items:center; justify-content:center; transition: all 0.15s; }
  .opt-label:has(input[type=radio]:checked) .opt-dot { border-color:#6366f1; background:#6366f1; }
  .opt-label:has(input[type=radio]:checked) .opt-dot::after { content:''; width:7px; height:7px; border-radius:50%; background:#fff; }
  .opt-box { flex-shrink:0; width:18px; height:18px; border-radius:5px; border:2px solid #cbd5e1; display:flex; align-items:center; justify-content:center; transition: all 0.15s; }
  .opt-label:has(input[type=checkbox]:checked) .opt-box { border-color:#6366f1; background:#6366f1; }
  .opt-label:has(input[type=checkbox]:checked) .opt-box::after { content:'✓'; font-size:11px; font-weight:900; color:#fff; }
</style>

<% content_for :nav_right do %>
  <div class="text-[11px] text-slate-400"><%= @questions.count %> <%= t("participate.survey.questions_count") %></div>
<% end %>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%)">

  <% if @survey.show_progress? %>
  <!-- Progress — fixed to avoid Chrome mobile stacking context issues -->
  <div class="px-4 sm:px-6 py-2" style="position:fixed; top:47px; left:0; right:0; z-index:9998; transform:translateZ(0); -webkit-transform:translateZ(0); background:linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%);">
    <div class="max-w-[680px] mx-auto">
      <div class="flex justify-between text-[11px] text-slate-500 mb-1.5 mt-2">
        <span id="progress-label"><%= t("participate.survey.progress", answered: 0, total: @questions.count) %></span>
      </div>
      <div class="h-1.5 bg-white/60 rounded-full overflow-hidden" style="border:1px solid rgba(99,102,241,0.15);">
        <div id="progress-bar" class="h-full rounded-full transition-all duration-500" style="width:0%; background:linear-gradient(90deg,#6366f1,#a855f7);"></div>
      </div>
    </div>
  </div>
  <!-- Spacer matching progress bar height -->
  <div style="height:44px;"></div>
  <% end %>

  <!-- Fixed survey header — same layer as navbar, immune to mobile Chrome viewport shifts -->
  <div id="survey-fixed-header"
       style="position:fixed; left:0; right:0; z-index:9997;
              background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%);
              border-bottom:1px solid rgba(226,232,240,0.7);
              box-shadow:0 2px 12px rgba(99,102,241,0.06);
              transform:translateZ(0); -webkit-transform:translateZ(0);">
    <div class="max-w-[680px] mx-auto px-4 py-3 text-center">
      <% if @survey.logo.attached? %>
        <img src="<%= url_for(@survey.logo) %>" alt="<%= @survey.title %>"
             class="object-contain mx-auto mb-1.5 rounded-xl"
             style="max-height:48px; max-width:180px;">
      <% end %>
      <h1 class="text-[18px] font-extrabold text-slate-900 tracking-tight leading-snug mb-0.5"><%= @survey.title %></h1>
      <% if @survey.description.present? %>
        <div id="survey-desc-wrap" class="mb-0.5">
          <p id="survey-desc-text" class="text-[12px] text-slate-500"
             style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:1; -webkit-box-orient:vertical;"><%= @survey.description %></p>
          <button id="survey-desc-toggle" type="button"
                  onclick="toggleSurveyDesc()"
                  class="text-[11px] font-semibold text-indigo-500 hover:text-indigo-700 border-0 bg-transparent p-0 cursor-pointer mt-0.5"
                  style="display:none;">
            <%= t("participate.feedback.show_more") %>
          </button>
        </div>
      <% end %>
      <span class="text-[11px] text-slate-400"><%= @questions.count %> <%= t("participate.survey.questions_count") %></span>
    </div>
  </div>
  <!-- Spacer — height set by JS -->
  <div id="survey-header-spacer"></div>
  <script>
    (function() {
      var showProgress = <%= @survey.show_progress? ? 'true' : 'false' %>;
      var navH = window.innerWidth >= 640 ? 57 : 47;
      var progH = showProgress ? 44 : 0;
      var hdr = document.getElementById('survey-fixed-header');
      function sync() {
        navH  = window.innerWidth >= 640 ? 57 : 47;
        hdr.style.top = (navH + progH) + 'px';
        document.getElementById('survey-header-spacer').style.height = hdr.offsetHeight + 'px';
      }
      sync();
      window.addEventListener('resize', sync);
      // Re-sync after images finish loading (logo may not be loaded yet on first run)
      window.addEventListener('load', sync);
      requestAnimationFrame(function() { requestAnimationFrame(sync); });

      // Show "Xem thêm" button only when text is actually clamped
      var desc = document.getElementById('survey-desc-text');
      var btn  = document.getElementById('survey-desc-toggle');
      if (desc && btn && desc.scrollHeight > desc.clientHeight + 2) {
        btn.style.display = 'inline';
      }
    })();

    var _surveyDescExpanded = false;
    function toggleSurveyDesc() {
      _surveyDescExpanded = !_surveyDescExpanded;
      var desc = document.getElementById('survey-desc-text');
      var btn  = document.getElementById('survey-desc-toggle');
      if (_surveyDescExpanded) {
        desc.style.webkitLineClamp = 'unset';
        desc.style.display = 'block';
        btn.textContent = '<%= j t("participate.feedback.show_less") %>';
      } else {
        desc.style.webkitLineClamp = '1';
        desc.style.display = '-webkit-box';
        btn.textContent = '<%= j t("participate.feedback.show_more") %>';
      }
      // re-sync spacer after height change
      var hdr = document.getElementById('survey-fixed-header');
      document.getElementById('survey-header-spacer').style.height = hdr.offsetHeight + 'px';
    }
  </script>

  <!-- Content -->
  <div class="flex-1 flex flex-col px-4 py-4">
    <div class="max-w-[680px] mx-auto w-full flex-1 flex flex-col">

      <% if @already_responded || flash[:alert].present? %>
        <div class="fade-in text-center">
          <div class="rounded-2xl py-10 px-8" style="background:#ffffff; border:1px solid rgba(99,102,241,0.15); box-shadow:0 8px 32px rgba(99,102,241,0.08);">
            <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4"
                 style="background:linear-gradient(135deg,#6366f1,#a855f7);">
              <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h2 class="text-[20px] font-extrabold text-slate-800 mb-2"><%= t("participate.survey.already_answered") %></h2>
            <p class="text-[13px] text-slate-500"><%= t("participate.survey.already_answered_desc") %></p>
          </div>
        </div>
      <% else %>

      <% if @previous_answers.present? %>
        <div class="mb-4 px-4 py-3 rounded-xl text-[13px] text-amber-700 font-medium" style="background:#fffbeb; border:1px solid #fcd34d;">
          ✏️ <%= t("participate.survey.editing_previous") %>
        </div>
      <% end %>

      <%= form_with url: submit_survey_path(@survey.slug), method: :post, local: true, id: "survey-form", class: "space-y-4", multipart: true, data: { turbo: false } do |f| %>

        <% if @survey.email_required? %>
          <div class="q-card rounded-2xl p-5" style="background:#ffffff; border:1px solid rgba(99,102,241,0.15); box-shadow:0 4px 16px rgba(99,102,241,0.06);">
            <label class="block text-[13px] font-semibold text-slate-700 mb-2"><%= t("participate.survey.email_label") %> <span class="text-red-400">*</span></label>
            <input type="email" name="response[respondent_email]" required placeholder="your@email.com"
              value="<%= @previous_email %>"
              class="w-full px-3 py-2.5 border border-slate-200 rounded-xl focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none bg-white" style="font-size:16px;">
          </div>
        <% end %>

        <% @questions.each_with_index do |question, idx| %>
          <% cond = question.conditional_logic.presence || {} %>
          <div class="q-card rounded-2xl p-5" data-qid="<%= question.id %>" data-required="<%= question.required? %>"
               data-condition="<%= cond.to_json %>"
               style="background:#ffffff; border:1px solid rgba(99,102,241,0.12); box-shadow:0 4px 16px rgba(99,102,241,0.06);">
            <div class="flex items-start gap-3 mb-4">
              <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-[11px] font-black text-white flex-shrink-0 mt-0.5"
                    style="background:linear-gradient(135deg,#6366f1,#a855f7);"><%= idx + 1 %></span>
              <div>
                <p class="text-[15px] font-semibold text-slate-900 leading-snug">
                  <%= question.title %>
                  <% if question.required? %><span class="text-red-400 ml-1">*</span><% end %>
                </p>
                <% if question.description.present? %>
                  <p class="text-[12px] text-slate-400 mt-1"><%= question.description %></p>
                <% end %>
              </div>
            </div>
            <%= render "participate/surveys/question_input", question: question, prev_answer: @previous_answers&.[](question.id) %>
          </div>
        <% end %>

        <div class="pt-4 pb-10">
          <button type="submit" id="survey-submit-btn"
            class="w-full py-3 text-[14px] font-semibold text-white rounded-lg transition-all"
            style="background:#4F46E5; border:0; cursor:not-allowed; opacity:0.45;"
            disabled>
            <%= t("participate.survey.submit") %>
          </button>
        </div>
      <% end %>

      <% end %> <%# end unless @already_responded %>

      <div class="flex-1"></div>
      <p class="flex justify-center items-center gap-1.5 py-6"><img src="/vox_logo.svg" alt="VOX" style="height:18px;width:auto;opacity:0.65;"><span style="font-size:11px;color:#94a3b8;">· Survey &amp; Voting Platform</span></p>
    </div>
  </div>

</div>

<script>
(function() {
  const PROG_TPL  = "<%= j t('participate.survey.progress', answered: '__N__', total: @questions.count) %>";
  const ERR_MSG   = "<%= I18n.locale.to_s == 'vi' ? 'Vui lòng trả lời câu hỏi này' : 'Please answer this question' %>";

  // ── Skip Logic ──────────────────────────────────────────────────────────────
  // Build condition map from data-condition attributes
  const COND_MAP = {};
  document.querySelectorAll('.q-card[data-condition]').forEach(card => {
    try {
      const cond = JSON.parse(card.dataset.condition || '{}');
      if (cond.source_question_id) COND_MAP[card.dataset.qid] = cond;
    } catch(e) {}
  });

  function getCardAnswerText(card) {
    // Radio (single choice)
    const checkedRadio = card.querySelector('input[type=radio]:checked');
    if (checkedRadio) {
      const lbl = card.querySelector(`label[for="${checkedRadio.id}"]`) || checkedRadio.closest('label');
      return (lbl?.textContent?.trim() || checkedRadio.value).toLowerCase();
    }
    // Checkbox (multiple choice) — return joined labels
    const checkedBoxes = [...card.querySelectorAll('input[type=checkbox]:checked')];
    if (checkedBoxes.length > 0) {
      return checkedBoxes.map(cb => {
        const lbl = card.querySelector(`label[for="${cb.id}"]`) || cb.closest('label');
        return (lbl?.textContent?.trim() || cb.value).toLowerCase();
      }).join(',');
    }
    // Select / dropdown
    const sel = card.querySelector('select');
    if (sel && sel.value) return (sel.options[sel.selectedIndex]?.text || sel.value).toLowerCase();
    // Text inputs
    const txt = card.querySelector('input[type=text], input[type=number], textarea');
    if (txt && txt.value.trim()) return txt.value.trim().toLowerCase();
    return '';
  }

  function checkCondition(sourceCard, cond) {
    const op    = cond.operator || 'equals';
    const val   = (cond.value || '').toLowerCase();
    const answered = isCardAnswered(sourceCard);

    if (op === 'answered')     return answered;
    if (op === 'not_answered') return !answered;

    const answerText = getCardAnswerText(sourceCard);
    if (op === 'equals')     return answerText === val;
    if (op === 'not_equals') return answerText !== val;
    if (op === 'contains')   return answerText.includes(val);
    return true;
  }

  function evaluateConditions() {
    Object.entries(COND_MAP).forEach(([qid, cond]) => {
      const card = document.querySelector(`.q-card[data-qid="${qid}"]`);
      if (!card) return;
      const sourceCard = document.querySelector(`.q-card[data-qid="${cond.source_question_id}"]`);
      if (!sourceCard) return;

      const show = checkCondition(sourceCard, cond);
      if (show) {
        card.style.display = '';
        card.dataset.condHidden = 'false';
      } else {
        card.style.display = 'none';
        card.dataset.condHidden = 'true';
        // Clear error styling if hidden
        card.style.removeProperty('border');
        card.querySelector('.q-validation-error')?.remove();
      }
    });
  }

  // ── Answered check ──────────────────────────────────────────────────────────
  function isCardAnswered(card) {
    const radios   = card.querySelectorAll('input[type=radio]');
    const checks   = card.querySelectorAll('input[type=checkbox]');
    const texts    = card.querySelectorAll('input[type=text], input[type=email], input[type=number], textarea');
    const files    = card.querySelectorAll('input[type=file]');
    const dtInputs = card.querySelectorAll('input[type=datetime-local]');
    if ([...radios].some(i => i.checked))      return true;
    if ([...checks].some(i => i.checked))      return true;
    if ([...texts].some(i => i.value.trim()))  return true;
    if ([...files].some(i => i.files && i.files.length)) return true;
    if ([...dtInputs].some(i => i.value))      return true;
    return false;
  }

  // ── Progress ────────────────────────────────────────────────────────────────
  function updateProgress() {
    evaluateConditions();
    let answered = 0, visibleTotal = 0;
    document.querySelectorAll('.q-card[data-qid]').forEach(card => {
      if (card.dataset.condHidden === 'true') return;
      visibleTotal++;
      if (isCardAnswered(card)) answered++;
    });
    const pct   = visibleTotal > 0 ? Math.round(answered / visibleTotal * 100) : 0;
    const bar   = document.getElementById('progress-bar');
    const label = document.getElementById('progress-label');
    if (bar)   bar.style.width = pct + '%';
    if (label) label.textContent = PROG_TPL.replace('__N__', answered);
    updateSubmitBtn();
  }

  function updateSubmitBtn() {
    const btn = document.getElementById('survey-submit-btn');
    if (!btn) return;
    const required = [...document.querySelectorAll('.q-card[data-required="true"]')]
      .filter(c => c.dataset.condHidden !== 'true');
    const allDone = required.every(isCardAnswered);
    btn.disabled      = !allDone;
    btn.style.opacity = allDone ? '1'       : '0.45';
    btn.style.cursor  = allDone ? 'pointer' : 'not-allowed';
  }

  function showErrors() {
    document.querySelectorAll('.q-validation-error').forEach(el => el.remove());
    document.querySelectorAll('.q-card[data-required="true"]').forEach(card => {
      card.style.removeProperty('border');
    });

    const failed = [];
    const required = [...document.querySelectorAll('.q-card[data-required="true"]')]
      .filter(c => c.dataset.condHidden !== 'true');
    required.forEach(card => {
      if (!isCardAnswered(card)) {
        failed.push(card);
        card.style.border = '2px solid #f87171';
        const err = document.createElement('p');
        err.className   = 'q-validation-error';
        err.textContent = ERR_MSG;
        err.style.cssText = 'color:#ef4444; font-size:12px; font-weight:600; margin-top:10px;';
        card.appendChild(err);
      }
    });

    if (failed.length > 0) {
      const offset = failed[0].getBoundingClientRect().top + window.scrollY - 120;
      window.scrollTo({ top: offset, behavior: 'smooth' });
      return false;
    }
    return true;
  }

  function clearCardError(card) {
    if (isCardAnswered(card)) {
      card.style.removeProperty('border');
      card.querySelector('.q-validation-error')?.remove();
    }
  }

  // On submit: disable inputs in condition-hidden cards so they're not posted
  const form = document.getElementById('survey-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      if (!showErrors()) { e.preventDefault(); return; }
      // Disable hidden-by-condition inputs so they're excluded from POST
      document.querySelectorAll('.q-card[data-cond-hidden="true"]').forEach(card => {
        card.querySelectorAll('input, textarea, select').forEach(el => el.disabled = true);
      });
    });
  }

  document.addEventListener('change', function(e) {
    updateProgress();
    const card = e.target.closest('.q-card[data-required="true"]');
    if (card) clearCardError(card);
  });
  document.addEventListener('input', function(e) {
    updateProgress();
    const card = e.target.closest('.q-card[data-required="true"]');
    if (card) clearCardError(card);
  });
  document.addEventListener('touchend', function() {
    setTimeout(updateProgress, 50);
  }, { passive: true });

  // Init
  evaluateConditions();
  updateSubmitBtn();
})();
</script>
