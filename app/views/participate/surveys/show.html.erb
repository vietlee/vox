<% content_for :title, @survey.title %>

<div class="max-w-[680px] mx-auto px-4 py-10">
  <!-- Survey header -->
  <div class="mb-8 text-center">
    <h1 class="text-[24px] font-extrabold text-slate-900 tracking-tight mb-2"><%= @survey.title %></h1>
    <% if @survey.description.present? %>
      <p class="text-[14px] text-slate-600 leading-relaxed"><%= @survey.description %></p>
    <% end %>
  </div>

  <!-- Progress -->
  <% if @survey.show_progress? %>
    <div class="mb-6">
      <div class="flex justify-between text-[11px] text-slate-500 mb-1.5">
        <span><%= @questions.count %> questions</span>
        <span>~<%= (@questions.count * 1.5).ceil %> min</span>
      </div>
      <div class="h-1.5 bg-slate-200 rounded-full"><div class="h-1.5 bg-indigo-500 rounded-full w-0"></div></div>
    </div>
  <% end %>

  <%= form_with url: submit_survey_path(@survey.slug), method: :post, local: true, class: "space-y-6" do |f| %>
    <% if @survey.email_required? %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <label class="block text-[13px] font-semibold text-slate-700 mb-2">Email address <span class="text-red-500">*</span></label>
        <%= f.fields_for :response do |rf| %>
          <%= rf.email_field :respondent_email, required: true, placeholder: "your@email.com",
            class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none" %>
        <% end %>
      </div>
    <% end %>

    <% @questions.each_with_index do |question, idx| %>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <p class="text-[15px] font-semibold text-slate-900 mb-1 leading-snug">
          <span class="text-slate-400 mr-1"><%= idx + 1 %>.</span>
          <%= question.title %>
          <% if question.required? %><span class="text-red-500 ml-0.5">*</span><% end %>
        </p>
        <% if question.description.present? %>
          <p class="text-[12px] text-slate-500 mb-3"><%= question.description %></p>
        <% end %>
        <div class="mt-4">
          <%= render "participate/surveys/question_input", question: question %>
        </div>
      </div>
    <% end %>

    <div class="flex justify-center pt-2">
      <%= f.submit "Submit Survey →", class: "px-10 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white text-[15px] font-bold rounded-xl transition-colors cursor-pointer min-w-[200px] text-center" %>
    </div>

    <p class="text-center text-[11px] text-slate-400">This survey is powered by <strong>Vox</strong></p>
  <% end %>
</div>
