<% field_name = "answers[#{question.id}]" %>
<% case question.question_type.to_sym %>
<% when :multiple_choice, :dropdown %>
  <div class="space-y-2">
    <% question.question_options.each do |opt| %>
      <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 hover:border-indigo-300 hover:bg-indigo-50 cursor-pointer transition-colors">
        <input type="radio" name="<%= field_name %>[option_id]" value="<%= opt.id %>" class="accent-indigo-600 w-4 h-4">
        <span class="text-[14px] text-slate-700"><%= opt.label %></span>
      </label>
    <% end %>
  </div>
<% when :checkbox %>
  <div class="space-y-2">
    <% question.question_options.each do |opt| %>
      <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 hover:border-indigo-300 hover:bg-indigo-50 cursor-pointer transition-colors">
        <input type="checkbox" name="<%= field_name %>[option_ids][]" value="<%= opt.id %>" class="accent-indigo-600 w-4 h-4 rounded">
        <span class="text-[14px] text-slate-700"><%= opt.label %></span>
      </label>
    <% end %>
  </div>
<% when :short_text %>
  <input type="text" name="<%= field_name %>[text]" <%= "required" if question.required? %>
    class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none"
    placeholder="Your answer...">
<% when :long_text %>
  <textarea name="<%= field_name %>[text]" rows="4" <%= "required" if question.required? %>
    class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none"
    placeholder="Your answer..."></textarea>
<% when :rating %>
  <% max = question.settings["max_value"]&.to_i || 5 %>
  <div class="flex gap-2">
    <% (1..max).each do |i| %>
      <label class="flex flex-col items-center gap-1 cursor-pointer">
        <input type="radio" name="<%= field_name %>[value]" value="<%= i %>" class="sr-only peer">
        <div class="w-10 h-10 rounded-full border-2 border-slate-200 flex items-center justify-center text-[14px] font-semibold text-slate-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-500 peer-checked:text-white hover:border-indigo-300 transition-colors"><%= i %></div>
      </label>
    <% end %>
  </div>
<% when :nps %>
  <div class="flex gap-1.5 flex-wrap">
    <% (0..10).each do |i| %>
      <label class="cursor-pointer">
        <input type="radio" name="<%= field_name %>[value]" value="<%= i %>" class="sr-only peer">
        <div class="w-10 h-10 rounded-lg border-2 border-slate-200 flex items-center justify-center text-[13px] font-semibold <%= i <= 6 ? 'text-red-500' : i <= 8 ? 'text-amber-500' : 'text-emerald-500' %> peer-checked:border-current peer-checked:bg-current peer-checked:text-white transition-colors"><%= i %></div>
      </label>
    <% end %>
  </div>
  <div class="flex justify-between text-[11px] text-slate-400 mt-1.5">
    <span>Not likely at all</span><span>Extremely likely</span>
  </div>
<% when :linear_scale %>
  <% min = question.settings["min_value"]&.to_i || 1; max = question.settings["max_value"]&.to_i || 5 %>
  <div class="flex gap-2 items-center">
    <span class="text-[12px] text-slate-500"><%= question.settings["min_label"] %></span>
    <% (min..max).each do |i| %>
      <label class="cursor-pointer">
        <input type="radio" name="<%= field_name %>[value]" value="<%= i %>" class="sr-only peer">
        <div class="w-9 h-9 rounded-lg border-2 border-slate-200 flex items-center justify-center text-[13px] font-semibold text-slate-600 peer-checked:border-indigo-500 peer-checked:bg-indigo-500 peer-checked:text-white hover:border-indigo-300 transition-colors"><%= i %></div>
      </label>
    <% end %>
    <span class="text-[12px] text-slate-500"><%= question.settings["max_label"] %></span>
  </div>
<% else %>
  <input type="text" name="<%= field_name %>[text]"
    class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none">
<% end %>
