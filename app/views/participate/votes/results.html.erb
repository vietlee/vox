<% content_for :title, @vote.title %>

<style>
  html, body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100%; }
  @keyframes fadeIn  { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes barGrow { from { width: 0; } to { width: var(--bar-w); } }
  .fade-in { animation: fadeIn 0.4s ease forwards; }
  .bar-anim { animation: barGrow 0.8s cubic-bezier(0.4,0,0.2,1) forwards; }
</style>

<%
  colors = [
    { bar: 'linear-gradient(90deg,#22d3ee,#3b82f6)', text: '#3b82f6' },
    { bar: 'linear-gradient(90deg,#2d5f8a,#1e3a5f)',  text: '#2d5f8a' },
    { bar: 'linear-gradient(90deg,#fb7185,#e11d48)',  text: '#fb7185' },
    { bar: 'linear-gradient(90deg,#fbbf24,#f97316)',  text: '#f97316' },
    { bar: 'linear-gradient(90deg,#34d399,#059669)',  text: '#34d399' },
    { bar: 'linear-gradient(90deg,#38bdf8,#1e3a5f)',  text: '#38bdf8' },
  ]
%>

<% content_for :nav_right do %>
  <div class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold
    <%= @vote.active? ? 'text-emerald-700' : 'text-slate-500' %>"
    style="background:<%= @vote.active? ? 'rgba(16,185,129,0.1)' : 'rgba(100,116,139,0.1)' %>; border:1px solid <%= @vote.active? ? 'rgba(16,185,129,0.2)' : 'rgba(100,116,139,0.2)' %>;">
    <% if @vote.active? %>
      <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
      <%= t("participate.vote.live_badge") %>
    <% else %>
      <%= t("participate.vote.closed_badge") %>
    <% end %>
  </div>
<% end %>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%)">

  <!-- Main -->
  <div class="flex-1 flex flex-col items-center px-4 pb-10 pt-2">
    <div class="w-full max-w-[560px]">

      <!-- Header -->
      <div class="text-center mb-8 fade-in">
        <h1 class="text-[26px] font-extrabold text-slate-900 tracking-tight leading-snug mb-2"><%= @vote.title %></h1>
        <p class="text-[13px] text-slate-400"><%= @vote.participant_count %> <%= t("participate.vote.participants") %></p>
      </div>

      <!-- Results -->
      <div class="space-y-3">
        <% @results.each_with_index do |result, i| %>
          <% c = colors[i % colors.size] %>
          <div class="fade-in rounded-2xl px-5 py-4" style="background:#ffffff; border:1px solid rgba(226,232,240,0.8); box-shadow:0 2px 12px rgba(0,0,0,0.04); animation-delay:<%= i * 0.07 %>s;">
            <div class="flex justify-between items-center mb-3">
              <span class="text-[15px] font-semibold text-slate-800"><%= result[:label] %></span>
              <div class="flex items-center gap-3">
                <span class="text-[12px] text-slate-400"><%= result[:count] %> <%= t("participate.vote.total_votes") %></span>
                <span class="text-[18px] font-black tabular-nums" style="color:<%= c[:text] %>"><%= result[:percentage] %>%</span>
              </div>
            </div>
            <div class="h-2.5 rounded-full overflow-hidden" style="background:rgba(226,232,240,0.6);">
              <div class="h-2.5 rounded-full bar-anim"
                   style="--bar-w:<%= [result[:percentage].to_f, result[:percentage].to_f > 0 ? 3 : 0].max %>%; background:<%= c[:bar] %>; width:var(--bar-w);"></div>
            </div>
          </div>
        <% end %>
      </div>


    </div>
  </div>

  <!-- Footer -->
  <div class="text-center pb-6">
    <span class="inline-flex items-center gap-1.5"><img src="/vox_logo.svg" alt="VOX" style="height:18px;width:auto;opacity:0.65;"><span style="font-size:11px;color:#94a3b8;">· Nền tảng học tiếng Anh</span></span>
  </div>

</div>
