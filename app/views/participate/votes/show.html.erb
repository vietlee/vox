<% content_for :title, @vote.title %>

<style>
  html, body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100%; }
  .option-btn { transition: all 0.15s ease; }
  .option-btn:hover { transform: translateY(-1px); }
  .option-btn.selected { transform: translateY(-1px); }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .fade-in { animation: fadeIn 0.4s ease forwards; }

  /* ── Rich description HTML (vote page) ── */
  .option-desc-html { font-size: 13px; color: #64748b; line-height: 1.6; }
  .option-desc-html p { margin: 0 0 2px 0; }
  .option-desc-html p:last-child { margin-bottom: 0; }
  .option-desc-html ul, .option-desc-html ol { padding-left: 0; margin: 2px 0; list-style: none; }
  .option-desc-html ul li::before { content: '·'; margin-right: 5px; color: #94a3b8; }
  .option-desc-html ol { counter-reset: odesc-ol; }
  .option-desc-html ol li { counter-increment: odesc-ol; }
  .option-desc-html ol li::before { content: counter(odesc-ol) '.'; margin-right: 5px; color: #94a3b8; }
  .option-desc-html li { margin: 1px 0; }
  .option-desc-html strong { font-weight: 700; color: #475569; }
  .option-desc-html em { font-style: italic; }
  .option-desc-html u  { text-decoration: underline; }
  .option-desc-html span[style] { }

  /* ── Collapsible description ── */
  .desc-collapsed {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .desc-expanded { display: block; }
  .desc-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-top: 4px;
    font-size: 11px;
    font-weight: 600;
    color: #1e3a5f;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    line-height: 1;
  }
  .desc-toggle-btn:hover { color: #1e3a5f; }
  .desc-toggle-btn svg { transition: transform 0.2s; }
  .desc-toggle-btn.expanded svg { transform: rotate(180deg); }
</style>

<% content_for :nav_right do %>
  <div class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold text-emerald-700" style="background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.2);">
    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
    <%= t("participate.vote.live_badge") %>
  </div>
<% end %>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%)">

  <!-- Main -->
  <div class="flex-1 flex flex-col items-center justify-center px-4 pb-10">
    <div class="w-full max-w-[520px]">

      <!-- Vote header card -->
      <div class="text-center mb-6 fade-in">
        <h1 class="text-[28px] font-extrabold text-slate-900 tracking-tight leading-snug mb-2"><%= @vote.title %></h1>
        <p class="text-[13px] text-slate-400" id="participant-count">
          <%= @vote.participant_count %> <%= t("participate.vote.participants") %>
        </p>

        <% if @seconds_remaining %>
          <div class="mt-5 flex flex-col items-center gap-2">
            <div class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" d="M12 6v6l4 2"/></svg>
              <span class="text-[12px] font-semibold text-slate-500"><%= t("participate.vote.time_remaining") %></span>
              <span id="countdown-text" class="text-[20px] font-black tabular-nums"
                    style="color:<%= @seconds_remaining > @vote.countdown_seconds * 0.2 ? '#1e3a5f' : '#ef4444' %>">
                <%= format("%02d:%02d", @seconds_remaining / 60, @seconds_remaining % 60) %>
              </span>
            </div>
            <div class="w-56 h-1.5 bg-slate-200 rounded-full overflow-hidden">
              <div id="countdown-bar" class="h-1.5 rounded-full transition-all duration-1000"
                   style="width:<%= (@seconds_remaining.to_f / @vote.countdown_seconds * 100).round(1) %>%;
                          background:<%= @seconds_remaining > @vote.countdown_seconds * 0.2 ? '#1e3a5f' : '#ef4444' %>;"></div>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Time up -->
      <div id="time-up-box" class="hidden fade-in mb-4">
        <div class="text-center py-8 px-6 rounded-2xl" style="background:#ffffff; border:1px solid rgba(239,68,68,0.2); box-shadow:0 8px 32px rgba(239,68,68,0.08);">
          <div class="text-[48px] mb-3">⏰</div>
          <p class="text-[18px] font-extrabold text-slate-800"><%= t("participate.vote.time_up") %></p>
        </div>
      </div>

      <!-- Already voted state -->
      <div id="already-voted" class="<%= @already_voted ? '' : 'hidden' %> fade-in">
        <%# Banner: only shown when revisiting after having voted (server-side flag) %>
        <% if @already_voted %>
          <div class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl mb-3"
               style="background:rgba(245,158,11,0.08); border:1px solid rgba(245,158,11,0.25);">
            <svg class="w-4 h-4 flex-shrink-0" style="color:#d97706;" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p class="text-[12px] font-semibold" style="color:#92400e;">
              <%= I18n.locale == :vi ? "Bạn đã bình chọn trước đó rồi." : "You have already submitted a response." %>
            </p>
          </div>
        <% end %>

        <div class="text-center py-10 px-6 rounded-2xl mb-4" style="background:#ffffff; border:1px solid rgba(30,58,95,0.15); box-shadow:0 8px 32px rgba(30,58,95,0.08);">
          <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4" style="background:linear-gradient(135deg,#1e3a5f,#2d5f8a);">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="text-[20px] font-extrabold text-slate-800 mb-1"><%= t("participate.vote.voted") %></h2>
          <p class="text-[13px] text-slate-500 mb-6"><%= t("participate.vote.voted_thanks") %></p>
          <% if @vote.show_results_live? %>
            <a href="/v/<%= @vote.slug %>/present?readonly=1" target="_blank"
               class="inline-flex items-center gap-2 px-6 py-3 text-[14px] font-bold text-white rounded-lg transition-all hover:opacity-90 hover:-translate-y-0.5"
               style="background:#1e3a5f;">
              <%= t("participate.vote.view_results_live") %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          <% end %>
        </div>
      </div>

      <!-- Vote options -->
      <div id="vote-form" class="<%= @already_voted ? 'hidden' : '' %> fade-in">

        <% if @vote.email_required? %>
          <div class="mb-4 rounded-2xl p-4" style="background:#ffffff; border:1px solid rgba(30,58,95,0.15); box-shadow:0 2px 12px rgba(30,58,95,0.06);">
            <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Email <span class="text-red-400">*</span></label>
            <input id="voter-email" type="email" placeholder="your@email.com" required
              class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none bg-white">
            <p id="email-error" class="hidden mt-1.5 text-[12px] text-red-500"><%= t("participate.vote.email_error") %></p>
          </div>
        <% end %>

        <%# ── Single / Multiple choice ── %>
        <% if @vote.single_choice? || @vote.multiple_choice? %>
          <div class="space-y-3" id="options-list">
            <% @options.each do |option| %>
              <% _desc = render_vote_desc(option.description) %>
              <% _has_img = option.image.attached? %>
              <div data-id="<%= option.id %>"
                class="option-btn rounded-2xl border-2 cursor-pointer"
                style="background:#ffffff; border-color:#e2e8f0; box-shadow:0 2px 12px rgba(0,0,0,0.04);"
                onclick="selectOption(this)">

                <%# ── Radio / label row ── %>
                <div class="flex items-center gap-3 px-4 pt-4 <%= (_desc || _has_img) ? 'pb-2' : 'pb-4' %>">
                  <% if @vote.multiple_choice? %>
                    <span class="radio-dot flex-shrink-0 w-5 h-5 rounded-md border-2 border-slate-300 flex items-center justify-center transition-all">
                      <span class="text-white text-[11px] font-black opacity-0 transition-opacity duration-150">✓</span>
                    </span>
                  <% else %>
                    <span class="radio-dot flex-shrink-0 w-5 h-5 rounded-full border-2 border-slate-300 flex items-center justify-center transition-all">
                      <span class="w-2.5 h-2.5 rounded-full bg-indigo-500 scale-0 transition-transform duration-200"></span>
                    </span>
                  <% end %>
                  <span class="text-[15px] font-semibold text-slate-800 leading-snug"><%= option.label %></span>
                </div>

                <%# ── Image + Description row ── %>
                <% if _has_img || _desc %>
                  <div class="flex items-start gap-3 px-4 pb-4 border-t border-slate-100 pt-3" onclick="event.stopPropagation()">
                    <% if _has_img %>
                      <img src="<%= url_for(option.image) %>"
                        class="flex-shrink-0 rounded-xl object-contain bg-slate-50"
                        style="width:clamp(48px,12vw,80px); height:clamp(48px,12vw,80px);"
                        alt="">
                    <% end %>
                    <% if _desc %>
                      <div class="flex-1 min-w-0">
                        <div class="option-desc-html desc-collapsed"><%= _desc %></div>
                        <button type="button" class="desc-toggle-btn" onclick="toggleDesc(this)">
                          <span class="desc-label"><%= I18n.locale == :vi ? "Xem thêm" : "Show more" %></span>
                          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="2,4 6,8 10,4"/>
                          </svg>
                        </button>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
          <div id="submit-wrap" class="mt-4 hidden">
            <button onclick="submitVote()" class="w-full py-3 text-[14px] font-semibold text-white rounded-lg transition-all hover:opacity-90 hover:-translate-y-0.5" style="background:#1e3a5f;"><%= t("participate.vote.vote_btn") %></button>
          </div>

        <%# ── Ranking ── %>
        <% elsif @vote.ranking? %>
          <p class="text-[12px] text-slate-500 mb-3 text-center"><%= t("participate.vote.ranking_hint") %></p>
          <div id="ranking-list" class="space-y-2">
            <% @options.each_with_index do |opt, i| %>
              <div class="ranking-item flex items-center gap-3 px-4 py-3.5 rounded-2xl border-2 border-slate-200 bg-white select-none"
                   data-id="<%= opt.id %>" draggable="true"
                   style="box-shadow:0 2px 8px rgba(0,0,0,0.04); cursor:grab;">
                <span class="rank-num w-7 h-7 rounded-full text-[12px] font-black flex items-center justify-center flex-shrink-0 text-white" style="background:linear-gradient(135deg,#1e3a5f,#2d5f8a);"><%= i + 1 %></span>
                <svg class="w-4 h-4 text-slate-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M7 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm6 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zM7 8a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm6 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-6 6a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm6 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/>
                </svg>
                <span class="text-[15px] font-semibold text-slate-800 flex-1"><%= opt.label %></span>
                <div class="flex flex-col gap-0.5">
                  <button type="button" onclick="rankMove(this,-1)" class="w-6 h-6 flex items-center justify-center rounded hover:bg-slate-100 text-slate-400 hover:text-slate-700 border-0 bg-transparent cursor-pointer text-[13px]">↑</button>
                  <button type="button" onclick="rankMove(this,1)"  class="w-6 h-6 flex items-center justify-center rounded hover:bg-slate-100 text-slate-400 hover:text-slate-700 border-0 bg-transparent cursor-pointer text-[13px]">↓</button>
                </div>
              </div>
            <% end %>
          </div>
          <div class="mt-4">
            <button onclick="submitVote()" class="w-full py-3 text-[14px] font-semibold text-white rounded-lg transition-all hover:opacity-90 hover:-translate-y-0.5" style="background:#1e3a5f;"><%= t("participate.vote.ranking_btn") %></button>
          </div>

        <%# ── Word Cloud ── %>
        <% elsif @vote.word_cloud? %>
          <div class="rounded-2xl p-5" style="background:#ffffff; border:2px solid #e2e8f0;">
            <label class="block text-[12px] font-semibold text-slate-600 mb-2"><%= t("participate.vote.word_cloud_label") %></label>
            <input id="wc-input" type="text" maxlength="40" placeholder="<%= t("participate.vote.word_cloud_placeholder") %>"
              oninput="document.getElementById('wc-count').textContent=this.value.length"
              class="w-full px-4 py-3 border border-slate-200 rounded-xl text-[15px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none bg-white">
            <p class="text-[11px] text-slate-400 mt-1.5 text-right"><span id="wc-count">0</span>/40</p>
          </div>
          <div class="mt-3">
            <button onclick="submitVote()" class="w-full py-3 text-[14px] font-semibold text-white rounded-lg transition-all hover:opacity-90 hover:-translate-y-0.5" style="background:#1e3a5f;"><%= t("participate.vote.send_btn") %></button>
          </div>

        <%# ── Open Ended ── %>
        <% elsif @vote.open_ended? %>
          <div class="rounded-2xl p-5" style="background:#ffffff; border:2px solid #e2e8f0;">
            <label class="block text-[12px] font-semibold text-slate-600 mb-2"><%= t("participate.vote.open_ended_label") %></label>
            <textarea id="oe-input" rows="4" placeholder="<%= t("participate.vote.open_ended_placeholder") %>"
              class="w-full px-4 py-3 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none bg-white resize-none"></textarea>
          </div>
          <div class="mt-3">
            <button onclick="submitVote()" class="w-full py-3 text-[14px] font-semibold text-white rounded-lg transition-all hover:opacity-90 hover:-translate-y-0.5" style="background:#1e3a5f;"><%= t("participate.vote.send_btn") %></button>
          </div>

        <%# ── Q&A Upvote ── %>
        <% elsif @vote.qa_upvote? %>
          <div class="rounded-2xl p-5 mb-3" style="background:#ffffff; border:2px solid #e2e8f0;">
            <label class="block text-[12px] font-semibold text-slate-600 mb-2"><%= t("participate.vote.qa_label") %></label>
            <textarea id="qa-input" rows="3" placeholder="<%= t("participate.vote.qa_placeholder") %>"
              class="w-full px-4 py-3 border border-slate-200 rounded-xl text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none bg-white resize-none"></textarea>
            <div class="mt-3">
              <button onclick="submitVote()" class="w-full py-3 text-[14px] font-semibold text-white rounded-lg transition-all hover:opacity-90 hover:-translate-y-0.5" style="background:#1e3a5f;"><%= t("participate.vote.qa_btn") %></button>
            </div>
          </div>
        <% end %>
      </div>

    </div>
  </div>

  <!-- Footer -->
  <div class="text-center pb-6">
    <span class="inline-flex items-center gap-1.5"><img src="/vox_logo.svg" alt="VOX" style="height:18px;width:auto;opacity:0.65;"><span style="font-size:11px;color:#94a3b8;">· Survey &amp; Voting Platform</span></span>
  </div>

</div>

<script>
const CSRF = document.querySelector("meta[name=csrf-token]")?.content || "<%= form_authenticity_token %>";
const VOTE_TYPE = "<%= @vote.vote_type %>";
const VOTE_BTN_TEXT = "<%= j t('participate.vote.vote_btn') %>";
const VOTE_SUBMITTING_TEXT = "<%= j t('participate.vote.voting') %>";
const VOTE_ERROR_TEXT = "<%= j t('participate.vote.error_occurred') %>";
let selectedIds = [];
const multipleChoice = <%= @vote.multiple_choice? ? 'true' : 'false' %>;

function toggleDesc(btn) {
  const wrap = btn.previousElementSibling; // .option-desc-html
  const isExpanded = btn.classList.contains('expanded');
  if (isExpanded) {
    wrap.classList.remove('desc-expanded');
    wrap.classList.add('desc-collapsed');
    btn.classList.remove('expanded');
    btn.querySelector('.desc-label').textContent = '<%= I18n.locale == :vi ? "Xem thêm" : "Show more" %>';
  } else {
    wrap.classList.remove('desc-collapsed');
    wrap.classList.add('desc-expanded');
    btn.classList.add('expanded');
    btn.querySelector('.desc-label').textContent = '<%= I18n.locale == :vi ? "Thu gọn" : "Show less" %>';
  }
}

// Hide toggle button if description is short enough to not overflow
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.desc-collapsed').forEach(el => {
    if (el.scrollHeight <= el.clientHeight + 2) {
      const btn = el.nextElementSibling;
      if (btn && btn.classList.contains('desc-toggle-btn')) btn.style.display = 'none';
    }
  });
});

function selectOption(btn) {
  const id = parseInt(btn.dataset.id);
  if (multipleChoice) {
    const idx = selectedIds.indexOf(id);
    if (idx >= 0) { selectedIds.splice(idx, 1); setSelected(btn, false); }
    else           { selectedIds.push(id);        setSelected(btn, true);  }
  } else {
    document.querySelectorAll('.option-btn').forEach(b => setSelected(b, false));
    selectedIds = [id];
    setSelected(btn, true);
  }
  document.getElementById('submit-wrap')?.classList.toggle('hidden', selectedIds.length === 0);
}

function setSelected(btn, on) {
  btn.style.borderColor = on ? '#1e3a5f' : '#e2e8f0';
  btn.style.background  = on ? 'rgba(238,243,249,0.95)' : 'rgba(255,255,255,0.85)';
  btn.style.boxShadow   = on ? '0 4px 16px rgba(30,58,95,0.18)' : '0 2px 12px rgba(0,0,0,0.04)';
  const ring = btn.querySelector('.radio-dot');
  if (!ring) return;
  ring.style.borderColor = on ? '#1e3a5f' : '#cbd5e1';
  if (multipleChoice) {
    ring.style.background = on ? '#1e3a5f' : '';
    const check = ring.querySelector('span');
    if (check) check.style.opacity = on ? '1' : '0';
  } else {
    const dot = ring.querySelector('span');
    if (dot) dot.style.transform = on ? 'scale(1)' : 'scale(0)';
  }
}

// ── Ranking drag-drop ─────────────────────────────────────────────────────────
function updateRankNumbers() {
  document.querySelectorAll('#ranking-list .ranking-item').forEach((el, i) => {
    el.querySelector('.rank-num').textContent = i + 1;
  });
}

function rankMove(btn, dir) {
  const item = btn.closest('.ranking-item');
  const list = item.parentElement;
  if (dir === -1 && item.previousElementSibling) {
    list.insertBefore(item, item.previousElementSibling);
  } else if (dir === 1 && item.nextElementSibling) {
    list.insertBefore(item.nextElementSibling, item);
  }
  updateRankNumbers();
}

(function initDragDrop() {
  let dragged = null;
  document.addEventListener('dragstart', e => {
    if (!e.target.classList.contains('ranking-item')) return;
    dragged = e.target;
    setTimeout(() => e.target.style.opacity = '0.4', 0);
  });
  document.addEventListener('dragend', e => {
    if (dragged) { dragged.style.opacity = '1'; dragged = null; }
    document.querySelectorAll('.ranking-item').forEach(el => el.style.borderColor = '#e2e8f0');
    updateRankNumbers();
  });
  document.addEventListener('dragover', e => {
    e.preventDefault();
    const target = e.target.closest('.ranking-item');
    if (target && target !== dragged) target.style.borderColor = '#1e3a5f';
  });
  document.addEventListener('dragleave', e => {
    const target = e.target.closest('.ranking-item');
    if (target) target.style.borderColor = '#e2e8f0';
  });
  document.addEventListener('drop', e => {
    e.preventDefault();
    const target = e.target.closest('.ranking-item');
    if (target && dragged && target !== dragged) {
      const list = target.parentElement;
      const items = [...list.children];
      const dragIdx = items.indexOf(dragged);
      const targetIdx = items.indexOf(target);
      list.insertBefore(dragged, dragIdx < targetIdx ? target.nextSibling : target);
    }
  });
})();

// ── Device Fingerprint (browser-agnostic) ────────────────────────────────────
// Goal: same physical device → same hash, regardless of which browser is used.
// On iOS all browsers use WebKit so canvas/WebGL output is identical across
// Chrome, Safari, Firefox — we exploit that instead of using userAgent.
async function getBrowserFingerprint() {
  const components = [];

  // 1. Screen — device hardware, same across all browsers on same device
  components.push([screen.width, screen.height, screen.colorDepth, window.devicePixelRatio || 1].join('x'));

  // 2. Timezone
  components.push(Intl.DateTimeFormat().resolvedOptions().timeZone || '');

  // 3. Language (device setting, not browser)
  components.push(navigator.language || '');

  // 4. Hardware — CPU cores and touch capability
  components.push(navigator.hardwareConcurrency || 0);
  components.push(navigator.maxTouchPoints || 0);

  // 5. Device memory (if available — rounds to nearest power of 2)
  components.push(navigator.deviceMemory || 0);

  // 6. Canvas fingerprint — GPU renders text/shapes uniquely per physical device.
  //    On iOS, Chrome & Safari both use WebKit → identical output on same device.
  try {
    const canvas = document.createElement('canvas');
    canvas.width = 240; canvas.height = 60;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = '#f0f';
    ctx.fillRect(0, 0, 10, 10);
    ctx.fillStyle = 'rgba(0,200,150,0.7)';
    ctx.font = 'bold 15px Arial';
    ctx.fillText('VOX device fp \u{1F3B5}', 12, 32);
    ctx.strokeStyle = '#ff0';
    ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.arc(90, 30, 18, 0, Math.PI * 2); ctx.stroke();
    ctx.fillStyle = 'rgba(30,58,95,0.5)';
    ctx.font = '11px sans-serif';
    ctx.fillText('中文 عربي', 120, 50);
    components.push(canvas.toDataURL());
  } catch(e) { components.push('canvas-err'); }

  // 7. WebGL GPU renderer — hardware string, same across browsers on same device
  try {
    const gl = document.createElement('canvas').getContext('webgl') ||
               document.createElement('canvas').getContext('experimental-webgl');
    if (gl) {
      const ext = gl.getExtension('WEBGL_debug_renderer_info');
      const renderer = ext ? gl.getParameter(ext.UNMASKED_RENDERER_WEBGL) : '';
      const vendor   = ext ? gl.getParameter(ext.UNMASKED_VENDOR_WEBGL)   : '';
      components.push(renderer + '|' + vendor);
    } else { components.push('no-webgl'); }
  } catch(e) { components.push('webgl-err'); }

  // 8. Audio context fingerprint — oscillator output varies per hardware
  try {
    const AudioCtx = window.OfflineAudioContext || window.webkitOfflineAudioContext;
    if (AudioCtx) {
      const ctx = new AudioCtx(1, 44100, 44100);
      const osc = ctx.createOscillator();
      const cmp = ctx.createDynamicsCompressor();
      osc.type = 'triangle';
      osc.frequency.value = 10000;
      osc.connect(cmp); cmp.connect(ctx.destination);
      osc.start(0);
      const buf = await ctx.startRendering();
      const data = buf.getChannelData(0);
      let sum = 0;
      for (let i = 0; i < 500; i++) sum += Math.abs(data[i]);
      components.push(sum.toFixed(10));
    }
  } catch(e) { /* audio not available */ }

  // SHA-256 → 64-char hex (browser-agnostic device ID)
  const raw = components.join('||');
  try {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(raw));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('').slice(0, 64);
  } catch(e) {
    let h = 5381;
    for (let i = 0; i < raw.length; i++) h = ((h << 5) + h) ^ raw.charCodeAt(i);
    return Math.abs(h).toString(16).padStart(8, '0');
  }
}

async function submitVote() {
  // Email validation
  const emailRequired = <%= @vote.email_required? ? 'true' : 'false' %>;
  let respondentEmail = null;
  if (emailRequired) {
    respondentEmail = document.getElementById('voter-email')?.value?.trim();
    if (!respondentEmail || !respondentEmail.includes('@')) {
      document.getElementById('email-error')?.classList.remove('hidden');
      document.getElementById('voter-email')?.focus();
      return;
    }
    document.getElementById('email-error')?.classList.add('hidden');
  }

  // Build payload by vote type
  const payload = {};
  if (respondentEmail) payload.respondent_email = respondentEmail;

  if (VOTE_TYPE === 'ranking') {
    payload.ranking_order = [...document.querySelectorAll('#ranking-list .ranking-item')].map(el => parseInt(el.dataset.id));
  } else if (VOTE_TYPE === 'word_cloud') {
    const val = document.getElementById('wc-input')?.value?.trim();
    if (!val) { document.getElementById('wc-input')?.focus(); return; }
    payload.text_value = val;
  } else if (VOTE_TYPE === 'open_ended') {
    const val = document.getElementById('oe-input')?.value?.trim();
    if (!val) { document.getElementById('oe-input')?.focus(); return; }
    payload.text_value = val;
  } else if (VOTE_TYPE === 'qa_upvote') {
    const val = document.getElementById('qa-input')?.value?.trim();
    if (!val) { document.getElementById('qa-input')?.focus(); return; }
    payload.text_value = val;
  } else {
    if (selectedIds.length === 0) return;
    payload.option_ids = selectedIds;
  }

  // Attach fingerprint
  payload.fingerprint = await getBrowserFingerprint();

  // Disable all submit buttons
  document.querySelectorAll('#vote-form button[onclick="submitVote()"]').forEach(b => { b.disabled = true; b.textContent = VOTE_SUBMITTING_TEXT; });

  const res  = await fetch("/v/<%= @vote.slug %>/submit", {
    method: "POST",
    headers: { "Content-Type": "application/json", "X-CSRF-Token": CSRF },
    body: JSON.stringify(payload)
  });

  if (res.status === 429) {
    document.querySelectorAll('#vote-form button[onclick="submitVote()"]').forEach(b => { b.disabled = false; b.textContent = VOTE_BTN_TEXT; });
    showRateLimitBanner(res.headers.get('Retry-After') || '60');
    return;
  }

  const data = await res.json();
  if (res.ok) {
    showAlreadyVoted(false);
  } else if (data.error === 'already_voted') {
    showAlreadyVoted(true);
  } else {
    document.querySelectorAll('#vote-form button[onclick="submitVote()"]').forEach(b => { b.disabled = false; b.textContent = VOTE_BTN_TEXT; });
    showRateLimitBanner(null, data.message || VOTE_ERROR_TEXT);
  }
}

function showRateLimitBanner(retryAfter, staticMsg) {
  const btns = () => document.querySelectorAll('#vote-form button[onclick="submitVote()"]');

  if (staticMsg) {
    let banner = document.getElementById('vote-rate-banner');
    if (!banner) {
      banner = document.createElement('div');
      banner.id = 'vote-rate-banner';
      banner.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;background:#1e293b;color:#fff;padding:12px 20px;border-radius:12px;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.3);display:flex;align-items:center;gap:10px;white-space:nowrap;';
      document.body.appendChild(banner);
    }
    banner.textContent = '⚠️ ' + staticMsg;
    setTimeout(() => banner.remove(), 4000);
    return;
  }

  // If already counting down, ignore
  if (window._voteRateLimitActive) return;
  window._voteRateLimitActive = true;

  // Disable all submit buttons for the entire cooldown
  btns().forEach(b => { b.disabled = true; b.textContent = VOTE_SUBMITTING_TEXT; });

  let banner = document.getElementById('vote-rate-banner');
  if (!banner) {
    banner = document.createElement('div');
    banner.id = 'vote-rate-banner';
    banner.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;background:#1e293b;color:#fff;padding:12px 20px;border-radius:12px;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.3);display:flex;align-items:center;gap:10px;white-space:nowrap;';
    document.body.appendChild(banner);
  }

  let secs = parseInt(retryAfter) || 60;
  const tick = () => {
    banner.innerHTML = `⏱ Quá nhiều yêu cầu — thử lại sau <span style="font-variant-numeric:tabular-nums;min-width:28px;display:inline-block;">${secs}s</span>`;
    if (secs <= 0) {
      banner.remove();
      window._voteRateLimitActive = false;
      btns().forEach(b => { b.disabled = false; b.textContent = VOTE_BTN_TEXT; });
      return;
    }
    secs--;
    setTimeout(tick, 1000);
  };
  tick();
}

function showAlreadyVoted(isDuplicate = false) {
  document.getElementById("vote-form").classList.add("hidden");
  const el = document.getElementById("already-voted");
  el.classList.remove("hidden");
  el.classList.add("fade-in");

  if (isDuplicate) {
    // Replace success icon with warning icon to indicate blocked duplicate
    const iconWrap = el.querySelector('.w-16.h-16');
    if (iconWrap) {
      iconWrap.style.background = 'linear-gradient(135deg,#f59e0b,#ef4444)';
      iconWrap.innerHTML = `<svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>`;
    }
    const title = el.querySelector('h2');
    if (title) title.textContent = '<%= I18n.locale == :vi ? "Bạn đã bình chọn rồi" : "Already voted" %>';
    const sub = el.querySelector('p.text-slate-500');
    if (sub) sub.textContent = '<%= I18n.locale == :vi ? "Thiết bị này đã bình chọn cho cuộc bỏ phiếu này." : "This device has already submitted a vote." %>';
    // Show the warning banner (hidden by default when @already_voted is false)
    const banner = el.querySelector('[style*="rgba(245,158,11"]');
    if (banner) banner.style.display = 'flex';
  }
}

// ── Countdown ────────────────────────────────────────────────────────────────
(function() {
  const totalSeconds = <%= @vote.countdown_seconds.to_i %>;
  if (totalSeconds <= 0) return;
  let remaining = <%= @seconds_remaining || 0 %>;
  const textEl = document.getElementById('countdown-text');
  const barEl  = document.getElementById('countdown-bar');

  function fmt(s) {
    return String(Math.floor(s/60)).padStart(2,'0') + ':' + String(s%60).padStart(2,'0');
  }
  function update() {
    if (!textEl) return;
    textEl.textContent = fmt(remaining);
    const isLow = remaining <= totalSeconds * 0.2;
    const color  = isLow ? '#ef4444' : '#1e3a5f';
    textEl.style.color = color;
    if (barEl) { barEl.style.width = (remaining/totalSeconds*100).toFixed(1)+'%'; barEl.style.background = color; }
  }
  update();
  const timer = setInterval(() => {
    remaining--;
    if (remaining <= 0) {
      remaining = 0; update(); clearInterval(timer);
      document.getElementById('vote-form')?.classList.add('hidden');
      document.getElementById('time-up-box')?.classList.remove('hidden');
    } else { update(); }
  }, 1000);
})();

<% unless @already_voted || @vote.allow_multiple_votes? %>
// ── Check voted on page load (fingerprint-based) ─────────────────────────────
// Runs only when server doesn't already know the user voted (different browser/device)
(async function checkVotedOnLoad() {
  try {
    const fp = await getBrowserFingerprint();
    const res = await fetch('<%= check_voted_path(@vote.slug) %>', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF },
      body: JSON.stringify({ fingerprint: fp })
    });
    if (!res.ok) return;
    const data = await res.json();
    if (data.voted) {
      // Device already voted → show blocked screen immediately, before user interacts
      showAlreadyVoted(true);
    }
  } catch(e) { /* network error — fail open, let them try */ }
})();
<% end %>
</script>
