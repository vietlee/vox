<% content_for :title, @vote.title %>

<style>
  @keyframes floatUp {
    0%   { opacity: 1; transform: translateY(0) scale(1); }
    60%  { opacity: 1; transform: translateY(-32px) scale(1.2); }
    100% { opacity: 0; transform: translateY(-56px) scale(0.85); }
  }
  @keyframes barPulse {
    0%   { filter: brightness(1) saturate(1); }
    35%  { filter: brightness(1.6) saturate(1.4); }
    100% { filter: brightness(1) saturate(1); }
  }
  @keyframes countBump {
    0%   { transform: scale(1); }
    35%  { transform: scale(1.5); }
    100% { transform: scale(1); }
  }
  @keyframes rowGlow {
    0%   { box-shadow: none; }
    30%  { box-shadow: 0 0 24px 4px var(--glow-color); }
    100% { box-shadow: none; }
  }
  .plus-one {
    position: absolute;
    right: 10px;
    bottom: 6px;
    font-size: 16px;
    font-weight: 900;
    color: #fff;
    text-shadow: 0 0 12px rgba(255,255,255,0.9);
    pointer-events: none;
    z-index: 50;
    animation: floatUp 3s ease-out forwards;
  }
  .bar-pulse  { animation: barPulse 0.7s ease-out; }
  .count-bump { animation: countBump 0.45s cubic-bezier(.36,.07,.19,.97); }
  .row-glow   { animation: rowGlow 0.8s ease-out; }

  .option-bar {
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
  }
  .option-bar::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(180deg, rgba(255,255,255,0.18) 0%, rgba(255,255,255,0) 60%);
    pointer-events: none;
  }
</style>

<%
  option_colors = [
    { grad: 'from-cyan-400 to-blue-500',     glow: 'rgba(34,211,238,0.5)',   shadow: '#22d3ee' },
    { grad: 'from-violet-500 to-purple-600', glow: 'rgba(167,139,250,0.5)',  shadow: '#a78bfa' },
    { grad: 'from-rose-400 to-pink-600',     glow: 'rgba(251,113,133,0.5)', shadow: '#fb7185' },
    { grad: 'from-amber-400 to-orange-500',  glow: 'rgba(251,191,36,0.5)',  shadow: '#fbbf24' },
    { grad: 'from-emerald-400 to-teal-500',  glow: 'rgba(52,211,153,0.5)',  shadow: '#34d399' },
    { grad: 'from-sky-400 to-indigo-500',    glow: 'rgba(56,189,248,0.5)',  shadow: '#38bdf8' },
  ]
%>

<div class="min-h-screen text-white flex flex-col p-8 p-10" id="presenter-view"
     data-vote-id="<%= @vote.id %>"
     style="background: radial-gradient(ellipse at 20% 20%, #1e1b4b 0%, #0f172a 50%, #0a0f1e 100%);">

  <!-- Header -->
  <div class="flex items-center justify-between mb-10">
    <%= link_to root_path, class: "text-[22px] font-black tracking-tight", style: "background: linear-gradient(135deg,#818cf8,#c084fc); -webkit-background-clip:text; -webkit-text-fill-color:transparent; text-decoration:none;" do %>VOX<% end %>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2 px-4 py-2 rounded-full text-[13px] font-semibold text-emerald-300" style="background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.25);">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
        <span id="participant-count"><%= @vote.participant_count %></span>&nbsp;participants
      </div>
      <% if @vote.active? && !@readonly %>
        <button id="close-btn" class="px-5 py-2 text-[13px] font-bold rounded-full text-white" style="background:linear-gradient(135deg,#dc2626,#b91c1c); box-shadow:0 4px 14px rgba(220,38,38,0.4);">Close Vote</button>
      <% end %>
    </div>
  </div>

  <!-- Question -->
  <div class="text-center mb-12">
    <h1 class="text-[40px] font-extrabold leading-tight tracking-tight text-white" style="text-shadow:0 2px 32px rgba(129,140,248,0.25);"><%= @vote.title %></h1>
    <% if @vote.seconds_remaining %>
      <div class="mt-4 flex justify-center">
        <div id="countdown-ring" class="relative w-28 h-28">
          <svg class="w-28 h-28 -rotate-90" viewBox="0 0 112 112">
            <circle cx="56" cy="56" r="48" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="7"/>
            <circle id="countdown-arc" cx="56" cy="56" r="48" fill="none" stroke="#818cf8" stroke-width="7"
              stroke-linecap="round"
              stroke-dasharray="<%= (2 * Math::PI * 48).round(2) %>"
              stroke-dashoffset="0"
              style="transition: stroke-dashoffset 1s linear, stroke 0.5s;"/>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span id="countdown-text" class="text-[18px] font-black text-white tabular-nums">
              <%= format("%02d:%02d", (@vote.seconds_remaining || 0) / 60, (@vote.seconds_remaining || 0) % 60) %>
            </span>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Results -->
  <% sorted = @vote.results_by_option.sort_by { |r| -r[:count] }
     max_count = [sorted.first&.dig(:count).to_i, 1].max %>
  <div id="vote-results" class="flex-1 max-w-4xl mx-auto w-full flex flex-col justify-center gap-4">
    <% @vote.results_by_option.each_with_index do |result, i| %>
      <% color = option_colors[i % option_colors.size]
         is_leading = result[:count] == max_count && result[:count] > 0 %>
      <div class="vote-option-row" data-option-id="<%= result[:id] %>" data-count="<%= result[:count] %>"
           style="position:relative; --glow-color:<%= color[:glow] %>; display:grid; grid-template-columns:32px 1fr; grid-template-rows:auto auto; column-gap:12px; align-items:center;">

        <!-- Rank dot — spans both rows, centered vertically -->
        <div class="row-span-2 self-center justify-self-center w-8 h-8 rounded-full flex items-center justify-center text-[12px] font-black"
             style="background:<%= is_leading ? color[:glow] : 'rgba(255,255,255,0.07)' %>; color:<%= is_leading ? '#fff' : 'rgba(255,255,255,0.35)' %>;">
          <%= i + 1 %>
        </div>

        <!-- Label + stats -->
        <div class="flex items-center gap-4 pb-2">
          <span class="text-[16px] font-bold text-slate-200 flex-1 leading-tight"><%= result[:label] %></span>
          <div class="flex items-center gap-4 flex-shrink-0">
            <span class="text-[13px] text-slate-500 option-count-label tabular-nums"><%= result[:count] %> votes</span>
            <span class="text-[24px] font-black tabular-nums option-pct" style="color:<%= color[:shadow] %>; min-width:4.5rem; text-align:right;"><%= result[:percentage] %>%</span>
          </div>
        </div>

        <!-- Bar track -->
        <div class="relative" style="height:10px; background:rgba(255,255,255,0.06); border-radius:99px;">
          <div class="option-bar absolute inset-y-0 left-0 rounded-full transition-all duration-700"
               style="width:<%= [result[:percentage].to_f, result[:percentage].to_f > 0 ? 2 : 0].max %>%;
                      background:<%= "linear-gradient(90deg, #{color[:shadow]}cc, #{color[:shadow]})" %>;
                      box-shadow: 0 0 12px 1px <%= color[:glow] %>;"></div>
          <div class="option-count absolute top-1/2 -translate-y-1/2 -translate-x-1/2 px-2 py-0.5 rounded-full text-[10px] font-black text-white transition-all duration-700"
               style="left:<%= [result[:percentage].to_f, result[:percentage].to_f > 0 ? 2 : 0].max %>%;
                      background:<%= color[:shadow] %>;
                      box-shadow:0 2px 8px <%= color[:glow] %>;
                      display:<%= result[:count] > 0 ? 'block' : 'none' %>;">
            <%= result[:count] %>
          </div>
        </div>

      </div>
    <% end %>
  </div>

  <!-- QR Code -->
  <div class="text-center mt-10">
    <% if @vote.qr_code&.token %>
      <div class="inline-block bg-white p-3 rounded-2xl" style="box-shadow:0 0 32px rgba(129,140,248,0.2);">
        <img src="/qr/<%= @vote.qr_code.token %>/image" alt="QR" class="w-28 h-28">
      </div>
    <% end %>
    <p class="text-[12px] text-slate-500 mt-3 tracking-wide uppercase">Scan to vote</p>
  </div>

  <!-- AI Insight -->
  <div id="ai-insight-box" class="hidden mt-8 rounded-2xl p-6 text-center max-w-2xl mx-auto" style="background:linear-gradient(135deg,rgba(109,40,217,0.2),rgba(67,56,202,0.2)); border:1px solid rgba(167,139,250,0.25); backdrop-filter:blur(12px);">
    <div class="text-[12px] font-bold tracking-widest uppercase text-violet-400 mb-3">AI Insight</div>
    <p id="ai-insight-text" class="text-[16px] text-slate-200 leading-relaxed"></p>
  </div>
</div>

<script type="module">
import { createConsumer } from "@rails/actioncable";

const voteId   = document.getElementById('presenter-view').dataset.voteId;
const voteSlug = "<%= @vote.slug %>";
const csrf     = document.querySelector('meta[name="csrf-token"]')?.content;

const GLOW_COLORS = <%= raw option_colors.map { |c| c[:shadow] }.to_json %>;

const consumer = createConsumer();
let cableConnected = false;

consumer.subscriptions.create({ channel: "VoteChannel", vote_id: voteId }, {
  connected()    { cableConnected = true; },
  disconnected() { cableConnected = false; },
  received(data) {
    if (data.type === 'new_vote') {
      updateResults(data.options, data.participant_count);
    } else if (data.type === 'ai_insight') {
      showInsight(data.insight);
    } else if (data.type === 'status_change' && data.status === 'closed') {
      document.getElementById('close-btn')?.remove();
    }
  }
});

let lastCount = <%= @vote.participant_count %>;

async function pollResults() {
  try {
    const res = await fetch(`/v/${voteSlug}/results.json`, { headers: { Accept: 'application/json' } });
    if (!res.ok) return;
    const data = await res.json();
    if (data.participant_count !== lastCount) {
      lastCount = data.participant_count;
      updateResults(data.results, data.participant_count);
    }
  } catch(e) {}
}
setInterval(pollResults, 1500);

function updateResults(options, count) {
  document.getElementById('participant-count').textContent = count;

  options.forEach((opt, idx) => {
    const id     = opt.id         ?? opt['id'];
    const pct    = opt.percentage ?? opt['percentage'];
    const newCnt = opt.count      ?? opt['count'];
    const row    = document.querySelector(`[data-option-id="${id}"]`);
    if (!row) return;

    const prevCnt = parseInt(row.dataset.count ?? '0', 10);
    const gained  = newCnt - prevCnt;
    row.dataset.count = newCnt;

    row.querySelector('.option-pct').textContent        = pct + '%';
    row.querySelector('.option-count-label').textContent = newCnt + ' votes';

    const countEl = row.querySelector('.option-count');
    countEl.textContent = newCnt;
    countEl.style.display = newCnt > 0 ? 'block' : 'none';

    const w = Math.max(pct, pct > 0 ? 2 : 0) + '%';
    const bar = row.querySelector('.option-bar');
    bar.style.width = w;
    countEl.style.left = w;

    if (gained > 0) {
      // +N floating badge
      const badge = document.createElement('span');
      badge.className = 'plus-one';
      badge.textContent = '+' + gained;
      row.appendChild(badge);
      setTimeout(() => badge.remove(), 3100);

      // bar flash
      bar.classList.remove('bar-pulse');
      void bar.offsetWidth;
      bar.classList.add('bar-pulse');
      bar.addEventListener('animationend', () => bar.classList.remove('bar-pulse'), { once: true });

      // count bump
      countEl.classList.remove('count-bump');
      void countEl.offsetWidth;
      countEl.classList.add('count-bump');
      countEl.addEventListener('animationend', () => countEl.classList.remove('count-bump'), { once: true });

      // row glow
      row.classList.remove('row-glow');
      void row.offsetWidth;
      row.classList.add('row-glow');
      row.addEventListener('animationend', () => row.classList.remove('row-glow'), { once: true });
    }
  });
}

function showInsight(text) {
  const box = document.getElementById('ai-insight-box');
  document.getElementById('ai-insight-text').textContent = text;
  box.classList.remove('hidden');
}

async function closeVote() {
  const res = await fetch('<%= close_vote_path(@vote) %>', {
    method: 'PATCH',
    headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json' }
  });
  if (res.ok) document.getElementById('close-btn')?.remove();
}

document.getElementById('close-btn')?.addEventListener('click', closeVote);

// ── Countdown ──────────────────────────────────────────────────────────────
(function() {
  const totalSeconds = <%= @vote.countdown_seconds.to_i %>;
  if (totalSeconds <= 0) return;

  let remaining = <%= @vote.seconds_remaining || 0 %>;
  const textEl = document.getElementById('countdown-text');
  const arcEl  = document.getElementById('countdown-arc');
  const circumference = 2 * Math.PI * 48;

  function fmt(s) {
    const m = Math.floor(s / 60).toString().padStart(2, '0');
    const sec = (s % 60).toString().padStart(2, '0');
    return `${m}:${sec}`;
  }

  function updateRing() {
    if (!textEl || !arcEl) return;
    textEl.textContent = fmt(remaining);
    const pct = remaining / totalSeconds;
    arcEl.style.strokeDashoffset = circumference * (1 - pct);
    if (pct > 0.5)      arcEl.style.stroke = '#818cf8';
    else if (pct > 0.2) arcEl.style.stroke = '#f59e0b';
    else                arcEl.style.stroke = '#ef4444';
  }

  updateRing();

  const timer = setInterval(() => {
    remaining--;
    if (remaining <= 0) {
      remaining = 0;
      updateRing();
      clearInterval(timer);
      closeVote();
    } else {
      updateRing();
    }
  }, 1000);
})();
</script>
