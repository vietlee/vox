<% content_for :title, @vote.title %>

<style>
  @keyframes floatUp {
    0%   { opacity:1; transform:translateY(0) scale(1); }
    60%  { opacity:1; transform:translateY(-32px) scale(1.2); }
    100% { opacity:0; transform:translateY(-56px) scale(0.85); }
  }
  @keyframes barPulse {
    0%   { filter:brightness(1) saturate(1); }
    35%  { filter:brightness(1.6) saturate(1.4); }
    100% { filter:brightness(1) saturate(1); }
  }
  @keyframes countBump {
    0%   { transform:scale(1); }
    35%  { transform:scale(1.5); }
    100% { transform:scale(1); }
  }
  @keyframes rowGlow {
    0%   { box-shadow:none; }
    30%  { box-shadow:0 0 24px 4px var(--glow-color); }
    100% { box-shadow:none; }
  }
  @keyframes timeUpSlide {
    from { opacity:0; transform:translateY(-20px) scale(0.96); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }
  @keyframes rankingSlideIn {
    from { opacity:0; transform:translateY(60px) scale(0.97); }
    to   { opacity:1; transform:translateY(0) scale(1); }
  }
  @keyframes medalDrop {
    0%   { opacity:0; transform:translateY(-40px) rotate(-8deg) scale(0.7); }
    60%  { opacity:1; transform:translateY(6px) rotate(3deg) scale(1.1); }
    80%  { transform:translateY(-3px) rotate(-1deg) scale(0.97); }
    100% { opacity:1; transform:translateY(0) rotate(0) scale(1); }
  }
  @keyframes podiumRise {
    from { opacity:0; transform:scaleY(0); transform-origin:bottom; }
    to   { opacity:1; transform:scaleY(1); transform-origin:bottom; }
  }
  @keyframes countUp {
    from { opacity:0; transform:scale(0.5); }
    to   { opacity:1; transform:scale(1); }
  }
  @keyframes pulse-ring {
    0%   { box-shadow:0 0 0 0 rgba(239,68,68,0.5); }
    70%  { box-shadow:0 0 0 16px rgba(239,68,68,0); }
    100% { box-shadow:0 0 0 0 rgba(239,68,68,0); }
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
  @keyframes rankLoadPulse {
    0%,100% { opacity:0.6; } 50% { opacity:1; }
  }
  .plus-one {
    position:absolute; right:4px; bottom:50%;
    font-size: clamp(22px, 5vw, 36px); font-weight:900; color:#fff;
    text-shadow:0 0 20px rgba(255,255,255,0.95), 0 2px 12px rgba(0,0,0,0.5);
    pointer-events:none; z-index:50;
    animation:floatUp 3s ease-out forwards;
  }
  .bar-pulse  { animation:barPulse 0.7s ease-out; }
  .count-bump { animation:countBump 0.45s cubic-bezier(.36,.07,.19,.97); }
  .row-glow   { animation:rowGlow 0.8s ease-out; }
  .option-bar {
    transition:width 0.6s cubic-bezier(0.4,0,0.2,1);
    position:relative;
  }
  .option-bar::after {
    content:''; position:absolute; inset:0; border-radius:inherit;
    background:linear-gradient(180deg,rgba(255,255,255,0.18) 0%,rgba(255,255,255,0) 60%);
    pointer-events:none;
  }

  /* ── Rich description on dark presenter background ── */
  .present-desc-html {
    font-size: clamp(10px, 2vw, 12px);
    color: rgba(148, 163, 184, 0.85);
    line-height: 1.5;
    margin-top: 3px;
  }
  .present-desc-html p { margin: 0; }
  .present-desc-html ul, .present-desc-html ol { padding-left: 0; margin: 1px 0; list-style: none; }
  .present-desc-html ul li::before { content: '·'; margin-right: 5px; opacity: 0.5; }
  .present-desc-html ol { counter-reset: pdesc-ol; }
  .present-desc-html ol li { counter-increment: pdesc-ol; }
  .present-desc-html ol li::before { content: counter(pdesc-ol) '.'; margin-right: 5px; opacity: 0.5; }
  .present-desc-html li { margin: 0; }
  .present-desc-html strong { color: rgba(203, 213, 225, 0.9); font-weight: 700; }
  .present-desc-html em { font-style: italic; }
  /* Strip all inline colors — dark bg makes them unreadable */
  .present-desc-html span { color: inherit !important; background: none !important; }

  /* ── Collapsible description (present page) ── */
  .pdesc-collapsed {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pdesc-expanded { display: block; }
  .pdesc-toggle {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    margin-top: 4px;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-size: clamp(9px, 1.6vw, 11px);
    font-weight: 600;
    color: rgba(148, 163, 184, 0.6);
    line-height: 1;
  }
  .pdesc-toggle:hover { color: rgba(148, 163, 184, 1); }
  .pdesc-toggle svg { transition: transform 0.2s; }
  .pdesc-toggle.expanded svg { transform: rotate(180deg); }

  /* Hide scrollbar on ranking screen while keeping scroll functionality */
  #ranking-screen::-webkit-scrollbar { display: none; }
</style>

<%
  option_colors = [
    { grad: 'from-cyan-400 to-blue-500',     glow: 'rgba(34,211,238,0.5)',   shadow: '#22d3ee' },
    { grad: 'from-violet-500 to-purple-600', glow: 'rgba(167,139,250,0.5)',  shadow: '#4a80a8' },
    { grad: 'from-rose-400 to-pink-600',     glow: 'rgba(251,113,133,0.5)', shadow: '#fb7185' },
    { grad: 'from-amber-400 to-orange-500',  glow: 'rgba(251,191,36,0.5)',  shadow: '#fbbf24' },
    { grad: 'from-emerald-400 to-teal-500',  glow: 'rgba(52,211,153,0.5)',  shadow: '#34d399' },
    { grad: 'from-sky-400 to-indigo-500',    glow: 'rgba(56,189,248,0.5)',  shadow: '#38bdf8' },
  ]
%>

<div class="min-h-screen text-white flex flex-col" id="presenter-view"
     data-vote-id="<%= @vote.id %>"
     style="background:radial-gradient(ellipse at 20% 20%,#1e1b4b 0%,#0f172a 50%,#0a0f1e 100%);
            padding: clamp(14px, 4vw, 40px);">

  <!-- ── Header: logo left · controls right ────────────────────────────── -->
  <div class="flex items-center justify-between gap-3 mb-5 sm:mb-6">
    <!-- Left: logo -->
    <%= link_to root_path do %>
      <img src="/vox_logo.svg" alt="VOX" style="height: clamp(20px, 3.5vw, 28px); width:auto;">
    <% end %>

    <!-- Right: countdown (mobile inline) + participant count + close -->
    <div id="header-controls" class="flex items-center gap-2 sm:gap-3">
      <!-- Countdown badge — visible on mobile, hidden on desktop (ring shown below title) -->
      <% if @vote.seconds_remaining %>
        <div id="countdown-inline" class="sm:hidden flex items-center gap-1.5 px-3 py-1.5 rounded-full font-black tabular-nums"
             style="font-size:clamp(11px,3vw,13px); background:rgba(129,140,248,0.15); border:1px solid rgba(129,140,248,0.3); color:#7aaac9;">
          ⏱ <span id="countdown-text-mobile">
            <%= format("%02d:%02d", (@vote.seconds_remaining || 0) / 60, (@vote.seconds_remaining || 0) % 60) %>
          </span>
        </div>
      <% end %>

      <!-- Participant count -->
      <div class="flex items-center gap-1.5 px-3 py-1.5 rounded-full font-semibold text-emerald-300"
           style="font-size:clamp(11px,3vw,13px); background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.25);">
        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse flex-shrink-0"></span>
        <span id="participant-count"><%= @vote.participant_count %></span>
        <span class="hidden sm:inline">participants</span>
      </div>

      <!-- Close button -->
      <% if @vote.active? && !@readonly %>
        <button id="close-btn"
          style="font-size:clamp(11px,3vw,13px); padding: clamp(6px,2vw,8px) clamp(12px,3vw,20px); background:#dc2626; border-radius:999px; font-weight:700; border:none; color:#fff; cursor:pointer;">
          <span class="sm:hidden">✕</span>
          <span class="hidden sm:inline">Close Vote</span>
        </button>
      <% end %>
    </div>
  </div>

  <!-- ── Time's up banner ───────────────────────────────────────────────── -->
  <div id="time-up-banner" class="hidden mb-5">
    <div class="flex items-center justify-center gap-3 px-5 py-3 rounded-2xl mx-auto"
         style="background:linear-gradient(135deg,rgba(220,38,38,0.22),rgba(185,28,28,0.16));
                border:1.5px solid rgba(239,68,68,0.45); max-width:600px;">
      <div class="w-9 h-9 rounded-full flex items-center justify-center flex-shrink-0"
           style="background:rgba(239,68,68,0.25); animation:pulse-ring 1.5s ease-out infinite;">
        <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 24 24">
          <rect x="6" y="6" width="12" height="12" rx="2"/>
        </svg>
      </div>
      <div>
        <p class="font-black text-white" style="font-size:clamp(14px,4vw,20px); line-height:1.2;">
          <%= I18n.locale.to_s == 'vi' ? 'Hết thời gian bầu chọn' : 'Voting session ended' %>
        </p>
        <p class="text-red-300 mt-0.5" style="font-size:clamp(11px,2.5vw,13px);">
          <%= I18n.locale.to_s == 'vi' ? 'Phiên bầu chọn đã dừng · Kết quả bên dưới' : 'The voting session has closed · Results below' %>
        </p>
      </div>
    </div>
  </div>

  <!-- ── Centered main content ────────────────────────────────────────── -->
  <div class="flex-1 flex flex-col justify-center" style="gap: clamp(16px, 4vw, 32px);">

  <!-- ── Title + desktop countdown ring ────────────────────────────────── -->
  <div class="text-center">
    <h1 class="font-extrabold leading-tight tracking-tight text-white"
        style="font-size:clamp(20px,5vw,44px); text-shadow:0 2px 32px rgba(129,140,248,0.25);">
      <%= @vote.title %>
    </h1>

    <!-- Desktop countdown ring (hidden on mobile) -->
    <% if @vote.seconds_remaining %>
      <div class="hidden sm:flex mt-4 justify-center">
        <div id="countdown-ring" class="relative" style="width:112px; height:112px;">
          <svg style="width:112px;height:112px;" class="-rotate-90" viewBox="0 0 112 112">
            <circle cx="56" cy="56" r="48" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="7"/>
            <circle id="countdown-arc" cx="56" cy="56" r="48" fill="none" stroke="#818cf8" stroke-width="7"
              stroke-linecap="round"
              stroke-dasharray="<%= (2 * Math::PI * 48).round(2) %>"
              stroke-dashoffset="0"
              style="transition:stroke-dashoffset 1s linear,stroke 0.5s;"/>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span id="countdown-text" class="text-[18px] font-black text-white tabular-nums">
              <%= format("%02d:%02d", (@vote.seconds_remaining || 0) / 60, (@vote.seconds_remaining || 0) % 60) %>
            </span>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- ── Results ────────────────────────────────────────────────────────── -->
  <% sorted    = @vote.results_by_option.sort_by { |r| -r[:count] }
     max_count = [sorted.first&.dig(:count).to_i, 1].max %>

  <div id="vote-results" class="max-w-4xl mx-auto w-full flex flex-col"
       style="gap: clamp(20px, 4vw, 36px);">
    <% @vote.results_by_option.each_with_index do |result, i| %>
      <% color      = option_colors[i % option_colors.size]
         is_leading = result[:count] == max_count && result[:count] > 0
         bar_pct    = [result[:percentage].to_f, result[:percentage].to_f > 0 ? 2 : 0].max
         # Cap bubble position so it never overflows the right edge
         bubble_left = bar_pct >= 96 ? "calc(100% - clamp(14px,3vw,18px))" : "#{bar_pct}%" %>

      <div class="vote-option-row"
           data-option-id="<%= result[:id] %>"
           data-count="<%= result[:count] %>"
           style="position:relative; --glow-color:<%= color[:glow] %>;
                  display:flex; align-items:stretch;
                  gap:clamp(8px,2vw,12px);">

        <!-- Col 1: Rank dot (bottom-aligned) -->
        <div style="display:flex; align-items:flex-end; flex-shrink:0; padding-bottom:clamp(3px,0.6vw,5px);">
          <div class="rounded-full flex items-center justify-center font-black"
               style="width:clamp(24px,4vw,32px); height:clamp(24px,4vw,32px);
                      font-size:clamp(9px,2vw,12px);
                      background:<%= is_leading ? color[:glow] : 'rgba(255,255,255,0.14)' %>;
                      color:<%= is_leading ? '#fff' : 'rgba(255,255,255,0.65)' %>;">
            <%= i + 1 %>
          </div>
        </div>

        <!-- Col 2: Image (bottom-aligned, only if present) -->
        <% if result[:image_url].present? %>
          <div style="display:flex; align-items:flex-end; flex-shrink:0;">
            <img src="<%= result[:image_url] %>"
                 class="rounded-xl object-cover"
                 style="width:clamp(48px,7vw,80px); height:clamp(48px,7vw,80px);"
                 alt="<%= result[:label] %>">
          </div>
        <% end %>

        <!-- Col 3: label + desc + progress bar -->
        <div style="flex:1; min-width:0; display:flex; flex-direction:column; justify-content:flex-end; gap:clamp(4px,0.8vw,8px);">

          <!-- Label + description -->
          <div class="leading-tight">
            <span class="block font-bold text-slate-200"
                  style="font-size:clamp(14px,3.5vw,18px);"><%= result[:label] %></span>
            <% if result[:description].present? %>
              <% _desc = render_vote_desc(result[:description]) %>
              <% if _desc %>
                <div class="present-desc-html pdesc-collapsed"><%= _desc %></div>
                <button type="button" class="pdesc-toggle" onclick="togglePDesc(this)">
                  <span class="pdesc-label"><%= I18n.locale == :vi ? "Xem thêm" : "Show more" %></span>
                  <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="2,4 6,8 10,4"/>
                  </svg>
                </button>
              <% end %>
            <% end %>
          </div>

          <!-- Bottom: progress bar (always full width, opacity reflects percentage) -->
          <div class="relative" style="height:clamp(14px,3vw,18px); background:rgba(255,255,255,0.06); border-radius:99px;">
            <div class="option-bar absolute inset-y-0 left-0 right-0 rounded-full"
                 style="background:linear-gradient(90deg, <%= color[:shadow] %>cc, <%= color[:shadow] %>);
                        box-shadow:0 0 14px 2px <%= color[:glow] %>;
                        opacity:<%= result[:percentage].to_f > 0 ? [result[:percentage].to_f / 100 * 0.85 + 0.15, 1.0].min.round(2) : 0.12 %>;"></div>
          </div>
        </div><%# /col 3 %>

        <!-- Col 4: votes + percentage — fixed width so col 3 bar is always same length -->
        <div style="display:flex; flex-direction:column; justify-content:flex-end; align-items:flex-end; flex-shrink:0;
                    width:clamp(5rem,11vw,7.5rem); gap:clamp(2px,0.4vw,4px); padding-bottom:clamp(3px,0.6vw,5px);">
          <span class="text-slate-400 option-count-label tabular-nums"
                style="font-size:clamp(13px,2.2vw,16px);">
            <%= result[:count] %> votes
          </span>
          <span class="font-black tabular-nums option-pct"
                style="font-size:clamp(20px,4vw,28px); color:<%= color[:shadow] %>; line-height:1;">
            <%= result[:percentage] %>%
          </span>
        </div><%# /col 4 %>
      </div><%# /vote-option-row %>
    <% end %>
  </div>

  <!-- ── QR Code — centered ─────────────────────────────────────────────── -->
  <% if @vote.qr_code&.token %>
    <div class="text-center">
      <div class="inline-block bg-white rounded-2xl"
           style="padding:clamp(8px,2vw,12px); box-shadow:0 0 32px rgba(129,140,248,0.2);">
        <img src="/qr/<%= @vote.qr_code.token %>/image" alt="QR"
             style="width:clamp(80px,18vw,112px); height:clamp(80px,18vw,112px); display:block;">
      </div>
      <p class="text-slate-500 mt-2 tracking-wide uppercase"
         style="font-size:clamp(9px,2vw,12px);">Scan to vote</p>
    </div>
  <% end %>

  </div><!-- /centered main content -->

</div>

<!-- ══════════════════════════════════════════════════════════════════════
     RANKING SCREEN — full-screen overlay, shown after vote closes
     Only rendered/shown when ranking_enabled? = true
     ══════════════════════════════════════════════════════════════════════ -->
<% if @vote.ranking_enabled? %>

<!-- Loading overlay — shown immediately on close, hidden once ranking screen is ready -->
<div id="ranking-loading"
     style="display:none; position:fixed; inset:0; z-index:99;
            background:radial-gradient(ellipse at 20% 20%,#1e1b4b 0%,#0f172a 50%,#0a0f1e 100%);
            flex-direction:column; align-items:center; justify-content:center; gap:24px;">
  <div style="width:72px; height:72px; border:5px solid rgba(129,140,248,0.18);
              border-top-color:#818cf8; border-radius:50%;
              animation:spin 0.85s linear infinite;"></div>
  <div style="text-align:center;">
    <p style="font-size:clamp(15px,3vw,20px); font-weight:800; color:#7aaac9; margin:0 0 6px;
              animation:rankLoadPulse 1.6s ease-in-out infinite;">
      <%= I18n.locale.to_s == 'vi' ? '🏆 Đang tải bảng xếp hạng…' : '🏆 Loading leaderboard…' %>
    </p>
    <p style="font-size:clamp(12px,2vw,14px); color:rgba(148,163,184,0.55); margin:0;">
      <%= I18n.locale.to_s == 'vi' ? 'Vui lòng đợi trong giây lát' : 'Please wait a moment' %>
    </p>
  </div>
</div>
<div id="ranking-screen"
     class="hidden fixed inset-0 overflow-y-auto"
     style="background:radial-gradient(ellipse at 20% 20%,#1e1b4b 0%,#0f172a 50%,#0a0f1e 100%);
            z-index:100; padding: clamp(20px,4vw,48px);
            scrollbar-width:none; -ms-overflow-style:none;">

  <!-- Header -->
  <div class="text-center mb-8" style="animation:rankingSlideIn 0.6s ease forwards;">
    <div class="text-5xl mb-3">🏆</div>
    <h2 class="font-black text-white tracking-tight"
        style="font-size:clamp(22px,5vw,40px); text-shadow:0 2px 32px rgba(251,191,36,0.3);">
      <%= I18n.locale.to_s == 'vi' ? 'Bảng Xếp Hạng' : 'Leaderboard' %>
    </h2>
    <p class="text-slate-400 mt-1" style="font-size:clamp(13px,2.5vw,16px);"><%= @vote.title %></p>
  </div>

  <!-- Podium — top N positions -->
  <div id="ranking-podium" class="max-w-4xl mx-auto mb-10">
    <!-- Populated by JS -->
  </div>

  <!-- Divider -->
  <div class="max-w-4xl mx-auto mb-6" style="height:1px; background:linear-gradient(90deg,transparent,rgba(129,140,248,0.3),transparent);"></div>

  <!-- All options summary -->
  <div class="max-w-4xl mx-auto mb-8">
    <p class="text-[11px] font-bold tracking-widest uppercase text-slate-500 mb-3">
      <%= I18n.locale.to_s == 'vi' ? 'Tất cả lựa chọn' : 'All options' %>
    </p>
    <div id="ranking-summary" class="space-y-2">
      <!-- Populated by JS -->
    </div>
  </div>


</div>
<% end %>

<script type="module">
import { createConsumer } from "@rails/actioncable";

const voteId   = document.getElementById('presenter-view').dataset.voteId;
const voteSlug = "<%= @vote.slug %>";
const csrf     = document.querySelector('meta[name="csrf-token"]')?.content;

const GLOW_COLORS = <%= raw option_colors.map { |c| c[:shadow] }.to_json %>;

const consumer = createConsumer();
consumer.subscriptions.create({ channel: "VoteChannel", vote_id: voteId }, {
  connected()    {},
  disconnected() {},
  received(data) {
    if (data.type === 'new_vote') {
      updateResults(data.options, data.participant_count);
    } else if (data.type === 'status_change' && data.status === 'active') {
      // Vote just opened — inject close button if we loaded the page before it was activated
      if (!document.getElementById('close-btn')) {
        const controls = document.getElementById('header-controls');
        if (controls) {
          const btn = document.createElement('button');
          btn.id = 'close-btn';
          btn.style.cssText = 'font-size:clamp(11px,3vw,13px);padding:clamp(6px,2vw,8px) clamp(12px,3vw,20px);background:#dc2626;border-radius:999px;font-weight:700;border:none;color:#fff;cursor:pointer;';
          btn.innerHTML = '<span class="sm:hidden">✕</span><span class="hidden sm:inline">Close Vote</span>';
          btn.addEventListener('click', closeVote);
          controls.appendChild(btn);
        }
      }
    } else if (data.type === 'status_change' && data.status === 'closed') {
      freezeCountdown();
      document.getElementById('close-btn')?.remove();
      showTimeUpBanner();
      <% if @vote.ranking_enabled? %>
      showRankingLoading();
      setTimeout(showRankingScreen, 1800);
      <% end %>
    }
  }
});

let lastCount = <%= @vote.participant_count %>;

async function pollResults() {
  try {
    const res = await fetch(`/v/${voteSlug}/results.json`, { headers: { Accept: 'application/json' } });
    if (!res.ok) return;
    const data = await res.json();
    if (data.participant_count !== lastCount) {
      lastCount = data.participant_count;
      updateResults(data.results, data.participant_count);
    }
  } catch(e) {}
}
setInterval(pollResults, 1500);

function updateResults(options, count) {
  document.getElementById('participant-count').textContent = count;
  options.forEach(opt => {
    const id     = opt.id ?? opt['id'];
    const pct    = opt.percentage ?? opt['percentage'];
    const newCnt = opt.count ?? opt['count'];
    const row    = document.querySelector(`[data-option-id="${id}"]`);
    if (!row) return;

    const prevCnt = parseInt(row.dataset.count ?? '0', 10);
    const gained  = newCnt - prevCnt;
    row.dataset.count = newCnt;

    row.querySelector('.option-pct').textContent         = pct + '%';
    row.querySelector('.option-count-label').textContent = newCnt + ' votes';

    const bar = row.querySelector('.option-bar');
    bar.style.opacity = pct > 0 ? Math.min(pct / 100 * 0.85 + 0.15, 1.0).toFixed(2) : '0.12';

    if (gained > 0) {
      const badge = document.createElement('span');
      badge.className   = 'plus-one';
      badge.textContent = '+' + gained;
      row.appendChild(badge);
      setTimeout(() => badge.remove(), 3100);

      bar.classList.remove('bar-pulse');
      void bar.offsetWidth;
      bar.classList.add('bar-pulse');
      bar.addEventListener('animationend', () => bar.classList.remove('bar-pulse'), { once: true });

      row.classList.remove('row-glow');
      void row.offsetWidth;
      row.classList.add('row-glow');
      row.addEventListener('animationend', () => row.classList.remove('row-glow'), { once: true });
    }
  });
}


function freezeCountdown() {
  if (_countdownTimer) { clearInterval(_countdownTimer); _countdownTimer = null; }
  // Zero out the display so it doesn't show a frozen mid-count number
  const arcEl    = document.getElementById('countdown-arc');
  const textEl   = document.getElementById('countdown-text');
  const mobileEl = document.getElementById('countdown-text-mobile');
  const ringWrap = document.getElementById('countdown-ring');
  if (arcEl)    { arcEl.style.stroke = 'rgba(255,255,255,0.08)'; arcEl.style.strokeDashoffset = String(2 * Math.PI * 48); }
  if (textEl)   { textEl.style.color   = 'rgba(255,255,255,0.2)'; textEl.textContent   = '00:00'; }
  if (mobileEl) { mobileEl.style.color = 'rgba(255,255,255,0.2)'; mobileEl.textContent = '00:00'; }
}

async function closeVote() {
  freezeCountdown();
  const res = await fetch('<%= close_vote_path(@vote) %>', {
    method: 'PATCH',
    headers: { 'X-CSRF-Token': csrf, 'Accept': 'application/json' }
  });
  if (res.ok) {
    document.getElementById('close-btn')?.remove();
    showTimeUpBanner();
    <% if @vote.ranking_enabled? %>
    showRankingLoading();
    setTimeout(showRankingScreen, 1800);
    <% end %>
  }
}
// Use event delegation so it works whether button was server-rendered or injected via ActionCable
document.addEventListener('click', e => { if (e.target.closest('#close-btn')) closeVote(); });

function showTimeUpBanner() {
  const banner = document.getElementById('time-up-banner');
  if (!banner) return;
  banner.classList.remove('hidden');
  banner.style.animation = 'timeUpSlide 0.5s ease forwards';
  const arc = document.getElementById('countdown-arc');
  if (arc) arc.style.stroke = 'rgba(255,255,255,0.15)';
  [document.getElementById('countdown-text'), document.getElementById('countdown-text-mobile')]
    .forEach(el => { if (el) el.style.color = 'rgba(255,255,255,0.3)'; });
}

// ── Ranking Screen ────────────────────────────────────────────────────────
<% if @vote.ranking_enabled? %>
const RANKING_TOP   = <%= @vote.ranking_top %>;
const MEDAL_ICONS   = ['🥇','🥈','🥉'];
const PODIUM_COLORS = [
  { bg:'linear-gradient(135deg,#fbbf24,#f59e0b)', shadow:'#fbbf24', text:'#451a03' },
  { bg:'linear-gradient(135deg,#94a3b8,#64748b)', shadow:'#94a3b8', text:'#0f172a' },
  { bg:'linear-gradient(135deg,#fb923c,#ea580c)', shadow:'#fb923c', text:'#431407' },
];
const RANKING_LABELS = {
  vi: { pos:'Hạng', votes:'lượt', tie:'đồng hạng' },
  en: { pos:'Rank', votes:'votes', tie:'tied'      }
};
const LANG = '<%= I18n.locale.to_s %>';

// ── Assign shared ranks for equal counts (1-based, ties share the same rank)
function assignRanks(sorted) {
  return sorted.map((opt, _i, arr) => ({
    ...opt,
    rank: 1 + arr.filter(o => o.count > opt.count).length
  }));
}

function showRankingLoading() {
  const el = document.getElementById('ranking-loading');
  if (el) el.style.display = 'flex';
}

async function showRankingScreen() {
  const screen = document.getElementById('ranking-screen');
  if (!screen) return;

  // ── Fetch latest results ──────────────────────────────────────────────
  let results = [];
  try {
    const res  = await fetch(`/v/${voteSlug}/results.json`, { headers: { Accept: 'application/json' } });
    const data = await res.json();
    results   = (data.results || []).slice().sort((a,b) => b.count - a.count);
  } catch(e) {
    // DOM fallback
    document.querySelectorAll('.vote-option-row').forEach(row => {
      results.push({
        id:         row.dataset.optionId,
        label:      row.querySelector('[class*="font-bold"]')?.textContent?.trim() || '',
        count:      parseInt(row.dataset.count || '0'),
        percentage: parseFloat(row.querySelector('.option-pct')?.textContent || '0'),
        image_url:  row.querySelector('img')?.src || null
      });
    });
    results.sort((a,b) => b.count - a.count);
  }

  const ranked     = assignRanks(results);
  const totalVotes = results.reduce((s,r) => s + r.count, 0);

  // Options that qualify for display (rank ≤ RANKING_TOP)
  const topRanked = ranked.filter(o => o.rank <= RANKING_TOP);

  // Group top options by rank
  const rankGroups = [];
  topRanked.forEach(o => {
    let g = rankGroups.find(g => g.rank === o.rank);
    if (!g) { g = { rank: o.rank, options: [] }; rankGroups.push(g); }
    g.options.push(o);
  });
  rankGroups.sort((a,b) => a.rank - b.rank);

  const hasTies        = rankGroups.some(g => g.options.length > 1);
  const isVisualPodium = !hasTies && rankGroups.length >= 2;

  const lbl      = RANKING_LABELS[LANG] || RANKING_LABELS.en;
  const podiumEl = document.getElementById('ranking-podium');

  // ── PODIUM: standard 2-1-3 visual (only when no ties, ≥2 unique ranks) ─
  if (isVisualPodium) {
    const pd       = rankGroups.map(g => g.options[0]);
    const reord    = pd.length >= 3 ? [pd[1], pd[0], pd[2]] : [pd[1], pd[0]];
    const heights  = pd.length >= 3 ? ['140px','180px','110px'] : ['140px','180px'];
    const origIdxs = pd.length >= 3 ? [1, 0, 2] : [1, 0];

    podiumEl.innerHTML = `
      <div style="display:flex;align-items:flex-end;justify-content:center;
                  gap:clamp(8px,2vw,20px);padding:0 clamp(8px,4vw,40px);">
        ${reord.map((opt, vi) => {
          if (!opt) return '';
          const oi   = origIdxs[vi];
          const clr  = PODIUM_COLORS[oi] || PODIUM_COLORS[2];
          const pct  = totalVotes > 0 ? (opt.count/totalVotes*100).toFixed(1) : '0.0';
          return `
            <div style="flex:1;max-width:${oi===0?'240px':'200px'};display:flex;flex-direction:column;
                         align-items:center;gap:8px;animation:medalDrop 0.7s ease ${vi*0.15}s both;">
              <div style="font-size:clamp(28px,5vw,44px);line-height:1;
                           filter:drop-shadow(0 4px 12px ${clr.shadow}88);">${MEDAL_ICONS[oi]||`#${oi+1}`}</div>
              <div style="width:100%;background:rgba(255,255,255,0.05);border:1.5px solid rgba(255,255,255,0.12);
                           border-radius:16px;padding:clamp(10px,2vw,16px);text-align:center;
                           box-shadow:0 0 32px ${clr.shadow}44;">
                ${opt.image_url?`<img src="${opt.image_url}" style="width:clamp(48px,8vw,72px);height:clamp(48px,8vw,72px);border-radius:12px;object-fit:cover;margin:0 auto 10px;">`:''}
                <p style="font-size:clamp(13px,2.5vw,17px);font-weight:800;color:#f1f5f9;line-height:1.3;margin:0 0 8px;">${escHtml(opt.label)}</p>
                <p style="font-size:clamp(22px,4vw,32px);font-weight:900;color:${clr.shadow};line-height:1;margin:0;">${pct}%</p>
                <p style="font-size:clamp(11px,2vw,13px);color:rgba(148,163,184,0.8);margin:4px 0 0;">${opt.count} ${lbl.votes}</p>
              </div>
              <div style="width:100%;border-radius:10px 10px 0 0;background:${clr.bg};height:${heights[vi]};
                           display:flex;align-items:flex-start;justify-content:center;padding-top:12px;
                           box-shadow:0 -4px 24px ${clr.shadow}55;
                           animation:podiumRise 0.6s ease ${vi*0.15+0.3}s both;">
                <span style="font-size:clamp(18px,3vw,26px);font-weight:900;color:${clr.text};opacity:0.7;">${oi+1}</span>
              </div>
            </div>`;
        }).join('')}
      </div>`;

    // 4th+ positions (only possible when RANKING_TOP > 3 with no ties)
    if (topRanked.length > 3) {
      const restHtml = topRanked.slice(3).map(opt => {
        const pct = totalVotes>0?(opt.count/totalVotes*100).toFixed(1):'0.0';
        return `<div style="display:flex;align-items:center;gap:12px;padding:10px 16px;
                              background:rgba(255,255,255,0.04);border-radius:12px;border:1px solid rgba(255,255,255,0.08);">
          <span style="width:28px;text-align:center;font-size:14px;font-weight:800;color:rgba(148,163,184,0.7);">#${opt.rank}</span>
          ${opt.image_url?`<img src="${opt.image_url}" style="width:36px;height:36px;border-radius:8px;object-fit:cover;flex-shrink:0;">`:''}
          <span style="flex:1;font-size:clamp(13px,2.5vw,15px);font-weight:700;color:#e2e8f0;">${escHtml(opt.label)}</span>
          <span style="font-size:14px;font-weight:800;color:#94a3b8;">${pct}%</span>
          <span style="font-size:12px;color:rgba(100,116,139,0.8);">${opt.count}v</span>
        </div>`;
      }).join('');
      podiumEl.insertAdjacentHTML('beforeend',`<div class="mt-4 space-y-2 max-w-2xl mx-auto">${restHtml}</div>`);
    }

  // ── PODIUM: tie-aware grouped layout ────────────────────────────────────
  } else {
    let html = '';
    rankGroups.forEach((group, gi) => {
      const { rank, options } = group;
      const clr    = PODIUM_COLORS[rank-1] || PODIUM_COLORS[2];
      const medal  = MEDAL_ICONS[rank-1]   || `#${rank}`;
      const isTied = options.length > 1;
      const tieTag = isTied
        ? `<span style="font-size:11px;background:rgba(255,255,255,0.1);border-radius:999px;
                         padding:2px 10px;font-weight:600;color:rgba(200,210,230,0.8);margin-left:8px;">
             ${options.length} ${lbl.tie}
           </span>`
        : '';

      html += `
        <div style="margin-bottom:${gi < rankGroups.length-1 ? '28px' : '0'};
                     animation:medalDrop 0.7s ease ${gi*0.15}s both;">
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:14px;justify-content:center;">
            <span style="font-size:clamp(22px,4vw,36px);line-height:1;">${medal}</span>
            <span style="font-size:clamp(14px,2.5vw,18px);font-weight:800;color:${clr.shadow};">
              ${lbl.pos} ${rank}
            </span>
            ${tieTag}
          </div>
          <div style="display:flex;justify-content:center;flex-wrap:wrap;
                       gap:clamp(8px,2vw,16px);max-width:840px;margin:0 auto;">
            ${options.map(opt => {
              const pct = totalVotes>0?(opt.count/totalVotes*100).toFixed(1):'0.0';
              const maxW = options.length===1 ? '300px' : options.length===2 ? '260px' : '220px';
              return `
                <div style="flex:1;min-width:140px;max-width:${maxW};
                             background:rgba(255,255,255,0.05);border:1.5px solid rgba(255,255,255,0.12);
                             border-radius:16px;padding:clamp(12px,2vw,20px);text-align:center;
                             box-shadow:0 0 24px ${clr.shadow}33;">
                  ${opt.image_url?`<img src="${opt.image_url}" style="width:clamp(44px,7vw,64px);height:clamp(44px,7vw,64px);border-radius:10px;object-fit:cover;margin:0 auto 10px;">`:''}
                  <p style="font-size:clamp(13px,2.5vw,16px);font-weight:800;color:#f1f5f9;line-height:1.3;margin:0 0 8px;">${escHtml(opt.label)}</p>
                  <p style="font-size:clamp(20px,3.5vw,28px);font-weight:900;color:${clr.shadow};line-height:1;margin:0;">${pct}%</p>
                  <p style="font-size:clamp(11px,1.8vw,13px);color:rgba(148,163,184,0.8);margin:4px 0 0;">${opt.count} ${lbl.votes}</p>
                </div>`;
            }).join('')}
          </div>
        </div>`;
    });
    podiumEl.innerHTML = html;
  }

  // ── Summary table (all options with proper tied ranks) ────────────────
  const summaryEl = document.getElementById('ranking-summary');
  summaryEl.innerHTML = ranked.map((opt, i) => {
    const pct      = totalVotes>0?(opt.count/totalVotes*100).toFixed(1):'0.0';
    const barWidth = totalVotes>0?Math.max(parseFloat(pct),pct>0?1:0):0;
    const rowColor = GLOW_COLORS[i%GLOW_COLORS.length];
    const tied     = ranked.filter(o => o.rank === opt.rank).length > 1;
    const rankStr  = tied
      ? `<span style="font-size:10px;opacity:0.65;vertical-align:middle;">=</span>${opt.rank}`
      : String(opt.rank);
    return `
      <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;
                  background:rgba(255,255,255,0.03);border-radius:10px;border:1px solid rgba(255,255,255,0.06);">
        <span style="width:30px;text-align:center;font-size:12px;font-weight:700;
                      color:rgba(148,163,184,0.6);">${rankStr}</span>
        ${opt.image_url?`<img src="${opt.image_url}" style="width:32px;height:32px;border-radius:6px;object-fit:cover;flex-shrink:0;">`:''}
        <div style="flex:1;min-width:0;">
          <p style="font-size:clamp(12px,2vw,14px);font-weight:600;color:#cbd5e1;margin:0 0 4px;
                     white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${escHtml(opt.label)}</p>
          <div style="height:4px;background:rgba(255,255,255,0.06);border-radius:99px;overflow:hidden;">
            <div style="height:100%;width:${barWidth}%;background:${rowColor};border-radius:99px;transition:width 0.8s ease;"></div>
          </div>
        </div>
        <div style="text-align:right;flex-shrink:0;min-width:70px;">
          <span style="font-size:clamp(14px,2.5vw,17px);font-weight:800;color:${rowColor};">${pct}%</span>
          <span style="display:block;font-size:11px;color:rgba(100,116,139,0.8);">${opt.count} ${lbl.votes}</span>
        </div>
      </div>`;
  }).join('');

  // ── Show screen, hide loading overlay ────────────────────────────────
  const loadingEl = document.getElementById('ranking-loading');
  if (loadingEl) loadingEl.style.display = 'none';
  screen.classList.remove('hidden');
  screen.style.animation = 'rankingSlideIn 0.6s ease forwards';
  screen.scrollTop = 0;
}

function escHtml(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
<% end %>

// ── Countdown ─────────────────────────────────────────────────────────────
// Hoisted to module scope so freezeCountdown() can clear it from outside the IIFE
let _countdownTimer = null;

(function() {
  const totalSeconds = <%= @vote.countdown_seconds.to_i %>;
  if (totalSeconds <= 0) return;
  const voteIsActive = <%= @vote.active? ? 'true' : 'false' %>;
  const voteIsDraft  = <%= @vote.draft?  ? 'true' : 'false' %>;
  // Only reload when draft (waiting to open). Do NOT reload when closed — that causes infinite loop.
  if (!voteIsActive) { if (voteIsDraft) setTimeout(() => location.reload(), 900); return; }

  let remaining  = <%= @vote.seconds_remaining || 0 %>;
  const arcEl    = document.getElementById('countdown-arc');
  const textEl   = document.getElementById('countdown-text');
  const mobileEl = document.getElementById('countdown-text-mobile');
  const circumference = 2 * Math.PI * 48;

  function fmt(s) {
    return `${Math.floor(s/60).toString().padStart(2,'0')}:${(s%60).toString().padStart(2,'0')}`;
  }
  function updateRing() {
    const pct = remaining / totalSeconds;
    if (textEl)   textEl.textContent   = fmt(remaining);
    if (mobileEl) mobileEl.textContent = fmt(remaining);
    if (arcEl) {
      arcEl.style.strokeDashoffset = circumference * (1 - pct);
      arcEl.style.stroke = pct > 0.5 ? '#818cf8' : pct > 0.2 ? '#f59e0b' : '#ef4444';
    }
  }

  updateRing();
  if (remaining <= 0) { if (voteIsActive) { showTimeUpBanner(); } return; }

  _countdownTimer = setInterval(() => {
    remaining--;
    if (remaining <= 0) {
      remaining = 0; updateRing();
      clearInterval(_countdownTimer); _countdownTimer = null;
      showTimeUpBanner(); closeVote();
      <% if @vote.ranking_enabled? %>
      showRankingLoading();
      setTimeout(showRankingScreen, 1800);
      <% end %>
    } else { updateRing(); }
  }, 1000);
})();

</script>

<script>
window.togglePDesc = function(btn) {
  const wrap = btn.previousElementSibling; // .present-desc-html
  const isExpanded = btn.classList.contains('expanded');
  if (isExpanded) {
    wrap.classList.remove('pdesc-expanded');
    wrap.classList.add('pdesc-collapsed');
    btn.classList.remove('expanded');
    btn.querySelector('.pdesc-label').textContent = '<%= I18n.locale == :vi ? "Xem thêm" : "Show more" %>';
  } else {
    wrap.classList.remove('pdesc-collapsed');
    wrap.classList.add('pdesc-expanded');
    btn.classList.add('expanded');
    btn.querySelector('.pdesc-label').textContent = '<%= I18n.locale == :vi ? "Thu gọn" : "Show less" %>';
  }
}

// Hide toggle if description fits without clamping (use RAF to ensure CSS is computed)
requestAnimationFrame(() => requestAnimationFrame(() => {
  document.querySelectorAll('.pdesc-collapsed').forEach(el => {
    if (el.scrollHeight <= el.clientHeight + 2) {
      const btn = el.nextElementSibling;
      if (btn && btn.classList.contains('pdesc-toggle')) btn.style.display = 'none';
    }
  });
}));
</script>
