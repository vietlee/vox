<% content_for :title, @vote.title %>

<div class="min-h-screen flex flex-col items-center justify-center" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%); padding:24px;">
  <div style="width:100%; max-width:420px;">

    <!-- Vote info -->
    <div style="text-align:center; margin-bottom:28px;">
      <div style="display:inline-flex; align-items:center; gap:6px; background:rgba(30,58,95,0.1); border:1px solid rgba(30,58,95,0.2); border-radius:20px; padding:5px 14px; font-size:12px; font-weight:700; color:#1e3a5f; margin-bottom:16px;">
        🗳️ <%= I18n.locale == :vi ? "Yêu cầu đăng nhập" : "Login Required" %>
      </div>
      <h1 style="font-size:20px; font-weight:800; color:#1e293b; margin:0 0 8px;">
        <%= @vote.title %>
      </h1>
      <p style="font-size:14px; color:#64748b; margin:0;">
        <%= I18n.locale == :vi ? "Vui lòng đăng nhập để tham gia vote này." : "Please sign in to participate in this vote." %>
      </p>
    </div>

    <!-- SSO buttons -->
    <div style="background:#fff; border-radius:20px; border:1px solid rgba(0,0,0,0.08); padding:28px; box-shadow:0 8px 32px rgba(0,0,0,0.08);">
      <div style="font-size:13px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:16px; text-align:center;">
        <%= I18n.locale == :vi ? "Đăng nhập với" : "Sign in with" %>
      </div>

      <div style="display:flex; flex-direction:column; gap:10px;">
        <% if @vote.requires_google? %>
          <%= button_to user_google_oauth2_omniauth_authorize_path(locale: I18n.locale), method: :post,
              data: { turbo: false },
              style: "display:flex; align-items:center; justify-content:center; gap:10px; padding:13px 16px; background:#fff; border:1.5px solid rgba(0,0,0,0.1); border-radius:10px; font-size:14px; font-weight:600; color:#1e293b; cursor:pointer; width:100%; font-family:'Inter',sans-serif;" do %>
            <svg width="18" height="18" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.95 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/><path fill="none" d="M0 0h48v48H0z"/></svg>
            <%= I18n.locale == :vi ? "Đăng nhập với Google" : "Continue with Google" %>
          <% end %>
        <% end %>

        <% if @vote.requires_microsoft? %>
          <%= button_to user_entra_id_omniauth_authorize_path(locale: I18n.locale), method: :post,
              data: { turbo: false },
              style: "display:flex; align-items:center; justify-content:center; gap:10px; padding:13px 16px; background:#2f3136; border:1px solid rgba(255,255,255,0.1); border-radius:10px; font-size:14px; font-weight:600; color:#f1f5f9; cursor:pointer; width:100%; font-family:'Inter',sans-serif;" do %>
            <svg width="18" height="18" viewBox="0 0 23 23"><path fill="#f3f3f3" d="M0 0h23v23H0z"/><path fill="#f35325" d="M1 1h10v10H1z"/><path fill="#81bc06" d="M12 1h10v10H12z"/><path fill="#05a6f0" d="M1 12h10v10H1z"/><path fill="#ffba08" d="M12 12h10v10H12z"/></svg>
            <%= I18n.locale == :vi ? "Đăng nhập với Microsoft" : "Continue with Microsoft" %>
          <% end %>
        <% end %>
      </div>
    </div>

  </div>
</div>
