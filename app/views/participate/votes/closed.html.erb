<% content_for :title, @vote.title %>

<style>
  html, body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100%; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  .fade-in { animation: fadeIn 0.4s ease forwards; }
</style>

<% content_for :nav_right do %>
  <div class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold text-slate-500" style="background:rgba(100,116,139,0.1); border:1px solid rgba(100,116,139,0.2);">
    <%= t("participate.vote.closed_badge") %>
  </div>
<% end %>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%)">

  <div class="flex-1 flex items-center justify-center px-4 pb-10">
    <div class="w-full max-w-[480px] fade-in">
      <div class="text-center py-12 px-8 rounded-2xl" style="background:rgba(255,255,255,0.85); border:1px solid rgba(99,102,241,0.12); box-shadow:0 8px 32px rgba(99,102,241,0.08); backdrop-filter:blur(12px);">
        <div class="w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-5" style="background:linear-gradient(135deg,#e0e7ff,#f3e8ff);">
          <svg class="w-8 h-8" fill="none" stroke="#6366f1" stroke-width="1.8" viewBox="0 0 24 24">
            <rect x="3" y="11" width="18" height="11" rx="2"/>
            <path stroke-linecap="round" d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h1 class="text-[22px] font-extrabold text-slate-800 mb-2"><%= @vote.title %></h1>
        <p class="text-[13px] text-slate-400 mb-1"><%= t("participate.vote.closed_title") %></p>
        <p class="text-[12px] text-slate-400"><%= @vote.participant_count %> <%= t("participate.vote.participants_joined") %></p>
        <% if @vote.show_results_live? %>
          <div class="mt-7">
            <%= link_to vote_results_path(@vote.slug),
                class: "inline-flex items-center gap-2 px-6 py-3 text-[14px] font-bold text-white rounded-lg transition-all hover:opacity-90",
                style: "background:#4F46E5;" do %>
              <%= t("participate.vote.view_results") %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="text-center pb-6">
    <span class="inline-flex items-center gap-1.5"><img src="/vox_logo.svg" alt="VOX" style="height:18px;width:auto;opacity:0.65;"><span style="font-size:11px;color:#94a3b8;">· Survey &amp; Voting Platform</span></span>
  </div>
</div>
