<%
  vi = I18n.locale.to_s == "vi"
%>
<div class="min-h-screen flex flex-col items-center justify-center px-4 py-20" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%);">
  <div class="text-center max-w-md">
    <!-- Illustration -->
    <div class="relative mx-auto mb-8 w-36 h-36">
      <div class="w-36 h-36 rounded-full flex items-center justify-center" style="background:linear-gradient(135deg,#eef2ff,#f5f3ff);">
        <svg class="w-16 h-16 text-indigo-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <div class="absolute -top-1 -right-1 w-10 h-10 rounded-full flex items-center justify-center text-[18px] font-black text-white shadow-lg" style="background:linear-gradient(135deg,#6366f1,#a855f7);">
        404
      </div>
    </div>

    <h1 class="text-[26px] font-extrabold text-slate-800 mb-3 tracking-tight">
      <%= vi ? "Không tìm thấy trang này" : "Page not found" %>
    </h1>
    <p class="text-[14px] text-slate-500 leading-relaxed mb-8">
      <%= vi ? "Link bạn truy cập không tồn tại hoặc đã bị xoá. Vui lòng kiểm tra lại URL hoặc liên hệ người tổ chức." : "The link you followed doesn't exist or may have been removed. Please check the URL or contact the organizer." %>
    </p>

    <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-[14px] font-bold text-white shadow transition-all hover:opacity-90" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      <%= vi ? "Về trang chủ" : "Go home" %>
    </a>
  </div>

  <p class="mt-12 flex items-center gap-1.5"><img src="/vox_logo.svg" alt="VOX" style="height:16px;opacity:0.5;"><span style="font-size:11px;color:#94a3b8;">· Survey &amp; Voting Platform</span></p>
</div>
