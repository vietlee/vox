<%
  vi = I18n.locale.to_s == "vi"
%>
<div style="min-height:calc(100vh - 57px); display:flex; flex-direction:column; background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%);">

  <!-- Main content — centered -->
  <div style="flex:1; display:flex; align-items:center; justify-content:center; padding:48px 16px;">
    <div style="text-align:center; max-width:420px; width:100%;">
      <!-- Illustration -->
      <div style="position:relative; width:128px; height:128px; margin:0 auto 32px;">
        <div style="width:128px; height:128px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#eef2ff,#eef3f9);">
          <svg width="52" height="52" fill="none" stroke="#7aaac9" stroke-width="1.4" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div style="position:absolute; top:-4px; right:-4px; width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:900; color:#fff; background:linear-gradient(135deg,#1e3a5f,#2d5f8a); box-shadow:0 4px 12px rgba(30,58,95,0.4);">
          404
        </div>
      </div>

      <h1 style="font-size:24px; font-weight:800; color:#1e293b; margin-bottom:12px; letter-spacing:-0.02em;">
        <%= vi ? "Không tìm thấy trang này" : "Page not found" %>
      </h1>
      <p style="font-size:14px; color:#64748b; line-height:1.7; margin-bottom:32px;">
        <%= vi ? "Link bạn truy cập không tồn tại hoặc đã bị xoá. Vui lòng kiểm tra lại URL hoặc liên hệ người tổ chức." : "The link you followed doesn't exist or may have been removed. Please check the URL or contact the organizer." %>
      </p>

      <a href="/" style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border-radius:12px; font-size:14px; font-weight:700; color:#fff; background:linear-gradient(135deg,#1e3a5f,#2d5f8a); text-decoration:none; box-shadow:0 4px 16px rgba(30,58,95,0.35); transition:opacity 0.15s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <%= vi ? "Về trang chủ" : "Go home" %>
      </a>
    </div>
  </div>

  <!-- Footer — pinned to bottom -->
  <div style="padding:16px; text-align:center; border-top:1px solid rgba(30,58,95,0.08);">
    <p style="display:inline-flex; align-items:center; gap:6px; margin:0;">
      <img src="/vox_logo.svg" alt="VOX" style="height:16px; opacity:0.5;">
      <span style="font-size:11px; color:#94a3b8;">· Nền tảng học tiếng Anh</span>
    </p>
  </div>

</div>
