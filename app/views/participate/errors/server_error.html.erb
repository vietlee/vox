<%
  vi = I18n.locale.to_s == "vi"
%>
<div class="min-h-screen flex flex-col items-center justify-center px-4 py-20" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%);">
  <div class="text-center max-w-md">
    <!-- Illustration -->
    <div class="relative mx-auto mb-8 w-36 h-36">
      <div class="w-36 h-36 rounded-full flex items-center justify-center" style="background:linear-gradient(135deg,#fff1f2,#fef3c7);">
        <svg class="w-16 h-16 text-orange-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
        </svg>
      </div>
      <div class="absolute -top-1 -right-1 w-10 h-10 rounded-full flex items-center justify-center text-[18px] font-black text-white shadow-lg" style="background:linear-gradient(135deg,#f97316,#ef4444);">
        500
      </div>
    </div>

    <h1 class="text-[26px] font-extrabold text-slate-800 mb-3 tracking-tight">
      <%= vi ? "Có lỗi xảy ra" : "Something went wrong" %>
    </h1>
    <p class="text-[14px] text-slate-500 leading-relaxed mb-8">
      <%= vi ? "Hệ thống gặp sự cố không mong muốn. Vui lòng thử lại sau ít phút hoặc liên hệ người tổ chức nếu lỗi tiếp tục xảy ra." : "An unexpected error occurred. Please try again in a few minutes or contact the organizer if the issue persists." %>
    </p>

    <div class="flex flex-col sm:flex-row gap-3 justify-center">
      <button onclick="window.location.reload()" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-[14px] font-bold text-white shadow transition-all hover:opacity-90" style="background:linear-gradient(135deg,#4F46E5,#7C3AED);">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
        <%= vi ? "Thử lại" : "Try again" %>
      </button>
      <a href="/" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-[14px] font-semibold text-slate-700 bg-white border border-slate-200 hover:border-indigo-200 hover:text-indigo-700 transition-all">
        <%= vi ? "Về trang chủ" : "Go home" %>
      </a>
    </div>
  </div>

  <p class="mt-12 flex items-center gap-1.5"><img src="/vox_logo.svg" alt="VOX" style="height:16px;opacity:0.5;"><span style="font-size:11px;color:#94a3b8;">· Survey &amp; Voting Platform</span></p>
</div>
