<%
  vi = I18n.locale.to_s == "vi"
%>
<div style="min-height:calc(100vh - 57px); display:flex; flex-direction:column; background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%);">


  <!-- Main content — centered -->
  <div style="flex:1; display:flex; align-items:center; justify-content:center; padding:48px 16px;">
    <div style="text-align:center; max-width:420px; width:100%;">
      <!-- Illustration -->
      <div style="position:relative; width:128px; height:128px; margin:0 auto 32px;">
        <div style="width:128px; height:128px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:linear-gradient(135deg,#fff7ed,#fef3c7);">
          <svg width="52" height="52" fill="none" stroke="#fbbf24" stroke-width="1.4" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
          </svg>
        </div>
        <div style="position:absolute; top:-4px; right:-4px; width:38px; height:38px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:900; color:#fff; background:linear-gradient(135deg,#f97316,#ef4444); box-shadow:0 4px 12px rgba(239,68,68,0.35);">
          500
        </div>
      </div>

      <h1 style="font-size:24px; font-weight:800; color:#1e293b; margin-bottom:12px; letter-spacing:-0.02em;">
        <%= vi ? "Có lỗi xảy ra" : "Something went wrong" %>
      </h1>
      <p style="font-size:14px; color:#64748b; line-height:1.7; margin-bottom:32px;">
        <%= vi ? "Hệ thống gặp sự cố không mong muốn. Vui lòng thử lại sau ít phút hoặc liên hệ người tổ chức nếu lỗi tiếp tục xảy ra." : "An unexpected error occurred. Please try again in a few minutes or contact the organizer if the issue persists." %>
      </p>

      <div style="display:flex; flex-wrap:wrap; gap:10px; justify-content:center;">
        <button onclick="window.location.reload()" style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border-radius:12px; font-size:14px; font-weight:700; color:#fff; background:linear-gradient(135deg,#4F46E5,#7C3AED); border:none; cursor:pointer; box-shadow:0 4px 16px rgba(99,102,241,0.35); transition:opacity 0.15s;" onmouseover="this.style.opacity='0.88'" onmouseout="this.style.opacity='1'">
          <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          <%= vi ? "Thử lại" : "Try again" %>
        </button>
        <a href="/" style="display:inline-flex; align-items:center; gap:8px; padding:12px 24px; border-radius:12px; font-size:14px; font-weight:600; color:#475569; background:#fff; border:1px solid #e2e8f0; text-decoration:none; transition:all 0.15s;" onmouseover="this.style.borderColor='#a5b4fc'; this.style.color='#4F46E5'" onmouseout="this.style.borderColor='#e2e8f0'; this.style.color='#475569'">
          <%= vi ? "Về trang chủ" : "Go home" %>
        </a>
      </div>
    </div>
  </div>

  <!-- Footer — pinned to bottom -->
  <div style="padding:16px; text-align:center; border-top:1px solid rgba(99,102,241,0.08);">
    <p style="display:inline-flex; align-items:center; gap:6px; margin:0;">
      <img src="/vox_logo.svg" alt="VOX" style="height:16px; opacity:0.5;">
      <span style="font-size:11px; color:#94a3b8;">· Survey &amp; Voting Platform</span>
    </p>
  </div>

</div>
