              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Empty state (hidden when there are feedbacks) -->
    <div id="empty-state" class="<%= @feedbacks.any? ? 'hidden' : '' %> text-center py-16 fade-in">
      <div class="text-[48px] mb-3">💭</div>
      <p class="text-[15px] font-semibold text-slate-500"><%= t("participate.feedback.empty_title") %></p>
      <p class="text-[13px] text-slate-400 mt-1"><%= t("participate.feedback.empty_desc") %></p>
    </div>

    <!-- Load more -->
    <div id="load-more-wrap" class="<%= @has_more ? '' : 'hidden' %> text-center mt-4 mb-2">
      <button id="load-more-btn" onclick="loadMore()"
        class="inline-flex items-center gap-2 px-6 py-2.5 text-[13px] font-semibold text-white rounded-full transition-all hover:opacity-90 disabled:opacity-60"
        style="background:linear-gradient(135deg,#6366f1,#4f46e5); box-shadow:0 4px 14px rgba(99,102,241,0.3);">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        <%= t('participate.feedback.load_more_feedbacks') %>
      </button>
    </div>
  </div>

  <!-- ── Voice Recording Modal ──────────────────────────────────────────────── -->
  <% if @board.allow_voice_input? %>
  <div id="vm-overlay"
       style="display:none; position:fixed; inset:0; z-index:10000;
              background:rgba(10,14,26,0.72);
              backdrop-filter:blur(4px);
              -webkit-backdrop-filter:blur(4px);
              align-items:center; justify-content:center;">
    <div style="background:rgba(255,255,255,0.07);
                backdrop-filter:blur(32px) saturate(160%); -webkit-backdrop-filter:blur(32px) saturate(160%);
