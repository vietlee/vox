<% content_for :title, @board.title %>

<!-- Image Gallery Lightbox -->
<div id="gallery-modal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.92); flex-direction:column; align-items:center; justify-content:center;"
     onclick="closeGallery()">
  <button onclick="closeGallery()" style="position:absolute; top:16px; right:16px; width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,0.15); border:none; color:white; font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center;">✕</button>
  <button id="gallery-prev" onclick="event.stopPropagation(); galleryNav(-1)" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.15); border:none; color:white; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center;">‹</button>
  <img id="gallery-img" src="" alt="" onclick="event.stopPropagation()"
       style="max-height:80vh; max-width:90vw; object-fit:contain; border-radius:12px; box-shadow:0 8px 40px rgba(0,0,0,0.5);">
  <div id="gallery-counter" style="color:rgba(255,255,255,0.7); margin-top:14px; font-size:13px; font-weight:600;"></div>
  <!-- Thumbnails -->
  <div id="gallery-thumbs" onclick="event.stopPropagation()"
       style="display:none; gap:8px; margin-top:12px; max-width:90vw; overflow-x:auto; padding:4px 0;"></div>
  <button id="gallery-next" onclick="event.stopPropagation(); galleryNav(1)" style="position:absolute; right:16px; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.15); border:none; color:white; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center;">›</button>
</div>

<style>
  html, body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100%; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes spin { to { transform: rotate(360deg); } }
  .fade-in { animation: fadeIn 0.35s ease forwards; }
  .reply-section { transition: all 0.2s ease; }
</style>

<% content_for :nav_right do %>
  <div class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold text-indigo-700" style="background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.15);">
    💬 <%= t("kpi.feedback") %>
  </div>
<% end %>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%)">

  <!-- Sticky board header -->
  <div class="sticky top-0 z-50 w-full"
       style="background:rgba(250,251,255,0.96); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
              border-bottom:1px solid rgba(226,232,240,0.65); box-shadow:0 1px 12px rgba(99,102,241,0.06);">
    <div id="board-header-section" class="max-w-2xl mx-auto px-4 py-3 text-center">
      <% if @board.logo.attached? %>
        <img src="<%= url_for(@board.logo) %>" alt="<%= @board.title %>"
             class="object-contain mx-auto mb-1.5 rounded-xl"
             style="max-height:48px; max-width:180px;">
      <% else %>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[22px] mx-auto mb-1.5"
             style="background:linear-gradient(135deg,#6366f1,#a855f7); box-shadow:0 4px 12px rgba(99,102,241,0.3);">💬</div>
      <% end %>
      <h1 class="text-[18px] font-extrabold text-slate-900 tracking-tight leading-snug mb-0.5"><%= @board.title %></h1>
      <% if @board.description.present? %>
        <p class="text-[12px] text-slate-500 mb-0.5" style="overflow:hidden; display:-webkit-box; -webkit-line-clamp:1; -webkit-box-orient:vertical;"><%= @board.description %></p>
      <% end %>
      <span id="sticky-feedback-count" class="text-[11px] text-slate-400">
        <%= @board.feedbacks.visible.count %> <%= t("participate.feedback.feedbacks_count") %>
      </span>
    </div>
  </div>

  <!-- Scrollable content -->
  <div class="max-w-2xl mx-auto w-full px-4 pt-4 pb-5 fade-in">

    <!-- Flash -->
    <% if notice %>
      <div class="flex items-center gap-2 px-4 py-3 mb-4 rounded-2xl text-[13px] font-semibold fade-in" style="background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.2); color:#065f46;">
        ✓ <%= notice %>
      </div>
    <% end %>
    <% if @feedback.errors.any? %>
      <div class="px-4 py-3 mb-4 rounded-2xl text-[13px] font-semibold fade-in" style="background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2); color:#991b1b;">
        <%= @feedback.errors.full_messages.join(", ") %>
      </div>
    <% end %>

    <!-- Flash toast (AJAX) -->
    <div id="feedback-toast" style="display:none;" class="mb-4 px-4 py-3 rounded-xl text-[13px] font-semibold fade-in"></div>

    <!-- Submit form -->
    <div class="rounded-2xl p-5 mb-5" style="background:#ffffff; border:1px solid rgba(99,102,241,0.12); box-shadow:0 4px 24px rgba(99,102,241,0.08);">
      <p class="text-[13px] font-bold text-slate-700 mb-3"><%= t("participate.feedback.submit_title") %></p>
      <form id="feedback-form" class="space-y-3">
        <textarea id="fb-content" name="feedback[content]" rows="3" required maxlength="1000"
          placeholder="<%= t("participate.feedback.content_placeholder") %>"
          class="w-full px-4 py-3 rounded-xl text-[14px] text-slate-800 outline-none resize-none"
          style="border:1.5px solid #e2e8f0; background:rgba(255,255,255,0.9); font-size:16px;"
          onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'"></textarea>

        <% if @board.public_identity? || @board.user_choice? %>
          <div class="grid grid-cols-2 gap-3">
            <input type="text" id="feedback-author-name" name="feedback[author_name]"
              placeholder="<%= t("participate.feedback.name_placeholder") %>"
              <% if @board.public_identity? %>required<% end %>
              class="px-3 py-2.5 rounded-xl text-[13px] outline-none"
              style="border:1.5px solid #e2e8f0; background:rgba(255,255,255,0.9); font-size:16px;"
              onfocus="this.style.borderColor='#6366f1';const ne=document.getElementById('name-error');if(ne)ne.style.display='none';" onblur="this.style.borderColor='#e2e8f0'">
            <input type="email" id="fb-email" name="feedback[author_email]" placeholder="<%= t("participate.feedback.email_placeholder") %>"
              class="px-3 py-2.5 rounded-xl text-[13px] outline-none"
              style="border:1.5px solid #e2e8f0; background:rgba(255,255,255,0.9); font-size:16px;"
              onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
          </div>
          <p id="name-error" style="display:none; color:#dc2626; font-size:12px; font-weight:500; margin-top:2px;">
            <%= t("participate.feedback.name_or_anonymous_required", default: "Vui lòng nhập tên hoặc chọn gửi ẩn danh") %>
          </p>
        <% end %>

        <% if @board.user_choice? %>
          <label class="flex items-center gap-2 cursor-pointer text-[13px] text-slate-500">
            <input type="checkbox" name="feedback[anonymous]" value="1" id="feedback-anonymous"
              class="w-4 h-4 accent-indigo-600" onchange="toggleAnonymous(this.checked)">
            <%= t("participate.feedback.anonymous_label") %>
          </label>
        <% end %>

        <!-- Image upload (multiple) -->
        <div>
          <input type="file" id="fb-image-input" accept="image/*" multiple class="hidden"
                 onchange="handleFbImageSelect(this)">
          <div id="fb-image-previews" style="display:none; flex-wrap:wrap; gap:8px; margin-bottom:8px;"></div>
          <button type="button" onclick="document.getElementById('fb-image-input').click()"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[12px] font-semibold text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                  style="border:1.5px dashed #cbd5e1;">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <%= t("participate.feedback.add_image", default: "Thêm ảnh") %>
          </button>
        </div>

        <button type="submit" id="fb-submit-btn"
          class="w-full py-3 text-[14px] font-bold text-white rounded-lg transition-all hover:opacity-90 flex items-center justify-center gap-2 disabled:opacity-70"
          style="background:#4F46E5;">
          <span id="fb-submit-spinner" style="display:none; width:14px; height:14px; border:2px solid rgba(255,255,255,0.4); border-top-color:white; border-radius:50%; animation:spin 0.7s linear infinite; flex-shrink:0;"></span>
          <span id="fb-submit-label"><%= t("participate.feedback.submit_btn") %></span>
        </button>
      </form>
    </div>

    <!-- Feedbacks list -->
    <% if @feedbacks.any? || @has_more %>
      <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-3 px-1"><%= t("participate.feedback.all_feedbacks") %></p>
    <% end %>

    <div id="feedbacks-list" class="space-y-3">
      <% @feedbacks.each do |fb| %>
        <div id="feedback-card-<%= fb.id %>" class="rounded-2xl overflow-hidden fade-in" style="background:#ffffff; border:1.5px solid <%= fb.pinned? ? '#fbbf24' : 'rgba(226,232,240,0.8)' %>; box-shadow:0 2px 12px rgba(0,0,0,0.04);">
          <% if fb.pinned? %>
            <div class="px-4 py-1.5 flex items-center gap-1.5" style="background:rgba(251,191,36,0.12);">
              <span class="text-[10px] font-bold text-amber-600 uppercase tracking-wider">📌 <%= t("participate.feedback.pinned") %></span>
            </div>
          <% end %>
          <div class="p-4 flex items-start gap-3">
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-[13px] font-bold flex-shrink-0 text-white mt-0.5"
              style="background:linear-gradient(135deg,#6366f1,#a855f7);">
              <%= fb.anonymous? || fb.author_name.blank? ? "?" : fb.author_name.first.upcase %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="text-[12px] font-semibold text-slate-600">
                  <%= fb.anonymous? || fb.author_name.blank? ? t("participate.feedback.anonymous") : fb.author_name %>
                </span>
                <span class="text-[11px] text-slate-300"><%= I18n.l(fb.created_at, format: :short) %></span>
                <% if fb.implemented? %>
                  <span class="px-2 py-0.5 rounded-full text-[10px] font-bold text-emerald-700" style="background:rgba(16,185,129,0.1);"><%= t("participate.feedback.implemented") %></span>
                <% end %>
              </div>
              <p class="text-[14px] text-slate-800 leading-relaxed mb-2"><%= fb.content %></p>
              <% if fb.images.attached? %>
                <% img_urls = fb.images.map { |img| url_for(img) } %>
                <div class="relative cursor-pointer mb-2 inline-block"
                     onclick='openGallery(<%= img_urls.to_json %>, 0)'
                     style="max-width:100%;">
                  <img src="<%= img_urls.first %>" alt=""
                       class="rounded-xl object-cover block"
                       style="max-height:200px; max-width:100%; border:1px solid rgba(226,232,240,0.8);">
                  <% if img_urls.size > 1 %>
                    <div class="absolute inset-0 rounded-xl flex items-center justify-center"
                         style="background:rgba(0,0,0,0.45);">
                      <span class="text-white font-extrabold" style="font-size:22px; text-shadow:0 1px 4px rgba(0,0,0,0.5);">+<%= img_urls.size - 1 %></span>
                    </div>
                  <% end %>
                </div>
              <% end %>
              <% if @board.allow_replies? %>
                <div class="flex justify-end">
                  <button onclick="toggleReplyForm(<%= fb.id %>)"
                    class="text-[11px] font-semibold text-indigo-500 hover:text-indigo-700 border-0 bg-transparent p-0">
                    💬 <%= fb.feedback_replies.count > 0 ? "#{fb.feedback_replies.count} #{t("participate.feedback.reply_count")}" : t("participate.feedback.reply_label") %>
                  </button>
                </div>
              <% end %>
            </div>
            <% if @board.allow_upvotes? %>
              <% upvoted = @upvoted_ids.include?(fb.id) %>
              <button data-feedback-id="<%= fb.id %>" onclick="toggleUpvote(this, <%= fb.id %>)"
                class="flex flex-col items-center gap-0.5 px-2.5 py-2 rounded-xl border transition-all cursor-pointer flex-shrink-0 upvote-btn"
                style="<%= upvoted ? 'background:rgba(99,102,241,0.08);border-color:#6366f1;color:#6366f1;' : 'background:white;border-color:#e2e8f0;color:#64748b;' %>">
                <span class="text-[15px] leading-none"><%= upvoted ? '▲' : '△' %></span>
                <span class="text-[12px] font-bold upvote-count"><%= fb.upvotes_count %></span>
              </button>
            <% end %>
          </div>
          <% if @board.allow_replies? %>
            <div id="replies-<%= fb.id %>" class="hidden border-t reply-section" style="border-color:rgba(226,232,240,0.6); background:rgba(248,250,252,0.5);">
              <div class="ml-11 mr-4 my-3 pl-3" style="border-left:2px solid rgba(99,102,241,0.18);">
                <div id="replies-list-<%= fb.id %>" class="space-y-2 mb-2">
                  <% fb.feedback_replies.order(:created_at).each do |r| %>
                    <div class="flex gap-2">
                      <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0 mt-0.5" style="background:linear-gradient(135deg,#94a3b8,#64748b);">
                        <%= r.anonymous? ? "?" : r.author_name.to_s.first.upcase %>
                      </div>
                      <div class="flex-1 rounded-xl px-3 py-2" style="background:rgba(255,255,255,0.9); border:1px solid rgba(226,232,240,0.7);">
                        <div class="flex items-baseline gap-2 mb-0.5">
                          <span class="text-[11px] font-semibold text-slate-600"><%= r.anonymous? ? t("participate.feedback.anonymous") : r.author_name %></span>
                          <span class="text-[10px] text-slate-300"><%= I18n.l(r.created_at, format: :short) %></span>
                        </div>
                        <p class="text-[13px] text-slate-700"><%= r.content %></p>
                        <% if r.images.attached? %>
                          <% r_urls = r.images.map { |img| url_for(img) } %>
                          <div class="relative cursor-pointer mt-1.5 inline-block"
                               onclick='openGallery(<%= r_urls.to_json %>, 0)'>
                            <img src="<%= r_urls.first %>" alt=""
                                 class="rounded-lg object-cover block"
                                 style="max-height:120px; max-width:100%; border:1px solid #e2e8f0;">
                            <% if r_urls.size > 1 %>
                              <div class="absolute inset-0 rounded-lg flex items-center justify-center"
                                   style="background:rgba(0,0,0,0.45);">
                                <span class="text-white font-bold" style="font-size:16px;">+<%= r_urls.size - 1 %></span>
                              </div>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
                <div class="space-y-2">
                  <input type="text" id="reply-name-<%= fb.id %>" placeholder="<%= t("participate.feedback.reply_name_placeholder") %>"
                    class="w-full px-3 py-1.5 rounded-lg text-[12px] outline-none"
                    style="border:1.5px solid #e2e8f0; background:white; font-size:16px;"
                    onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
                  <div class="flex gap-2 items-center">
                    <div class="relative flex-1">
                      <textarea id="reply-content-<%= fb.id %>" rows="2" maxlength="500"
                        placeholder="<%= t("participate.feedback.reply_content_placeholder") %>"
                        class="w-full px-3 py-1.5 pr-9 rounded-lg text-[13px] text-slate-800 outline-none resize-none"
                        style="border:1.5px solid #e2e8f0; background:white; font-size:16px;"
                        onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'"></textarea>
                      <button type="button" onclick="document.getElementById('reply-image-input-<%= fb.id %>').click()"
                        class="absolute top-1/2 -translate-y-1/2 right-2 w-6 h-6 rounded-md flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                        style="border:1px solid #e2e8f0; background:white;">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                      </button>
                    </div>
                    <button id="reply-submit-btn-<%= fb.id %>" onclick="submitReply(<%= fb.id %>)"
                      class="px-4 py-2 text-white text-[12px] font-bold rounded-lg flex-shrink-0 border-0 flex items-center gap-1.5 disabled:opacity-60"
                      style="background:#4F46E5;">
                      <%= t("participate.feedback.reply_submit") %>
                    </button>
                  </div>
                  <input type="file" id="reply-image-input-<%= fb.id %>" accept="image/*" multiple class="hidden"
                         onchange="handleReplyImage(this, <%= fb.id %>)">
                  <div id="reply-image-previews-<%= fb.id %>" style="display:none; flex-wrap:wrap; gap:6px;"></div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Empty state (hidden when there are feedbacks) -->
    <div id="empty-state" class="<%= @feedbacks.any? ? 'hidden' : '' %> text-center py-16 fade-in">
      <div class="text-[48px] mb-3">💭</div>
      <p class="text-[15px] font-semibold text-slate-500"><%= t("participate.feedback.empty_title") %></p>
      <p class="text-[13px] text-slate-400 mt-1"><%= t("participate.feedback.empty_desc") %></p>
    </div>

    <!-- Load more -->
    <div id="load-more-wrap" class="<%= @has_more ? '' : 'hidden' %> text-center mt-4 mb-2">
      <button id="load-more-btn" onclick="loadMore()"
        class="px-6 py-2.5 text-[13px] font-semibold text-indigo-600 rounded-xl border border-indigo-200 hover:bg-indigo-50 transition-colors bg-white">
        <%= I18n.locale.to_s == 'vi' ? 'Xem thêm góp ý' : 'Load more' %>
      </button>
    </div>
  </div>

  <!-- Footer -->
  <div class="text-center py-6 mt-auto">
    <span class="inline-flex items-center gap-1.5"><img src="/vox_logo.svg" alt="VOX" style="height:18px;width:auto;opacity:0.65;"><span style="font-size:11px;color:#94a3b8;">· Survey &amp; Voting Platform</span></span>
  </div>

</div>

<script>
const SUBMIT_URL   = "<%= submit_feedback_path(@board.slug) %>";
const LIST_URL     = "<%= list_feedbacks_path(@board.slug) %>";
const UPVOTE_URL   = "<%= upvote_feedback_path(@board.slug) %>";
const REPLY_URL    = "<%= reply_feedback_path(@board.slug) %>";
const CSRF         = document.querySelector('meta[name="csrf-token"]')?.content;
const ALLOW_UPVOTES  = <%= @board.allow_upvotes? ? 'true' : 'false' %>;
const ALLOW_REPLIES  = <%= @board.allow_replies? ? 'true' : 'false' %>;
const IDENTITY_MODE  = "<%= @board.identity_mode %>";
const ANONYMOUS_LABEL = "<%= j t('participate.feedback.anonymous') %>";
const REPLY_LABEL     = "<%= j t('participate.feedback.reply_label') %>";
const REPLY_COUNT_LABEL = "<%= j t('participate.feedback.reply_count') %>";
const IMPLEMENTED_LABEL = "<%= j t('participate.feedback.implemented') %>";
const PINNED_LABEL    = "<%= j t('participate.feedback.pinned') %>";
const REPLY_NAME_PH   = "<%= j t('participate.feedback.reply_name_placeholder') %>";
const REPLY_CONTENT_PH = "<%= j t('participate.feedback.reply_content_placeholder') %>";
const REPLY_SUBMIT_LABEL = "<%= j t('participate.feedback.reply_submit') %>";

let currentOffset = <%= @feedbacks.size %>;

function showToast(message, isError = false) {
  const toast = document.getElementById('feedback-toast');
  toast.textContent = message;
  toast.style.background  = isError ? 'rgba(239,68,68,0.08)'       : 'rgba(16,185,129,0.1)';
  toast.style.border      = isError ? '1px solid rgba(239,68,68,0.2)' : '1px solid rgba(16,185,129,0.2)';
  toast.style.color       = isError ? '#991b1b'                     : '#065f46';
  toast.style.display     = 'block';
  setTimeout(() => { toast.style.display = 'none'; }, 4000);
}

function renderFeedbackCard(fb) {
  const initial = fb.anonymous || !fb.author_name ? '?' : fb.author_name.charAt(0).toUpperCase();
  const authorLabel = fb.anonymous || !fb.author_name ? ANONYMOUS_LABEL : fb.author_name;
  const borderColor = fb.pinned ? '#fbbf24' : 'rgba(226,232,240,0.8)';

  const pinnedBanner = fb.pinned
    ? `<div class="px-4 py-1.5 flex items-center gap-1.5" style="background:rgba(251,191,36,0.12);">
         <span class="text-[10px] font-bold text-amber-600 uppercase tracking-wider">📌 ${PINNED_LABEL}</span>
       </div>`
    : '';

  const implementedBadge = fb.implemented
    ? `<span class="px-2 py-0.5 rounded-full text-[10px] font-bold text-emerald-700" style="background:rgba(16,185,129,0.1);">${IMPLEMENTED_LABEL}</span>`
    : '';

  const replyBtn = ALLOW_REPLIES
    ? `<button onclick="toggleReplyForm(${fb.id})"
         class="ml-auto text-[11px] font-semibold text-indigo-500 hover:text-indigo-700 border-0 bg-transparent p-0">
         💬 ${fb.replies_count > 0 ? fb.replies_count + ' ' + REPLY_COUNT_LABEL : REPLY_LABEL}
       </button>`
    : '';

  const upvoteBtn = ALLOW_UPVOTES
    ? `<button data-feedback-id="${fb.id}" onclick="toggleUpvote(this, ${fb.id})"
         class="flex flex-col items-center gap-0.5 px-2.5 py-2 rounded-xl border transition-all cursor-pointer flex-shrink-0 upvote-btn"
         style="${fb.upvoted ? 'background:rgba(99,102,241,0.08);border-color:#6366f1;color:#6366f1;' : 'background:white;border-color:#e2e8f0;color:#64748b;'}">
         <span class="text-[15px] leading-none">${fb.upvoted ? '▲' : '△'}</span>
         <span class="text-[12px] font-bold upvote-count">${fb.upvotes_count}</span>
       </button>`
    : '';

  const repliesSection = ALLOW_REPLIES
    ? `<div id="replies-${fb.id}" class="hidden border-t reply-section" style="border-color:rgba(226,232,240,0.6); background:rgba(248,250,252,0.5);">
         <div class="ml-11 mr-4 my-3 pl-3" style="border-left:2px solid rgba(99,102,241,0.18);">
           <div id="replies-list-${fb.id}" class="space-y-2 mb-2"></div>
           <div class="space-y-2">
             <input type="text" id="reply-name-${fb.id}" placeholder="${REPLY_NAME_PH}"
               class="w-full px-3 py-1.5 rounded-lg text-[12px] outline-none"
               style="border:1.5px solid #e2e8f0; background:white; font-size:16px;"
               onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
             <div class="flex gap-2 items-center">
               <div class="relative flex-1">
                 <textarea id="reply-content-${fb.id}" rows="2" maxlength="500"
                   placeholder="${REPLY_CONTENT_PH}"
                   class="w-full px-3 py-1.5 pr-9 rounded-lg text-[13px] text-slate-800 outline-none resize-none"
                   style="border:1.5px solid #e2e8f0; background:white; font-size:16px;"
                   onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'"></textarea>
                 <button type="button" onclick="document.getElementById('reply-image-input-${fb.id}').click()"
                   class="absolute top-1/2 -translate-y-1/2 right-2 w-6 h-6 rounded-md flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:bg-indigo-50 transition-colors"
                   style="border:1px solid #e2e8f0; background:white;">
                   <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                 </button>
               </div>
               <button id="reply-submit-btn-${fb.id}" onclick="submitReply(${fb.id})"
                 class="px-4 py-2 text-white text-[12px] font-bold rounded-lg flex-shrink-0 border-0 flex items-center gap-1.5 disabled:opacity-60"
                 style="background:#4F46E5;">
                 ${REPLY_SUBMIT_LABEL}
               </button>
             </div>
             <input type="file" id="reply-image-input-${fb.id}" accept="image/*" multiple class="hidden"
                    onchange="handleReplyImage(this, ${fb.id})">
             <div id="reply-image-previews-${fb.id}" style="display:none;flex-wrap:wrap;gap:6px;"></div>
           </div>
         </div>
       </div>`
    : '';

  const card = document.createElement('div');
  card.id = `feedback-card-${fb.id}`;
  card.className = 'rounded-2xl overflow-hidden fade-in';
  card.style.cssText = `background:#ffffff; border:1.5px solid ${borderColor}; box-shadow:0 2px 12px rgba(0,0,0,0.04);`;
  card.innerHTML = `
    ${pinnedBanner}
    <div class="p-4 flex items-start gap-3">
      <div class="w-8 h-8 rounded-full flex items-center justify-center text-[13px] font-bold flex-shrink-0 text-white mt-0.5"
        style="background:linear-gradient(135deg,#6366f1,#a855f7);">${initial}</div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1 flex-wrap">
          <span class="text-[12px] font-semibold text-slate-600">${authorLabel}</span>
          <span class="text-[11px] text-slate-300">${fb.created_at}</span>
          ${implementedBadge}
        </div>
        <p class="text-[14px] text-slate-800 leading-relaxed mb-2">${fb.content}</p>
        ${fb.image_urls && fb.image_urls.length > 0 ? `
          <div class="relative cursor-pointer mb-2 inline-block" style="max-width:100%;"
               onclick='openGallery(${JSON.stringify(fb.image_urls)}, 0)'>
            <img src="${fb.image_urls[0]}" alt="" class="rounded-xl object-cover block"
                 style="max-height:200px;max-width:100%;border:1px solid rgba(226,232,240,0.8);">
            ${fb.image_urls.length > 1 ? `<div class="absolute inset-0 rounded-xl flex items-center justify-center" style="background:rgba(0,0,0,0.45);">
              <span style="color:white;font-size:22px;font-weight:800;text-shadow:0 1px 4px rgba(0,0,0,0.5);">+${fb.image_urls.length - 1}</span></div>` : ''}
          </div>` : ''}
        ${replyBtn ? `<div class="flex justify-end">${replyBtn}</div>` : ''}
      </div>
      ${upvoteBtn}
    </div>
    ${repliesSection}`;
  return card;
}

// ── Gallery / Lightbox ───────────────────────────────────────────────────────
let _gallery = [], _gIdx = 0;

function openGallery(urls, startIdx) {
  _gallery = Array.isArray(urls) ? urls : [urls];
  _gIdx = startIdx || 0;
  _renderGallery();
  document.getElementById('gallery-modal').style.display = 'flex';
}

function closeGallery() {
  document.getElementById('gallery-modal').style.display = 'none';
}

function galleryNav(dir) {
  _gIdx = Math.max(0, Math.min(_gallery.length - 1, _gIdx + dir));
  _renderGallery();
}

function _renderGallery() {
  document.getElementById('gallery-img').src = _gallery[_gIdx];
  document.getElementById('gallery-counter').textContent = `${_gIdx + 1} / ${_gallery.length}`;
  document.getElementById('gallery-prev').style.display = _gIdx > 0 ? 'flex' : 'none';
  document.getElementById('gallery-next').style.display = _gIdx < _gallery.length - 1 ? 'flex' : 'none';
  const thumbs = document.getElementById('gallery-thumbs');
  thumbs.style.display = _gallery.length > 1 ? 'flex' : 'none';
  thumbs.innerHTML = _gallery.map((url, i) =>
    `<img src="${url}" onclick="event.stopPropagation();_gIdx=${i};_renderGallery()"
          style="width:52px;height:52px;object-fit:cover;border-radius:8px;cursor:pointer;flex-shrink:0;
                 border:2px solid ${i===_gIdx?'#6366f1':'rgba(255,255,255,0.3)'};
                 opacity:${i===_gIdx?1:0.6};transition:all 0.15s;">`
  ).join('');
}

document.addEventListener('keydown', e => {
  const modal = document.getElementById('gallery-modal');
  if (modal.style.display === 'none') return;
  if (e.key === 'ArrowLeft') galleryNav(-1);
  if (e.key === 'ArrowRight') galleryNav(1);
  if (e.key === 'Escape') closeGallery();
});

// ── Feedback form multi-image upload ─────────────────────────────────────────
let fbFiles = [];

function handleFbImageSelect(input) {
  Array.from(input.files).forEach(f => fbFiles.push(f));
  input.value = '';
  _renderFbPreviews();
}

function _removeFbFile(idx) {
  const f = fbFiles[idx];
  if (f._blobUrl) URL.revokeObjectURL(f._blobUrl);
  fbFiles.splice(idx, 1);
  _renderFbPreviews();
}

function _renderFbPreviews() {
  const container = document.getElementById('fb-image-previews');
  if (fbFiles.length === 0) { container.style.display = 'none'; container.innerHTML = ''; return; }
  container.style.display = 'flex';
  container.innerHTML = fbFiles.map((f, i) => {
    if (!f._blobUrl) f._blobUrl = URL.createObjectURL(f);
    return `<div style="position:relative;flex-shrink:0;">
      <img src="${f._blobUrl}" style="width:64px;height:64px;object-fit:cover;border-radius:10px;border:1.5px solid #e2e8f0;display:block;">
      <button type="button" onclick="_removeFbFile(${i})"
        style="position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:#ef4444;border:none;color:white;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">✕</button>
    </div>`;
  }).join('');
}

function _clearFbFiles() {
  fbFiles.forEach(f => { if (f._blobUrl) URL.revokeObjectURL(f._blobUrl); });
  fbFiles = [];
  _renderFbPreviews();
}

document.getElementById('feedback-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('fb-submit-btn');

  // Client-side validation: user_choice requires name OR anonymous
  if (IDENTITY_MODE === 'user_choice') {
    const nameField = document.getElementById('feedback-author-name');
    const anonCb    = document.getElementById('feedback-anonymous');
    if (nameField && !anonCb?.checked && !nameField.value.trim()) {
      nameField.style.borderColor = '#ef4444';
      nameField.style.background  = 'rgba(239,68,68,0.04)';
      showToast("<%= j t('participate.feedback.name_or_anonymous_required', default: 'Vui lòng nhập tên hoặc chọn gửi ẩn danh') %>", true);
      const nameError = document.getElementById('name-error');
      if (nameError) nameError.style.display = 'block';
      nameField.focus();
      nameField.animate([
        { transform: 'translateX(0)' },
        { transform: 'translateX(-6px)' },
        { transform: 'translateX(6px)' },
        { transform: 'translateX(-4px)' },
        { transform: 'translateX(4px)' },
        { transform: 'translateX(0)' }
      ], { duration: 320, easing: 'ease-out' });
      return;
    }
  }

  btn.disabled = true;
  const spinner = document.getElementById('fb-submit-spinner');
  if (spinner) spinner.style.display = 'inline-block';

  // Use FormData with manually managed files
  const formData = new FormData(this);
  if (!formData.get('feedback[anonymous]')) formData.set('feedback[anonymous]', '0');
  fbFiles.forEach(f => formData.append('feedback[images][]', f));

  try {
    const res = await fetch(SUBMIT_URL, {
      method: 'POST',
      headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json' },
      body: formData
    });
    const data = await res.json();

    if (!res.ok) {
      showToast(data.error || 'Error', true);
      return;
    }

    showToast(data.message);
    this.reset();
    _clearFbFiles();
    const nameField = document.getElementById('feedback-author-name');
    if (nameField) {
      nameField.disabled = false;
      nameField.style.opacity = '1';
      nameField.style.borderColor = '#e2e8f0';
      nameField.style.background  = 'rgba(255,255,255,0.9)';
    }
    const ne = document.getElementById('name-error'); if (ne) ne.style.display = 'none';

    if (data.status === 'submitted' && data.feedback) {
      const list = document.getElementById('feedbacks-list');
      const emptyState = document.getElementById('empty-state');
      const card = renderFeedbackCard(data.feedback);
      list.insertBefore(card, list.firstChild);
      emptyState.classList.add('hidden');
      currentOffset += 1;
      // update sticky count
      const countEl = document.getElementById('sticky-feedback-count');
      if (countEl) {
        const cur = parseInt(countEl.textContent) || 0;
        countEl.textContent = `${cur + 1} ${countEl.textContent.replace(/^\d+\s*/, '')}`;
      }
    }
  } catch(err) {
    showToast('Network error', true);
  } finally {
    btn.disabled = false;
    if (spinner) spinner.style.display = 'none';
  }
});

async function loadMore() {
  const btn = document.getElementById('load-more-btn');
  btn.disabled = true;
  btn.textContent = '...';

  try {
    const res = await fetch(`${LIST_URL}?offset=${currentOffset}`, {
      headers: { 'Accept': 'application/json', 'X-CSRF-Token': CSRF }
    });
    const data = await res.json();
    const list = document.getElementById('feedbacks-list');

    data.feedbacks.forEach(fb => {
      list.appendChild(renderFeedbackCard(fb));
    });

    currentOffset += data.feedbacks.length;

    if (!data.has_more) {
      document.getElementById('load-more-wrap').classList.add('hidden');
    }
  } finally {
    btn.disabled = false;
    btn.textContent = "<%= I18n.locale.to_s == 'vi' ? 'Xem thêm góp ý' : 'Load more' %>";
  }
}

function toggleAnonymous(checked) {
  const nameField = document.getElementById('feedback-author-name');
  if (!nameField) return;
  if (checked) {
    nameField.required = false;
    nameField.disabled = true;
    nameField.value = '';
    nameField.style.opacity = '0.4';
  } else {
    nameField.required = true;
    nameField.disabled = false;
    nameField.style.opacity = '1';
  }
}

function toggleReplyForm(id) {
  const section = document.getElementById(`replies-${id}`);
  section.classList.toggle('hidden');
  if (!section.classList.contains('hidden')) {
    document.getElementById(`reply-content-${id}`)?.focus();
  }
}

// ── Reply multi-image upload ──────────────────────────────────────────────────
const replyFiles = {}; // { feedbackId: [File, ...] }

function handleReplyImage(input, feedbackId) {
  if (!replyFiles[feedbackId]) replyFiles[feedbackId] = [];
  Array.from(input.files).forEach(f => replyFiles[feedbackId].push(f));
  input.value = '';
  _renderReplyPreviews(feedbackId);
}

function _removeReplyFile(feedbackId, idx) {
  const f = replyFiles[feedbackId][idx];
  if (f && f._blobUrl) URL.revokeObjectURL(f._blobUrl);
  replyFiles[feedbackId].splice(idx, 1);
  _renderReplyPreviews(feedbackId);
}

function _renderReplyPreviews(feedbackId) {
  const container = document.getElementById(`reply-image-previews-${feedbackId}`);
  if (!container) return;
  const files = replyFiles[feedbackId] || [];
  if (files.length === 0) { container.style.display = 'none'; container.innerHTML = ''; return; }
  container.style.display = 'flex';
  container.innerHTML = files.map((f, i) => {
    if (!f._blobUrl) f._blobUrl = URL.createObjectURL(f);
    return `<div style="position:relative;flex-shrink:0;">
      <img src="${f._blobUrl}" style="width:52px;height:52px;object-fit:cover;border-radius:8px;border:1.5px solid #e2e8f0;display:block;">
      <button type="button" onclick="_removeReplyFile(${feedbackId},${i})"
        style="position:absolute;top:-5px;right:-5px;width:16px;height:16px;border-radius:50%;background:#ef4444;border:none;color:white;font-size:9px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">✕</button>
    </div>`;
  }).join('');
}

function _clearReplyFiles(feedbackId) {
  (replyFiles[feedbackId] || []).forEach(f => { if (f._blobUrl) URL.revokeObjectURL(f._blobUrl); });
  replyFiles[feedbackId] = [];
  _renderReplyPreviews(feedbackId);
}

async function submitReply(feedbackId) {
  const nameEl    = document.getElementById(`reply-name-${feedbackId}`);
  const contentEl = document.getElementById(`reply-content-${feedbackId}`);
  const btn       = document.getElementById(`reply-submit-btn-${feedbackId}`);
  const content   = contentEl.value.trim();
  if (!content) { contentEl.focus(); return; }

  // Loading state
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = `<span style="width:12px;height:12px;border:2px solid rgba(255,255,255,0.4);border-top-color:white;border-radius:50%;display:inline-block;animation:spin 0.7s linear infinite;"></span> ${REPLY_SUBMIT_LABEL}`;
  }

  const formData = new FormData();
  formData.append('feedback_id', feedbackId);
  formData.append('reply[content]', content);
  formData.append('reply[author_name]', nameEl.value.trim());
  (replyFiles[feedbackId] || []).forEach(f => formData.append('reply[images][]', f));

  const res = await fetch(REPLY_URL, {
    method: "POST",
    headers: { "X-CSRF-Token": CSRF, "Accept": "application/json" },
    body: formData
  });
  if (!res.ok) return;
  const data = await res.json();

  const list = document.getElementById(`replies-list-${feedbackId}`);
  const initial = data.anonymous ? "?" : (data.author_name || "?").charAt(0).toUpperCase();
  const authorLabel = data.anonymous ? ANONYMOUS_LABEL : data.author_name;
  const imageHtml = data.image_urls && data.image_urls.length > 0
    ? `<div class="relative cursor-pointer mt-1.5 inline-block"
            onclick='openGallery(${JSON.stringify(data.image_urls)}, 0)'>
         <img src="${data.image_urls[0]}" style="max-height:120px;max-width:100%;border-radius:8px;object-fit:cover;border:1px solid #e2e8f0;display:block;">
         ${data.image_urls.length > 1 ? `<div style="position:absolute;inset:0;background:rgba(0,0,0,0.45);border-radius:8px;display:flex;align-items:center;justify-content:center;">
           <span style="color:white;font-size:16px;font-weight:700;">+${data.image_urls.length - 1}</span></div>` : ''}
       </div>`
    : '';

  const div = document.createElement('div');
  div.className = 'flex gap-2';
  div.innerHTML = `
    <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0 mt-0.5" style="background:linear-gradient(135deg,#94a3b8,#64748b);">${initial}</div>
    <div class="flex-1 rounded-xl px-3 py-2" style="background:rgba(255,255,255,0.9); border:1px solid rgba(226,232,240,0.7);">
      <div class="flex items-baseline gap-2 mb-0.5">
        <span class="text-[11px] font-semibold text-slate-600">${authorLabel}</span>
        <span class="text-[10px] text-slate-300">${data.created_at}</span>
      </div>
      <p class="text-[13px] text-slate-700">${data.content}</p>
      ${imageHtml}
    </div>`;
  list.appendChild(div);
  contentEl.value = '';
  nameEl.value = '';
  _clearReplyFiles(feedbackId);
  if (btn) { btn.disabled = false; btn.innerHTML = REPLY_SUBMIT_LABEL; }
}

// ── Turbo cache cleanup ───────────────────────────────────────────────────────
// Clears all preview UIs before Turbo caches the page, so restored cached
// pages never show stale X buttons or open gallery.
document.addEventListener('turbo:before-cache', () => {
  // Reset feedback form previews
  _clearFbFiles();
  // Reset all reply previews
  Object.keys(replyFiles).forEach(id => _clearReplyFiles(parseInt(id)));
  // Close gallery
  const modal = document.getElementById('gallery-modal');
  if (modal) modal.style.display = 'none';
});

async function toggleUpvote(btn, feedbackId) {
  btn.disabled = true;
  try {
    const res = await fetch(UPVOTE_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-CSRF-Token": CSRF, "Accept": "application/json" },
      body: JSON.stringify({ feedback_id: feedbackId })
    });
    if (!res.ok) return;
    const data = await res.json();
    btn.querySelector(".upvote-count").textContent = data.count;
    const arrow = btn.querySelector("span:first-child");
    if (data.upvoted) {
      btn.style.background = 'rgba(99,102,241,0.08)';
      btn.style.borderColor = '#6366f1';
      btn.style.color = '#6366f1';
      arrow.textContent = "▲";
    } else {
      btn.style.background = 'white';
      btn.style.borderColor = '#e2e8f0';
      btn.style.color = '#64748b';
      arrow.textContent = "△";
    }
  } finally {
    btn.disabled = false;
  }
}
</script>
