  let _currentFbId = null;
  let _activeCat = 0;

  function buildPicker() {
    const el = document.createElement('div');
    el.id = 'shared-emoji-picker';
    el.style.cssText = 'position:fixed; z-index:9999; background:white; border:1px solid #e2e8f0; border-radius:16px; display:none; box-shadow:0 8px 32px rgba(0,0,0,0.14); width:272px; overflow:hidden;';
    el.onclick = e => e.stopPropagation();

    // Tab bar
    const tabs = document.createElement('div');
    tabs.id = 'ep-tabs';
    tabs.style.cssText = 'display:flex; overflow-x:auto; padding:8px 8px 0; gap:2px; scrollbar-width:none; border-bottom:1px solid #f1f5f9;';
    tabs.style.msOverflowStyle = 'none';

    EMOJI_CATS.forEach((cat, i) => {
      const tb = document.createElement('button');
      tb.type = 'button';
      tb.title = cat.label;
      tb.textContent = cat.icon;
      tb.dataset.catIdx = i;
      tb.style.cssText = 'border:none; cursor:pointer; font-size:18px; padding:4px 6px; border-radius:8px; line-height:1; flex-shrink:0; transition:background 0.1s;';
      tb.style.background = i === _activeCat ? '#f1f5f9' : 'transparent';
      tb.onclick = () => { _activeCat = i; _renderGrid(el); _highlightTab(tabs); };
      tabs.appendChild(tb);
    });
    el.appendChild(tabs);

    // Grid container
    const gridWrap = document.createElement('div');
    gridWrap.id = 'ep-grid-wrap';
    gridWrap.style.cssText = 'height:200px; overflow-y:auto; padding:8px; scrollbar-width:none; -ms-overflow-style:none;';
    gridWrap.style.setProperty('::-webkit-scrollbar', 'display:none');
    el.appendChild(gridWrap);

    document.body.appendChild(el);
    _renderGrid(el);
    return el;
  }

  function _highlightTab(tabs) {
    tabs.querySelectorAll('button').forEach(b => {
      b.style.background = parseInt(b.dataset.catIdx) === _activeCat ? '#f1f5f9' : 'transparent';
    });
  }

  function _renderGrid(el) {
    const wrap = el.querySelector('#ep-grid-wrap');
    wrap.innerHTML = '';
    wrap.scrollTop = 0;
    const grid = document.createElement('div');
    grid.style.cssText = 'display:grid; grid-template-columns:repeat(7,1fr); gap:1px;';
    EMOJI_CATS[_activeCat].emojis.forEach(emoji => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = emoji;
      btn.style.cssText = 'border:none; background:transparent; cursor:pointer; font-size:22px; padding:4px; border-radius:8px; line-height:1; transition:background 0.15s, transform 0.15s;';
      btn.onmouseenter = () => btn.style.background = '#f1f5f9';
      btn.onmouseleave = () => btn.style.background = 'transparent';
      btn.onclick = () => {
        insertEmoji(_currentFbId, emoji);
        btn.style.background = '#dcfce7';
        btn.style.transform = 'scale(1.3)';
        setTimeout(() => { btn.style.transform = 'scale(1)'; btn.style.background = 'transparent'; }, 220);
      };
      grid.appendChild(btn);
    });
    wrap.appendChild(grid);
  }

  function insertEmoji(feedbackId, emoji) {
    const ta = feedbackId === '__fb__'
      ? document.getElementById('fb-content')
      : document.getElementById('reply-content-' + feedbackId);
    if (!ta) return;
    const s = ta.selectionStart, e = ta.selectionEnd;
    ta.value = ta.value.slice(0, s) + emoji + ta.value.slice(e);
    ta.selectionStart = ta.selectionEnd = s + emoji.length;
    ta.focus();
  }

  function closePicker() {
    const p = document.getElementById('shared-emoji-picker');
    if (p) p.style.display = 'none';
    document.removeEventListener('click', closePicker);
  }

  window.openFbEmojiPicker = function(triggerEl) {
    window.openEmojiPicker('__fb__', triggerEl);
  };

  window.openEmojiPicker = function(feedbackId, triggerEl) {
    let picker = document.getElementById('shared-emoji-picker') || buildPicker();
    _currentFbId = feedbackId;

    const rect = triggerEl.getBoundingClientRect();
    // Position above the trigger button
    picker.style.display = 'block';
    const ph = picker.offsetHeight;
    let top = rect.top - ph - 8;
    let left = rect.left;
    // Keep within viewport
    if (top < 8) top = rect.bottom + 8;
    if (left + 272 > window.innerWidth - 8) left = window.innerWidth - 280;
    picker.style.top  = top + 'px';
    picker.style.left = left + 'px';

    setTimeout(() => document.addEventListener('click', closePicker), 0);
  };
})();
