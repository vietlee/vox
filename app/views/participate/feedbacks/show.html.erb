<% content_for :title, @board.title %>

<!-- Image Gallery Lightbox -->
<div id="gallery-modal" style="display:none; position:fixed; inset:0; z-index:9999; background:rgba(0,0,0,0.92); flex-direction:column; align-items:center; justify-content:center;"
     onclick="closeGallery()">
  <button onclick="closeGallery()" style="position:absolute; top:16px; right:16px; width:36px; height:36px; border-radius:50%; background:rgba(255,255,255,0.15); border:none; color:white; font-size:18px; cursor:pointer; display:flex; align-items:center; justify-content:center;">✕</button>
  <button id="gallery-prev" onclick="event.stopPropagation(); galleryNav(-1)" style="position:absolute; left:16px; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.15); border:none; color:white; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center;">‹</button>
  <img id="gallery-img" src="" alt="" onclick="event.stopPropagation()"
       style="max-height:80vh; max-width:90vw; object-fit:contain; border-radius:12px; box-shadow:0 8px 40px rgba(0,0,0,0.5);">
  <div id="gallery-counter" style="color:rgba(255,255,255,0.7); margin-top:14px; font-size:13px; font-weight:600;"></div>
  <!-- Thumbnails -->
  <div id="gallery-thumbs" onclick="event.stopPropagation()"
       style="display:none; gap:8px; margin-top:12px; max-width:90vw; overflow-x:auto; padding:4px 0;"></div>
  <button id="gallery-next" onclick="event.stopPropagation(); galleryNav(1)" style="position:absolute; right:16px; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.15); border:none; color:white; font-size:24px; cursor:pointer; display:flex; align-items:center; justify-content:center;">›</button>
</div>

<style>
  html, body { background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height: 100%; scrollbar-width: none; -ms-overflow-style: none; }
  html::-webkit-scrollbar, body::-webkit-scrollbar { display: none; }
  /* Prevent iOS Safari auto-zoom on input focus (requires font-size >= 16px) */
  input, textarea, select { font-size: 16px !important; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes spin { to { transform: rotate(360deg); } }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
  @keyframes vm-bar  { 0%,100%{transform:scaleY(0.18)} 50%{transform:scaleY(1)} }
  @keyframes vm-ring { 0%{transform:scale(1);opacity:0.6} 100%{transform:scale(2.2);opacity:0} }
  @keyframes vm-modal-in { from{opacity:0;transform:scale(0.92)} to{opacity:1;transform:scale(1)} }
  @keyframes vm-check { 0%{stroke-dashoffset:40} 100%{stroke-dashoffset:0} }
  .fade-in { animation: fadeIn 0.35s ease forwards; }
  .reply-section { transition: all 0.2s ease; }
  .vm-bar { transform-origin: bottom; animation: vm-bar 0.65s ease-in-out infinite; }
  #ep-grid-wrap::-webkit-scrollbar { display: none; }
  #ep-tabs::-webkit-scrollbar { display: none; }
</style>

<% content_for :nav_right do %>
  <div class="flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-bold text-indigo-700" style="background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.15);">
    💬 <%= t("kpi.feedback") %>
  </div>
<% end %>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%)">

  <!-- Board header — scrolls with page -->
  <div class="border-b" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%); border-color:rgba(226,232,240,0.7);">
    <div class="max-w-2xl mx-auto px-4 py-5 text-center">
      <% if @board.logo.attached? %>
        <img src="<%= url_for(@board.logo) %>" alt="<%= @board.title %>"
             class="object-contain mx-auto mb-2"
             style="max-height:56px; max-width:200px;">
      <% else %>
        <div class="w-10 h-10 rounded-xl flex items-center justify-center text-[22px] mx-auto mb-2"
             style="background:linear-gradient(135deg,#6366f1,#a855f7); box-shadow:0 4px 12px rgba(99,102,241,0.3);">💬</div>
      <% end %>
      <h1 class="text-[18px] font-extrabold text-slate-900 tracking-tight leading-snug mb-1"><%= @board.title %></h1>
      <% if @board.description.present? %>
        <p class="text-[12px] text-slate-500 mb-1"><%= @board.description %></p>
      <% end %>
      <span id="sticky-feedback-count" class="text-[11px] text-slate-400">
        <%= @board.feedbacks.visible.count %> <%= t("participate.feedback.feedbacks_count") %>
      </span>
    </div>
  </div>

  <!-- Scrollable content -->
  <div class="max-w-3xl mx-auto w-full px-4 pt-4 pb-5 fade-in">

    <!-- Flash -->
    <% if notice %>
      <div class="flex items-center gap-2 px-4 py-3 mb-4 rounded-2xl text-[13px] font-semibold fade-in" style="background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.2); color:#065f46;">
        ✓ <%= notice %>
      </div>
    <% end %>
    <% if @feedback.errors.any? %>
      <div class="px-4 py-3 mb-4 rounded-2xl text-[13px] font-semibold fade-in" style="background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2); color:#991b1b;">
        <%= @feedback.errors.full_messages.join(", ") %>
      </div>
    <% end %>

    <!-- Flash toast (AJAX) -->
    <div id="feedback-toast" style="display:none;" class="mb-4 px-4 py-3 rounded-xl text-[13px] font-semibold fade-in"></div>

    <!-- Submit form -->
    <div class="rounded-2xl p-5 mb-5" style="background:#ffffff; border:1px solid rgba(99,102,241,0.12); box-shadow:0 4px 24px rgba(99,102,241,0.08);">
      <p class="text-[13px] font-bold text-slate-700 mb-3"><%= t("participate.feedback.submit_title") %></p>
      <form id="feedback-form" class="space-y-3" novalidate>

        <!-- Unified input box (same style as reply box) -->
        <div class="rounded-2xl overflow-hidden transition-all"
             style="border:1.5px solid #e2e8f0; background:white;"
             onfocusin="this.style.borderColor='#6366f1'" onfocusout="this.style.borderColor='#e2e8f0'">

          <textarea id="fb-content" name="feedback[content]" rows="3" required maxlength="1000"
            data-richtext
            placeholder="<%= t("participate.feedback.content_placeholder") %>"
            class="w-full"></textarea>

          <div id="fb-image-previews" style="display:none; flex-wrap:wrap; gap:6px; padding:0 12px 8px;"></div>

          <div class="flex items-center justify-between px-3 py-2" style="border-top:1px solid #f1f5f9;">
            <div class="flex items-center gap-1">
              <button type="button" onclick="openFbEmojiPicker(this)"
                class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:text-amber-500 hover:bg-amber-50 transition-colors border-0 bg-transparent cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
              </button>
              <% if @board.allow_voice_input? %>
                <button type="button" id="fb-voice-btn" onclick="openVoiceModal()"
                  title="<%= t('participate.feedback.voice_record') %>"
                  class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:text-red-500 hover:bg-red-50 transition-colors border-0 bg-transparent cursor-pointer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                </button>
              <% end %>
              <button type="button" onclick="document.getElementById('fb-image-input').click()"
                class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:text-indigo-500 hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              </button>
            </div>
            <button type="submit" id="fb-submit-btn"
              class="w-8 h-8 rounded-full flex items-center justify-center text-indigo-500 hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer disabled:opacity-40">
              <span id="fb-submit-spinner" style="display:none; width:16px; height:16px; border:2px solid #e0e7ff; border-top-color:#6366f1; border-radius:50%; animation:spin 0.7s linear infinite; flex-shrink:0;"></span>
              <svg id="fb-submit-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </div>
        </div>

        <% if @board.public_identity? || @board.user_choice? %>
          <div class="grid grid-cols-2 gap-2">
            <input type="text" id="feedback-author-name" name="feedback[author_name]"
              placeholder="<%= t("participate.feedback.name_placeholder") %>"
              <% if @board.public_identity? %>required<% end %>
              class="w-full px-3 py-2.5 rounded-xl text-[13px] outline-none"
              style="border:1.5px solid #e2e8f0; background:rgba(255,255,255,0.9); font-size:16px;"
              onfocus="this.style.borderColor='#6366f1'; const se=document.getElementById('fb-submit-error');if(se)se.style.display='none';"
              onblur="this.style.borderColor='#e2e8f0'">
            <input type="email" id="fb-email" name="feedback[author_email]"
              placeholder="<%= t("participate.feedback.email_placeholder") %>"
              class="w-full px-3 py-2.5 rounded-xl text-[13px] outline-none"
              style="border:1.5px solid #e2e8f0; background:rgba(255,255,255,0.9); font-size:16px;"
              onfocus="this.style.borderColor='#6366f1'" onblur="this.style.borderColor='#e2e8f0'">
          </div>
        <% end %>

        <% if @board.user_choice? %>
          <label class="flex items-center gap-2 cursor-pointer text-[13px] text-slate-500">
            <input type="checkbox" name="feedback[anonymous]" value="1" id="feedback-anonymous"
              class="w-4 h-4 accent-indigo-600" onchange="toggleAnonymous(this.checked)">
            <%= t("participate.feedback.anonymous_label") %>
          </label>
        <% end %>

        <input type="file" id="fb-image-input" accept="image/*" multiple class="hidden"
               onchange="handleFbImageSelect(this)">

        <div id="fb-submit-error" style="display:none; padding:10px 14px; border-radius:10px; font-size:13px; font-weight:600; color:#991b1b; background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.2);"></div>
      </form>
    </div>

    <!-- Feedbacks list -->
    <% if @feedbacks.any? || @has_more %>
      <p class="text-[11px] font-bold text-slate-400 uppercase tracking-widest mb-3 px-1"><%= t("participate.feedback.all_feedbacks") %></p>
    <% end %>

    <div id="feedbacks-list" class="space-y-3">
      <% @feedbacks.each do |fb| %>
        <div id="feedback-card-<%= fb.id %>" class="rounded-2xl overflow-hidden fade-in" style="background:#ffffff; border:1.5px solid <%= fb.pinned? ? '#fbbf24' : 'rgba(226,232,240,0.8)' %>; box-shadow:0 2px 12px rgba(0,0,0,0.04);">
          <% if fb.pinned? %>
            <div class="px-4 py-1.5 flex items-center gap-1.5" style="background:rgba(251,191,36,0.12);">
              <span class="text-[10px] font-bold text-amber-600 uppercase tracking-wider">📌 <%= t("participate.feedback.pinned") %></span>
            </div>
          <% end %>
          <div class="p-4 flex items-start gap-3">
            <div class="w-8 h-8 rounded-full flex items-center justify-center text-[13px] font-bold flex-shrink-0 text-white mt-0.5"
              style="background:linear-gradient(135deg,#6366f1,#a855f7);">
              <%= fb.anonymous? || fb.author_name.blank? ? "?" : fb.author_name.first.upcase %>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="text-[12px] font-semibold text-slate-600">
                  <%= fb.anonymous? || fb.author_name.blank? ? t("participate.feedback.anonymous") : fb.author_name %>
                </span>
                <span class="text-[11px] text-slate-300"><%= I18n.l(fb.created_at, format: :short) %></span>
                <% if fb.implemented? %>
                  <span class="px-2 py-0.5 rounded-full text-[10px] font-bold text-emerald-700" style="background:rgba(16,185,129,0.1);"><%= t("participate.feedback.implemented") %></span>
                <% end %>
              </div>
              <% if fb.content.to_s.strip.start_with?("<") %>
                <div class="prose prose-sm max-w-none text-[14px] text-slate-800 leading-relaxed mb-2"><%= render_vote_desc(fb.content) %></div>
              <% else %>
                <p class="text-[14px] text-slate-800 leading-relaxed mb-2"><%= fb.content %></p>
              <% end %>
              <% if fb.images.attached? %>
                <% img_urls = fb.images.map { |img| url_for(img) }; max_t = 4 %>
                <div class="flex flex-wrap gap-1.5 mb-2">
                  <% img_urls.first(max_t).each_with_index do |url, i| %>
                    <div class="relative flex-shrink-0 cursor-pointer"
                         style="width:72px; height:72px;"
                         onclick='openGallery(<%= img_urls.to_json %>, <%= i %>)'>
                      <img src="<%= url %>" alt=""
                           class="w-full h-full rounded-xl object-cover"
                           style="border:1px solid rgba(226,232,240,0.8);">
                      <% if i == max_t - 1 && img_urls.size > max_t %>
                        <div class="absolute inset-0 rounded-xl flex items-center justify-center"
                             style="background:rgba(0,0,0,0.5);">
                          <span class="text-white font-bold" style="font-size:15px;">+<%= img_urls.size - max_t %></span>
                        </div>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              <% end %>
              <% if fb.admin_reply.present? || fb.admin_reply_image.attached? %>
                <div class="mt-2 pt-2 border-t border-slate-100">
                  <div class="flex items-start gap-2">
                    <div class="w-5 h-5 rounded-full flex items-center justify-center text-[9px] font-bold text-white flex-shrink-0 mt-0.5"
                         style="background:linear-gradient(135deg,#6366f1,#4f46e5);">A</div>
                    <div class="flex-1 rounded-xl px-3 py-2" style="background:rgba(99,102,241,0.06); border:1px solid rgba(99,102,241,0.15);">
                      <div class="text-[10px] font-bold text-indigo-500 mb-1">↩ Admin</div>
                      <% if fb.admin_reply.present? %>
                        <p class="text-[13px] text-slate-700 leading-relaxed"><%= fb.admin_reply %></p>
                      <% end %>
                      <% if fb.admin_reply_image.attached? %>
                        <div class="relative flex-shrink-0 cursor-pointer mt-1.5"
                             style="width:72px; height:72px;"
                             onclick="openGallery(['<%= j url_for(fb.admin_reply_image) %>'], 0)">
                          <img src="<%= url_for(fb.admin_reply_image) %>" alt=""
                               class="w-full h-full rounded-lg object-cover"
                               style="border:1px solid rgba(99,102,241,0.15);">
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
              <% if @board.allow_replies? %>
                <div class="flex justify-end mt-1">
                  <button onclick="toggleReplyForm(<%= fb.id %>)"
                    class="text-[11px] font-semibold text-indigo-500 hover:text-indigo-700 border-0 bg-transparent p-0">
                    💬 <%= fb.feedback_replies.count > 0 ? "#{fb.feedback_replies.count} #{t("participate.feedback.reply_count")}" : t("participate.feedback.reply_label") %>
                  </button>
                </div>
              <% end %>
            </div>
            <% if @board.allow_upvotes? %>
              <% upvoted = @upvoted_ids.include?(fb.id) %>
              <button data-feedback-id="<%= fb.id %>" onclick="toggleUpvote(this, <%= fb.id %>)"
                class="flex flex-col items-center gap-0.5 px-2.5 py-2 rounded-xl border transition-all cursor-pointer flex-shrink-0 upvote-btn"
                style="<%= upvoted ? 'background:rgba(99,102,241,0.08);border-color:#6366f1;color:#6366f1;' : 'background:white;border-color:#e2e8f0;color:#64748b;' %>">
                <span class="text-[15px] leading-none"><%= upvoted ? '▲' : '△' %></span>
                <span class="text-[12px] font-bold upvote-count"><%= fb.upvotes_count %></span>
              </button>
            <% end %>
          </div>
          <% if @board.allow_replies? %>
            <div id="replies-<%= fb.id %>" class="hidden border-t reply-section" style="border-color:rgba(226,232,240,0.6); background:rgba(248,250,252,0.5);">
              <div class="ml-11 mr-4 my-3 pl-3" style="border-left:2px solid rgba(99,102,241,0.18);">
                <div id="replies-list-<%= fb.id %>" class="space-y-2 mb-2">
                  <% fb.feedback_replies.order(:created_at).each do |r| %>
                    <div class="flex gap-2">
                      <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0 mt-0.5" style="background:linear-gradient(135deg,#94a3b8,#64748b);">
                        <%= r.anonymous? ? "?" : r.author_name.to_s.first.upcase %>
                      </div>
                      <div class="flex-1 rounded-xl px-3 py-2" style="background:rgba(255,255,255,0.9); border:1px solid rgba(226,232,240,0.7);">
                        <div class="flex items-baseline gap-2 mb-0.5">
                          <span class="text-[11px] font-semibold text-slate-600"><%= r.anonymous? ? t("participate.feedback.anonymous") : r.author_name %></span>
                          <span class="text-[10px] text-slate-300"><%= I18n.l(r.created_at, format: :short) %></span>
                        </div>
                        <p class="text-[13px] text-slate-700"><%= r.content %></p>
                        <% if r.images.attached? %>
                          <% r_urls = r.images.map { |img| url_for(img) }; max_rt = 4 %>
                          <div class="flex flex-wrap gap-1.5 mt-1.5">
                            <% r_urls.first(max_rt).each_with_index do |url, i| %>
                              <div class="relative flex-shrink-0 cursor-pointer"
                                   style="width:60px; height:60px;"
                                   onclick='openGallery(<%= r_urls.to_json %>, <%= i %>)'>
                                <img src="<%= url %>" alt=""
                                     class="w-full h-full rounded-lg object-cover"
                                     style="border:1px solid #e2e8f0;">
                                <% if i == max_rt - 1 && r_urls.size > max_rt %>
                                  <div class="absolute inset-0 rounded-lg flex items-center justify-center"
                                       style="background:rgba(0,0,0,0.5);">
                                    <span class="text-white font-bold" style="font-size:13px;">+<%= r_urls.size - max_rt %></span>
                                  </div>
                                <% end %>
                              </div>
                            <% end %>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
                <div>
                  <div class="rounded-2xl overflow-hidden transition-all"
                       style="border:1.5px solid #e2e8f0; background:white;"
                       onfocusin="this.style.borderColor='#6366f1'" onfocusout="this.style.borderColor='#e2e8f0'">
                    <input type="text" id="reply-name-<%= fb.id %>"
                      value="<%= j @reply_default_name %>"
                      placeholder="<%= t("participate.feedback.reply_name_placeholder") %>"
                      class="w-full px-4 pt-3 pb-0 text-[13px] font-semibold text-slate-600 outline-none bg-transparent block"
                      style="border:none; font-size:13px;">
                    <textarea id="reply-content-<%= fb.id %>" rows="2" maxlength="500"
                      placeholder="<%= t("participate.feedback.reply_content_placeholder") %>"
                      class="w-full px-4 pt-2 pb-2 text-[13px] text-slate-800 outline-none resize-none bg-transparent block"
                      style="border:none; font-size:15px;"></textarea>
                    <div id="reply-image-previews-<%= fb.id %>" style="display:none; flex-wrap:wrap; gap:6px; padding:0 12px 8px;"></div>
                    <div class="flex items-center justify-between px-3 py-2" style="border-top:1px solid #f1f5f9;">
                      <div class="flex items-center gap-1">
                        <button type="button" onclick="openEmojiPicker(<%= fb.id %>, this)"
                          class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:text-amber-500 hover:bg-amber-50 transition-colors border-0 bg-transparent cursor-pointer">
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                        </button>
                        <button type="button" onclick="document.getElementById('reply-image-input-<%= fb.id %>').click()"
                          class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:text-indigo-500 hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer">
                          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                        </button>
                      </div>
                      <button id="reply-submit-btn-<%= fb.id %>" onclick="submitReply(<%= fb.id %>)"
                        class="w-8 h-8 rounded-full flex items-center justify-center text-indigo-500 hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer disabled:opacity-40">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                      </button>
                    </div>
                  </div>
                  <input type="file" id="reply-image-input-<%= fb.id %>" accept="image/*" multiple class="hidden"
                         onchange="handleReplyImage(this, <%= fb.id %>)">
