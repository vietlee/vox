        <button onclick="closeVoiceModal()"
          style="width:28px; height:28px; border-radius:50%; border:none;
                 background:rgba(255,255,255,0.12); color:rgba(255,255,255,0.7); font-size:13px;
                 cursor:pointer; display:flex; align-items:center; justify-content:center;
                 transition:background 0.15s; flex-shrink:0;"
          onmouseenter="this.style.background='rgba(255,255,255,0.2)'"
