</div>

<script>
const SUBMIT_URL   = "<%= submit_feedback_path(@board.slug) %>";
const LIST_URL     = "<%= list_feedbacks_path(@board.slug) %>";
const UPVOTE_URL   = "<%= upvote_feedback_path(@board.slug) %>";
const REPLY_URL    = "<%= reply_feedback_path(@board.slug) %>";
const VOICE_URL    = "<%= @board.allow_voice_input? ? feedback_voice_transcribe_path(@board.slug) : '' %>";
const CSRF         = document.querySelector('meta[name="csrf-token"]')?.content;
const ALLOW_UPVOTES    = <%= @board.allow_upvotes? ? 'true' : 'false' %>;
const ALLOW_REPLIES    = <%= @board.allow_replies? ? 'true' : 'false' %>;
const ALLOW_VOICE      = <%= @board.allow_voice_input? ? 'true' : 'false' %>;
const AUTO_MODERATION  = <%= @board.auto_moderation? ? 'true' : 'false' %>;
const BOARD_SLUG       = "<%= @board.slug %>";
const IDENTITY_MODE    = "<%= @board.identity_mode %>";
const I18N_VOICE_RECORD          = "<%= j t('participate.feedback.voice_record') %>";
const I18N_VOICE_RECORDING       = "<%= j t('participate.feedback.voice_recording') %>";
const I18N_VOICE_PROCESSING      = "<%= j t('participate.feedback.voice_processing') %>";
const I18N_VOICE_MODAL_TITLE     = "<%= j t('participate.feedback.voice_modal_title') %>";
const I18N_VOICE_HINT_START      = "<%= j t('participate.feedback.voice_hint_start') %>";
const I18N_VOICE_STATUS_REC      = "<%= j t('participate.feedback.voice_status_recording') %>";
const I18N_VOICE_HINT_STOP       = "<%= j t('participate.feedback.voice_hint_stop') %>";
const I18N_VOICE_STATUS_PROC     = "<%= j t('participate.feedback.voice_status_processing') %>";
const I18N_VOICE_STATUS_READY    = "<%= j t('participate.feedback.voice_status_ready') %>";
const I18N_VOICE_STARTING        = "<%= j t('participate.feedback.voice_starting') %>";
const I18N_VOICE_NO_BROWSER      = "<%= j t('participate.feedback.voice_no_browser_support') %>";
const I18N_VOICE_MIC_DENIED      = "<%= j t('participate.feedback.voice_mic_denied') %>";
const I18N_VOICE_MIC_ERROR       = "<%= j t('participate.feedback.voice_mic_error') %>";
const I18N_VOICE_NO_AUDIO_MSG    = "<%= j t('participate.feedback.voice_no_audio_msg') %>";
const I18N_VOICE_GENERIC_ERROR   = "<%= j t('participate.feedback.voice_generic_error') %>";
const I18N_VOICE_NO_SPEECH       = "<%= j t('participate.feedback.voice_no_speech') %>";
const I18N_VOICE_CONN_ERROR      = "<%= j t('participate.feedback.voice_connection_error') %>";
const I18N_VOICE_HINT_RETRY      = "<%= j t('participate.feedback.voice_hint_retry') %>";
const I18N_LOAD_MORE             = "<%= j t('participate.feedback.load_more_feedbacks') %>";
const ANONYMOUS_LABEL = "<%= j t('participate.feedback.anonymous') %>";
const REPLY_LABEL     = "<%= j t('participate.feedback.reply_label') %>";
const REPLY_COUNT_LABEL = "<%= j t('participate.feedback.reply_count') %>";
const IMPLEMENTED_LABEL = "<%= j t('participate.feedback.implemented') %>";
const PINNED_LABEL    = "<%= j t('participate.feedback.pinned') %>";
const REPLY_NAME_PH        = "<%= j t('participate.feedback.reply_name_placeholder') %>";
const REPLY_DEFAULT_NAME   = "<%= j @reply_default_name %>";
const REPLY_CONTENT_PH = "<%= j t('participate.feedback.reply_content_placeholder') %>";
const REPLY_SUBMIT_LABEL = "<%= j t('participate.feedback.reply_submit') %>";

let currentOffset = <%= @feedbacks.size %>;

// Restore any pending-moderation cards from previous session on DOMContentLoaded
document.addEventListener('DOMContentLoaded', loadPendingCards);

function showToast(message, isError = false) {
  const toast = document.getElementById('feedback-toast');
  toast.textContent = message;
  toast.style.background  = isError ? 'rgba(239,68,68,0.08)'       : 'rgba(16,185,129,0.1)';
  toast.style.border      = isError ? '1px solid rgba(239,68,68,0.2)' : '1px solid rgba(16,185,129,0.2)';
  toast.style.color       = isError ? '#991b1b'                     : '#065f46';
  toast.style.display     = 'block';
  setTimeout(() => { toast.style.display = 'none'; }, 4000);
}

function showRateLimitBanner(retryAfter) {
  // If already counting down, ignore new calls
  if (window._fbRateLimitActive) return;
  window._fbRateLimitActive = true;

  // Disable submit button for the entire cooldown
  const btn     = document.getElementById('fb-submit-btn');
  const spinner = document.getElementById('fb-submit-spinner');
  const icon    = document.getElementById('fb-submit-icon');
  if (btn) { btn.disabled = true; btn.style.opacity = '0.45'; }
  if (spinner) spinner.style.display = 'none';
  if (icon)    icon.style.display    = 'inline-block';

  let banner = document.getElementById('fb-rate-banner');
  if (!banner) {
    banner = document.createElement('div');
    banner.id = 'fb-rate-banner';
    banner.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:9999;background:#1e293b;color:#fff;padding:12px 20px;border-radius:12px;font-size:13px;font-weight:600;box-shadow:0 8px 24px rgba(0,0,0,0.3);display:flex;align-items:center;gap:10px;white-space:nowrap;';
    document.body.appendChild(banner);
  }

  let secs = parseInt(retryAfter) || 60;
  const tick = () => {
    banner.innerHTML = `⏱ Quá nhiều yêu cầu — thử lại sau <span style="font-variant-numeric:tabular-nums;min-width:28px;display:inline-block;">${secs}s</span>`;
    if (secs <= 0) {
      banner.remove();
      window._fbRateLimitActive = false;
      // Re-enable submit button
      if (btn) { btn.disabled = false; btn.style.opacity = '1'; }
      return;
    }
    secs--;
    setTimeout(tick, 1000);
  };
  tick();
}

// ── Pending moderation persistence (localStorage) ─────────────────────────────
const PENDING_KEY = `pending_moderation_${BOARD_SLUG}`;
const PENDING_TTL = 24 * 60 * 60 * 1000; // 24 hours

function savePendingCard(fb) {
  try {
    const saved = JSON.parse(localStorage.getItem(PENDING_KEY) || '[]');
    // avoid duplicates
    const deduped = saved.filter(s => s.id !== fb.id);
    deduped.unshift({ ...fb, savedAt: Date.now() });
    // keep max 20 entries, drop expired
    const fresh = deduped.filter(s => Date.now() - s.savedAt < PENDING_TTL).slice(0, 20);
    localStorage.setItem(PENDING_KEY, JSON.stringify(fresh));
  } catch(e) {}
}

async function loadPendingCards() {
  try {
    const saved = JSON.parse(localStorage.getItem(PENDING_KEY) || '[]');
    const fresh = saved.filter(s => Date.now() - s.savedAt < PENDING_TTL);
    if (!fresh.length) {
      localStorage.setItem(PENDING_KEY, JSON.stringify([]));
      return;
    }

    // Verify with server which IDs still exist (not deleted by admin)
    const ids = fresh.map(s => s.id);
    let existingOnServer = new Set(ids); // fallback: assume all exist
    try {
      const verifyUrl = '<%= verify_pending_feedbacks_path(@board.slug) %>?ids[]=' + ids.join('&ids[]=');
      const res = await fetch(verifyUrl, { headers: { 'Accept': 'application/json' } });
      if (res.ok) {
        const data = await res.json();
        existingOnServer = new Set(data.existing);
      }
    } catch(e) {}

    // Remove deleted IDs from localStorage
    const verified = fresh.filter(s => existingOnServer.has(s.id));
    localStorage.setItem(PENDING_KEY, JSON.stringify(verified));
    if (!verified.length) return;

    const list = document.getElementById('feedbacks-list');
    if (!list) return;

    // IDs already rendered by server (already visible/approved)
    const renderedIds = new Set(
      Array.from(list.querySelectorAll('[id^="feedback-card-"]'))
        .map(el => parseInt(el.id.replace('feedback-card-', '')))
    );

    let added = 0;
    [...verified].reverse().forEach(fb => {
      if (renderedIds.has(fb.id)) return;
      const card = renderFeedbackCard(fb, true);
      list.insertBefore(card, list.firstChild);
      added++;
    });

    if (added > 0) {
      document.getElementById('empty-state')?.classList.add('hidden');
    }
  } catch(e) {}
}

function renderFeedbackCard(fb, pendingModeration = false) {
  const initial = fb.anonymous || !fb.author_name ? '?' : fb.author_name.charAt(0).toUpperCase();
  const authorLabel = fb.anonymous || !fb.author_name ? ANONYMOUS_LABEL : fb.author_name;
  const borderColor = fb.pinned ? '#fbbf24' : 'rgba(226,232,240,0.8)';

  const pinnedBanner = fb.pinned
    ? `<div class="px-4 py-1.5 flex items-center gap-1.5" style="background:rgba(251,191,36,0.12);">
         <span class="text-[10px] font-bold text-amber-600 uppercase tracking-wider">📌 ${PINNED_LABEL}</span>
       </div>`
    : '';

  const implementedBadge = fb.implemented
    ? `<span class="px-2 py-0.5 rounded-full text-[10px] font-bold text-emerald-700" style="background:rgba(16,185,129,0.1);">${IMPLEMENTED_LABEL}</span>`
    : '';

  const moderationBadge = pendingModeration
    ? `<span style="display:inline-flex;align-items:center;gap:4px;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;background:rgba(251,191,36,0.15);color:#92400e;border:1px solid rgba(251,191,36,0.3);">🔍 <%= j t('participate.feedback.moderation_pending') %></span>`
    : '';

  const replyBtn = ALLOW_REPLIES
    ? `<button onclick="toggleReplyForm(${fb.id})"
         class="ml-auto text-[11px] font-semibold text-indigo-500 hover:text-indigo-700 border-0 bg-transparent p-0">
         💬 ${fb.replies_count > 0 ? fb.replies_count + ' ' + REPLY_COUNT_LABEL : REPLY_LABEL}
       </button>`
    : '';

  const upvoteBtn = ALLOW_UPVOTES
    ? `<button data-feedback-id="${fb.id}" onclick="toggleUpvote(this, ${fb.id})"
         class="flex flex-col items-center gap-0.5 px-2.5 py-2 rounded-xl border transition-all cursor-pointer flex-shrink-0 upvote-btn"
         style="${fb.upvoted ? 'background:rgba(99,102,241,0.08);border-color:#6366f1;color:#6366f1;' : 'background:white;border-color:#e2e8f0;color:#64748b;'}">
         <span class="text-[15px] leading-none">${fb.upvoted ? '▲' : '△'}</span>
         <span class="text-[12px] font-bold upvote-count">${fb.upvotes_count}</span>
       </button>`
    : '';

  const repliesSection = ALLOW_REPLIES
    ? `<div id="replies-${fb.id}" class="hidden border-t reply-section" style="border-color:rgba(226,232,240,0.6); background:rgba(248,250,252,0.5);">
         <div class="ml-11 mr-4 my-3 pl-3" style="border-left:2px solid rgba(99,102,241,0.18);">
           <div id="replies-list-${fb.id}" class="space-y-2 mb-2"></div>
           <div>
             <div class="rounded-2xl overflow-hidden transition-all"
                  style="border:1.5px solid #e2e8f0; background:white;"
                  onfocusin="this.style.borderColor='#6366f1'" onfocusout="this.style.borderColor='#e2e8f0'">
               <input type="text" id="reply-name-${fb.id}" value="${REPLY_DEFAULT_NAME}" placeholder="${REPLY_NAME_PH}"
                 class="w-full px-4 pt-3 pb-0 text-[13px] font-semibold text-slate-600 outline-none bg-transparent block"
                 style="border:none; font-size:13px;">
               <textarea id="reply-content-${fb.id}" rows="2" maxlength="500"
                 placeholder="${REPLY_CONTENT_PH}"
                 class="w-full px-4 pt-2 pb-2 text-[13px] text-slate-800 outline-none resize-none bg-transparent block"
                 style="border:none; font-size:15px;"></textarea>
               <div id="reply-image-previews-${fb.id}" style="display:none;flex-wrap:wrap;gap:6px;padding:0 12px 8px;"></div>
               <div class="flex items-center justify-between px-3 py-2" style="border-top:1px solid #f1f5f9;">
                 <div class="flex items-center gap-1">
                   <button type="button" onclick="openEmojiPicker(${fb.id}, this)"
                     class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:text-amber-500 hover:bg-amber-50 transition-colors border-0 bg-transparent cursor-pointer">
                     <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 13s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
                   </button>
                   <button type="button" onclick="document.getElementById('reply-image-input-${fb.id}').click()"
                     class="w-8 h-8 rounded-full flex items-center justify-center text-slate-400 hover:text-indigo-500 hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer">
                     <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                   </button>
                 </div>
                 <button id="reply-submit-btn-${fb.id}" onclick="submitReply(${fb.id})"
                   class="w-8 h-8 rounded-full flex items-center justify-center text-indigo-500 hover:bg-indigo-50 transition-colors border-0 bg-transparent cursor-pointer disabled:opacity-40">
                   <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                 </button>
               </div>
             </div>
             <input type="file" id="reply-image-input-${fb.id}" accept="image/*" multiple class="hidden"
                    onchange="handleReplyImage(this, ${fb.id})">
           </div>
         </div>
       </div>`
    : '';

  const card = document.createElement('div');
  card.id = `feedback-card-${fb.id}`;
  card.className = 'rounded-2xl overflow-hidden fade-in';
  card.style.cssText = `background:#ffffff; border:1.5px solid ${borderColor}; box-shadow:0 2px 12px rgba(0,0,0,0.04);`;
  card.innerHTML = `
    ${pinnedBanner}
    <div class="p-4 flex items-start gap-3">
      <div class="w-8 h-8 rounded-full flex items-center justify-center text-[13px] font-bold flex-shrink-0 text-white mt-0.5"
        style="background:linear-gradient(135deg,#6366f1,#a855f7);">${initial}</div>
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-1 flex-wrap">
          <span class="text-[12px] font-semibold text-slate-600">${authorLabel}</span>
          <span class="text-[11px] text-slate-300">${fb.created_at}</span>
          ${implementedBadge}
          ${moderationBadge}
        </div>
        <p class="text-[14px] text-slate-800 leading-relaxed mb-2">${fb.content}</p>
        ${fb.image_urls && fb.image_urls.length > 0 ? (() => {
          const MAX_T = 4;
          const thumbs = fb.image_urls.slice(0, MAX_T).map((url, i) => {
            const overlay = (i === MAX_T - 1 && fb.image_urls.length > MAX_T)
              ? `<div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);border-radius:12px;display:flex;align-items:center;justify-content:center;"><span style="color:white;font-size:15px;font-weight:700;">+${fb.image_urls.length - MAX_T}</span></div>`
              : '';
            return `<div style="position:relative;width:72px;height:72px;flex-shrink:0;cursor:pointer;" onclick='openGallery(${JSON.stringify(fb.image_urls)}, ${i})'>
              <img src="${url}" alt="" style="width:100%;height:100%;border-radius:12px;object-fit:cover;border:1px solid rgba(226,232,240,0.8);">
              ${overlay}
            </div>`;
          }).join('');
          return `<div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;">${thumbs}</div>`;
        })() : ''}
        ${replyBtn ? `<div class="flex justify-end">${replyBtn}</div>` : ''}
      </div>
      ${upvoteBtn}
    </div>
    ${repliesSection}`;
  return card;
}

// ── Gallery / Lightbox ───────────────────────────────────────────────────────
let _gallery = [], _gIdx = 0;

function openGallery(urls, startIdx) {
  _gallery = Array.isArray(urls) ? urls : [urls];
  _gIdx = startIdx || 0;
  _renderGallery();
  document.getElementById('gallery-modal').style.display = 'flex';
}

function closeGallery() {
  document.getElementById('gallery-modal').style.display = 'none';
}

function galleryNav(dir) {
  _gIdx = Math.max(0, Math.min(_gallery.length - 1, _gIdx + dir));
  _renderGallery();
}

function _renderGallery() {
  document.getElementById('gallery-img').src = _gallery[_gIdx];
  document.getElementById('gallery-counter').textContent = `${_gIdx + 1} / ${_gallery.length}`;
  document.getElementById('gallery-prev').style.display = _gIdx > 0 ? 'flex' : 'none';
  document.getElementById('gallery-next').style.display = _gIdx < _gallery.length - 1 ? 'flex' : 'none';
  const thumbs = document.getElementById('gallery-thumbs');
  thumbs.style.display = _gallery.length > 1 ? 'flex' : 'none';
  thumbs.innerHTML = _gallery.map((url, i) =>
    `<img src="${url}" onclick="event.stopPropagation();_gIdx=${i};_renderGallery()"
          style="width:52px;height:52px;object-fit:cover;border-radius:8px;cursor:pointer;flex-shrink:0;
                 border:2px solid ${i===_gIdx?'#6366f1':'rgba(255,255,255,0.3)'};
                 opacity:${i===_gIdx?1:0.6};transition:all 0.15s;">`
  ).join('');
}

document.addEventListener('keydown', e => {
  const modal = document.getElementById('gallery-modal');
  if (modal.style.display === 'none') return;
  if (e.key === 'ArrowLeft') galleryNav(-1);
  if (e.key === 'ArrowRight') galleryNav(1);
  if (e.key === 'Escape') closeGallery();
});

// ── Feedback form multi-image upload ─────────────────────────────────────────
let fbFiles = [];

function handleFbImageSelect(input) {
  Array.from(input.files).forEach(f => fbFiles.push(f));
  input.value = '';
  _renderFbPreviews();
}

function _removeFbFile(idx) {
  const f = fbFiles[idx];
  if (f._blobUrl) URL.revokeObjectURL(f._blobUrl);
  fbFiles.splice(idx, 1);
  _renderFbPreviews();
}

function _renderFbPreviews() {
  const container = document.getElementById('fb-image-previews');
  if (fbFiles.length === 0) { container.style.display = 'none'; container.innerHTML = ''; return; }
  container.style.display = 'flex';
  container.innerHTML = fbFiles.map((f, i) => {
    if (!f._blobUrl) f._blobUrl = URL.createObjectURL(f);
    return `<div style="position:relative;flex-shrink:0;">
      <img src="${f._blobUrl}" style="width:64px;height:64px;object-fit:cover;border-radius:10px;border:1.5px solid #e2e8f0;display:block;">
      <button type="button" onclick="_removeFbFile(${i})"
        style="position:absolute;top:-6px;right:-6px;width:18px;height:18px;border-radius:50%;background:#ef4444;border:none;color:white;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">✕</button>
    </div>`;
  }).join('');
}

function _clearFbFiles() {
  fbFiles.forEach(f => { if (f._blobUrl) URL.revokeObjectURL(f._blobUrl); });
  fbFiles = [];
  _renderFbPreviews();
}

document.getElementById('feedback-form').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('fb-submit-btn');

  // Validate content (required)
  const contentField = document.getElementById('fb-content');
  if (contentField && !contentField.value.trim()) {
    if (document.activeElement) document.activeElement.blur();
    const box = contentField.closest('.rounded-2xl');
    if (box) { box.style.borderColor = '#ef4444'; setTimeout(() => { box.style.borderColor = '#e2e8f0'; }, 2000); }
    contentField.animate([
      { transform: 'translateX(0)' }, { transform: 'translateX(-5px)' },
      { transform: 'translateX(5px)' }, { transform: 'translateX(0)' }
    ], { duration: 280, easing: 'ease-out' });
    return;
  }

  // Client-side validation: user_choice requires name OR anonymous
  if (IDENTITY_MODE === 'user_choice') {
    const nameField = document.getElementById('feedback-author-name');
    const anonCb    = document.getElementById('feedback-anonymous');
    if (nameField && !anonCb?.checked && !nameField.value.trim()) {
      // Blur immediately so mobile keyboard doesn't pop up
      if (document.activeElement) document.activeElement.blur();

      nameField.style.borderColor = '#ef4444';
      nameField.style.background  = 'rgba(239,68,68,0.04)';
      const submitErr = document.getElementById('fb-submit-error');
      if (submitErr) {
        submitErr.textContent = "<%= j t('participate.feedback.name_or_anonymous_required', default: 'Vui lòng nhập tên hoặc chọn gửi ẩn danh') %>";
        submitErr.style.display = 'block';
        submitErr.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
      nameField.animate([
        { transform: 'translateX(0)' },
        { transform: 'translateX(-6px)' },
        { transform: 'translateX(6px)' },
        { transform: 'translateX(-4px)' },
        { transform: 'translateX(4px)' },
        { transform: 'translateX(0)' }
      ], { duration: 320, easing: 'ease-out' });
      return;
    }
  }

  btn.disabled = true;
  const spinner = document.getElementById('fb-submit-spinner');
  const icon    = document.getElementById('fb-submit-icon');
  if (spinner) spinner.style.display = 'inline-block';
  if (icon)    icon.style.display    = 'none';

  // Use FormData with manually managed files
  const formData = new FormData(this);
  if (!formData.get('feedback[anonymous]')) formData.set('feedback[anonymous]', '0');
  fbFiles.forEach(f => formData.append('feedback[images][]', f));

  try {
    const res = await fetch(SUBMIT_URL, {
      method: 'POST',
      headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json' },
      body: formData
    });
    if (res.status === 429) {
      showRateLimitBanner(res.headers.get('Retry-After') || '60');
      return;
    }

    const data = await res.json();

    if (!res.ok) {
      showToast(data.error || 'Error', true);
      btn.disabled = false;
      if (spinner) spinner.style.display = 'none';
      if (icon)    icon.style.display    = 'inline-block';
      return;
    }

    showToast(data.message);
    this.reset();
    _clearFbFiles();
    const nameField = document.getElementById('feedback-author-name');
    if (nameField) {
      nameField.disabled = false;
      nameField.style.opacity = '1';
      nameField.style.borderColor = '#e2e8f0';
      nameField.style.background  = 'rgba(255,255,255,0.9)';
    }
    const ne = document.getElementById('name-error'); if (ne) ne.style.display = 'none';

    if (data.status === 'submitted' && data.feedback) {
      const list = document.getElementById('feedbacks-list');
      const emptyState = document.getElementById('empty-state');
      const isPendingModeration = !!data.moderation;
      const card = renderFeedbackCard(data.feedback, isPendingModeration);
      // Remove stale pending-card if it was already injected by loadPendingCards
      const existing = document.getElementById(`feedback-card-${data.feedback.id}`);
      if (existing) existing.remove();
      list.insertBefore(card, list.firstChild);
      emptyState.classList.add('hidden');
      currentOffset += 1;
      // Persist to localStorage so badge survives page refresh
      if (isPendingModeration) savePendingCard(data.feedback);
      // update sticky count
      const countEl = document.getElementById('sticky-feedback-count');
      if (countEl) {
        const cur = parseInt(countEl.textContent) || 0;
        countEl.textContent = `${cur + 1} ${countEl.textContent.replace(/^\d+\s*/, '')}`;
      }
    }
  } catch(err) {
    showToast('Network error', true);
  } finally {
    btn.disabled = false;
    if (spinner) spinner.style.display = 'none';
    if (icon)    icon.style.display    = '';
  }
});

async function loadMore() {
  const btn = document.getElementById('load-more-btn');
  btn.disabled = true;
  btn.textContent = '...';

  try {
    const res = await fetch(`${LIST_URL}?offset=${currentOffset}`, {
      headers: { 'Accept': 'application/json', 'X-CSRF-Token': CSRF }
    });
    const data = await res.json();
    const list = document.getElementById('feedbacks-list');

    data.feedbacks.forEach(fb => {
      list.appendChild(renderFeedbackCard(fb));
    });

    currentOffset += data.feedbacks.length;

    if (!data.has_more) {
      document.getElementById('load-more-wrap').classList.add('hidden');
    }
  } finally {
    btn.disabled = false;
    btn.textContent = I18N_LOAD_MORE;
  }
}

function toggleAnonymous(checked) {
  const nameField = document.getElementById('feedback-author-name');
  if (!nameField) return;
  if (checked) {
    nameField.required = false;
    nameField.disabled = true;
    nameField.value = '';
    nameField.style.opacity = '0.4';
    nameField.style.borderColor = '#e2e8f0';
    nameField.style.background = '';
    const se = document.getElementById('fb-submit-error');
    if (se) se.style.display = 'none';
  } else {
    nameField.required = true;
    nameField.disabled = false;
    nameField.style.opacity = '1';
  }
}

function toggleReplyForm(id) {
  const section = document.getElementById(`replies-${id}`);
  section.classList.toggle('hidden');
  if (!section.classList.contains('hidden')) {
    document.getElementById(`reply-content-${id}`)?.focus();
  }
}

// ── Reply multi-image upload ──────────────────────────────────────────────────
const replyFiles = {}; // { feedbackId: [File, ...] }

function handleReplyImage(input, feedbackId) {
  if (!replyFiles[feedbackId]) replyFiles[feedbackId] = [];
  Array.from(input.files).forEach(f => replyFiles[feedbackId].push(f));
  input.value = '';
  _renderReplyPreviews(feedbackId);
}

function _removeReplyFile(feedbackId, idx) {
  const f = replyFiles[feedbackId][idx];
  if (f && f._blobUrl) URL.revokeObjectURL(f._blobUrl);
  replyFiles[feedbackId].splice(idx, 1);
  _renderReplyPreviews(feedbackId);
}

function _renderReplyPreviews(feedbackId) {
  const container = document.getElementById(`reply-image-previews-${feedbackId}`);
  if (!container) return;
  const files = replyFiles[feedbackId] || [];
  if (files.length === 0) { container.style.display = 'none'; container.innerHTML = ''; return; }
  container.style.display = 'flex';
  container.innerHTML = files.map((f, i) => {
    if (!f._blobUrl) f._blobUrl = URL.createObjectURL(f);
    return `<div style="position:relative;flex-shrink:0;">
      <img src="${f._blobUrl}" style="width:52px;height:52px;object-fit:cover;border-radius:8px;border:1.5px solid #e2e8f0;display:block;">
      <button type="button" onclick="_removeReplyFile(${feedbackId},${i})"
        style="position:absolute;top:-5px;right:-5px;width:16px;height:16px;border-radius:50%;background:#ef4444;border:none;color:white;font-size:9px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;">✕</button>
    </div>`;
  }).join('');
}

function _clearReplyFiles(feedbackId) {
  (replyFiles[feedbackId] || []).forEach(f => { if (f._blobUrl) URL.revokeObjectURL(f._blobUrl); });
  replyFiles[feedbackId] = [];
  _renderReplyPreviews(feedbackId);
}

async function submitReply(feedbackId) {
  const nameEl    = document.getElementById(`reply-name-${feedbackId}`);
  const contentEl = document.getElementById(`reply-content-${feedbackId}`);
  const btn       = document.getElementById(`reply-submit-btn-${feedbackId}`);
  const content   = contentEl.value.trim();
  if (!content) { contentEl.focus(); return; }

  // Loading state
  const SEND_SVG = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>`;
  if (btn) {
    btn.disabled = true;
    btn.innerHTML = `<span style="width:16px;height:16px;border:2px solid #e0e7ff;border-top-color:#6366f1;border-radius:50%;display:inline-block;animation:spin 0.7s linear infinite;flex-shrink:0;"></span>`;
  }

  const formData = new FormData();
  formData.append('feedback_id', feedbackId);
  formData.append('reply[content]', content);
  formData.append('reply[author_name]', nameEl.value.trim());
  (replyFiles[feedbackId] || []).forEach(f => formData.append('reply[images][]', f));

  const res = await fetch(REPLY_URL, {
    method: "POST",
    headers: { "X-CSRF-Token": CSRF, "Accept": "application/json" },
    body: formData
  });
  if (!res.ok) return;
  const data = await res.json();

  const list = document.getElementById(`replies-list-${feedbackId}`);
  const initial = data.anonymous ? "?" : (data.author_name || "?").charAt(0).toUpperCase();
  const authorLabel = data.anonymous ? ANONYMOUS_LABEL : data.author_name;
  const imageHtml = (() => {
    if (!data.image_urls || !data.image_urls.length) return '';
    const MAX_T = 4;
    const thumbs = data.image_urls.slice(0, MAX_T).map((url, i) => {
      const overlay = (i === MAX_T - 1 && data.image_urls.length > MAX_T)
        ? `<div style="position:absolute;inset:0;background:rgba(0,0,0,0.5);border-radius:8px;display:flex;align-items:center;justify-content:center;"><span style="color:white;font-size:13px;font-weight:700;">+${data.image_urls.length - MAX_T}</span></div>`
        : '';
      return `<div style="position:relative;width:60px;height:60px;flex-shrink:0;cursor:pointer;" onclick='openGallery(${JSON.stringify(data.image_urls)}, ${i})'>
        <img src="${url}" style="width:100%;height:100%;border-radius:8px;object-fit:cover;border:1px solid #e2e8f0;">
        ${overlay}
      </div>`;
    }).join('');
    return `<div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:6px;">${thumbs}</div>`;
  })();

  const div = document.createElement('div');
  div.className = 'flex gap-2';
  div.innerHTML = `
    <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold text-white flex-shrink-0 mt-0.5" style="background:linear-gradient(135deg,#94a3b8,#64748b);">${initial}</div>
    <div class="flex-1 rounded-xl px-3 py-2" style="background:rgba(255,255,255,0.9); border:1px solid rgba(226,232,240,0.7);">
      <div class="flex items-baseline gap-2 mb-0.5">
        <span class="text-[11px] font-semibold text-slate-600">${authorLabel}</span>
        <span class="text-[10px] text-slate-300">${data.created_at}</span>
      </div>
      <p class="text-[13px] text-slate-700">${data.content}</p>
      ${imageHtml}
    </div>`;
  list.appendChild(div);
  contentEl.value = '';
  nameEl.value = REPLY_DEFAULT_NAME;
  _clearReplyFiles(feedbackId);
  if (btn) { btn.disabled = false; btn.innerHTML = SEND_SVG; }
}

// ── Turbo cache cleanup ───────────────────────────────────────────────────────
// Clears all preview UIs before Turbo caches the page, so restored cached
// pages never show stale X buttons or open gallery.
document.addEventListener('turbo:before-cache', () => {
  // Reset feedback form previews
  _clearFbFiles();
  // Reset all reply previews
  Object.keys(replyFiles).forEach(id => _clearReplyFiles(parseInt(id)));
  // Close gallery
  const modal = document.getElementById('gallery-modal');
  if (modal) modal.style.display = 'none';
});

async function toggleUpvote(btn, feedbackId) {
  btn.disabled = true;
  try {
    const res = await fetch(UPVOTE_URL, {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-CSRF-Token": CSRF, "Accept": "application/json" },
      body: JSON.stringify({ feedback_id: feedbackId })
    });
    if (!res.ok) return;
    const data = await res.json();
    btn.querySelector(".upvote-count").textContent = data.count;
    const arrow = btn.querySelector("span:first-child");
    if (data.upvoted) {
      btn.style.background = 'rgba(99,102,241,0.08)';
      btn.style.borderColor = '#6366f1';
      btn.style.color = '#6366f1';
      arrow.textContent = "▲";
    } else {
      btn.style.background = 'white';
      btn.style.borderColor = '#e2e8f0';
      btn.style.color = '#64748b';
      arrow.textContent = "△";
    }
  } finally {
    btn.disabled = false;
  }
}

// ── Voice Recording Modal (STT) ──────────────────────────────────────────────
(function() {
  if (!ALLOW_VOICE) return;

  let _mr = null, _stream = null, _chunks = [], _startMs = 0;
  let _timerIv = null, _discarding = false;
  // 'idle' | 'recording' | 'processing'
  let _vmState = 'idle';

  function _el(id) { return document.getElementById(id); }

  // ── Render UI for state ───────────────────────────────────────────────────
  function _applyState(s) {
    _vmState = s;
    const waves     = _el('vm-waves');
    const timerRow  = _el('vm-timer-row');
    const statusEl  = _el('vm-status');
    const hintEl    = _el('vm-hint');
    const btn       = _el('vm-action-btn');
    const btnIcon   = _el('vm-btn-icon');
    const btnSpinner= _el('vm-btn-spinner');
    const ring1     = _el('vm-ring1');
    const ring2     = _el('vm-ring2');

    // Clear transient error banner
    const errMsgEl = _el('vm-err-msg');
    if (errMsgEl)  errMsgEl.style.display  = 'none';

    if (s === 'recording') {
      if (waves)    { waves.style.display = 'flex'; }
      if (timerRow) { timerRow.style.display = 'flex'; }
      if (statusEl) { statusEl.textContent = I18N_VOICE_STATUS_REC; statusEl.style.color = 'rgba(255,255,255,0.45)'; }
      if (hintEl)   { hintEl.textContent   = I18N_VOICE_HINT_STOP; hintEl.style.color = 'rgba(255,255,255,0.35)'; }
      if (btn)      { btn.disabled = false; btn.style.background = 'linear-gradient(135deg,#ef4444,#dc2626)'; btn.style.boxShadow = '0 8px 24px rgba(239,68,68,0.45)'; }
      if (btnIcon)  btnIcon.style.display = '';
      if (btnSpinner) btnSpinner.style.display = 'none';
      if (ring1)    { ring1.style.animationPlayState = 'running'; ring1.style.borderColor = 'rgba(239,68,68,0.3)'; }
      if (ring2)    { ring2.style.animationPlayState = 'running'; ring2.style.borderColor = 'rgba(239,68,68,0.15)'; }

    } else if (s === 'processing') {
      if (waves)    waves.style.display = 'none';
      if (timerRow) timerRow.style.display = 'none';
      if (statusEl) { statusEl.textContent = I18N_VOICE_STATUS_PROC; statusEl.style.color = 'rgba(255,255,255,0.45)'; }
      if (hintEl)   hintEl.textContent   = '';
      if (btn)      { btn.disabled = true; btn.style.background = 'rgba(226,232,240,0.8)'; btn.style.boxShadow = 'none'; }
      if (btnIcon)  btnIcon.style.display = 'none';
      if (btnSpinner) btnSpinner.style.display = '';
      if (ring1)    ring1.style.animationPlayState = 'paused';
      if (ring2)    ring2.style.animationPlayState = 'paused';

    } else { // idle
      if (waves)    waves.style.display = 'none';
      if (timerRow) timerRow.style.display = 'none';
      const timerEl = _el('vm-timer'); if (timerEl) timerEl.textContent = '0:00';
      if (statusEl) { statusEl.textContent = I18N_VOICE_STATUS_READY; statusEl.style.color = 'rgba(255,255,255,0.45)'; }
      if (hintEl)   hintEl.textContent   = '';
      if (btn)      { btn.disabled = false; btn.style.background = 'linear-gradient(135deg,#6366f1,#4f46e5)'; btn.style.boxShadow = '0 8px 24px rgba(99,102,241,0.35)'; }
      if (btnIcon)  btnIcon.style.display = '';
      if (btnSpinner) btnSpinner.style.display = 'none';
      if (ring1)    ring1.style.animationPlayState = 'paused';
      if (ring2)    ring2.style.animationPlayState = 'paused';
    }
  }

  // ── Timer ─────────────────────────────────────────────────────────────────
  function _startTimer() {
    _startMs = Date.now();
    if (_timerIv) clearInterval(_timerIv);
    _timerIv = setInterval(() => {
      const s = Math.floor((Date.now() - _startMs) / 1000);
      const el = _el('vm-timer');
      if (el) el.textContent = Math.floor(s/60) + ':' + String(s%60).padStart(2,'0');
    }, 500);
  }
  function _stopTimer() { if (_timerIv) { clearInterval(_timerIv); _timerIv = null; } }

  // ── Open modal (first time) ───────────────────────────────────────────────
  function _openModal() {
    const ov = _el('vm-overlay');
    if (ov) ov.style.display = 'flex';
    _applyState('idle');
    const statusEl = _el('vm-status');
    if (statusEl) statusEl.textContent = I18N_VOICE_STARTING;
  }

  // ── Start recording ───────────────────────────────────────────────────────
  async function _startRecording() {
    _discarding = false;
    _chunks = [];

    if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      showToast(I18N_VOICE_NO_BROWSER, true);
      return;
    }

    // Show modal with “starting” message
    _openModal();

    let stream;
    try {
      stream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
    } catch(err) {
      const ov = _el('vm-overlay');
      if (ov) ov.style.display = 'none';
      _stopTimer();
      showToast(
        err.name === 'NotAllowedError' ? I18N_VOICE_MIC_DENIED : I18N_VOICE_MIC_ERROR,
        true
      );
      return;
    }

    _stream = stream;

    // Best MIME (Safari needs mp4)
    const mimeType = ['audio/webm;codecs=opus','audio/webm','audio/ogg;codecs=opus','audio/mp4']
      .find(t => { try { return MediaRecorder.isTypeSupported(t); } catch(e) { return false; } }) || '';

    try { _mr = mimeType ? new MediaRecorder(stream, { mimeType }) : new MediaRecorder(stream); }
    catch(e) { _mr = new MediaRecorder(stream); }

    _mr.addEventListener('dataavailable', e => { if (e.data && e.data.size > 0) _chunks.push(e.data); });
    _mr.addEventListener('stop', _onStop);

    _mr.start(250); // collect every 250ms → reliable data capture
    _applyState('recording');
    _startTimer();
  }

  // ── After stop: transcribe + fill textarea → back to idle ─────────────────
  async function _onStop() {
    if (_stream) { _stream.getTracks().forEach(t => t.stop()); _stream = null; }
    _stopTimer();

    if (_discarding) { _chunks = []; _mr = null; return; }

    const durationSecs = (Date.now() - _startMs) / 1000;

    if (_chunks.length === 0) {
      _showError(I18N_VOICE_NO_AUDIO_MSG);
      _mr = null;
      return;
    }

    const blobType = (_mr && _mr.mimeType) ? _mr.mimeType : 'audio/webm';
    const blob = new Blob(_chunks, { type: blobType });
    _chunks = [];
    _mr = null;

    _applyState('processing');

    try {
      const ext = blobType.includes('mp4') || blobType.includes('m4a') ? 'm4a'
                : blobType.includes('ogg') ? 'ogg' : 'webm';
      const fd = new FormData();
      fd.append('audio', blob, 'recording.' + ext);
      fd.append('duration_secs', durationSecs.toFixed(2));

      const res = await fetch(VOICE_URL, {
        method: 'POST',
        headers: { 'X-CSRF-Token': CSRF, 'Accept': 'application/json' },
        body: fd
      });

      let data;
      try { data = await res.json(); } catch(e) { data = {}; }

      if (!res.ok) {
        _showError(data.error || I18N_VOICE_GENERIC_ERROR);
        return;
      }

      const text = (data.text || '').trim();
      if (text) {
        // Fill into textarea, separating chunks with ". "
        const ta = _el('fb-content');
        if (ta) {
          const existing = ta.value.trim();
          ta.value = existing
            ? existing + (existing.endsWith('.') ? ' ' : '. ') + text
            : text;
          ta.dispatchEvent(new Event('input'));
        }
        // Go idle — ready to record more
        _applyState('idle');
      } else {
        _showError(I18N_VOICE_NO_SPEECH);
      }
    } catch(e) {
      _showError(I18N_VOICE_CONN_ERROR);
    }
  }

  function _showError(msg) {
    _applyState('idle');
    const errEl = _el('vm-err-msg');
    if (errEl) { errEl.textContent = msg; errEl.style.display = ''; }
    const statusEl = _el('vm-status');
    if (statusEl) { statusEl.textContent = I18N_VOICE_HINT_RETRY; statusEl.style.color = 'rgba(255,255,255,0.45)'; }
  }

  // ── Public API ────────────────────────────────────────────────────────────
  // Open modal (from mic button in toolbar)
  window.openVoiceModal = function() {
    const ov = _el('vm-overlay');
    if (!ov || ov.style.display === 'flex') return;
    ov.style.display = 'flex';
    _applyState('idle');
    // Fresh open: clear status, show "tap to start" hint
    const statusEl = _el('vm-status');
    if (statusEl) statusEl.textContent = '';
    const hintEl = _el('vm-hint');
    if (hintEl) hintEl.textContent = I18N_VOICE_HINT_START;
  };

  // Big button click: start (idle) or stop (recording)
  window.voiceActionClick = function() {
    if (_vmState === 'idle')      { _startRecording(); }
    else if (_vmState === 'recording') {
      if (_mr && _mr.state !== 'inactive') _mr.stop();
    }
    // processing: ignore
  };

  // X button: close and discard
  window.closeVoiceModal = function() {
    _discarding = true;
    if (_mr && _mr.state !== 'inactive') _mr.stop();
    if (_stream) { _stream.getTracks().forEach(t => t.stop()); _stream = null; }
    _stopTimer();
    _mr = null;
    const ov = _el('vm-overlay');
    if (ov) ov.style.display = 'none';
    _vmState = 'idle';
  };
})();

