<% if @active_total.zero? && (@quiz_count + @flashcard_count + @path_count) > 0 %>
  <div style="text-align:center;padding:20px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:14px;margin-bottom:16px;">
    <div style="font-size:32px;">🎉</div>
    <p style="font-size:14px;font-weight:700;color:#166534;margin:4px 0 2px;"><%= t('learner_dashboard.all_done_title') %></p>
    <%= link_to t('learner_dashboard.all_done_link'), learner_library_path, style:"font-size:12px;font-weight:700;color:#166534;text-decoration:none;" %>
  </div>
<% end %>

<script>
(function(){
  const FETCH_URL   = '<%= learner_fetch_suggestion_path %>';
  const DISMISS_URL = '<%= learner_dismiss_suggestion_path(id: "__id__") %>';
  const CSRF        = () => document.querySelector('meta[name="csrf-token"]').content;

  const BG = {
    deadline:    'linear-gradient(135deg,#fff7ed,#ffedd5)',
    low_score:   'linear-gradient(135deg,#fef2f2,#fee2e2)',
    abandoned:   'linear-gradient(135deg,#f0f9ff,#e0f2fe)',
    ai_trending: 'linear-gradient(135deg,#faf5ff,#f3e8ff)'
  };
  const BORDER = {
    deadline:    '#fed7aa', low_score: '#fecaca',
    abandoned:   '#bae6fd', ai_trending: '#e9d5ff'
  };
  const BTN_BG = {
    deadline:    '#ea580c', low_score: '#dc2626',
    abandoned:   '#0284c7', ai_trending: '#7c3aed'
  };

  function render(d) {
    var wrap = document.getElementById('lp-suggest-wrap');
    var card = document.getElementById('lp-suggest-card');
    var bg     = BG[d.kind]     || BG.ai_trending;
    var border = BORDER[d.kind] || BORDER.ai_trending;
    var btnBg  = BTN_BG[d.kind] || BTN_BG.ai_trending;

    card.style.background = bg;
    card.style.border     = '1.5px solid ' + border;

    var actionHref = d.action_url;
    if (d.prefill_topic && actionHref.includes('my_flashcards/new')) {
      actionHref += '?topic=' + encodeURIComponent(d.prefill_topic);
    }

    card.innerHTML =
      '<button onclick="lpDismiss(' + d.id + ')" aria-label="Bỏ qua" style="position:absolute;top:8px;right:8px;width:24px;height:24px;border-radius:50%;border:none;background:rgba(0,0,0,.06);color:#64748b;cursor:pointer;font-size:14px;line-height:1;display:flex;align-items:center;justify-content:center;padding:0;transition:background .15s;" onmouseover="this.style.background=\'rgba(0,0,0,.12)\'" onmouseout="this.style.background=\'rgba(0,0,0,.06)\'">✕</button>' +
      '<div style="display:flex;align-items:flex-start;gap:10px;">' +
        '<div style="font-size:22px;line-height:1;flex-shrink:0;margin-top:2px;">' + d.icon + '</div>' +
        '<div style="flex:1;min-width:0;">' +
          '<p style="font-size:12px;font-weight:800;color:#64748b;margin:0 24px 3px 0;text-transform:uppercase;letter-spacing:.5px;">' + d.title + '</p>' +
          '<p style="font-size:13px;color:#1e293b;line-height:1.5;margin:0 0 12px;">' + d.body + '</p>' +
          '<a href="' + actionHref + '" style="display:block;width:50%;margin:0 auto;text-align:center;padding:9px 16px;border-radius:10px;background:' + btnBg + ';color:white;font-size:12px;font-weight:700;text-decoration:none;">' + d.action_label + '</a>' +
        '</div>' +
      '</div>';

    wrap.style.display = 'block';
    wrap.style.opacity = '0';
    wrap.style.transform = 'translateY(-8px)';
    wrap.style.transition = 'opacity .3s, transform .3s';
    requestAnimationFrame(function() { requestAnimationFrame(function() {
      wrap.style.opacity = '1';
      wrap.style.transform = 'translateY(0)';
    }); });
  }

  window.lpDismiss = function(id) {
    var wrap = document.getElementById('lp-suggest-wrap');
    wrap.style.opacity = '0';
    wrap.style.transform = 'translateY(-8px)';
    setTimeout(function() { wrap.style.display = 'none'; }, 300);
    fetch(DISMISS_URL.replace('__id__', id), {
      method: 'POST',
      headers: { 'X-CSRF-Token': CSRF(), 'Content-Type': 'application/json' }
    });
  };

  // Fetch after a short delay so page renders first
  setTimeout(function() {
    fetch(FETCH_URL, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
      .then(function(r) { return r.json(); })
      .then(function(d) { if (!d.none) render(d); })
      .catch(function() {});
  }, 400);
})();
</script>

<%# ── Activity detail bottom sheet ── %>
<div id="activity-sheet-backdrop"
     onclick="closeActivitySheet()"
     style="display:none;position:fixed;inset:0;z-index:9990;background:rgba(15,23,42,0.45);opacity:0;transition:opacity .25s;">
</div>
<style>
  @media (min-width: 1024px) {
    #activity-sheet { left: 20.835% !important; right: 20.835% !important; }
  }
</style>
<div id="activity-sheet"
     style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9991;background:#fff;border-radius:20px 20px 0 0;padding:0 0 calc(env(safe-area-inset-bottom,0px) + 16px);transform:translateY(100%);transition:transform .32s cubic-bezier(.32,1,.23,1);box-shadow:0 -4px 32px rgba(0,0,0,.13);max-height:75vh;display:none;flex-direction:column;">
  <div onclick="closeActivitySheet()" style="padding:10px 0 4px;cursor:pointer;display:flex;justify-content:center;">
    <div style="width:36px;height:4px;background:#e2e8f0;border-radius:2px;"></div>
  </div>
  <div style="display:flex;align-items:center;justify-content:space-between;padding:4px 16px 12px;">
    <p style="font-size:14px;font-weight:800;color:#1e293b;margin:0;"><%= t('learner_dashboard.activity_sheet_title') %></p>
    <button onclick="closeActivitySheet()" style="width:28px;height:28px;border-radius:50%;border:none;background:#f1f5f9;color:#94a3b8;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;line-height:1;padding:0;">×</button>
  </div>
  <div style="overflow-y:auto;padding:0 16px 4px;flex:1;">
    <% if @activity_details.any? %>
      <% @activity_details.each do |act| %>
        <a href="<%= act[:url] %>" style="display:flex;align-items:center;gap:12px;padding:11px 0;border-bottom:1px solid #f1f5f9;text-decoration:none;color:inherit;">
          <div style="width:38px;height:38px;border-radius:10px;background:#f0f4f8;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;"><%= act[:icon] %></div>
          <div style="flex:1;min-width:0;">
            <p style="font-size:13px;font-weight:600;color:#1e293b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin:0;"><%= act[:label] %></p>
          </div>
          <svg width="15" height="15" fill="none" stroke="#cbd5e1" viewBox="0 0 24 24" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      <% end %>
    <% else %>
      <div style="text-align:center;padding:28px 0;color:#9ca3af;">
        <div style="font-size:32px;margin-bottom:8px;">🌱</div>
        <p style="font-size:13px;"><%= t('learner_dashboard.activity_sheet_empty') %></p>
      </div>
    <% end %>
    <% if @activities_today > 0 %>
      <div style="display:flex;justify-content:space-between;align-items:center;padding:12px 0 2px;border-top:1px solid #f1f5f9;margin-top:4px;">
        <span style="font-size:12px;color:#9ca3af;"><%= t('learner_dashboard.activity_total') %></span>
        <span style="font-size:13px;font-weight:800;color:#1e3a5f;"><%= @activities_today %> <%= t('learner_dashboard.activities_unit') %> · +<%= LearnerDailyStat.find_by(learner_id: current_learner.id, day: Date.current)&.xp.to_i %> XP</span>
      </div>
    <% end %>
  </div>
</div>

<script>
function openActivitySheet() {
  var bd = document.getElementById('activity-sheet-backdrop');
  var sh = document.getElementById('activity-sheet');
  bd.style.display = 'block';
  sh.style.display = 'flex';
  requestAnimationFrame(function() { requestAnimationFrame(function() {
    bd.style.opacity = '1';
    sh.style.transform = 'translateY(0)';
  }); });
}
function closeActivitySheet() {
  var bd = document.getElementById('activity-sheet-backdrop');
  var sh = document.getElementById('activity-sheet');
  bd.style.opacity = '0';
  sh.style.transform = 'translateY(100%)';
  setTimeout(function() { bd.style.display = 'none'; sh.style.display = 'none'; }, 330);
}
</script>

<% if @quiz_assignments.empty? && @flashcard_assignments.empty? && @path_assignments.empty? %>
  <div style="text-align:center;padding:60px 20px;">
    <div style="font-size:48px;margin-bottom:12px;">📚</div>
    <p style="font-weight:700;font-size:16px;color:#374151;"><%= t('learner_dashboard.empty_title') %></p>
    <p style="font-size:14px;color:#9ca3af;margin-top:6px;"><%= t('learner_dashboard.empty_desc') %></p>
  </div>
<% end %>
