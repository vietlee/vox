<% content_for :title, t('learner_portal.nav_home') %>

<%# Hero greeting %>
<div style="background:linear-gradient(135deg,#1e3a5f,#16304f);border-radius:20px;padding:20px;margin-bottom:16px;color:white;">
  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
    <div style="min-width:0;">
      <p style="font-size:13px;opacity:0.8;margin-bottom:4px;"><%= t('learner_dashboard.greeting') %> 👋</p>
      <h1 style="font-size:22px;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= current_learner.name %></h1>
    </div>
    <%= link_to learner_progress_path, style:"flex-shrink:0;display:flex;align-items:center;gap:10px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.2);border-radius:14px;padding:8px 12px;text-decoration:none;color:#fff;" do %>
      <div style="text-align:center;">
        <div style="font-size:18px;font-weight:900;line-height:1;">🔥 <%= @streak %></div>
        <div style="font-size:9px;opacity:.7;margin-top:2px;">streak</div>
      </div>
      <div style="width:1px;height:26px;background:rgba(255,255,255,.2);"></div>
      <div style="text-align:center;">
        <div style="font-size:18px;font-weight:900;line-height:1;">⚡ <%= @xp %></div>
        <div style="font-size:9px;opacity:.7;margin-top:2px;">XP</div>
      </div>
    <% end %>
  </div>

  <%# Daily goal progress — tap to see activity breakdown %>
  <div onclick="openActivitySheet()" style="margin-top:14px;background:rgba(255,255,255,0.1);border-radius:12px;padding:10px 14px;cursor:pointer;-webkit-tap-highlight-color:transparent;transition:background .15s;" onmousedown="this.style.background='rgba(255,255,255,0.18)'" onmouseup="this.style.background='rgba(255,255,255,0.1)'" ontouchstart="this.style.background='rgba(255,255,255,0.18)'" ontouchend="this.style.background='rgba(255,255,255,0.1)'">
    <div style="display:flex;justify-content:space-between;align-items:center;font-size:12px;margin-bottom:6px;">
      <span style="font-weight:600;"><%= @goal_met ? t('learner_dashboard.goal_met') : t('learner_dashboard.goal_today') %></span>
      <div style="display:flex;align-items:center;gap:5px;opacity:.85;">
        <span><%= [@activities_today, @daily_goal].min %>/<%= @daily_goal %> <%= t('learner_dashboard.activities_unit') %></span>
        <svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="opacity:.7;flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </div>
    </div>
    <div style="background:rgba(255,255,255,0.2);border-radius:99px;height:7px;overflow:hidden;">
      <div style="height:100%;border-radius:99px;background:<%= @goal_met ? '#22c55e' : 'linear-gradient(90deg,#fbbf24,#f59e0b)' %>;width:<%= [(@activities_today * 100.0 / [@daily_goal,1].max).round, 100].min %>%;transition:width .5s;"></div>
    </div>
  </div>

  <div style="display:flex;gap:16px;margin-top:14px;">
    <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 14px;flex:1;text-align:center;">
      <p style="font-size:20px;font-weight:800;"><%= @quiz_assignments.count %></p>
      <p style="font-size:11px;opacity:0.8;"><%= t('learner_dashboard.quiz_count') %></p>
    </div>
    <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 14px;flex:1;text-align:center;">
      <p style="font-size:20px;font-weight:800;"><%= @flashcard_assignments.count %></p>
      <p style="font-size:11px;opacity:0.8;"><%= t('learner_dashboard.flashcard_count') %></p>
    </div>
    <div style="background:rgba(255,255,255,0.15);border-radius:12px;padding:10px 14px;flex:1;text-align:center;">
      <p style="font-size:20px;font-weight:800;"><%= @path_assignments.count %></p>
      <p style="font-size:11px;opacity:0.8;"><%= t('learner_dashboard.lp_count') %></p>
    </div>
  </div>
</div>

<%# Daily Challenge card %>
<% dc = @daily_challenge %>
<%= link_to learner_daily_challenge_path,
      style: "display:block;text-decoration:none;margin-bottom:14px;background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1.5px solid #f59e0b;border-radius:16px;padding:14px 16px;" do %>
  <div style="display:flex;align-items:center;gap:12px;">
    <div style="width:44px;height:44px;background:linear-gradient(135deg,#f59e0b,#d97706);border-radius:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <span style="font-size:22px;">⚔️</span>
    </div>
    <div style="flex:1;min-width:0;">
      <p style="font-size:14px;font-weight:800;color:#92400e;margin:0;">Thử thách hôm nay</p>
      <p style="font-size:12px;color:#b45309;margin:2px 0 0;">
        <% if dc&.completed? %>
          <span style="color:#16a34a;font-weight:700;">✓ Hoàn thành · <%= dc.score %>/<%= dc.total %> đúng</span>
        <% else %>
          5 câu hỏi · +15 XP ·
          <% if dc&.questions.present? %>Đang chờ bạn!<% else %>Nhấn để bắt đầu<% end %>
        <% end %>
      </p>
    </div>
    <% unless dc&.completed? %>
      <span style="background:#f59e0b;color:#fff;font-size:12px;font-weight:800;padding:6px 12px;border-radius:99px;flex-shrink:0;">BẮT ĐẦU</span>
    <% end %>
  </div>
<% end %>

<%# SRS: Thẻ cần ôn hôm nay %>
<% if @srs_due_decks.any? %>
  <div style="margin-bottom:14px;">
    <p style="font-size:12px;font-weight:700;color:#7c3aed;text-transform:uppercase;letter-spacing:.05em;margin:0 0 8px;">🔁 Ôn tập theo lịch SRS</p>
    <div style="display:grid;gap:7px;">
      <% @srs_due_decks.each do |d| %>
        <%= link_to d[:url], style:"display:flex;align-items:center;gap:12px;background:linear-gradient(135deg,#f5f3ff,#ede9fe);border:1.5px solid #c4b5fd;border-radius:14px;padding:12px 14px;text-decoration:none;" do %>
          <div style="width:40px;height:40px;background:linear-gradient(135deg,#7c3aed,#6d28d9);border-radius:11px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <span style="font-size:20px;">🃏</span>
          </div>
          <div style="flex:1;min-width:0;">
            <p style="font-size:13px;font-weight:700;color:#4c1d95;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin:0;"><%= d[:title] %></p>
            <p style="font-size:12px;color:#6d28d9;margin:2px 0 0;"><%= d[:due_count] %> thẻ cần ôn hôm nay</p>
          </div>
          <span style="background:#7c3aed;color:#fff;font-size:11px;font-weight:800;padding:5px 11px;border-radius:99px;flex-shrink:0;white-space:nowrap;">ÔN NGAY</span>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<%# AI Suggestion card (loaded async) %>
<div id="lp-suggest-wrap" style="margin-bottom:16px;display:none;">
  <div id="lp-suggest-card" style="border-radius:16px;padding:14px 16px;position:relative;overflow:hidden;">
    <!-- content injected by JS -->
  </div>
</div>

<%# ── Tiếp tục học (danh sách ưu tiên) ── %>
<% type_meta = {
     quiz:      { c1:'#dbeafe', c2:'#bfdbfe', stroke:'#1d4ed8', bar:'#1e3a5f',
                  svg:'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4' },
     flashcard: { c1:'#d1fae5', c2:'#a7f3d0', stroke:'#065f46', bar:'#059669',
                  svg:'M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10' },
     path:      { c1:'#fef3c7', c2:'#fde68a', stroke:'#92400e', bar:'#d97706',
                  svg:'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' }
   } %>

<% total_items = @quiz_count + @flashcard_count + @path_count %>
<% if @continue.any? %>
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
    <p class="lp-section-title" style="margin:0;"><%= t('learner_dashboard.section_continue') %></p>
    <% if total_items > 0 %>
      <%= link_to t('learner_dashboard.view_all', n: total_items), learner_library_path,
            onmouseover: "this.style.background='#c2410c'", onmouseout: "this.style.background='#ea580c'",
            style:"font-size:12px;font-weight:700;color:#fff;text-decoration:none;background:#ea580c;padding:6px 12px;border-radius:9px;box-shadow:0 1px 4px rgba(234,88,12,.35);transition:background .15s;" %>
    <% end %>
  </div>
  <div style="display:grid;gap:10px;margin-bottom:22px;">
    <% @continue.each do |it| %>
      <% m = type_meta[it[:type]] %>
      <div class="lp-card" style="margin:0;">
        <div class="lp-card-body" style="display:flex;align-items:center;gap:12px;">
          <div style="width:44px;height:44px;background:linear-gradient(135deg,<%= m[:c1] %>,<%= m[:c2] %>);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="22" height="22" fill="none" stroke="<%= m[:stroke] %>" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= m[:svg] %>"/></svg>
          </div>
          <div style="flex:1;min-width:0;">
            <p style="font-weight:700;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= it[:title] %></p>
            <div style="display:flex;align-items:center;gap:6px;margin-top:3px;">
              <% if it[:overdue] %>
                <span class="lp-badge lp-badge-overdue"><%= t('learner_dashboard.overdue_badge') %></span>
              <% elsif it[:progress].to_i > 0 %>
                <span style="font-size:11px;font-weight:700;color:<%= m[:bar] %>;"><%= it[:progress] %>%</span>
              <% end %>
              <% if it[:due] %>
                <span style="font-size:11px;color:#9ca3af;">· <%= t('learner_dashboard.due_prefix') %> <%= it[:due].strftime("%d/%m") %></span>
              <% end %>
            </div>
            <% if it[:progress].to_i > 0 %>
              <div class="lp-progress-bar" style="margin-top:5px;"><div class="lp-progress-fill" style="width:<%= it[:progress] %>%;background:<%= m[:bar] %>;"></div></div>
            <% end %>
          </div>
          <%= link_to it[:cta], it[:url], class: "lp-btn lp-btn-primary", style: "padding:8px 14px;font-size:13px;flex-shrink:0;" %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── Quick actions ── %>
<p class="lp-section-title" style="margin-bottom:8px;"><%= t('learner_dashboard.section_explore') %></p>
<style>
  #lp-explore-grid{grid-template-columns:repeat(3,1fr);}
  @media(max-width:280px){#lp-explore-grid{grid-template-columns:repeat(2,1fr);}}
</style>
<div id="lp-explore-grid" style="display:grid;gap:8px;margin-bottom:20px;">
  <% quick = [
       { url: learner_ai_tutor_path,        icon:'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z', label: t('learner_dashboard.explore_tutor_label'), desc: t('learner_dashboard.explore_tutor_desc'), c:'#6b21a8', bg:'#faf5ff', bd:'#e9d5ff' },
       { url: learner_speaking_path,         icon:'M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z', label: t('learner_dashboard.explore_speaking_label'), desc: t('learner_dashboard.explore_speaking_desc'), c:'#92400e', bg:'#fffbeb', bd:'#fde68a' },
       { url: learner_study_plans_path,      icon:'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: t('learner_dashboard.explore_path_label'), desc: t('learner_dashboard.explore_path_desc'), c:'#3730a3', bg:'#eef2ff', bd:'#c7d2fe' },
       { url: learner_new_my_flashcard_path, icon:'M12 4v16m8-8H4', label: t('learner_dashboard.explore_flashcard_label'), desc: t('learner_dashboard.explore_flashcard_desc'), c:'#065f46', bg:'#ecfdf5', bd:'#a7f3d0' },
       { url: learner_progress_path,         icon:'M16 8v8m-4-5v5m-4-2v2M3 20h18', label: t('learner_dashboard.explore_progress_label'), desc: t('learner_dashboard.explore_progress_desc'), c:'#0284c7', bg:'#f0f9ff', bd:'#7dd3fc' },
       { url: learner_tools_summarize_path,  icon:'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z', label: t('learner_dashboard.explore_summarize_label'), desc: t('learner_dashboard.explore_summarize_desc'), c:'#be123c', bg:'#fff1f2', bd:'#fecdd3' },
       { url: learner_tools_tts_path,        icon:'M3 18v-6a9 9 0 0118 0v6M3 18a1 1 0 001 1h1a1 1 0 001-1v-3a1 1 0 00-1-1H4a1 1 0 00-1 1v3zM21 18a1 1 0 01-1 1h-1a1 1 0 01-1-1v-3a1 1 0 011-1h1a1 1 0 011 1v3z', label: t('learner_dashboard.explore_tts_label'), desc: t('learner_dashboard.explore_tts_desc'), c:'#0f766e', bg:'#f0fdfa', bd:'#99f6e4' },
       { url: learner_tools_stt_path,        icon:'M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z', label: t('learner_dashboard.explore_stt_label'), desc: t('learner_dashboard.explore_stt_desc'), c:'#334155', bg:'#f8fafc', bd:'#cbd5e1' },
       { url: learner_credits_path,          icon:'M13 10V3L4 14h7v7l9-11h-7z', label: t('learner_dashboard.explore_credits_label'), desc: t('learner_dashboard.explore_credits_desc'), c:'#7c3aed', bg:'#f5f3ff', bd:'#ddd6fe' }
     ] %>
  <% quick.each do |q| %>
    <%= link_to q[:url], style:"text-decoration:none;background:#{q[:bg]};border:1.5px solid #{q[:bd]};border-radius:12px;padding:10px;display:block;" do %>
      <div style="width:30px;height:30px;border-radius:8px;background:#fff;display:flex;align-items:center;justify-content:center;margin-bottom:6px;">
        <svg width="16" height="16" fill="none" stroke="<%= q[:c] %>" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="<%= q[:icon] %>"/></svg>
      </div>
      <p style="font-size:12px;font-weight:700;color:<%= q[:c] %>;margin:0;line-height:1.3;"><%= q[:label] %></p>
