<% content_for :title, "Đăng ký" %>
<% content_for :head do %>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  html, body { background: #0F172A !important; overflow: hidden !important; height: 100% !important; }
  .lp-main { background: #0F172A !important; overflow-y: auto !important; }

  .lp-alert-success, .lp-alert-error { display: none !important; }
</style>
<% end %>

<div style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px 16px; font-family:'Inter',sans-serif;">

  <% if notice.present? %>
    <div style="position:fixed;top:16px;left:50%;transform:translateX(-50%);background:#10b981;color:#fff;padding:10px 20px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div style="position:fixed;top:16px;left:50%;transform:translateX(-50%);background:rgba(239,68,68,0.9);color:#fff;padding:10px 20px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;"><%= alert %></div>
  <% end %>

  <div style="width:100%;max-width:440px;">
    <!-- Logo -->
    <div style="text-align:center; margin-bottom:16px;">
      <div style="display:inline-flex; align-items:center; gap:10px; filter:drop-shadow(0 6px 18px rgba(26,107,255,0.4));">
        <svg width="36" height="36" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
          <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
          <polygon points="325,84 318,98 338,84" fill="white"/>
          <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
          <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
          <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
          <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
        </svg>
        <div style="font-size:28px; font-weight:800; letter-spacing:8px; color:#1A6BFF; line-height:1; padding-left:4px;">VOX</div>
      </div>
    </div>

    <!-- Card -->
    <div style="background:#1E293B; border-radius:20px; border:1px solid rgba(255,255,255,0.07); box-shadow:0 24px 60px rgba(0,0,0,0.5); overflow:hidden;">

      <!-- Header -->
      <div style="padding:20px 24px 16px; border-bottom:1px solid rgba(255,255,255,0.05);">
        <div style="width:38px; height:38px; background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.25); border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:12px;">✨</div>
        <h1 style="font-size:18px; font-weight:800; color:#f1f5f9; margin:0 0 4px;">Tạo tài khoản</h1>
        <p style="font-size:12px; color:#64748b; margin:0; line-height:1.5;">Đăng ký để bắt đầu hành trình học tập trên VOX.</p>
      </div>

      <!-- Form -->
      <div style="padding:18px 24px;">
        <% if resource.errors.any? %>
          <div style="margin-bottom:16px; display:flex; align-items:flex-start; gap:10px; padding:14px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:12px; font-size:13px; color:#f87171; line-height:1.5;">
            <span>⚠</span>
            <div>
              <% resource.errors.full_messages.each do |msg| %>
                <div>• <%= msg %></div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%= form_with model: resource, as: resource_name, url: learner_registration_path, method: :post, local: true, data: { turbo: false } do |f| %>
          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Họ tên</label>
            <%= f.text_field :name, autocomplete: "name",
              placeholder: "Nguyễn Văn A",
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
          </div>
          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Email</label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
              placeholder: "you@example.com",
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
          </div>
          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Mật khẩu</label>
            <%= f.password_field :password, autocomplete: "new-password",
              placeholder: "Tối thiểu 8 ký tự",
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
          </div>
          <div style="margin-bottom:20px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Xác nhận mật khẩu</label>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
              placeholder: "••••••••",
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
          </div>
          <button type="submit"
            style="display:block; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:12px; cursor:pointer; font-family:'Inter',sans-serif; transition:opacity 0.2s;">
            Tạo tài khoản →
          </button>
        <% end %>
      </div>

      <!-- Back to sign in -->
      <div style="padding:0 24px 20px;">
        <%= link_to new_learner_session_path,
          style: "display:flex; align-items:center; justify-content:center; gap:8px; padding:13px; font-size:13px; color:#64748b; text-decoration:none; border:1.5px solid rgba(255,255,255,0.07); border-radius:12px;" do %>
          ← Đã có tài khoản? <span style="color:#818cf8; font-weight:600;">Đăng nhập</span>
        <% end %>
      </div>
    </div>

    <p style="text-align:center; font-size:11px; color:#334155; margin-top:18px;">© <%= Date.current.year %> VOX Platform</p>
  </div>
</div>
