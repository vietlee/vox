<% content_for :title, t('learner_auth.login_title') %>
<% content_for :head do %>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  html, body { background: #0F172A !important; }
  .lp-main { background: #0F172A !important; overflow-y: auto !important; min-height: 100dvh !important; padding-bottom: 0 !important; }
  .lp-page { padding: 0 !important; max-width: none !important; width: 100% !important; }
  .lp-topbar, .lp-bottom-nav { display: none !important; }
  .lp-alert-success, .lp-alert-error { display: none !important; }
</style>
<% end %>

<div style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px 16px; font-family:'Inter',sans-serif;">

  <!-- Flash notices (inline, not from layout) -->
  <% if notice.present? %>
    <div style="position:fixed;top:16px;left:50%;transform:translateX(-50%);background:#10b981;color:#fff;padding:10px 20px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;"><%= notice %></div>
  <% end %>
  <% if alert.present? %>
    <div style="position:fixed;top:16px;left:50%;transform:translateX(-50%);background:rgba(239,68,68,0.9);color:#fff;padding:10px 20px;border-radius:10px;font-size:13px;font-weight:600;z-index:999;"><%= alert %></div>
  <% end %>

  <div style="width:100%;max-width:440px;">
    <!-- Logo (lang switcher provided by layout, floating top-right) -->
    <div style="text-align:center; margin-bottom:16px;">
      <div style="display:inline-flex; align-items:center; gap:10px; filter:drop-shadow(0 6px 18px rgba(26,107,255,0.4));">
        <img src="/icon.svg" width="36" height="36" alt="VOX" style="display:block;">
        <div style="font-size:28px; font-weight:800; letter-spacing:8px; color:#2D1B8B; line-height:1; padding-left:4px;">VOX</div>
      </div>
    </div>

    <!-- Card -->
    <div style="background:#1E293B; border-radius:20px; border:1px solid rgba(255,255,255,0.07); box-shadow:0 24px 60px rgba(0,0,0,0.5); overflow:hidden;">

      <!-- Header -->
      <div style="padding:20px 24px 16px; border-bottom:1px solid rgba(255,255,255,0.05);">
        <div style="width:38px; height:38px; background:rgba(99,102,241,0.12); border:1px solid rgba(99,102,241,0.25); border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:18px; margin-bottom:12px;">🎓</div>
        <h1 style="font-size:18px; font-weight:800; color:#f1f5f9; margin:0 0 4px;"><%= t('learner_auth.login_title') %></h1>
        <p style="font-size:12px; color:#64748b; margin:0; line-height:1.5;"><%= t('learner_auth.login_subtitle') %></p>
      </div>

      <!-- Form -->
      <div style="padding:18px 24px;">
        <% if resource.errors.any? %>
          <div style="margin-bottom:16px; display:flex; align-items:flex-start; gap:10px; padding:14px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:12px; font-size:13px; color:#f87171; line-height:1.5;">
            <span>⚠</span>
            <div>
              <% resource.errors.full_messages.each do |msg| %>
                <div>• <%= msg %></div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%= form_with scope: :learner, url: learner_session_path, method: :post, local: true, data: { turbo: false } do |f| %>
          <div style="margin-bottom:16px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;"><%= t('learner_auth.email') %></label>
            <%= f.email_field :email, autofocus: true, autocomplete: "email",
              value: params[:email].presence || "",
              placeholder: t('learner_auth.ph_email'),
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
          </div>
          <div style="margin-bottom:20px;">
            <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;"><%= t('learner_auth.password') %></label>
            <%= f.password_field :password, autocomplete: "current-password",
              placeholder: "••••••••",
              style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
          </div>
          <%= f.hidden_field :remember_me, value: "1" %>
          <button type="submit"
            style="display:block; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:12px; cursor:pointer; font-family:'Inter',sans-serif; transition:opacity 0.2s;">
            <%= t('learner_auth.login_btn') %>
          </button>
        <% end %>
      </div>

      <!-- Links -->
      <div style="padding:0 28px 24px; display:flex; flex-direction:column; gap:10px;">
        <%= link_to new_learner_password_path,
          style: "display:flex; align-items:center; justify-content:center; gap:8px; padding:13px; font-size:13px; color:#64748b; text-decoration:none; border:1.5px solid rgba(255,255,255,0.07); border-radius:12px;" do %>
          🔑 <%= t('learner_auth.forgot_link') %>
        <% end %>
        <%= link_to new_learner_registration_path,
          style: "display:flex; align-items:center; justify-content:center; gap:8px; padding:13px; font-size:13px; color:#64748b; text-decoration:none; border:1.5px solid rgba(255,255,255,0.07); border-radius:12px;" do %>
          ✨ <%= t('learner_auth.no_account') %> <span style="color:#818cf8; font-weight:600;"><%= t('learner_auth.register_link') %></span>
        <% end %>
      </div>
    </div>

    <p style="text-align:center; font-size:11px; color:#334155; margin-top:18px;">© <%= Date.current.year %> VOX Platform</p>
  </div>
</div>
