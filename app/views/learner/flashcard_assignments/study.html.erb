<% content_for :title, "Học: #{@deck.title}" %>
<% content_for :lp_style, "padding:0;height:calc(100dvh - var(--topbar-h) - var(--bottomnav-h));display:flex;flex-direction:column;overflow:hidden;" %>
<style>
  @media (min-width: 1024px) { .lp-page { max-width: 58.33%; } }
  .fc-header { padding: 12px 16px; background: var(--lp-card); border-bottom: 1px solid var(--lp-border); flex-shrink: 0; }
  .fc-inner { width: 100%; max-width: 100%; margin: 0 auto; }
  .fc-progress { background: #e5e7eb; border-radius: 99px; height: 6px; margin-top: 8px; }
  .fc-progress-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg,#1e3a5f,#4a7fa8); transition: width 0.4s; }
  .fc-arena { flex: 1; display: flex; align-items: center; justify-content: center; padding: 20px 16px 8px; perspective: 1000px; }
  .fc-card-wrap { width: 100%; max-width: 480px; min-height: 220px; height: 280px; position: relative; cursor: pointer; transition: height 0.3s ease; }
  .fc-card { width: 100%; height: 100%; position: relative; transform-style: preserve-3d; transition: transform 0.5s cubic-bezier(0.4,0,0.2,1); }
  .fc-card.flipped { transform: rotateY(180deg); }
  .fc-face { position: absolute; inset: 0; backface-visibility: hidden; border-radius: 24px; display: flex; align-items: center; justify-content: center; padding: 44px 20px 20px; text-align: center; box-shadow: 0 8px 32px rgba(0,0,0,0.12); overflow-y: auto; }
  .fc-front { background: linear-gradient(135deg, #1e3a5f, #16304f); color: white; }
  .fc-back  { background: white; border: 1.5px solid #e5e7eb; transform: rotateY(180deg); }
  .fc-face-label { position: absolute; top: 14px; left: 0; right: 0; text-align: center; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; opacity: 0.6; }
  .fc-front .fc-face-label { color: rgba(255,255,255,0.7); }
  .fc-back .fc-face-label  { color: #9ca3af; }
  .fc-word { font-size: 26px; font-weight: 800; line-height: 1.3; }
  .fc-front .fc-word { color: white; }
  .fc-back .fc-word { color: #1e293b; }
  .fc-image { max-width: 260px; max-height: 220px; width: 100%; object-fit: contain; border-radius: 10px; margin-bottom: 10px; }
  .fc-speak-btn { position: absolute; top: 12px; right: 12px; width: 40px; height: 40px; border-radius: 50%; border: none; display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 2; transition: transform .12s, background .15s; -webkit-tap-highlight-color: transparent; }
  .fc-speak-btn:active { transform: scale(0.88); }
  .fc-speak-front { background: rgba(255,255,255,0.18); color: #fff; }
  .fc-speak-front:hover { background: rgba(255,255,255,0.3); }
  .fc-speak-back  { background: #eef2ff; color: #1e3a5f; }
  .fc-speak-back:hover { background: #e0e7ff; }
  .fc-speak-btn.speaking { animation: fc-pulse 1s ease-in-out infinite; }
  @keyframes fc-pulse { 0%,100% { transform: scale(1); } 50% { transform: scale(1.12); } }
  .fc-tap-hint { color: #9ca3af; font-size: 12px; text-align: center; padding: 6px 0 4px; flex-shrink: 0; }
  .fc-actions { display: flex; justify-content: center; padding: 10px 16px 14px; flex-shrink: 0; background: var(--lp-card); border-top: 1px solid var(--lp-border); }
  .fc-btn-rate { flex: 1; padding: 12px 0; border: none; border-radius: 14px; font-size: 13px; font-weight: 700; cursor: pointer; transition: all 0.15s; }
  .fc-btn-again { background: #fee2e2; color: #991b1b; }
  .fc-btn-hard  { background: #fef3c7; color: #92400e; }
  .fc-btn-good  { background: #d1fae5; color: #065f46; }
  .fc-btn-easy  { background: #dbeafe; color: #1e40af; }
  .fc-btn-rate:active { transform: scale(0.96); }
  .fc-done { text-align: center; padding: 40px 20px; color: var(--lp-text); }
</style>

<div class="fc-header">
  <div class="fc-inner">
    <div style="display:flex;justify-content:space-between;align-items:center;font-size:13px;font-weight:600;color:#6b7280;">
      <span style="min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= @deck.title.truncate(28) %></span>
      <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
        <% if @deck.learner_id == current_learner.id %>
          <%= link_to learner_my_flashcard_path(@deck), title: t('learner_fc.img_make'), "aria-label": t('learner_fc.img_make'),
                style:"display:flex;align-items:center;justify-content:center;width:30px;height:30px;border-radius:10px;border:1px solid #c4b5fd;background:#f5f3ff;color:#6d28d9;flex-shrink:0;" do %>
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2.5"/><circle cx="8.5" cy="8.5" r="1.5"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 15l-5-5L5 21"/></svg>
          <% end %>
        <% end %>
        <button id="fc-tts-btn" onclick="toggleTTS()" title="Bật/tắt đọc to"
                style="display:flex;align-items:center;gap:4px;padding:5px 10px;border-radius:10px;border:1px solid #e2e8f0;background:#fff;color:#64748b;font-size:12px;font-weight:700;cursor:pointer;transition:all .15s;">
          🔊 <span id="fc-tts-label">Đọc</span>
        </button>
        <button id="fc-tts-replay" onclick="replayTTS()" title="Đọc lại"
                style="display:none;align-items:center;justify-content:center;width:30px;height:30px;border-radius:10px;border:1px solid #1e3a5f;background:#eef2ff;color:#1e3a5f;font-size:14px;cursor:pointer;">↺</button>
        <span id="fc-counter" style="font-weight:700;color:#1e3a5f;">1 / <%= @cards.count %></span>
      </div>
    </div>
    <div class="fc-progress"><div class="fc-progress-fill" id="fc-bar" style="width:0%;"></div></div>
  </div>
</div>

<div class="fc-arena" id="fc-arena">
  <% if @cards.any? %>
    <div class="fc-card-wrap" onclick="flipCard()">
      <div class="fc-card" id="fc-card">
        <div class="fc-face fc-front">
          <span class="fc-face-label">Mặt trước</span>
          <button type="button" class="fc-speak-btn fc-speak-front" data-speak="front" title="Đọc mặt trước" aria-label="Đọc">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M6.5 8.788v6.424a.5.5 0 00.757.429l4.5-2.712a.5.5 0 000-.858l-4.5-2.712a.5.5 0 00-.757.429z"/></svg>
          </button>
          <p class="fc-word" id="fc-front-text"></p>
        </div>
        <div class="fc-face fc-back">
          <span class="fc-face-label">Mặt sau</span>
          <button type="button" class="fc-speak-btn fc-speak-back" data-speak="back" title="Đọc mặt sau" aria-label="Đọc">
            <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M6.5 8.788v6.424a.5.5 0 00.757.429l4.5-2.712a.5.5 0 000-.858l-4.5-2.712a.5.5 0 00-.757.429z"/></svg>
          </button>
          <div style="display:flex;flex-direction:column;align-items:center;">
            <img id="fc-back-img" src="" alt="" class="fc-image" style="display:none;">
            <p class="fc-word" id="fc-back-text" style="color:#1e1b4b;"></p>
          </div>
        </div>
      </div>
    </div>
  <% else %>
    <div class="fc-done"><p style="font-size:20px;">Không có thẻ nào</p></div>
  <% end %>
</div>

<% if @cards.any? %>
<p class="fc-tap-hint">Nhấn vào thẻ để lật</p>
<div class="fc-actions" id="fc-actions" style="display:none;">
  <div class="fc-inner" style="display:flex;gap:10px;width:100%;">
    <button class="fc-btn-rate fc-btn-again" onclick="rate('again')">Chưa nhớ</button>
    <button class="fc-btn-rate fc-btn-hard"  onclick="rate('hard')">Khó</button>
    <button class="fc-btn-rate fc-btn-good"  onclick="rate('good')">Tốt</button>
    <button class="fc-btn-rate fc-btn-easy"  onclick="rate('easy')">Dễ</button>
  </div>
</div>
<% end %>

<script>
var _allCards = <%= raw @cards.map { |c| { id: c.id, front: c.front, back: c.back, image: c.image_data.present? ? learner_flashcard_image_path(c.id) : nil } }.to_json %>;
var _queue    = _allCards.slice(); // working queue, may grow with "again" cards
var _total    = _allCards.length;
var _mastered = 0;
var _flipped  = false;
var _csrf     = '<%= form_authenticity_token %>';
var _reviewUrl = '<%= review_learner_flashcard_assignment_path(@assignment.token) %>';
var _doneUrl   = '<%= learner_root_path %>';

function updateUI() {
  var remaining = _queue.length;
  var pct = _total > 0 ? Math.round(_mastered / _total * 100) : 0;
  document.getElementById('fc-bar').style.width = pct + '%';
  // counter: show mastered / total; if there are cards looping back, show (remaining) hint
  var extra = (remaining > _total - _mastered) ? ' (+' + (remaining - (_total - _mastered)) + ' lại)' : '';
  document.getElementById('fc-counter').textContent = _mastered + ' / ' + _total + extra;
}

/* ── Text-to-speech via ElevenLabs (chất lượng cao; 1 credit / đoạn mới, cache để nghe lại miễn phí) ── */
var _ttsOn    = localStorage.getItem('fc_lp_tts_on') === '1';
var TTS_URL   = '<%= learner_ai_tutor_tts_path %>';
var _ttsCache = {};      /* text -> object URL */
var _ttsBusy  = false;

/* Shared audio element primed on first tap — required for iOS Safari playback */
var _fcAudio = new Audio();
_fcAudio.setAttribute('playsinline','');
var _fcPrimed = false;
function fcPrime(){ if(_fcPrimed) return; _fcPrimed=true; try{ var p=_fcAudio.play(); if(p&&p.then) p.then(function(){_fcAudio.pause();_fcAudio.currentTime=0;}).catch(function(){}); }catch(e){} }
document.addEventListener('touchend', fcPrime, {passive:true});
document.addEventListener('click', fcPrime, true);

function fcStopAudio() {
  try { _fcAudio.pause(); } catch(e){}
  document.querySelectorAll('.fc-speak-btn.speaking').forEach(function(b){ b.classList.remove('speaking'); });
}

function fcPlayUrl(url, btn) {
  fcStopAudio();
  if (btn) btn.classList.add('speaking');
  _fcAudio.onended = _fcAudio.onerror = function(){ if (btn) btn.classList.remove('speaking'); };
  _fcAudio.src = url;
  var p = _fcAudio.play(); if (p && p.catch) p.catch(function(){ if(btn) btn.classList.remove('speaking'); });
}

var FC_VI_RE = /[àáảãạăắặằẳẵâấầẩẫậđèéẻẽẹêếềểễệìíỉĩịòóỏõọôốồổỗộơớờởỡợùúủũụưứừửữựỳýỷỹỵ]/i;
function fcDetectLang(t){
  if (FC_VI_RE.test(t)) return 'vi';           // has Vietnamese diacritics
  if (/^[\x00-\x7F\s]*$/.test(t)) return 'en'; // pure ASCII → English
  return 'vi';                                 // other marked chars → default Vietnamese
}
// Language-matched voices
var FC_VOICE = { en: '21m00Tcm4TlvDq8ikWAM', vi: 'EXAVITQu4vr4xnSDxMaL' }; // Rachel (EN) · Sarah (VI)

/* Strip IPA phonetic notation before TTS — e.g. "penguin /ˈpeŋwɪn/" → "penguin" */
function fcStripIPA(text) {
  return (text || '')
    .replace(/\s*\/[^/]{1,60}\//g, '')   // /ˈpeŋwɪn/ style
    .replace(/\s*\[[^\]]{1,60}\]/g, '')   // [phonetics] style
    .trim();
}

/* Add punctuation at natural break points so ElevenLabs pauses correctly */
function fcNormalizeTTS(text) {
  return (text || '')
    // "con voi Ví dụ:" → "con voi, Ví dụ:"
    .replace(/([^\s,.:;!?…])\s+(Ví dụ\s*:)/g, '$1, $2')
    // "elephant Example:" → "elephant. Example:"
    .replace(/([^\s,.:;!?…])\s+(Example\s*:)/gi, '$1. $2')
    // "sentence (Translation" → "sentence. (Translation"
    .replace(/([.!?])\s+\(/g, '$1 (')   // already has punct — keep as is
    .replace(/([^\s,.:;!?…])\s+\(/g, '$1. (') // no punct before ( → add period
    .trim();
}

/* Split mixed text into [{lang, text}] segments at VI/EN word boundaries.
   Punctuation and numbers are absorbed into the current segment. */
function fcSplitLang(text) {
  var tokens = text.match(/[^\s]+|\s+/g) || [];
  var segs = [], cur = null;
  tokens.forEach(function(tok) {
    if (/^\s+$/.test(tok)) { if (cur) cur.text += tok; return; }
    var lang = FC_VI_RE.test(tok) ? 'vi'
             : (/[a-zA-Z]{3,}/.test(tok) ? 'en' : null);
    if (!lang) { if (cur) cur.text += tok; return; } // punct/numbers: attach to current
    if (!cur) { cur = {lang: lang, text: tok}; return; }
    if (lang === cur.lang) { cur.text += tok; }
    else { segs.push(cur); cur = {lang: lang, text: tok}; }
  });
  if (cur && cur.text.trim()) segs.push(cur);
  return segs.length ? segs : [{lang: fcDetectLang(text), text: text}];
}

/* Fetch TTS for one segment with eleven_flash_v2_5 + correct language/voice. */
function fcFetchSeg(segText, lang) {
  segText = segText.trim();
  if (!segText) return Promise.resolve({url: null, credits: null});
  var key = 'seg:' + lang + ':' + segText;
  if (_ttsCache[key]) return Promise.resolve({url: _ttsCache[key], credits: null});
  var fd = new FormData();
  fd.append('text', segText);
  fd.append('model', 'eleven_flash_v2_5');
  fd.append('language_code', lang);
  fd.append('voice_id', FC_VOICE[lang]);
  fd.append('stability', '0.4');
  fd.append('similarity', '0.85');
  fd.append('speed', '0.82');
  fd.append('authenticity_token', _csrf);
  return fetch(TTS_URL, {method:'POST', body:fd})
    .then(function(r){ return r.json(); })
    .then(function(d){
      if (d.error) return {url: null, credits: d.credits_remaining};
      var bin = atob(d.audio_base64), arr = new Uint8Array(bin.length);
      for (var i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);
      var url = URL.createObjectURL(new Blob([arr], {type:'audio/mpeg'}));
      _ttsCache[key] = url;
      return {url: url, credits: d.credits_remaining};
    })
    .catch(function(){ return {url: null, credits: null}; });
}

function fcSpeakRaw(text, btn) {
  if (!text) return;
  if (_ttsCache[text]) { fcPlayUrl(_ttsCache[text], btn); return; }  /* free replay */
  if (_ttsBusy) return;
  _ttsBusy = true;
  if (btn) btn.classList.add('speaking');

  var mixed = FC_VI_RE.test(text) && /[a-zA-Z]{4,}/.test(text);
  var segs  = mixed ? fcSplitLang(text) : [{lang: fcDetectLang(text), text: text}];

  /* Fetch all segments in parallel, then play sequentially */
  Promise.all(segs.map(function(s){ return fcFetchSeg(s.text, s.lang); }))
    .then(function(results) {
      _ttsBusy = false;
      var lastCredits = null;
      var urls = [];
      results.forEach(function(r){
        if (r.credits != null) lastCredits = r.credits;
        if (r.url) urls.push(r.url);
      });
      if (lastCredits != null && window.updateLpCredits) updateLpCredits(lastCredits);
      if (!mixed && urls[0]) _ttsCache[text] = urls[0]; /* cache single-lang by full text */
      if (!urls.length) { if (btn) btn.classList.remove('speaking'); return; }
      fcStopAudio();
      (function play(i) {
        if (i >= urls.length) { if (btn) btn.classList.remove('speaking'); return; }
        _fcAudio.onended = _fcAudio.onerror = function(){ play(i + 1); };
        _fcAudio.src = urls[i];
        var p = _fcAudio.play(); if (p && p.catch) p.catch(function(){ play(i + 1); });
      })(0);
    })
    .catch(function(){ _ttsBusy = false; if (btn) btn.classList.remove('speaking'); });
}

/* Auto-read (only when toggle is on) */
function fcSpeak(text) {
  if (!_ttsOn) return;
  fcSpeakRaw(text, null);
}

/* Manual per-card read — works regardless of auto-read toggle */
function speakSide(side) {
  var card = _queue[0];
  if (!card) return;
  var text = side === 'back' ? fcNormalizeTTS(card.back) : fcStripIPA(card.front);
  var btn  = document.querySelector('.fc-speak-' + side);
  fcSpeakRaw(text, btn);
}

/* Bind speak buttons (avoids inline-onclick global-resolution issues under Turbo) */
document.querySelectorAll('.fc-speak-btn').forEach(function(btn) {
  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    speakSide(btn.getAttribute('data-speak'));
  });
});

window.toggleTTS = function() {
  _ttsOn = !_ttsOn;
  localStorage.setItem('fc_lp_tts_on', _ttsOn ? '1' : '0');
  var btn = document.getElementById('fc-tts-btn');
  var lbl = document.getElementById('fc-tts-label');
  var replay = document.getElementById('fc-tts-replay');
  if (_ttsOn) {
    btn.style.borderColor = '#1e3a5f'; btn.style.color = '#1e3a5f'; btn.style.background = '#eef2ff';
    lbl.textContent = 'Đang bật';
    replay.style.display = 'flex';
    var card = _queue[0];
    if (card) fcSpeak(_flipped ? card.back : card.front);
  } else {
    fcStopAudio();
    btn.style.borderColor = '#e2e8f0'; btn.style.color = '#64748b'; btn.style.background = '#fff';
    lbl.textContent = 'Đọc';
    replay.style.display = 'none';
  }
};

window.replayTTS = function() {
  var card = _queue[0];
  if (!card) return;
  fcSpeak(_flipped ? fcNormalizeTTS(card.back) : fcStripIPA(card.front));
};

function scaleFcFont(el, text) {
  var len = (text || '').length;
  el.style.fontSize = len <= 30 ? '26px' : len <= 60 ? '20px' : len <= 120 ? '16px' : '13px';
}

function showCard(card) {
  var wrap = document.querySelector('.fc-card-wrap');
  if (wrap) wrap.style.height = '280px';
  var frontEl = document.getElementById('fc-front-text');
  var backEl  = document.getElementById('fc-back-text');
  frontEl.textContent = card.front;
  backEl.textContent  = card.back;
  scaleFcFont(frontEl, card.front);
  scaleFcFont(backEl,  card.back);
  var img = document.getElementById('fc-back-img');
  if (card.image) { img.src = card.image; img.style.display = ''; }
  else { img.style.display = 'none'; }
  document.getElementById('fc-card').classList.remove('flipped');
  document.getElementById('fc-actions').style.display = 'none';
  document.querySelector('.fc-tap-hint').style.display = '';
  _flipped = false;
  updateUI();
  fcSpeak(fcStripIPA(card.front));
}

function expandCardWrap() {
  var backFace = document.querySelector('.fc-back');
  var wrap = document.querySelector('.fc-card-wrap');
  if (!backFace || !wrap) return;
  var sh = backFace.scrollHeight;
  if (sh > wrap.offsetHeight) wrap.style.height = sh + 'px';
}

function flipCard() {
  if (_flipped) return;
  document.getElementById('fc-card').classList.add('flipped');
  document.getElementById('fc-actions').style.display = 'flex';
  document.querySelector('.fc-tap-hint').style.display = 'none';
  _flipped = true;
  var card = _queue[0];
  if (card) fcSpeak(fcNormalizeTTS(card.back));
  // Expand card height to fit back content (image + text)
  requestAnimationFrame(function() { requestAnimationFrame(expandCardWrap); });
  // Re-expand after image finishes loading
  var img = document.getElementById('fc-back-img');
  if (img && img.style.display !== 'none' && !img.complete) {
    img.addEventListener('load', expandCardWrap, { once: true });
  }
}

function rate(r) {
  var card = _queue.shift(); // take current card
  var mastered = (r !== 'again');

  if (r === 'again') {
    _queue.push(card); // re-add to end of queue
  } else {
    _mastered++;
  }

  // save to server
  fetch(_reviewUrl, {
    method: 'POST',
    headers: { 'X-CSRF-Token': _csrf, 'Content-Type': 'application/json' },
    body: JSON.stringify({ flashcard_id: card.id, rating: r, mastered: mastered })
  }).then(function(res){ return res.json(); }).then(function(d){
    if (d.new_badges && d.new_badges.length > 0 && window.showBadgeToast) {
      var b = d.new_badges[0];
      window.showBadgeToast(b.icon, b.title, b.desc);
    }
  }).catch(function(){});

  if (_queue.length === 0) {
    showDone();
    return;
  }
  showCard(_queue[0]);
}

function showDone() {
  document.getElementById('fc-arena').innerHTML = '<div class="fc-done"><div style="font-size:64px;margin-bottom:16px;">🎉</div><h2 style="font-size:24px;font-weight:800;color:#1e293b;margin-bottom:8px;">Hoàn thành!</h2><p style="color:#6b7280;margin-bottom:24px;">Bạn đã học hết tất cả ' + _total + ' thẻ.</p><a href="' + _doneUrl + '" style="background:#1e3a5f;color:white;padding:12px 28px;border-radius:14px;font-weight:700;font-size:15px;text-decoration:none;">← Về trang chủ</a></div>';
  document.getElementById('fc-actions') && (document.getElementById('fc-actions').style.display = 'none');
  document.querySelector('.fc-tap-hint') && (document.querySelector('.fc-tap-hint').style.display = 'none');
  document.getElementById('fc-bar').style.width = '100%';
  document.getElementById('fc-counter').textContent = _total + ' / ' + _total;
}

// Restore TTS button state on load
if (_ttsOn) {
  document.getElementById('fc-tts-btn').style.borderColor = '#1e3a5f';
  document.getElementById('fc-tts-btn').style.color = '#1e3a5f';
  document.getElementById('fc-tts-btn').style.background = '#eef2ff';
  document.getElementById('fc-tts-label').textContent = 'Đang bật';
  document.getElementById('fc-tts-replay').style.display = 'flex';
}

showCard(_queue[0]);
</script>
