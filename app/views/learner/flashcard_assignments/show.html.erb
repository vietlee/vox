<% content_for :title, @assignment.flashcard_deck.title %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= @assignment.flashcard_deck.title %></span>
<% end %>
<% deck = @assignment.flashcard_deck %>
<% study_url = study_learner_flashcard_assignment_path(@assignment.token) %>
<% btn_label = @assignment.completed? ? t('learner_fc.review_again') : t('learner_fc.start_study') %>
<style>
  @media (min-width: 1024px) { .lp-page { max-width: 60%; } }
  .fc-sticky { position:fixed; bottom:var(--bottomnav-h,56px); left:0; right:0; z-index:100;
    padding:10px 16px; background:rgba(255,255,255,.92); backdrop-filter:blur(10px);
    border-top:1px solid #e5e7eb; display:none; }
  .fc-sticky a { display:flex; align-items:center; justify-content:center; gap:8px;
    width:100%; max-width:500px; margin:0 auto; padding:14px;
    background:linear-gradient(135deg,#1e3a5f,#2d5f8a); color:#fff; border-radius:14px;
    font-size:16px; font-weight:800; text-decoration:none; }
</style>

<%# Hero section: icon + title + inline card count + big CTA %>
<div style="text-align:center;padding:20px 0 24px;">
  <div style="width:72px;height:72px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
    <svg width="36" height="36" fill="none" stroke="#065f46" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
  </div>
  <h1 style="font-size:20px;font-weight:800;line-height:1.3;margin:0 0 6px;"><%= deck.title %></h1>
  <% if deck.subject.present? %>
    <p style="font-size:13px;color:#6b7280;margin:0 0 10px;"><%= deck.subject %></p>
  <% end %>
  <span style="display:inline-block;background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;border-radius:20px;font-size:13px;font-weight:700;padding:4px 14px;">
    <%= deck.flashcards.count %> <%= t('learner_fc.cards_count_unit') %>
  </span>
</div>

<%# Primary CTA — always visible on load %>
<div style="margin-bottom:16px;">
  <%= link_to study_url, id: "fc-start-btn", style: "display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:16px;background:linear-gradient(135deg,#1e3a5f,#2d5f8a);color:#fff;border-radius:14px;font-size:17px;font-weight:800;text-decoration:none;box-shadow:0 4px 16px rgba(30,58,95,.3);" do %>
    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <%= btn_label %>
  <% end %>
</div>

<% if deck.learner_id == current_learner.id %>
  <% has_images = deck.flashcards.where.not(image_data: [nil, ""]).exists? %>
  <button id="fc-img-btn" onclick="fcGenImages()"
          style="width:100%;margin-bottom:20px;padding:12px;border-radius:12px;border:1px solid #c4b5fd;background:#f5f3ff;color:#6d28d9;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2.5"/><circle cx="8.5" cy="8.5" r="1.5"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 15l-5-5L5 21"/></svg>
    <span id="fc-img-label"><%= has_images ? t('learner_fc.img_remake') : t('learner_fc.img_make') %> <%= t('learner_fc.img_cost_suffix', n: 5) %></span>
  </button>
  <p style="font-size:11px;color:#94a3b8;margin:-14px 0 16px;"><%= t('learner_fc.img_hint') %></p>
<% end %>

<%# Sticky bar — appears once user scrolls past the main CTA %>
<div class="fc-sticky" id="fc-sticky">
  <%= link_to study_url do %>
    <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <%= btn_label %>
  <% end %>
</div>
<script>
  (function(){
    var btn = document.getElementById('fc-start-btn');
    var sticky = document.getElementById('fc-sticky');
    if (!btn || !sticky) return;
    var io = new IntersectionObserver(function(entries){
      sticky.style.display = entries[0].isIntersecting ? 'none' : 'block';
    }, { threshold: 0.1 });
    io.observe(btn);
  })();
</script>

<!-- Card preview with images -->
<% preview_cards = deck.flashcards.limit(6).to_a %>
<% if preview_cards.any? %>
  <p class="lp-section-title"><%= t('learner_fc.preview_title') %></p>
  <div style="display:grid;gap:10px;margin-bottom:16px;">
    <% preview_cards.each do |card| %>
      <% has_img = card.image_data.present? %>
      <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;<%= has_img ? '' : 'padding:14px 16px;' %>">
        <% if has_img %>
          <div style="display:flex;align-items:stretch;">
            <div style="width:80px;flex-shrink:0;background:#f1f5f9;">
              <img src="<%= learner_flashcard_image_path(card.id) %>" alt="" style="width:80px;height:80px;object-fit:cover;display:block;">
            </div>
            <div style="padding:10px 14px;flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:700;color:#0f172a;margin:0 0 3px;"><%= card.front %></p>
              <p style="font-size:12px;color:#64748b;margin:0;line-height:1.5;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;"><%= card.back %></p>
            </div>
          </div>
        <% else %>
          <p style="font-size:13px;font-weight:700;color:#0f172a;margin:0 0 4px;"><%= card.front %></p>
          <p style="font-size:12px;color:#64748b;margin:0;line-height:1.5;"><%= card.back %></p>
        <% end %>
      </div>
    <% end %>
    <% rest = deck.flashcards.count - 6 %>
    <% if rest > 0 %>
      <p style="text-align:center;font-size:12px;color:#94a3b8;margin:4px 0 0;"><%= t('learner_fc.preview_more', n: rest) %></p>
    <% end %>
  </div>
<% end %>

<% if deck.learner_id == current_learner.id %>
<script>
(function(){
  var CSRF      = document.querySelector('meta[name="csrf-token"]').content;
  var GEN_URL   = '<%= learner_generate_images_my_flashcard_path(deck) %>';
  var POLL_URL  = '<%= learner_image_status_my_flashcard_path(deck) %>';
  var RESET_URL = '<%= learner_reset_image_status_my_flashcard_path(deck) %>';
  var PAGE_URL  = window.location.href;
  var LBL_MAKE = '<%= j (t('learner_fc.img_make') + " " + t('learner_fc.img_cost_suffix', n: 5)) %>';
  var LBL_MIN  = '<%= j t('learner_fc.img_mini_label') %>';
  var LBL_DRAW = '<%= j t('learner_fc.img_drawing') %>';
  var LBL_READY= '<%= j t('learner_fc.img_ready') %>';
  var LBL_TOUT = '<%= j t('learner_fc.img_timeout') %>';
  var btn = document.getElementById('fc-img-btn'), label = document.getElementById('fc-img-label');
  var _gen = <%= deck.image_generating? ? 'true' : 'false' %>;
  var _totalCards = <%= deck.flashcards.count %>;
  var _pollCount = 0;
  var _allDoneCount = 0;
  var _lastDone = -1;
  var _stuckCount = 0;

  function busy(t){ btn.disabled=true; btn.style.opacity='.7'; btn.style.cursor='wait'; label.textContent=t; }
  function setReady(){ btn.disabled=false; btn.style.opacity='1'; btn.style.cursor='pointer'; label.textContent=LBL_MAKE; }

  function startOverlay(){
    AiProgress.start({
      title: LBL_DRAW,
      miniLabel: LBL_MIN,
      msgs: [LBL_DRAW, 'AI đang vẽ ảnh cho từng thẻ…', 'Đang hoàn thiện…']
    });
  }

  function forceFinish(){
    fetch(RESET_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF} }).catch(function(){});
    AiProgress.done(PAGE_URL, LBL_READY);
  }

  function poll(){
    _pollCount++;
    if (_pollCount > 100) {  // ~5 minutes max
      fetch(RESET_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF} }).catch(function(){});
      AiProgress.error();
      showLpToast(LBL_TOUT, 'error');
      setReady();
      return;
    }
    fetch(POLL_URL,{headers:{'Accept':'application/json'}}).then(function(r){return r.json();}).then(function(d){
      if (d.pending) {
        if (d.done != null && _totalCards > 0) {
          var allDone = d.done >= _totalCards;
          var cardPct = Math.round(d.done / _totalCards * 90);
          var msg = allDone ? 'Đang hoàn tất xử lý…' : 'AI đang vẽ… ' + d.done + '/' + _totalCards + ' thẻ xong';
          if (AiProgress.setProgress) AiProgress.setProgress(cardPct, msg);
          if (allDone) {
            _allDoneCount++;
            if (_allDoneCount >= 2) { forceFinish(); return; }
          } else {
            _allDoneCount = 0;
          }
          // Stuck detector: done count hasn't changed for 15 polls (~45s) and
          // at least 1 card is done — some cards likely failed, finish anyway.
          if (d.done === _lastDone) {
            _stuckCount++;
            if (_stuckCount >= 15 && d.done > 0) { forceFinish(); return; }
          } else {
            _stuckCount = 0;
            _lastDone = d.done;
          }
        }
        setTimeout(poll,3000);
        return;
      }
      if (window.updateLpCredits) updateLpCredits(d.credits_remaining);
      AiProgress.done(PAGE_URL, LBL_READY);
    }).catch(function(){ setTimeout(poll,4000); });
  }

  if (_gen){ busy('⏳ ' + LBL_DRAW); startOverlay(); poll(); }

  window.fcGenImages = function(){
    lpConfirm('<%= j t('learner_fc.img_confirm') %>', function(){
      busy('⏳ <%= j t('learner_fc.img_init') %>');
      var fd = new FormData(); fd.append('authenticity_token', CSRF);
      fetch(GEN_URL,{method:'POST',body:fd}).then(function(r){return r.json();}).then(function(d){
        if (d.error){ showLpToast(d.error, 'error'); setReady(); return; }
        busy('⏳ ' + LBL_DRAW);
        startOverlay();
        poll();
      }).catch(function(){ showLpToast('<%= j t('learner_fc.err_conn') %>', 'error'); setReady(); });
    });
  };
})();
</script>
<% end %>
