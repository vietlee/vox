<% content_for :title, @deck.title %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_fc.mine_title'), learner_my_flashcards_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= @deck.title.truncate(30) %></span>
<% end %>

<div style="text-align:center;padding:20px 0 28px;">
  <div style="width:72px;height:72px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
    <svg width="36" height="36" fill="none" stroke="#065f46" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
  </div>
  <h1 style="font-size:20px;font-weight:800;color:#0f172a;margin:0 0 4px;"><%= @deck.title %></h1>
  <% if @deck.subject.present? && @deck.subject != @deck.title %>
    <p style="font-size:13px;color:#64748b;margin:0;"><%= @deck.subject %></p>
  <% end %>
  <div style="display:inline-flex;align-items:center;gap:6px;margin-top:10px;background:#dcfce7;border-radius:99px;padding:4px 12px;">
    <span style="font-size:12px;font-weight:700;color:#166534;">✨ <%= t('learner_fc.ai_generated') %></span>
  </div>
</div>

<div class="lp-card" style="margin-bottom:16px;">
  <div class="lp-card-body" style="text-align:center;">
    <p style="font-size:40px;font-weight:900;color:#10b981;margin:0;"><%= @deck.card_count %></p>
    <p style="color:#9ca3af;font-size:13px;margin:4px 0 20px;"><%= t('learner_fc.cards_count_unit') %></p>
    <% if @assignment %>
      <%= link_to study_learner_flashcard_assignment_path(@assignment.token),
            class: "lp-btn lp-btn-primary lp-btn-full", style: "font-size:15px;padding:13px;" do %>
        <%= @assignment.completed? ? t('learner_fc.review_again') : t('learner_fc.start_study') %>
      <% end %>
    <% end %>

    <% has_images = @deck.flashcards.where.not(image_data: [nil, ""]).exists? %>
    <button id="fc-img-btn" onclick="fcGenImages()"
            style="width:100%;margin-top:10px;padding:11px;border-radius:12px;border:1px solid #c4b5fd;background:#f5f3ff;color:#6d28d9;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">
      <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2.5"/><circle cx="8.5" cy="8.5" r="1.5"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 15l-5-5L5 21"/></svg>
      <span id="fc-img-label"><%= (has_images ? t('learner_fc.img_remake') : t('learner_fc.img_make')) + " " + t('learner_fc.img_cost_suffix', n: @image_cost) %></span>
    </button>
    <p id="fc-img-hint" style="font-size:11px;color:#94a3b8;margin:6px 0 0;"><%= t('learner_fc.img_hint') %></p>

    <div style="margin-top:18px;padding-top:14px;border-top:1px solid #f1f5f9;text-align:center;">
      <button onclick="fcDeleteThisDeck()" style="background:none;border:none;font-size:13px;color:#94a3b8;cursor:pointer;padding:4px 10px;border-radius:8px;display:inline-flex;align-items:center;gap:5px;">
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><polyline points="3 6 5 6 21 6"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14H6L5 6m5 4v7m4-7v7M9 6V4h6v2"/></svg>
        Xoá bộ thẻ này
      </button>
    </div>
  </div>
</div>

<!-- All cards (editable) -->
<p class="lp-section-title"><%= t('learner_fc.preview_title') %></p>
<% all_cards = @deck.flashcards.order(:position).to_a %>
<div style="display:grid;gap:10px;" id="fc-cards-list">
  <% all_cards.each do |card| %>
    <% has_img = card.image_data.present? %>
    <div id="fc-card-<%= card.id %>" style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;">
      <%# Display mode %>
      <div id="fc-view-<%= card.id %>" style="<%= has_img ? '' : 'padding:12px 14px;' %>">
        <% if has_img %>
          <div style="display:flex;align-items:stretch;">
            <div style="width:72px;flex-shrink:0;background:#f1f5f9;">
              <img src="<%= learner_flashcard_image_path(card.id) %>" alt="" style="width:72px;height:72px;object-fit:cover;display:block;">
            </div>
            <div style="padding:10px 12px;flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:700;color:#0f172a;margin:0 0 2px;"><%= card.front %></p>
              <p style="font-size:12px;color:#64748b;margin:0;line-height:1.5;"><%= card.back %></p>
            </div>
            <button onclick="fcEditCard(<%= card.id %>)" style="flex-shrink:0;padding:0 12px;border:none;background:none;cursor:pointer;color:#94a3b8;font-size:16px;" title="Sửa">✏️</button>
          </div>
        <% else %>
          <div style="display:flex;align-items:flex-start;gap:8px;">
            <div style="flex:1;min-width:0;">
              <p style="font-size:13px;font-weight:700;color:#0f172a;margin:0 0 3px;"><%= card.front %></p>
              <p style="font-size:12px;color:#64748b;margin:0;line-height:1.5;"><%= card.back %></p>
            </div>
            <button onclick="fcEditCard(<%= card.id %>)" style="flex-shrink:0;border:none;background:none;cursor:pointer;color:#94a3b8;padding:2px 4px;font-size:15px;" title="Sửa">✏️</button>
          </div>
        <% end %>
      </div>
      <%# Edit mode (hidden by default) %>
      <div id="fc-edit-<%= card.id %>" style="display:none;padding:12px 14px;">
        <textarea id="fc-front-<%= card.id %>" rows="2"
          style="display:block;width:100%;padding:8px 10px;border:1.5px solid #6366f1;border-radius:10px;font-size:13px;font-weight:700;color:#0f172a;resize:vertical;font-family:inherit;margin-bottom:8px;"><%= card.front %></textarea>
        <textarea id="fc-back-<%= card.id %>" rows="3"
          style="display:block;width:100%;padding:8px 10px;border:1.5px solid #e2e8f0;border-radius:10px;font-size:12px;color:#374151;resize:vertical;font-family:inherit;margin-bottom:10px;"><%= card.back %></textarea>
        <div style="display:flex;gap:8px;">
          <button onclick="fcSaveCard(<%= card.id %>)"
            style="flex:1;padding:8px;background:#4f46e5;color:#fff;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;">
            Lưu
          </button>
          <button onclick="fcCancelEdit(<%= card.id %>)"
            style="padding:8px 14px;background:#f1f5f9;color:#64748b;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;">
            Huỷ
          </button>
        </div>
      </div>
    </div>
  <% end %>
</div>
<script>
var FC_CSRF = document.querySelector('meta[name="csrf-token"]').content;
var FC_BASE = '<%= learner_my_flashcard_path(@deck) %>/cards/';
function fcEditCard(id) {
  document.getElementById('fc-view-' + id).style.display = 'none';
  document.getElementById('fc-edit-' + id).style.display = 'block';
  document.getElementById('fc-front-' + id).focus();
}
function fcCancelEdit(id) {
  document.getElementById('fc-edit-' + id).style.display = 'none';
  document.getElementById('fc-view-' + id).style.display = '';
}
function fcSaveCard(id) {
  var front = document.getElementById('fc-front-' + id).value.trim();
  var back  = document.getElementById('fc-back-' + id).value.trim();
  if (!front || !back) { alert('Không được để trống.'); return; }
  fetch(FC_BASE + id, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': FC_CSRF, 'Accept': 'application/json' },
    body: JSON.stringify({ front: front, back: back })
  }).then(function(r){ return r.json(); }).then(function(d) {
    if (d.ok) {
      var viewEl = document.getElementById('fc-view-' + id);
      var ps = viewEl.querySelectorAll('p');
      if (ps[0]) ps[0].textContent = d.front;
      if (ps[1]) ps[1].textContent = d.back;
      fcCancelEdit(id);
    } else {
      alert(d.error || 'Lỗi khi lưu.');
    }
  }).catch(function(){ alert('Lỗi kết nối.'); });
}
</script>

<script>
(function(){
  var CSRF      = document.querySelector('meta[name="csrf-token"]').content;
  var GEN_URL   = '<%= learner_generate_images_my_flashcard_path(@deck) %>';
  var POLL_URL  = '<%= learner_image_status_my_flashcard_path(@deck) %>';
  var RESET_URL = '<%= learner_reset_image_status_my_flashcard_path(@deck) %>';
  var PAGE_URL  = window.location.href;
  var LBL_MAKE = '<%= j (t('learner_fc.img_make') + " " + t('learner_fc.img_cost_suffix', n: @image_cost)) %>';
  var LBL_MIN  = '<%= j t('learner_fc.img_mini_label') %>';
  var LBL_DRAW = '<%= j t('learner_fc.img_drawing') %>';
  var LBL_READY= '<%= j t('learner_fc.img_ready') %>';
  var LBL_TOUT = '<%= j t('learner_fc.img_timeout') %>';
  var btn   = document.getElementById('fc-img-btn');
  var label = document.getElementById('fc-img-label');
  var _generating = <%= @deck.image_generating? ? 'true' : 'false' %>;
  var _pollCount  = 0;

  function setBusy(txt){ btn.disabled=true; btn.style.opacity='.7'; btn.style.cursor='wait'; label.textContent=txt; }
  function setReady(){ btn.disabled=false; btn.style.opacity='1'; btn.style.cursor='pointer'; label.textContent=LBL_MAKE; }

  var _totalCards = <%= @deck.flashcards.count %>;
  var _allDoneCount = 0;
  var _lastDone = -1;
  var _stuckCount = 0;

  function startOverlay(){
    AiProgress.start({
      title: LBL_DRAW,
      miniLabel: LBL_MIN,
      msgs: [LBL_DRAW, 'AI đang vẽ ảnh cho từng thẻ…', 'Đang hoàn thiện…']
    });
  }

  function forceFinish(){
    fetch(RESET_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF} }).catch(function(){});
    AiProgress.done(PAGE_URL, LBL_READY);
  }

  function poll(){
    _pollCount++;
    if (_pollCount > 100) {  // ~5 minutes max
      fetch(RESET_URL, { method:'POST', headers:{'X-CSRF-Token':CSRF} }).catch(function(){});
      AiProgress.error();
      showLpToast(LBL_TOUT, 'error');
      setReady();
      return;
    }
    fetch(POLL_URL, { headers:{'Accept':'application/json'} })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.pending) {
          if (d.done != null && _totalCards > 0) {
            var allDone = d.done >= _totalCards;
            var cardPct = Math.round(d.done / _totalCards * 90);
            var msg = allDone ? 'Đang hoàn tất xử lý…' : 'AI đang vẽ… ' + d.done + '/' + _totalCards + ' thẻ xong';
            if (AiProgress.setProgress) AiProgress.setProgress(cardPct, msg);
            if (allDone) {
              _allDoneCount++;
              if (_allDoneCount >= 2) { forceFinish(); return; }
            } else {
              _allDoneCount = 0;
            }
            // Stuck detector: if done count hasn't changed for 15 polls (~45s) and
            // we have at least 1 card done, some cards likely failed — finish anyway.
            if (d.done === _lastDone) {
              _stuckCount++;
              if (_stuckCount >= 15 && d.done > 0) { forceFinish(); return; }
            } else {
              _stuckCount = 0;
              _lastDone = d.done;
            }
          }
          setTimeout(poll, 3000);
          return;
        }
        if (window.updateLpCredits) updateLpCredits(d.credits_remaining);
        AiProgress.done(PAGE_URL, LBL_READY);
      })
      .catch(function(){ setTimeout(poll, 4000); });
  }

  if (_generating) { setBusy('⏳ ' + LBL_DRAW); startOverlay(); poll(); }

  window.fcDeleteThisDeck = function() {
    lpDeleteConfirm(
      '<%= learner_destroy_my_flashcard_path(@deck) %>',
      'Xoá bộ flashcard?',
      'Bộ "<%= j @deck.title %>" và tất cả thẻ sẽ bị xoá vĩnh viễn. Hành động này không thể hoàn tác.',
      function() { window.location = '<%= learner_my_flashcards_path %>'; }
    );
  };

  window.fcGenImages = function(){
    lpConfirm('<%= j t('learner_fc.img_confirm') %>', function(){
      setBusy('⏳ <%= j t('learner_fc.img_init') %>');
      var fd = new FormData(); fd.append('authenticity_token', CSRF);
      fetch(GEN_URL, { method:'POST', body:fd })
        .then(function(r){ return r.json(); })
        .then(function(d){
          if (d.error) { showLpToast(d.error, 'error'); setReady(); return; }
          setBusy('⏳ ' + LBL_DRAW);
          startOverlay();
          poll();
        })
        .catch(function(){ showLpToast('<%= j t('learner_fc.err_conn') %>', 'error'); setReady(); });
    });
  };
})();
</script>
