<% content_for :title, @deck.title %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_fc.mine_title'), learner_my_flashcards_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= @deck.title.truncate(30) %></span>
<% end %>

<div style="text-align:center;padding:20px 0 28px;">
  <div style="width:72px;height:72px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;">
    <svg width="36" height="36" fill="none" stroke="#065f46" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
  </div>
  <h1 style="font-size:20px;font-weight:800;color:#0f172a;margin:0 0 4px;"><%= @deck.title %></h1>
  <% if @deck.subject.present? && @deck.subject != @deck.title %>
    <p style="font-size:13px;color:#64748b;margin:0;"><%= @deck.subject %></p>
  <% end %>
  <div style="display:inline-flex;align-items:center;gap:6px;margin-top:10px;background:#dcfce7;border-radius:99px;padding:4px 12px;">
    <span style="font-size:12px;font-weight:700;color:#166534;">✨ <%= t('learner_fc.ai_generated') %></span>
  </div>
</div>

<div class="lp-card" style="margin-bottom:16px;">
  <div class="lp-card-body" style="text-align:center;">
    <p style="font-size:40px;font-weight:900;color:#10b981;margin:0;"><%= @deck.card_count %></p>
    <p style="color:#9ca3af;font-size:13px;margin:4px 0 20px;"><%= t('learner_fc.cards_count_unit') %></p>
    <% if @assignment %>
      <%= link_to study_learner_flashcard_assignment_path(@assignment.token),
            class: "lp-btn lp-btn-primary lp-btn-full", style: "font-size:15px;padding:13px;" do %>
        <%= @assignment.completed? ? t('learner_fc.review_again') : t('learner_fc.start_study') %>
      <% end %>
    <% end %>

    <% has_images = @deck.flashcards.where.not(image_data: [nil, ""]).exists? %>
    <button id="fc-img-btn" onclick="fcGenImages()"
            style="width:100%;margin-top:10px;padding:11px;border-radius:12px;border:1px solid #c4b5fd;background:#f5f3ff;color:#6d28d9;font-size:13px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;">
      <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2.5"/><circle cx="8.5" cy="8.5" r="1.5"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 15l-5-5L5 21"/></svg>
      <span id="fc-img-label"><%= (has_images ? t('learner_fc.img_remake') : t('learner_fc.img_make')) + " " + t('learner_fc.img_cost_suffix', n: @image_cost) %></span>
    </button>
    <p id="fc-img-hint" style="font-size:11px;color:#94a3b8;margin:6px 0 0;"><%= t('learner_fc.img_hint') %></p>
  </div>
</div>

<!-- Preview cards -->
<p class="lp-section-title"><%= t('learner_fc.preview_title') %></p>
<div style="display:grid;gap:10px;">
  <% @deck.flashcards.limit(6).each do |card| %>
    <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px;">
      <p style="font-size:13px;font-weight:700;color:#0f172a;margin:0 0 4px;"><%= card.front %></p>
      <p style="font-size:12px;color:#64748b;margin:0;line-height:1.5;"><%= card.back %></p>
    </div>
  <% end %>
  <% if @deck.card_count > 6 %>
    <p style="text-align:center;font-size:12px;color:#94a3b8;margin:4px 0 0;"><%= t('learner_fc.preview_more', n: @deck.card_count - 6) %></p>
  <% end %>
</div>

<script>
(function(){
  var CSRF = document.querySelector('meta[name="csrf-token"]').content;
  var GEN_URL  = '<%= learner_generate_images_my_flashcard_path(@deck) %>';
  var POLL_URL = '<%= learner_image_status_my_flashcard_path(@deck) %>';
  var LBL_MAKE = '<%= j (t('learner_fc.img_make') + " " + t('learner_fc.img_cost_suffix', n: @image_cost)) %>';
  var btn = document.getElementById('fc-img-btn');
  var label = document.getElementById('fc-img-label');
  var _generating = <%= @deck.image_generating? ? 'true' : 'false' %>;

  function setBusy(txt){ btn.disabled = true; btn.style.opacity = '.7'; btn.style.cursor = 'wait'; label.textContent = txt; }
  function poll(){
    fetch(POLL_URL, { headers:{'Accept':'application/json'} })
      .then(function(r){ return r.json(); })
      .then(function(d){
        if (d.pending) { setTimeout(poll, 3000); return; }
        if (window.updateLpCredits) updateLpCredits(d.credits_remaining);
        label.textContent = '✓ <%= j t('learner_fc.img_done') %>';
        setTimeout(function(){ location.reload(); }, 800);
      })
      .catch(function(){ setTimeout(poll, 4000); });
  }
  if (_generating) { setBusy('⏳ <%= j t('learner_fc.img_drawing') %>'); poll(); }

  window.fcGenImages = function(){
    lpConfirm('<%= j t('learner_fc.img_confirm') %>', function(){
      setBusy('⏳ <%= j t('learner_fc.img_init') %>');
      var fd = new FormData(); fd.append('authenticity_token', CSRF);
      fetch(GEN_URL, { method:'POST', body:fd })
        .then(function(r){ return r.json(); })
        .then(function(d){
          if (d.error) { showLpToast(d.error, 'error'); btn.disabled=false; btn.style.opacity='1'; btn.style.cursor='pointer'; label.textContent=LBL_MAKE; return; }
          setBusy('⏳ <%= j t('learner_fc.img_drawing') %>'); poll();
        })
        .catch(function(){ showLpToast('<%= j t('learner_fc.err_conn') %>', 'error'); btn.disabled=false; btn.style.opacity='1'; });
    });
  };
})();
</script>
