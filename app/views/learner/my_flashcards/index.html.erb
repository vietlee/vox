<% content_for :title, t('learner_fc.mine_title') %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= t('learner_fc.mine_title') %></span>
<% end %>

<!-- Header -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
  <div>
    <h1 style="font-size:18px;font-weight:800;color:#0f172a;margin:0 0 2px;"><%= t('learner_fc.mine_title') %></h1>
    <p style="font-size:12px;color:#64748b;margin:0;"><%= t('learner_fc.mine_subtitle') %></p>
  </div>
  <%= link_to learner_new_my_flashcard_path, class: "lp-btn lp-btn-primary", style: "font-size:13px;padding:8px 14px;white-space:nowrap;" do %>
    ✨ <%= t('learner_fc.create_new') %>
  <% end %>
</div>

<% if @decks.empty? %>
  <div style="text-align:center;padding:48px 24px;background:#fff;border-radius:16px;border:1px dashed #e2e8f0;">
    <div style="font-size:40px;margin-bottom:12px;">🗂️</div>
    <p style="font-size:15px;font-weight:700;color:#1e293b;margin:0 0 6px;"><%= t('learner_fc.empty_title') %></p>
    <p style="font-size:13px;color:#64748b;margin:0 0 20px;"><%= t('learner_fc.empty_desc') %></p>
    <%= link_to "✨ #{t('learner_fc.create_now')}", learner_new_my_flashcard_path, class: "lp-btn lp-btn-primary" %>
  </div>
<% else %>
  <div style="display:grid;gap:12px;">
    <% @decks.each do |deck| %>
      <div id="fc-deck-<%= deck.id %>" style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:14px;transition:box-shadow .15s;"
           onmouseover="this.style.boxShadow='0 4px 16px rgba(0,0,0,.08)'" onmouseout="this.style.boxShadow='none'">
        <%= link_to learner_my_flashcard_path(deck.id), style: "display:flex;align-items:center;gap:14px;flex:1;min-width:0;text-decoration:none;" do %>
          <div style="width:44px;height:44px;background:linear-gradient(135deg,#d1fae5,#a7f3d0);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="22" height="22" fill="none" stroke="#065f46" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <div style="flex:1;min-width:0;">
            <p style="font-size:14px;font-weight:700;color:#0f172a;margin:0 0 3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= deck.title %></p>
            <p style="font-size:12px;color:#64748b;margin:0;"><%= deck.card_count %> <%= t('learner_fc.cards_unit') %> · <%= deck.created_at.strftime("%d/%m/%Y") %></p>
          </div>
          <svg width="16" height="16" fill="none" stroke="#94a3b8" viewBox="0 0 24 24" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        <% end %>
        <button onclick="fcDeleteDeck(<%= deck.id %>, '<%= j deck.title %>')"
                style="flex-shrink:0;width:32px;height:32px;border:none;background:transparent;cursor:pointer;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#cbd5e1;transition:color .15s,background .15s;"
                onmouseover="this.style.color='#ef4444';this.style.background='#fef2f2'" onmouseout="this.style.color='#cbd5e1';this.style.background='transparent'" title="Xoá">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      </div>
    <% end %>
  </div>
  <script>
  function fcDeleteDeck(id, name) {
    lpDeleteConfirm(
      '/learner/my_flashcards/' + id,
      'Xoá bộ flashcard?',
      'Bộ "' + name + '" và tất cả thẻ sẽ bị xoá vĩnh viễn. Hành động này không thể hoàn tác.',
      function() { document.getElementById('fc-deck-' + id).remove(); }
    );
  }
  </script>
<% end %>
