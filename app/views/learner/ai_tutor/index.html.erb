  <div id="lp-vc-bars" style="display:flex;align-items:center;gap:3px;height:40px;margin-bottom:24px;color:#6366f1;">
    <% [['a',1.1],['b',1.28],['c',1.46],['b',1.64],['a',1.82],['c',1.1],['b',1.28],['a',1.46],['c',1.64],['b',1.82],['a',1.1],['b',1.28],['c',1.46],['b',1.64],['a',1.82],['c',1.1],['b',1.28],['a',1.46],['c',1.64],['b',1.82]].each_with_index do |(w,spd),i| %>
