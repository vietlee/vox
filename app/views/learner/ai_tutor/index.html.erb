    <div style="position:absolute;width:165px;height:165px;border-radius:50%;border:1px solid rgba(99,102,241,0.12);animation:lp-vc-ring-pulse2 2.2s ease-in-out infinite .4s;pointer-events:none;"></div>
    <div id="lp-vc-orb" style="width:100px;height:100px;border-radius:50%;overflow:hidden;position:relative;cursor:pointer;animation:lp-vc-blob 7s ease-in-out infinite,lp-vc-glow-listening 2.5s ease-in-out infinite;">
      <div style="position:absolute;inset:0;background:radial-gradient(circle at 35% 30%,#1e3a5f 0%,#0d1b2e 50%,#050810 100%);"></div>
      <div style="position:absolute;inset:-6px;background:conic-gradient(from 0deg,transparent 0%,rgba(99,102,241,.85) 10%,transparent 22%,rgba(59,130,246,.70) 38%,transparent 52%,rgba(16,185,129,.55) 68%,transparent 80%,rgba(99,102,241,.45) 94%,transparent 100%);animation:lp-vc-spin 5s linear infinite;mix-blend-mode:screen;border-radius:50%;"></div>
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 30% 22%,rgba(255,255,255,.45) 0%,rgba(255,255,255,.05) 50%,transparent 72%);"></div>
    </div>
  </div>

  <div id="lp-vc-status" style="font-size:18px;font-weight:700;color:#f1f5f9;margin-bottom:4px;">Đang lắng nghe...</div>
