async function lpSpeakText(text, btn) {
  if (!HAS_TTS) return;
  lpPrimeAudio();
  lpStopShared();
  const plain = text.replace(/\*\*(.+?)\*\*/g,'$1').replace(/`(.+?)`/g,'$1').replace(/#+\s/g,'').trim().slice(0,1000);
  if (btn) { btn.innerHTML = '⏳ Đang tải...'; btn.disabled = true; }
  try {
    const fd = new FormData(); fd.append('text',plain); fd.append('model','eleven_turbo_v2_5'); fd.append('authenticity_token',CSRF());
    const res = await fetch(TTS_URL, {method:'POST',body:fd});
    const d = await res.json().catch(function(){return {};});
    if (!res.ok || !d.audio_base64) throw new Error(d.error||'');
    if (d.credits_remaining !== undefined && window.updateLpCredits) updateLpCredits(d.credits_remaining);
    const bin = atob(d.audio_base64), arr = new Uint8Array(bin.length);
    for (let i=0;i<bin.length;i++) arr[i]=bin.charCodeAt(i);
    const url = URL.createObjectURL(new Blob([arr],{type:'audio/mpeg'}));
    lpPlayShared(url, function(){ URL.revokeObjectURL(url); if (btn) { btn.innerHTML = '🔊 Nghe lại'; btn.disabled = false; } });
    if (btn) btn.innerHTML = '⏸ Đang phát';
  } catch(e) { if (btn) { btn.innerHTML = '⚠ Lỗi'; btn.disabled = false; } }
}

