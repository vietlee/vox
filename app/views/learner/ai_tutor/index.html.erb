let _autoSpeak = false, _currentAudio = null;

// Shared audio element — iOS Safari only allows playback on an element that was
// "unlocked" during a real user gesture. We prime one element on first tap and
// reuse it for every TTS clip so autoplay-after-fetch works on mobile.
var _lpAudioEl = new Audio();
_lpAudioEl.setAttribute('playsinline', '');
var _lpAudioPrimed = false;
function lpPrimeAudio() {
  if (_lpAudioPrimed) return;
  _lpAudioPrimed = true;
  try { var p = _lpAudioEl.play(); if (p && p.then) p.then(function(){ _lpAudioEl.pause(); _lpAudioEl.currentTime = 0; }).catch(function(){}); } catch(e){}
}
document.addEventListener('touchend', lpPrimeAudio, { passive: true });
document.addEventListener('click', lpPrimeAudio, true);
function lpPlayShared(url, onended) {
  try { _lpAudioEl.pause(); } catch(e){}
  _lpAudioEl.onended = _lpAudioEl.onerror = function(){ if (onended) onended(); };
  _lpAudioEl.src = url;
  var p = _lpAudioEl.play();
  if (p && p.catch) p.catch(function(){ if (onended) onended(); });
  return _lpAudioEl;
}
function lpStopShared(){ try { _lpAudioEl.pause(); } catch(e){} }
function lpToggleAutoSpeak() {
