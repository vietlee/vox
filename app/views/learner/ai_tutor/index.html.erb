let _recorder = null, _audioChunks = [], _cancelled = false;
function lpToggleRecording() { _recorder ? lpStopRecording(false) : lpStartRecording(); }
window.lpToggleRecording = lpToggleRecording;
async function lpStartRecording() {
  if (!HAS_STT || _recorder) return;
  _cancelled = false; _audioChunks = [];
  try {
    const stream = await navigator.mediaDevices.getUserMedia({audio:true});
    _recorder = new MediaRecorder(stream, {mimeType:'audio/webm'});
    _recorder.ondataavailable = e => { if (e.data.size>0) _audioChunks.push(e.data); };
    _recorder.onstop = async () => {
      stream.getTracks().forEach(t=>t.stop());
      document.getElementById('lp-voice-indicator').style.display = 'none';
      const btn = document.getElementById('lp-mic-btn');
      if (btn) btn.classList.remove('active');
      if (_cancelled || !_audioChunks.length) { _recorder=null; return; }
      await lpTranscribe(new Blob(_audioChunks,{type:'audio/webm'}));
      _recorder = null;
    };
    _recorder.start(250);
    document.getElementById('lp-voice-indicator').style.display = 'flex';
    const btn = document.getElementById('lp-mic-btn');
    if (btn) btn.classList.add('active');
  } catch(e) { alert('Không thể truy cập microphone.'); _recorder=null; }
}
function lpStopRecording(cancel) { if (!_recorder) return; _cancelled=cancel; _recorder.stop(); }
window.lpStopRecording = lpStopRecording;
async function lpTranscribe(blob) {
  const input = document.getElementById('lp-input');
  input.placeholder = '⏳ Đang nhận dạng...'; input.disabled = true;
  try {
    const fd = new FormData(); fd.append('chunk',blob,'voice.webm'); fd.append('authenticity_token',CSRF());
    const res  = await fetch(STT_URL,{method:'POST',body:fd});
    const data = await res.json();
    if (data.text?.trim()) { input.value=data.text.trim(); lpToggleSend(input.value); setTimeout(()=>{ if(input.value.trim()) lpSendMsg(); },400); }
    else input.placeholder = 'Không nhận được. Thử lại...';
  } catch(e) { input.placeholder = 'Lỗi. Thử lại...'; }
  finally { input.disabled=false; setTimeout(()=>{input.placeholder='Hỏi bất cứ điều gì...';},2000); }
}

