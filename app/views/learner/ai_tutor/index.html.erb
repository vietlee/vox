}

async function lpVcInitStream() {
  if (_vcStream) return;
  _vcStream=await navigator.mediaDevices.getUserMedia({audio:true});
  _vcAudioCtx=new (window.AudioContext||window.webkitAudioContext)();
  const src=_vcAudioCtx.createMediaStreamSource(_vcStream);
  _vcAnalyser=_vcAudioCtx.createAnalyser(); _vcAnalyser.fftSize=256;
  src.connect(_vcAnalyser);
}
async function lpVcStartListening() {
  if (!_vcActive) return; lpVcSetStatus('listening'); _vcListening=true; _vcChunks=[];
  try { await lpVcInitStream(); lpVcAnimateBars(); }
  catch(e) { lpVcSetStatus('idle'); const s=document.getElementById('lp-vc-sub'); if(s) s.textContent='Không thể truy cập mic'; return; }
  if (_hasSpeechRec) {
    _vcSpeechRec=new SpeechRecCtor();
    _vcSpeechRec.lang=SPEECH_LANG; _vcSpeechRec.continuous=false; _vcSpeechRec.interimResults=true; _vcSpeechRec.maxAlternatives=1;
    let finalTxt=''; const txEl=document.getElementById('lp-vc-transcript');
    _vcSpeechRec.onresult=function(ev){
      let finals='',interim='';
      for(let i=ev.resultIndex;i<ev.results.length;i++){const t=ev.results[i][0].transcript;if(ev.results[i].isFinal)finals+=t;else interim+=t;}
      if(finals)finalTxt+=finals;
      if(txEl)txEl.textContent='🗣 '+(finalTxt||interim);
    };
    _vcSpeechRec.onend=function(){
      _vcListening=false; if(!_vcActive)return;
      if(finalTxt.trim())lpVcProcessWithText(finalTxt.trim());
      else setTimeout(()=>{if(_vcActive)lpVcStartListening();},300);
    };
    _vcSpeechRec.onerror=function(e){
      _vcListening=false; if(!_vcActive)return;
      setTimeout(()=>{if(_vcActive)lpVcStartListening();},300);
    };
    try{_vcSpeechRec.start();}catch(e){}
  } else {
    _vcRecorder=new MediaRecorder(_vcStream,{mimeType:'audio/webm'});
    _vcRecorder.ondataavailable=e=>{ if(e.data.size>0) _vcChunks.push(e.data); };
    _vcRecorder.onstop=async()=>{ if(!_vcActive||!_vcChunks.length) return; lpVcSetStatus('processing'); await lpVcProcessAndReply(); };
    _vcRecorder.start(200); lpVcDetectSilence();
  }
}
function lpVcDetectSilence() {
  const data=new Uint8Array(_vcAnalyser.frequencyBinCount);
  let silMs=0,spk=false;
  const start=Date.now();
  function check() {
    if (!_vcListening||!_vcActive) return;
    _vcAnalyser.getByteFrequencyData(data);
    const avg=data.reduce((a,b)=>a+b,0)/data.length;
    if (avg>=20) { spk=true; silMs=0; }
    else if (spk&&avg<14) { silMs+=100; if(silMs>=1500) { lpVcStopListening(); return; } }
    if (Date.now()-start>30000) { lpVcStopListening(); return; }
    _vcSilTimer=setTimeout(check,100);
  }
  _vcSilTimer=setTimeout(check,300);
}
function lpVcAnimateBars() {
  if (!_vcAnalyser) return;
  _vcAnalyser.fftSize=512; _vcAnalyser.smoothingTimeConstant=0.80;
  const data=new Uint8Array(_vcAnalyser.frequencyBinCount);
  const bars=document.querySelectorAll('.lp-vc-bar');
  const smoothed=new Array(bars.length).fill(0.10);
  const voiceBins=Math.floor(_vcAnalyser.frequencyBinCount*0.35);
  function frame() {
    if (!_vcActive) return;
    _vcAnalyser.getByteFrequencyData(data);
    const slice=Math.max(1,Math.floor(voiceBins/bars.length));
    bars.forEach((b,i)=>{ let sum=0; for(let j=0;j<Math.min(slice,4);j++) sum+=(data[i*slice+j]||0); const boosted=Math.pow(sum/Math.min(slice,4)/255,0.45); const target=Math.max(0.08,Math.min(1.0,boosted*1.4)); smoothed[i]=smoothed[i]*0.4+target*0.6; b.style.transform='scaleY('+smoothed[i].toFixed(3)+')'; b.style.animation='none'; });
    _vcAnimFrame=requestAnimationFrame(frame);
  }
  _vcAnimFrame=requestAnimationFrame(frame);
}
function lpVcStopListening() {
  _vcListening=false; clearTimeout(_vcSilTimer);
  if(_vcSpeechRec){try{_vcSpeechRec.abort();}catch(e){} _vcSpeechRec=null;}
  if(_vcRecorder?.state==='recording') _vcRecorder.stop();
}
function lpVcStopStream() { _vcStream?.getTracks().forEach(t=>t.stop()); _vcStream=null; _vcAudioCtx?.close().catch(()=>{}); _vcAudioCtx=null; if(_vcAnimFrame){cancelAnimationFrame(_vcAnimFrame);_vcAnimFrame=null;} }
function lpVcStopAll() { _vcListening=false; clearTimeout(_vcSilTimer); if(_vcRecorder?.state!=='inactive'){try{_vcRecorder.stop();}catch(e){}} lpVcStopStream(); }
function lpVcTapMic() { if(!_vcActive) return; if(_vcListening){lpVcStopListening();}else if(_vcAudioCtx){lpStopShared();setTimeout(()=>{if(_vcActive)lpVcStartListening();},200);}else{lpVcStartListening();} }
window.lpVcTapMic = lpVcTapMic;

async function lpVcProcessAndReply() {
  if (!_vcChunks.length) { if(_vcActive) lpVcStartListening(); return; }
  const blob=new Blob(_vcChunks,{type:'audio/webm'}); _vcChunks=[];
  const txEl=document.getElementById('lp-vc-transcript'); if(txEl){txEl.textContent='⏳ Đang nhận dạng...';txEl.style.opacity='1';}
  const fd=new FormData(); fd.append('chunk',blob,'voice.webm'); fd.append('authenticity_token',CSRF());
  let userText='';
  try { const r=await fetch(STT_URL,{method:'POST',body:fd}); const d=await r.json(); userText=(d.text||'').trim(); } catch(e) {}
  if (!userText) { if(_vcActive) lpVcStartListening(); return; }
  await lpVcProcessWithText(userText);
}
async function lpVcProcessWithText(userText) {
  const txEl=document.getElementById('lp-vc-transcript');
  if(txEl){txEl.textContent='🗣 '+userText;txEl.style.opacity='1';}
  lpAppendMsg('user',userText); chatHistory.push({role:'user',content:userText}); lpSaveHistory();
  lpVcSetStatus('processing');
  const thinkEl=lpAppendMsg('assistant',null,true);
  let reply='', data={};
  try {
    const res=await fetch(VOICE_URL,{method:'POST',headers:{'Content-Type':'application/json','X-CSRF-Token':CSRF()},body:JSON.stringify({message:userText,history:chatHistory.slice(0,-1)})});
    data=await res.json().catch(function(){return {};});
    if (!res.ok || data.error) throw new Error(data.error || ('HTTP '+res.status));
    reply=(data.reply||data.response||'').trim();
    thinkEl.innerHTML=reply?lpMd(reply):'<span style="color:#94a3b8;">(không có phản hồi)</span>';
  } catch(e) {
    thinkEl.innerHTML='<span style="color:#ef4444;">⚠️ '+(e.message||'Lỗi kết nối')+'</span>';
    if(txEl){txEl.textContent='';txEl.style.opacity='0';}
    lpVcSetStatus('idle');
    if(_vcActive) setTimeout(function(){if(_vcActive)lpVcStartListening();},1500);
    return;
  }
  if (reply) {
    chatHistory.push({role:'assistant',content:reply}); lpSaveHistory();
    if (window.updateLpCredits && data.credits_remaining !== undefined) updateLpCredits(data.credits_remaining);
    if(txEl) txEl.textContent='🤖 '+reply.slice(0,80)+(reply.length>80?'...':'');
    if (HAS_TTS) {
      lpVcSetStatus('speaking');
      const fd2=new FormData(); fd2.append('text',reply.replace(/\*\*(.+?)\*\*/g,'$1').replace(/`(.+?)`/g,'$1').slice(0,1000)); fd2.append('model','eleven_flash_v2_5'); fd2.append('speed',String(_vcSpeed)); if(_vcVoiceId) fd2.append('voice_id',_vcVoiceId); fd2.append('authenticity_token',CSRF());
      try {
        const ar=await fetch(TTS_URL,{method:'POST',body:fd2});
        const ad=await ar.json().catch(function(){return {};});
        if(ar.ok && ad.audio_base64){
          const bin=atob(ad.audio_base64); const arr=new Uint8Array(bin.length); for(let i=0;i<bin.length;i++)arr[i]=bin.charCodeAt(i);
          const url=URL.createObjectURL(new Blob([arr],{type:'audio/mpeg'}));
          if(ad.credits_remaining!==undefined && window.updateLpCredits) updateLpCredits(ad.credits_remaining);
          lpPlayShared(url, function(){ URL.revokeObjectURL(url); if(_vcActive) lpVcStartListening(); });
          return;
        }
      } catch(e) {}
    }
  }
  if (_vcActive) lpVcStartListening();
}

window.lpVcSpeedDec=function(){const i=VC_SPEEDS.indexOf(_vcSpeed);if(i>0){_vcSpeed=VC_SPEEDS[i-1];localStorage.setItem('lp_vc_speed',_vcSpeed);const l=document.getElementById('lp-vc-speed-label');if(l)l.textContent=_vcSpeed+'×';}};
window.lpVcSpeedInc=function(){const i=VC_SPEEDS.indexOf(_vcSpeed);if(i<VC_SPEEDS.length-1){_vcSpeed=VC_SPEEDS[i+1];localStorage.setItem('lp_vc_speed',_vcSpeed);const l=document.getElementById('lp-vc-speed-label');if(l)l.textContent=_vcSpeed+'×';}};
document.addEventListener('DOMContentLoaded',()=>{const l=document.getElementById('lp-vc-speed-label');if(l)l.textContent=_vcSpeed+'×';});

document.getElementById('lp-input').focus();
})();
</script>

</div><!-- end chat card -->

