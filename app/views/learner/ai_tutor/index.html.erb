<% content_for :title, "AI Tutor" %>
<% content_for :lp_style, "padding:12px;background:#f0f4f8;height:calc(100dvh - var(--topbar-h) - var(--bottomnav-h));display:flex;flex-direction:column;overflow:hidden;" %>

<style>
/* ── Animations ── */
@keyframes dot-bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-4px)} }
@keyframes lp-fade-in { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }
@keyframes lp-vc-spin  { to{transform:rotate(360deg)} }
@keyframes lp-vc-blob  { 0%,100%{border-radius:62% 38% 54% 46%/48% 62% 38% 52%} 33%{border-radius:44% 56% 38% 62%/62% 38% 57% 43%} 66%{border-radius:57% 43% 62% 38%/38% 57% 43% 62%} }
@keyframes lp-vc-glow-listening { 0%,100%{box-shadow:0 0 40px 10px rgba(99,102,241,.5),0 0 80px 24px rgba(79,70,229,.2)} 50%{box-shadow:0 0 60px 18px rgba(139,92,246,.7),0 0 110px 36px rgba(99,102,241,.15)} }
@keyframes lp-vc-glow-speaking  { 0%,100%{box-shadow:0 0 40px 10px rgba(16,185,129,.55),0 0 80px 24px rgba(5,150,105,.2)} 50%{box-shadow:0 0 60px 18px rgba(52,211,153,.75),0 0 110px 36px rgba(16,185,129,.15)} }
@keyframes lp-vc-glow-processing{ 0%,100%{box-shadow:0 0 40px 10px rgba(245,158,11,.5)} 50%{box-shadow:0 0 60px 18px rgba(252,211,77,.7)} }
@keyframes lp-vc-ring-pulse  { 0%,100%{transform:scale(1);opacity:.5} 50%{transform:scale(1.1);opacity:.15} }
@keyframes lp-vc-ring-pulse2 { 0%,100%{transform:scale(1);opacity:.25} 50%{transform:scale(1.2);opacity:.05} }
@keyframes lp-vc-float  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }
@keyframes lp-vc-wave-a { 0%,100%{transform:scaleY(.10)} 50%{transform:scaleY(1.00)} }
@keyframes lp-vc-wave-b { 0%,100%{transform:scaleY(.18)} 50%{transform:scaleY(.80)} }
@keyframes lp-vc-wave-c { 0%,100%{transform:scaleY(.25)} 50%{transform:scaleY(.60)} }

.lp-msg-row { animation: lp-fade-in .22s ease both; }
.lp-bubble-ai  { background:#fff; border:1px solid #e8ecf0; border-radius:4px 18px 18px 18px; box-shadow:0 1px 4px rgba(0,0,0,.05); }
.lp-bubble-user{ background:linear-gradient(135deg,#1e3a5f,#2d5282); color:#fff; border-radius:18px 4px 18px 18px; }
.lp-input-wrap  { border:1.5px solid #e2e8f0; border-radius:16px; background:#fff; transition:border-color .2s,box-shadow .2s; }
.lp-input-wrap:focus-within { border-color:#1e3a5f; box-shadow:0 0 0 3px rgba(30,58,95,.08); }
.lp-toolbar-btn { display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:10px;border:none;background:transparent;color:#94a3b8;cursor:pointer;transition:all .15s; }
.lp-toolbar-btn:hover { background:#f1f5f9; color:#1e3a5f; }
.lp-toolbar-btn.active { background:#fee2e2; color:#ef4444; }
.lp-send-btn { width:38px;height:38px;border-radius:12px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .18s; }
.lp-send-btn:disabled { background:#8a9cb5; color:#eef2f7; cursor:not-allowed; }
.lp-send-btn:not(:disabled) { background:#1e3a5f; color:#fff; box-shadow:0 2px 8px rgba(30,58,95,.3); }
.lp-send-btn:not(:disabled):hover { background:#16304f; transform:translateY(-1px); box-shadow:0 4px 12px rgba(30,58,95,.35); }
.lp-vc-bar { width:3px; border-radius:99px; background:currentColor; transform-origin:center; transform:scaleY(.10); height:32px; }
.lp-vc-voice-card { transition:border-color .15s,background .15s; cursor:pointer; }
.lp-vc-voice-card:hover { transform:translateY(-1px); }
pre  { background:#f8fafc; border:1px solid #e2e8f0; border-radius:8px; padding:10px 12px; overflow-x:auto; font-size:12.5px; margin:6px 0; }
code { background:#f1f5f9; padding:1px 5px; border-radius:4px; font-size:12.5px; font-family:monospace; }
</style>

<div style="flex:1;display:flex;flex-direction:column;overflow:hidden;background:#fff;border-radius:16px;border:1px solid #e2e8f0;box-shadow:0 2px 16px rgba(0,0,0,.07);">

<!-- ── Top bar ── -->
<div style="flex-shrink:0;display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-bottom:1px solid #f0f4f8;background:#fff;">
  <div style="display:flex;align-items:center;gap:10px;">
    <div style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,#1e3a5f,#2d5282);display:flex;align-items:center;justify-content:center;">
      <svg width="16" height="16" fill="none" stroke="white" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
    </div>
    <div>
      <p style="font-size:13px;font-weight:700;color:#0f172a;margin:0;line-height:1.2;">AI Tutor</p>
      <p style="font-size:11px;color:#64748b;margin:0;">
        <span style="display:inline-flex;align-items:center;gap:3px;">
          <span style="width:6px;height:6px;border-radius:50%;background:#22c55e;display:inline-block;"></span> <%= t('learner_ai_tutor.ready') %>
        </span>
      </p>
    </div>
  </div>
  <div style="display:flex;align-items:center;gap:6px;">
    <div style="display:flex;align-items:center;gap:5px;background:#f8fafc;border:1px solid #e2e8f0;border-radius:20px;padding:5px 10px;">
      <svg width="12" height="12" fill="none" stroke="#f59e0b" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <span style="font-size:12px;font-weight:700;color:#0f172a;"><span id="lp-credits-count"><%= current_learner.credits %></span></span>
      <span style="font-size:11px;color:#94a3b8;">credits</span>
    </div>
    <% if @has_tts %>
    <button id="lp-auto-speak-btn" onclick="lpToggleAutoSpeak()" title="<%= t('learner_ai_tutor.auto_speak') %>"
            style="height:34px;padding:0 10px;border-radius:20px;border:1px solid #e2e8f0;background:#f8fafc;color:#94a3b8;cursor:pointer;font-size:11px;display:flex;align-items:center;gap:4px;transition:all .15s;">
      <svg id="lp-speak-icon" width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15zM17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/></svg>
      <span id="lp-speak-label"><%= t('learner_ai_tutor.auto_speak') %></span>
    </button>
    <% end %>
    <button onclick="lpClearHistory()" title="Xoá lịch sử"
            style="width:34px;height:34px;border-radius:10px;border:1px solid #e2e8f0;background:#f8fafc;color:#94a3b8;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;"
            onmouseover="this.style.background='#fee2e2';this.style.color='#ef4444'" onmouseout="this.style.background='#f8fafc';this.style.color='#94a3b8'">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
    </button>
  </div>
</div>

<!-- ── Messages ── -->
<div id="lp-chat-msgs" style="flex:1;overflow-y:auto;padding:20px 16px;display:flex;flex-direction:column;gap:16px;">
  <!-- Welcome bubble -->
  <div class="lp-msg-row" style="display:flex;gap:10px;max-width:100%;">
    <div style="width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,#1e3a5f,#2d5282);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;">
      <svg width="15" height="15" fill="none" stroke="white" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>
    </div>
    <div class="lp-bubble-ai" style="padding:12px 15px;max-width:80%;font-size:14px;color:#1e293b;line-height:1.65;">
      <%= t('learner_ai_tutor.welcome_before_name') %><strong><%= current_learner.name %></strong><%= t('learner_ai_tutor.welcome_after_name') %><%= raw(params[:context].present? ? t('learner_ai_tutor.welcome_context', topic: "<strong>#{ERB::Util.html_escape(params[:context])}</strong>") : "") %><%= t('learner_ai_tutor.welcome_hint') %>
    </div>
  </div>
</div>

<!-- ── Voice recording bar ── -->
<div id="lp-voice-indicator" style="display:none;flex-shrink:0;align-items:center;justify-content:center;gap:10px;padding:8px 16px;background:#fff5f5;border-top:1px solid #fecaca;">
  <div style="display:flex;gap:2px;align-items:flex-end;">
    <% [7,11,9,14,9,11,7].each_with_index do |h,i| %>
      <div style="width:3px;background:#f87171;border-radius:99px;height:<%= h %>px;animation:dot-bounce 1.1s ease-in-out infinite <%= (i*0.09).round(2) %>s;"></div>
    <% end %>
  </div>
  <span style="font-size:12px;font-weight:600;color:#ef4444;">Đang ghi âm...</span>
  <button onclick="lpStopRecording(false)" style="padding:4px 12px;border-radius:20px;background:#ef4444;border:none;color:white;cursor:pointer;font-size:11px;font-weight:600;">Gửi</button>
  <button onclick="lpStopRecording(true)"  style="padding:4px 12px;border-radius:20px;background:#fee2e2;border:none;color:#ef4444;cursor:pointer;font-size:11px;font-weight:600;">Huỷ</button>
</div>

<!-- ── Input area ── -->
<div style="flex-shrink:0;padding:10px 14px 12px;background:#f8fafc;border-top:1px solid #e8edf2;border-radius:0 0 16px 16px;">
  <!-- Attach preview -->
  <div id="lp-attach-preview" style="display:none;flex-wrap:wrap;gap:6px;margin-bottom:8px;"></div>

  <div style="display:flex;gap:8px;align-items:flex-end;">
    <div class="lp-input-wrap" style="flex:1;padding:8px 8px 8px 14px;">
      <textarea id="lp-input" rows="1" placeholder="<%= t('learner_ai_tutor.placeholder') %>"
                style="width:100%;border:none;outline:none;font-size:14px;resize:none;max-height:120px;background:transparent;font-family:inherit;color:#1e293b;line-height:1.6;box-sizing:border-box;"
                oninput="lpAutoResize(this);lpToggleSend(this.value)"
                onkeydown="if(event.key==='Enter'&&!event.shiftKey&&!event.isComposing){event.preventDefault();lpSendMsg();}"></textarea>

      <input id="lp-attach-input" type="file" style="display:none;" multiple
             accept=".txt,.md,.csv,.json,.html,.xml,.pdf,.png,.jpg,.jpeg,.gif,.webp"
             onchange="lpHandleAttach(this)">

      <div style="display:flex;align-items:center;justify-content:space-between;margin-top:4px;">
        <div style="display:flex;align-items:center;gap:2px;">
          <label for="lp-attach-input" class="lp-toolbar-btn" title="Đính kèm file" style="cursor:pointer;">
            <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
          </label>
          <% if @has_stt %>
          <button id="lp-mic-btn" class="lp-toolbar-btn" onclick="lpToggleRecording()" title="Ghi âm giọng nói">
            <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/></svg>
          </button>
          <% end %>
        </div>
        <span style="font-size:11px;color:#cbd5e1;"><%= t('learner_ai_tutor.hint') %></span>
      </div>
    </div>

    <!-- Right column: voice call orb + send (giống admin) -->
    <div style="display:flex;flex-direction:column;gap:6px;flex-shrink:0;">
      <% if @has_stt && @has_tts %>
      <button onclick="lpEnterVoiceCall()" title="Trò chuyện cùng AI"
              style="width:38px;height:38px;border-radius:12px;border:0;padding:0;cursor:pointer;position:relative;overflow:hidden;box-shadow:0 2px 12px rgba(99,102,241,.40);transition:transform .15s,box-shadow .15s;"
              onmouseenter="this.style.transform='scale(1.07)';this.style.boxShadow='0 4px 18px rgba(99,102,241,.60)'"
              onmouseleave="this.style.transform='scale(1)';this.style.boxShadow='0 2px 12px rgba(99,102,241,.40)'">
        <div style="position:absolute;inset:0;background:radial-gradient(circle at 35% 30%,#4f46e5 0%,#1e1b4b 55%,#07060f 100%);"></div>
        <div style="position:absolute;inset:-3px;background:conic-gradient(from 0deg,transparent 0%,rgba(167,139,250,.85) 10%,transparent 22%,rgba(96,165,250,.70) 38%,transparent 52%,rgba(236,72,153,.60) 68%,transparent 80%,rgba(34,211,238,.50) 94%,transparent 100%);animation:lp-vc-spin 5s linear infinite;mix-blend-mode:screen;border-radius:14px;"></div>
        <div style="position:absolute;inset:0;background:radial-gradient(ellipse 60% 50% at 30% 22%,rgba(255,255,255,.45) 0%,rgba(255,255,255,.05) 50%,transparent 72%);border-radius:14px;"></div>
      </button>
      <% end %>
      <button id="lp-send-btn" class="lp-send-btn" onclick="lpSendMsg()" disabled>
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
(function() {
const CSRF      = () => document.querySelector('meta[name="csrf-token"]').content;
const CHAT_URL  = '<%= learner_ai_tutor_chat_path %>';
const VOICE_URL = '<%= learner_ai_tutor_voice_path %>';
const TTS_URL   = '<%= learner_ai_tutor_tts_path %>';
const TTS_V_URL = '<%= learner_ai_tutor_tts_voices_path %>';
const STT_URL   = '<%= learner_ai_tutor_stt_path %>';
const HAS_TTS   = <%= @has_tts ? 'true' : 'false' %>;
const HAS_STT   = <%= @has_stt ? 'true' : 'false' %>;
const STORAGE_KEY = 'vox_lp_tutor_<%= current_learner.id %>';

// ── History ──────────────────────────────────────────────────────
let chatHistory = [];
try { const s = localStorage.getItem(STORAGE_KEY); if (s) chatHistory = JSON.parse(s); } catch(e) {}
(function restoreHistory() {
  chatHistory.forEach(m => lpAppendMsg(m.role, m.content));
  const c = document.getElementById('lp-chat-msgs');
  if (c) c.scrollTop = c.scrollHeight;
})();
function lpSaveHistory() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(chatHistory.slice(-40))); } catch(e) {}
}
function lpClearHistory() {
  chatHistory = []; localStorage.removeItem(STORAGE_KEY);
  const c = document.getElementById('lp-chat-msgs');
  // keep only first welcome bubble
  while (c.children.length > 1) c.removeChild(c.lastChild);
}
window.lpClearHistory = lpClearHistory;

// ── Attachments ─────────────────────────────────────────────────
let _attached = [];
function lpHandleAttach(input) {
  const files = Array.from(input.files); if (!files.length) return; input.value = '';
  let pending = files.length;
  files.forEach(f => {
    const isImg = f.type.startsWith('image/');
    const r = new FileReader();
    r.onload = e => {
      _attached.push({ name: f.name, content: e.target.result, type: isImg ? 'image' : 'text' });
      if (--pending === 0) { lpRenderAttachPreview(); lpToggleSend(document.getElementById('lp-input').value); }
    };
    isImg ? r.readAsDataURL(f) : r.readAsText(f);
  });
}
window.lpHandleAttach = lpHandleAttach;
function lpRenderAttachPreview() {
  const w = document.getElementById('lp-attach-preview');
  if (!_attached.length) { w.style.display = 'none'; w.innerHTML = ''; return; }
  w.style.display = 'flex';
  w.innerHTML = _attached.map((f,i) => f.type === 'image'
    ? `<div style="position:relative"><img src="${f.content}" style="width:40px;height:40px;border-radius:8px;object-fit:cover;border:1px solid #e2e8f0"><button onclick="lpRemoveAttach(${i})" style="position:absolute;top:-6px;right:-6px;width:16px;height:16px;border-radius:50%;background:#64748b;border:none;color:white;cursor:pointer;font-size:9px;display:flex;align-items:center;justify-content:center;">×</button></div>`
    : `<div style="display:flex;align-items:center;gap:5px;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:8px;padding:4px 9px;font-size:11px;color:#475569;max-width:130px;overflow:hidden;white-space:nowrap;text-overflow:ellipsis;"><svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" style="flex-shrink:0"><path stroke-linecap="round" stroke-linejoin="round" d="M14 3v4a1 1 0 001 1h4M7 3h7l5 5v11a2 2 0 01-2 2H7a2 2 0 01-2-2V5a2 2 0 012-2z"/></svg> ${f.name}<button onclick="lpRemoveAttach(${i})" style="border:none;background:none;color:#94a3b8;cursor:pointer;padding:0 0 0 4px;font-size:12px;">×</button></div>`
  ).join('');
}
function lpRemoveAttach(i) { _attached.splice(i,1); lpRenderAttachPreview(); lpToggleSend(document.getElementById('lp-input').value); }
window.lpRemoveAttach = lpRemoveAttach;

// ── Input helpers ────────────────────────────────────────────────
function lpAutoResize(ta) { ta.style.height='auto'; ta.style.height=Math.min(ta.scrollHeight,120)+'px'; }
window.lpAutoResize = lpAutoResize;
function lpToggleSend(v) {
  const btn = document.getElementById('lp-send-btn');
  btn.disabled = !(v.trim() || _attached.length);
}
window.lpToggleSend = lpToggleSend;

// ── Send message ─────────────────────────────────────────────────
async function lpSendMsg() {
  const input = document.getElementById('lp-input');
  let msg = input.value.trim();
  if (!msg && !_attached.length) return;
  let payloadMsg = msg;
  if (_attached.length) {
    const parts = _attached.map(f => f.type==='image' ? `[Hình ảnh: ${f.name}]` : `File (${f.name}):\n\`\`\`\n${f.content.slice(0,8000)}\n\`\`\``);
    payloadMsg = [msg,...parts].filter(Boolean).join('\n\n');
    _attached = []; lpRenderAttachPreview();
  }
  input.value = ''; lpToggleSend(''); input.style.height = '';
  chatHistory.push({ role:'user', content:payloadMsg }); lpSaveHistory();
  lpAppendMsg('user', msg || '📎 File đính kèm');
  const thinkEl = lpAppendMsg('assistant', null, true);
  try {
    const res  = await fetch(CHAT_URL, { method:'POST', headers:{'Content-Type':'application/json','X-CSRF-Token':CSRF()}, body:JSON.stringify({message:payloadMsg, history:chatHistory.slice(0,-1)}) });
    const data = await res.json();
    const reply = data.response || data.error || 'Lỗi không xác định';
    thinkEl.innerHTML = lpMd(reply);
    if (data.response) {
      chatHistory.push({ role:'assistant', content:data.response }); lpSaveHistory();
      const el = document.getElementById('lp-credits-count'); if (el) el.textContent = data.credits_remaining;
      if (window.updateLpCredits) updateLpCredits(data.credits_remaining);
      if (_autoSpeak) lpSpeakText(data.response);
      if (HAS_TTS) lpAddSpeakBtn(thinkEl, data.response);
    }
  } catch(e) { thinkEl.innerHTML = '<span style="color:#ef4444;font-size:13px;">Lỗi kết nối. Thử lại.</span>'; }
}
window.lpSendMsg = lpSendMsg;

function lpAppendMsg(role, html, thinking = false) {
  const c = document.getElementById('lp-chat-msgs');
  const isUser = role === 'user';
  const row = document.createElement('div');
  row.className = 'lp-msg-row';
  row.style.cssText = 'display:flex;gap:10px;max-width:100%;' + (isUser ? 'justify-content:flex-end;' : '');

  if (!isUser) {
    const av = document.createElement('div');
    av.style.cssText = 'width:32px;height:32px;border-radius:10px;background:linear-gradient(135deg,#1e3a5f,#2d5282);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;';
    av.innerHTML = '<svg width="15" height="15" fill="none" stroke="white" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/></svg>';
    row.appendChild(av);
  }

  const b = document.createElement('div');
  if (isUser) {
    b.className = 'lp-bubble-user';
    b.style.cssText = 'padding:10px 14px;max-width:78%;font-size:14px;line-height:1.6;word-break:break-word;';
    b.innerHTML = lpEsc(html||'');
  } else {
    b.className = 'lp-bubble-ai';
    b.style.cssText = 'padding:12px 15px;max-width:85%;font-size:14px;color:#1e293b;line-height:1.65;word-break:break-word;';
    b.innerHTML = thinking
      ? '<span style="display:inline-flex;gap:4px;align-items:center;"><span style="width:6px;height:6px;border-radius:50%;background:#cbd5e1;animation:dot-bounce 1.2s ease-in-out infinite;"></span><span style="width:6px;height:6px;border-radius:50%;background:#cbd5e1;animation:dot-bounce 1.2s ease-in-out infinite .2s;"></span><span style="width:6px;height:6px;border-radius:50%;background:#cbd5e1;animation:dot-bounce 1.2s ease-in-out infinite .4s;"></span></span>'
      : lpMd(html||'');
  }
  row.appendChild(b);
  c.appendChild(row);
  c.scrollTop = c.scrollHeight;
  return b;
}

function lpMd(t) {
  return (t||'')
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/```([\s\S]*?)```/g,'<pre><code>$1</code></pre>')
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,'<em>$1</em>')
    .replace(/^### (.+)$/gm,'<p style="font-weight:700;font-size:13px;color:#475569;text-transform:uppercase;letter-spacing:.04em;margin:10px 0 4px;">$1</p>')
    .replace(/^## (.+)$/gm,'<p style="font-weight:700;font-size:15px;color:#1e293b;margin:10px 0 4px;">$1</p>')
    .replace(/^- (.+)$/gm,'<div style="display:flex;gap:6px;margin:2px 0;"><span style="color:#1e3a5f;margin-top:2px;">•</span><span>$1</span></div>')
    .replace(/\n/g,'<br>');
}
function lpEsc(t) { return (t||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>'); }

