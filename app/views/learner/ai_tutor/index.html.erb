  const glows={listening:'lp-vc-blob 7s ease-in-out infinite,lp-vc-glow-listening 2.5s ease-in-out infinite',speaking:'lp-vc-blob 3.5s ease-in-out infinite,lp-vc-glow-speaking 1.6s ease-in-out infinite',processing:'lp-vc-blob 4.5s ease-in-out infinite,lp-vc-glow-processing 1.0s ease-in-out infinite',idle:'lp-vc-blob 10s ease-in-out infinite'};
  const dot=document.getElementById('lp-vc-orb'); if(dot) dot.style.animation=glows[state]||glows.idle;
  const barsWrap=document.getElementById('lp-vc-bars');
  const clrs={listening:'#6366f1',speaking:'#10b981',processing:'#f59e0b',idle:'#64748b'};
