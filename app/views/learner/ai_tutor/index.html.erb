<!-- ── Voice Call Overlay ── -->
<div id="lp-vc-overlay" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;height:100%;height:-webkit-fill-available;z-index:190;background:linear-gradient(160deg,#07080f 0%,#0d0f1e 55%,#080c18 100%);flex-direction:column;align-items:center;justify-content:center;overflow:hidden;">
  <div style="position:absolute;top:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;padding:16px 20px;">
    <div style="display:flex;align-items:center;gap:8px;">
