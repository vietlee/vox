      <span id="lp-vc-voice-name" style="font-size:12px;font-weight:600;color:#64748b;">AI Tutor</span>
    </div>
    <button onclick="lpExitVoiceCall()" style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.09);color:#64748b;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;">×</button>
  </div>

  <div style="position:relative;display:flex;align-items:center;justify-content:center;margin-bottom:32px;animation:lp-vc-float 5s ease-in-out infinite;" onclick="lpVcTapMic()">
