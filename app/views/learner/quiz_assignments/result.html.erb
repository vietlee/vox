<% content_for :title, "Kết quả" %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <%= link_to learner_quiz_assignment_path(@assignment.token), class: "lp-bc-link" do %><%= @assignment.quiz_set.title %><% end %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current">Kết quả</span>
<% end %>
<% passed = @attempt&.passed? %>

<div style="text-align:center;padding:28px 0;">
  <div style="width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,<%= passed ? '#10b981,#059669' : '#ef4444,#dc2626' %>);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 8px 24px rgba(<%= passed ? '16,185,129' : '239,68,68' %>,0.3);">
    <span style="font-size:36px;"><%= passed ? '🎉' : '💪' %></span>
  </div>
  <h1 style="font-size:24px;font-weight:800;"><%= passed ? 'Xuất sắc!' : 'Cố lên!' %></h1>
  <p style="color:#6b7280;margin-top:6px;"><%= @assignment.quiz_set.title %></p>
</div>

<div class="lp-card" style="margin-bottom:16px;">
  <div class="lp-card-body" style="text-align:center;">
    <p style="font-size:52px;font-weight:900;color:<%= passed ? '#10b981' : '#ef4444' %>;line-height:1;"><%= @attempt ? @attempt.score_pct : 0 %>%</p>
    <p style="color:#1e3a5f;margin-top:8px;font-size:18px;font-weight:800;">
      <%= @attempt&.earned_points || 0 %><span style="color:#cbd5e1;font-weight:600;"> / </span><%= @attempt&.total_points || 0 %>
      <span style="font-size:13px;color:#9ca3af;font-weight:600;">điểm</span>
    </p>
    <div style="display:flex;justify-content:center;gap:28px;margin-top:18px;">
      <div>
        <p style="font-size:20px;font-weight:700;color:#1e3a5f;"><%= @attempt&.earned_points || 0 %></p>
        <p style="font-size:12px;color:#9ca3af;">Câu đúng</p>
      </div>
      <div>
        <p style="font-size:20px;font-weight:700;color:#6b7280;"><%= (@attempt&.total_points || 0) - (@attempt&.earned_points || 0) %></p>
        <p style="font-size:12px;color:#9ca3af;">Câu sai</p>
      </div>
      <div>
        <p style="font-size:20px;font-weight:700;color:#6b7280;"><%= @attempt&.total_points || 0 %></p>
        <p style="font-size:12px;color:#9ca3af;">Tổng câu</p>
      </div>
    </div>

    <!-- AI Tutor CTA — ngay dưới điểm -->
    <%= link_to learner_ai_tutor_path(context: "Quiz: #{@assignment.quiz_set.title}"),
          style: "display:flex;align-items:center;gap:10px;margin-top:20px;padding:12px 14px;border-radius:12px;background:linear-gradient(135deg,#f5f3ff,#faf5ff);border:1px solid #e9d5ff;text-decoration:none;" do %>
      <div style="width:38px;height:38px;background:linear-gradient(135deg,#1e3a5f,#16304f);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="19" height="19" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      </div>
      <div style="flex:1;text-align:left;min-width:0;">
        <p style="font-weight:700;color:#6b21a8;font-size:13.5px;margin:0;">Hỏi AI Tutor về bài này</p>
        <p style="font-size:11.5px;color:#7c3aed;margin:0;">Giải thích câu sai · ôn lại kiến thức</p>
      </div>
      <svg width="17" height="17" fill="none" stroke="#7c3aed" viewBox="0 0 24 24" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
  </div>
</div>

<% if @attempt&.ai_evaluation.present? %>
  <div class="lp-card" style="margin-bottom:16px;">
    <div class="lp-card-body">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;">
        <span style="font-size:18px;">🤖</span>
        <p style="font-size:13px;font-weight:800;color:#0f172a;margin:0;">Nhận xét từ AI</p>
      </div>
      <p style="font-size:14px;color:#334155;line-height:1.7;margin:0;white-space:pre-wrap;"><%= @attempt.ai_evaluation %></p>
    </div>
  </div>
<% end %>

<% if @questions.present? && @quiz_set.show_answers %>
  <p class="lp-section-title">Chi tiết kết quả</p>
  <div style="display:grid;gap:12px;margin-bottom:16px;">
    <% @questions.each_with_index do |q, i| %>
      <% ans = @answers_by_q[q.id] %>
      <div class="lp-card" style="margin:0;"><div class="lp-card-body">
        <div style="display:flex;gap:8px;align-items:flex-start;margin-bottom:10px;">
          <span style="flex-shrink:0;width:22px;height:22px;border-radius:50%;background:#eef3fb;color:#1e3a5f;font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;margin-top:1px;"><%= i + 1 %></span>
          <p style="font-size:14px;font-weight:700;color:#0f172a;margin:0;line-height:1.5;"><%= q.question_text %></p>
        </div>

        <% if q.essay? || q.short_answer? %>
          <%# ── Essay / short answer ── %>
          <p style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.4px;margin:0 0 4px;">Bài làm của bạn</p>
          <div style="font-size:13px;color:#334155;line-height:1.6;background:#f8fafc;border:1px solid #eef2f7;border-radius:10px;padding:10px 12px;margin-bottom:10px;white-space:pre-wrap;"><%= (ans&.essay_text.presence || ans&.text_answer).presence || "(Chưa trả lời)" %></div>
          <% if ans&.ai_grade %>
            <div style="display:inline-block;font-size:12px;font-weight:800;color:#1e3a5f;background:#eef3fb;padding:3px 10px;border-radius:99px;margin-bottom:8px;"><%= ans.ai_grade %>/<%= q.points.to_i %> điểm</div>
          <% end %>
          <% if ans&.ai_feedback.present? %>
            <div style="background:#f5f3ff;border:1px solid #ede9fe;border-radius:10px;padding:10px 12px;">
              <p style="font-size:11px;font-weight:700;color:#7c3aed;margin:0 0 3px;">🤖 Nhận xét</p>
              <p style="font-size:13px;color:#475569;line-height:1.6;margin:0;"><%= ans.ai_feedback %></p>
            </div>
          <% end %>
        <% else %>
          <%# ── Multiple choice / true-false ── %>
          <div style="display:grid;gap:6px;">
            <% q.quiz_options.each do |opt| %>
              <% chosen = ans&.quiz_option_id == opt.id %>
              <% correct = opt.is_correct? %>
              <% bg = correct ? '#f0fdf4' : (chosen ? '#fef2f2' : '#fff') %>
              <% bd = correct ? '#86efac' : (chosen ? '#fecaca' : '#e2e8f0') %>
              <div style="display:flex;align-items:center;gap:8px;padding:9px 12px;border:1px solid <%= bd %>;border-radius:10px;background:<%= bg %>;">
                <span style="flex-shrink:0;width:18px;height:18px;">
                  <% if correct %>
                    <svg width="18" height="18" fill="none" stroke="#16a34a" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <% elsif chosen %>
                    <svg width="18" height="18" fill="none" stroke="#ef4444" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                  <% end %>
                </span>
                <span style="flex:1;font-size:13px;color:<%= correct ? '#166534' : (chosen ? '#991b1b' : '#475569') %>;line-height:1.5;"><%= opt.option_text %></span>
                <% if chosen %><span style="flex-shrink:0;font-size:10px;font-weight:700;color:#64748b;background:rgba(0,0,0,.05);padding:2px 7px;border-radius:99px;">Bạn chọn</span><% end %>
              </div>
            <% end %>
          </div>
          <% if q.explanation.present? %>
            <div style="margin-top:8px;background:#f8fafc;border:1px solid #eef2f7;border-radius:10px;padding:9px 12px;">
              <p style="font-size:11px;font-weight:700;color:#94a3b8;margin:0 0 2px;">💡 Giải thích</p>
              <p style="font-size:12.5px;color:#475569;line-height:1.6;margin:0;"><%= q.explanation %></p>
            </div>
          <% end %>
        <% end %>
      </div></div>
    <% end %>
  </div>
<% end %>
