<% content_for :title, "Kết quả" %>
<% passed = @attempt&.passed? %>

<div style="text-align:center;padding:28px 0;">
  <div style="width:100px;height:100px;border-radius:50%;background:linear-gradient(135deg,<%= passed ? '#10b981,#059669' : '#ef4444,#dc2626' %>);display:flex;align-items:center;justify-content:center;margin:0 auto 16px;box-shadow:0 8px 24px rgba(<%= passed ? '16,185,129' : '239,68,68' %>,0.3);">
    <span style="font-size:36px;"><%= passed ? '🎉' : '💪' %></span>
  </div>
  <h1 style="font-size:24px;font-weight:800;"><%= passed ? 'Xuất sắc!' : 'Cố lên!' %></h1>
  <p style="color:#6b7280;margin-top:6px;"><%= @assignment.quiz_set.title %></p>
</div>

<div class="lp-card" style="margin-bottom:16px;">
  <div class="lp-card-body" style="text-align:center;">
    <p style="font-size:52px;font-weight:900;color:<%= passed ? '#10b981' : '#ef4444' %>;line-height:1;"><%= @attempt ? @attempt.score_pct : 0 %>%</p>
    <p style="color:#9ca3af;margin-top:4px;font-size:13px;">Điểm số</p>
    <div style="display:flex;justify-content:center;gap:28px;margin-top:18px;">
      <div>
        <p style="font-size:20px;font-weight:700;color:#6366f1;"><%= @attempt&.earned_points || 0 %></p>
        <p style="font-size:12px;color:#9ca3af;">Câu đúng</p>
      </div>
      <div>
        <p style="font-size:20px;font-weight:700;color:#6b7280;"><%= (@attempt&.total_points || 0) - (@attempt&.earned_points || 0) %></p>
        <p style="font-size:12px;color:#9ca3af;">Câu sai</p>
      </div>
      <div>
        <p style="font-size:20px;font-weight:700;color:#6b7280;"><%= @attempt&.total_points || 0 %></p>
        <p style="font-size:12px;color:#9ca3af;">Tổng câu</p>
      </div>
    </div>
  </div>
</div>

<%= link_to learner_ai_tutor_path(context: "Quiz: #{@assignment.quiz_set.title}"), class: "lp-card", style: "display:block;text-decoration:none;margin-bottom:16px;" do %>
  <div class="lp-card-body" style="display:flex;align-items:center;gap:12px;">
    <div style="width:44px;height:44px;background:linear-gradient(135deg,#9333ea,#7c3aed);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
      <svg width="22" height="22" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
    </div>
    <div>
      <p style="font-weight:700;color:#6b21a8;font-size:14px;">Hỏi AI Tutor về bài này</p>
      <p style="font-size:12px;color:#9333ea;">Giải thích những câu sai, ôn lại kiến thức</p>
    </div>
    <svg width="18" height="18" fill="none" stroke="#9333ea" viewBox="0 0 24 24" style="margin-left:auto;flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
  </div>
<% end %>

<%= link_to learner_root_path, class: "lp-btn lp-btn-outline lp-btn-full" do %>
  ← Về trang chủ
<% end %>
