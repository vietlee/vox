<% content_for :title, @assignment.quiz_set.title %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= @assignment.quiz_set.title %></span>
<% end %>

<div style="text-align:center;padding:20px 0 30px;">
  <div style="width:80px;height:80px;background:linear-gradient(135deg,#dbeafe,#bfdbfe);border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
    <svg width="40" height="40" fill="none" stroke="#1d4ed8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
  </div>
  <h1 style="font-size:22px;font-weight:800;margin-bottom:6px;"><%= @assignment.quiz_set.title %></h1>
  <% if @assignment.quiz_set.description.present? %>
    <p style="font-size:14px;color:#6b7280;max-width:320px;margin:0 auto;"><%= @assignment.quiz_set.description %></p>
  <% end %>
</div>

<div class="lp-card">
  <div class="lp-card-body">
    <% qs = @assignment.quiz_set %>
    <% own = qs.learner_id.present? && qs.learner_id == current_learner.id %>
    <div style="display:flex;justify-content:center;margin-bottom:14px;">
      <div style="text-align:center;flex:1;">
        <p style="font-size:22px;font-weight:800;color:#1e3a5f;"><%= qs.quiz_questions.count %></p>
        <p style="font-size:12px;color:#9ca3af;"><%= t('learner_qz.questions_label') %></p>
      </div>
      <% if qs.time_limit_minutes.present? %>
        <div style="width:1px;background:#f3f4f6;"></div>
        <div style="text-align:center;flex:1;">
          <p style="font-size:22px;font-weight:800;color:#1e3a5f;"><%= qs.time_limit_minutes %>′</p>
          <p style="font-size:12px;color:#9ca3af;"><%= t('learner_qz.time_label_short') %></p>
        </div>
      <% end %>
      <% unless own %>
        <div style="width:1px;background:#f3f4f6;"></div>
        <div style="text-align:center;flex:1;">
          <% if qs.passing_score_type == 'points' %>
            <p style="font-size:22px;font-weight:800;color:#1e3a5f;"><%= qs.passing_score %>đ</p>
          <% else %>
            <p style="font-size:22px;font-weight:800;color:#1e3a5f;"><%= qs.passing_score %>%</p>
          <% end %>
          <p style="font-size:12px;color:#9ca3af;"><%= t('learner_qz.passing_score_label') %></p>
        </div>
        <% if @assignment.due_at %>
          <div style="width:1px;background:#f3f4f6;"></div>
          <div style="text-align:center;flex:1;">
            <p style="font-size:16px;font-weight:800;color:<%= @assignment.overdue? ? '#ef4444' : '#1e3a5f' %>;"><%= @assignment.due_at.strftime("%d/%m") %></p>
            <p style="font-size:12px;color:#9ca3af;"><%= t('learner_qz.due_date_label') %></p>
          </div>
        <% end %>
      <% end %>
    </div>
    <div style="text-align:center;">
    <% if @assignment.completed? %>
      <%= link_to result_learner_quiz_assignment_path(@assignment.token), class: "lp-btn lp-btn-outline", style: "display:inline-flex;padding:13px 40px;font-size:15px;" do %>
        <%= t('learner_qz.view_result') %>
      <% end %>
    <% else %>
      <%= button_to start_learner_quiz_assignment_path(@assignment.token), method: :post, class: "lp-btn lp-btn-primary", style: "display:inline-flex;font-size:15px;padding:13px 48px;" do %>
        <%= @assignment.in_progress? ? t('learner_qz.continue_quiz') : t('learner_qz.start_quiz') %>
      <% end %>
    <% end %>
    </div>
  </div>
</div>
