<% content_for :title, @assignment.quiz_set.title %>

<div style="text-align:center;padding:20px 0 30px;">
  <div style="width:80px;height:80px;background:linear-gradient(135deg,#dbeafe,#bfdbfe);border-radius:20px;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;">
    <svg width="40" height="40" fill="none" stroke="#1d4ed8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
  </div>
  <h1 style="font-size:22px;font-weight:800;margin-bottom:6px;"><%= @assignment.quiz_set.title %></h1>
  <% if @assignment.quiz_set.description.present? %>
    <p style="font-size:14px;color:#6b7280;max-width:320px;margin:0 auto;"><%= @assignment.quiz_set.description %></p>
  <% end %>
</div>

<div class="lp-card">
  <div class="lp-card-body">
    <div style="display:flex;justify-content:space-between;margin-bottom:14px;">
      <div style="text-align:center;flex:1;">
        <p style="font-size:22px;font-weight:800;color:#6366f1;"><%= @assignment.quiz_set.quiz_questions.count %></p>
        <p style="font-size:12px;color:#9ca3af;">Câu hỏi</p>
      </div>
      <div style="width:1px;background:#f3f4f6;"></div>
      <div style="text-align:center;flex:1;">
        <p style="font-size:22px;font-weight:800;color:#6366f1;"><%= @assignment.quiz_set.passing_score || 50 %>%</p>
        <p style="font-size:12px;color:#9ca3af;">Điểm đạt</p>
      </div>
      <% if @assignment.due_at %>
        <div style="width:1px;background:#f3f4f6;"></div>
        <div style="text-align:center;flex:1;">
          <p style="font-size:16px;font-weight:800;color:<%= @assignment.overdue? ? '#ef4444' : '#6366f1' %>;"><%= @assignment.due_at.strftime("%d/%m") %></p>
          <p style="font-size:12px;color:#9ca3af;">Hạn nộp</p>
        </div>
      <% end %>
    </div>
    <% if @assignment.completed? %>
      <%= link_to result_learner_quiz_assignment_path(@assignment.token), class: "lp-btn lp-btn-outline lp-btn-full" do %>
        Xem kết quả đã làm
      <% end %>
    <% else %>
      <%= button_to start_learner_quiz_assignment_path(@assignment.token), method: :post, class: "lp-btn lp-btn-primary lp-btn-full", style: "font-size:16px;padding:14px;" do %>
        <%= @assignment.in_progress? ? "Tiếp tục làm bài →" : "Bắt đầu làm bài →" %>
      <% end %>
    <% end %>
  </div>
</div>
