<% content_for :title, t('learner_plan.title') %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= t('learner_plan.title') %></span>
<% end %>

<div style="text-align:center;padding:16px 0 20px;">
  <div style="width:64px;height:64px;background:linear-gradient(135deg,#eef3fa,#dce7f4);border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;border:2px solid #bcd0e8;">
    <span style="font-size:30px;">🧠</span>
  </div>
  <h1 style="font-size:19px;font-weight:800;color:#0f172a;margin:0 0 4px;"><%= t('learner_plan.hero_title') %></h1>
  <p style="font-size:13px;color:#64748b;margin:0;"><%= t('learner_plan.hero_desc') %></p>
</div>

<%= button_to learner_study_plans_path, method: :post, form: { id: "gen-plan-form" },
      style: "width:100%;border:none;cursor:pointer;background:linear-gradient(135deg,#1e3a5f,#16304f);color:#fff;font-size:15px;font-weight:700;padding:14px;border-radius:14px;margin-bottom:8px;" do %>
  ✨ <%= t('learner_plan.create_btn', n: @cost) %>
<% end %>
<p style="text-align:center;font-size:11px;color:#94a3b8;margin-bottom:20px;"><%= t('learner_plan.credits_left', n: current_learner.credits) %></p>

<% if @plans.any? %>
  <p class="lp-section-title"><%= t('learner_plan.yours') %></p>
  <div style="display:grid;gap:12px;">
    <% @plans.each do |plan| %>
      <%= link_to learner_study_plan_path(plan), style:"text-decoration:none;" do %>
        <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px;">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
            <p style="font-size:14px;font-weight:700;color:#0f172a;margin:0;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= plan.title %></p>
            <% if plan.completed? %>
              <span style="font-size:10px;font-weight:700;background:#dcfce7;color:#166534;padding:2px 8px;border-radius:99px;flex-shrink:0;">✓ <%= t('learner_plan.completed') %></span>
            <% else %>
              <span style="font-size:11px;font-weight:700;color:#1e3a5f;flex-shrink:0;"><%= plan.progress_pct %>%</span>
            <% end %>
          </div>
          <div style="background:#f1f5f9;border-radius:99px;height:6px;overflow:hidden;">
            <div style="height:100%;border-radius:99px;background:linear-gradient(90deg,#1e3a5f,#4a7fa8);width:<%= plan.progress_pct %>%;"></div>
          </div>
          <p style="font-size:11px;color:#94a3b8;margin:8px 0 0;"><%= t('learner_plan.steps_date', n: plan.items.count, date: plan.created_at.strftime('%d/%m/%Y')) %></p>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div style="text-align:center;padding:32px 20px;background:#fff;border:1px dashed #e2e8f0;border-radius:16px;">
    <div style="font-size:36px;margin-bottom:10px;">🗺️</div>
    <p style="font-size:14px;font-weight:700;color:#1e293b;margin:0 0 4px;"><%= t('learner_plan.empty_title') %></p>
    <p style="font-size:13px;color:#64748b;margin:0;"><%= t('learner_plan.empty_desc') %></p>
  </div>
<% end %>

<script>
  // Show a loading state while AI generates (can take a few seconds)
  var f = document.getElementById('gen-plan-form');
  if (f) f.addEventListener('submit', function() {
    var btn = f.querySelector('button');
    btn.disabled = true;
    btn.textContent = '⏳ <%= j t('learner_plan.generating') %>';
  });
</script>
