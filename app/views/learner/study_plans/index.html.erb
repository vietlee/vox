<% content_for :title, t('learner_plan.title') %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <%= link_to t('learner_dashboard.library'), learner_library_path, class: "lp-bc-link" %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= t('learner_plan.title') %></span>
<% end %>

<div style="text-align:center;padding:16px 0 20px;">
  <div style="width:64px;height:64px;background:linear-gradient(135deg,#eef3fa,#dce7f4);border-radius:18px;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;border:2px solid #bcd0e8;">
    <span style="font-size:30px;">🧠</span>
  </div>
  <h1 style="font-size:19px;font-weight:800;color:#0f172a;margin:0 0 4px;"><%= t('learner_plan.hero_title') %></h1>
  <p style="font-size:13px;color:#64748b;margin:0;"><%= t('learner_plan.hero_desc') %></p>
</div>

<%= form_with url: learner_study_plans_path, method: :post, id: "gen-plan-form", data: { turbo: false } do |f| %>
  <div style="margin-bottom:10px;">
    <label style="display:block;font-size:13px;font-weight:700;color:#374151;margin-bottom:6px;"><%= t('learner_plan.wish_label') %></label>
    <textarea name="focus" rows="3" maxlength="500" placeholder="<%= t('learner_plan.wish_ph') %>"
      style="width:100%;padding:12px 14px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;color:#1e293b;font-family:inherit;resize:vertical;outline:none;box-sizing:border-box;line-height:1.5;"
      onfocus="this.style.borderColor='#1e3a5f'" onblur="this.style.borderColor='#e5e7eb'"></textarea>
  </div>
  <button type="submit" id="gen-plan-btn"
      style="width:100%;border:none;cursor:pointer;background:linear-gradient(135deg,#1e3a5f,#16304f);color:#fff;font-size:15px;font-weight:700;padding:14px;border-radius:14px;margin-bottom:8px;">
    ✨ <%= t('learner_plan.create_btn', n: @cost) %>
  </button>
<% end %>
<p style="text-align:center;font-size:11px;color:#94a3b8;margin-bottom:20px;"><%= t('learner_plan.credits_left', n: current_learner.credits) %></p>


<% if @plans.any? %>
  <p class="lp-section-title"><%= t('learner_plan.yours') %></p>
  <div style="display:grid;gap:12px;">
    <% @plans.each do |plan| %>
      <div id="study-plan-<%= plan.id %>" style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px 16px;display:flex;align-items:center;gap:10px;">
        <%= link_to learner_study_plan_path(plan), style:"text-decoration:none;flex:1;min-width:0;" do %>
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
            <p style="font-size:14px;font-weight:700;color:#0f172a;margin:0;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= plan.title %></p>
            <% if plan.completed? %>
              <span style="font-size:10px;font-weight:700;background:#dcfce7;color:#166534;padding:2px 8px;border-radius:99px;flex-shrink:0;margin-left:8px;">✓ <%= t('learner_plan.completed') %></span>
            <% else %>
              <span style="font-size:11px;font-weight:700;color:#1e3a5f;flex-shrink:0;margin-left:8px;"><%= plan.progress_pct %>%</span>
            <% end %>
          </div>
          <div style="background:#f1f5f9;border-radius:99px;height:6px;overflow:hidden;">
            <div style="height:100%;border-radius:99px;background:linear-gradient(90deg,#1e3a5f,#4a7fa8);width:<%= plan.progress_pct %>%;"></div>
          </div>
          <p style="font-size:11px;color:#94a3b8;margin:8px 0 0;"><%= t('learner_plan.steps_date', n: plan.items.count, date: plan.created_at.strftime('%d/%m/%Y')) %></p>
        <% end %>
        <button onclick="planDelete(<%= plan.id %>, '<%= j plan.title %>')"
                style="flex-shrink:0;width:32px;height:32px;border:none;background:transparent;cursor:pointer;border-radius:8px;display:flex;align-items:center;justify-content:center;color:#cbd5e1;transition:color .15s,background .15s;"
                onmouseover="this.style.color='#ef4444';this.style.background='#fef2f2'" onmouseout="this.style.color='#cbd5e1';this.style.background='transparent'" title="Xoá">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      </div>
    <% end %>
  </div>
  <script>
  function planDelete(id, name) {
    lpDeleteConfirm(
      '/learner/study-plans/' + id,
      'Xoá lộ trình học?',
      'Lộ trình "' + name + '" sẽ bị xoá vĩnh viễn. Hành động này không thể hoàn tác.',
      function() { document.getElementById('study-plan-' + id).remove(); }
    );
  }
  </script>
<% else %>
  <div style="text-align:center;padding:32px 20px;background:#fff;border:1px dashed #e2e8f0;border-radius:16px;">
    <div style="font-size:36px;margin-bottom:10px;">🗺️</div>
    <p style="font-size:14px;font-weight:700;color:#1e293b;margin:0 0 4px;"><%= t('learner_plan.empty_title') %></p>
    <p style="font-size:13px;color:#64748b;margin:0;"><%= t('learner_plan.empty_desc') %></p>
  </div>
<% end %>

<script>
(function(){
  var _planMsgs = ['<%= j t("learner_plan.gen_1") %>','<%= j t("learner_plan.gen_2") %>','<%= j t("learner_plan.gen_3") %>','<%= j t("learner_plan.gen_4") %>'];
  var f = document.getElementById('gen-plan-form');
  if (!f) return;
  f.addEventListener('submit', function(e) {
    e.preventDefault();
    var btn   = document.getElementById('gen-plan-btn');
    var focus = (f.querySelector('[name=focus]') || {}).value || '';
    btn.disabled = true;
    AiProgress.start({
      title: '<%= j t("learner_plan.loading_title") %>',
      miniLabel: focus.trim().slice(0, 32) || 'Lộ trình học mới',
      msgs: _planMsgs
    });
    var fd = new FormData(f);
    fetch(f.action, {
      method: 'POST', body: fd,
      headers: { 'Accept': 'application/json', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content }
    })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.redirect_url) {
          AiProgress.done(d.redirect_url, '<%= j t("learner_plan.done_label") %>');
        } else {
          AiProgress.error();
          alert(d.error || 'Có lỗi xảy ra, vui lòng thử lại.');
          btn.disabled = false;
        }
      })
      .catch(function() {
        AiProgress.error();
        alert('Không thể kết nối máy chủ.');
        btn.disabled = false;
      });
  });
})();
</script>
