<% content_for :title, "Thông báo" %>

<div style="max-width:560px;margin:0 auto;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
    <h1 style="font-size:18px;font-weight:800;color:#1e293b;margin:0;">🔔 Thông báo</h1>
    <% if @notifications.any? %>
      <span style="font-size:12px;color:#9ca3af;"><%= @notifications.size %> thông báo</span>
    <% end %>
  </div>

  <% if @notifications.empty? %>
    <div style="text-align:center;padding:60px 20px;">
      <div style="font-size:48px;margin-bottom:12px;">🔕</div>
      <p style="font-weight:700;font-size:15px;color:#374151;">Chưa có thông báo</p>
      <p style="font-size:13px;color:#9ca3af;margin-top:4px;">Các thông báo về bài thi và lộ trình học sẽ xuất hiện ở đây.</p>
    </div>
  <% else %>
    <div style="display:grid;gap:8px;">
      <% @notifications.each do |n| %>
        <% icon = { "quiz_assigned" => "📝", "flashcard_assigned" => "🃏", "path_assigned" => "🗺️", "badge_earned" => "🏆" }[n.notification_type] || "🔔" %>
        <% item_style = "display:flex;align-items:flex-start;gap:12px;background:#fff;border:1.5px solid #e5e7eb;border-radius:14px;padding:14px 16px;text-decoration:none;color:inherit;" %>
        <% item_style += "border-color:#c7d2fe;background:#f5f7ff;" if !n.read %>
        <% if n.action_url.present? %>
          <%= link_to n.action_url, style: item_style do %>
            <%= render partial: "learner/notifications/item", locals: { n: n, icon: icon } %>
          <% end %>
        <% else %>
          <div style="<%= item_style %>">
            <%= render partial: "learner/notifications/item", locals: { n: n, icon: icon } %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
