<div style="width:40px;height:40px;border-radius:11px;background:<%= n.read ? '#f0f4f8' : '#e0e7ff' %>;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;"><%= icon %></div>
<div style="flex:1;min-width:0;">
  <p style="font-size:13px;font-weight:<%= n.read ? '600' : '800' %>;color:#1e293b;margin:0;"><%= n.title %></p>
  <% if n.body.present? %>
    <p style="font-size:12px;color:#64748b;margin:2px 0 0;"><%= n.body %></p>
  <% end %>
  <p style="font-size:11px;color:#9ca3af;margin:4px 0 0;"><%= t('notifications.time_ago', time: time_ago_in_words(n.created_at)) %></p>
</div>
<% unless n.read %>
  <div style="width:8px;height:8px;border-radius:50%;background:#6366f1;flex-shrink:0;margin-top:4px;"></div>
<% end %>
