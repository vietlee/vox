<% content_for :title, t('learner_profile.title') %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= t('learner_profile.title') %></span>
<% end %>

<div style="text-align:center;padding:20px 0 24px;">
  <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#1e3a5f,#16304f);display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
    <span style="font-size:32px;font-weight:800;color:white;"><%= current_learner.name.first.upcase %></span>
  </div>
  <h1 style="font-size:20px;font-weight:800;"><%= current_learner.name %></h1>
  <p style="font-size:14px;color:#9ca3af;margin-top:4px;"><%= current_learner.email %></p>
</div>

<div class="lp-card" style="margin-bottom:20px;">
  <div class="lp-card-body">
    <%= form_with url: learner_profile_path, method: :patch, scope: :learner do |f| %>
      <div class="form-group" style="margin-bottom:14px;">
        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;"><%= t('learner_profile.display_name') %></label>
        <%= f.text_field :name, value: current_learner.name, style: "width:100%;padding:11px 14px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:15px;outline:none;", onfocus: "this.style.borderColor='#1e3a5f'", onblur: "this.style.borderColor='#e5e7eb'" %>
      </div>
      <div style="margin-bottom:14px;">
        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;"><%= t('learner_profile.email') %></label>
        <input type="email" value="<%= current_learner.email %>" disabled style="width:100%;padding:11px 14px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:15px;background:#f9fafb;color:#6b7280;">
      </div>
      <div style="margin-bottom:14px;">
        <label style="display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:6px;"><%= t('learner_profile.daily_goal_label') %></label>
        <div style="display:flex;gap:8px;" id="lp-goal-picker">
          <% [2,3,5,10].each do |g| %>
            <% on = current_learner.daily_goal == g %>
            <label style="flex:1;cursor:pointer;">
              <input type="radio" name="learner[daily_goal]" value="<%= g %>" <%= "checked" if on %> style="display:none;" onchange="lpPickGoal(this)">
              <span class="lp-goal-opt" style="display:block;text-align:center;padding:10px 0;border-radius:10px;border:1.5px solid <%= on ? '#1e3a5f' : '#e5e7eb' %>;background:<%= on ? '#f0f6ff' : '#fff' %>;color:<%= on ? '#1e3a5f' : '#64748b' %>;font-size:14px;font-weight:700;"><%= g %></span>
            </label>
          <% end %>
        </div>
        <p style="font-size:11px;color:#9ca3af;margin-top:5px;"><%= t('learner_profile.daily_goal_hint') %></p>
      </div>
      <%= f.submit t('learner_profile.save'), class: "lp-btn lp-btn-primary lp-btn-full" %>
    <% end %>
    <script>
      function lpPickGoal(input){
        document.querySelectorAll('#lp-goal-picker .lp-goal-opt').forEach(function(s){
          s.style.borderColor='#e5e7eb'; s.style.background='#fff'; s.style.color='#64748b';
        });
        var s = input.nextElementSibling;
        s.style.borderColor='#1e3a5f'; s.style.background='#f0f6ff'; s.style.color='#1e3a5f';
      }
    </script>
  </div>
</div>

<div class="lp-card" id="pwa-profile-card" style="margin-bottom:20px;">
  <div class="lp-card-body">
    <div style="display:flex;align-items:center;gap:12px;">
      <img src="/icon-192.png" alt="VOX" style="width:44px;height:44px;border-radius:12px;flex-shrink:0;">
      <div style="flex:1;min-width:0;">
        <p style="font-weight:700;font-size:14px;margin:0;"><%= t('learner_profile.pwa_app_name') %></p>
        <p id="pwa-profile-desc" style="font-size:12px;color:#9ca3af;margin:2px 0 0;"><%= t('learner_profile.pwa_install_desc') %></p>
      </div>
      <button type="button" id="pwa-profile-btn" onclick="lpProfileInstall()"
              style="flex-shrink:0;padding:9px 16px;border-radius:11px;border:none;background:#1e3a5f;color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:inherit;"><%= t('learner_profile.pwa_install_btn') %></button>
    </div>
  </div>
</div>
<script>
  (function(){
    var btn = document.getElementById('pwa-profile-btn');
    var desc = document.getElementById('pwa-profile-desc');
    var INSTALLED_LABEL = '<%= j t('learner_profile.pwa_installed') %>';
    var ALREADY_DESC    = '<%= j t('learner_profile.pwa_already_desc') %>';
    var MANUAL_DESC     = '<%= j t('learner_profile.pwa_manual_desc') %>';
    function refresh(){
      if (window.voxIsStandalone && window.voxIsStandalone()) {
        btn.textContent = INSTALLED_LABEL;
        btn.disabled = true;
        btn.style.background = '#e2e8f0';
        btn.style.color = '#64748b';
        btn.style.cursor = 'default';
        desc.textContent = ALREADY_DESC;
      }
    }
    window.lpProfileInstall = function(){
      var res = window.voxTriggerInstall ? window.voxTriggerInstall() : 'unavailable';
      if (res === 'installed') { refresh(); }
      else if (res === 'unavailable') {
        desc.textContent = MANUAL_DESC;
      }
    };
    refresh();
    window.addEventListener('appinstalled', refresh);
  })();
</script>

<!-- Push Notifications -->
<div class="lp-card" id="push-notif-card" style="margin-bottom:20px;display:none;">
  <div class="lp-card-body">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px;">
      <div style="width:44px;height:44px;background:linear-gradient(135deg,#dbeafe,#bfdbfe);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:20px;">🔔</div>
      <div style="flex:1;min-width:0;">
        <p style="font-weight:700;font-size:14px;margin:0;">Thông báo nhắc học</p>
        <p id="push-status-desc" style="font-size:12px;color:#9ca3af;margin:2px 0 0;">Nhận nhắc nhở hàng ngày để duy trì streak</p>
      </div>
      <label style="position:relative;display:inline-flex;align-items:center;cursor:pointer;flex-shrink:0;">
        <input type="checkbox" id="push-toggle" style="sr-only;opacity:0;position:absolute;width:0;height:0;" onchange="lpTogglePush(this)">
        <span id="push-toggle-track" style="width:44px;height:26px;background:#e2e8f0;border-radius:13px;display:block;transition:background .2s;position:relative;">
          <span id="push-toggle-thumb" style="position:absolute;top:3px;left:3px;width:20px;height:20px;background:#fff;border-radius:50%;box-shadow:0 1px 3px rgba(0,0,0,.15);transition:transform .2s;"></span>
        </span>
      </label>
    </div>
    <div id="push-hour-row" style="display:none;align-items:center;justify-content:space-between;padding:10px 0;border-top:1px solid #f1f5f9;">
      <span style="font-size:13px;color:#374151;">Giờ nhắc mỗi ngày</span>
      <select id="push-hour-select" onchange="lpUpdateReminderHour(this.value)"
              style="padding:6px 10px;border:1.5px solid #e5e7eb;border-radius:10px;font-size:13px;font-weight:600;color:#1e293b;background:#fff;outline:none;">
        <% (6..23).each do |h| %>
          <option value="<%= h %>" <%= 'selected' if h.to_s == (@reminder_hour || "20").to_s %>><%= h %>:00</option>
        <% end %>
      </select>
    </div>
  </div>
</div>

<script>
(function(){
  var SUBSCRIBE_URL   = '<%= learner_push_subscriptions_path %>';
  var UNSUBSCRIBE_URL = '<%= learner_push_subscriptions_destroy_path %>';
  var CSRF = function(){ return document.querySelector('meta[name="csrf-token"]').content; };
  var SW_URL = '/service-worker.js';
  var VAPID_PUBLIC = '<%= ENV["VAPID_PUBLIC_KEY"] %>';

  if (!('Notification' in window) || !('serviceWorker' in navigator)) return;

  var card   = document.getElementById('push-notif-card');
  var toggle = document.getElementById('push-toggle');
  var track  = document.getElementById('push-toggle-track');
  var thumb  = document.getElementById('push-toggle-thumb');
  var desc   = document.getElementById('push-status-desc');
  var hourRow = document.getElementById('push-hour-row');
  card.style.display = 'block';

  function setToggleState(on) {
    toggle.checked = on;
    track.style.background = on ? '#1e3a5f' : '#e2e8f0';
    thumb.style.transform  = on ? 'translateX(18px)' : 'translateX(0)';
    hourRow.style.display  = on ? 'flex' : 'none';
    desc.textContent = on ? 'Bạn sẽ nhận thông báo hàng ngày' : 'Nhận nhắc nhở hàng ngày để duy trì streak';
  }

  // Check current subscription state
  navigator.serviceWorker.getRegistration(SW_URL).then(function(reg) {
    if (!reg) return;
    reg.pushManager.getSubscription().then(function(sub) {
      setToggleState(!!sub);
    });
  });

  window.lpTogglePush = function(el) {
    if (el.checked) { requestAndSubscribe(); }
    else { unsubscribe(); }
  };

  function requestAndSubscribe() {
    if (Notification.permission === 'denied') {
      desc.textContent = 'Bạn đã tắt thông báo trong trình duyệt. Vui lòng bật lại trong Settings.';
      setToggleState(false); return;
    }
    Notification.requestPermission().then(function(perm) {
      if (perm !== 'granted') { setToggleState(false); return; }
      subscribe();
    });
  }

  function subscribe() {
    navigator.serviceWorker.getRegistration(SW_URL).then(function(reg) {
      if (!reg) { navigator.serviceWorker.register(SW_URL).then(doSubscribe); }
      else doSubscribe(reg);
    });
  }

  function doSubscribe(reg) {
    var appKey = urlBase64ToUint8Array(VAPID_PUBLIC);
    reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: appKey })
      .then(function(sub) {
        var keys = sub.getKey ? { p256dh: bufToB64(sub.getKey('p256dh')), auth: bufToB64(sub.getKey('auth')) } : {};
        var hour = document.getElementById('push-hour-select').value;
        return fetch(SUBSCRIBE_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF() },
          body: JSON.stringify({ subscription: { endpoint: sub.endpoint, keys: keys }, reminder_hour: hour })
        });
      })
      .then(function(){ setToggleState(true); })
      .catch(function(e){ setToggleState(false); console.error(e); });
  }

  function unsubscribe() {
    navigator.serviceWorker.getRegistration(SW_URL).then(function(reg) {
      if (!reg) { setToggleState(false); return; }
      reg.pushManager.getSubscription().then(function(sub) {
        if (!sub) { setToggleState(false); return; }
        sub.unsubscribe().then(function() {
          fetch(UNSUBSCRIBE_URL, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF() },
            body: JSON.stringify({ endpoint: sub.endpoint })
          });
          setToggleState(false);
        });
      });
    });
  }

  window.lpUpdateReminderHour = function(hour) {
    navigator.serviceWorker.getRegistration(SW_URL).then(function(reg) {
      if (!reg) { if (window.showLpToast) showLpToast('Vui lòng bật thông báo trước.', 'error'); return; }
      reg.pushManager.getSubscription().then(function(sub) {
        if (!sub) { if (window.showLpToast) showLpToast('Vui lòng bật thông báo trước.', 'error'); return; }
        var keys = sub.getKey ? { p256dh: bufToB64(sub.getKey('p256dh')), auth: bufToB64(sub.getKey('auth')) } : {};
        fetch(SUBSCRIBE_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': CSRF() },
          body: JSON.stringify({ subscription: { endpoint: sub.endpoint, keys: keys }, reminder_hour: hour })
        })
        .then(function(r){ return r.json(); })
        .then(function(d){
          if (d && d.ok) { if (window.showLpToast) showLpToast('Đã lưu giờ nhắc: ' + hour + ':00', 'success'); }
          else { if (window.showLpToast) showLpToast('Không lưu được, thử lại.', 'error'); }
        })
        .catch(function(){ if (window.showLpToast) showLpToast('Không lưu được, thử lại.', 'error'); });
      });
    });
  };

  function bufToB64(buf) {
    return btoa(String.fromCharCode.apply(null, new Uint8Array(buf)));
  }

  function urlBase64ToUint8Array(base64String) {
    var padding = '='.repeat((4 - base64String.length % 4) % 4);
    var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
    var raw = atob(base64);
    return Uint8Array.from(Array.from(raw).map(function(c){ return c.charCodeAt(0); }));
  }
})();
</script>

<div class="lp-card">
  <div class="lp-card-body">
    <p style="font-weight:700;font-size:14px;margin-bottom:12px;"><%= t('learner_profile.account_section') %></p>
    <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f3f4f6;">
      <span style="font-size:14px;color:#6b7280;"><%= t('learner_profile.credits_remaining') %></span>
      <span style="font-weight:700;color:#1e3a5f;"><%= current_learner.credits %></span>
    </div>
    <div style="display:flex;justify-content:space-between;padding:10px 0;border-bottom:1px solid #f3f4f6;">
      <span style="font-size:14px;color:#6b7280;"><%= t('learner_profile.joined_at') %></span>
      <span style="font-weight:600;"><%= current_learner.created_at.strftime("%d/%m/%Y") %></span>
    </div>
    <div style="padding-top:14px;">
      <button type="button" onclick="document.getElementById('logout-confirm').style.display='flex'"
              class="lp-btn lp-btn-full" style="background:#fee2e2;color:#991b1b;border:none;cursor:pointer;font-family:inherit;">
        <%= t('learner_profile.logout') %>
      </button>

      <!-- Confirm popup -->
      <div id="logout-confirm" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(15,23,42,0.5);align-items:center;justify-content:center;">
        <div style="background:#fff;border-radius:18px;padding:28px 24px;width:100%;max-width:320px;margin:16px;box-shadow:0 8px 40px rgba(0,0,0,0.18);text-align:center;">
          <div style="width:48px;height:48px;border-radius:50%;background:#fef2f2;display:flex;align-items:center;justify-content:center;margin:0 auto 14px;font-size:22px;">🚪</div>
          <p style="font-size:16px;font-weight:800;color:#1e293b;margin:0 0 6px;"><%= t('learner_profile.logout_confirm_title') %></p>
          <p style="font-size:13px;color:#94a3b8;margin:0 0 20px;"><%= t('learner_profile.logout_confirm_desc') %></p>
          <div style="display:flex;gap:10px;">
            <button type="button" onclick="document.getElementById('logout-confirm').style.display='none'"
                    style="flex:1;padding:11px;border:1.5px solid #e5e7eb;border-radius:12px;font-size:14px;font-weight:600;color:#475569;background:#fff;cursor:pointer;font-family:inherit;">
              <%= t('learner_profile.logout_cancel') %>
            </button>
            <form action="<%= destroy_learner_session_path %>" method="post" style="flex:1;">
              <%= hidden_field_tag :_method, :delete %>
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <button type="submit" style="width:100%;padding:11px;border:none;border-radius:12px;font-size:14px;font-weight:700;color:#fff;background:#ef4444;cursor:pointer;font-family:inherit;">
                <%= t('learner_profile.logout_confirm') %>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
