<% content_for :title, "Thiết lập tài khoản" %>
<style>
  body { background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 60%, #a855f7 100%) !important; }
  .auth-card { background: white; border-radius: 24px; padding: 32px 28px; box-shadow: 0 20px 60px rgba(0,0,0,0.15); max-width: 400px; margin: 40px auto 0; }
  .auth-logo { text-align: center; margin-bottom: 24px; }
  .invite-hello { background: linear-gradient(135deg, #f0fdf4, #dcfce7); border-radius: 14px; padding: 14px 16px; margin-bottom: 20px; }
  .invite-hello h2 { font-size: 16px; font-weight: 700; color: #065f46; }
  .invite-hello p { font-size: 13px; color: #047857; margin-top: 4px; }
  .form-group { margin-bottom: 16px; }
  .form-label { display: block; font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 6px; }
  .form-input { width: 100%; padding: 12px 14px; border: 1.5px solid #e5e7eb; border-radius: 12px; font-size: 15px; outline: none; transition: border-color 0.2s; background: #fafafa; }
  .form-input:focus { border-color: #6366f1; background: white; box-shadow: 0 0 0 3px rgba(99,102,241,0.1); }
  .auth-submit { width: 100%; padding: 13px; background: linear-gradient(135deg, #6366f1, #7c3aed); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 700; cursor: pointer; margin-top: 4px; transition: all 0.2s; }
  .auth-submit:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(99,102,241,0.4); }
  .req-hint { font-size: 12px; color: #9ca3af; margin-top: 4px; }
</style>

<div class="auth-card">
  <div class="auth-logo">
    <svg width="52" height="52" viewBox="0 0 36 36" fill="none"><rect width="36" height="36" rx="9" fill="#6366f1"/><polygon points="10,24 6,31 16,24" fill="white"/><rect x="6" y="6" width="24" height="19" rx="5" fill="white" fill-opacity="0.9"/><rect x="10" y="11" width="4" height="7" rx="1" fill="#6366f1"/><rect x="16" y="8" width="4" height="13" rx="1" fill="#6366f1"/><rect x="23" y="10" width="4" height="9" rx="1" fill="#6366f1"/></svg>
  </div>

  <div class="invite-hello">
    <h2>Chào mừng, <%= @learner.name %>! 👋</h2>
    <p>Bạn được mời tham gia VOX Learn. Thiết lập mật khẩu để bắt đầu.</p>
  </div>

  <%= form_with url: learner_invitation_path(token: @learner.invite_token), method: :patch do |f| %>
    <div class="form-group">
      <label class="form-label">Email</label>
      <input type="email" value="<%= @learner.email %>" class="form-input" readonly style="background:#f3f4f6;color:#6b7280;">
    </div>
    <div class="form-group">
      <label class="form-label">Mật khẩu mới</label>
      <input type="password" name="password" class="form-input" placeholder="Tối thiểu 8 ký tự" autocomplete="new-password">
      <p class="req-hint">Ít nhất 8 ký tự</p>
    </div>
    <div class="form-group">
      <label class="form-label">Xác nhận mật khẩu</label>
      <input type="password" name="password_confirmation" class="form-input" placeholder="Nhập lại mật khẩu" autocomplete="new-password">
    </div>
    <button type="submit" class="auth-submit">Bắt đầu học ngay →</button>
  <% end %>
</div>
