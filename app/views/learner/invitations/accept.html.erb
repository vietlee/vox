<% content_for :title, "Thiết lập tài khoản" %>
<% content_for :head do %>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  html, body { background: #0F172A !important; overflow: hidden !important; height: 100% !important; }
  .lp-main { background: #0F172A !important; overflow: hidden !important; height: 100% !important; }
  .lp-page { padding: 0 !important; max-width: none !important; height: 100% !important; }
  .lp-alert-success, .lp-alert-error, .lp-alert { display: none !important; }
  .inv-input { display:block;width:100%;padding:11px 14px;background:#0F172A;border:1.5px solid rgba(255,255,255,0.08);border-radius:10px;font-size:15px;color:#f1f5f9;font-family:'Inter',sans-serif;box-sizing:border-box;outline:none;transition:border-color .2s; }
  .inv-input:focus { border-color:rgba(99,102,241,0.6); }
  .inv-label { display:block;font-size:10px;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:6px; }
</style>
<% end %>

<div style="height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:20px 16px;font-family:'Inter',sans-serif;overflow:hidden;">

  <div style="width:100%;max-width:420px;">

    <!-- Logo compact -->
    <div style="text-align:center;margin-bottom:20px;">
      <div style="display:inline-flex;align-items:center;gap:10px;">
        <img src="/icon.svg" width="40" height="40" alt="VOX" style="display:block;">
        <span style="font-size:28px;font-weight:800;letter-spacing:8px;color:#2D1B8B;">VOX</span>
      </div>
    </div>

    <!-- Card -->
    <div style="background:#1E293B;border-radius:20px;border:1px solid rgba(255,255,255,0.07);box-shadow:0 24px 60px rgba(0,0,0,0.5);padding:24px 24px 20px;">

      <!-- Welcome line -->
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid rgba(255,255,255,0.05);">
        <span style="font-size:22px;">👋</span>
        <div>
          <p style="margin:0;font-size:15px;font-weight:800;color:#f1f5f9;">Chào mừng, <%= @learner.name %>!</p>
          <p style="margin:0;font-size:12px;color:#64748b;">Thiết lập mật khẩu để bắt đầu học tập.</p>
        </div>
      </div>

      <% if flash[:alert] %>
        <div style="margin-bottom:14px;padding:10px 14px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2);border-radius:10px;font-size:13px;color:#f87171;">
          ⚠ <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: learner_invitation_path(token: @learner.invite_token), method: :patch, local: true, data: { turbo: false } do |f| %>
        <div style="margin-bottom:12px;">
          <label class="inv-label">Email</label>
          <input type="email" value="<%= @learner.email %>" class="inv-input" readonly style="color:#475569;">
        </div>
        <div style="margin-bottom:12px;">
          <label class="inv-label">Mật khẩu mới</label>
          <input type="password" name="password" autocomplete="new-password" placeholder="Tối thiểu 8 ký tự" class="inv-input">
        </div>
        <div style="margin-bottom:20px;">
          <label class="inv-label">Xác nhận mật khẩu</label>
          <input type="password" name="password_confirmation" autocomplete="new-password" placeholder="Nhập lại mật khẩu" class="inv-input">
        </div>
        <button type="submit"
                style="display:block;width:100%;padding:13px;background:#4F46E5;color:#fff;font-size:15px;font-weight:700;border:none;border-radius:12px;cursor:pointer;font-family:'Inter',sans-serif;">
          Bắt đầu học ngay →
        </button>
      <% end %>
    </div>

    <p style="text-align:center;font-size:11px;color:#334155;margin-top:14px;">© <%= Date.current.year %> VOX Platform</p>
  </div>
</div>
