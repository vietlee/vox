<% content_for :title, t('saved_links.page_title') %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= t('saved_links.breadcrumb') %></span>
<% end %>

<style>
/* ── Add form ── */
.sl-form { background:#fff; border-radius:16px; box-shadow:0 2px 12px rgba(0,0,0,.07); overflow:hidden; margin-bottom:20px; }
.sl-form-header { padding:14px 16px 0; display:flex; align-items:center; gap:8px; }
.sl-form-header-icon { width:30px; height:30px; background:#eef3fa; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:15px; flex-shrink:0; }
.sl-form-header-title { font-size:14px; font-weight:700; color:#1e3a5f; }

.sl-url-wrap { padding:12px 16px; position:relative; }
.sl-url-field { display:flex; align-items:center; background:#f8fafc; border:1.5px solid #e2e8f0; border-radius:10px; overflow:hidden; transition:border-color .2s,box-shadow .2s; }
.sl-url-field:focus-within { border-color:#1e3a5f; box-shadow:0 0 0 3px rgba(30,58,95,.08); background:#fff; }
.sl-url-icon { padding:0 10px 0 13px; color:#94a3b8; flex-shrink:0; display:flex; }
.sl-url-input { flex:1; border:none; background:transparent; padding:11px 0; font-size:14px; color:#1e293b; outline:none; min-width:0; }
.sl-url-input::placeholder { color:#94a3b8; }
.sl-detect-btn { margin:6px; padding:7px 14px; background:#1e3a5f; color:#fff; border:none; border-radius:7px; font-size:13px; font-weight:600; cursor:pointer; white-space:nowrap; flex-shrink:0; transition:background .15s; }
.sl-detect-btn:hover { background:#16304f; }
.sl-detect-btn:disabled { opacity:.5; cursor:default; }

.sl-detecting { display:none; align-items:center; gap:8px; font-size:13px; color:#64748b; padding:0 16px 12px; }
.sl-detecting.show { display:flex; }
.sl-spinner { width:15px; height:15px; border:2px solid #e2e8f0; border-top-color:#1e3a5f; border-radius:50%; animation:sl-spin .7s linear infinite; flex-shrink:0; }
@keyframes sl-spin { to { transform:rotate(360deg); } }

/* ── Preview / meta panel ── */
.sl-meta { display:none; border-top:1px solid #f1f5f9; }
.sl-preview-row { display:flex; gap:12px; align-items:flex-start; padding:14px 16px 12px; }
.sl-thumb-wrap { position:relative; flex-shrink:0; }
.sl-thumb { width:90px; height:64px; border-radius:8px; object-fit:cover; display:block; background:#f0f4f8; }
.sl-thumb-ph { width:90px; height:64px; border-radius:8px; background:#eef3fa; display:flex; align-items:center; justify-content:center; font-size:28px; }
.sl-type-badge { position:absolute; bottom:4px; right:4px; background:rgba(0,0,0,.55); color:#fff; font-size:9px; font-weight:700; padding:2px 5px; border-radius:4px; letter-spacing:.3px; }
.sl-preview-fields { flex:1; min-width:0; display:flex; flex-direction:column; gap:8px; }
.sl-title-input { border:1.5px solid #e2e8f0; border-radius:8px; padding:8px 10px; font-size:14px; color:#1e293b; outline:none; width:100%; box-sizing:border-box; transition:border-color .18s; background:#f8fafc; }
.sl-title-input:focus { border-color:#1e3a5f; background:#fff; }

.sl-cat-row { display:flex; gap:6px; }
.sl-cat-btn { flex:1; padding:7px 6px; border:1.5px solid #e2e8f0; border-radius:8px; background:#f8fafc; font-size:12px; font-weight:600; cursor:pointer; text-align:center; transition:all .15s; color:#475569; }
.sl-cat-btn.active.learning  { border-color:#2563eb; background:#eff6ff; color:#1d4ed8; }
.sl-cat-btn.active.entertainment { border-color:#db2777; background:#fdf2f8; color:#be185d; }

.sl-save-row { padding:0 16px 16px; }
.sl-save-btn { width:100%; padding:12px; background:#1e3a5f; color:#fff; border:none; border-radius:10px; font-size:14px; font-weight:700; cursor:pointer; transition:background .15s; letter-spacing:.2px; }
.sl-save-btn:hover { background:#16304f; }
.sl-save-btn:disabled { opacity:.5; cursor:default; }

/* ── List ── */
.sl-list-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:10px; }
.sl-list-count { font-size:12px; color:#94a3b8; font-weight:500; }
.sl-list { display:flex; flex-direction:column; gap:8px; }

.sl-item { background:#fff; border-radius:14px; box-shadow:0 1px 4px rgba(0,0,0,.06); display:flex; align-items:stretch; overflow:hidden; cursor:grab; user-select:none; transition:box-shadow .15s,opacity .15s,transform .1s; border:1px solid #f1f5f9; }
.sl-item:hover { box-shadow:0 3px 10px rgba(0,0,0,.09); }
.sl-item.dragging { opacity:.4; box-shadow:0 6px 20px rgba(0,0,0,.14); transform:scale(1.01); }
.sl-item.drag-over { box-shadow:0 0 0 2px #1e3a5f; }

.sl-handle { display:flex; align-items:center; padding:0 6px 0 10px; color:#d1d5db; cursor:grab; flex-shrink:0; }
.sl-handle svg { width:14px; height:14px; }

/* Thumbnail column for embeddable items */
.sl-item-thumb { width:72px; flex-shrink:0; position:relative; overflow:hidden; background:#f0f4f8; }
.sl-item-thumb img { width:100%; height:100%; object-fit:cover; display:block; }
.sl-item-thumb-ph { width:72px; height:100%; display:flex; align-items:center; justify-content:center; font-size:22px; min-height:56px; }
.sl-item-play-overlay { position:absolute; inset:0; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,.3); opacity:0; transition:opacity .15s; }
.sl-item-thumb:hover .sl-item-play-overlay { opacity:1; }
.sl-play-circle { width:28px; height:28px; background:#fff; border-radius:50%; display:flex; align-items:center; justify-content:center; }
.sl-play-circle svg { width:12px; height:12px; color:#1e3a5f; margin-left:2px; }

.sl-item-body { flex:1; min-width:0; padding:10px 10px 10px 8px; display:flex; flex-direction:column; justify-content:center; gap:3px; }
.sl-item-title { font-size:13px; font-weight:700; color:#1e293b; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; line-height:1.3; }
.sl-item-domain { font-size:11px; color:#94a3b8; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.sl-item-pills { display:flex; align-items:center; gap:5px; margin-top:2px; }
.sl-cat-pill { font-size:10px; font-weight:600; padding:2px 7px; border-radius:10px; }
.sl-cat-pill.learning { background:#eff6ff; color:#2563eb; }
.sl-cat-pill.entertainment { background:#fdf2f8; color:#db2777; }
.sl-type-pill { font-size:10px; font-weight:600; padding:2px 6px; border-radius:10px; background:#f1f5f9; color:#64748b; }

.sl-item-actions { display:flex; flex-direction:column; justify-content:center; align-items:center; gap:4px; padding:8px 10px 8px 4px; flex-shrink:0; }
.sl-icon-btn { border:none; border-radius:8px; cursor:pointer; display:flex; align-items:center; justify-content:center; transition:background .12s; flex-shrink:0; }
.sl-play-btn  { width:40px; height:40px; background:#dcfce7; color:#15803d; }
.sl-play-btn svg { width:20px; height:20px; }
.sl-play-btn:hover  { background:#bbf7d0; }
.sl-detail-btn { width:26px; height:26px; background:#e0f2fe; color:#0369a1; }
.sl-detail-btn svg { width:13px; height:13px; }
.sl-detail-btn:hover { background:#bae6fd; }
.sl-del-btn   { width:26px; height:26px; background:#fee2e2; color:#dc2626; }
.sl-del-btn svg { width:13px; height:13px; }
.sl-del-btn:hover   { background:#fecaca; }

/* ── Empty state ── */
.sl-empty { text-align:center; padding:48px 20px; background:#fff; border-radius:14px; border:1.5px dashed #e2e8f0; }
.sl-empty-icon { font-size:44px; margin-bottom:10px; line-height:1; }
.sl-empty-title { font-size:15px; font-weight:700; color:#1e293b; margin-bottom:4px; }
.sl-empty-sub { font-size:13px; color:#94a3b8; }
</style>

<div style="padding-bottom:28px;">

  <%# ── Add form ── %>
  <div class="sl-form">
    <div class="sl-form-header">
      <div class="sl-form-header-icon">🔖</div>
      <span class="sl-form-header-title"><%= t('saved_links.add_title') %></span>
    </div>
    <div class="sl-url-wrap">
      <div class="sl-url-field">
        <span class="sl-url-icon">
          <svg width="15" height="15" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
        </span>
        <input id="sl-url" class="sl-url-input" type="url" placeholder="<%= t('saved_links.url_placeholder') %>" autocomplete="off" />
        <button class="sl-detect-btn" id="sl-detect-btn" onclick="slDetect()"><%= t('saved_links.detect_btn') %></button>
      </div>
    </div>

    <div class="sl-detecting" id="sl-detecting">
      <div class="sl-spinner"></div> <%= t('saved_links.detecting') %>
    </div>

    <div class="sl-meta" id="sl-meta">
      <div class="sl-preview-row">
        <div class="sl-thumb-wrap">
          <div class="sl-thumb-ph" id="sl-thumb-ph">🔗</div>
          <img id="sl-thumb-img" class="sl-thumb" style="display:none;" alt="" />
          <span class="sl-type-badge" id="sl-type-badge"></span>
        </div>
        <div class="sl-preview-fields">
          <input id="sl-title" class="sl-title-input" type="text" placeholder="<%= t('saved_links.title_placeholder') %>" />
          <div class="sl-cat-row">
            <button class="sl-cat-btn active learning" id="sl-cat-learning" onclick="slSetCat('learning')"><%= t('saved_links.cat_learning') %></button>
            <button class="sl-cat-btn entertainment" id="sl-cat-entertainment" onclick="slSetCat('entertainment')"><%= t('saved_links.cat_entertainment') %></button>
          </div>
        </div>
      </div>
      <div class="sl-save-row">
        <button class="sl-save-btn" id="sl-save-btn" onclick="slSave()"><%= t('saved_links.save_btn') %></button>
      </div>
    </div>
  </div>

  <%# ── List ── %>
  <div class="sl-list-header">
    <span class="lp-section-title"><%= t('saved_links.section_saved') %></span>
    <span class="sl-list-count" id="sl-count"><%= @links.size %> link</span>
  </div>

  <div class="sl-list" id="sl-list">
    <% if @links.empty? %>
      <div class="sl-empty" id="sl-empty">
        <div class="sl-empty-icon">🔖</div>
        <div class="sl-empty-title"><%= t('saved_links.empty_title') %></div>
        <div class="sl-empty-sub"><%= t('saved_links.empty_sub') %></div>
      </div>
    <% else %>
      <% @links.each do |link| %>
        <%= render partial: 'learner/saved_links/item', locals: { link: link } %>
      <% end %>
    <% end %>
  </div>
</div>

<script>
(function() {
  var DETECT_URL  = '<%= detect_learner_saved_links_path %>';
  var CREATE_URL  = '<%= learner_saved_links_path %>';
  var REORDER_URL = '<%= reorder_learner_saved_links_path %>';
  var csrf = function() { return document.querySelector('meta[name=csrf-token]')?.content || ''; };

  var I18N = {
    catLearning:     '<%= j t("saved_links.cat_learning") %>',
    catEntertainment:'<%= j t("saved_links.cat_entertainment") %>',
    saving:          '<%= j t("saved_links.saving") %>',
    saveBtn:         '<%= j t("saved_links.save_btn") %>',
    toastSaved:      '<%= j t("saved_links.toast_saved") %>',
    toastUrlRequired:'<%= j t("saved_links.toast_url_required") %>',
    toastDetectError:'<%= j t("saved_links.toast_detect_error") %>',
    toastSaveError:  '<%= j t("saved_links.toast_save_error") %>',
    deleteTitle:     '<%= j t("saved_links.delete_title") %>',
    deleteMessage:   '<%= j t("saved_links.delete_message") %>',
    btnPlay:         '<%= j t("saved_links.btn_play") %>',
    btnDetail:       '<%= j t("saved_links.btn_detail") %>',
    btnDelete:       '<%= j t("saved_links.btn_delete") %>'
  };

  var _detected = {};
  var _cat = 'learning';

  var TYPE_LABELS = { youtube:'YouTube', facebook:'Facebook', vimeo:'Vimeo', tiktok:'TikTok', generic:'Web' };
  var TYPE_ICONS  = { youtube:'▶️', facebook:'📘', vimeo:'🎬', tiktok:'🎵', generic:'🔗' };

  window.slSetCat = function(c) {
    _cat = c;
    document.getElementById('sl-cat-learning').classList.toggle('active', c === 'learning');
    document.getElementById('sl-cat-entertainment').classList.toggle('active', c === 'entertainment');
  };

  window.slDetect = function() {
    var url = document.getElementById('sl-url').value.trim();
    if (!url) { showLpToast(I18N.toastUrlRequired, 'error'); return; }
    if (!/^https?:\/\//i.test(url)) url = 'https://' + url;
    document.getElementById('sl-url').value = url;

    var btn = document.getElementById('sl-detect-btn');
    btn.disabled = true;
    document.getElementById('sl-detecting').classList.add('show');
    document.getElementById('sl-meta').style.display = 'none';

    var fd = new FormData();
    fd.append('url', url);
    fd.append('authenticity_token', csrf());

    fetch(DETECT_URL, { method:'POST', body:fd })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        _detected = d;
        _detected.url = url;
        document.getElementById('sl-title').value = d.title || '';

        var img = document.getElementById('sl-thumb-img');
        var ph  = document.getElementById('sl-thumb-ph');
        if (d.thumbnail) {
          img.src = d.thumbnail;
          img.style.display = 'block';
          ph.style.display = 'none';
        } else {
          img.style.display = 'none';
          ph.style.display = 'flex';
          ph.textContent = TYPE_ICONS[d.link_type] || '🔗';
        }
        var badge = document.getElementById('sl-type-badge');
        badge.textContent = TYPE_LABELS[d.link_type] || 'Web';
        badge.style.display = d.link_type !== 'generic' ? 'block' : 'none';

        document.getElementById('sl-meta').style.display = 'block';
      })
      .catch(function() { showLpToast(I18N.toastDetectError, 'error'); })
      .finally(function() {
        btn.disabled = false;
        document.getElementById('sl-detecting').classList.remove('show');
      });
  };

  window.slSave = function() {
    var url = _detected.url || document.getElementById('sl-url').value.trim();
    if (!url) { showLpToast(I18N.toastUrlRequired, 'error'); return; }
    var title = document.getElementById('sl-title').value.trim() || url;

    var btn = document.getElementById('sl-save-btn');
    btn.disabled = true;
    btn.textContent = I18N.saving;

    var fd = new FormData();
    fd.append('authenticity_token', csrf());
    fd.append('saved_link[url]', url);
    fd.append('saved_link[title]', title);
    fd.append('saved_link[category]', _cat);
    fd.append('saved_link[link_type]', _detected.link_type || 'generic');
    if (_detected.thumbnail)   fd.append('saved_link[thumbnail]',   _detected.thumbnail);
    if (_detected.favicon)     fd.append('saved_link[favicon]',     _detected.favicon);
    if (_detected.description) fd.append('saved_link[description]', _detected.description);

    fetch(CREATE_URL, { method:'POST', body:fd })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.success) {
          prependCard(d.link);
          document.getElementById('sl-url').value  = '';
          document.getElementById('sl-title').value = '';
          document.getElementById('sl-meta').style.display = 'none';
          document.getElementById('sl-thumb-img').style.display = 'none';
          document.getElementById('sl-thumb-ph').style.display  = 'flex';
          _detected = {};
          showLpToast(I18N.toastSaved, 'success');
          updateCount(1);
        } else {
          showLpToast((d.errors || [I18N.toastSaveError]).join(', '), 'error');
        }
      })
      .catch(function() { showLpToast(I18N.toastSaveError, 'error'); })
      .finally(function() { btn.disabled = false; btn.textContent = I18N.saveBtn; });
  };

  window.slDelete = function(id) {
    lpDeleteConfirm('/learner/saved_links/' + id, I18N.deleteTitle, I18N.deleteMessage, function() {
      var el = document.querySelector('[data-link-id="' + id + '"]');
      if (el) { el.style.opacity = '0'; el.style.transform = 'scale(.96)'; el.style.transition = 'all .2s'; setTimeout(function() { el.remove(); updateCount(-1); }, 200); }
    });
  };

  window.slPlay   = function(url) { window.open(url, '_blank', 'noopener'); };
  window.slDetail = function(id)  { window.location.href = '/learner/saved_links/' + id; };

  function updateCount(delta) {
    var el = document.getElementById('sl-count');
    var n = (parseInt(el.textContent) || 0) + delta;
    el.textContent = n + ' link';
    var empty = document.getElementById('sl-empty');
    if (empty) empty.style.display = n > 0 ? 'none' : 'block';
  }

  function domainOf(url) {
    try { return new URL(url).hostname.replace(/^www\./, ''); } catch(e) { return url; }
  }

  function prependCard(link) {
    var list  = document.getElementById('sl-list');
    var empty = document.getElementById('sl-empty');
    if (empty) empty.style.display = 'none';
    var div = document.createElement('div');
    div.innerHTML = buildCardHtml(link);
    var card = div.firstElementChild;
    list.insertBefore(card, list.firstChild);
    initDrag(card);
  }

  function buildCardHtml(link) {
    var hasThumb = !!link.thumbnail;
    var typeLabel = TYPE_LABELS[link.link_type] || 'Web';
    var typeIcon  = TYPE_ICONS[link.link_type]  || '🔗';
    var catClass  = link.category === 'learning' ? 'learning' : 'entertainment';
    var catLabel  = link.category === 'learning' ? I18N.catLearning : I18N.catEntertainment;
    var playAction = link.embeddable ? 'slDetail(' + link.id + ')' : 'slPlay(\'' + escJs(link.url) + '\')';

    var thumbHtml = hasThumb
      ? '<div class="sl-item-thumb" onclick="' + playAction + '" style="cursor:pointer">' +
          '<img src="' + escHtml(link.thumbnail) + '" alt="" onerror="this.parentNode.innerHTML=\'<div class=sl-item-thumb-ph>' + typeIcon + '</div>\'">' +
          '<div class="sl-item-play-overlay"><div class="sl-play-circle"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg></div></div>' +
        '</div>'
      : '<div class="sl-item-thumb-ph" style="width:72px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:22px;background:#f0f4f8;">' + typeIcon + '</div>';

    return '<div class="sl-item" draggable="true" data-link-id="' + link.id + '">' +
      '<div class="sl-handle"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></div>' +
      thumbHtml +
      '<div class="sl-item-body">' +
        '<div class="sl-item-title">' + escHtml(link.title || link.url) + '</div>' +
        '<div class="sl-item-domain">' + escHtml(domainOf(link.url)) + '</div>' +
        '<div class="sl-item-pills">' +
          '<span class="sl-cat-pill ' + catClass + '">' + catLabel + '</span>' +
          (link.link_type !== 'generic' ? '<span class="sl-type-pill">' + typeLabel + '</span>' : '') +
        '</div>' +
      '</div>' +
      '<div class="sl-item-actions">' +
        '<button class="sl-icon-btn sl-play-btn" onclick="' + playAction + '" title="' + escHtml(I18N.btnPlay) + '"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg></button>' +
        '<button class="sl-icon-btn sl-detail-btn" onclick="slDetail(' + link.id + ')" title="' + escHtml(I18N.btnDetail) + '"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg></button>' +
        '<button class="sl-icon-btn sl-del-btn" onclick="slDelete(' + link.id + ')" title="' + escHtml(I18N.btnDelete) + '"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button>' +
      '</div>' +
    '</div>';
  }

  function escHtml(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function escJs(s)   { return (s||'').replace(/\\/g,'\\\\').replace(/'/g,"\\'"); }

  /* ── Drag & drop ── */
  var _dragged = null;
  function initDrag(el) {
    el.addEventListener('dragstart', function(e) {
      _dragged = el;
      setTimeout(function() { el.classList.add('dragging'); }, 0);
      e.dataTransfer.effectAllowed = 'move';
    });
    el.addEventListener('dragend', function() {
      el.classList.remove('dragging');
      document.querySelectorAll('.sl-item').forEach(function(i) { i.classList.remove('drag-over'); });
      saveOrder();
    });
    el.addEventListener('dragover', function(e) {
      e.preventDefault();
      if (!_dragged || _dragged === el) return;
      document.querySelectorAll('.sl-item').forEach(function(i) { i.classList.remove('drag-over'); });
      el.classList.add('drag-over');
      var list = el.parentNode;
      var items = Array.from(list.querySelectorAll('.sl-item'));
      if (items.indexOf(_dragged) < items.indexOf(el)) list.insertBefore(_dragged, el.nextSibling);
      else list.insertBefore(_dragged, el);
    });
    el.addEventListener('dragleave', function() { el.classList.remove('drag-over'); });
    el.addEventListener('drop', function(e) { e.preventDefault(); });
  }

  function saveOrder() {
    var ids = Array.from(document.querySelectorAll('.sl-item[data-link-id]')).map(function(el) { return el.dataset.linkId; });
    var fd = new FormData();
    fd.append('authenticity_token', csrf());
    ids.forEach(function(id) { fd.append('ids[]', id); });
    fetch(REORDER_URL, { method:'POST', body:fd }).catch(function() {});
  }

  document.querySelectorAll('.sl-item').forEach(initDrag);

  /* Auto-detect on paste */
  document.getElementById('sl-url').addEventListener('paste', function() { setTimeout(slDetect, 80); });
})();
</script>
