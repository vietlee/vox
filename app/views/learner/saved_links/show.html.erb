<% content_for :title, (@link.title.presence || "Link") %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <a href="<%= learner_saved_links_path %>" class="lp-bc-link">Link đã lưu</a>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current"><%= @link.title.presence || "Chi tiết" %></span>
<% end %>

<style>
  .sl-show-wrap { display:flex; flex-direction:column; gap:16px; padding-bottom:24px; }
  .sl-player-card { background:#000; border-radius:12px; overflow:hidden; position:relative; }
  .sl-player-card iframe { width:100%; height:0; padding-bottom:56.25%; border:none; display:block; }
  .sl-player-card iframe { position:absolute; top:0; left:0; width:100%; height:100%; }
  .sl-iframe-wrap { position:relative; width:100%; padding-bottom:56.25%; border-radius:12px; overflow:hidden; background:#000; }
  .sl-generic-frame { width:100%; height:60vh; border:none; border-radius:12px; box-shadow:0 2px 8px rgba(0,0,0,.1); }

  .sl-info-card { background:#fff; border-radius:12px; box-shadow:0 1px 6px rgba(0,0,0,.07); padding:16px; }
  .sl-info-title { font-size:17px; font-weight:700; color:#1e293b; line-height:1.4; margin-bottom:6px; }
  .sl-info-url { font-size:12px; color:#94a3b8; word-break:break-all; margin-bottom:10px; }
  .sl-info-desc { font-size:13px; color:#475569; line-height:1.6; }
  .sl-info-meta { display:flex; gap:8px; align-items:center; margin-bottom:12px; flex-wrap:wrap; }
  .sl-type-pill { font-size:11px; font-weight:600; padding:3px 9px; border-radius:10px; background:#f1f5f9; color:#475569; }
  .sl-cat-pill { font-size:11px; font-weight:600; padding:3px 9px; border-radius:10px; }
  .sl-cat-pill.learning { background:#dbeafe; color:#1d4ed8; }
  .sl-cat-pill.entertainment { background:#fce7f3; color:#be185d; }

  .sl-open-btn { display:flex; align-items:center; justify-content:center; gap:8px; width:100%; padding:13px; background:#1e3a5f; color:#fff; border:none; border-radius:10px; font-size:15px; font-weight:600; cursor:pointer; text-decoration:none; margin-top:10px; }
  .sl-open-btn:hover { background:#16304f; }
  .sl-fb-notice { background:#e0f2fe; border-radius:10px; padding:14px; font-size:13px; color:#0369a1; text-align:center; line-height:1.6; }
</style>

<div class="sl-show-wrap">
  <% if @link.embeddable? %>
    <%# YouTube / Vimeo embed %>
    <div class="sl-iframe-wrap">
      <iframe src="<%= @link.embed_url %>"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen loading="lazy"></iframe>
    </div>
  <% elsif @link.link_type == 'facebook' %>
    <%# Facebook embed via oEmbed page approach %>
    <div class="sl-fb-notice">
      <div style="font-size:28px;margin-bottom:8px;">📘</div>
      <strong>Video Facebook</strong><br>
      Facebook không cho phép nhúng trực tiếp.<br>
      Nhấn nút bên dưới để mở trong tab mới.
    </div>
  <% elsif @link.link_type == 'tiktok' %>
    <div class="sl-fb-notice" style="background:#fff0f3;color:#be185d;">
      <div style="font-size:28px;margin-bottom:8px;">🎵</div>
      <strong>Video TikTok</strong><br>
      TikTok không hỗ trợ nhúng trực tiếp.<br>
      Nhấn nút bên dưới để mở trong tab mới.
    </div>
  <% else %>
    <%# Generic — try to iframe it %>
    <iframe class="sl-generic-frame"
            src="<%= @link.url %>"
            sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
            loading="lazy"
            title="<%= h(@link.title || @link.url) %>"
            onerror="this.style.display='none';document.getElementById('sl-iframe-fallback').style.display='block'">
    </iframe>
    <div id="sl-iframe-fallback" style="display:none;background:#f8fafc;border-radius:12px;padding:32px;text-align:center;color:#64748b;font-size:14px;">
      Trang này không cho phép nhúng trực tiếp.<br>Nhấn nút bên dưới để mở.
    </div>
  <% end %>

  <%# Info card %>
  <div class="sl-info-card">
    <div class="sl-info-meta">
      <span class="sl-type-pill"><%= { 'youtube' => '▶ YouTube', 'facebook' => '📘 Facebook', 'vimeo' => '🎬 Vimeo', 'tiktok' => '🎵 TikTok', 'generic' => '🔗 Web' }[@link.link_type] || '🔗 Web' %></span>
      <span class="sl-cat-pill <%= @link.category %>"><%= @link.category == 'learning' ? '📚 Học tập' : '🎬 Giải trí' %></span>
    </div>

    <div class="sl-info-title"><%= @link.title.presence || @link.url %></div>
    <div class="sl-info-url"><%= @link.url %></div>
    <% if @link.description.present? %>
      <div class="sl-info-desc"><%= @link.description %></div>
    <% end %>

    <a href="<%= @link.url %>" target="_blank" rel="noopener noreferrer" class="sl-open-btn">
      🔗 Mở link gốc
    </a>
  </div>
</div>
