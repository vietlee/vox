<% content_for :title, "Speech to Text" %>
<% content_for :breadcrumb do %>
  <span class="lp-bc-sep">›</span>
  <span class="lp-bc-current">Speech to Text</span>
<% end %>

<!-- Header -->
<div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
  <%= link_to learner_root_path, style:"display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:10px;background:#f1f5f9;color:#64748b;text-decoration:none;flex-shrink:0;" do %>
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
  <% end %>
  <div style="width:36px;height:36px;border-radius:10px;background:#fdf4ff;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;">🎙️</div>
  <div>
    <h1 style="font-size:16px;font-weight:700;color:#0f172a;margin:0;">Speech to Text</h1>
    <p style="font-size:12px;color:#64748b;margin:0;"><%= t('learner_stt.subtitle_full') %></p>
  </div>
</div>

<% if @has_stt %>

<!-- ===== Mode toggle: Transcription vs Translation ===== -->
<div style="background:#e8edf3;border-radius:14px;padding:4px;display:flex;gap:0;margin-bottom:14px;position:relative;">
  <button id="stt-mode-transcribe" onclick="setSttMode('transcribe')"
          style="flex:1;padding:10px 8px;border:none;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;background:#1e3a5f;color:#fff;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:5px;box-shadow:0 2px 8px rgba(30,58,95,.25);">
    📝 <%= t('learner_stt.mode_transcribe') %>
  </button>
  <button id="stt-mode-translate" onclick="setSttMode('translate')"
          style="flex:1;padding:10px 8px;border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;background:transparent;color:#1e3a5f;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:5px;position:relative;">
    🌐 <%= t('learner_stt.mode_translate') %>
    <span style="position:absolute;top:-5px;right:8px;background:#7c3aed;color:#fff;font-size:9px;font-weight:800;padding:1px 6px;border-radius:99px;letter-spacing:.3px;white-space:nowrap;">AI</span>
  </button>
</div>

<!-- Translation target (hidden in transcription mode) -->
<div id="stt-translate-opts" style="display:none;margin-bottom:14px;">
  <div style="background:#fff;border:1px solid #e2e8f0;border-radius:12px;padding:12px 14px;">
    <p style="font-size:12px;font-weight:700;color:#374151;margin:0 0 8px;"><%= t('learner_stt.translate_to') %></p>
    <div style="display:flex;gap:6px;flex-wrap:wrap;" id="stt-lang-btns">
      <% [
        ['vi','🇻🇳 Tiếng Việt','Vietnamese'],
        ['en','🇬🇧 English','English'],
        ['ja','🇯🇵 日本語','Japanese'],
        ['ko','🇰🇷 한국어','Korean'],
        ['zh','🇨🇳 中文','Chinese'],
        ['fr','🇫🇷 Français','French'],
        ['es','🇪🇸 Español','Spanish'],
      ].each do |code, label, name| %>
        <button onclick="setTranslateLang('<%= code %>','<%= name %>')"
                data-lang="<%= code %>" data-name="<%= name %>"
                style="padding:6px 12px;border-radius:20px;border:1.5px solid #e2e8f0;background:#f8fafc;font-size:12px;font-weight:600;color:#475569;cursor:pointer;transition:all .15s;">
          <%= label %>
        </button>
      <% end %>
    </div>
    <p style="font-size:11px;color:#94a3b8;margin:8px 0 0;"><%= t('learner_stt.translate_cost') %></p>
  </div>
</div>

<!-- ===== Input tabs: Mic / File ===== -->
<div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;overflow:hidden;margin-bottom:12px;">
  <div style="display:flex;border-bottom:1px solid #f0f4f8;">
    <button id="stt-tab-mic" onclick="setSttTab('mic')"
            style="flex:1;padding:10px;font-size:13px;font-weight:600;border:none;cursor:pointer;background:#fff;color:#1e3a5f;border-bottom:2px solid #1e3a5f;transition:all .15s;">
      🎤 <%= t('learner_stt.tab_mic') %>
    </button>
    <button id="stt-tab-file" onclick="setSttTab('file')"
            style="flex:1;padding:10px;font-size:13px;font-weight:600;border:none;cursor:pointer;background:#fff;color:#94a3b8;border-bottom:2px solid transparent;transition:all .15s;">
      📁 <%= t('learner_stt.tab_file') %>
    </button>
  </div>

  <!-- ── Mic panel ── -->
  <div id="stt-panel-mic" style="padding:20px;text-align:center;">

    <!-- Source language hint for mic -->
    <div style="display:flex;justify-content:center;margin-bottom:16px;">
      <select id="stt-src-lang" style="padding:6px 12px;border:1.5px solid #e2e8f0;border-radius:20px;font-size:12px;font-weight:600;color:#475569;background:#f8fafc;outline:none;cursor:pointer;">
        <option value="">🌍 <%= t('learner_stt.auto_detect') %></option>
        <option value="vi-VN">🇻🇳 Tiếng Việt</option>
        <option value="en-US">🇬🇧 English</option>
        <option value="ja-JP">🇯🇵 日本語</option>
        <option value="ko-KR">🇰🇷 한국어</option>
        <option value="zh-CN">🇨🇳 中文</option>
        <option value="fr-FR">🇫🇷 Français</option>
      </select>
    </div>

    <!-- Orb -->
    <div id="stt-orb" onclick="sttToggleMic()"
         style="width:80px;height:80px;border-radius:50%;background:#f1f5f9;border:2px solid #e2e8f0;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;cursor:pointer;transition:all .25s;user-select:none;">
      <svg id="stt-orb-icon" width="32" height="32" fill="none" stroke="#64748b" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
      </svg>
    </div>
    <p id="stt-orb-status" style="font-size:13px;font-weight:700;color:#64748b;margin:0 0 3px;"><%= t('learner_stt.mic_hint') %></p>
    <p style="font-size:11px;color:#94a3b8;margin:0;"><%= t('learner_stt.realtime_free') %></p>

    <!-- Waveform bars -->
    <div id="stt-wave" style="display:none;justify-content:center;gap:2px;align-items:flex-end;height:28px;margin:12px 0 0;">
      <% 14.times do |i| %>
        <div style="width:3px;background:#ef4444;border-radius:99px;height:8px;animation:lp-wave <%= 0.7+(i%4)*0.15 %>s ease-in-out infinite alternate <%= (i*0.06).round(2) %>s;"></div>
      <% end %>
    </div>
  </div>

  <!-- ── File panel ── -->
  <div id="stt-panel-file" style="display:none;padding:20px;">
    <label for="stt-file-input" id="stt-file-drop"
           style="display:block;border:2px dashed #e2e8f0;border-radius:12px;padding:28px;text-align:center;cursor:pointer;transition:border-color .15s;"
           onmouseover="this.style.borderColor='#1e3a5f'" onmouseout="this.style.borderColor='#e2e8f0'">
      <div style="font-size:32px;margin-bottom:8px;">📁</div>
      <p style="font-size:13px;font-weight:700;color:#1e293b;margin:0 0 4px;"><%= t('learner_stt.file_choose_v') %></p>
      <p style="font-size:11px;color:#94a3b8;margin:0;"><%= t('learner_stt.file_note') %></p>
      <input id="stt-file-input" type="file" accept="audio/*,video/*" style="display:none;" onchange="sttHandleFile(this)">
    </label>
    <div id="stt-file-name" style="display:none;margin-top:8px;padding:8px 12px;background:#f1f5f9;border-radius:8px;font-size:12px;color:#475569;"></div>
    <button id="stt-file-btn" onclick="sttTranscribeFile()" style="display:none;width:100%;margin-top:10px;padding:11px;background:#1e3a5f;color:#fff;font-size:13px;font-weight:700;border:none;border-radius:10px;cursor:pointer;">
      ✍️ <%= t('learner_stt.convert_credit') %>
    </button>
  </div>
</div>

<!-- ===== Live transcript / result ===== -->
<div id="stt-result-area" style="display:grid;gap:10px;">

  <!-- Transcript box -->
  <div style="background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
      <p style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin:0;" id="stt-box1-label"><%= t('learner_stt.orig_text') %></p>
      <div style="display:flex;gap:6px;">
        <button onclick="sttCopy('stt-transcript-final')" style="padding:4px 10px;border-radius:6px;border:1px solid #e2e8f0;background:#f8fafc;font-size:11px;font-weight:600;color:#475569;cursor:pointer;">📋 <%= t('learner_stt.copy') %></button>
        <button onclick="sttClear()" style="padding:4px 10px;border-radius:6px;border:1px solid #e2e8f0;background:#f8fafc;font-size:11px;font-weight:600;color:#94a3b8;cursor:pointer;"><%= t('learner_stt.clear') %></button>
      </div>
    </div>
    <div style="min-height:80px;padding:10px;background:#f8fafc;border-radius:8px;position:relative;">
      <span id="stt-transcript-final" style="font-size:14px;color:#1e293b;line-height:1.8;white-space:pre-wrap;"></span><span id="stt-transcript-interim" style="font-size:14px;color:#94a3b8;line-height:1.8;font-style:italic;white-space:pre-wrap;"></span>
      <p id="stt-placeholder" style="font-size:13px;color:#cbd5e1;margin:0;position:absolute;top:10px;left:10px;"><%= t('learner_stt.placeholder_live') %></p>
    </div>
  </div>

  <!-- Translation box (hidden in transcribe mode) -->
  <div id="stt-translation-box" style="display:none;background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:14px;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
      <p style="font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px;margin:0;" id="stt-box2-label"><%= t('learner_stt.translation') %></p>
      <div style="display:flex;gap:6px;align-items:center;">
        <span id="stt-translate-spinner" style="display:none;">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" style="animation:lp-spin 1s linear infinite;"><circle cx="12" cy="12" r="10" stroke="#1e3a5f" stroke-width="3" opacity=".25"/><path fill="#1e3a5f" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
        </span>
        <button onclick="sttCopy('stt-translation-text')" style="padding:4px 10px;border-radius:6px;border:1px solid #e2e8f0;background:#f8fafc;font-size:11px;font-weight:600;color:#475569;cursor:pointer;">📋 <%= t('learner_stt.copy') %></button>
      </div>
    </div>
    <div style="min-height:80px;padding:10px;background:#f5f3ff;border-radius:8px;">
      <span id="stt-translation-text" style="font-size:14px;color:#1e293b;line-height:1.8;white-space:pre-wrap;"></span>
      <span id="stt-translation-interim" style="font-size:14px;color:#94a3b8;line-height:1.8;font-style:italic;"></span>
    </div>
  </div>

  <!-- Processing for file -->
  <div id="stt-processing" style="display:none;background:#eff6ff;border:1px solid #bfdbfe;border-radius:12px;padding:12px 16px;align-items:center;gap:10px;">
    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" style="animation:lp-spin 1s linear infinite;flex-shrink:0;"><circle cx="12" cy="12" r="10" stroke="#3b82f6" stroke-width="3" opacity=".25"/><path fill="#3b82f6" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg>
    <span style="font-size:13px;color:#1d4ed8;font-weight:500;"><%= t('learner_stt.processing') %></span>
  </div>

  <div id="stt-error" style="display:none;padding:12px;background:#fff1f2;border:1px solid #fecdd3;border-radius:12px;font-size:13px;color:#be123c;"></div>
</div>

<style>
  @keyframes lp-spin  { to { transform: rotate(360deg); } }
  @keyframes lp-wave  { 0% { transform: scaleY(.3); } 100% { transform: scaleY(1); } }
</style>

<script>
(function(){
  const CSRF      = () => document.querySelector('meta[name="csrf-token"]').content;
  const STT_URL   = '<%= learner_ai_tutor_stt_path %>';
  const TRANS_URL = '<%= learner_tools_translate_path %>';
  const PUNC_URL  = '<%= learner_tools_punctuate_path %>';

  // ── State ──
  let _mode        = 'transcribe';
  let _tab         = 'mic';
  let _targetLang  = 'Vietnamese';
  let _targetCode  = 'vi';
  let _recognition = null;
  let _listening   = false;
  let _pendingFile = null;
  let _finalText     = '';   // raw accumulated final transcript
  let _lastInterim   = '';   // latest interim (in-progress) transcript
  let _committedTrans = '';  // locked translation of fully-finalized text
  let _committedUpTo  = 0;   // chars of _finalText already committed (translated + locked)
  let _transTimer  = null; // debounce timer for translation
  let _puncTimer   = null; // debounce timer for punctuation
  let _transSeq    = 0;    // sequence number — ignore stale translation responses

  // ── Mode toggle ──
  window.setSttMode = function(m) {
    if (m === _mode) return;
    _mode = m;
    // Switching modes auto-clears previous data (both directions)
    window.sttClear();
    const isTrans = m === 'translate';
    var btnTrans = document.getElementById('stt-mode-transcribe');
    var btnTl    = document.getElementById('stt-mode-translate');
    btnTrans.style.background  = isTrans ? 'transparent' : '#1e3a5f';
    btnTrans.style.color       = isTrans ? '#1e3a5f' : '#fff';
    btnTrans.style.boxShadow   = isTrans ? 'none' : '0 2px 8px rgba(30,58,95,.25)';
    btnTl.style.background     = isTrans ? '#1e3a5f' : 'transparent';
    btnTl.style.color          = isTrans ? '#fff' : '#1e3a5f';
    btnTl.style.boxShadow      = isTrans ? '0 2px 8px rgba(30,58,95,.25)' : 'none';
    document.getElementById('stt-translate-opts').style.display  = isTrans ? 'block' : 'none';
    document.getElementById('stt-translation-box').style.display = isTrans ? 'block' : 'none';
    document.getElementById('stt-box1-label').textContent        = isTrans ? '<%= j t('learner_stt.orig_text') %>' : '<%= j t('learner_stt.result') %>';
  };

  // ── Target language ──
  window.setTranslateLang = function(code, name) {
    _targetCode = code; _targetLang = name;
    // Reset so full text is re-translated in new language
    _committedTrans = ''; _committedUpTo = 0;
    document.getElementById('stt-translation-text').textContent = '';
    document.querySelectorAll('#stt-lang-btns button').forEach(function(b) {
      var active = b.dataset.lang === code;
      b.style.background  = active ? '#1e3a5f' : '#f8fafc';
      b.style.color       = active ? '#fff' : '#475569';
      b.style.borderColor = active ? '#1e3a5f' : '#e2e8f0';
    });
    document.getElementById('stt-box2-label').textContent = '<%= j t('learner_stt.translation') %> (' + name + ')';
    if (_finalText.trim()) scheduleTranslation();
  };
  setTranslateLang('vi', 'Vietnamese');

  // ── Tab toggle ──
  window.setSttTab = function(tab) {
    _tab = tab;
    const isMic = tab === 'mic';
    document.getElementById('stt-panel-mic').style.display  = isMic ? 'block' : 'none';
    document.getElementById('stt-panel-file').style.display = isMic ? 'none'  : 'block';
    document.getElementById('stt-tab-mic').style.color      = isMic ? '#1e3a5f' : '#94a3b8';
    document.getElementById('stt-tab-mic').style.borderBottomColor  = isMic ? '#1e3a5f' : 'transparent';
    document.getElementById('stt-tab-file').style.color     = isMic ? '#94a3b8' : '#1e3a5f';
    document.getElementById('stt-tab-file').style.borderBottomColor = isMic ? 'transparent' : '#1e3a5f';
    if (!isMic && _listening) stopRecognition();
  };

  // ── Web Speech API ──
  const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;

  window.sttToggleMic = function() { _listening ? stopRecognition() : startRecognition(); };

  async function startRecognition() {
    hideError();

    // Explicitly request mic permission first — required on PWA / iOS Safari
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      stream.getTracks().forEach(function(t) { t.stop(); });
    } catch(e) {
      showError('Không có quyền truy cập microphone. Vui lòng cho phép trong cài đặt trình duyệt.');
      return;
    }

    if (!SpeechRecognition) {
      showError('Trình duyệt không hỗ trợ nhận giọng nói realtime. Hãy dùng Chrome hoặc Safari, hoặc chuyển sang tab File để tải lên âm thanh.');
      return;
    }

    try {
      _recognition = new SpeechRecognition();
      _recognition.continuous     = true;
      _recognition.interimResults = true;
      _recognition.lang = document.getElementById('stt-src-lang').value || 'vi-VN';

      _recognition.onstart = function() { _listening = true; setOrbUI(true); };

      _recognition.onresult = function(e) {
        var interim = '';
        var gotFinal = false;
        for (var i = e.resultIndex; i < e.results.length; i++) {
          var t = e.results[i][0].transcript;
          if (e.results[i].isFinal) {
            // Each finalized chunk on its own line; punctuation added server-side later
            _finalText += (_finalText ? '\n' : '') + t.trim();
            gotFinal = true;
          } else {
            interim += t;
          }
        }

        _lastInterim = interim;
        updateTranscript(_finalText, interim);

        // Translation: fire on EVERY result (interim + final) for true realtime —
        // translates only the untranslated tail (current sentence), so each request
        // is short → fast. Interim previews are free; only finalized text costs credit.
        if (_mode === 'translate') {
          scheduleTranslation();
        }

        // Punctuation: only in transcribe mode. (In translate mode it would rewrite
        // _finalText and desync the translation's char-offset tracker.)
        if (gotFinal && _mode === 'transcribe') schedulePunctuation();
      };

      _recognition.onerror = function(e) {
        if (e.error === 'not-allowed') {
          showError('Microphone bị từ chối. Vui lòng cấp quyền trong cài đặt trình duyệt.');
          _listening = false; setOrbUI(false);
        } else if (e.error === 'no-speech') {
          // normal — user paused
        } else if (e.error !== 'aborted') {
          showError('Lỗi nhận dạng giọng nói: ' + e.error);
        }
      };

      _recognition.onend = function() {
        // Auto-restart for continuous recording; 200ms delay avoids InvalidStateError on PWA.
        if (_listening) {
          setTimeout(function() {
            if (_listening && _recognition) {
              try { _recognition.start(); } catch(ex) {}
            }
          }, 200);
        }
      };

      _recognition.start();
    } catch(ex) {
      showError('Không thể khởi động microphone: ' + ex.message);
    }
  }

  function stopRecognition() {
    _listening = false;
    setOrbUI(false);
    if (_recognition) {
      _recognition.onend = null;
      try { _recognition.stop(); } catch(e) {}
      _recognition = null;
    }
    // Final punctuation pass when user stops recording (transcribe mode only)
    if (_finalText.trim() && _mode === 'transcribe') doPunctuate();
  }

  function setOrbUI(on) {
    var orb    = document.getElementById('stt-orb');
    var icon   = document.getElementById('stt-orb-icon');
    var status = document.getElementById('stt-orb-status');
    var wave   = document.getElementById('stt-wave');
    orb.style.background  = on ? '#fee2e2' : '#f1f5f9';
    orb.style.borderColor = on ? '#fca5a5' : '#e2e8f0';
    icon.setAttribute('stroke', on ? '#ef4444' : '#64748b');
    status.textContent = on ? '<%= j t('learner_stt.listening') %>' : '<%= j t('learner_stt.mic_hint') %>';
    status.style.color = on ? '#ef4444' : '#64748b';
    wave.style.display = on ? 'flex' : 'none';
  }

  function updateTranscript(final, interim) {
    document.getElementById('stt-transcript-final').textContent  = final;
    // Interim (in-progress sentence) shown on its own new line below the final text
    document.getElementById('stt-transcript-interim').textContent = interim ? (final ? '\n' : '') + interim : '';
    document.getElementById('stt-placeholder').style.display = (final || interim) ? 'none' : 'block';
  }

  // ── Realtime translation ──
  // Translates the "untranslated tail" (finalized-but-uncommitted text + current
  // interim) on every speech result. The committed part stays locked so we never
  // re-translate whole sentences. Live interim previews are free; only when a
  // sentence finalizes do we lock its translation and charge 1 credit.
  function scheduleTranslation() {
    clearTimeout(_transTimer);
    _transTimer = setTimeout(doTranslate, 250);
  }

  function doTranslate() {
    var full = (_finalText + (_lastInterim ? ' ' + _lastInterim : '')).trim();
    var tail = full.slice(_committedUpTo).trim();
    if (!tail) return;

    var isFinal        = !_lastInterim;        // no interim → this tail is finalized
    var finalLenSnap   = _finalText.length;    // commit point if finalized
    var mySeq          = ++_transSeq;
    document.getElementById('stt-translate-spinner').style.display = 'inline';

    var fd = new FormData();
    fd.append('text', tail);
    fd.append('target_lang', _targetLang);
    fd.append('final', isFinal ? 'true' : 'false');
    fd.append('authenticity_token', CSRF());

    fetch(TRANS_URL, { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (mySeq < _transSeq) return; // stale — a newer request is in-flight
        document.getElementById('stt-translate-spinner').style.display = 'none';
        if (d.error) { showError(d.error); return; }
        var tailTrans = (d.translated || '').trim();
        // Each translated sentence on its own line, aligned with the transcript
        var sep = (_committedTrans && tailTrans) ? '\n' : '';
        document.getElementById('stt-translation-text').textContent = _committedTrans + sep + tailTrans;
        document.getElementById('stt-translation-interim').textContent = '';
        // Lock it in once the sentence is finalized
        if (isFinal) {
          _committedTrans = _committedTrans + sep + tailTrans;
          _committedUpTo  = finalLenSnap;
        }
        if (window.updateLpCredits) updateLpCredits(d.credits_remaining);
      })
      .catch(function() {
        document.getElementById('stt-translate-spinner').style.display = 'none';
      });
  }

  // ── Server-side punctuation ──
  // Fires 1.5s after last final result. Sends full raw _finalText to Claude,
  // gets properly punctuated version back, updates display in place.
  function schedulePunctuation() {
    clearTimeout(_puncTimer);
    _puncTimer = setTimeout(doPunctuate, 1500);
  }

  function doPunctuate() {
    var snapshot = _finalText.trim();
    if (!snapshot) return;

    var fd = new FormData();
    fd.append('text', snapshot);
    fd.append('authenticity_token', CSRF());

    fetch(PUNC_URL, { method: 'POST', body: fd })
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d.punctuated || d.punctuated === snapshot) return;
        // Preserve any text appended since we sent the request (on its own line)
        var extra = _finalText.slice(snapshot.length).trim();
        _finalText = d.punctuated + (extra ? '\n' + extra : '');
        document.getElementById('stt-transcript-final').textContent = _finalText;
      })
      .catch(function() {});
  }

  // ── File upload (ElevenLabs) ──
  window.sttHandleFile = function(input) {
    var file = input.files[0]; if (!file) return;
    _pendingFile = file;
    var nameEl = document.getElementById('stt-file-name');
    nameEl.style.display = 'flex';
    nameEl.style.alignItems = 'center';
    nameEl.style.gap = '5px';
    nameEl.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.8" style="flex-shrink:0"><path stroke-linecap="round" stroke-linejoin="round" d="M9 18V5l12-2v13M9 13l12-2M6 21a3 3 0 100-6 3 3 0 000 6zM18 19a3 3 0 100-6 3 3 0 000 6z"/></svg><span>' + file.name + ' (' + (file.size/1024/1024).toFixed(1) + ' MB)</span>';
    document.getElementById('stt-file-btn').style.display = 'block';
  };

  window.sttTranscribeFile = async function() {
    if (!_pendingFile) return;
    document.getElementById('stt-processing').style.display = 'flex';
    hideError();
    try {
      var fd = new FormData();
      fd.append('chunk', _pendingFile, _pendingFile.name);
      fd.append('authenticity_token', CSRF());
      var res  = await fetch(STT_URL, { method: 'POST', body: fd });
      var data = await res.json();
      if (data.error) throw new Error(data.error);
      // ElevenLabs already returns punctuated text — split each sentence onto its own line
      _finalText = (data.text || '').trim().replace(/([.!?…])\s+/g, '$1\n');
      _lastInterim = ''; _committedTrans = ''; _committedUpTo = 0;
      updateTranscript(_finalText || '<%= j t('learner_stt.no_text') %>', '');
      if (window.updateLpCredits) updateLpCredits(data.credits_remaining);
      if (_mode === 'translate' && _finalText) scheduleTranslation();
    } catch(e) { showError(e.message); }
    finally { document.getElementById('stt-processing').style.display = 'none'; }
  };

  // ── Utils ──
  window.sttCopy = function(elId) {
    var text = document.getElementById(elId).textContent;
    navigator.clipboard.writeText(text.trim()).then(function() {
      var btn = event.target;
      btn.textContent = '✅ <%= j t('learner_stt.copied') %>';
      setTimeout(function() { btn.textContent = '📋 <%= j t('learner_stt.copy') %>'; }, 1500);
    });
  };

  window.sttClear = function() {
    _finalText = ''; _lastInterim = ''; _transSeq = 0;
    _committedTrans = ''; _committedUpTo = 0;
    clearTimeout(_transTimer);
    updateTranscript('', '');
    document.getElementById('stt-translation-text').textContent = '';
    document.getElementById('stt-translation-interim').textContent = '';
  };

  function showError(msg) {
    var el = document.getElementById('stt-error');
    el.style.display = 'block'; el.textContent = '⚠️ ' + msg;
  }
  function hideError() {
    document.getElementById('stt-error').style.display = 'none';
  }
})();
</script>

<% else %>
<div style="text-align:center;padding:40px;color:#94a3b8;font-size:14px;"><%= t('learner_stt.disabled') %></div>
<% end %>
