<% content_for :title, t('learner_auth.forgot_title') %>
<% content_for :head do %>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  html, body { background: #0F172A !important; }
  .lp-main { background: #0F172A !important; overflow-y: auto !important; min-height: 100dvh !important; padding-bottom: 0 !important; }
  .lp-page { padding: 0 !important; max-width: none !important; width: 100% !important; }
  .lp-topbar, .lp-bottom-nav { display: none !important; }
  .lp-alert-success, .lp-alert-error { display: none !important; }
</style>
<% end %>

<div style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:20px 16px; font-family:'Inter',sans-serif;">

  <div style="width:100%;max-width:440px;">
    <!-- Logo + lang switcher -->
    <div style="text-align:center; margin-bottom:16px;">
      <div style="display:inline-flex; align-items:center; gap:10px; filter:drop-shadow(0 6px 18px rgba(26,107,255,0.4));">
        <img src="/icon.svg" width="36" height="36" alt="VOX" style="display:block;">
        <div style="font-size:28px; font-weight:800; letter-spacing:8px; color:#2D1B8B; line-height:1; padding-left:4px;">VOX</div>
      </div>
    </div>

    <!-- Card -->
    <div style="background:#1E293B; border-radius:20px; border:1px solid rgba(255,255,255,0.07); box-shadow:0 24px 60px rgba(0,0,0,0.5); overflow:hidden;">

      <!-- Header -->
      <div style="padding:28px 28px 24px; border-bottom:1px solid rgba(255,255,255,0.05);">
        <div style="width:46px; height:46px; background:rgba(245,158,11,0.12); border:1px solid rgba(245,158,11,0.25); border-radius:13px; display:flex; align-items:center; justify-content:center; font-size:22px; margin-bottom:16px;">🔑</div>
        <h1 style="font-size:20px; font-weight:800; color:#f1f5f9; margin:0 0 8px;"><%= t('learner_auth.forgot_title') %></h1>
        <p style="font-size:13px; color:#64748b; margin:0; line-height:1.6;"><%= t('learner_auth.forgot_subtitle') %></p>
      </div>

      <!-- Body -->
      <div style="padding:24px 28px;">

        <%# ── SUCCESS STATE ── %>
        <div id="sent-state" style="display:<%= @email_sent ? 'block' : 'none' %>; text-align:center; padding:8px 0 16px;">
          <div style="width:56px; height:56px; background:rgba(16,185,129,0.12); border:1px solid rgba(16,185,129,0.25); border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:26px; margin:0 auto 16px;">📬</div>
          <div style="font-size:15px; font-weight:700; color:#f1f5f9; margin-bottom:8px;"><%= t('learner_auth.sent_title') %></div>
          <p style="font-size:13px; color:#94a3b8; line-height:1.8; margin:0 0 20px;">
            Chúng tôi đã gửi liên kết đặt lại mật khẩu tới<br>
            <span style="color:#a5b4fc; font-weight:600;"><%= @submitted_email %></span><br>
            Hãy kiểm tra hộp thư (kể cả thư mục Spam).
          </p>
          <div>
            <span style="font-size:12px; color:#475569;"><%= t('learner_auth.not_received') %></span>
            <button type="button"
              onclick="document.getElementById('sent-state').style.display='none'; document.getElementById('form-state').style.display='block';"
              style="background:none; border:none; color:#818cf8; font-size:12px; font-weight:600; cursor:pointer; padding:0 0 0 4px; font-family:'Inter',sans-serif; text-decoration:underline;">
              Gửi lại
            </button>
          </div>
        </div>

        <%# ── FORM STATE ── %>
        <div id="form-state" style="display:<%= @email_sent ? 'none' : 'block' %>;">
          <% if resource.errors.any? %>
            <div style="margin-bottom:16px; display:flex; align-items:flex-start; gap:10px; padding:14px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); border-radius:12px; font-size:13px; color:#f87171; line-height:1.5;">
              <span>⚠</span>
              <div>
                <% resource.errors.full_messages.each do |msg| %>
                  <div>• <%= msg %></div>
                <% end %>
              </div>
            </div>
          <% end %>

          <%= form_with model: resource, as: resource_name, url: learner_password_path, method: :post, local: true, data: { turbo: false } do |f| %>
            <div style="margin-bottom:16px;">
              <label style="display:block; font-size:11px; font-weight:700; color:#475569; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;"><%= t('learner_auth.email') %></label>
              <%= f.email_field :email, autofocus: true, autocomplete: "email",
                placeholder: t('learner_auth.ph_email'),
                style: "display:block; width:100%; padding:13px 16px; background:#0F172A; border:1.5px solid rgba(255,255,255,0.08); border-radius:12px; font-size:16px; color:#f1f5f9; font-family:'Inter',sans-serif;" %>
            </div>
            <button type="submit" id="submit-btn"
              style="display:block; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:12px; cursor:pointer; font-family:'Inter',sans-serif;">
              <span id="submit-text"><%= t('learner_auth.send_reset_btn') %></span>
              <span id="submit-loading" style="display:none;"><%= t('learner_auth.sending') %></span>
            </button>
          <% end %>

          <script>
            document.getElementById('submit-btn').closest('form').addEventListener('submit', function() {
              document.getElementById('submit-text').style.display = 'none';
              document.getElementById('submit-loading').style.display = 'inline';
              document.getElementById('submit-btn').disabled = true;
              document.getElementById('submit-btn').style.opacity = '0.75';
            });
          </script>
        </div>
      </div>

      <!-- Back -->
      <div style="padding:0 28px 24px;">
        <%= link_to new_learner_session_path,
          style: "display:flex; align-items:center; justify-content:center; gap:8px; padding:13px; font-size:13px; color:#64748b; text-decoration:none; border:1.5px solid rgba(255,255,255,0.07); border-radius:12px;" do %>
          ← Quay lại đăng nhập
        <% end %>
      </div>
    </div>

    <p style="text-align:center; font-size:11px; color:#334155; margin-top:18px;">© <%= Date.current.year %> VOX Platform</p>
  </div>
</div>
