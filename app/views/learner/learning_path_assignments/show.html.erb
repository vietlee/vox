<% content_for :title, @path.title %>

<div style="background:linear-gradient(135deg,#4f46e5,#7c3aed);border-radius:20px;padding:20px;margin-bottom:20px;color:white;">
  <p style="font-size:12px;opacity:0.7;margin-bottom:4px;">Lộ trình học</p>
  <h1 style="font-size:20px;font-weight:800;"><%= @path.title %></h1>
  <% if @path.description.present? %>
    <p style="font-size:13px;opacity:0.8;margin-top:6px;"><%= @path.description.truncate(100) %></p>
  <% end %>
  <div style="margin-top:14px;">
    <div style="display:flex;justify-content:space-between;font-size:12px;opacity:0.8;margin-bottom:4px;">
      <span>Tiến độ</span>
      <span id="path-pct"><%= @assignment.progress_pct %>%</span>
    </div>
    <div style="background:rgba(255,255,255,0.25);border-radius:99px;height:8px;">
      <div id="path-bar" style="width:<%= @assignment.progress_pct %>%;height:100%;border-radius:99px;background:white;transition:width 0.4s;"></div>
    </div>
  </div>
</div>

<p class="lp-section-title">Nội dung (<%= @items.count %> mục)</p>

<% @items.each_with_index do |item, i| %>
  <% progress = @progresses[item.id] %>
  <% done = progress&.completed? %>
  <div class="lp-card" style="<%= done ? 'opacity:0.7;' : '' %>">
    <div class="lp-card-body" style="display:flex;align-items:center;gap:12px;">
      <%# Step number / checkmark %>
      <div style="width:36px;height:36px;border-radius:50%;background:<%= done ? 'linear-gradient(135deg,#10b981,#059669)' : 'linear-gradient(135deg,#e5e7eb,#d1d5db)' %>;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <% if done %>
          <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
        <% else %>
          <span style="font-size:14px;font-weight:700;color:#9ca3af;"><%= i + 1 %></span>
        <% end %>
      </div>

      <div style="flex:1;min-width:0;">
        <p style="font-weight:700;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= item.title %></p>
        <p style="font-size:12px;color:#9ca3af;margin-top:2px;">
          <%= item.item_type == "quiz" ? "📝 Quiz" : item.item_type == "flashcard" ? "🃏 Flashcard" : "📖 Bài học" %> · <%= item.estimated_minutes %> phút
        </p>
      </div>

      <% if item.item_type == "lesson" %>
        <% if done %>
          <span class="lp-badge lp-badge-done" style="flex-shrink:0;">Xong</span>
        <% else %>
          <button onclick="completeItem(<%= item.id %>, this)"
                  style="background:linear-gradient(135deg,#6366f1,#7c3aed);color:white;border:none;border-radius:10px;padding:8px 12px;font-size:12px;font-weight:700;cursor:pointer;flex-shrink:0;">
            Hoàn thành
          </button>
        <% end %>
      <% elsif item.item_type == "quiz" && item.quiz_set %>
        <%# Find learner's quiz assignment for this quiz %>
        <% qa = current_learner.quiz_assignments.find_by(quiz_set_id: item.quiz_set_id) %>
        <% if qa %>
          <%= link_to qa.completed? ? result_learner_quiz_assignment_path(qa.token) : show_learner_quiz_assignment_path(qa.token),
                class: "lp-badge", style: "flex-shrink:0;background:#{done ? '#d1fae5' : '#dbeafe'};color:#{done ? '#065f46' : '#1e40af'};text-decoration:none;" do %>
            <%= done ? "✓ Xong" : "Làm bài" %>
          <% end %>
        <% else %>
          <span class="lp-badge lp-badge-pending" style="flex-shrink:0;">Chưa giao</span>
        <% end %>
      <% elsif item.item_type == "flashcard" && item.flashcard_deck %>
        <% fa = current_learner.flashcard_assignments.find_by(flashcard_deck_id: item.flashcard_deck_id) %>
        <% if fa %>
          <%= link_to study_learner_flashcard_assignment_path(fa.token),
                class: "lp-badge", style: "flex-shrink:0;background:#{done ? '#d1fae5' : '#d1fae5'};color:#065f46;text-decoration:none;" do %>
            <%= done ? "✓ Xong" : "Học" %>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<script>
function completeItem(itemId, btn) {
  btn.disabled = true; btn.textContent = '...';
  var csrf = '<%= form_authenticity_token %>';
  fetch('<%= complete_item_learner_learning_path_assignment_path(@assignment.token) %>', {
    method: 'POST',
    headers: { 'X-CSRF-Token': csrf, 'Content-Type': 'application/json' },
    body: JSON.stringify({ item_id: itemId })
  }).then(function(r){ return r.json(); }).then(function(d){
    document.getElementById('path-pct').textContent = d.progress_pct + '%';
    document.getElementById('path-bar').style.width = d.progress_pct + '%';
    btn.closest('.lp-card').style.opacity = '0.7';
    var circle = btn.closest('.lp-card').querySelector('[style*="border-radius:50%"]');
    if (circle) { circle.style.background = 'linear-gradient(135deg,#10b981,#059669)'; circle.innerHTML = '<svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>'; }
    btn.outerHTML = '<span class="lp-badge lp-badge-done" style="flex-shrink:0;">Xong</span>';
    if (d.completed) setTimeout(function(){ window.location.reload(); }, 600);
  });
}
</script>
