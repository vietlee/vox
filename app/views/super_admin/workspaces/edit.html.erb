<div class="max-w-[500px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5"><%= t("super_admin.workspaces.edit_title") %>: <%= @workspace.name %></h1>
  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <%= form_with model: [:super_admin, @workspace], method: :patch, local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("super_admin.workspaces.company_name_label") %></label>
          <%= f.text_field :name, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div class="flex gap-2 pt-4">
          <%= f.submit t("super_admin.workspaces.save_btn"), class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= button_to reset_admin_password_super_admin_workspace_path(@workspace), method: :patch,
                class: "px-5 py-2.5 bg-amber-100 text-amber-700 text-[13px] font-semibold rounded-lg" do %>
            <%= t("super_admin.workspaces.action_reset_password") %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
