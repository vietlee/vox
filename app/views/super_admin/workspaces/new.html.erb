<div class="max-w-[500px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5"><%= t("super_admin.workspaces.create_title") %></h1>
  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <%= form_with model: [:super_admin, @workspace], local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("super_admin.workspaces.company_name_label") %></label>
          <%= f.text_field :name, required: true, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("super_admin.workspaces.admin_name_label") %></label>
          <input name="admin_name" type="text" required class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("super_admin.workspaces.admin_email_label") %></label>
          <input name="admin_email" type="email" required class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("super_admin.workspaces.plan_label") %></label>
          <select name="plan" class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none">
            <option value="free"><%= t("super_admin.workspaces.plan_free") %></option>
            <option value="pro"><%= t("super_admin.workspaces.plan_pro") %></option>
            <option value="enterprise"><%= t("super_admin.workspaces.plan_enterprise") %></option>
          </select>
        </div>
        <div class="flex gap-2 pt-4">
          <%= f.submit t("super_admin.workspaces.create_btn"), class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to t("super_admin.workspaces.cancel_btn"), super_admin_workspaces_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
