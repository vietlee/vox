<div class="max-w-[500px]">
  <h1 class="text-[19px] font-extrabold text-slate-900 mb-5">Create Workspace</h1>
  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <%= form_with model: [:super_admin, @workspace], local: true do |f| %>
      <div class="space-y-4">
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Company Name *</label>
          <%= f.text_field :name, required: true, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none" %>
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Admin Name *</label>
          <input name="admin_name" type="text" required class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Admin Email *</label>
          <input name="admin_email" type="email" required class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 outline-none">
        </div>
        <div>
          <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">Plan</label>
          <select name="plan" class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none">
            <option value="free">Free</option>
            <option value="pro">Pro</option>
            <option value="enterprise">Enterprise</option>
          </select>
        </div>
        <div class="flex gap-2 pt-4">
          <%= f.submit "Create & Send Invite", class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer" %>
          <%= link_to "Cancel", super_admin_workspaces_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
