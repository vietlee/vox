<%
  def fmt_vnd(cents)
    return "0 ₫" if cents.to_i == 0
    cents.to_i.to_s.reverse.gsub(/\d{3}(?=.)/, '\0.').reverse + " ₫"
  end
  d = "super_admin.dashboard"
%>

<h1 class="text-[21px] font-extrabold text-slate-900 mb-6"><%= t("#{d}.title") %></h1>

<!-- System stats -->
<div class="grid grid-cols-4 gap-4 mb-8">
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <div class="text-[26px] font-black text-slate-900"><%= @workspaces_count %></div>
    <div class="text-[12px] text-slate-500"><%= t("#{d}.workspaces") %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <div class="text-[26px] font-black text-slate-900"><%= @users_count %></div>
    <div class="text-[12px] text-slate-500"><%= t("#{d}.users") %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <div class="text-[26px] font-black text-slate-900"><%= @surveys_count %></div>
    <div class="text-[12px] text-slate-500"><%= t("#{d}.surveys") %></div>
  </div>
  <div class="bg-white rounded-xl border border-slate-200 p-4 text-center">
    <div class="text-[26px] font-black text-slate-900"><%= @votes_count %></div>
    <div class="text-[12px] text-slate-500"><%= t("#{d}.votes") %></div>
  </div>
</div>

<!-- Online & active users -->
<div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
  <div class="flex items-center gap-2 mb-4">
    <span class="inline-block w-2 h-2 rounded-full bg-emerald-500" style="box-shadow:0 0 0 3px rgba(16,185,129,.2)"></span>
    <h2 class="text-[13px] font-bold text-slate-700">Người dùng online & tổng hệ thống</h2>
    <span class="text-[11px] text-slate-400 ml-auto">Cập nhật mỗi 5 phút</span>
  </div>
  <div class="grid grid-cols-4 gap-4">
    <div class="rounded-xl border border-emerald-100 bg-emerald-50 p-4 text-center">
      <div class="flex items-center justify-center gap-1.5 mb-1">
        <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        <span class="text-[11px] font-semibold text-emerald-600 uppercase tracking-wide">Learner online</span>
      </div>
      <div class="text-[28px] font-black text-emerald-700"><%= @learners_online %></div>
    </div>
    <div class="rounded-xl border border-blue-100 bg-blue-50 p-4 text-center">
      <div class="flex items-center justify-center gap-1.5 mb-1">
        <span class="inline-block w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        <span class="text-[11px] font-semibold text-blue-600 uppercase tracking-wide">Trainer online</span>
      </div>
      <div class="text-[28px] font-black text-blue-700"><%= @trainers_online %></div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
      <div class="text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Tổng Learner</div>
      <div class="text-[28px] font-black text-slate-800"><%= @total_learners %></div>
    </div>
    <div class="rounded-xl border border-slate-200 bg-slate-50 p-4 text-center">
      <div class="text-[11px] font-semibold text-slate-500 uppercase tracking-wide mb-1">Tổng Trainer</div>
      <div class="text-[28px] font-black text-slate-800"><%= @total_trainers %></div>
    </div>
  </div>
</div>

<!-- ElevenLabs API Usage -->
<% if @elevenlabs %>
  <% el = @elevenlabs %>
  <% bar_color = el[:pct] >= 90 ? "from-red-500 to-red-400" : el[:pct] >= 70 ? "from-amber-500 to-amber-400" : "from-emerald-500 to-teal-400" %>
  <% text_color = el[:pct] >= 90 ? "text-red-600" : el[:pct] >= 70 ? "text-amber-600" : "text-emerald-600" %>
  <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-2">
        <span class="text-[15px]">🎙️</span>
        <h2 class="text-[13px] font-bold text-slate-700">ElevenLabs API</h2>
        <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase bg-slate-100 text-slate-500"><%= el[:tier] %></span>
      </div>
      <% if el[:next_reset] %>
        <span class="text-[11px] text-slate-400">
          Reset: <%= Time.at(el[:next_reset]).strftime("%d/%m/%Y") rescue "—" %>
        </span>
      <% end %>
    </div>

    <div class="grid grid-cols-3 gap-4 mb-3">
      <div class="text-center">
        <div class="text-[20px] font-black <%= text_color %>"><%= number_with_delimiter(el[:remaining]) %></div>
        <div class="text-[11px] text-slate-400">Chars còn lại</div>
      </div>
      <div class="text-center">
        <div class="text-[20px] font-black text-slate-700"><%= number_with_delimiter(el[:used]) %></div>
        <div class="text-[11px] text-slate-400">Đã dùng</div>
      </div>
      <div class="text-center">
        <div class="text-[20px] font-black text-slate-500"><%= number_with_delimiter(el[:limit]) %></div>
        <div class="text-[11px] text-slate-400">Giới hạn/tháng</div>
      </div>
    </div>

    <div class="h-2 bg-slate-100 rounded-full overflow-hidden">
      <div class="h-full bg-gradient-to-r <%= bar_color %> rounded-full transition-all" style="width: <%= el[:pct] %>%"></div>
    </div>
    <div class="flex justify-between mt-1">
      <span class="text-[10px] text-slate-400"><%= el[:pct] %>% đã dùng</span>
      <span class="text-[10px] <%= text_color %> font-semibold"><%= number_with_delimiter(el[:remaining]) %> chars còn lại</span>
    </div>
  </div>
<% elsif @elevenlabs_error %>
  <div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
    <div class="flex items-center gap-2 mb-2">
      <span class="text-[15px]">🎙️</span>
      <h2 class="text-[13px] font-bold text-slate-700">ElevenLabs API</h2>
    </div>
    <% if @elevenlabs_error == :no_key %>
      <p class="text-[12px] text-amber-600">⚠️ ELEVENLABS_API_KEY chưa được cấu hình.</p>
    <% else %>
      <p class="text-[12px] text-red-500 mb-1">⚠️ Không thể lấy dữ liệu usage. API key thiếu quyền <strong>user_read</strong>.</p>
      <p class="text-[11px] text-slate-400">Vào <a href="https://elevenlabs.io/app/settings/api-keys" target="_blank" class="underline text-indigo-500">ElevenLabs → API Keys</a> → tạo key mới với quyền <strong>User</strong> rồi cập nhật lại <code class="bg-slate-100 px-1 rounded">ELEVENLABS_API_KEY</code> trên server.</p>
    <% end %>
  </div>
<% end %>

<!-- Revenue section header + date filter -->
<div class="flex items-center justify-between mb-4 flex-wrap gap-3">
  <div class="flex items-center gap-2">
    <h2 class="text-[16px] font-extrabold text-slate-900">💰 <%= t("#{d}.revenue_section") %></h2>
  </div>
  <%= form_with url: super_admin_root_path, method: :get, local: true, class: "flex items-center gap-2" do |f| %>
    <div class="flex items-center gap-1.5 bg-white border border-slate-200 rounded-lg px-3 py-1.5">
      <span class="text-[11px] text-slate-400 font-semibold"><%= t("#{d}.date_from") %></span>
      <%= f.date_field :date_from, value: @date_from, class: "text-[12px] text-slate-700 border-0 outline-none bg-transparent cursor-pointer" %>
    </div>
    <div class="flex items-center gap-1.5 bg-white border border-slate-200 rounded-lg px-3 py-1.5">
      <span class="text-[11px] text-slate-400 font-semibold"><%= t("#{d}.date_to") %></span>
      <%= f.date_field :date_to, value: @date_to, class: "text-[12px] text-slate-700 border-0 outline-none bg-transparent cursor-pointer" %>
    </div>
    <%= f.submit t("#{d}.date_apply"), class: "px-3 py-1.5 bg-indigo-600 text-white text-[12px] font-semibold rounded-lg cursor-pointer border-0 hover:bg-indigo-700" %>
    <% if @date_from || @date_to %>
      <%= link_to t("#{d}.date_reset"), super_admin_root_path, class: "px-3 py-1.5 bg-slate-100 text-slate-600 text-[12px] font-semibold rounded-lg hover:bg-slate-200" %>
    <% end %>
  <% end %>
</div>

<!-- Revenue stat cards -->
<div class="grid grid-cols-4 gap-4 mb-6">
  <!-- All-time total -->
  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wide mb-1"><%= t("#{d}.revenue_total") %></div>
    <div class="text-[22px] font-black text-emerald-600"><%= fmt_vnd(@alltime_revenue) %></div>
    <div class="text-[11px] text-slate-400 mt-1"><%= t("#{d}.revenue_all_paid") %></div>
  </div>
  <!-- Period revenue -->
  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wide mb-1"><%= t("#{d}.revenue_period") %></div>
    <div class="text-[22px] font-black text-indigo-600"><%= fmt_vnd(@period_revenue) %></div>
    <div class="text-[11px] text-slate-400 mt-1">
      <% if @date_from || @date_to %>
        <%= @date_from&.strftime("%d/%m/%Y") || "..." %> – <%= @date_to&.strftime("%d/%m/%Y") || "..." %>
      <% else %>
        <%= Date.current.strftime("%B %Y") %>
      <% end %>
    </div>
  </div>
  <!-- Pending -->
  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wide mb-1"><%= t("#{d}.revenue_pending") %></div>
    <div class="text-[22px] font-black text-amber-500"><%= fmt_vnd(@pending_revenue) %></div>
    <div class="text-[11px] text-slate-400 mt-1"><%= t("#{d}.revenue_waiting") %></div>
  </div>
  <!-- Active paid subs -->
  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <div class="text-[11px] font-bold text-slate-400 uppercase tracking-wide mb-1"><%= t("#{d}.revenue_active_subs") %></div>
    <div class="text-[22px] font-black text-slate-900"><%= @active_subs %></div>
    <div class="text-[11px] text-slate-400 mt-1"><%= t("#{d}.revenue_active_subs_desc") %></div>
  </div>
</div>

<!-- Monthly chart + this month subs -->
<div class="grid grid-cols-5 gap-4 mb-6">

  <!-- Bar chart -->
  <div class="col-span-3 bg-white rounded-xl border border-slate-200 p-5">
    <h3 class="text-[13px] font-bold text-slate-700 mb-4"><%= t("#{d}.revenue_chart") %></h3>
    <%
      max_amount = [@monthly_revenue.map { |r| r[:amount] }.max.to_i, 1].max
    %>
    <div class="flex items-end gap-2 h-36">
      <% @monthly_revenue.each do |row| %>
        <%
          pct        = (row[:amount].to_f / max_amount * 100).round
          pct        = [pct, 2].max if row[:amount] > 0
          is_current = row[:label] == Date.current.strftime("%b %Y")
        %>
        <div class="flex-1 flex flex-col items-center gap-1">
          <div class="text-[9px] font-bold text-slate-500 leading-none">
            <%= row[:amount] > 0 ? (row[:amount] / 1_000_000.0).round(1).to_s + "M" : "" %>
          </div>
          <div class="w-full rounded-t-md"
               style="height:<%= pct %>%; min-height:<%= row[:amount] > 0 ? '4px' : '2px' %>;
                      background:<%= is_current ? 'linear-gradient(180deg,#6366f1,#4f46e5)' : 'linear-gradient(180deg,#94a3b8,#cbd5e1)' %>;">
          </div>
          <div class="text-[9px] text-slate-400 text-center leading-tight whitespace-nowrap">
            <%= row[:label].split(" ").first %><br><%= row[:label].split(" ").last %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-3 pt-3 border-t border-slate-100 flex gap-4 text-[11px] text-slate-400">
      <span><span class="inline-block w-2.5 h-2.5 rounded-sm bg-indigo-500 mr-1 align-middle"></span><%= t("#{d}.revenue_current_month") %></span>
      <span><span class="inline-block w-2.5 h-2.5 rounded-sm bg-slate-300 mr-1 align-middle"></span><%= t("#{d}.revenue_prev_month") %></span>
    </div>
  </div>

  <!-- This month's new subscriptions -->
  <div class="col-span-2 bg-white rounded-xl border border-slate-200 p-5">
    <h3 class="text-[13px] font-bold text-slate-700 mb-3"><%= t("#{d}.revenue_month_subs") %></h3>
    <% if @month_subs.any? %>
      <div class="overflow-y-auto" style="max-height:185px;">
        <% @month_subs.each do |sub| %>
          <% paid = sub.payments.any? { |p| p.status == "completed" } %>
          <div class="flex items-center justify-between py-2 border-b border-slate-50 last:border-0">
            <div class="min-w-0 flex-1 pr-2">
              <div class="text-[12px] font-semibold text-slate-800 truncate"><%= sub.workspace&.name %></div>
              <div class="flex items-center gap-1 mt-0.5 flex-wrap">
                <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold bg-emerald-100 text-emerald-700">
                  active
                </span>
                <% if paid %>
                  <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold bg-emerald-50 text-emerald-600 border border-emerald-200">
                    ✓ <%= t("#{d}.pay_completed") %>
                  </span>
                <% else %>
                  <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold bg-amber-50 text-amber-600 border border-amber-200">
                    ⏳ <%= t("#{d}.pay_pending") %>
                  </span>
                <% end %>
              </div>
            </div>
            <div class="text-right flex-shrink-0">
              <div class="text-[12px] font-bold <%= paid ? 'text-emerald-600' : 'text-amber-500' %>"><%= fmt_vnd(sub.price_cents) %></div>
              <div class="text-[10px] text-slate-400"><%= sub.billing_cycle %></div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8 text-[12px] text-slate-400"><%= t("#{d}.revenue_no_month_subs") %></div>
    <% end %>
  </div>

</div>

<!-- Recent payments table -->
<div class="bg-white rounded-xl border border-slate-200 p-5 mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-[13px] font-bold text-slate-700"><%= t("#{d}.revenue_history") %></h3>
    <%= link_to t("#{d}.revenue_view_all"), super_admin_subscriptions_path, class: "text-[11px] text-indigo-500 hover:text-indigo-700 font-semibold" %>
  </div>
  <% if @recent_payments.any? %>
    <table class="w-full border-collapse">
      <thead>
        <tr class="border-b border-slate-100">
          <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_workspace") %></th>
          <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_plan") %></th>
          <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_amount") %></th>
          <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_gateway") %></th>
          <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_pay_status") %></th>
          <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_date") %></th>
        </tr>
      </thead>
      <tbody>
        <% @recent_payments.each do |payment| %>
          <tr class="border-b border-slate-50 hover:bg-slate-50">
            <td class="px-2 py-2.5 text-[12px] font-semibold text-slate-800">
              <%= link_to payment.workspace&.name, super_admin_workspace_path(payment.workspace), class: "hover:text-indigo-600" rescue payment.workspace&.name %>
            </td>
            <td class="px-2 py-2.5">
              <span class="text-[10px] px-1.5 py-0.5 rounded font-semibold <%= payment.subscription&.plan == 'enterprise' ? 'bg-violet-100 text-violet-700' : payment.subscription&.plan == 'pro' ? 'bg-indigo-100 text-indigo-700' : 'bg-slate-100 text-slate-500' %>">
                <%= payment.subscription&.plan&.upcase || "—" %>
              </span>
            </td>
            <td class="px-2 py-2.5 text-[12px] font-bold text-slate-800"><%= fmt_vnd(payment.amount_cents) %></td>
            <td class="px-2 py-2.5 text-[11px] text-slate-500"><%= payment.gateway_label %></td>
            <td class="px-2 py-2.5">
              <% badge = case payment.status
                when "completed" then ["bg-emerald-100 text-emerald-700", t("#{d}.pay_completed")]
                when "pending"   then ["bg-amber-100 text-amber-700",     t("#{d}.pay_pending")]
                when "failed"    then ["bg-red-100 text-red-700",         t("#{d}.pay_failed")]
                when "refunded"  then ["bg-slate-100 text-slate-600",     t("#{d}.pay_refunded")]
                else                  ["bg-slate-100 text-slate-500",     payment.status]
                end %>
              <span class="text-[10px] px-2 py-0.5 rounded-full font-semibold <%= badge[0] %>"><%= badge[1] %></span>
            </td>
            <td class="px-2 py-2.5 text-[11px] text-slate-400">
              <%= (payment.paid_at || payment.created_at).strftime("%d/%m/%Y") %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-8 text-[13px] text-slate-400"><%= t("#{d}.revenue_no_history") %></div>
  <% end %>
</div>

<!-- Recent workspaces -->
<div class="bg-white rounded-xl border border-slate-200 p-5">
  <h2 class="text-[13px] font-bold text-slate-700 mb-4"><%= t("#{d}.recent_workspaces") %></h2>
  <table class="w-full border-collapse">
    <thead><tr class="border-b border-slate-100">
      <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_name") %></th>
      <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_status") %></th>
      <th class="text-left text-[10px] font-bold text-slate-400 uppercase tracking-wide px-2 py-2"><%= t("#{d}.col_created") %></th>
    </tr></thead>
    <tbody>
      <% @recent_workspaces.each do |ws| %>
        <tr class="border-b border-slate-50 hover:bg-slate-50">
          <td class="px-2 py-2.5 text-[13px] font-semibold text-slate-900"><%= link_to ws.name, super_admin_workspace_path(ws), class: "hover:text-indigo-600" %></td>
          <td class="px-2 py-2.5 text-[12px] text-slate-500"><%= ws.status %></td>
          <td class="px-2 py-2.5 text-[12px] text-slate-500"><%= ws.created_at.strftime("%d/%m/%Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
