<div class="max-w-md">
  <div class="flex items-center gap-2 mb-5">
    <%= link_to super_admin_subscriptions_path, class: "text-slate-400 hover:text-slate-600 text-[13px]" do %>← Quay lại<% end %>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <div class="flex items-center gap-3 mb-5">
      <div class="w-11 h-11 rounded-xl bg-amber-50 border border-amber-200 flex items-center justify-center text-lg">🎓</div>
      <div>
        <div class="text-[15px] font-bold text-slate-900"><%= @learner.name.presence || @learner.email %></div>
        <div class="text-[12px] text-slate-400"><%= @learner.email %> · <span class="text-amber-600 font-semibold">Học viên</span></div>
      </div>
    </div>

    <%= form_with url: super_admin_learner_credit_path(@learner), method: :patch, scope: :learner do |f| %>
      <div class="mb-4">
        <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Credit hiện có</label>
        <%= f.number_field :credits, value: @learner.credits, min: 0, class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-[14px] outline-none focus:border-indigo-500" %>
      </div>
      <div class="mb-5">
        <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Credit tối đa (hạn mức)</label>
        <%= f.number_field :max_credits, value: @learner.max_credits, min: 0, class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-[14px] outline-none focus:border-indigo-500" %>
      </div>
      <div class="flex gap-2 justify-end">
        <%= link_to "Huỷ", super_admin_subscriptions_path, class: "px-4 py-2 text-[13px] font-semibold text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200" %>
        <%= f.submit "Lưu thay đổi", class: "px-4 py-2 text-[13px] font-semibold text-white bg-indigo-600 rounded-lg hover:bg-indigo-700 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
