<div class="flex justify-between items-center mb-5">
  <h1 class="text-[21px] font-extrabold text-slate-900"><%= t("super_admin.subscriptions.title") %></h1>
  <span class="text-[12px] text-slate-400">Credit theo user — mỗi user 1 budget duy nhất</span>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
  <table class="w-full border-collapse">
    <thead>
      <tr class="bg-slate-50 border-b border-slate-200">
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">User</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Loại</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Workspaces / Lớp</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">AI Credits</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2.5">Đã dùng</th>
        <th class="px-4 py-2.5"></th>
      </tr>
    </thead>
    <tbody>
      <% @owners.each do |user| %>
        <% sub = @primary_subs[user.id] %>
        <% workspaces = user.owned_workspaces.sort_by(&:id) %>
        <tr class="border-b border-slate-100 hover:bg-slate-50">
          <td class="px-4 py-3">
            <div class="text-[13px] font-semibold text-slate-900"><%= user.name.presence || user.email %></div>
            <div class="text-[11px] text-slate-400"><%= user.email %></div>
          </td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold bg-indigo-50 text-indigo-600">👩‍🏫 Giáo viên</span>
          </td>
          <td class="px-4 py-3">
            <div class="flex flex-wrap gap-1">
              <% workspaces.each do |ws| %>
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-medium bg-slate-100 text-slate-600">
                  <%= ws.name %>
                </span>
              <% end %>
            </div>
          </td>
          <td class="px-4 py-3">
            <% if sub %>
              <span class="text-[14px] font-bold text-violet-600"><%= sub.credit_balance %></span>
              <span class="text-[11px] text-slate-400"> / <%= sub.max_ai_credits.to_i > 0 ? sub.max_ai_credits : "∞" %></span>
            <% else %>
              <span class="text-[12px] text-slate-400">—</span>
            <% end %>
          </td>
          <td class="px-4 py-3 text-[12px] text-slate-500"><%= sub&.credit_used || 0 %></td>
          <td class="px-4 py-3">
            <% if sub %>
              <div class="flex gap-1.5 justify-end">
                <%= link_to super_admin_subscription_path(sub), class: "px-2.5 py-1 text-[11px] bg-slate-100 rounded text-slate-600 hover:bg-slate-200" do %><%= t("super_admin.subscriptions.action_view") %><% end %>
                <%= link_to edit_super_admin_subscription_path(sub), class: "px-2.5 py-1 text-[11px] bg-indigo-50 rounded text-indigo-600 hover:bg-indigo-100" do %><%= t("super_admin.subscriptions.action_edit") %><% end %>
              </div>
            <% end %>
          </td>
        </tr>
      <% end %>

      <%# ── Learners ── %>
      <% @learners.each do |learner| %>
        <% used = [learner.max_credits.to_i - learner.credits.to_i, 0].max %>
        <tr class="border-b border-slate-100 hover:bg-slate-50">
          <td class="px-4 py-3">
            <div class="text-[13px] font-semibold text-slate-900"><%= learner.name.presence || learner.email %></div>
            <div class="text-[11px] text-slate-400"><%= learner.email %></div>
          </td>
          <td class="px-4 py-3">
            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[11px] font-semibold bg-amber-50 text-amber-600">🎓 Học viên</span>
          </td>
          <td class="px-4 py-3 text-[12px] text-slate-400">—</td>
          <td class="px-4 py-3">
            <span class="text-[14px] font-bold text-violet-600"><%= learner.credits %></span>
            <span class="text-[11px] text-slate-400"> / <%= learner.max_credits %></span>
          </td>
          <td class="px-4 py-3 text-[12px] text-slate-500"><%= used %></td>
          <td class="px-4 py-3">
            <div class="flex gap-1.5 justify-end">
              <%= link_to edit_super_admin_learner_credit_path(learner), class: "px-2.5 py-1 text-[11px] bg-indigo-50 rounded text-indigo-600 hover:bg-indigo-100" do %><%= t("super_admin.subscriptions.action_edit") %><% end %>
            </div>
          </td>
        </tr>
      <% end %>

      <% if @owners.empty? && @learners.empty? %>
        <tr><td colspan="6" class="px-4 py-8 text-center text-[13px] text-slate-400"><%= t("super_admin.subscriptions.empty") %></td></tr>
      <% end %>
    </tbody>
  </table>
</div>
