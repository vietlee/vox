<div class="flex items-center gap-3 mb-6">
  <%= link_to super_admin_subscription_path(@subscription), class: "text-[13px] text-slate-500 hover:text-slate-700" do %><%= t("super_admin.subscriptions.back") %><% end %>
  <h1 class="text-[21px] font-extrabold text-slate-900"><%= t("super_admin.subscriptions.edit_title") %> — <%= @subscription_user&.name.presence || @subscription_user&.email %></h1>
</div>

<%= form_with model: [:super_admin, @subscription], local: true, class: "space-y-5 max-w-lg" do |f| %>
  <!-- AI Credits -->
  <div class="bg-white rounded-xl border border-violet-200 p-5">
    <h2 class="text-[13px] font-bold text-violet-700 mb-4">AI Credits</h2>
    <div class="space-y-4">
      <div>
        <label class="block text-[11px] font-semibold text-slate-500 uppercase mb-1">Credit Balance (còn lại)</label>
        <%= f.number_field :credit_balance, value: @subscription.credit_balance, min: 0,
              class: "w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-800" %>
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-slate-500 uppercase mb-1">Max AI Credits (hiển thị tối đa)</label>
        <%= f.number_field :max_ai_credits, value: @subscription.max_ai_credits, min: 0,
              class: "w-full border border-slate-200 rounded-lg px-3 py-2 text-[13px] text-slate-800",
              placeholder: "∞" %>
      </div>
      <div class="p-3 bg-violet-50 rounded-lg border border-violet-100">
        <p class="text-[11px] text-violet-600">Thay đổi credit balance sẽ có hiệu lực ngay. Cron job hàng tháng sẽ cộng thêm <%= PlanConfig.monthly_free_credits %> credits.</p>
      </div>
    </div>
  </div>

  <div class="flex gap-3">
    <%= f.submit t("super_admin.subscriptions.save_btn"), class: "px-6 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg cursor-pointer hover:bg-indigo-700" %>
    <%= link_to t("super_admin.subscriptions.cancel_btn"), super_admin_subscription_path(@subscription), class: "px-6 py-2.5 bg-slate-100 text-slate-700 text-[13px] font-semibold rounded-lg hover:bg-slate-200" %>
  </div>
<% end %>
