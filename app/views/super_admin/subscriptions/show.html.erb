<div class="flex items-center gap-3 mb-6">
  <%= link_to super_admin_subscriptions_path, class: "text-[13px] text-slate-500 hover:text-slate-700" do %>← Back<% end %>
  <h1 class="text-[21px] font-extrabold text-slate-900">Subscription — <%= @subscription.workspace&.name %></h1>
  <%= link_to edit_super_admin_subscription_path(@subscription), class: "ml-auto px-4 py-2 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700" do %>Edit<% end %>
</div>

<div class="grid grid-cols-3 gap-4 mb-6">
  <% [
    ["Plan",    @subscription.plan&.upcase,    "indigo"],
    ["Status",  @subscription.status,          "emerald"],
    ["Billing", @subscription.billing_cycle,   "slate"]
  ].each do |label, value, color| %>
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="text-[11px] font-semibold text-slate-400 uppercase mb-1"><%= label %></div>
      <div class="text-[20px] font-extrabold text-slate-900"><%= value %></div>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-2 gap-4 mb-6">
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h2 class="text-[13px] font-bold text-slate-700 mb-3">Subscription Details</h2>
    <dl class="space-y-2 text-[13px]">
      <div class="flex justify-between"><dt class="text-slate-500">Workspace</dt><dd class="font-semibold text-slate-900"><%= @subscription.workspace&.name %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Starts</dt><dd class="text-slate-700"><%= @subscription.starts_at&.strftime("%b %d, %Y") || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Expires</dt><dd class="<%= @subscription.expires_soon? ? 'text-amber-600 font-semibold' : 'text-slate-700' %>"><%= @subscription.ends_at&.strftime("%b %d, %Y") || "—" %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Auto-renew</dt><dd class="text-slate-700"><%= @subscription.auto_renew? ? "Yes" : "No" %></dd></div>
      <div class="flex justify-between"><dt class="text-slate-500">Price</dt><dd class="text-slate-700"><%= number_with_delimiter(@subscription.price_cents) %> ₫</dd></div>
    </dl>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <h2 class="text-[13px] font-bold text-slate-700 mb-3">Limits & Credits</h2>
    <dl class="space-y-2 text-[13px]">
      <% [
        ["Max Surveys",    @subscription.max_surveys],
        ["Max Votes",      @subscription.max_votes],
        ["Max Feedbacks",  @subscription.max_feedbacks],
        ["Max Supporters", @subscription.max_supporters],
        ["AI Credits",     @subscription.max_ai_credits],
        ["Credit Balance", @subscription.credit_balance]
      ].each do |label, val| %>
        <div class="flex justify-between">
          <dt class="text-slate-500"><%= label %></dt>
          <dd class="font-semibold text-slate-900"><%= val.nil? ? "∞" : val %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>

<div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
  <div class="px-5 py-3 border-b border-slate-100">
    <h2 class="text-[13px] font-bold text-slate-700">Payment History</h2>
  </div>
  <table class="w-full border-collapse">
    <thead>
      <tr class="bg-slate-50 border-b border-slate-200">
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2">Invoice</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2">Amount</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2">Gateway</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2">Status</th>
        <th class="text-left text-[11px] font-semibold text-slate-500 uppercase px-4 py-2">Date</th>
      </tr>
    </thead>
    <tbody>
      <% @payments.each do |p| %>
        <tr class="border-b border-slate-100 hover:bg-slate-50">
          <td class="px-4 py-2.5 text-[12px] font-mono text-slate-600"><%= p.invoice_number %></td>
          <td class="px-4 py-2.5 text-[13px] font-semibold text-slate-900"><%= p.amount_formatted %></td>
          <td class="px-4 py-2.5 text-[12px] text-slate-600 uppercase"><%= p.gateway %></td>
          <td class="px-4 py-2.5">
            <% sc = { "completed" => "bg-emerald-50 text-emerald-700", "pending" => "bg-amber-50 text-amber-700", "failed" => "bg-red-50 text-red-600", "refunded" => "bg-slate-100 text-slate-500" } %>
            <span class="px-2 py-0.5 rounded text-[11px] font-semibold <%= sc[p.status] %>"><%= p.status %></span>
          </td>
          <td class="px-4 py-2.5 text-[12px] text-slate-500"><%= p.created_at.strftime("%b %d, %Y %H:%M") %></td>
        </tr>
      <% end %>
      <% if @payments.empty? %>
        <tr><td colspan="5" class="px-4 py-6 text-center text-[13px] text-slate-400">Chưa có giao dịch nào.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
