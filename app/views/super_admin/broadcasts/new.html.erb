<div class="flex items-center gap-3 mb-6">
  <%= link_to super_admin_broadcasts_path, class: "text-[13px] text-slate-500 hover:text-slate-700" do %>← <%= t("super_admin.broadcasts.back") %><% end %>
  <h1 class="text-[21px] font-extrabold text-slate-900">📢 <%= t("super_admin.broadcasts.new_title") %></h1>
</div>

<div class="max-w-[680px]">
  <%= form_with url: super_admin_broadcasts_path, method: :post, local: true do |f| %>
    <div class="space-y-5">

      <!-- Message -->
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-4">📝 <%= t("super_admin.broadcasts.message_section") %></h2>
        <div class="space-y-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5">
              <%= t("super_admin.broadcasts.title_label") %> <span class="text-red-500">*</span>
            </label>
            <input type="text" name="title" required maxlength="120"
              placeholder="<%= j t("super_admin.broadcasts.title_placeholder") %>"
              class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[14px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none">
            <p class="text-[11px] text-slate-400 mt-1"><%= t("super_admin.broadcasts.title_hint") %></p>
          </div>
          <div>
            <label class="block text-[12px] font-semibold text-slate-700 mb-1.5"><%= t("super_admin.broadcasts.body_label") %></label>
            <textarea name="body" rows="4" maxlength="500"
              placeholder="<%= j t("super_admin.broadcasts.body_placeholder") %>"
              class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 outline-none resize-none"></textarea>
          </div>
        </div>
      </div>

      <!-- Target -->
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-4">🎯 <%= t("super_admin.broadcasts.target_section") %></h2>

        <!-- All workspaces option -->
        <label class="flex items-start gap-3 p-3 rounded-lg border-2 border-indigo-500 bg-indigo-50 cursor-pointer mb-3" id="target-all-label">
          <input type="radio" name="target" value="all" checked
            class="mt-0.5 accent-indigo-600" onchange="toggleTargetMode(this.value)">
          <div>
            <div class="text-[13px] font-semibold text-slate-900"><%= t("super_admin.broadcasts.target_all") %></div>
            <div class="text-[12px] text-slate-500 mt-0.5"><%= t("super_admin.broadcasts.target_all_desc", count: @workspaces.count) %></div>
          </div>
        </label>

        <!-- Specific workspaces option -->
        <label class="flex items-start gap-3 p-3 rounded-lg border-2 border-slate-200 cursor-pointer" id="target-specific-label">
          <input type="radio" name="target" value="specific"
            class="mt-0.5 accent-indigo-600" onchange="toggleTargetMode(this.value)">
          <div class="flex-1">
            <div class="text-[13px] font-semibold text-slate-900"><%= t("super_admin.broadcasts.target_specific") %></div>
            <div class="text-[12px] text-slate-500 mt-0.5"><%= t("super_admin.broadcasts.target_specific_desc") %></div>
          </div>
        </label>

        <!-- Workspace selector (hidden by default) -->
        <div id="workspace-selector" class="hidden mt-3 border border-slate-200 rounded-lg overflow-hidden">
          <!-- Search -->
          <div class="p-3 border-b border-slate-100">
            <input type="text" id="ws-search" placeholder="<%= j t("super_admin.broadcasts.search_workspace") %>"
              oninput="filterWorkspaces()"
              class="w-full px-3 py-2 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-400 outline-none">
          </div>
          <!-- Select all -->
          <div class="px-4 py-2 border-b border-slate-100 flex items-center gap-2 bg-slate-50">
            <input type="checkbox" id="select-all" class="w-4 h-4 accent-indigo-600" onchange="toggleSelectAll(this.checked)">
            <label for="select-all" class="text-[12px] font-semibold text-slate-600 cursor-pointer"><%= t("super_admin.broadcasts.select_all") %></label>
            <span id="selected-count" class="ml-auto text-[11px] text-indigo-600 font-semibold"></span>
          </div>
          <!-- List -->
          <div class="max-h-[280px] overflow-y-auto divide-y divide-slate-50" id="workspace-list">
            <% @workspaces.each do |ws| %>
              <label class="flex items-center gap-3 px-4 py-2.5 hover:bg-slate-50 cursor-pointer workspace-item"
                     data-name="<%= ws.name.downcase %>">
                <input type="checkbox" name="workspace_ids[]" value="<%= ws.id %>"
                  class="w-4 h-4 accent-indigo-600 ws-checkbox" onchange="updateCount()">
                <div class="flex-1 min-w-0">
                  <div class="text-[13px] font-semibold text-slate-900 truncate"><%= ws.name %></div>
                  <div class="text-[11px] text-slate-400"><%= ws.slug %> · <%= ws.admin_users.count %> admin</div>
                </div>
                <% sub = ws.active_subscription %>
                <span class="text-[10px] font-bold px-1.5 py-0.5 rounded <%= sub&.pro? ? 'bg-indigo-100 text-indigo-700' : sub&.enterprise? ? 'bg-violet-100 text-violet-700' : 'bg-slate-100 text-slate-500' %>">
                  <%= sub&.plan&.upcase || "FREE" %>
                </span>
              </label>
            <% end %>
          </div>
        </div>
      </div>

      <!-- Preview -->
      <div class="bg-gradient-to-br from-indigo-50 to-violet-50 border border-indigo-200 rounded-xl p-5">
        <h2 class="text-[12px] font-bold text-slate-600 uppercase tracking-wide mb-3">👁 <%= t("super_admin.broadcasts.preview_section") %></h2>
        <div class="bg-white rounded-lg border border-slate-200 p-4 flex items-start gap-3">
          <div class="w-2 h-2 rounded-full bg-indigo-500 mt-1.5 flex-shrink-0"></div>
          <div class="flex-1">
            <div id="preview-title" class="text-[13px] font-semibold text-slate-900"><%= t("super_admin.broadcasts.preview_title_placeholder") %></div>
            <div id="preview-body" class="text-[12px] text-slate-500 mt-0.5 hidden"></div>
            <div class="text-[11px] text-slate-400 mt-1"><%= t("super_admin.broadcasts.preview_time") %></div>
          </div>
        </div>
      </div>

      <div class="flex gap-3">
        <button type="submit"
          class="px-6 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700 cursor-pointer">
          📢 <%= t("super_admin.broadcasts.send_btn") %>
        </button>
        <%= link_to t("super_admin.broadcasts.cancel_btn"), super_admin_broadcasts_path,
              class: "px-6 py-2.5 bg-slate-100 text-slate-700 text-[13px] font-semibold rounded-lg hover:bg-slate-200" %>
      </div>
    </div>
  <% end %>
</div>

<script>
function toggleTargetMode(val) {
  const allLabel      = document.getElementById('target-all-label');
  const specificLabel = document.getElementById('target-specific-label');
  const selector      = document.getElementById('workspace-selector');
  if (val === 'all') {
    allLabel.classList.replace('border-slate-200', 'border-indigo-500');
    allLabel.classList.add('bg-indigo-50');
    specificLabel.classList.replace('border-indigo-500', 'border-slate-200');
    specificLabel.classList.remove('bg-indigo-50');
    selector.classList.add('hidden');
  } else {
    specificLabel.classList.replace('border-slate-200', 'border-indigo-500');
    specificLabel.classList.add('bg-indigo-50');
    allLabel.classList.replace('border-indigo-500', 'border-slate-200');
    allLabel.classList.remove('bg-indigo-50');
    selector.classList.remove('hidden');
  }
}

function filterWorkspaces() {
  const q = document.getElementById('ws-search').value.toLowerCase();
  document.querySelectorAll('.workspace-item').forEach(el => {
    el.classList.toggle('hidden', q && !el.dataset.name.includes(q));
  });
}

function toggleSelectAll(checked) {
  document.querySelectorAll('.ws-checkbox').forEach(cb => {
    if (!cb.closest('.workspace-item').classList.contains('hidden')) cb.checked = checked;
  });
  updateCount();
}

function updateCount() {
  const n = document.querySelectorAll('.ws-checkbox:checked').length;
  const el = document.getElementById('selected-count');
  el.textContent = n > 0 ? `${n} <%= j t("super_admin.broadcasts.selected") %>` : '';
}

// Live preview
document.querySelector('input[name="title"]').addEventListener('input', function() {
  const el = document.getElementById('preview-title');
  el.textContent = this.value || "<%= j t("super_admin.broadcasts.preview_title_placeholder") %>";
});
document.querySelector('textarea[name="body"]').addEventListener('input', function() {
  const el = document.getElementById('preview-body');
  if (this.value.trim()) {
    el.textContent = this.value;
    el.classList.remove('hidden');
  } else {
    el.classList.add('hidden');
  }
});
</script>
