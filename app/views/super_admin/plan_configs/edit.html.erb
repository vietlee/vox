<div class="max-w-[640px]">
  <div class="flex items-center gap-3 mb-5">
    <%= link_to super_admin_plan_configs_path, class: "text-[13px] text-slate-500 hover:text-slate-700" do %><%= t("super_admin.plan_configs.back") %><% end %>
    <h1 class="text-[20px] font-extrabold text-slate-900"><%= t("super_admin.plan_configs.edit_title") %> <%= @plan_config.display_name %></h1>
  </div>

  <%= form_with model: [:super_admin, @plan_config], local: true do |f| %>
    <div class="space-y-5">

      <!-- Basic info -->
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-4"><%= t("super_admin.plan_configs.basic_info") %></h2>
        <div class="space-y-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("super_admin.plan_configs.display_name") %></label>
            <%= f.text_field :display_name, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("super_admin.plan_configs.price_vnd") %></label>
              <%= f.number_field :price_vnd, min: 0, step: 1000,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
              <p class="text-[11px] text-slate-400 mt-1"><%= t("super_admin.plan_configs.price_contact_note") %></p>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= t("super_admin.plan_configs.billing_cycle") %></label>
              <%= f.select :billing_cycle,
                    [[t("super_admin.plan_configs.billing_monthly"), "month"],
                     [t("super_admin.plan_configs.billing_yearly"), "year"]],
                    { selected: @plan_config.billing_cycle },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Monthly free AI credits (only on free plan) -->
      <% if @plan_config.plan_key == "free" %>
        <div class="bg-white rounded-xl border border-violet-200 p-5">
          <h2 class="text-[13px] font-bold text-violet-700 mb-1">AI Credits hàng tháng</h2>
          <p class="text-[12px] text-slate-400 mb-4">Số AI Credits miễn phí được cấp cho tất cả workspace vào đầu mỗi tháng bởi cron job.</p>
          <div class="max-w-[200px]">
            <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Monthly Free Credits</label>
            <%= f.number_field :monthly_free_credits, min: 0, step: 10,
                  class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
        </div>
      <% end %>


      <div class="flex gap-3">
        <%= f.submit t("super_admin.plan_configs.save_btn"), class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700 cursor-pointer border-0" %>
        <%= link_to t("super_admin.plan_configs.cancel_btn"), super_admin_plan_configs_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg hover:bg-slate-200" %>
      </div>
    </div>
  <% end %>
</div>
