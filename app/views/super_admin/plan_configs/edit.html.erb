<div class="max-w-[640px]">
  <div class="flex items-center gap-3 mb-5">
    <%= link_to super_admin_plan_configs_path, class: "text-[13px] text-slate-500 hover:text-slate-700" do %>← Quay lại<% end %>
    <h1 class="text-[20px] font-extrabold text-slate-900">Chỉnh sửa gói <%= @plan_config.display_name %></h1>
  </div>

  <%= form_with model: [:super_admin, @plan_config], local: true do |f| %>
    <div class="space-y-5">

      <!-- Basic info -->
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-4">Thông tin cơ bản</h2>
        <div class="space-y-4">
          <div>
            <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Tên hiển thị</label>
            <%= f.text_field :display_name, class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Giá (VND)</label>
              <%= f.number_field :price_vnd, min: 0, step: 1000,
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
              <p class="text-[11px] text-slate-400 mt-1">Nhập 0 = "Liên hệ Sales"</p>
            </div>
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5">Chu kỳ thanh toán</label>
              <%= f.select :billing_cycle, [["Hàng tháng", "month"], ["Hàng năm", "year"]],
                    { selected: @plan_config.billing_cycle },
                    class: "w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Limits -->
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-1">Giới hạn sử dụng</h2>
        <p class="text-[12px] text-slate-400 mb-4">Để trống = không giới hạn</p>
        <% limits = @plan_config.limits || {} %>
        <div class="grid grid-cols-2 gap-4">
          <% [
            ["max_surveys", "Survey tối đa"],
            ["max_votes", "Vote tối đa"],
            ["max_feedbacks", "Feedback board tối đa"],
            ["max_supporters", "Supporter tối đa"],
            ["max_ai_credits", "AI Credits / tháng"]
          ].each do |key, label| %>
            <div>
              <label class="block text-[12px] font-semibold text-slate-600 mb-1.5"><%= label %></label>
              <input type="number" name="plan_config[limits][<%= key %>]" min="0"
                value="<%= limits[key] %>"
                placeholder="Không giới hạn"
                class="w-full px-3 py-2.5 border border-slate-200 rounded-lg text-[13px] focus:border-indigo-500 outline-none">
            </div>
          <% end %>
        </div>
      </div>

      <!-- Features -->
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h2 class="text-[13px] font-bold text-slate-700 mb-4">Tính năng</h2>
        <% features = @plan_config.features || {} %>
        <div class="grid grid-cols-2 gap-3">
          <% [
            ["ai_survey_builder", "AI Survey Builder"],
            ["ai_analysis", "AI Phân tích"],
            ["ai_executive_report", "AI Báo cáo điều hành"],
            ["ai_chat", "AI Chat với dữ liệu"],
            ["ai_moderation", "AI Kiểm duyệt nội dung"],
            ["custom_branding", "Custom Branding"],
            ["export", "Export Excel/PDF"],
            ["sso", "SSO / SAML"]
          ].each do |key, label| %>
            <label class="flex items-center gap-2.5 cursor-pointer group">
              <input type="hidden" name="plan_config[features][<%= key %>]" value="0">
              <input type="checkbox" name="plan_config[features][<%= key %>]" value="1"
                <%= "checked" if features[key].to_s == "true" || features[key] == true %>
                class="w-4 h-4 accent-indigo-600">
              <span class="text-[13px] text-slate-700 group-hover:text-slate-900"><%= label %></span>
            </label>
          <% end %>
        </div>
      </div>

      <div class="flex gap-3">
        <%= f.submit "Lưu cấu hình", class: "px-5 py-2.5 bg-indigo-600 text-white text-[13px] font-semibold rounded-lg hover:bg-indigo-700 cursor-pointer border-0" %>
        <%= link_to "Huỷ", super_admin_plan_configs_path, class: "px-5 py-2.5 bg-slate-100 text-slate-600 text-[13px] font-semibold rounded-lg hover:bg-slate-200" %>
      </div>
    </div>
  <% end %>
</div>
