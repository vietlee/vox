<div class="flex justify-between items-center mb-5">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900"><%= t("super_admin.plan_configs.title") %></h1>
    <p class="text-[12px] text-slate-500 mt-0.5">Cấu hình AI Credits miễn phí hàng tháng cho tất cả workspace.</p>
  </div>
</div>

<% free_config = @plan_configs.find { |pc| pc.plan_key == "free" } %>

<div class="max-w-lg">
  <!-- AI Credits config card -->
  <div class="bg-white rounded-xl border-2 border-violet-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-3">
        <span class="inline-flex px-2.5 py-1 rounded-lg text-[12px] font-bold uppercase bg-violet-100 text-violet-700">AI Credits</span>
        <span class="text-[12px] text-emerald-600 font-semibold">Tất cả tính năng miễn phí</span>
      </div>
      <% if free_config %>
        <%= link_to edit_super_admin_plan_config_path(free_config), class: "text-[12px] text-indigo-600 hover:text-indigo-700 font-semibold" do %>
          Chỉnh sửa →
        <% end %>
      <% end %>
    </div>

    <div class="bg-violet-50 rounded-lg p-4 mb-4">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-[11px] font-semibold text-violet-500 uppercase mb-1">Monthly Free Credits</div>
          <div class="text-[32px] font-black text-violet-700 leading-none"><%= free_config&.monthly_free_credits || 100 %></div>
          <div class="text-[12px] text-violet-400 mt-1">credits / tháng / workspace</div>
        </div>
        <div class="text-[48px] opacity-20">✨</div>
      </div>
    </div>

    <div class="space-y-2 text-[13px]">
      <div class="flex items-center gap-2 text-slate-600">
        <span class="text-emerald-500">✓</span> Survey, Vote, Feedback, Dynamic Forms — không giới hạn
      </div>
      <div class="flex items-center gap-2 text-slate-600">
        <span class="text-emerald-500">✓</span> Tất cả tính năng AI, TTS, STT, Export, SSO — miễn phí
      </div>
      <div class="flex items-center gap-2 text-slate-600">
        <span class="text-emerald-500">✓</span> Supporter & Members — không giới hạn
      </div>
      <div class="flex items-center gap-2 text-slate-600">
        <span class="text-violet-500">✦</span> Cron job cấp credits vào ngày 1 hàng tháng
      </div>
      <div class="flex items-center gap-2 text-slate-600">
        <span class="text-violet-500">✦</span> Người dùng có thể mua thêm AI Credits qua PayOS
      </div>
    </div>
  </div>
</div>
