<div class="flex justify-between items-center mb-5">
  <div>
    <h1 class="text-[21px] font-extrabold text-slate-900">Cấu hình giá gói</h1>
    <p class="text-[12px] text-slate-500 mt-0.5">Thiết lập giá và giới hạn cho từng gói dịch vụ</p>
  </div>
</div>

<div class="grid grid-cols-3 gap-5">
  <% @plan_configs.each do |pc| %>
    <% plan_color = { "free" => "border-slate-200", "pro" => "border-indigo-300", "enterprise" => "border-violet-300" }[pc.plan_key] || "border-slate-200" %>
    <% badge_color = { "free" => "bg-slate-100 text-slate-600", "pro" => "bg-indigo-100 text-indigo-700", "enterprise" => "bg-violet-100 text-violet-700" }[pc.plan_key] || "bg-slate-100 text-slate-600" %>
    <div class="bg-white rounded-xl border-2 <%= plan_color %> p-5">
      <div class="flex items-center justify-between mb-3">
        <span class="inline-flex px-2 py-0.5 rounded text-[11px] font-semibold uppercase <%= badge_color %>"><%= pc.plan_key %></span>
        <%= link_to edit_super_admin_plan_config_path(pc), class: "text-[11px] text-indigo-600 hover:text-indigo-700 font-semibold" do %>Chỉnh sửa<% end %>
      </div>

      <div class="mb-4">
        <div class="text-[28px] font-black text-slate-900 leading-none">
          <% if pc.price_vnd == 0 && pc.plan_key == "free" %>
            Miễn phí
          <% elsif pc.price_vnd == 0 %>
            Liên hệ
          <% else %>
            <%= number_with_delimiter(pc.price_vnd) %> ₫
          <% end %>
        </div>
        <% if pc.price_vnd > 0 %>
          <div class="text-[12px] text-slate-400">/<%= pc.billing_cycle || "tháng" %></div>
        <% end %>
      </div>

      <div class="space-y-1 text-[12px]">
        <div class="font-semibold text-slate-500 uppercase text-[10px] mb-1.5">Giới hạn</div>
        <% limits = pc.limits || {} %>
        <% [
          ["Survey", limits["max_surveys"]],
          ["Vote", limits["max_votes"]],
          ["Feedback board", limits["max_feedbacks"]],
          ["Supporter", limits["max_supporters"]],
          ["AI Credits", limits["max_ai_credits"]]
        ].each do |label, val| %>
          <div class="flex justify-between">
            <span class="text-slate-500"><%= label %></span>
            <span class="font-semibold text-slate-700"><%= val.nil? ? "∞" : val.to_s %></span>
          </div>
        <% end %>
      </div>

      <div class="mt-3 pt-3 border-t border-slate-100 space-y-1 text-[12px]">
        <div class="font-semibold text-slate-500 uppercase text-[10px] mb-1.5">Tính năng AI</div>
        <% features = pc.features || {} %>
        <% [
          ["AI Survey Builder", "ai_survey_builder"],
          ["AI Phân tích", "ai_analysis"],
          ["AI Báo cáo", "ai_executive_report"],
          ["AI Chat", "ai_chat"],
          ["AI Kiểm duyệt", "ai_moderation"]
        ].each do |label, key| %>
          <div class="flex items-center gap-1.5">
            <span class="<%= features[key] ? 'text-emerald-500' : 'text-slate-200' %>"><%= features[key] ? '✓' : '✗' %></span>
            <span class="<%= features[key] ? 'text-slate-700' : 'text-slate-400' %>"><%= label %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
