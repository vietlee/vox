<% content_for :title, @quiz_set.title %>

<style>
.quiz-card { background:#fff; border-radius:20px; box-shadow:0 4px 24px rgba(0,0,0,0.10); overflow:hidden; width:100%; max-width:480px; margin:0 auto; }
.quiz-hero { background:linear-gradient(135deg,#4F46E5 0%,#7C3AED 60%,#9333EA 100%); padding:40px 32px 36px; text-align:center; color:#fff; }
.quiz-hero-icon { font-size:52px; margin-bottom:12px; }
.quiz-hero-title { font-size:22px; font-weight:800; line-height:1.3; margin:0 0 8px; }
.quiz-hero-desc { font-size:13px; color:rgba(255,255,255,0.75); margin:0 0 16px; }
.quiz-chips { display:flex; justify-content:center; gap:8px; flex-wrap:wrap; }
.quiz-chip { display:inline-flex; align-items:center; gap:5px; background:rgba(255,255,255,0.15); backdrop-filter:blur(8px); padding:4px 12px; border-radius:99px; font-size:12px; font-weight:600; }
.quiz-body { padding:28px 28px 32px; }
.quiz-body h2 { font-size:15px; font-weight:800; color:#1E293B; margin:0 0 20px; }
.quiz-field { margin-bottom:16px; }
.quiz-label { display:block; font-size:11px; font-weight:700; color:#64748B; text-transform:uppercase; letter-spacing:0.06em; margin-bottom:6px; }
.quiz-label span { color:#F87171; }
.quiz-input { width:100%; padding:12px 16px; border:1.5px solid #E2E8F0; border-radius:12px; font-size:14px; font-family:inherit; outline:none; transition:border-color .2s; box-sizing:border-box; }
.quiz-input:focus { border-color:#4F46E5; box-shadow:0 0 0 3px rgba(79,70,229,0.12); }
.quiz-btn { display:flex; align-items:center; justify-content:center; gap:8px; width:100%; padding:14px; background:#4F46E5; color:#fff; font-size:15px; font-weight:700; border:none; border-radius:12px; cursor:pointer; font-family:inherit; margin-top:4px; transition:background .2s; }
.quiz-btn:hover { background:#4338CA; }
.quiz-footer { text-align:center; font-size:11px; color:#94A3B8; margin-top:16px; }
.quiz-footer span { font-weight:700; color:#4F46E5; }
</style>

<div style="min-height:calc(100vh - 52px); display:flex; align-items:center; justify-content:center; padding:24px 16px;">
  <div style="width:100%;">
    <div class="quiz-card">

      <!-- Hero -->
      <div class="quiz-hero">
        <div class="quiz-hero-icon">📚</div>
        <h1 class="quiz-hero-title"><%= @quiz_set.title %></h1>
        <% if @quiz_set.description.present? %>
          <p class="quiz-hero-desc"><%= @quiz_set.description %></p>
        <% end %>
        <div class="quiz-chips">
          <span class="quiz-chip">📋 <%= t("quiz.n_questions", count: @quiz_set.question_count) %></span>
          <% if @quiz_set.time_limit_minutes.to_i > 0 %>
            <span class="quiz-chip">⏱ <%= t("quiz.n_minutes", count: @quiz_set.time_limit_minutes) %></span>
          <% end %>
          <% if @quiz_set.allow_retake? %>
            <span class="quiz-chip">🔄 <%= t("quiz.retake_allowed") %></span>
          <% end %>
        </div>
      </div>

      <!-- Form -->
      <div class="quiz-body">
        <h2><%= t("quiz.enter_info") %></h2>
        <% if @already_submitted %>
          <!-- Already submitted + retake not allowed -->
          <div style="background:#FFF7ED;border:1.5px solid #FED7AA;border-radius:12px;padding:16px 18px;margin-bottom:16px;text-align:center;">
            <div style="font-size:20px;margin-bottom:6px;">🔒</div>
            <p style="font-size:13px;font-weight:700;color:#92400E;margin:0 0 4px;">Bạn đã hoàn thành bài thi này</p>
            <p style="font-size:12px;color:#B45309;margin:0;">Bài thi này không cho phép làm lại.</p>
          </div>
          <% if @quiz_set.result_immediate? %>
            <%= link_to quiz_path(@quiz_set.share_token, attempt_id: @submitted_attempt.id),
                style: "display:block;text-align:center;padding:13px;background:#6366F1;color:#fff;font-weight:700;font-size:14px;border-radius:12px;text-decoration:none;" do %>
              📋 Xem kết quả của bạn
            <% end %>
          <% end %>
        <% else %>
          <form action="<%= start_quiz_path(@quiz_set.share_token) %>" method="post">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">
            <div class="quiz-field">
              <label class="quiz-label"><%= t("quiz.your_name") %> <span>*</span></label>
              <input type="text" name="name" required autofocus class="quiz-input"
                     placeholder="<%= t('quiz.name_placeholder') %>"
                     oninvalid="this.setCustomValidity('<%= j t("quiz.validation_required") %>')"
                     oninput="this.setCustomValidity('')">
            </div>
            <div class="quiz-field">
              <label class="quiz-label"><%= t("quiz.your_email") %> <span>*</span></label>
              <input type="email" name="email" required class="quiz-input"
                     placeholder="<%= t('quiz.email_placeholder') %>"
                     oninvalid="this.setCustomValidity(this.value ? '<%= j t("quiz.validation_email") %>' : '<%= j t("quiz.validation_required") %>')"
                     oninput="this.setCustomValidity('')">
            </div>
            <button type="submit" class="quiz-btn">
              🚀 <%= t("quiz.start_quiz") %>
            </button>
          </form>
        <% end %>
      </div>

    </div>

    <p class="quiz-footer">Powered by <span>VOX</span></p>
  </div>
</div>
