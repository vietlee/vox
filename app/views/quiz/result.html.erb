<% content_for :title, t("quiz.result_title") %>

<style>
@keyframes fade-up { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
.r-card { animation: fade-up .4s ease both; }
.r-q { background:#fff; border-radius:14px; border:1.5px solid #E2E8F0; margin-bottom:12px; overflow:hidden; }
.r-q.r-correct { border-color:#A7F3D0; }
.r-q.r-wrong   { border-color:#FECACA; }
.r-q.r-manual  { border-color:#FDE68A; }
.r-q-header { display:flex; align-items:flex-start; gap:10px; padding:14px 16px 10px; }
.r-q-body   { padding:0 16px 14px 44px; }
.r-opt { display:flex; align-items:center; gap:8px; padding:7px 10px; border-radius:8px; font-size:13px; margin-bottom:5px; }
.r-opt-correct  { background:#F0FDF4; border:1px solid #A7F3D0; color:#065F46; font-weight:600; }
.r-opt-wrong    { background:#FFF5F5; border:1px solid #FECACA; color:#991B1B; }
.r-opt-neutral  { background:#F8FAFC; border:1px solid #E2E8F0; color:#475569; }
</style>

<% pct = @attempt.score_pct %>
<% correct_count = @attempt.quiz_attempt_answers.where(is_correct: true).pluck(:quiz_question_id).uniq.size %>
<% wrong_count   = @quiz_set.quiz_questions.count - correct_count %>

<!-- Score Hero -->
<div class="r-card" style="border-radius:20px; overflow:hidden; margin-bottom:16px;
  <%= pct >= 80 ? 'background:linear-gradient(135deg,#10B981,#0D9488)' : pct >= 50 ? 'background:linear-gradient(135deg,#1e3a5f,#2d5f8a)' : 'background:linear-gradient(135deg,#64748B,#475569)' %>;">
  <div style="padding:32px 24px; text-align:center; color:#fff;">
    <div style="font-size:56px; margin-bottom:8px;"><%= pct >= 80 ? "🏆" : pct >= 50 ? "👍" : "📖" %></div>
    <div style="font-size:72px; font-weight:900; line-height:1; margin-bottom:4px;"><%= pct %>%</div>
    <div style="font-size:15px; font-weight:700; opacity:0.9; margin-bottom:4px;">
      <%= @attempt.passed? ? t("quiz.passed") : t("quiz.failed") %>
    </div>
    <div style="font-size:15px; font-weight:600; opacity:0.85; margin-top:2px;"><%= t("quiz.your_score", earned: @attempt.earned_points, total: @attempt.total_points) %></div>
    <div style="font-size:12px; opacity:0.6; margin-top:6px;">
      <%= @attempt.participant_name %> · <%= @attempt.participant_email %>
    </div>
  </div>

  <!-- Stat bar -->
  <div style="display:flex; background:rgba(0,0,0,0.15); border-top:1px solid rgba(255,255,255,0.12);">
    <div style="flex:1; padding:12px; text-align:center; border-right:1px solid rgba(255,255,255,0.12);">
      <div style="font-size:22px; font-weight:900; color:#fff;"><%= correct_count %></div>
      <div style="font-size:10px; font-weight:600; color:rgba(255,255,255,0.7); margin-top:1px;"><%= t("quiz.correct_answers") %></div>
    </div>
    <div style="flex:1; padding:12px; text-align:center; border-right:1px solid rgba(255,255,255,0.12);">
      <div style="font-size:22px; font-weight:900; color:#fff;"><%= wrong_count %></div>
      <div style="font-size:10px; font-weight:600; color:rgba(255,255,255,0.7); margin-top:1px;"><%= t("quiz.wrong_answers") %></div>
    </div>
    <div style="flex:1; padding:12px; text-align:center;">
      <div style="font-size:22px; font-weight:900; color:#fff;"><%= @attempt.total_questions %></div>
      <div style="font-size:10px; font-weight:600; color:rgba(255,255,255,0.7); margin-top:1px;"><%= t("quiz.total_questions") %></div>
    </div>
  </div>
</div>

<!-- Answer Review -->
<% if @quiz_set.result_immediate? || @quiz_set.show_answers? %>
<div class="r-card" style="animation-delay:.1s;">
  <h3 style="font-size:14px; font-weight:800; color:#1E293B; margin:0 0 12px;">📋 <%= t("quiz.review_answers") %></h3>
  <% answers_by_q = @attempt.quiz_attempt_answers.includes(:quiz_option).group_by(&:quiz_question_id) %>
  <% @quiz_set.quiz_questions.includes(:quiz_options).each_with_index do |q, i| %>
    <% my_answers = answers_by_q[q.id] || [] %>
    <% is_correct = my_answers.any?(&:is_correct?) %>
    <% selected_ids = my_answers.map(&:quiz_option_id).compact %>
    <% row_cls = q.short_answer? ? 'r-manual' : (is_correct ? 'r-correct' : 'r-wrong') %>
    <div class="r-q <%= row_cls %>">
      <div class="r-q-header">
        <% if q.short_answer? %>
          <span style="font-size:16px; flex-shrink:0;">📝</span>
        <% elsif is_correct %>
          <div style="width:22px; height:22px; border-radius:50%; background:#10B981; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px;">
            <svg width="12" height="12" fill="none" stroke="#fff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
          </div>
        <% else %>
          <div style="width:22px; height:22px; border-radius:50%; background:#EF4444; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px;">
            <svg width="12" height="12" fill="none" stroke="#fff" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/></svg>
          </div>
        <% end %>
        <p style="font-size:13px; font-weight:600; color:#1E293B; margin:0; line-height:1.5;"><%= i + 1 %>. <%= q.question_text %></p>
      </div>
      <div class="r-q-body">
        <% if q.short_answer? %>
          <% text_ans = my_answers.first&.text_answer %>
          <% if text_ans.present? %>
            <div style="font-size:13px; color:#374151; background:#FFFBEB; border:1px solid #FDE68A; border-radius:8px; padding:10px 12px; margin-bottom:6px;"><%= text_ans %></div>
          <% else %>
            <p style="font-size:12px; color:#94A3B8; font-style:italic; margin:0 0 6px;">Không có câu trả lời</p>
          <% end %>
          <p style="font-size:11px; color:#D97706; margin:0;">✏️ Câu tự luận — giáo viên chấm thủ công</p>
        <% else %>
          <% q.quiz_options.each do |opt| %>
            <% i_sel = selected_ids.include?(opt.id) %>
            <% opt_cls = opt.is_correct? ? 'r-opt-correct' : (i_sel ? 'r-opt-wrong' : 'r-opt-neutral') %>
            <div class="r-opt <%= opt_cls %>">
              <% if opt.is_correct? %>
                <svg width="14" height="14" fill="none" stroke="#10B981" viewBox="0 0 24 24" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              <% elsif i_sel %>
                <svg width="14" height="14" fill="none" stroke="#EF4444" viewBox="0 0 24 24" style="flex-shrink:0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
              <% else %>
                <div style="width:14px; height:14px; flex-shrink:0;"></div>
              <% end %>
              <span style="flex:1;"><%= opt.option_text %></span>
              <% if opt.is_correct? %>
                <span style="font-size:10px; background:#D1FAE5; color:#065F46; font-weight:700; padding:1px 6px; border-radius:4px;"><%= t("quiz.correct") %></span>
              <% elsif i_sel %>
                <span style="font-size:10px; background:#FEE2E2; color:#991B1B; font-weight:700; padding:1px 6px; border-radius:4px;"><%= t("quiz.your_answer") %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
        <% if q.explanation.present? %>
          <div style="margin-top:8px; font-size:11px; color:#94A3B8; font-style:italic; display:flex; gap:4px;">
            <span>💡</span><span><%= q.explanation %></span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
<% end %>

<!-- Actions -->
<div class="r-card" style="animation-delay:.2s; text-align:center; padding-top:8px;">
  <% if @quiz_set.allow_retake? %>
    <%= link_to t("quiz.retake"), quiz_path(@quiz_set.share_token),
        style: "display:inline-block; padding:13px 32px; background:#1e3a5f; color:#fff; font-weight:700; font-size:14px; border-radius:12px; text-decoration:none; margin-bottom:12px;" %>
  <% end %>
  <p style="font-size:12px; color:#94A3B8; margin:0;"><%= t("quiz.completed_by", name: @attempt.participant_name) %></p>
</div>
