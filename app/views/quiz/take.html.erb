<% content_for :title, @quiz_set.title %>

<style>
html, body { background:linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); min-height:100%; scrollbar-width:none; -ms-overflow-style:none; }
html::-webkit-scrollbar, body::-webkit-scrollbar { display:none; }
.q-card { background:#ffffff; border-radius:16px; border:1px solid rgba(99,102,241,0.12); box-shadow:0 4px 16px rgba(99,102,241,0.06); padding:16px 20px; margin-bottom:16px; }
.q-num { width:24px; height:24px; border-radius:50%; background:linear-gradient(135deg,#6366f1,#a855f7); color:#fff; font-size:11px; font-weight:800; display:inline-flex; align-items:center; justify-content:center; flex-shrink:0; }
.q-text { font-size:15px; font-weight:600; color:#1E293B; line-height:1.5; }
.opt-label { display:flex; align-items:center; gap:12px; padding:12px 16px; border-radius:14px; border:2px solid #e2e8f0; background:rgba(255,255,255,0.85); cursor:pointer; margin-bottom:8px; transition:all .15s ease; }
.opt-label:hover { border-color:#a5b4fc; background:rgba(238,240,255,0.5); }
.opt-label input:checked ~ span { color:#4338ca; font-weight:600; }
.opt-label:has(input:checked) { border-color:#6366f1; background:rgba(238,240,255,0.9); }
.opt-dot { flex-shrink:0; width:18px; height:18px; border-radius:50%; border:2px solid #cbd5e1; display:flex; align-items:center; justify-content:center; transition:all .15s; }
.opt-label:has(input[type=radio]:checked) .opt-dot { border-color:#6366f1; background:#6366f1; }
.opt-label:has(input[type=radio]:checked) .opt-dot::after { content:''; width:7px; height:7px; border-radius:50%; background:#fff; }
.opt-box { flex-shrink:0; width:18px; height:18px; border-radius:5px; border:2px solid #cbd5e1; display:flex; align-items:center; justify-content:center; transition:all .15s; }
.opt-label:has(input[type=checkbox]:checked) .opt-box { border-color:#6366f1; background:#6366f1; }
.opt-label:has(input[type=checkbox]:checked) .opt-box::after { content:'✓'; color:#fff; font-size:11px; font-weight:900; }
.short-answer-ta { width:100%; padding:12px; border:2px solid #e2e8f0; border-radius:14px; font-size:14px; font-family:inherit; resize:vertical; outline:none; transition:border-color .15s; box-sizing:border-box; background:rgba(255,255,255,0.85); }
.short-answer-ta:focus { border-color:#6366f1; }
</style>

<div class="min-h-screen flex flex-col" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%)">

  <!-- Progress bar — fixed -->
  <div id="progress-fixed" class="px-4 sm:px-6 py-2.5"
       style="position:fixed; left:0; right:0; z-index:9997;
              background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%);
              border-bottom:1px solid rgba(226,232,240,0.6);
              box-shadow:0 1px 8px rgba(99,102,241,0.06);">
    <div class="max-w-[680px] mx-auto">
      <div class="flex justify-between text-[11px] text-slate-500 mb-1.5">
        <span><span id="answered-count">0</span> / <%= @questions.count %> câu đã trả lời</span>
        <% if @quiz_set.time_limit_minutes.to_i > 0 %>
          <span id="timer" style="font-family:monospace; font-weight:700; color:#1E293B;">--:--</span>
        <% end %>
      </div>
      <div class="h-1.5 bg-white/60 rounded-full overflow-hidden" style="border:1px solid rgba(99,102,241,0.15);">
        <div id="progress-bar" class="h-full rounded-full transition-all duration-500" style="width:0%; background:linear-gradient(90deg,#6366f1,#a855f7);"></div>
      </div>
    </div>
  </div>
  <div id="progress-spacer"></div>
  <script>
    (function() {
      var bar = document.getElementById('progress-fixed');
      var spacer = document.getElementById('progress-spacer');
      function syncProgress() {
        var navH = window.innerWidth >= 640 ? 57 : 47;
        bar.style.top = navH + 'px';
        spacer.style.height = bar.offsetHeight + 'px';
      }
      syncProgress();
      window.addEventListener('resize', syncProgress);
      window.addEventListener('load', syncProgress);
    })();
  </script>

  <!-- Quiz header -->
  <div class="border-b" style="background:linear-gradient(135deg,#f8faff 0%,#f0f4ff 50%,#faf5ff 100%); border-color:rgba(226,232,240,0.7);">
    <div class="max-w-[680px] mx-auto px-4 py-5 text-center">
      <h1 class="text-[18px] font-extrabold text-slate-900 tracking-tight leading-snug mb-1"><%= @quiz_set.title %></h1>
      <span class="text-[11px] text-slate-400"><%= @questions.count %> câu hỏi</span>
    </div>
  </div>

  <!-- Content -->
  <div class="flex-1 flex flex-col px-2 sm:px-4 py-4">
    <div class="max-w-[680px] mx-auto w-full px-1 sm:px-4 pt-4 pb-5">

      <form action="<%= submit_quiz_path(@quiz_set.share_token, attempt_id: @attempt.id) %>" method="post" id="quiz-form" class="space-y-4">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <input type="hidden" name="time_spent" id="time-spent-input" value="0">

        <% @questions.each_with_index do |q, i| %>
          <div class="q-card" id="question-<%= q.id %>">
            <div class="flex items-start gap-3 mb-4">
              <span class="q-num mt-0.5"><%= i + 1 %></span>
              <p class="q-text"><%= q.question_text %></p>
            </div>
            <% if q.short_answer? %>
              <textarea name="answers[<%= q.id %>]" rows="3" class="short-answer-ta"
                        data-qid="<%= q.id %>" data-qtype="short"
                        placeholder="<%= t('quiz.type_your_answer') %>"
                        onchange="onAnswer(<%= q.id %>); saveAnswer(this)"
                        oninput="onAnswer(<%= q.id %>)"></textarea>
            <% elsif q.allow_multiple %>
              <p class="text-[11px] text-slate-400 mb-2"><%= t('quiz.select_all_correct') %></p>
              <% q.quiz_options.each do |opt| %>
                <label class="opt-label">
                  <input type="checkbox" name="answers[<%= q.id %>][]" value="<%= opt.id %>"
                         data-qid="<%= q.id %>" data-qtype="multi"
                         onchange="onAnswer(<%= q.id %>); saveAnswer(this)"
                         class="hidden">
                  <span class="opt-box"></span>
                  <span style="font-size:14px; color:#334155;"><%= opt.option_text %></span>
                </label>
              <% end %>
            <% else %>
              <% q.quiz_options.each do |opt| %>
                <label class="opt-label">
                  <input type="radio" name="answers[<%= q.id %>]" value="<%= opt.id %>"
                         data-qid="<%= q.id %>" data-qtype="single"
                         onchange="onAnswer(<%= q.id %>); saveAnswer(this)"
                         class="hidden">
                  <span class="opt-dot"></span>
                  <span style="font-size:14px; color:#334155;"><%= opt.option_text %></span>
                </label>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <div class="pt-4 pb-10">
          <button type="button" onclick="submitQuiz()"
                  class="w-full py-3 text-[14px] font-semibold text-white rounded-lg transition-all"
                  style="background:linear-gradient(135deg,#6366f1,#a855f7); border:0; box-shadow:0 2px 8px rgba(99,102,241,0.25);">
            <%= t("quiz.submit") %>
          </button>
        </div>
      </form>

    </div>
  </div>
</div>

<!-- Submit confirm modal -->
<div id="submit-modal" style="display:none; position:fixed; inset:0; z-index:50; align-items:center; justify-content:center; padding:16px; background:rgba(15,23,42,0.55);">
  <div style="background:#fff; border-radius:20px; box-shadow:0 8px 32px rgba(0,0,0,0.18); width:100%; max-width:360px; padding:28px 24px; text-align:center;">
    <div style="font-size:40px; margin-bottom:12px;">📬</div>
    <h3 style="font-size:17px; font-weight:800; color:#1E293B; margin:0 0 8px;"><%= t("quiz.confirm_submit") %></h3>
    <p style="font-size:13px; color:#64748B; margin:0 0 20px;" id="submit-modal-desc"></p>
    <div style="display:flex; gap:8px;">
      <button onclick="confirmSubmit()"
              style="flex:1; padding:12px; background:linear-gradient(135deg,#6366f1,#a855f7); color:#fff; font-weight:700; font-size:14px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">
        <%= t("quiz.yes_submit") %>
      </button>
      <button onclick="closeSubmitModal()"
              style="flex:1; padding:12px; background:#F1F5F9; color:#475569; font-weight:600; font-size:14px; border:none; border-radius:12px; cursor:pointer; font-family:inherit;">
        <%= t("common.cancel") %>
      </button>
    </div>
  </div>
</div>

<script>
const TOTAL = <%= @questions.count %>;
const CSRF  = document.querySelector('meta[name="csrf-token"]').content;
const SAVE_URL = '<%= save_quiz_answer_path(@quiz_set.share_token, attempt_id: @attempt.id) %>';
const ATTEMPT_ID = <%= @attempt.id %>;

let answered  = new Set();
let pageStart = Date.now();
let timerInterval;

function onAnswer(qid) {
  answered.add(qid);
  document.getElementById('answered-count').textContent = answered.size;
  document.getElementById('progress-bar').style.width = (answered.size / TOTAL * 100) + '%';
}

// ── Auto-save ────────────────────────────────────────────────────────────────
let _saveQueue = {};
let _saveTimer = null;
function saveAnswer(el) {
  const qid   = el.dataset.qid;
  const qtype = el.dataset.qtype;
  _saveQueue[qid] = { qid, qtype, el };
  clearTimeout(_saveTimer);
  _saveTimer = setTimeout(flushSaveQueue, 600);
}
function flushSaveQueue() {
  Object.values(_saveQueue).forEach(({ qid, qtype, el }) => {
    const body = new URLSearchParams({ authenticity_token: CSRF, question_id: qid });
    if (qtype === 'short') {
      body.append('text_answer', el.value);
    } else if (qtype === 'multi') {
      const allChecked = document.querySelectorAll(`input[data-qid="${qid}"][data-qtype="multi"]:checked`);
      allChecked.forEach(cb => body.append('option_ids[]', cb.value));
    } else {
      body.append('option_id', el.value);
    }
    fetch(SAVE_URL, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' }, body: body.toString() });
  });
  _saveQueue = {};
}

// ── Submit ───────────────────────────────────────────────────────────────────
function submitQuiz() {
  const unanswered = TOTAL - answered.size;
  document.getElementById('submit-modal-desc').textContent =
    unanswered > 0
      ? '<%= j t("quiz.unanswered_warning") %>'.replace('{n}', unanswered)
      : '<%= j t("quiz.all_answered") %>';
  document.getElementById('submit-modal').style.display = 'flex';
}
function closeSubmitModal() {
  document.getElementById('submit-modal').style.display = 'none';
}
function confirmSubmit() {
  clearInterval(timerInterval);
  const elapsed = Math.round((Date.now() - pageStart) / 1000);
  document.getElementById('time-spent-input').value = elapsed;
  document.getElementById('quiz-form').submit();
}

// ── Timer (server-side remaining) ────────────────────────────────────────────
<% if @quiz_set.time_limit_minutes.to_i > 0 && @remaining_seconds %>
let remaining = <%= @remaining_seconds %>;
const timerEl = document.getElementById('timer');
function renderTimer(sec) {
  const m = Math.floor(sec / 60).toString().padStart(2, '0');
  const s = (sec % 60).toString().padStart(2, '0');
  timerEl.textContent = m + ':' + s;
  timerEl.style.color = sec <= 60 ? '#DC2626' : '#1E293B';
}
renderTimer(remaining);
timerInterval = setInterval(function() {
  remaining--;
  renderTimer(remaining);
  if (remaining <= 0) {
    clearInterval(timerInterval);
    confirmSubmit();
  }
}, 1000);
<% elsif @quiz_set.time_limit_minutes.to_i > 0 %>
<%# Fallback: no started_at stored yet — show full limit %>
let remaining = <%= @quiz_set.time_limit_minutes * 60 %>;
const timerEl = document.getElementById('timer');
function renderTimer(sec) {
  const m = Math.floor(sec / 60).toString().padStart(2, '0');
  const s = (sec % 60).toString().padStart(2, '0');
  timerEl.textContent = m + ':' + s;
  timerEl.style.color = sec <= 60 ? '#DC2626' : '#1E293B';
}
renderTimer(remaining);
timerInterval = setInterval(function() {
  remaining--;
  renderTimer(remaining);
  if (remaining <= 0) { clearInterval(timerInterval); confirmSubmit(); }
}, 1000);
<% end %>

// ── Restore existing answers from server ─────────────────────────────────────
<% @existing_answers.each do |qid, answers| %>
  <% first = answers.first %>
  <% if first.text_answer.present? %>
    (function() {
      const ta = document.querySelector('textarea[data-qid="<%= qid %>"]');
      if (ta) { ta.value = <%= first.text_answer.to_json %>; onAnswer(<%= qid %>); }
    })();
  <% else %>
    (function() {
      let restored = false;
      <% answers.each do |ans| %>
        <% if ans.quiz_option_id %>
          (function() {
            const inp = document.querySelector('input[name="answers[<%= qid %>]"][value="<%= ans.quiz_option_id %>"]') ||
                        document.querySelector('input[name="answers[<%= qid %>][]"][value="<%= ans.quiz_option_id %>"]');
            if (inp) { inp.checked = true; restored = true; }
          })();
        <% end %>
      <% end %>
      if (restored) onAnswer(<%= qid %>);
    })();
  <% end %>
<% end %>
</script>
