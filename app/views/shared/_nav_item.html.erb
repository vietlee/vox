<% active = request.path.start_with?(path.gsub(/\?.*$/, '')) %>
<%= link_to path, class: "flex items-center gap-2.5 px-5 py-2 text-[13px] font-medium transition-all border-l-[3px] #{active ? 'text-white bg-indigo-500/[0.12] border-indigo-500' : 'text-slate-400 hover:text-white hover:bg-white/[0.04] border-transparent'}" do %>
  <span class="text-[15px] w-[18px] text-center flex-shrink-0"><%= icon %></span>
  <span class="sidebar-label"><%= label %></span>
  <% if local_assigns[:badge].to_i > 0 %>
    <span class="ml-auto bg-indigo-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full"><%= badge %></span>
  <% end %>
<% end %>
