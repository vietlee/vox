<p style="margin:0 0 8px;font-size:22px;font-weight:800;color:#0f172a;">Chào mừng đến với Vox! 👋</p>
<p style="margin:0 0 28px;font-size:15px;color:#64748b;">Xin chào <strong style="color:#0f172a;"><%= @admin.name %></strong>, workspace của bạn đã được tạo thành công.</p>

<!-- Workspace + credentials box -->
<table cellpadding="0" cellspacing="0" width="100%" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:28px;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 12px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.8px;">Workspace</p>
      <p style="margin:0 0 20px;font-size:18px;font-weight:800;color:#0f172a;"><%= @workspace.name %></p>

      <p style="margin:0 0 12px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.8px;">Thông tin đăng nhập</p>
      <table cellpadding="0" cellspacing="0">
        <tr>
          <td style="font-size:13px;color:#64748b;padding-bottom:8px;padding-right:16px;">Email</td>
          <td style="font-size:13px;font-weight:600;color:#0f172a;padding-bottom:8px;"><%= @admin.email %></td>
        </tr>
        <tr>
          <td style="font-size:13px;color:#64748b;padding-right:16px;">Mật khẩu tạm thời</td>
          <td>
            <span style="font-size:15px;font-weight:700;color:#4f46e5;font-family:monospace;background:#ede9fe;padding:3px 10px;border-radius:6px;"><%= @password %></span>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 24px;font-size:14px;color:#64748b;">Vui lòng đổi mật khẩu ngay sau khi đăng nhập lần đầu.</p>

<!-- CTA Button -->
<table cellpadding="0" cellspacing="0">
  <tr>
    <td style="background:#4f46e5;border-radius:8px;">
      <a href="<%= new_user_session_url(host: ENV.fetch('APP_HOST', 'localhost:3000'), protocol: ENV['APP_HOST'].present? ? 'https' : 'http') %>"
         style="display:inline-block;padding:12px 28px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        Bắt đầu ngay →
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0;font-size:12px;color:#cbd5e1;">Nếu bạn không đăng ký tài khoản này, hãy bỏ qua email.</p>
