<!-- Header -->
<p style="margin:0 0 6px;font-size:22px;font-weight:800;color:#0f172a;">🏢 Workspace mới được tạo</p>
<p style="margin:0 0 28px;font-size:15px;color:#64748b;">Một workspace vừa được đăng ký trên <strong style="color:#4f46e5;">VOX</strong>.</p>

<!-- Workspace info box -->
<table cellpadding="0" cellspacing="0" width="100%" style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;margin-bottom:24px;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 4px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.8px;">Workspace</p>
      <p style="margin:0 0 20px;font-size:20px;font-weight:800;color:#0f172a;"><%= @workspace.name %></p>

      <p style="margin:0 0 4px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.8px;">Admin đăng ký</p>
      <table cellpadding="0" cellspacing="0" style="margin-bottom:16px;">
        <tr>
          <td style="font-size:13px;color:#64748b;padding-bottom:6px;padding-right:16px;">Tên</td>
          <td style="font-size:13px;font-weight:600;color:#0f172a;padding-bottom:6px;"><%= @admin_user.name %></td>
        </tr>
        <tr>
          <td style="font-size:13px;color:#64748b;padding-right:16px;">Email</td>
          <td style="font-size:13px;font-weight:600;color:#0f172a;"><%= @admin_user.email %></td>
        </tr>
      </table>

      <p style="margin:0 0 4px;font-size:11px;font-weight:700;color:#94a3b8;text-transform:uppercase;letter-spacing:0.8px;">Thời gian</p>
      <p style="margin:0;font-size:13px;color:#0f172a;font-weight:600;"><%= @workspace.created_at.in_time_zone("Asia/Ho_Chi_Minh").strftime("%d/%m/%Y %H:%M") %></p>
    </td>
  </tr>
</table>

<!-- Stats row -->
<table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:24px;">
  <tr>
    <td width="50%" style="padding-right:6px;">
      <table cellpadding="0" cellspacing="0" width="100%" style="background:#ede9fe;border-radius:8px;">
        <tr>
          <td style="padding:14px 18px;">
            <p style="margin:0 0 2px;font-size:11px;font-weight:700;color:#7c3aed;text-transform:uppercase;letter-spacing:0.6px;">Gói hiện tại</p>
            <p style="margin:0;font-size:16px;font-weight:800;color:#4f46e5;">FREE</p>
          </td>
        </tr>
      </table>
    </td>
    <td width="50%" style="padding-left:6px;">
      <table cellpadding="0" cellspacing="0" width="100%" style="background:#f0fdf4;border-radius:8px;">
        <tr>
          <td style="padding:14px 18px;">
            <p style="margin:0 0 2px;font-size:11px;font-weight:700;color:#16a34a;text-transform:uppercase;letter-spacing:0.6px;">Trạng thái</p>
            <p style="margin:0;font-size:16px;font-weight:800;color:#15803d;">Active ✓</p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- CTA -->
<table cellpadding="0" cellspacing="0">
  <tr>
    <td style="background:#4f46e5;border-radius:8px;">
      <a href="<%= "#{@protocol}://#{@app_host}/super_admin/workspaces/#{@workspace.id}" %>"
         style="display:inline-block;padding:12px 28px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        Xem trong Super Admin →
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0;font-size:12px;color:#cbd5e1;">Email này được gửi tự động từ hệ thống VOX.</p>
