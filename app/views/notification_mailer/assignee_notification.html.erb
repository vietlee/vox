<!-- Header -->
<p style="margin:0 0 6px;font-size:22px;font-weight:800;color:#0f172a;">
  👋 Bạn có yêu cầu mới được assign
</p>
<p style="margin:0 0 24px;font-size:15px;color:#64748b;">
  Xin chào <strong style="color:#0f172a;"><%= @assignee.name.presence || @assignee.email %></strong>,
  một yêu cầu mới từ form <strong style="color:#4f46e5;"><%= @form.title %></strong> vừa được giao cho bạn xử lý.
</p>

<!-- Submission card -->
<table cellpadding="0" cellspacing="0" width="100%"
       style="background:#f8faff;border:1.5px solid #e0e7ff;border-radius:12px;margin-bottom:24px;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 6px;font-size:13px;font-weight:700;color:#0f172a;">
        Tên yêu cầu: <span style="color:#4f46e5;"><%= @form.title %></span>
      </p>
      <p style="margin:0;font-size:12px;color:#64748b;">
        Nhận lúc: <%= I18n.l(@submission.created_at, format: :short) %>
      </p>
    </td>
  </tr>
</table>

<!-- CTA -->
<table cellpadding="0" cellspacing="0">
  <tr>
    <td style="background:#4f46e5;border-radius:8px;">
      <a href="<%= @review_url %>"
         style="display:inline-block;padding:12px 28px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        Xem yêu cầu →
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0;font-size:12px;color:#94a3b8;">
  Bạn nhận được email này vì được giao xử lý yêu cầu trên VOX.
</p>
