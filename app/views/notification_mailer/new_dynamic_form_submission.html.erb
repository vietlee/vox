<!-- Header -->
<p style="margin:0 0 6px;font-size:22px;font-weight:800;color:#0f172a;">
  📝 Submission mới
</p>
<p style="margin:0 0 24px;font-size:15px;color:#64748b;">
  Form <strong style="color:#0f172a;"><%= @form.title %></strong> vừa nhận được một submission mới.
</p>

<!-- Submission card -->
<table cellpadding="0" cellspacing="0" width="100%"
       style="background:#f8faff;border:1.5px solid #e0e7ff;border-radius:12px;margin-bottom:24px;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 14px;font-size:11px;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;">
        Thời gian nhận: <%= @submitted_at %>
      </p>
      <% @form.dynamic_form_fields.each do |field| %>
        <% val = @submission.value_for(field.field_key) %>
        <% next if val.blank? || (val.is_a?(Array) && val.empty?) %>
        <table cellpadding="0" cellspacing="0" width="100%" style="margin-bottom:12px;">
          <tr>
            <td>
              <p style="margin:0 0 3px;font-size:11px;font-weight:700;color:#6366f1;text-transform:uppercase;letter-spacing:0.4px;">
                <%= field.label %>
              </p>
              <% display = val.is_a?(Array) ? val.join(", ") : (val.is_a?(Hash) ? val["filename"].to_s : val.to_s) %>
              <p style="margin:0;font-size:13px;color:#1e293b;line-height:1.6;
                        padding:10px 14px;background:white;border-radius:8px;border:1px solid #e2e8f0;">
                <% if val.is_a?(Hash) && val["filename"].present? %>
                  📎 <%= val["filename"] %>
                <% else %>
                  <%= display %>
                <% end %>
              </p>
            </td>
          </tr>
        </table>
      <% end %>
    </td>
  </tr>
</table>

<!-- CTA -->
<table cellpadding="0" cellspacing="0">
  <tr>
    <td style="background:#4f46e5;border-radius:8px;">
      <a href="<%= @review_url %>"
         style="display:inline-block;padding:12px 28px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        Xem tất cả submissions →
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0;font-size:12px;color:#94a3b8;">
  Bạn nhận được email này vì được phân công quản lý form <em><%= @form.title %></em> trên VOX.
</p>
