<% locale = @workspace.language&.to_sym || :vi %>

<!-- Header -->
<p style="margin:0 0 6px;font-size:22px;font-weight:800;color:#0f172a;">
  📋 <%= I18n.t("notification_mailer.new_response.heading", locale: locale) %>
</p>
<p style="margin:0 0 28px;font-size:15px;color:#64748b;">
  <%= I18n.t("notification_mailer.new_response.intro",
        survey: "<strong style='color:#0f172a;'>#{@survey.title}</strong>",
        workspace: "<strong>#{@workspace.name}</strong>",
        locale: locale).html_safe %>
</p>

<!-- Response info card -->
<table cellpadding="0" cellspacing="0" width="100%"
       style="background:#f8faff;border:1.5px solid #e0e7ff;border-radius:12px;margin-bottom:24px;">
  <tr>
    <td style="padding:20px 24px;">
      <table cellpadding="0" cellspacing="0" width="100%">
        <tr>
          <td style="font-size:13px;color:#64748b;padding-bottom:10px;padding-right:16px;width:40%;">
            <%= I18n.t("notification_mailer.new_response.respondent", locale: locale) %>
          </td>
          <td style="font-size:13px;font-weight:600;color:#1e293b;padding-bottom:10px;">
            <% if @response.respondent_email.present? %>
              <%= @response.respondent_email %>
            <% elsif @response.user_id.present? %>
              <%= User.find_by(id: @response.user_id)&.email || I18n.t("participate.feedback.anonymous", locale: locale) %>
            <% else %>
              <%= I18n.t("participate.feedback.anonymous", locale: locale) %>
            <% end %>
          </td>
        </tr>
        <tr>
          <td style="font-size:13px;color:#64748b;padding-bottom:10px;padding-right:16px;">
            <%= I18n.t("notification_mailer.new_response.submitted_at", locale: locale) %>
          </td>
          <td style="font-size:13px;font-weight:600;color:#1e293b;padding-bottom:10px;">
            <%= I18n.l(@response.completed_at&.in_time_zone(@workspace.timezone) || @response.updated_at, format: :short) rescue @response.updated_at.strftime("%d/%m/%Y %H:%M") %>
          </td>
        </tr>
        <tr>
          <td style="font-size:13px;color:#64748b;padding-right:16px;">
            <%= I18n.t("notification_mailer.new_response.total_responses", locale: locale) %>
          </td>
          <td style="font-size:13px;font-weight:700;color:#4f46e5;">
            <%= @survey.response_count %> <%= I18n.t("notification_mailer.new_response.responses_unit", locale: locale) %>
          </td>
        </tr>
        <% if @response.completion_time_seconds.to_i > 0 %>
          <tr>
            <td style="font-size:13px;color:#64748b;padding-top:10px;padding-right:16px;">
              <%= I18n.t("notification_mailer.new_response.completion_time", locale: locale) %>
            </td>
            <td style="font-size:13px;color:#64748b;padding-top:10px;">
              <% secs = @response.completion_time_seconds.to_i %>
              <%= secs < 60 ? "#{secs}s" : "#{(secs/60.0).round(1)} phút" %>
            </td>
          </tr>
        <% end %>
      </table>
    </td>
  </tr>
</table>

<!-- CTA -->
<table cellpadding="0" cellspacing="0">
  <tr>
    <td style="background:#4f46e5;border-radius:8px;">
      <a href="<%= @results_url %>"
         style="display:inline-block;padding:12px 28px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        <%= I18n.t("notification_mailer.new_response.cta", locale: locale) %> →
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0;font-size:12px;color:#94a3b8;">
  <%= I18n.t("notification_mailer.unsubscribe_hint", locale: locale) %>
</p>
