<p style="margin:0 0 8px;font-size:22px;font-weight:800;color:#0f172a;">Thanh toán thành công ✅</p>
<p style="margin:0 0 28px;font-size:15px;color:#64748b;">Xin chào <strong style="color:#0f172a;"><%= @admin.name %></strong>, gói dịch vụ của bạn đã được kích hoạt.</p>

<table cellpadding="0" cellspacing="0" width="100%" style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;margin-bottom:28px;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 12px;font-size:11px;font-weight:700;color:#166534;text-transform:uppercase;letter-spacing:0.8px;">Chi tiết thanh toán</p>
      <table cellpadding="0" cellspacing="0">
        <tr>
          <td style="font-size:13px;color:#166534;padding-bottom:8px;padding-right:16px;">Workspace</td>
          <td style="font-size:13px;font-weight:600;color:#14532d;padding-bottom:8px;"><%= @workspace.name %></td>
        </tr>
        <tr>
          <td style="font-size:13px;color:#166534;padding-bottom:8px;padding-right:16px;">Gói</td>
          <td style="font-size:13px;font-weight:600;color:#14532d;padding-bottom:8px;"><%= @payment.subscription.plan.upcase %></td>
        </tr>
        <tr>
          <td style="font-size:13px;color:#166534;padding-right:16px;">Số tiền</td>
          <td style="font-size:15px;font-weight:800;color:#14532d;"><%= number_to_currency(@payment.amount, unit: "₫", format: "%n %u", delimiter: ".") %></td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 24px;font-size:14px;color:#64748b;">Cảm ơn bạn đã tin dùng Vox!</p>

<table cellpadding="0" cellspacing="0">
  <tr>
    <td style="background:#4f46e5;border-radius:8px;">
      <a href="<%= subscription_url(host: ENV.fetch('APP_HOST', 'localhost:3000'), protocol: ENV['APP_HOST'].present? ? 'https' : 'http') %>"
         style="display:inline-block;padding:12px 28px;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;">
        Xem subscription →
      </a>
    </td>
  </tr>
</table>
