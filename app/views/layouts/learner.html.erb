  <style>@keyframes aip-spin { to { transform: rotate(360deg); } }</style>
  <script>
  window.AiProgress = (function() {
    var _pct = 0, _ticker, _msgInt, _msgIdx = 0;
    var _msgs = [], _minimized = false, _toastTimer;
    var _SS = 'aip_state';

    function $id(id) { return document.getElementById(id); }

    function setBar(p) {
      _pct = p;
      var r = Math.round(p);
      $id('aip-bar').style.width = p + '%';
      $id('aip-pct').textContent  = r + '%';
      $id('aip-mini-pct').textContent = r + '%';
    }

    function cycleMsg() {
      if (_msgs.length) $id('aip-msg').textContent = _msgs[_msgIdx++ % _msgs.length];
    }

    // Restore minimized pill immediately — this script runs after body elements
    // are in DOM (Turbo re-executes scripts after body-swap, so turbo:load has
    // already fired by the time we get here; direct DOM access is the only
    // reliable way to restore state on every navigation).
    (function() {
      try {
        var saved = JSON.parse(sessionStorage.getItem(_SS) || 'null');
        if (saved && saved.minimized) {
          _minimized = true;
          var mini = document.getElementById('aip-mini');
          if (mini) {
            var lbl = document.getElementById('aip-mini-label');
            var pct = document.getElementById('aip-mini-pct');
            if (lbl) lbl.textContent = saved.label || 'Đang tạo...';
            if (pct) pct.textContent = '...';
            mini.style.display = 'flex';
          }
        }
      } catch(e) {}
    })();

    return {
      start: function(opts) {
        _minimized = false; _pct = 0; _msgIdx = 0;
        _msgs = opts.msgs || [];
        try { sessionStorage.removeItem(_SS); } catch(e) {}
        setBar(0);
        $id('aip-title').textContent = opts.title || 'Đang tạo...';
        $id('aip-mini-label').textContent = opts.miniLabel || opts.title || 'Đang tạo...';
        cycleMsg();
        clearInterval(_ticker); clearInterval(_msgInt);
        _ticker = setInterval(function() { setBar(_pct + (95 - _pct) * 0.036); }, 400);
        _msgInt = setInterval(cycleMsg, 2200);
        $id('aip-overlay').style.display = 'flex';
        $id('aip-mini').style.display    = 'none';
        $id('aip-toast').style.display   = 'none';
      },

      minimize: function() {
        _minimized = true;
        $id('aip-overlay').style.display = 'none';
        $id('aip-mini').style.display    = 'flex';
        try { sessionStorage.setItem(_SS, JSON.stringify({ minimized: true, label: $id('aip-mini-label').textContent })); } catch(e) {}
      },

      expand: function() {
        _minimized = false;
        try { sessionStorage.removeItem(_SS); } catch(e) {}
        $id('aip-overlay').style.display = 'flex';
        $id('aip-mini').style.display    = 'none';
      },

      setProgress: function(pct, msg) {
        if (msg) $id('aip-msg').textContent = msg;
        if (pct <= _pct) return; // never let the bar go backward
        clearInterval(_ticker);
        setBar(pct);
        _ticker = setInterval(function() { setBar(_pct + (95 - _pct) * 0.036); }, 400);
      },

      done: function(url, label) {
        clearInterval(_ticker); clearInterval(_msgInt);
        try { sessionStorage.removeItem(_SS); } catch(e) {}
        if (_minimized) {
          setBar(100);
          $id('aip-mini').style.display = 'none';
          var lnk = $id('aip-toast-link');
          lnk.onclick = null;              // clear any stale inline handler
          lnk.href = url;
          lnk.textContent = (label || 'Mở ngay') + ' →';
          var t = $id('aip-toast'); t.style.display = 'block';
          var bar = $id('aip-toast-bar');
          bar.style.transition = 'none'; bar.style.width = '100%';
          setTimeout(function() { bar.style.transition = 'width 8s linear'; bar.style.width = '0%'; }, 60);
          clearTimeout(_toastTimer);
          _toastTimer = setTimeout(function() { AiProgress.dismissToast(); }, 8200);
        } else {
          setBar(100);
          $id('aip-msg').textContent = 'Hoàn tất!';
          setTimeout(function() { window.location = url; }, 500);
        }
      },

      // Inline completion: result appears on the SAME page (no redirect). `reveal`
      // is a callback that shows the inline result. Supports minimize while on-page.
      finishInline: function(reveal, label) {
        clearInterval(_ticker); clearInterval(_msgInt);
        try { sessionStorage.removeItem(_SS); } catch(e) {}
        setBar(100);
        if (_minimized) {
          $id('aip-mini').style.display = 'none';
          var lnk = $id('aip-toast-link');
          lnk.href = '#';
          lnk.textContent = (label || 'Xem kết quả') + ' →';
          lnk.onclick = function(e) { e.preventDefault(); AiProgress.dismissToast(); try { if (reveal) reveal(); } catch(_){} };
          var t = $id('aip-toast'); t.style.display = 'block';
          var bar = $id('aip-toast-bar');
          bar.style.transition = 'none'; bar.style.width = '100%';
          setTimeout(function() { bar.style.transition = 'width 8s linear'; bar.style.width = '0%'; }, 60);
          clearTimeout(_toastTimer);
          _toastTimer = setTimeout(function() { AiProgress.dismissToast(); }, 8200);
        } else {
          $id('aip-overlay').style.display = 'none';
          $id('aip-mini').style.display    = 'none';
          try { if (reveal) reveal(); } catch(_){}
        }
      },

      error: function() {
        clearInterval(_ticker); clearInterval(_msgInt);
        _minimized = false;
        try { sessionStorage.removeItem(_SS); } catch(e) {}
        $id('aip-overlay').style.display = 'none';
        $id('aip-mini').style.display    = 'none';
      },

      isMinimized: function() { return _minimized; },

      dismissToast: function() {
        clearTimeout(_toastTimer);
        $id('aip-toast').style.display = 'none';
      }
    };
  })();
  </script>

