<!DOCTYPE html>
<html lang="vi" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#6366f1">
  <title><%= content_for?(:title) ? "#{yield :title} · VOX Learn" : "VOX Learn" %></title>
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  <style>
    :root {
      --lp-purple: #6366f1;
      --lp-purple-dark: #4f46e5;
      --lp-purple-light: #a5b4fc;
      --lp-bg: #f8f7ff;
      --lp-card: #ffffff;
      --lp-text: #1e1b4b;
      --lp-muted: #6b7280;
      --lp-border: #e5e7eb;
      --lp-success: #10b981;
      --lp-warning: #f59e0b;
      --lp-danger: #ef4444;
      --safe-bottom: env(safe-area-inset-bottom, 0px);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; background: var(--lp-bg); font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--lp-text); }
    body { display: flex; flex-direction: column; min-height: 100dvh; }
    .lp-topbar {
      position: sticky; top: 0; z-index: 50;
      background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
      color: white; padding: 0 16px;
      height: 56px; display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 12px rgba(79,70,229,0.25);
    }
    .lp-topbar-logo { font-size: 18px; font-weight: 800; letter-spacing: -0.5px; display: flex; align-items: center; gap: 8px; text-decoration: none; color: white; }
    .lp-topbar-logo span { background: rgba(255,255,255,0.2); border-radius: 8px; padding: 3px 8px; font-size: 13px; }
    .lp-credits-badge { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 20px; padding: 4px 12px; font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 5px; }
    .lp-main { flex: 1; padding-bottom: calc(68px + var(--safe-bottom)); overflow-y: auto; }
    .lp-page { max-width: 680px; margin: 0 auto; padding: 20px 16px; }
    .lp-bottom-nav {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 50;
      background: white; border-top: 1px solid var(--lp-border);
      display: flex; height: calc(60px + var(--safe-bottom));
      padding-bottom: var(--safe-bottom);
      box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
    }
    .lp-nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3px; text-decoration: none; color: var(--lp-muted); font-size: 11px; font-weight: 500; transition: color 0.2s; padding-top: 8px; }
    .lp-nav-item svg { width: 22px; height: 22px; }
    .lp-nav-item.active, .lp-nav-item:hover { color: var(--lp-purple); }
    .lp-nav-item.active svg { stroke-width: 2.5; }
    .lp-card { background: white; border-radius: 16px; box-shadow: 0 1px 8px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04); margin-bottom: 12px; overflow: hidden; }
    .lp-card-header { padding: 16px 16px 12px; border-bottom: 1px solid #f3f4f6; }
    .lp-card-body { padding: 16px; }
    .lp-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .lp-badge-pending   { background: #fef3c7; color: #92400e; }
    .lp-badge-progress  { background: #dbeafe; color: #1e40af; }
    .lp-badge-done      { background: #d1fae5; color: #065f46; }
    .lp-badge-overdue   { background: #fee2e2; color: #991b1b; }
    .lp-btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 10px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; border: none; cursor: pointer; text-decoration: none; transition: all 0.15s; }
    .lp-btn-primary { background: linear-gradient(135deg, #6366f1, #7c3aed); color: white; }
    .lp-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(99,102,241,0.35); }
    .lp-btn-outline { background: white; color: var(--lp-purple); border: 1.5px solid var(--lp-purple); }
    .lp-btn-full { width: 100%; }
    .lp-progress-bar { background: #e5e7eb; border-radius: 99px; height: 8px; overflow: hidden; }
    .lp-progress-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, #6366f1, #8b5cf6); transition: width 0.4s ease; }
    .lp-section-title { font-size: 13px; font-weight: 700; color: var(--lp-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; }
    .lp-alert { padding: 12px 16px; border-radius: 12px; font-size: 14px; margin-bottom: 12px; }
    .lp-alert-success { background: #d1fae5; color: #065f46; }
    .lp-alert-error   { background: #fee2e2; color: #991b1b; }
    .lp-alert-info    { background: #dbeafe; color: #1e40af; }
    @media (min-width: 640px) {
      .lp-page { padding: 28px 24px; }
      .lp-card { border-radius: 20px; margin-bottom: 16px; }
    }
  </style>
  <%= yield :head %>
</head>
<body>
  <%# Top bar — hidden on auth pages %>
  <% if learner_signed_in? %>
  <header class="lp-topbar">
    <%= link_to learner_root_path, class: "lp-topbar-logo" do %>
      <svg width="24" height="24" viewBox="0 0 36 36" fill="none"><rect width="36" height="36" rx="9" fill="white" fill-opacity="0.2"/><polygon points="10,24 6,31 16,24" fill="white"/><rect x="6" y="6" width="24" height="19" rx="5" fill="white" fill-opacity="0.9"/><rect x="10" y="11" width="4" height="7" rx="1" fill="#6366f1"/><rect x="16" y="8" width="4" height="13" rx="1" fill="#6366f1"/><rect x="23" y="10" width="4" height="9" rx="1" fill="#6366f1"/></svg>
      VOX <span>Learn</span>
    <% end %>
    <%= link_to learner_credits_path, class: "lp-credits-badge" do %>
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      <%= current_learner.credits %> credits
    <% end %>
  </header>
  <% end %>

  <main class="lp-main">
    <div class="lp-page">
      <% if notice.present? %>
        <div class="lp-alert lp-alert-success"><%= notice %></div>
      <% end %>
      <% if alert.present? %>
        <div class="lp-alert lp-alert-error"><%= alert %></div>
      <% end %>
      <%= yield %>
    </div>
  </main>

  <% if learner_signed_in? %>
  <nav class="lp-bottom-nav">
    <%= link_to learner_root_path, class: "lp-nav-item #{controller_name == 'dashboard' ? 'active' : ''}" do %>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
      Trang chủ
    <% end %>
    <%= link_to learner_ai_tutor_path, class: "lp-nav-item #{controller_name == 'ai_tutor' ? 'active' : ''}" do %>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
      AI Tutor
    <% end %>
    <%= link_to learner_credits_path, class: "lp-nav-item #{controller_name == 'credits' ? 'active' : ''}" do %>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      Credits
    <% end %>
    <%= link_to learner_profile_path, class: "lp-nav-item #{controller_name == 'profile' ? 'active' : ''}" do %>
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
      Tôi
    <% end %>
  </nav>
  <% end %>
</body>
</html>
