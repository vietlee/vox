<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
  <meta name="theme-color" content="#1e3a5f">
  <title><%= content_for?(:title) ? "#{yield :title} · VOX Learn" : "VOX Learn" %></title>
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/icon.png" type="image/png">
  <%# ── PWA (installable app on phone home screen) ── %>
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="turbo-cache-control" content="no-cache">
  <meta name="apple-mobile-web-app-title" content="VOX">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7029957032076351" crossorigin="anonymous"></script>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload", preload_links_header: false %>
  <%= javascript_importmap_tags %>
  <style>
    :root {
      --lp-purple: #1e3a5f;
      --lp-purple-dark: #16304f;
      --lp-purple-light: #4a7fa8;
      --lp-bg: #f0f4f8;
      --lp-card: #ffffff;
      --lp-text: #1e293b;
      --lp-muted: #6b7280;
      --lp-border: #e5e7eb;
      --lp-success: #10b981;
      --lp-warning: #f59e0b;
      --lp-danger: #ef4444;
      --safe-top: min(env(safe-area-inset-top, 0px), 60px);
      /* Cap at 34px (real iPhone home-indicator max). iOS PWA sometimes reports a
         wildly inflated safe-area-inset-bottom, which blew the bottom nav up into a
         tall bar with a big white area below the icons. min() clamps that. */
      --safe-bottom: min(env(safe-area-inset-bottom, 0px), 34px);
      --topbar-h: calc(56px + var(--safe-top));
      --bottomnav-h: calc(50px + var(--safe-bottom));
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { height: 100%; height: -webkit-fill-available; height: 100dvh; background: var(--lp-bg); }
    body { height: 100%; min-height: -webkit-fill-available; min-height: 100dvh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--lp-text); display: flex; flex-direction: column; background: var(--lp-bg); }
    /* Consistent app canvas on every page so the empty area below short content
       reads as intentional background (not a stark white void). */
    .lp-main { background: var(--lp-bg); }
    .lp-topbar {
      position: sticky; top: 0; z-index: 50; flex-shrink: 0;
      background: linear-gradient(135deg, #1e3a5f 0%, #16304f 100%);
      color: white;
      padding: var(--safe-top) 16px 0;
      height: var(--topbar-h);
      display: flex; align-items: center; justify-content: space-between;
      box-shadow: 0 2px 12px rgba(30,58,95,0.25);
    }
    .lp-topbar-logo { font-size: 18px; font-weight: 800; letter-spacing: -0.5px; display: flex; align-items: center; gap: 8px; text-decoration: none; color: white; }
    .lp-credits-badge { background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); border-radius: 20px; padding: 4px 12px; font-size: 13px; font-weight: 700; display: flex; align-items: center; gap: 4px; color: white; text-decoration: none; }
    /* lp-main is a flex column so the page wrapper can grow to fill the viewport.
       Content stays TOP-aligned (flex-start). */
    .lp-main { flex: 1; display: flex; flex-direction: column; padding-bottom: calc(56px + min(env(safe-area-inset-bottom, 0px), 34px)); overflow-y: auto; }
    /* .lp-page grows to fill the height (as a flex item) but stays block flow, so
       content is top-aligned and inner layouts are untouched. Only pages that opt in
       (body[data-page=...] rules below) become flex columns with an .lp-fill child
       that stretches to remove the empty band above the nav. */
    .lp-page { margin: 0 auto; padding: 20px 16px; max-width: 100%; width: 100%; flex: 1 0 auto; }
    /* Tool/generator pages: replicate the WORKING "Luyện nói" (speaking) page —
       give .lp-page a DEFINITE height via 100dvh (iOS resolves this accurately) so
       flex-fill children actually stretch. With only flex:1 (no definite height),
       iOS flexbox refuses to fill and leaves a white band at the bottom. The page
       scrolls internally if a form is taller than the screen. */
    body[data-page="learner-tools-summarize"] .lp-main,
    body[data-page="learner-tools-tts"] .lp-main,
    body[data-page="learner-tools-stt"] .lp-main,
    body[data-page="learner-study_plans-index"] .lp-main,
    body[data-page="learner-my_quizzes-new"] .lp-main,
    body[data-page="learner-my_quizzes-index"] .lp-main,
    body[data-page="learner-my_flashcards-new"] .lp-main,
    body[data-page="learner-my_flashcards-index"] .lp-main,
    body[data-page="learner-notifications-index"] .lp-main,
    body[data-page="learner-quiz_assignments-show"] .lp-main,
    body[data-page="learner-flashcard_assignments-show"] .lp-main { padding-bottom: 0; overflow: hidden; }
    body[data-page="learner-tools-summarize"] .lp-page,
    body[data-page="learner-tools-tts"] .lp-page,
    body[data-page="learner-tools-stt"] .lp-page,
    body[data-page="learner-study_plans-index"] .lp-page,
    body[data-page="learner-my_quizzes-new"] .lp-page,
    body[data-page="learner-my_quizzes-index"] .lp-page,
    body[data-page="learner-my_flashcards-new"] .lp-page,
    body[data-page="learner-my_flashcards-index"] .lp-page,
    body[data-page="learner-notifications-index"] .lp-page,
    body[data-page="learner-quiz_assignments-show"] .lp-page,
    body[data-page="learner-flashcard_assignments-show"] .lp-page {
      display: flex; flex-direction: column; flex: none;
      height: calc(100dvh - var(--topbar-h) - var(--bottomnav-h));
      overflow-y: auto; -webkit-overflow-scrolling: touch;
    }
    .lp-fill { flex: 1 1 auto; display: flex; flex-direction: column; min-height: 0; }
    /* Generic filler: a transparent flex-grow block pages drop in after their content
       to consume the leftover space, keeping content top-aligned with no bottom gap. */
    .lp-spacer { flex: 1 1 auto; min-height: 0; }
    @media (min-width: 1024px) {
      .lp-page          { max-width: 58.33%; }
      .lp-page-profile  { max-width: 50%; }
      .lp-page-fullwidth{ max-width: 100%; padding: 0; }
    }
    .lp-bottom-nav {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 50;
      background: white; border-top: 1px solid var(--lp-border);
      display: flex; height: calc(56px + min(env(safe-area-inset-bottom, 0px), 34px));
      padding-top: 2px; padding-bottom: min(env(safe-area-inset-bottom, 0px), 34px);
      box-shadow: 0 -4px 20px rgba(0,0,0,0.06);
    }
    @media (min-width: 1024px) {
      .lp-bottom-nav { left: 20.835%; right: 20.835%; border-radius: 16px 16px 0 0; border-left: 1px solid var(--lp-border); border-right: 1px solid var(--lp-border); }
      .lp-tools-sheet-inner { max-width: 58.33%; }
    }
    .lp-nav-item { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; text-decoration: none; color: var(--lp-muted); font-size: 10.5px; font-weight: 500; transition: color 0.2s, background 0.15s, transform 0.1s; padding: 4px 2px; border-radius: 10px; margin: 2px; background: transparent; }
    .lp-nav-item svg { width: 22px; height: 22px; transition: transform 0.15s; }
    @media (hover: hover) {
      .lp-nav-item:hover { color: var(--lp-purple); background: rgba(30,58,95,0.06); }
      .lp-nav-item:hover svg { transform: translateY(-2px); }
    }
    .lp-nav-item:active { transform: scale(0.93); }
    .lp-nav-item.active { color: #1e3a5f; font-weight: 700; }
    .lp-nav-item.active svg { stroke-width: 2.5; }
    .lp-nav-item.active .lp-nav-icon { background: rgba(30,58,95,0.1); border-radius: 8px; padding: 3px 10px; margin-bottom: 1px; }
    .lp-nav-icon { padding: 3px 10px; margin-bottom: 1px; transition: background 0.15s; }
    .lp-card { background: white; border-radius: 16px; box-shadow: 0 1px 8px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04); margin-bottom: 12px; overflow: hidden; }
    .lp-card-header { padding: 16px 16px 12px; border-bottom: 1px solid #f3f4f6; }
    .lp-card-body { padding: 16px; }
    .lp-badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; }
    .lp-badge-pending   { background: #fef3c7; color: #92400e; }
    .lp-badge-progress  { background: #dbeafe; color: #1e40af; }
    .lp-badge-done      { background: #d1fae5; color: #065f46; }
    .lp-badge-overdue   { background: #fee2e2; color: #991b1b; }
    .lp-btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 10px 20px; border-radius: 12px; font-size: 14px; font-weight: 600; border: none; cursor: pointer; text-decoration: none; transition: all 0.15s; }
    .lp-btn-primary { background: #1e3a5f; color: white; }
    .lp-btn-primary:hover { transform: translateY(-1px); box-shadow: 0 4px 12px rgba(30,58,95,0.35); background: #16304f; }
    .lp-btn-outline { background: white; color: var(--lp-purple); border: 1.5px solid var(--lp-purple); }
    .lp-btn-full { width: 100%; }
    /* Compact buttons on mobile (overrides inline padding/font on card action buttons) */
    @media (max-width: 640px) {
      .lp-btn { padding: 8px 12px !important; font-size: 12.5px !important; border-radius: 10px !important; gap: 4px; }
      .lp-btn-full { padding: 12px 14px !important; font-size: 14px !important; }
    }
    .lp-progress-bar { background: #e5e7eb; border-radius: 99px; height: 8px; overflow: hidden; }
    .lp-progress-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, #1e3a5f, #4a7fa8); transition: width 0.4s ease; }
    .lp-section-title { font-size: 13px; font-weight: 700; color: var(--lp-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; }
    /* Hide scrollbars globally while keeping scroll functionality */
    *::-webkit-scrollbar { display: none; }
    * { -ms-overflow-style: none; scrollbar-width: none; }
    /* Breadcrumb */
    .lp-breadcrumb { display:flex;align-items:center;gap:2px;margin-bottom:16px;font-size:13px;overflow-x:auto;scrollbar-width:none;-webkit-overflow-scrolling:touch;flex-wrap:nowrap; }
    .lp-breadcrumb::-webkit-scrollbar { display:none; }
    .lp-bc-link { color:var(--lp-muted);text-decoration:none;white-space:nowrap;padding:5px 8px;border-radius:8px;transition:color .15s,background .15s;display:flex;align-items:center;gap:4px;font-weight:500;flex-shrink:0; }
    .lp-bc-link:hover { color:var(--lp-purple);background:rgba(30,58,95,.06); }
    .lp-bc-sep { color:#d1d5db;font-size:15px;flex-shrink:0;padding:0 1px;user-select:none; }
    .lp-bc-current { color:var(--lp-text);font-weight:600;white-space:nowrap;padding:5px 8px;overflow:hidden;text-overflow:ellipsis;max-width:160px;flex-shrink:1; }
    @media (min-width:640px) { .lp-bc-current { max-width:280px; } }
    @media (min-width:640px) {
      .lp-page { padding: 28px 24px; }
      .lp-card { border-radius: 20px; margin-bottom: 16px; }
    }
  </style>
  <%= yield :head %>
  <%# VOX splash: shows on PWA cold-start, hidden instantly on subsequent Turbo navigations %>
  <style>
    #vox-splash{position:fixed;inset:0;z-index:99999;background:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity .3s ease;}
    html.vox-loaded #vox-splash{display:none!important;}
    #vox-splash.vox-splash-out{opacity:0;pointer-events:none;}
    @keyframes vox-spl-pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.85);opacity:.7}}
    @keyframes vox-spl-dot{0%,80%,100%{transform:scale(.45);opacity:.25}40%{transform:scale(1);opacity:.75}}
    #vox-splash-icon{animation:vox-spl-pulse 1.5s ease-in-out infinite}
    .vox-spl-dot{width:7px;height:7px;border-radius:50%;background:#1e3a5f;display:inline-block;animation:vox-spl-dot 1.2s ease-in-out infinite}
    .vox-spl-dot:nth-child(2){animation-delay:.18s}
    .vox-spl-dot:nth-child(3){animation-delay:.36s}
  </style>
  <script>if(sessionStorage.getItem('vox_loaded'))document.documentElement.classList.add('vox-loaded');</script>
</head>
<body data-page="<%= "#{controller_path}/#{action_name}".gsub('/', '-') %>">
  <div id="vox-splash" role="status" aria-label="Đang tải...">
    <div id="vox-splash-icon"><img src="/icon-mark.svg" width="76" height="76" alt="VOX" onerror="this.style.display='none'"></div>
    <div style="display:flex;gap:7px;align-items:center;">
      <span class="vox-spl-dot"></span><span class="vox-spl-dot"></span><span class="vox-spl-dot"></span>
    </div>
  </div>
  <script>
    (function(){
      function hideSplash(){
        var s=document.getElementById('vox-splash');
        if(!s||s._done)return; s._done=true;
        sessionStorage.setItem('vox_loaded','1');
        document.documentElement.classList.add('vox-loaded');
        s.classList.add('vox-splash-out');
        setTimeout(function(){s.style.display='none';},320);
      }
      document.addEventListener('turbo:load',hideSplash,{once:true});
      window.addEventListener('load',hideSplash,{once:true});
    })();
  </script>
  <%# Top bar — hidden on auth pages %>
  <% if learner_signed_in? %>
  <header class="lp-topbar">
    <div style="display:flex;align-items:center;gap:4px;min-width:0;flex:1;">
      <%# Back button — shown/hidden by JS based on nav stack %>
      <button id="lp-back-btn" onclick="lpGoBack()"
              style="display:none;width:36px;height:36px;background:rgba(255,255,255,0.12);border:none;border-radius:50%;color:white;cursor:pointer;align-items:center;justify-content:center;flex-shrink:0;padding:0;-webkit-tap-highlight-color:transparent;transition:background .15s;"
              onmousedown="this.style.background='rgba(255,255,255,0.22)'" onmouseup="this.style.background='rgba(255,255,255,0.12)'" ontouchstart="this.style.background='rgba(255,255,255,0.22)'" ontouchend="this.style.background='rgba(255,255,255,0.12)'">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <%# Logo — hidden when back button is active %>
      <%= link_to learner_root_path, class: "lp-topbar-logo", id: "lp-topbar-logo" do %>
        <img src="/icon.svg" width="28" height="28" alt="VOX" style="display:block;">
        <span style="font-size:17px;font-weight:800;color:#ffffff;letter-spacing:2.5px;line-height:1;">VOX</span>
      <% end %>
      <%# Page title — shown when back button is active %>
      <span id="lp-topbar-title" style="display:none;font-size:15px;font-weight:700;color:rgba(255,255,255,0.9);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:180px;"></span>
    </div>
    <div style="display:flex;align-items:center;gap:8px;flex-shrink:0;">
      <!-- Language switcher -->
      <div style="display:flex;align-items:center;background:rgba(255,255,255,0.12);border-radius:20px;padding:3px;">
        <%= link_to request.path + "?locale=vi", style: "padding:3px 10px;border-radius:16px;font-size:11px;font-weight:700;text-decoration:none;transition:all .15s;#{I18n.locale == :vi ? 'background:white;color:#1e3a5f;' : 'color:rgba(255,255,255,0.7);'}" do %>🇻🇳 VI<% end %>
        <%= link_to request.path + "?locale=en", style: "padding:3px 10px;border-radius:16px;font-size:11px;font-weight:700;text-decoration:none;transition:all .15s;#{I18n.locale == :en ? 'background:white;color:#1e3a5f;' : 'color:rgba(255,255,255,0.7);'}" do %>🇬🇧 EN<% end %>
      </div>
      <%# Bell icon notification %>
      <%= link_to learner_notifications_path, id: "lp-bell-btn",
            style: "position:relative;display:flex;align-items:center;justify-content:center;width:34px;height:34px;border-radius:50%;background:rgba(255,255,255,0.12);text-decoration:none;" do %>
        <svg width="18" height="18" fill="none" stroke="white" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        <span id="lp-bell-badge" style="display:none;position:absolute;top:2px;right:2px;min-width:16px;height:16px;background:#ef4444;border-radius:99px;font-size:9px;font-weight:800;color:#fff;display:flex;align-items:center;justify-content:center;padding:0 3px;line-height:1;border:1.5px solid rgba(30,58,95,1);"></span>
      <% end %>
      <%= link_to learner_credits_path, class: "lp-credits-badge" do %>
        <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        <span id="lp-credits-val"><%= current_learner.credits %></span><span style="opacity:0.55;font-weight:500;">/</span><span style="opacity:0.55;font-weight:500;"><%= current_learner.max_credits %></span>
      <% end %>
    </div>
  </header>
  <script>
  /* ── PWA back-button navigation ──
     Maintains a pathname stack in sessionStorage. On detail pages (stack depth ≥ 2)
     the back button replaces the logo. Tapping it pops the stack and visits the
     previous page via Turbo so the main scroll area stays intact. */
  (function() {
    var KEY  = 'lp_nav';
    /* Root pages: back button never shown here */
    var ROOT = /^\/learner(\/library|\/my_flashcards$|\/my_quizzes$|\/study-plans$|\/credits|\/notifications|\/profile|\/progress|\/speaking$|\/ai-tutor$|\/tools\/tts|\/tools\/translate|\/tools\/summarize|\/tools\/punctuate)?[\/]?(\?.*)?$/;

    var _stack;
    try { _stack = JSON.parse(sessionStorage.getItem(KEY) || '[]'); } catch(e) { _stack = []; }

    function save() {
      try { sessionStorage.setItem(KEY, JSON.stringify(_stack.slice(-20))); } catch(e) {}
    }

    function isRoot(path) {
      return path === '/' || ROOT.test(path.split('?')[0]);
    }

    function getPageTitle() {
      /* Prefer the first lp-bc-current span, fall back to document.title minus suffix */
      var bc = document.querySelector('.lp-bc-current');
      if (bc) return bc.textContent.trim();
      return (document.title || '').replace(/\s*·\s*VOX Learn\s*$/, '').trim();
    }

    function updateBar() {
      var btn   = document.getElementById('lp-back-btn');
      var logo  = document.getElementById('lp-topbar-logo');
      var title = document.getElementById('lp-topbar-title');
      if (!btn) return;
      var showBack = _stack.length >= 2 && !isRoot(window.location.pathname);
      if (showBack) {
        btn.style.display   = 'flex';
        logo.style.display  = 'none';
        title.style.display = 'block';
        title.textContent   = getPageTitle();
      } else {
        btn.style.display   = 'none';
        logo.style.display  = 'flex';
        title.style.display = 'none';
      }
    }

    document.addEventListener('turbo:load', function() {
      var path = window.location.pathname;
      var last = _stack[_stack.length - 1];
      /* Ignore locale-only query param changes (don't push duplicate path) */
      if (last !== path) {
        _stack.push(path);
        save();
      }
      updateBar();
    });

    window.lpGoBack = function() {
      if (_stack.length >= 2) {
        _stack.pop();           /* remove current page */
        var prev = _stack[_stack.length - 1];
        save();
        if (typeof Turbo !== 'undefined') {
          Turbo.visit(prev, { action: 'replace' });
        } else {
          window.location.href = prev;
        }
      }
    };

    /* Also run on plain (non-Turbo) load */
    updateBar();
  })();
  </script>
  <% end %>

  <%# Floating language switcher — auth pages (not signed in) %>
  <% unless learner_signed_in? %>
    <div style="position:fixed;top:14px;right:14px;z-index:60;display:flex;align-items:center;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.18);border-radius:20px;padding:3px;backdrop-filter:blur(8px);">
      <%= link_to request.path + "?locale=vi", style: "padding:4px 11px;border-radius:16px;font-size:11px;font-weight:700;text-decoration:none;transition:all .15s;#{I18n.locale == :vi ? 'background:#fff;color:#1e3a5f;' : 'color:rgba(255,255,255,0.7);'}" do %>🇻🇳 VI<% end %>
      <%= link_to request.path + "?locale=en", style: "padding:4px 11px;border-radius:16px;font-size:11px;font-weight:700;text-decoration:none;transition:all .15s;#{I18n.locale == :en ? 'background:#fff;color:#1e3a5f;' : 'color:rgba(255,255,255,0.7);'}" do %>🇬🇧 EN<% end %>
    </div>
  <% end %>

  <!-- Toast container -->
  <div id="lp-toast-container" style="position:fixed;top:calc(var(--topbar-h) + 12px);right:0;z-index:9999;padding:0 12px;display:flex;flex-direction:column;gap:8px;width:min(340px,100vw);box-sizing:border-box;pointer-events:none;"></div>

  <% if notice.present? || alert.present? %>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      <% if notice.present? %> showLpToast(<%= notice.to_json %>, 'success'); <% end %>
      <% if alert.present? %>  showLpToast(<%= alert.to_json %>,  'error');   <% end %>
    });
  </script>
  <% end %>

  <main class="lp-main">
    <% _lp_auth    = %w[sessions registrations passwords].include?(controller_name) %>
    <% _lp_profile = controller_name == 'profile' %>
    <% _lp_extra_class = _lp_auth ? 'lp-page-fullwidth' : (_lp_profile ? 'lp-page-profile' : '') %>
