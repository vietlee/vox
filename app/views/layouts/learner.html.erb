  <script>
  // Bottom-nav safe-area fix. Only clamps a buggy/inflated safe-area-inset-bottom
  // (some iOS PWAs report a huge value that balloons the nav). It does NOT move the
  // nav — the nav stays at its normal fixed bottom:0 position with the icons AND
  // labels fully visible. (An earlier attempt shifted the nav down to "cover" a
  // bottom band, which pushed the labels off-screen — reverted.)
  (function () {
    function measure(expr) {
      var p = document.createElement('div');
      p.style.cssText = 'position:fixed;left:0;bottom:0;width:0;height:' + expr + ';visibility:hidden;pointer-events:none;';
      document.body.appendChild(p);
      var h = p.getBoundingClientRect().height;
      document.body.removeChild(p);
      return (isFinite(h) && h > 0) ? h : 0;
    }
    function fixBottomNav() {
      var nav  = document.querySelector('.lp-bottom-nav');
      var main = document.querySelector('.lp-main');
      if (!nav && !main) return;

      var inset = measure('env(safe-area-inset-bottom,0px)');
      if (!isFinite(inset) || inset < 0) inset = 0;
      if (inset > 34) inset = 34;                      // clamp buggy inflated value

      if (nav) {
        nav.style.bottom        = '0px';                // normal position (clear any stale shift)
        nav.style.height        = (56 + inset) + 'px';
        nav.style.paddingBottom = inset + 'px';
      }
      if (main) main.style.paddingBottom = (56 + inset) + 'px';
    }
    fixBottomNav();
    document.addEventListener('turbo:load',   fixBottomNav);
    document.addEventListener('turbo:render', fixBottomNav);
    window.addEventListener('orientationchange', function () { setTimeout(fixBottomNav, 250); });
  })();
  </script>
