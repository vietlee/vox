<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? "#{yield(:title)} — Vox" : "Vox" %></title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
  <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
  <%= javascript_importmap_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
</head>
<body class="h-full font-inter antialiased bg-slate-100">

<div class="flex h-full">
  <!-- Sidebar -->
  <aside class="w-[232px] bg-[#0F172A] flex flex-col flex-shrink-0 overflow-y-auto">
    <div class="px-5 pt-[18px] pb-1.5">
      <div class="text-[21px] font-black text-indigo-400 tracking-tight">VOX</div>
      <div class="text-[10px] text-slate-500 font-normal mt-0.5"><%= current_workspace&.name || "Platform" %></div>
    </div>

    <nav class="flex-1 pt-3">
      <div class="px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_overview") %></div>
      <%= render "shared/nav_item", icon: "📊", label: t("nav.dashboard"), path: dashboard_path %>

      <div class="px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_tools") %></div>
      <%= render "shared/nav_item", icon: "📋", label: t("nav.surveys"), path: surveys_path, badge: current_workspace&.surveys&.active&.count %>
      <%= render "shared/nav_item", icon: "🗳️", label: t("nav.votes"), path: votes_path, badge: current_workspace&.votes&.active&.count %>
      <%= render "shared/nav_item", icon: "💬", label: t("nav.feedback"), path: feedback_boards_path %>
      <% if current_workspace&.active_subscription&.has_feature?(:ai_chat) %>
        <%= render "shared/nav_item", icon: "🤖", label: "AI Chat", path: ai_chat_page_path %>
      <% end %>

      <% if current_user.admin? %>
        <div class="px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_manage") %></div>
        <%= render "shared/nav_item", icon: "👥", label: t("nav.members"), path: members_path %>
        <%= render "shared/nav_item", icon: "⚙️", label: t("nav.settings"), path: workspace_settings_path %>
        <%= render "shared/nav_item", icon: "💳", label: t("nav.subscription"), path: subscription_path %>
        <%= render "shared/nav_item", icon: "📜", label: t("nav.audit_log"), path: audit_log_path %>
      <% end %>
    </nav>

    <!-- Sidebar footer: AI credits + user -->
    <div class="mt-auto border-t border-white/[0.06] px-4 py-3.5">
      <% if (sub = current_workspace&.active_subscription) && !sub.free? %>
        <div class="flex justify-between text-[11px] text-slate-500 mb-1.5">
          <span>AI Credits</span>
          <strong class="text-violet-400"><%= sub.credit_balance %> / <%= sub.max_ai_credits || "∞" %></strong>
        </div>
        <div class="h-1 bg-white/[0.07] rounded-sm mb-3 overflow-hidden">
          <div class="h-1 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-sm" style="width: <%= sub.credit_percentage %>%"></div>
        </div>
      <% end %>
      <div class="flex items-center gap-2.5">
        <div class="w-[30px] h-[30px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[12px] font-bold text-white flex-shrink-0">
          <%= current_user.initials %>
        </div>
        <div class="min-w-0">
          <div class="text-[12px] font-semibold text-white truncate"><%= current_user.display_name %></div>
          <div class="text-[10px] text-slate-500"><%= t("roles.#{current_user.role}") %></div>
        </div>
        <button type="button" onclick="document.getElementById('logout-modal').classList.remove('hidden')" title="<%= t('nav.sign_out') %>" class="ml-auto text-slate-600 hover:text-slate-400 text-[13px] bg-transparent border-0 cursor-pointer p-0">⏻</button>
      </div>
    </div>
  </aside>

  <!-- Main area -->
  <div class="flex-1 flex flex-col overflow-hidden min-w-0">
    <!-- Top header -->
    <header class="h-14 bg-white border-b border-slate-200 flex items-center px-6 gap-3.5 flex-shrink-0">
      <nav class="flex items-center gap-1.5 text-[13px] text-slate-400">
        <% if content_for?(:breadcrumb) %>
          <%= yield(:breadcrumb) %>
        <% end %>
      </nav>
      <div class="ml-auto flex items-center gap-2.5">
        <!-- Language switcher -->
        <div class="flex gap-0.5 bg-slate-100 border border-slate-200 rounded-lg p-0.5">
          <%= link_to request.path + "?locale=vi", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :vi ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇻🇳 VI<% end %>
          <%= link_to request.path + "?locale=en", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :en ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇬🇧 EN<% end %>
        </div>
        <%= link_to notifications_path, class: "relative w-[34px] h-[34px] rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-[15px] text-slate-500 hover:bg-slate-200 transition-colors" do %>
          🔔
          <% unread = current_user.notifications.unread.count; if unread > 0 %>
            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
          <% end %>
        <% end %>
        <div class="w-[34px] h-[34px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[13px] font-bold text-white">
          <%= current_user.initials %>
        </div>
      </div>
    </header>

    <!-- Subscription expiry banner -->
    <% sub = current_workspace&.active_subscription %>
    <% if sub && !sub.free? && sub.ends_at && sub.ends_at <= 7.days.from_now %>
      <% days_left = [(sub.ends_at.to_date - Date.current).to_i, 0].max %>
      <div class="<%= days_left <= 1 ? 'bg-red-600' : 'bg-amber-500' %> text-white px-6 py-2.5 flex items-center gap-3 flex-shrink-0">
        <span class="text-[14px]"><%= days_left <= 1 ? '🚨' : '⚠️' %></span>
        <span class="text-[13px] font-semibold flex-1">
          <% if days_left == 0 %>
            Gói <%= sub.plan.upcase %> của bạn hết hạn hôm nay!
          <% elsif days_left == 1 %>
            Gói <%= sub.plan.upcase %> của bạn hết hạn vào ngày mai!
          <% else %>
            Gói <%= sub.plan.upcase %> của bạn sẽ hết hạn sau <strong><%= days_left %> ngày</strong> (<%= sub.ends_at.strftime("%d/%m/%Y") %>).
          <% end %>
          Gia hạn ngay để không bị gián đoạn.
        </span>
        <%= link_to billing_subscription_path, class: "px-3 py-1 bg-white/20 hover:bg-white/30 text-white text-[12px] font-bold rounded-lg whitespace-nowrap" do %>
          Gia hạn ngay →
        <% end %>
      </div>
    <% end %>

    <!-- Flash messages -->
    <% if notice || alert %>
      <div id="flash" class="px-6 pt-4">
        <% if notice %>
          <div class="flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg px-4 py-2.5 text-[13px] font-medium">
            ✓ <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-2.5 text-[13px] font-medium">
            ⚠ <%= alert %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Page content -->
    <main class="flex-1 overflow-y-auto p-6">
      <%= yield %>
    </main>
  </div>
</div>

<!-- Logout confirm modal -->
<div id="logout-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center">
  <div class="absolute inset-0 bg-black/40" onclick="document.getElementById('logout-modal').classList.add('hidden')"></div>
  <div class="relative bg-white rounded-2xl shadow-xl p-6 w-[320px] text-center">
    <div class="text-[32px] mb-3">👋</div>
    <h3 class="text-[16px] font-extrabold text-slate-900 mb-1">Đăng xuất?</h3>
    <p class="text-[13px] text-slate-500 mb-5">Bạn sẽ cần đăng nhập lại để tiếp tục.</p>
    <div class="flex gap-2">
      <button onclick="document.getElementById('logout-modal').classList.add('hidden')"
        class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-[13px] font-semibold rounded-xl hover:bg-slate-200 border-0 cursor-pointer">
        Huỷ
      </button>
      <%= button_to destroy_user_session_path, method: :delete,
            form_class: "flex-1",
            class: "w-full py-2.5 bg-red-500 text-white text-[13px] font-semibold rounded-xl hover:bg-red-600 border-0 cursor-pointer" do %>
        Đăng xuất
      <% end %>
    </div>
  </div>
</div>

</body>
</html>
