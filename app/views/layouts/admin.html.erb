<script data-turbo-eval="false">
window.VoxTaskManager = window.VoxTaskManager || (function() {
  var STORE_KEY = 'vox_active_tasks';
  var POLL_MS   = 3000;
  var _tasks    = [];
  var _timer    = null;

  function _load() {
    try { _tasks = JSON.parse(localStorage.getItem(STORE_KEY) || '[]'); } catch(e) { _tasks = []; }
  }
  function _save() {
    localStorage.setItem(STORE_KEY, JSON.stringify(_tasks));
  }
  function _render() {
    var dock = document.getElementById('vox-task-dock');
    if (!dock) return;
    if (!_tasks.length) { dock.innerHTML = ''; return; }
    dock.innerHTML = _tasks.map(function(t) {
      var bodyHtml = t.minimized ? '' : (
        '<div class="vtask-body">' +
          '<div class="vtask-title" title="' + _esc(t.title) + '">' + _esc(t.title) + '</div>' +
          '<div class="vtask-bar-track"><div class="vtask-bar-fill" style="width:' + (t.pct||0) + '%"></div></div>' +
          '<div class="vtask-pct">' + (t.pct||0) + '%</div>' +
        '</div>'
      );
      return '<div class="vtask-card" data-vtask="' + _esc(t.id) + '">' +
        '<div class="vtask-header" onclick="VoxTaskManager.toggle(\'' + _esc(t.id) + '\')">' +
          '<span style="font-size:14px">' + (t.icon||'⚙️') + '</span>' +
          '<span class="vtask-header-label">' + _esc(t.label) + '</span>' +
          '<button class="vtask-btn" onclick="event.stopPropagation();VoxTaskManager.toggle(\'' + _esc(t.id) + '\')" title="Thu nhỏ/Mở rộng">' + (t.minimized ? '▲' : '▼') + '</button>' +
          '<button class="vtask-btn" onclick="event.stopPropagation();VoxTaskManager.dismiss(\'' + _esc(t.id) + '\')" title="Ẩn">×</button>' +
        '</div>' + bodyHtml + '</div>';
    }).join('');
  }
  function _esc(s) {
    return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function _startPolling() {
    if (_timer) return;
    _timer = setInterval(_poll, POLL_MS);
  }
  function _stopPolling() {
    clearInterval(_timer); _timer = null;
  }
  async function _poll() {
    if (!_tasks.length) { _stopPolling(); return; }
    for (var i = 0; i < _tasks.length; i++) {
      var t = _tasks[i];
      try {
        var r = await fetch(t.poll_url, { headers: { 'Accept': 'application/json' } });
        var d = await r.json();
        if (d.success || d.ready) {
          _complete(t, d.redirect || t.redirect_url);
        } else if (d.failed || d.error) {
          _fail(t, d.error || 'Có lỗi xảy ra');
        } else {
          // still pending — fake progress up to 92%
          t.pct = Math.min((t.pct||0) + Math.floor(Math.random()*6+3), 92);
          _save(); _updateProgressInPlace(t);
        }
      } catch(e) { /* network error, keep polling */ }
    }
  }
  function _updateProgressInPlace(t) {
    var card = document.querySelector('[data-vtask="' + CSS.escape(t.id) + '"]');
    if (!card) { _render(); return; }
    var fill  = card.querySelector('.vtask-bar-fill');
    var pctEl = card.querySelector('.vtask-pct');
    if (fill)  fill.style.width    = (t.pct || 0) + '%';
    if (pctEl) pctEl.textContent   = (t.pct || 0) + '%';
  }
  var TOAST_STORE_KEY = 'vox_pending_toasts';
  var TOAST_TTL_MS    = 300000; // 5 minutes

  function _persistToast(icon, label, title, url) {
    try {
      var toasts = JSON.parse(sessionStorage.getItem(TOAST_STORE_KEY) || '[]');
      toasts.push({ icon: icon, label: label, title: title, url: url, at: Date.now() });
      sessionStorage.setItem(TOAST_STORE_KEY, JSON.stringify(toasts));
    } catch(e) {}
  }

  function _restoreToasts() {
    try {
      var toasts = JSON.parse(sessionStorage.getItem(TOAST_STORE_KEY) || '[]');
      var now = Date.now();
      var remaining = toasts.filter(function(t) { return (now - t.at) < TOAST_TTL_MS; });
      sessionStorage.setItem(TOAST_STORE_KEY, JSON.stringify(remaining));
      remaining.forEach(function(t) {
        _renderToast(t.icon, t.label, t.title, t.url, TOAST_TTL_MS - (now - t.at));
      });
    } catch(e) {}
  }

  function _complete(task, redirectUrl) {
    _tasks = _tasks.filter(function(t) { return t.id !== task.id; });
    _save(); _render();
    if (!_tasks.length) _stopPolling();
    _persistToast('✅', task.label, task.title, redirectUrl);
    if (redirectUrl && window.location.pathname === new URL(redirectUrl, location.href).pathname) {
      setTimeout(function() { window.location.reload(); }, 400);
    } else {
      _showToast('✅', task.label, task.title, redirectUrl);
    }
  }
  function _fail(task, msg) {
    _tasks = _tasks.filter(function(t) { return t.id !== task.id; });
    _save(); _render();
    if (!_tasks.length) _stopPolling();
    _showToast('❌', task.label + ' thất bại', msg || '', null);
  }
  function _renderToast(icon, label, title, url, ttl) {
    var el = document.createElement('div');
    el.className = 'vox-toast';
    var link = url ? ' <a href="' + url + '" onclick="this.closest(\'.vox-toast\').remove();try{var ts=JSON.parse(sessionStorage.getItem(\'vox_pending_toasts\')||\'[]\');sessionStorage.setItem(\'vox_pending_toasts\',JSON.stringify(ts.filter(function(x){return x.url!==\''+url+'\'})));}catch(e){}">Xem ngay →</a>' : '';
    el.innerHTML = icon + ' <strong>' + _esc(label) + ':</strong> ' + _esc(title) + link +
      ' <button class="vox-toast-close" style="margin-left:10px;background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:4px;padding:2px 7px;cursor:pointer;font-size:13px;line-height:1.4;">×</button>';
    el.querySelector('.vox-toast-close').addEventListener('click', function() { el.remove(); });
    document.body.appendChild(el);
    setTimeout(function() {
      el.style.transition = 'opacity .4s';
      el.style.opacity = '0';
      setTimeout(function() { el.remove(); }, 400);
    }, ttl || TOAST_TTL_MS);
  }
  function _showToast(icon, label, title, url) {
    _renderToast(icon, label, title, url, TOAST_TTL_MS);
  }

  // Public API
  return {
    add: function(task) {
      // task: {id, icon, label, title, poll_url, redirect_url}
      var existing = _tasks.find(function(t) { return t.id === task.id; });
      if (existing) {
        // Task đã có — chỉ update poll_url (nếu thay đổi), giữ pct và trạng thái
        existing.poll_url = task.poll_url || existing.poll_url;
        _save(); _startPolling(); return;
      }
      task.pct = task.pct || 0;
      task.minimized = false;
      _tasks.push(task);
      _save(); _render(); _startPolling();
    },
    toggle: function(id) {
      var t = _tasks.find(function(t) { return t.id === id; });
      if (t) { t.minimized = !t.minimized; _save(); _render(); }
    },
    dismiss: function(id) {
      _tasks = _tasks.filter(function(t) { return t.id !== id; });
      _save(); _render();
      if (!_tasks.length) _stopPolling();
    },
    init: function() {
      _load(); _render();
      if (_tasks.length) _startPolling();
      _restoreToasts();
    }
  };
})();

document.addEventListener('DOMContentLoaded', function() { VoxTaskManager.init(); });
document.addEventListener('turbo:load', function() { VoxTaskManager.init(); });

// ── Đồng bộ hover navy cho inline-styled buttons chưa có hover ──
(function applyNavyHover() {
  var NEUTRAL_BG = ['#f1f5f9','#f8fafc','#f0f4f8','#f4f6f8','rgb(241,245,249)','rgb(248,250,252)'];
  var SKIP_BG    = ['#1e3a5f','#ef4444','#dc2626','#10b981','#059669','#6d28d9','#7c3aed','#f59e0b','rgba'];

  function isNeutral(bg) {
    if (!bg) return false;
    var b = bg.toLowerCase().replace(/\s/g,'');
    return NEUTRAL_BG.some(function(c){ return b === c || b === c.toLowerCase(); });
  }
  function isSkip(bg) {
    if (!bg) return true;
    return SKIP_BG.some(function(c){ return bg.includes(c); });
  }

  function applyToEl(el) {
    // Skip if already has navy hover class or a colored bg
    var cls = el.className || '';
    if (cls.includes('1e3a5f') || el.dataset.navyHover) return;
    var style = el.getAttribute('style') || '';
    var bgMatch = style.match(/background(?:-color)?:\s*([^;]+)/i);
    var bg = bgMatch ? bgMatch[1].trim() : null;
    if (!bg || isSkip(bg) || !isNeutral(bg)) return;
    // Has light neutral background — add navy hover
    el.dataset.navyHover = '1';
    var origBg    = bg;
    var origColor = (style.match(/(?:^|;)\s*color:\s*([^;]+)/i)||[])[1] || '';
    el.addEventListener('mouseenter', function() {
      el.style.background = '#1e3a5f';
      el.style.color = '#fff';
      if (el.style.borderColor) el.style.borderColor = '#1e3a5f';
    });
    el.addEventListener('mouseleave', function() {
      el.style.background = origBg;
      el.style.color = origColor;
      if (el.style.borderColor) el.style.borderColor = '';
    });
  }

  function run() {
    document.querySelectorAll('button[style], a[style][href], [onclick][style]').forEach(applyToEl);
  }

  document.addEventListener('DOMContentLoaded', run);
  document.addEventListener('turbo:load', run);
})();
</script>

<script>
(function(){
  var KEY = 'vox_sb_collapsed';
  function apply(collapsed) {
    var sb = document.getElementById('main-sidebar');
    if (!sb) return;
    sb.classList.toggle('sb-collapsed', collapsed);
    var icon = document.getElementById('sb-toggle-icon');
    if (icon) {
      var p = icon.querySelector('path');
      if (p) p.setAttribute('d', collapsed ? 'M5 2l5 5-5 5' : 'M9 2L4 7l5 5');
    }
  }
  window.toggleSidebar = function() {
    var sb = document.getElementById('main-sidebar');
    if (!sb) return;
    var next = !sb.classList.contains('sb-collapsed');
    localStorage.setItem(KEY, next ? '1' : '0');
    apply(next);
    /* Let slide editors / other resize-aware components re-measure */
    setTimeout(function(){ window.dispatchEvent(new Event('resize')); }, 220);
  };
  function init() {
    apply(localStorage.getItem(KEY) === '1');
    /* Wait two animation frames so flex layout recalculates after sidebar state applied */
    requestAnimationFrame(function(){
      requestAnimationFrame(function(){
        window.dispatchEvent(new Event('resize'));
      });
    });
  }
  document.addEventListener('DOMContentLoaded', init);
  document.addEventListener('turbo:render', init);
})();
</script>
<script>
/* markFieldError — highlight a required field with red border on failed submit */
window.markFieldError = function(el) {
  el.focus();
  el.style.borderColor = '#ef4444';
  el.style.boxShadow = '0 0 0 3px rgba(239,68,68,0.12)';
  function clearErr() { el.style.borderColor = ''; el.style.boxShadow = ''; }
  el.addEventListener('input', clearErr, {once: true});
  setTimeout(function() { el.addEventListener('focus', clearErr, {once: true}); }, 0);
};
</script>
