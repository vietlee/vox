<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? "#{yield(:title)} — Vox" : "Vox" %></title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/icon.png" type="image/png">
  <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
  <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
  <%= javascript_importmap_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    /* Critical CSS — prevents FOUC during Turbo navigation / CSS lazy-compile */
    html,body{height:100%;margin:0}
    body{background:#f1f5f9;font-family:Inter,system-ui,sans-serif}
    .flex{display:flex}.flex-col{flex-direction:column}
    .h-full{height:100%}.overflow-hidden{overflow:hidden}
    aside{background:#0F172A;width:232px;min-width:232px;flex-shrink:0;display:flex;flex-direction:column;overflow:hidden}
    .flex-1{flex:1 1 0%}.overflow-auto{overflow:auto}
    .overflow-y-auto{overflow-y:auto}
    /* Hide scrollbars globally while keeping scroll functionality */
    *::-webkit-scrollbar{display:none}
    *{-ms-overflow-style:none;scrollbar-width:none}
  </style>
</head>
<body class="h-full font-inter antialiased bg-slate-100">

<div class="flex h-full">
  <!-- Sidebar -->
  <aside class="w-[232px] bg-[#0F172A] flex flex-col flex-shrink-0 overflow-hidden">
    <div class="px-5 pt-[18px] pb-1.5 flex-shrink-0">
      <%= link_to dashboard_path, class: "block" do %>
        <div class="flex items-center gap-2">
          <svg width="28" height="28" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
            <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
            <polygon points="325,84 318,98 338,84" fill="white"/>
            <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
            <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
            <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
            <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
          </svg>
          <span style="font-size:17px;font-weight:800;color:#1A6BFF;letter-spacing:2.5px;line-height:1;">VOX</span>
        </div>
      <% end %>

      <%# Workspace switcher %>
      <% all_workspaces = accessible_workspaces rescue [] %>
      <% if all_workspaces.size > 1 %>
        <div class="relative mt-2" id="ws-switcher">
          <button type="button" onclick="document.getElementById('ws-dropdown').classList.toggle('hidden')"
            class="w-full flex items-center gap-2 text-left group cursor-pointer bg-white/[0.06] hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-lg px-2.5 py-1.5 transition-all">
            <span class="text-[12px] text-slate-200 font-semibold truncate flex-1 group-hover:text-white transition-colors">
              <%= current_workspace&.name || "Platform" %>
            </span>
            <svg class="w-3.5 h-3.5 text-slate-400 group-hover:text-slate-200 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
            </svg>
          </button>
          <div id="ws-dropdown" class="hidden absolute left-0 top-full mt-1 z-50 bg-[#1e293b] border border-white/10 rounded-xl shadow-xl py-1 min-w-[180px] max-w-[220px]">
            <% all_workspaces.each do |ws| %>
              <% is_active = ws.id == current_workspace&.id %>
              <% ws_suspended = !ws.active? %>
              <% ws_role = (current_user.workspace_id == ws.id ? :admin : current_user.workspace_memberships.find_by(workspace: ws, status: :active)&.role&.to_sym) %>
              <%= button_to switch_workspace_path(workspace_id: ws.id), method: :post,
                    data: { turbo: false },
                    class: "w-full text-left px-3 py-2.5 flex items-center gap-2 hover:bg-white/5 transition-colors border-0 bg-transparent cursor-pointer #{is_active ? '' : 'opacity-75 hover:opacity-100'}" do %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[12px] font-semibold text-white truncate"><%= ws.name %></span>
                    <% if ws_suspended %>
                      <span class="text-[9px] px-1 py-0.5 rounded bg-red-500/20 text-red-400 font-bold flex-shrink-0">🔒</span>
                    <% end %>
                  </div>
                  <div class="text-[10px] text-slate-500 mt-0.5"><%= t("roles.#{ws_role}") %></div>
                </div>
                <% if is_active %>
                  <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
        <script>
          document.addEventListener('click', function(e) {
            var sw = document.getElementById('ws-switcher');
            var dd = document.getElementById('ws-dropdown');
            if (sw && dd && !sw.contains(e.target)) dd.classList.add('hidden');
          });
        </script>
      <% else %>
        <div class="text-[11px] text-slate-500 font-normal mt-0.5"><%= current_workspace&.name || "Platform" %></div>
      <% end %>
    </div>

    <nav class="flex-1 pt-3 overflow-y-auto">
      <div class="px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_overview") %></div>
      <%= render "shared/nav_item", icon: "📊", label: t("nav.dashboard"), path: dashboard_path %>

      <div class="px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_tools") %></div>
      <%= render "shared/nav_item", icon: "📋", label: t("nav.surveys"), path: surveys_path, badge: current_workspace&.surveys&.active&.count %>
      <%= render "shared/nav_item", icon: "🗳️", label: t("nav.votes"), path: votes_path, badge: current_workspace&.votes&.active&.count %>
      <%= render "shared/nav_item", icon: "💬", label: t("nav.feedback"), path: feedback_boards_path %>
      <% if current_workspace&.active_subscription&.has_feature?(:ai_chat) %>
        <%= render "shared/nav_item", icon: "✨", label: t("nav.ai_chat"), path: ai_chat_page_path %>
      <% end %>
      <%= render "shared/nav_item", icon: "🎙️", label: t("nav.tts"), path: tts_path %>
      <%= render "shared/nav_item", icon: "🎤", label: t("nav.stt"), path: stt_path %>

      <% if current_workspace_admin? %>
        <div class="px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_manage") %></div>
        <%= render "shared/nav_item", icon: "👥", label: t("nav.members"), path: members_path %>
        <%= render "shared/nav_item", icon: "⚙️", label: t("nav.settings"), path: workspace_settings_path %>
        <%= render "shared/nav_item", icon: "💳", label: t("nav.subscription"), path: subscription_path %>
        <%= render "shared/nav_item", icon: "📜", label: t("nav.audit_log"), path: audit_log_path %>
      <% end %>
    </nav>

    <!-- Sidebar footer: AI credits + user -->
    <div class="mt-auto border-t border-white/[0.06] px-4 py-3.5">
      <% if (sub = current_workspace&.active_subscription) && sub.max_ai_credits.to_i > 0 %>
        <div class="flex justify-between text-[11px] text-slate-500 mb-1.5 mt-2">
          <span>AI Credits</span>
          <strong class="text-violet-400">
            <span id="nav-credit-balance"><%= sub.credit_balance %></span> / <span id="nav-credit-max"><%= sub.max_ai_credits || "∞" %></span>
          </strong>
        </div>
        <div class="h-1 bg-white/[0.07] rounded-sm mb-3 overflow-hidden">
          <div id="nav-credit-bar" class="h-1 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-sm" style="width: <%= sub.credit_percentage %>%"></div>
        </div>
        <script>
          // Global helper — called after any AI job completes
          window.__maxCredits     = <%= sub.max_ai_credits.nil? ? 'null' : sub.max_ai_credits %>;
          window.__currentCredits = <%= sub.credit_balance %>;
          window.deductDisplayCredits = function(amount) {
            const el  = document.getElementById('nav-credit-balance');
            const bar = document.getElementById('nav-credit-bar');
            if (!el) return;
            const current = parseInt(el.textContent) || 0;
            const next    = Math.max(0, current - amount);
            el.textContent = next;
            window.__currentCredits = next;
            if (bar && window.__maxCredits) {
              bar.style.width = Math.round((next / window.__maxCredits) * 100) + '%';
            }
            // Also update chat page counter if present
            const chatEl = document.getElementById('credit-display');
            if (chatEl) chatEl.textContent = next;
          };
        </script>
      <% end %>
      <div class="flex items-center gap-2.5">
        <%= link_to profile_path, class: "flex items-center gap-2.5 min-w-0 flex-1 group", title: t("nav.profile") do %>
          <div class="w-[30px] h-[30px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[12px] font-bold text-white flex-shrink-0 group-hover:ring-2 group-hover:ring-indigo-400 transition-all">
            <%= current_user.initials %>
          </div>
          <div class="min-w-0">
            <div class="text-[12px] font-semibold text-white truncate group-hover:text-indigo-300 transition-colors"><%= current_user.display_name %></div>
            <div class="text-[10px] text-slate-500"><%= t("roles.#{current_workspace_role || current_user.role}") %></div>
          </div>
        <% end %>
        <button type="button" onclick="document.getElementById('logout-modal').classList.remove('hidden')" title="<%= t('nav.sign_out') %>" class="ml-auto text-slate-600 hover:text-slate-400 text-[13px] bg-transparent border-0 cursor-pointer p-0 flex-shrink-0">⏻</button>
      </div>
    </div>
  </aside>

  <!-- Main area -->
  <div class="flex-1 flex flex-col overflow-hidden min-w-0">
    <!-- Top header -->
    <header class="h-14 bg-white border-b border-slate-200 flex items-center px-6 gap-3.5 flex-shrink-0">
      <nav class="flex items-center gap-1.5 text-[13px] text-slate-400">
        <% if content_for?(:breadcrumb) %>
          <%= yield(:breadcrumb) %>
        <% end %>
      </nav>
      <div class="ml-auto flex items-center gap-2.5">
        <!-- Language switcher -->
        <div class="flex gap-0.5 bg-slate-100 border border-slate-200 rounded-lg p-0.5">
          <%= link_to request.path + "?locale=vi", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :vi ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇻🇳 VI<% end %>
          <%= link_to request.path + "?locale=en", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :en ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇬🇧 EN<% end %>
        </div>
        <%= link_to notifications_path, class: "relative w-[34px] h-[34px] rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-[15px] text-slate-500 hover:bg-slate-200 transition-colors" do %>
          🔔
          <% unread = current_user.notifications.unread.count; if unread > 0 %>
            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
          <% end %>
        <% end %>
        <div class="w-[34px] h-[34px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[13px] font-bold text-white">
          <%= current_user.initials %>
        </div>
      </div>
    </header>

    <!-- Subscription expiry banner -->
    <% sub = current_workspace&.active_subscription %>
    <% if sub && !sub.free? && sub.ends_at && sub.ends_at <= 7.days.from_now %>
      <% days_left = [(sub.ends_at.to_date - Date.current).to_i, 0].max %>
      <div class="<%= days_left <= 1 ? 'bg-red-600' : 'bg-amber-500' %> text-white px-6 py-2.5 flex items-center gap-3 flex-shrink-0">
        <span class="text-[14px]"><%= days_left <= 1 ? '🚨' : '⚠️' %></span>
        <span class="text-[13px] font-semibold flex-1">
          <% if days_left == 0 %>
            <%= t("subscription.expiry_today", plan: sub.plan.upcase) %>
          <% elsif days_left == 1 %>
            <%= t("subscription.expiry_tomorrow", plan: sub.plan.upcase) %>
          <% else %>
            <%= t("subscription.expiry_days", plan: sub.plan.upcase, days: days_left, date: I18n.l(sub.ends_at.to_date, format: :short)) %>
          <% end %>
          <%= t("subscription.renew_prompt") %>
        </span>
        <%= link_to billing_subscription_path, class: "px-3 py-1 bg-white/20 hover:bg-white/30 text-white text-[12px] font-bold rounded-lg whitespace-nowrap" do %>
          <%= t("subscription.renew_now") %>
        <% end %>
      </div>
    <% end %>

    <!-- Flash messages -->
    <% if notice || alert %>
      <div id="flash" class="px-6 pt-4 transition-all duration-500">
        <% if notice %>
          <div class="flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg px-4 py-2.5 text-[13px] font-medium">
            ✓ <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-2.5 text-[13px] font-medium">
            ⚠ <%= alert %>
          </div>
        <% end %>
      </div>
      <script>
        (function() {
          const flash = document.getElementById('flash');
          if (!flash) return;
          setTimeout(function() {
            flash.style.transition = 'opacity 0.5s ease, max-height 0.5s ease, padding 0.5s ease';
            flash.style.overflow = 'hidden';
            flash.style.opacity = '0';
            flash.style.maxHeight = '0';
            flash.style.paddingTop = '0';
            flash.style.paddingBottom = '0';
          }, 5000);
        })();
      </script>
    <% end %>

    <!-- Page content -->
    <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'flex-1 overflow-y-auto p-6' %>">
      <%= yield %>
    </main>
  </div>
</div>

<!-- AI Upgrade modal -->
<div id="ai-upgrade-modal" class="hidden fixed inset-0 z-[60]">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" onclick="window.closeAiUpgradeModal()"></div>
    <div class="relative bg-white rounded-2xl shadow-xl p-7 w-[420px] text-center">
      <div id="ai-upgrade-modal-icon" class="w-14 h-14 rounded-2xl bg-indigo-50 flex items-center justify-center mx-auto mb-4 text-[28px]">✨</div>
      <h3 id="ai-upgrade-modal-title" class="text-[17px] font-extrabold text-slate-900 mb-2"><%= t("ai.upgrade_modal_title") %></h3>
      <p id="ai-upgrade-feature-name" class="text-[13px] text-indigo-600 font-semibold mb-1"></p>
      <p id="ai-upgrade-modal-desc" class="text-[13px] text-slate-500 mb-6"><%= t("ai.upgrade_modal_desc") %></p>
      <div class="flex gap-2">
        <button onclick="window.closeAiUpgradeModal()"
          class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-[13px] font-semibold rounded-lg hover:bg-slate-200 border-0 cursor-pointer transition-colors">
          <%= t("common.cancel") %>
        </button>
        <a id="ai-upgrade-modal-cta" href="<%= billing_subscription_path %>"
          class="flex-1 py-2.5 bg-blue-500 hover:bg-blue-600 text-white text-[13px] font-semibold rounded-lg text-center transition-colors">
          <%= t("ai.upgrade_modal_cta") %>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Logout confirm modal -->
<div id="logout-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" onclick="document.getElementById('logout-modal').classList.add('hidden')"></div>
    <div class="relative bg-white rounded-2xl shadow-xl p-6 w-[320px] text-center">
      <div class="text-[32px] mb-3">👋</div>
      <h3 class="text-[16px] font-extrabold text-slate-900 mb-1"><%= t("super_admin.logout.title") %></h3>
      <p class="text-[13px] text-slate-500 mb-5"><%= t("super_admin.logout.desc") %></p>
      <div class="flex gap-2">
        <button onclick="document.getElementById('logout-modal').classList.add('hidden')"
          class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-[13px] font-semibold rounded-lg hover:bg-slate-200 border-0 cursor-pointer">
          <%= t("super_admin.logout.cancel") %>
        </button>
        <%= button_to destroy_user_session_path, method: :delete,
              form_class: "flex-1",
              class: "w-full py-2.5 bg-red-500 text-white text-[13px] font-semibold rounded-lg hover:bg-red-600 border-0 cursor-pointer" do %>
          <%= t("super_admin.logout.confirm") %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= render "shared/mobile_admin_warning" %>

<script>
  // ── AI Upgrade Modal ─────────────────────────────────────────────────────────
  var _aiUpgradeI18n = {
    upgradeTitle: '<%= j t("ai.upgrade_modal_title") %>',
    upgradeDesc:  '<%= j t("ai.upgrade_modal_desc") %>',
    upgradeCta:   '<%= j t("ai.upgrade_modal_cta") %>',
    creditsTitle: '<%= j t("ai.credits_modal_title") %>',
    creditsDesc:  '<%= j t("ai.credits_modal_desc") %>',
    creditsCta:   '<%= j t("ai.credits_modal_cta") %>',
    billingUrl:   '<%= billing_subscription_path %>'
  };

  // showAiUpgradeModal(featureName, insufficientCredits)
  window.showAiUpgradeModal = function(featureName, insufficientCredits) {
    var isCredits = !!insufficientCredits;
    document.getElementById('ai-upgrade-modal-icon').textContent = isCredits ? '💎' : '✨';
    document.getElementById('ai-upgrade-modal-title').textContent = isCredits ? _aiUpgradeI18n.creditsTitle : _aiUpgradeI18n.upgradeTitle;
    document.getElementById('ai-upgrade-modal-desc').textContent  = isCredits ? _aiUpgradeI18n.creditsDesc  : _aiUpgradeI18n.upgradeDesc;
    document.getElementById('ai-upgrade-modal-cta').textContent   = isCredits ? _aiUpgradeI18n.creditsCta   : _aiUpgradeI18n.upgradeCta;
    document.getElementById('ai-upgrade-modal-cta').href          = _aiUpgradeI18n.billingUrl;
    var nameEl = document.getElementById('ai-upgrade-feature-name');
    if (nameEl) nameEl.textContent = featureName || '';
    document.getElementById('ai-upgrade-modal').classList.remove('hidden');
  };
  window.closeAiUpgradeModal = function() {
    document.getElementById('ai-upgrade-modal').classList.add('hidden');
  };

  // Global helper: call after every AI fetch. Returns true if upgrade required.
  // Usage: if (window.handleAiUpgrade(resp, data, 'Feature name')) return;
  window.handleAiUpgrade = function(resp, data, featureName) {
    if (resp.status === 402 || data?.upgrade_required) {
      window.showAiUpgradeModal(featureName, data?.insufficient_credits);
      return true;
    }
    return false;
  };

  // Hide all modals before Turbo snapshots the page for its cache.
  document.addEventListener('turbo:before-cache', function() {
    document.querySelectorAll('[id$="-modal"]').forEach(function(el) {
      el.classList.add('hidden');
    });
  });
</script>
</body>
</html>
