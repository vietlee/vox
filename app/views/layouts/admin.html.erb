<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? "#{yield(:title)} — Vox" : "Vox" %></title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <meta name="turbo-cache-control" content="no-cache">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/icon.png" type="image/png">
  <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
  <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
  <style>
    /* VOX brand color override: dark navy #1e3a5f */
    :root, :host {
      --color-violet-50: #eef3f9; --color-violet-100: #d9e5f1;
      --color-violet-200: #b3cbe3; --color-violet-300: #7aaac9;
      --color-violet-400: #4a80a8; --color-violet-500: #2d5f8a;
      --color-violet-600: #1e3a5f; --color-violet-700: #162c47;
      --color-violet-800: #0e1e30; --color-violet-900: #070f18;
      --color-indigo-50: #eef3f9;  --color-indigo-100: #d9e5f1;
      --color-indigo-200: #b3cbe3; --color-indigo-300: #7aaac9;
      --color-indigo-400: #4a80a8; --color-indigo-500: #2d5f8a;
      --color-indigo-600: #1e3a5f; --color-indigo-700: #162c47;
      --color-indigo-800: #0e1e30; --color-indigo-900: #070f18;
    }

    /* ── Đồng bộ hover: tất cả button/link/label neutral → navy + trắng ── */
    button.hover\:bg-slate-50:hover,
    button.hover\:bg-slate-100:hover,
    button.hover\:bg-slate-200:hover,
    button.hover\:bg-gray-100:hover,
    button.hover\:bg-gray-200:hover,
    a.hover\:bg-slate-50:hover,
    a.hover\:bg-slate-100:hover,
    a.hover\:bg-slate-200:hover,
    a.hover\:bg-gray-100:hover,
    label.hover\:bg-slate-50:hover,
    label.hover\:bg-slate-100:hover,
    label.hover\:bg-slate-200:hover,
    [onclick].hover\:bg-slate-50:hover,
    [onclick].hover\:bg-slate-100:hover,
    [onclick].hover\:bg-slate-200:hover,
    [onclick].hover\:bg-gray-100:hover {
      background-color: #1e3a5f !important;
      color: #fff !important;
      border-color: #1e3a5f !important;
    }

    /* Unify hover:bg-indigo-50 trên button/link (light hover không phù hợp) */
    button.hover\:bg-indigo-50:hover,
    a.hover\:bg-indigo-50:hover {
      background-color: #1e3a5f !important;
      color: #fff !important;
    }

    /* Unify darker navy variant → chuẩn */
    .hover\:bg-\[#162d4a\]:hover { background-color: #1e3a5f !important; }
  </style>
  <%= javascript_importmap_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    /* Critical CSS — prevents FOUC during Turbo navigation / CSS lazy-compile */
    html,body{height:100%;margin:0}
    body{background:#f1f5f9;font-family:Inter,system-ui,sans-serif}
    .flex{display:flex}.flex-col{flex-direction:column}
    .h-full{height:100%}.overflow-hidden{overflow:hidden}
    aside{background:#0F172A;width:232px;min-width:232px;flex-shrink:0;display:flex;flex-direction:column;overflow:hidden}
    #main-sidebar.sb-collapsed{width:56px!important;min-width:56px!important}
    #main-sidebar.sb-collapsed .sb-label{display:none!important}
    #main-sidebar.sb-collapsed .sb-section{display:none!important}
    #main-sidebar.sb-collapsed #ws-switcher{display:none!important}
    #main-sidebar.sb-collapsed nav a{justify-content:center;padding-left:8px;padding-right:8px}
    #main-sidebar.sb-collapsed nav a .ml-auto{display:none}
    #main-sidebar.sb-collapsed .sb-footer{display:none!important}
    #main-sidebar.sb-collapsed .sb-logo-wrap{display:none!important}
    #main-sidebar.sb-collapsed .sb-toggle-row{justify-content:center}
    #main-sidebar:not(.sb-collapsed) #sb-expand-hint{display:none!important}
    .flex-1{flex:1 1 0%}.overflow-auto{overflow:auto}
    .overflow-y-auto{overflow-y:auto}
    /* Hide scrollbars globally while keeping scroll functionality */
    *::-webkit-scrollbar{display:none}
    *{-ms-overflow-style:none;scrollbar-width:none}
  </style>
  <!-- Quill rich text (lazy — only initialised when data-richtext found) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" data-turbo-track="false">
  <style>
    /* ── VOX Pulse Loader ─────────────────────────────────────────── */
    .vox-pulse-loader { display:inline-flex; flex-direction:column; align-items:center; gap:12px; }
    .vox-pulse-ring-wrap { position:relative; display:inline-flex; align-items:center; justify-content:center; }
    .vox-pulse-ring-wrap svg { position:absolute; inset:0; width:100%; height:100%; }
    .vox-pulse-icon { position:relative; z-index:1; display:flex; align-items:center; justify-content:center;
      animation: vox-pulse 1.6s ease-in-out infinite; }
    @keyframes vox-pulse {
      0%,100% { transform: scale(1);   opacity: 1;   }
      50%      { transform: scale(1.3); opacity: 0.7; }
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    .vox-pulse-pct { font-size:11px; font-weight:700; color:#7c3aed; margin-top:-4px; }
    .vox-pulse-label { font-size:12px; font-weight:600; color:#475569; text-align:center; max-width:220px; }
    .vox-pulse-sub   { font-size:11px; color:#94a3b8; text-align:center; }

    /* Shared richtext editor wrapper */
    .vox-richtext-wrap { border:1.5px solid #e2e8f0; border-radius:10px; overflow:hidden; background:#fff; }
    .vox-richtext-wrap.focused { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,0.08); }
    .vox-richtext-wrap .ql-toolbar.ql-snow { padding:4px 8px; border:none; border-bottom:1px solid #f1f5f9; background:#f8fafc; }
    .vox-richtext-wrap .ql-container.ql-snow { border:none; font-size:13px; font-family:inherit; }
    .vox-richtext-wrap .ql-editor { padding:8px 12px; min-height:72px; font-size:13px; color:#334155; line-height:1.6; }
    .vox-richtext-wrap .ql-editor.ql-blank::before { font-style:normal; color:#94a3b8; font-size:13px; }
    .vox-richtext-wrap .ql-toolbar .ql-formats { margin-right:6px; }
    .vox-richtext-wrap .ql-snow.ql-toolbar button,
    .vox-richtext-wrap .ql-snow .ql-toolbar button { width:22px; height:22px; padding:2px; }
    .vox-richtext-wrap .ql-snow .ql-picker { font-size:11px; }

    /* ── VOX Copy Button ─────────────────────────────────────────── */
    .vox-copy-btn {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 5px; padding: 5px 10px; border-radius: 7px; border: 1px solid #e2e8f0;
      background: #f8fafc; color: #64748b; font-size: 11px; font-weight: 600;
      cursor: pointer; transition: background 0.15s, border-color 0.15s, color 0.15s;
      white-space: nowrap; flex-shrink: 0; position: relative; overflow: hidden;
    }
    .vox-copy-btn:hover { background: #f1f5f9; border-color: #cbd5e1; color: #334155; }
    .vox-copy-btn.copied {
      background: #f0fdf4; border-color: #86efac; color: #16a34a;
      animation: vox-copy-success 0.35s ease;
    }
    .vox-copy-btn svg { flex-shrink: 0; display: block; transition: transform 0.2s; }
    .vox-copy-btn:active svg { transform: scale(0.88); }
    @keyframes vox-copy-success {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.1); }
      70%  { transform: scale(0.96); }
      100% { transform: scale(1); }
    }
  </style>
  <%= yield :head if content_for?(:head) %>
  <%# VOX splash: shows on cold-start, hidden instantly on subsequent Turbo navigations %>
  <style>
    #vox-splash{position:fixed;inset:0;z-index:99999;background:#0F172A;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;transition:opacity .3s ease;}
    html.vox-loaded #vox-splash{display:none!important;}
    #vox-splash.vox-splash-out{opacity:0;pointer-events:none;}
    @keyframes vox-spl-pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(.85);opacity:.7}}
    @keyframes vox-spl-dot{0%,80%,100%{transform:scale(.45);opacity:.3}40%{transform:scale(1);opacity:.85}}
    #vox-splash-icon{animation:vox-spl-pulse 1.5s ease-in-out infinite}
    .vox-spl-dot{width:7px;height:7px;border-radius:50%;background:#7aaac9;display:inline-block;animation:vox-spl-dot 1.2s ease-in-out infinite}
    .vox-spl-dot:nth-child(2){animation-delay:.18s}
    .vox-spl-dot:nth-child(3){animation-delay:.36s}
  </style>
  <script>if(sessionStorage.getItem('vox_loaded'))document.documentElement.classList.add('vox-loaded');</script>
</head>
<body class="h-full font-inter antialiased bg-slate-100">
<div id="vox-splash" role="status" aria-label="Đang tải...">
  <div id="vox-splash-icon"><img src="/icon-mark.svg" width="76" height="76" alt="VOX" onerror="this.style.display='none'"></div>
  <div style="display:flex;gap:7px;align-items:center;">
    <span class="vox-spl-dot"></span><span class="vox-spl-dot"></span><span class="vox-spl-dot"></span>
  </div>
</div>
<script>
  (function(){
    function hideSplash(){
      var s=document.getElementById('vox-splash');
      if(!s||s._done)return; s._done=true;
      sessionStorage.setItem('vox_loaded','1');
      document.documentElement.classList.add('vox-loaded');
      s.classList.add('vox-splash-out');
      setTimeout(function(){s.style.display='none';},320);
    }
    document.addEventListener('turbo:load',hideSplash,{once:true});
    window.addEventListener('load',hideSplash,{once:true});
  })();
</script>

<div class="flex h-full">
  <!-- Sidebar -->
  <aside id="main-sidebar" class="w-[232px] bg-[#0F172A] flex flex-col flex-shrink-0 overflow-hidden" style="transition:width .2s ease,min-width .2s ease">
    <div class="px-5 pt-[18px] pb-1.5 flex-shrink-0">
      <!-- Logo row -->
      <div class="sb-toggle-row flex items-center justify-between">
        <%= link_to dashboard_path, class: "block sb-logo-wrap" do %>
          <div class="flex items-center gap-2">
            <img src="/icon.svg" width="28" height="28" alt="VOX" style="display:block;">
            <span class="sb-label" style="font-size:17px;font-weight:800;color:#ffffff;letter-spacing:2.5px;line-height:1;">VOX</span>
          </div>
        <% end %>
        <button onclick="toggleSidebar()" title="Thu gọn / Mở rộng" style="background:none;border:none;cursor:pointer;padding:4px;border-radius:6px;color:#475569;display:flex;align-items:center;justify-content:center;flex-shrink:0;" onmouseover="this.style.color='#94a3b8';this.style.background='rgba(255,255,255,0.08)'" onmouseout="this.style.color='#475569';this.style.background='none'">
          <svg id="sb-toggle-icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>

    </div>

    <nav class="flex-1 pt-3 overflow-y-auto">
      <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_overview") %></div>
      <%= render "shared/nav_item", icon: "📊", label: t("nav.dashboard"), path: dashboard_path %>

      <% if current_workspace_admin? %>
        <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest">Học viên</div>
        <%= render "shared/nav_item", icon: "👥", label: "Lớp/Nhóm", path: learner_folders_path %>
      <% end %>

      <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_learning") %></div>
      <%= render "shared/nav_item", icon: "🎓", label: t("quiz.nav"), path: quiz_sets_path %>
      <%= render "shared/nav_item", icon: "🃏", label: t("flashcard.nav"), path: flashcard_decks_path %>
      <%= render "shared/nav_item", icon: "🗺️", label: t("learning_path.nav"), path: learning_paths_path %>

      <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_ai_content") %></div>
      <%= render "shared/nav_item", icon: "✍️", label: t("content_outline.nav"), path: content_outlines_path %>
      <%= render "shared/nav_item", icon: "📄", label: t("document_summary.nav"), path: document_summaries_path %>

      <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_ai_assistant") %></div>
      <%= render "shared/nav_item", icon: "🎓", label: t("ai_tutor.nav"), subtitle: t("nav.ai_tutor_subtitle"), path: ai_tutor_page_path %>
      <%= render "shared/nav_item", icon: "🔍", label: t("nav.ai_chat"), subtitle: t("nav.ai_chat_subtitle"), path: ai_chat_page_path %>

      <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_data_collection") %></div>
      <%= render "shared/nav_item", icon: "📝", label: t("nav.dynamic_forms"), path: dynamic_forms_path %>
      <%= render "shared/nav_item", icon: "📋", label: t("nav.surveys"), path: surveys_path, badge: current_workspace&.surveys&.active&.count %>
      <%= render "shared/nav_item", icon: "🗳️", label: t("nav.votes"), path: votes_path, badge: current_workspace&.votes&.active&.count %>
      <%= render "shared/nav_item", icon: "💬", label: t("nav.feedback"), path: feedback_boards_path %>

      <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_voice_tools") %></div>
      <%= render "shared/nav_item", icon: "🎙️", label: t("nav.tts"), path: tts_path %>
      <%= render "shared/nav_item", icon: "🎤", label: t("nav.stt"), path: stt_path %>

      <% if current_workspace_admin? %>
        <div class="sb-section px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_manage") %></div>
        <%= render "shared/nav_item", icon: "💳", label: t("nav.subscription"), path: subscription_path %>
        <%= render "shared/nav_item", icon: "📜", label: t("nav.audit_log"), path: audit_log_path %>
        <% if workspace_owner? %>
          <%= render "shared/nav_item", icon: "👥", label: t("nav.members"), path: members_path %>
          <%= render "shared/nav_item", icon: "⚙️", label: t("nav.settings"), path: workspace_settings_path %>
        <% end %>
      <% end %>
    </nav>

    <!-- Sidebar footer: workspace switcher + AI credits + user -->
    <div class="mt-auto border-t border-white/[0.06] px-4 py-3.5 sb-footer">
      <%# Workspace switcher — lives in footer so dropdown opens upward (never overlaps nav items) %>
      <% all_workspaces = accessible_workspaces rescue [] %>
      <% if all_workspaces.size > 0 %>
        <div class="relative mb-3" id="ws-switcher">
          <button type="button" onclick="document.getElementById('ws-dropdown').classList.toggle('hidden')"
            class="w-full flex items-center gap-2 text-left group cursor-pointer bg-white/[0.06] hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-lg px-2.5 py-1.5 transition-all">
            <div class="w-4 h-4 rounded bg-indigo-500/30 flex items-center justify-center flex-shrink-0">
              <svg class="w-2.5 h-2.5 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 7h18M3 12h18M3 17h18"/></svg>
            </div>
            <span class="sb-label text-[12px] text-slate-200 font-semibold truncate flex-1 group-hover:text-white transition-colors">
              <%= current_workspace&.name || "Platform" %>
            </span>
            <svg class="sb-label w-3 h-3 text-slate-500 group-hover:text-slate-300 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
            </svg>
          </button>
          <%# Dropdown opens UPWARD (bottom-full) — never overlaps nav items %>
          <div id="ws-dropdown" class="hidden absolute left-0 bottom-full mb-1 z-50 bg-[#1e293b] border border-white/10 rounded-xl shadow-xl py-1 min-w-[180px] max-w-[220px]">
            <% all_workspaces.each do |ws| %>
              <% is_active = ws.id == current_workspace&.id %>
              <% ws_suspended = !ws.active? %>
              <% ws_role = (ws.owner_id == current_user.id || current_user.workspace_id == ws.id) ? :admin : current_user.workspace_memberships.find_by(workspace: ws, status: :active)&.role&.to_sym %>
              <%= button_to switch_workspace_path(workspace_id: ws.id), method: :post,
                    data: { turbo: false },
                    class: "w-full text-left px-3 py-2.5 flex items-center gap-2 hover:bg-white/5 transition-colors border-0 bg-transparent cursor-pointer #{is_active ? '' : 'opacity-75 hover:opacity-100'}" do %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-1.5">
                    <span class="text-[12px] font-semibold text-white truncate"><%= ws.name %></span>
                    <% if ws_suspended %>
                      <span class="text-[9px] px-1 py-0.5 rounded bg-red-500/20 text-red-400 font-bold flex-shrink-0">🔒</span>
                    <% end %>
                  </div>
                  <div class="text-[10px] text-slate-500 mt-0.5"><%= ws_role ? t("roles.#{ws_role}") : "" %></div>
                </div>
                <% if is_active %>
                  <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                <% end %>
              <% end %>
            <% end %>
            <div class="border-t border-white/10 mt-1 pt-1">
              <%= link_to new_workspace_path,
                    class: "flex items-center gap-2 px-3 py-2 text-[11px] font-semibold text-indigo-300 hover:text-indigo-200 hover:bg-white/5 transition-colors rounded-lg mx-1" do %>
                <span class="text-[14px]">+</span>
                <%= I18n.locale == :vi ? "Tạo không gian mới" : "Create new workspace" %>
              <% end %>
            </div>
          </div>
        </div>
        <script>
          document.addEventListener('click', function(e) {
            var sw = document.getElementById('ws-switcher');
            var dd = document.getElementById('ws-dropdown');
            if (sw && dd && !sw.contains(e.target)) dd.classList.add('hidden');
          });
          // Also close dropdown on any Turbo navigation to prevent stale open state
          document.addEventListener('turbo:before-visit', function() {
            document.getElementById('ws-dropdown')?.classList.add('hidden');
          });
        </script>
      <% end %>

      <% if (sub = current_workspace&.credit_subscription) && sub.max_ai_credits.to_i > 0 %>
        <div class="flex justify-between text-[11px] text-slate-500 mb-1.5 mt-2">
          <span>AI Credits</span>
          <strong class="text-violet-400">
            <span id="nav-credit-balance"><%= sub.credit_balance %></span> / <span id="nav-credit-max"><%= sub.max_ai_credits || "∞" %></span>
          </strong>
        </div>
        <div class="h-1 bg-white/[0.07] rounded-sm mb-3 overflow-hidden">
          <div id="nav-credit-bar" class="h-1 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-sm" style="width: <%= sub.credit_percentage %>%"></div>
        </div>
        <script>
          // Global helper — called after any AI job completes
          window.__maxCredits     = <%= sub.max_ai_credits.nil? ? 'null' : sub.max_ai_credits %>;
          window.__currentCredits = <%= sub.credit_balance %>;
          window.deductDisplayCredits = function(amount) {
            const el  = document.getElementById('nav-credit-balance');
            const bar = document.getElementById('nav-credit-bar');
            if (!el) return;
            const current = parseInt(el.textContent) || 0;
            const next    = Math.max(0, current - amount);
            el.textContent = next;
            window.__currentCredits = next;
            if (bar && window.__maxCredits) {
              bar.style.width = Math.round((next / window.__maxCredits) * 100) + '%';
            }
            // Also update chat page counter if present
            const chatEl = document.getElementById('credit-display');
            if (chatEl) chatEl.textContent = next;
          };
        </script>
      <% end %>
      <div class="flex items-center gap-2.5">
        <%= link_to profile_path, class: "flex items-center gap-2.5 min-w-0 flex-1 group", title: t("nav.profile") do %>
          <div class="w-[30px] h-[30px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[12px] font-bold text-white flex-shrink-0 group-hover:ring-2 group-hover:ring-indigo-400 transition-all">
            <%= current_user.initials %>
          </div>
          <div class="min-w-0">
            <div class="text-[12px] font-semibold text-white truncate group-hover:text-indigo-300 transition-colors"><%= current_user.display_name %></div>
            <div class="text-[10px] text-slate-500"><%= t("roles.#{current_workspace_role || current_user.role}") %></div>
          </div>
        <% end %>
        <button type="button" onclick="document.getElementById('logout-modal').classList.remove('hidden')" title="<%= t('nav.sign_out') %>" class="ml-auto text-slate-600 hover:text-slate-400 text-[13px] bg-transparent border-0 cursor-pointer p-0 flex-shrink-0">⏻</button>
      </div>
    </div>
  </aside>

  <!-- Main area -->
  <div class="flex-1 flex flex-col overflow-hidden min-w-0">
    <!-- Top header -->
    <header class="h-14 bg-white border-b border-slate-200 flex items-center px-6 gap-3.5 flex-shrink-0">
      <nav class="flex items-center gap-1.5 text-[13px] text-slate-400">
        <% if content_for?(:breadcrumb) %>
          <%= yield(:breadcrumb) %>
        <% end %>
      </nav>
      <div class="ml-auto flex items-center gap-2.5">
        <!-- Language switcher -->
        <div class="flex gap-0.5 bg-slate-100 border border-slate-200 rounded-lg p-0.5">
