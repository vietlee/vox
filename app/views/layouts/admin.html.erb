          <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-2.5 text-[13px] font-medium">
            ⚠ <%= alert %>
          </div>
        <% end %>
      </div>
      <script>
        (function() {
          const flash = document.getElementById('flash');
          if (!flash) return;
          setTimeout(function() {
            flash.style.transition = 'opacity 0.5s ease, max-height 0.5s ease, padding 0.5s ease';
            flash.style.overflow = 'hidden';
            flash.style.opacity = '0';
            flash.style.maxHeight = '0';
            flash.style.paddingTop = '0';
            flash.style.paddingBottom = '0';
          }, 5000);
        })();
      </script>
    <% end %>

    <!-- Page content -->
    <main id="admin-main" class="<%= content_for?(:main_class) ? yield(:main_class) : 'flex-1 overflow-y-auto p-6' %>">
      <%= yield %>
    </main>

    <script>
    (function() {
      function applyPageHeaderSticky() {
        var anchor = document.querySelector('[data-page-header-anchor]');
        if (!anchor) return;
        var main = document.getElementById('admin-main');
        if (!main) return;

        // Only apply sticky when main itself is the scroll container
        // (flex-col overflow-hidden pages pin header via flex layout already)
        var mainOverflow = window.getComputedStyle(main).overflowY;
        if (mainOverflow !== 'auto' && mainOverflow !== 'scroll') return;

        // Walk up from anchor to find the direct child of main
        var el = anchor;
        while (el && el.parentElement !== main) { el = el.parentElement; }
        if (!el || el === main) return;

        // Extend full width (main has p-6 = 24px padding)
        var pad = parseInt(window.getComputedStyle(main).paddingLeft) || 24;
        el.style.position = 'sticky';
        el.style.top      = '-' + pad + 'px';
        el.style.zIndex   = '30';
        el.style.marginLeft  = '-' + pad + 'px';
        el.style.marginRight = '-' + pad + 'px';
        el.style.paddingLeft  = pad + 'px';
        el.style.paddingRight = pad + 'px';
        el.style.paddingTop    = pad + 'px';
        el.style.paddingBottom = '12px';
        el.style.background = 'rgba(241,245,249,0.97)';
        el.style.backdropFilter = 'blur(6px)';
        el.style.webkitBackdropFilter = 'blur(6px)';
        el.style.boxShadow = '0 1px 0 0 #e2e8f0';
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', applyPageHeaderSticky);
      } else {
        applyPageHeaderSticky();
      }
    })();
    </script>
  </div>
</div>


