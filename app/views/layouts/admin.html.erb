<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? "#{yield(:title)} — Vox" : "Vox" %></title>
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <meta name="turbo-cache-control" content="no-cache">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/icon.png" type="image/png">
  <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
  <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
  <%= javascript_importmap_tags %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    /* Critical CSS — prevents FOUC during Turbo navigation / CSS lazy-compile */
    html,body{height:100%;margin:0}
    body{background:#f1f5f9;font-family:Inter,system-ui,sans-serif}
    .flex{display:flex}.flex-col{flex-direction:column}
    .h-full{height:100%}.overflow-hidden{overflow:hidden}
    aside{background:#0F172A;width:232px;min-width:232px;flex-shrink:0;display:flex;flex-direction:column;overflow:hidden;transition:width .2s ease,min-width .2s ease}
    aside.collapsed{width:56px;min-width:56px}
    aside.collapsed .sidebar-label{display:none}
    aside.collapsed .sidebar-section-label{display:none}
    aside.collapsed .sidebar-footer-text{display:none}
    aside.collapsed .ws-switcher-wrap{display:none}
    aside.collapsed .sidebar-logo-text{display:none}
    aside.collapsed nav a,aside.collapsed nav form{justify-content:center;padding-left:0;padding-right:0}
    aside.collapsed nav a span:first-child,aside.collapsed nav form span:first-child{margin:0}
    aside.collapsed .sidebar-footer-wrap{padding-left:0;padding-right:0;display:flex;justify-content:center}
    aside.collapsed .sidebar-footer-wrap>*{display:none}
    aside.collapsed #sidebar-toggle{display:flex!important;margin:0}
    aside:not(.collapsed) #sidebar-expand-btn{display:none}
    .flex-1{flex:1 1 0%}.overflow-auto{overflow:auto}
    .overflow-y-auto{overflow-y:auto}
    /* Hide scrollbars globally while keeping scroll functionality */
    *::-webkit-scrollbar{display:none}
    *{-ms-overflow-style:none;scrollbar-width:none}
  </style>
  <!-- Quill rich text (lazy — only initialised when data-richtext found) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" data-turbo-track="false">
  <style>
    /* ── VOX Pulse Loader ─────────────────────────────────────────── */
    .vox-pulse-loader { display:inline-flex; flex-direction:column; align-items:center; gap:12px; }
    .vox-pulse-ring-wrap { position:relative; display:inline-flex; align-items:center; justify-content:center; }
    .vox-pulse-ring-wrap svg { position:absolute; inset:0; width:100%; height:100%; }
    .vox-pulse-icon { position:relative; z-index:1; display:flex; align-items:center; justify-content:center;
      animation: vox-pulse 1.6s ease-in-out infinite; }
    @keyframes vox-pulse {
      0%,100% { transform: scale(1);   opacity: 1;   }
      50%      { transform: scale(1.3); opacity: 0.7; }
    }
    @keyframes spin {
      from { transform: rotate(0deg); }
      to   { transform: rotate(360deg); }
    }
    .vox-pulse-pct { font-size:11px; font-weight:700; color:#7c3aed; margin-top:-4px; }
    .vox-pulse-label { font-size:12px; font-weight:600; color:#475569; text-align:center; max-width:220px; }
    .vox-pulse-sub   { font-size:11px; color:#94a3b8; text-align:center; }

    /* Shared richtext editor wrapper */
    .vox-richtext-wrap { border:1.5px solid #e2e8f0; border-radius:10px; overflow:hidden; background:#fff; }
    .vox-richtext-wrap.focused { border-color:#6366f1; box-shadow:0 0 0 3px rgba(99,102,241,0.08); }
    .vox-richtext-wrap .ql-toolbar.ql-snow { padding:4px 8px; border:none; border-bottom:1px solid #f1f5f9; background:#f8fafc; }
    .vox-richtext-wrap .ql-container.ql-snow { border:none; font-size:13px; font-family:inherit; }
    .vox-richtext-wrap .ql-editor { padding:8px 12px; min-height:72px; font-size:13px; color:#334155; line-height:1.6; }
    .vox-richtext-wrap .ql-editor.ql-blank::before { font-style:normal; color:#94a3b8; font-size:13px; }
    .vox-richtext-wrap .ql-toolbar .ql-formats { margin-right:6px; }
    .vox-richtext-wrap .ql-snow.ql-toolbar button,
    .vox-richtext-wrap .ql-snow .ql-toolbar button { width:22px; height:22px; padding:2px; }
    .vox-richtext-wrap .ql-snow .ql-picker { font-size:11px; }

    /* ── VOX Copy Button ─────────────────────────────────────────── */
    .vox-copy-btn {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 5px; padding: 5px 10px; border-radius: 7px; border: 1px solid #e2e8f0;
      background: #f8fafc; color: #64748b; font-size: 11px; font-weight: 600;
      cursor: pointer; transition: background 0.15s, border-color 0.15s, color 0.15s;
      white-space: nowrap; flex-shrink: 0; position: relative; overflow: hidden;
    }
    .vox-copy-btn:hover { background: #f1f5f9; border-color: #cbd5e1; color: #334155; }
    .vox-copy-btn.copied {
      background: #f0fdf4; border-color: #86efac; color: #16a34a;
      animation: vox-copy-success 0.35s ease;
    }
    .vox-copy-btn svg { flex-shrink: 0; display: block; transition: transform 0.2s; }
    .vox-copy-btn:active svg { transform: scale(0.88); }
    @keyframes vox-copy-success {
      0%   { transform: scale(1); }
      40%  { transform: scale(1.1); }
      70%  { transform: scale(0.96); }
      100% { transform: scale(1); }
    }
  </style>
  <%= yield :head if content_for?(:head) %>
</head>
<body class="h-full font-inter antialiased bg-slate-100">

<div class="flex h-full">
  <!-- Sidebar -->
  <aside id="main-sidebar" class="w-[232px] bg-[#0F172A] flex flex-col flex-shrink-0 overflow-hidden">
    <div class="px-4 pt-[18px] pb-1.5 flex-shrink-0 flex items-center justify-between">
      <%= link_to dashboard_path, class: "block" do %>
        <div class="flex items-center gap-2">
          <svg width="28" height="28" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
            <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
            <polygon points="325,84 318,98 338,84" fill="white"/>
            <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
            <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
            <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
            <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
          </svg>
          <span class="sidebar-logo-text" style="font-size:17px;font-weight:800;color:#1A6BFF;letter-spacing:2.5px;line-height:1;">VOX</span>
        </div>
      <% end %>
      <button id="sidebar-toggle" onclick="toggleSidebar()" title="Thu gọn / Mở rộng"
        class="ml-auto flex items-center justify-center w-6 h-6 rounded-md text-slate-500 hover:text-slate-300 hover:bg-white/10 transition-all border-0 bg-transparent cursor-pointer flex-shrink-0">
        <svg id="sidebar-toggle-icon" width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>

      <%# Workspace switcher %>
      <% all_workspaces = accessible_workspaces rescue [] %>
      <div class="relative mt-2 ws-switcher-wrap" id="ws-switcher">
        <button type="button" onclick="document.getElementById('ws-dropdown').classList.toggle('hidden')"
          class="w-full flex items-center gap-2 text-left group cursor-pointer bg-white/[0.06] hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-lg px-2.5 py-1.5 transition-all">
          <span class="text-[12px] text-slate-200 font-semibold truncate flex-1 group-hover:text-white transition-colors">
            <%= current_workspace&.name || "Platform" %>
          </span>
          <svg class="w-3.5 h-3.5 text-slate-400 group-hover:text-slate-200 flex-shrink-0 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 9l4-4 4 4m0 6l-4 4-4-4"/>
          </svg>
        </button>
        <div id="ws-dropdown" class="hidden absolute left-0 top-full mt-1 z-50 bg-[#1e293b] border border-white/10 rounded-xl shadow-xl py-1 min-w-[180px] max-w-[220px]">
          <% all_workspaces.each do |ws| %>
            <% is_active = ws.id == current_workspace&.id %>
            <% ws_suspended = !ws.active? %>
            <% ws_role = (ws.owner_id == current_user.id || current_user.workspace_id == ws.id) ? :admin : current_user.workspace_memberships.find_by(workspace: ws, status: :active)&.role&.to_sym %>
            <%= button_to switch_workspace_path(workspace_id: ws.id), method: :post,
                  data: { turbo: false },
                  class: "w-full text-left px-3 py-2.5 flex items-center gap-2 hover:bg-white/5 transition-colors border-0 bg-transparent cursor-pointer #{is_active ? '' : 'opacity-75 hover:opacity-100'}" do %>
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-1.5">
                  <span class="text-[12px] font-semibold text-white truncate"><%= ws.name %></span>
                  <% if ws_suspended %>
                    <span class="text-[9px] px-1 py-0.5 rounded bg-red-500/20 text-red-400 font-bold flex-shrink-0">🔒</span>
                  <% end %>
                </div>
                <div class="text-[10px] text-slate-500 mt-0.5"><%= ws_role ? t("roles.#{ws_role}") : "" %></div>
              </div>
              <% if is_active %>
                <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
              <% end %>
            <% end %>
          <% end %>
          <div class="border-t border-white/10 mt-1 pt-1">
            <%= link_to new_workspace_path,
                  class: "flex items-center gap-2 px-3 py-2 text-[11px] font-semibold text-indigo-300 hover:text-indigo-200 hover:bg-white/5 transition-colors rounded-lg mx-1" do %>
              <span class="text-[14px]">+</span>
              <%= I18n.locale == :vi ? "Tạo không gian mới" : "Create new workspace" %>
            <% end %>
          </div>
        </div>
      </div>
      <script>
        document.addEventListener('click', function(e) {
          var sw = document.getElementById('ws-switcher');
          var dd = document.getElementById('ws-dropdown');
          if (sw && dd && !sw.contains(e.target)) dd.classList.add('hidden');
        });
      </script>
    </div>

    <nav class="flex-1 pt-3 overflow-y-auto">
      <div class="sidebar-section-label px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_overview") %></div>
      <%= render "shared/nav_item", icon: "📊", label: t("nav.dashboard"), path: dashboard_path %>

      <div class="sidebar-section-label px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest">Tạo nội dung</div>
      <%= render "shared/nav_item", icon: "🎓", label: t("quiz.nav"), path: quiz_sets_path %>
      <%= render "shared/nav_item", icon: "✍️", label: "Tạo nội dung AI", path: content_outlines_path %>
      <%= render "shared/nav_item", icon: "🗺️", label: "Lộ trình học tập", path: learning_paths_path %>

      <div class="sidebar-section-label px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest">Học & luyện tập</div>
      <%= render "shared/nav_item", icon: "🃏", label: "Flashcards", path: flashcard_decks_path %>
      <%= render "shared/nav_item", icon: "📄", label: "Tóm tắt tài liệu", path: document_summaries_path %>
      <%= render "shared/nav_item", icon: "🤖", label: "AI Tutor", path: ai_tutor_page_path %>
      <%= render "shared/nav_item", icon: "✨", label: t("nav.ai_chat"), path: ai_chat_page_path %>

      <div class="sidebar-section-label px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_tools") %></div>
      <%= render "shared/nav_item", icon: "🎙️", label: t("nav.tts"), path: tts_path %>
      <%= render "shared/nav_item", icon: "🎤", label: t("nav.stt"), path: stt_path %>
      <%= render "shared/nav_item", icon: "📝", label: "Dynamic Forms", path: dynamic_forms_path %>
      <%= render "shared/nav_item", icon: "📋", label: t("nav.surveys"), path: surveys_path, badge: current_workspace&.surveys&.active&.count %>
      <%= render "shared/nav_item", icon: "🗳️", label: t("nav.votes"), path: votes_path, badge: current_workspace&.votes&.active&.count %>
      <%= render "shared/nav_item", icon: "💬", label: t("nav.feedback"), path: feedback_boards_path %>

      <% if current_workspace_admin? %>
        <div class="sidebar-section-label px-5 pt-3 pb-1 text-[10px] font-bold text-slate-600 uppercase tracking-widest"><%= t("nav.section_manage") %></div>
        <%= render "shared/nav_item", icon: "👥", label: t("nav.members"), path: members_path %>
        <%= render "shared/nav_item", icon: "⚙️", label: t("nav.settings"), path: workspace_settings_path %>
        <%= render "shared/nav_item", icon: "💳", label: t("nav.subscription"), path: subscription_path %>
        <%= render "shared/nav_item", icon: "📜", label: t("nav.audit_log"), path: audit_log_path %>
      <% end %>
    </nav>

    <!-- Sidebar footer: AI credits + user -->
    <div class="mt-auto border-t border-white/[0.06] px-4 py-3.5 sidebar-footer-wrap">
      <% if (sub = current_workspace&.active_subscription) && sub.max_ai_credits.to_i > 0 %>
        <div class="flex justify-between text-[11px] text-slate-500 mb-1.5 mt-2">
          <span>AI Credits</span>
          <strong class="text-violet-400">
            <span id="nav-credit-balance"><%= sub.credit_balance %></span> / <span id="nav-credit-max"><%= sub.max_ai_credits || "∞" %></span>
          </strong>
        </div>
        <div class="h-1 bg-white/[0.07] rounded-sm mb-3 overflow-hidden">
          <div id="nav-credit-bar" class="h-1 bg-gradient-to-r from-indigo-500 to-violet-500 rounded-sm" style="width: <%= sub.credit_percentage %>%"></div>
        </div>
        <script>
          // Global helper — called after any AI job completes
          window.__maxCredits     = <%= sub.max_ai_credits.nil? ? 'null' : sub.max_ai_credits %>;
          window.__currentCredits = <%= sub.credit_balance %>;
          window.deductDisplayCredits = function(amount) {
            const el  = document.getElementById('nav-credit-balance');
            const bar = document.getElementById('nav-credit-bar');
            if (!el) return;
            const current = parseInt(el.textContent) || 0;
            const next    = Math.max(0, current - amount);
            el.textContent = next;
            window.__currentCredits = next;
            if (bar && window.__maxCredits) {
              bar.style.width = Math.round((next / window.__maxCredits) * 100) + '%';
            }
            // Also update chat page counter if present
            const chatEl = document.getElementById('credit-display');
            if (chatEl) chatEl.textContent = next;
          };
        </script>
      <% end %>
      <div class="flex items-center gap-2.5">
        <%= link_to profile_path, class: "flex items-center gap-2.5 min-w-0 flex-1 group", title: t("nav.profile") do %>
          <div class="w-[30px] h-[30px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[12px] font-bold text-white flex-shrink-0 group-hover:ring-2 group-hover:ring-indigo-400 transition-all">
            <%= current_user.initials %>
          </div>
          <div class="min-w-0">
            <div class="text-[12px] font-semibold text-white truncate group-hover:text-indigo-300 transition-colors"><%= current_user.display_name %></div>
            <div class="text-[10px] text-slate-500"><%= t("roles.#{current_workspace_role || current_user.role}") %></div>
          </div>
        <% end %>
        <button type="button" onclick="document.getElementById('logout-modal').classList.remove('hidden')" title="<%= t('nav.sign_out') %>" class="ml-auto text-slate-600 hover:text-slate-400 text-[13px] bg-transparent border-0 cursor-pointer p-0 flex-shrink-0">⏻</button>
      </div>
    </div>
  </aside>

  <!-- Main area -->
  <div class="flex-1 flex flex-col overflow-hidden min-w-0">
    <!-- Top header -->
    <header class="h-14 bg-white border-b border-slate-200 flex items-center px-6 gap-3.5 flex-shrink-0">
      <nav class="flex items-center gap-1.5 text-[13px] text-slate-400">
        <% if content_for?(:breadcrumb) %>
          <%= yield(:breadcrumb) %>
        <% end %>
      </nav>
      <div class="ml-auto flex items-center gap-2.5">
        <!-- Language switcher -->
        <div class="flex gap-0.5 bg-slate-100 border border-slate-200 rounded-lg p-0.5">
          <%= link_to request.path + "?locale=vi", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :vi ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇻🇳 VI<% end %>
          <%= link_to request.path + "?locale=en", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :en ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇬🇧 EN<% end %>
        </div>
        <%= link_to notifications_path, class: "relative w-[34px] h-[34px] rounded-lg bg-slate-100 border border-slate-200 flex items-center justify-center text-[15px] text-slate-500 hover:bg-slate-200 transition-colors" do %>
          🔔
          <% unread = current_user.notifications.unread.count; if unread > 0 %>
            <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
          <% end %>
        <% end %>
        <div class="w-[34px] h-[34px] rounded-full bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-[13px] font-bold text-white">
          <%= current_user.initials %>
        </div>
      </div>
    </header>


    <!-- Flash messages -->
    <% if notice || alert %>
      <div id="flash" class="px-6 pt-4 transition-all duration-500">
        <% if notice %>
          <div class="flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg px-4 py-2.5 text-[13px] font-medium">
            ✓ <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-2.5 text-[13px] font-medium">
            ⚠ <%= alert %>
          </div>
        <% end %>
      </div>
      <script>
        (function() {
          const flash = document.getElementById('flash');
          if (!flash) return;
          setTimeout(function() {
            flash.style.transition = 'opacity 0.5s ease, max-height 0.5s ease, padding 0.5s ease';
            flash.style.overflow = 'hidden';
            flash.style.opacity = '0';
            flash.style.maxHeight = '0';
            flash.style.paddingTop = '0';
            flash.style.paddingBottom = '0';
          }, 5000);
        })();
      </script>
    <% end %>

    <!-- Page content -->
    <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'flex-1 overflow-y-auto p-6' %>">
      <%= yield %>
    </main>
  </div>
</div>


<!-- Logout confirm modal -->
<div id="logout-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" onclick="document.getElementById('logout-modal').classList.add('hidden')"></div>
    <div class="relative bg-white rounded-2xl shadow-xl p-6 w-[320px] text-center">
      <div class="text-[32px] mb-3">👋</div>
      <h3 class="text-[16px] font-extrabold text-slate-900 mb-1"><%= t("super_admin.logout.title") %></h3>
      <p class="text-[13px] text-slate-500 mb-5"><%= t("super_admin.logout.desc") %></p>
      <div class="flex gap-2">
        <button onclick="document.getElementById('logout-modal').classList.add('hidden')"
          class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-[13px] font-semibold rounded-lg hover:bg-slate-200 border-0 cursor-pointer">
          <%= t("super_admin.logout.cancel") %>
        </button>
        <%= button_to destroy_user_session_path, method: :delete,
              form_class: "flex-1",
              class: "w-full py-2.5 bg-red-500 text-white text-[13px] font-semibold rounded-lg hover:bg-red-600 border-0 cursor-pointer" do %>
          <%= t("super_admin.logout.confirm") %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= render "shared/mobile_admin_warning" %>

<!-- ── AI Credits Insufficient Modal ──────────────────────────────────── -->
<div id="ai-credits-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4"
     style="background:rgba(15,23,42,0.6);"
     onclick="if(event.target===this)closeAiCreditsModal()">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-[420px] overflow-hidden">
    <!-- Header -->
    <div class="bg-gradient-to-br from-amber-400 to-orange-500 px-6 py-5 text-center">
      <div class="text-4xl mb-2">🪙</div>
      <h3 class="text-[17px] font-extrabold text-white"><%= t("ai.credits_modal_title") %></h3>
    </div>
    <!-- Body -->
    <div class="px-6 py-5">
      <p class="text-[13px] text-slate-600 leading-relaxed mb-5"><%= t("ai.credits_modal_desc") %></p>
      <div class="flex flex-col gap-2">
        <a href="<%= billing_subscription_path %>"
           class="block w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white text-[14px] font-bold rounded-xl text-center transition-colors">
          🛒 <%= t("ai.credits_modal_cta") %>
        </a>
        <button onclick="closeAiCreditsModal()"
                class="block w-full py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 text-[13px] font-semibold rounded-xl transition-colors">
          <%= t("common.cancel") %>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  window.showAiCreditsModal = function() {
    var m = document.getElementById('ai-credits-modal');
    m.classList.remove('hidden');
    m.classList.add('flex');
  };
  window.closeAiCreditsModal = function() {
    var m = document.getElementById('ai-credits-modal');
    m.classList.add('hidden');
    m.classList.remove('flex');
  };
  window.showAiUpgradeModal = function() { showAiCreditsModal(); };
  window.closeAiUpgradeModal = function() { closeAiCreditsModal(); };
  window.handleAiUpgrade = function(resp, data) {
    if (resp.status === 402 || data?.insufficient_credits) {
      showAiCreditsModal();
      return true;
    }
    return false;
  };
  /* Returns true if error was a credits issue (and opens modal), false otherwise */
  window.handleAiError = function(data, resp) {
    if ((resp && resp.status === 402) || data?.insufficient_credits) {
      showAiCreditsModal();
      return true;
    }
    return false;
  };

  document.addEventListener('turbo:before-cache', function() {
    document.querySelectorAll('[id$="-modal"]').forEach(function(el) {
      el.classList.add('hidden');
    });
  });

</script>

<script>
// ── Override browser-native HTML5 validation messages with i18n strings ──────
(function() {
  const MSGS = {
    valueMissing:   "<%= j t('errors.messages.blank', default: 'Không được để trống') %>",
    typeMismatch:   "<%= j t('errors.messages.invalid', default: 'Giá trị không hợp lệ') %>",
    tooShort:       "<%= j t('errors.messages.too_short.other', count: '__COUNT__', default: 'Quá ngắn (tối thiểu __COUNT__ ký tự)') %>",
    tooLong:        "<%= j t('errors.messages.too_long.other', count: '__COUNT__', default: 'Quá dài (tối đa __COUNT__ ký tự)') %>",
    rangeUnderflow: "<%= j t('errors.messages.greater_than_or_equal_to', count: '__COUNT__', default: 'Phải lớn hơn hoặc bằng __COUNT__') %>",
    rangeOverflow:  "<%= j t('errors.messages.less_than_or_equal_to', count: '__COUNT__', default: 'Phải nhỏ hơn hoặc bằng __COUNT__') %>",
    patternMismatch:"<%= j t('errors.messages.invalid', default: 'Định dạng không hợp lệ') %>",
  };

  document.addEventListener('invalid', function(e) {
    const el = e.target;
    el.setCustomValidity(''); // reset first so we get fresh validity state
    const v = el.validity;
    let msg = '';
    if (v.valueMissing)    msg = MSGS.valueMissing;
    else if (v.typeMismatch)    msg = MSGS.typeMismatch;
    else if (v.tooShort)        msg = MSGS.tooShort.replace(/__COUNT__/g, el.minLength);
    else if (v.tooLong)         msg = MSGS.tooLong.replace(/__COUNT__/g, el.maxLength);
    else if (v.rangeUnderflow)  msg = MSGS.rangeUnderflow.replace(/__COUNT__/g, el.min);
    else if (v.rangeOverflow)   msg = MSGS.rangeOverflow.replace(/__COUNT__/g, el.max);
    else if (v.patternMismatch) msg = MSGS.patternMismatch;
    if (msg) el.setCustomValidity(msg);
  }, true);

  // Clear custom message when user starts typing so next submit re-validates cleanly
  document.addEventListener('input', function(e) {
    if (e.target.setCustomValidity) e.target.setCustomValidity('');
  }, true);
})();
</script>

<!-- Quill rich text initializer (shared across all admin pages) -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js" data-turbo-track="false"></script>
<script>
(function() {
  const RICHTEXT_TOOLBAR = [
    ['bold', 'italic', 'underline'],
    [{ list: 'ordered' }, { list: 'bullet' }],
    [{ color: [] }],
    ['clean']
  ];

  function initRichtextAreas(root) {
    (root || document).querySelectorAll('textarea[data-richtext]').forEach(function(ta) {
      if (ta._voxQuill) return;
      ta._voxQuill = true;

      // Build wrapper
      const wrap = document.createElement('div');
      wrap.className = 'vox-richtext-wrap';
      const editorDiv = document.createElement('div');
      wrap.appendChild(editorDiv);
      ta.parentNode.insertBefore(wrap, ta);
      ta.style.display = 'none';
      wrap.appendChild(ta); // keep in DOM for form submit

      const q = new Quill(editorDiv, {
        theme: 'snow',
        placeholder: ta.placeholder || '',
        modules: { toolbar: RICHTEXT_TOOLBAR }
      });

      // Load existing value
      const existing = ta.value.trim();
      if (existing) {
        if (existing.startsWith('<')) {
          q.clipboard.dangerouslyPasteHTML(existing);
        } else {
          q.setText(existing);
        }
        q.history.clear();
      }

      // Sync to textarea on change
      q.on('text-change', function() {
        const html = q.root.innerHTML;
        ta.value = (html === '<p><br></p>' || html === '') ? '' : html;
      });

      // Focus ring
      q.on('selection-change', function(range) {
        wrap.classList.toggle('focused', !!range);
      });
    });
  }

  // Run on page load and after Turbo navigation
  document.addEventListener('DOMContentLoaded', function() { initRichtextAreas(); });
  document.addEventListener('turbo:load', function() { initRichtextAreas(); });
  document.addEventListener('turbo:frame-load', function(e) { initRichtextAreas(e.target); });
  window.initRichtextAreas = initRichtextAreas;
})();
</script>
<script>
// ── Global VOX Copy Helper ────────────────────────────────────────────
// Standard copy icon: 2 overlapping pages (back page offset top-right)
window.VOX_COPY_ICON = `<svg width="15" height="15" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect x="7" y="7" width="11" height="13" rx="2.5" stroke="currentColor" stroke-width="1.6"/>
  <path d="M13 7V4.5A1.5 1.5 0 0 0 11.5 3H3.5A1.5 1.5 0 0 0 2 4.5V13.5A1.5 1.5 0 0 0 3.5 15H7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
</svg>`;

// Checkmark icon for success state
window.VOX_CHECK_ICON = `<svg width="15" height="15" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
  <path d="M4 10.5L8.5 15L16 6" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
</svg>`;

// voxCopy(text, btn) — copies text, animates btn to success state
window.voxCopy = function(text, btn) {
  const doAnim = (ok) => {
    if (!btn) return;
    const orig = btn.innerHTML;
    if (ok) {
      const iconOnly = btn.dataset.iconOnly === 'true' || !btn.querySelector('span');
      // Icon-only buttons: show check icon only; text buttons: show check + text
      const checkIcon = `<svg width="15" height="15" viewBox="0 0 20 20" fill="none" style="display:block;"><path d="M4 10.5L8.5 15L16 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
      btn.innerHTML = iconOnly ? checkIcon : (checkIcon + `<span>Đã sao chép</span>`);
      btn.classList.add('copied');
      setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
    }
  };
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(text).then(() => doAnim(true)).catch(() => {
      fallbackCopy(text); doAnim(true);
    });
  } else {
    fallbackCopy(text); doAnim(true);
  }
};
function fallbackCopy(text) {
  const ta = document.createElement('textarea');
  ta.value = text; ta.style.cssText = 'position:fixed;opacity:0;top:0;left:0;';
  document.body.appendChild(ta); ta.select();
  try { document.execCommand('copy'); } catch(e) {}
  document.body.removeChild(ta);
}

// copyQrImage(imgEl, btn) — draw <img> to canvas, copy as PNG
window.copyQrImage = function(imgEl, btn) {
  if (!imgEl) return;
  const canvas = document.createElement('canvas');
  canvas.width = 512; canvas.height = 512;
  const ctx = canvas.getContext('2d');
  const draw = () => {
    ctx.fillStyle = '#ffffff';
    ctx.fillRect(0, 0, 512, 512);
    ctx.drawImage(imgEl, 0, 0, 512, 512);
    canvas.toBlob(async blob => {
      try {
        await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);
        if (btn) {
          const orig = btn.innerHTML;
          btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 20 20" fill="none"><path d="M4 10.5L8.5 15L16 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Đã copy!</span>`;
          btn.classList.add('copied');
          setTimeout(() => { btn.innerHTML = orig; btn.classList.remove('copied'); }, 2000);
        }
      } catch(e) { alert('Trình duyệt không hỗ trợ copy ảnh. Hãy tải về thay thế.'); }
    }, 'image/png');
  };
  if (imgEl.complete && imgEl.naturalWidth) { draw(); }
  else { imgEl.onload = draw; }
};

// voxConfirm(message, onOk) — HTML confirm popup instead of browser confirm()
window.voxConfirm = function(message, onOk) {
  let overlay = document.getElementById('vox-confirm-overlay');
  if (!overlay) {
    overlay = document.createElement('div');
    overlay.id = 'vox-confirm-overlay';
    overlay.style.cssText = 'display:none;position:fixed;inset:0;background:rgba(15,23,42,.5);z-index:99999;align-items:center;justify-content:center;';
    overlay.innerHTML = `
      <div style="background:white;border-radius:16px;padding:28px 28px 20px;max-width:380px;width:90%;box-shadow:0 20px 60px rgba(0,0,0,.2);">
        <p id="vox-confirm-msg" style="font-size:14px;color:#1e293b;line-height:1.6;margin-bottom:20px;font-weight:500;"></p>
        <div style="display:flex;gap:10px;justify-content:flex-end;">
          <button id="vox-confirm-cancel" style="padding:8px 18px;border:1px solid #e2e8f0;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;background:white;color:#64748b;">Huỷ</button>
          <button id="vox-confirm-ok" style="padding:8px 18px;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;background:#ef4444;color:white;">Xác nhận</button>
        </div>
      </div>`;
    document.body.appendChild(overlay);
  }
  document.getElementById('vox-confirm-msg').textContent = message;
  overlay.style.display = 'flex';
  const close = () => { overlay.style.display = 'none'; };
  document.getElementById('vox-confirm-cancel').onclick = close;
  overlay.onclick = (e) => { if (e.target === overlay) close(); };
  document.getElementById('vox-confirm-ok').onclick = () => { close(); onOk(); };
};
</script>
<script>
/* Sidebar collapse/expand */
(function() {
  var STORAGE_KEY = 'vox_sidebar_collapsed';
  function applyState(collapsed) {
    var sb = document.getElementById('main-sidebar');
    var icon = document.getElementById('sidebar-toggle-icon');
    if (!sb) return;
    if (collapsed) {
      sb.classList.add('collapsed');
      if (icon) icon.setAttribute('d-collapsed','1');
      /* Rotate arrow to point right */
      if (icon) icon.querySelector('path').setAttribute('d','M5 2l5 5-5 5');
    } else {
      sb.classList.remove('collapsed');
      if (icon) icon.querySelector('path').setAttribute('d','M9 2L4 7l5 5');
    }
  }
  window.toggleSidebar = function() {
    var sb = document.getElementById('main-sidebar');
    if (!sb) return;
    var collapsed = !sb.classList.contains('collapsed');
    localStorage.setItem(STORAGE_KEY, collapsed ? '1' : '0');
    applyState(collapsed);
  };
  /* Restore state on load */
  document.addEventListener('DOMContentLoaded', function() {
    applyState(localStorage.getItem(STORAGE_KEY) === '1');
  });
  document.addEventListener('turbo:render', function() {
    applyState(localStorage.getItem(STORAGE_KEY) === '1');
  });
})();
</script>
