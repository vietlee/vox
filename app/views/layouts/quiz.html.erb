<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "VOX Quiz" %></title>
  <%= csrf_meta_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_include_tag "application", defer: true %>
  <script>
    MathJax = {
      tex: { inlineMath: [['$', '$'], ['\\(', '\\)']], displayMath: [['$$', '$$'], ['\\[', '\\]']] },
      options: { skipHtmlTags: ['script','noscript','style','textarea','pre'] }
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
  <style>
    html, body { margin: 0; padding: 0; background: #F1F5F9; font-family: 'Inter', sans-serif; min-height: 100vh; }
    * { box-sizing: border-box; }
  </style>
</head>
<body>
  <!-- Header -->
  <div style="background:#1E293B; padding:10px 24px; display:flex; align-items:center; justify-content:space-between;">
    <div style="display:flex; align-items:center; gap:10px;">
      <svg width="26" height="26" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
        <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
        <polygon points="325,84 318,98 338,84" fill="white"/>
        <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
        <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
        <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
        <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
      </svg>
      <span style="font-size:18px; font-weight:800; letter-spacing:5px; color:#1A6BFF;">VOX</span>
    </div>

    <!-- Right side -->
    <div style="display:flex; align-items:center; gap:16px;">
    <span style="color:#94A3B8; font-size:11px; font-weight:700; letter-spacing:2px; text-transform:uppercase;">Quiz</span>
    <!-- Language switcher — preserve all existing query params except locale -->
    <% base_params = request.query_parameters.except("locale") %>
    <% vi_url = request.path + "?" + base_params.merge("locale" => "vi").to_query %>
    <% en_url = request.path + "?" + base_params.merge("locale" => "en").to_query %>
    <div style="display:flex; align-items:center; border-radius:99px; overflow:hidden; border:1px solid rgba(255,255,255,0.12); font-size:11px; font-weight:700;">
      <a href="<%= vi_url %>" data-turbo="false"
         style="padding:5px 14px; text-decoration:none; transition:all .15s;
                <%= I18n.locale.to_s == 'vi' ? 'background:#4F46E5; color:#fff;' : 'color:#64748B;' %>">
        🇻🇳 VI
      </a>
      <a href="<%= en_url %>" data-turbo="false"
         style="padding:5px 14px; text-decoration:none; transition:all .15s;
                <%= I18n.locale.to_s == 'en' ? 'background:#4F46E5; color:#fff;' : 'color:#64748B;' %>">
        🇬🇧 EN
      </a>
    </div>
    </div>
  </div>

  <div style="max-width:720px; margin:0 auto; padding:24px 16px 60px;">
    <%= yield %>
  </div>
</body>
</html>
