<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : "VOX Quiz" %></title>
  <%= csrf_meta_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <%= stylesheet_link_tag "application", media: "all" %>
  <%= javascript_importmap_tags %>
  <script>
    MathJax = {
      tex: { inlineMath: [['$', '$'], ['\\(', '\\)']], displayMath: [['$$', '$$'], ['\\[', '\\]']] },
      options: { skipHtmlTags: ['script','noscript','style','textarea','pre'] }
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
  <style>
    html, body { margin: 0; padding: 0; background: linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%); font-family: 'Inter', sans-serif; min-height: 100vh; }
    * { box-sizing: border-box; scrollbar-width: none; -ms-overflow-style: none; }
    *::-webkit-scrollbar { display: none; }
  </style>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7029957032076351" crossorigin="anonymous"></script>
</head>
<body>
  <!-- Header — matching participate layout -->
  <% base_params = request.query_parameters.except("locale") %>
  <% vi_url = request.path + "?" + base_params.merge("locale" => "vi").to_query %>
  <% en_url = request.path + "?" + base_params.merge("locale" => "en").to_query %>

  <div id="quiz-header" style="position:fixed; top:0; left:0; right:0; z-index:9999;
       background:linear-gradient(135deg, #f8faff 0%, #f0f4ff 50%, #faf5ff 100%);
       padding:10px 16px; display:flex; align-items:center; justify-content:space-between;">
    <!-- Left: logo -->
    <img src="/vox_logo.svg" alt="VOX" style="height:22px; width:auto;">

    <!-- Right: badge + language -->
    <div style="display:flex; align-items:center; gap:12px;">
      <span style="font-size:11px; font-weight:700; letter-spacing:1px; color:#6366f1;
                   padding:4px 12px; border-radius:99px;
                   background:rgba(99,102,241,0.08); border:1px solid rgba(99,102,241,0.15);">
        📝 Quiz
      </span>
      <div style="display:flex; align-items:center; border-radius:99px; overflow:hidden;
                  border:1px solid rgba(99,102,241,0.2); background:rgba(255,255,255,0.7);
                  font-size:11px; font-weight:700;">
        <a href="<%= vi_url %>" data-turbo="false"
           style="padding:5px 14px; text-decoration:none; transition:all .15s;
                  <%= I18n.locale.to_s == 'vi' ? 'background:#4F46E5; color:#fff;' : 'color:#64748b;' %>">
          VI
        </a>
        <a href="<%= en_url %>" data-turbo="false"
           style="padding:5px 14px; text-decoration:none; transition:all .15s;
                  <%= I18n.locale.to_s == 'en' ? 'background:#4F46E5; color:#fff;' : 'color:#64748b;' %>">
          EN
        </a>
      </div>
    </div>
  </div>
  <!-- Spacer -->
  <div style="height:46px;"></div>

  <div style="max-width:680px; margin:0 auto; padding:0 16px 60px;">
    <%= yield %>
  </div>
</body>
</html>
