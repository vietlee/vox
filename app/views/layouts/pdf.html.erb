<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', 'Helvetica Neue', Arial, sans-serif; font-size: 13px; color: #1e293b; line-height: 1.6; background: white; -webkit-print-color-adjust: exact; print-color-adjust: exact; }

    /* ── Cover ──────────────────────────────────────────────────────── */
    .cover { min-height: 100vh; display: flex; flex-direction: column; justify-content: flex-end; padding: 0; background: #0f172a; position: relative; overflow: hidden; page-break-after: always; }
    .cover-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #1e1b4b 0%, #312e81 40%, #4c1d95 100%); }
    .cover-grid { position: absolute; inset: 0; background-image: radial-gradient(circle, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 32px 32px; }
    .cover-glow { position: absolute; top: -120px; right: -120px; width: 480px; height: 480px; background: radial-gradient(circle, rgba(139,92,246,0.4) 0%, transparent 70%); border-radius: 50%; }
    .cover-glow2 { position: absolute; bottom: 80px; left: -80px; width: 320px; height: 320px; background: radial-gradient(circle, rgba(99,102,241,0.3) 0%, transparent 70%); border-radius: 50%; }
    .cover-content { position: relative; z-index: 2; padding: 64px 56px 56px; }
    .cover-tag { display: inline-flex; align-items: center; gap: 6px; background: rgba(139,92,246,0.25); border: 1px solid rgba(139,92,246,0.4); color: #c4b5fd; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 12px; border-radius: 99px; margin-bottom: 28px; }
    .cover-title { font-size: 36px; font-weight: 900; color: #ffffff; line-height: 1.15; margin-bottom: 12px; letter-spacing: -0.02em; }
    .cover-subtitle { font-size: 14px; color: #a5b4fc; font-weight: 500; margin-bottom: 48px; }
    .cover-stats { display: flex; gap: 0; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 32px; }
    .cover-stat { flex: 1; padding-right: 24px; border-right: 1px solid rgba(255,255,255,0.1); margin-right: 24px; }
    .cover-stat:last-child { border-right: none; margin-right: 0; }
    .cover-stat-val { font-size: 32px; font-weight: 900; color: #ffffff; line-height: 1; }
    .cover-stat-lbl { font-size: 10px; color: #94a3b8; margin-top: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; }

    /* ── Page wrapper ───────────────────────────────────────────────── */
    .page { padding: 48px 52px; }
    .page-break { page-break-before: always; }

    /* ── Section header ─────────────────────────────────────────────── */
    .section-header { display: flex; align-items: center; gap: 10px; margin: 0 0 20px; }
    .section-num { width: 28px; height: 28px; border-radius: 8px; background: linear-gradient(135deg, #6366f1, #8b5cf6); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; color: white; flex-shrink: 0; }
    .section-title { font-size: 16px; font-weight: 800; color: #1e1b4b; letter-spacing: -0.01em; }

    /* ── Executive Summary ──────────────────────────────────────────── */
    .exec-card { background: linear-gradient(135deg, #f8faff 0%, #f0f0ff 100%); border: 1px solid #c7d2fe; border-radius: 12px; padding: 20px 24px; margin-bottom: 32px; }
    .exec-card p { font-size: 13px; color: #1e293b; line-height: 1.8; margin-bottom: 8px; }
    .exec-card p:last-child { margin-bottom: 0; }

    /* ── Key metrics ────────────────────────────────────────────────── */
    .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-bottom: 28px; }
    .kpi-card { background: white; border: 1px solid #e2e8f0; border-radius: 10px; padding: 14px 16px; position: relative; overflow: hidden; }
    .kpi-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; border-radius: 10px 10px 0 0; }
    .kpi-card.green::before { background: linear-gradient(90deg, #10b981, #34d399); }
    .kpi-card.red::before   { background: linear-gradient(90deg, #ef4444, #f87171); }
    .kpi-card.purple::before{ background: linear-gradient(90deg, #6366f1, #8b5cf6); }
    .kpi-card.amber::before { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
    .kpi-val { font-size: 26px; font-weight: 900; line-height: 1; margin-bottom: 4px; }
    .kpi-lbl { font-size: 10px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .kpi-card.green .kpi-val { color: #059669; }
    .kpi-card.red   .kpi-val { color: #dc2626; }
    .kpi-card.purple .kpi-val { color: #4f46e5; }
    .kpi-card.amber  .kpi-val { color: #d97706; }

    /* ── Charts overview ────────────────────────────────────────────── */
    .charts-overview { display: grid; grid-template-columns: 200px 1fr; gap: 20px; margin-bottom: 32px; }
    .chart-card { background: #fafafa; border: 1px solid #e8eaf0; border-radius: 10px; padding: 16px; }
    .chart-card-title { font-size: 10px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 12px; }

    /* ── Question chart cards ───────────────────────────────────────── */
    .questions-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 8px; }
    .q-card { background: white; border: 1px solid #e2e8f0; border-radius: 10px; padding: 16px; }
    .q-card.full-width { grid-column: 1 / -1; }
    .q-title { font-size: 11px; font-weight: 700; color: #1e293b; margin-bottom: 4px; line-height: 1.4; }
    .q-subtitle { font-size: 10px; color: #94a3b8; margin-bottom: 12px; }
    .bar-track { height: 8px; background: #f1f5f9; border-radius: 4px; overflow: hidden; margin-top: 3px; }
    .bar-fill  { height: 100%; border-radius: 4px; }
    .bar-row   { margin-bottom: 8px; }
    .bar-label { display: flex; justify-content: space-between; font-size: 10px; color: #475569; margin-bottom: 2px; }
    .bar-label span.pct { font-weight: 700; color: #6366f1; }
    .score-display { display: flex; align-items: baseline; gap: 4px; margin-bottom: 10px; }
    .score-big   { font-size: 36px; font-weight: 900; color: #4f46e5; line-height: 1; }
    .score-max   { font-size: 14px; color: #94a3b8; font-weight: 500; }
    .score-label { font-size: 10px; color: #64748b; margin-top: 2px; }
    .dist-bar-row { display: flex; align-items: center; gap: 6px; margin-bottom: 5px; }
    .dist-val-lbl { width: 18px; text-align: right; font-size: 10px; color: #64748b; font-weight: 600; flex-shrink: 0; }
    .dist-track { flex: 1; height: 14px; background: #f1f5f9; border-radius: 4px; overflow: hidden; }
    .dist-fill  { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #6366f1, #8b5cf6); }
    .dist-count { width: 28px; font-size: 10px; color: #64748b; text-align: right; flex-shrink: 0; }
    .text-q-stat { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: #f8fafc; border-radius: 8px; }
    .text-q-num  { font-size: 24px; font-weight: 900; color: #6366f1; }
    .text-q-lbl  { font-size: 11px; color: #64748b; }

    /* ── AI Insights / Sections ─────────────────────────────────────── */
    .insights-list { display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; }
    .insight-item { border-left: 3px solid #6366f1; padding: 10px 14px; background: #f8f9ff; border-radius: 0 8px 8px 0; }
    .insight-heading { font-size: 12px; font-weight: 700; color: #3730a3; margin-bottom: 4px; }
    .insight-body    { font-size: 12px; color: #374151; line-height: 1.7; }
    .key-finding { display: flex; gap: 8px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 6px; padding: 8px 12px; margin-top: 6px; font-size: 11px; color: #92400e; font-style: italic; }

    /* ── Recommendations ────────────────────────────────────────────── */
    .recs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .rec-card { border-radius: 10px; padding: 14px 16px; border: 1px solid; }
    .rec-card.high   { background: #fff5f5; border-color: #fecaca; }
    .rec-card.medium { background: #fffbeb; border-color: #fde68a; }
    .rec-card.low    { background: #f0fdf4; border-color: #bbf7d0; }
    .rec-num  { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 6px; }
    .rec-card.high   .rec-num { color: #dc2626; }
    .rec-card.medium .rec-num { color: #d97706; }
    .rec-card.low    .rec-num { color: #16a34a; }
    .rec-action   { font-size: 12px; font-weight: 700; color: #1e293b; margin-bottom: 5px; line-height: 1.4; }
    .rec-rationale{ font-size: 11px; color: #64748b; margin-bottom: 4px; line-height: 1.5; }
    .rec-impact   { font-size: 11px; color: #4f46e5; font-style: italic; }

    /* ── Conclusion ─────────────────────────────────────────────────── */
    .conclusion-card { background: linear-gradient(135deg, #f0fdf4, #ecfdf5); border: 1px solid #86efac; border-radius: 12px; padding: 18px 22px; margin-top: 24px; }
    .conclusion-card p { font-size: 13px; color: #166534; line-height: 1.8; }

    /* ── Footer ─────────────────────────────────────────────────────── */
    .footer { margin-top: 32px; padding-top: 14px; border-top: 1px solid #e2e8f0; display: flex; justify-content: space-between; font-size: 10px; color: #94a3b8; }
    .vox-badge { display: inline-flex; align-items: center; gap: 4px; background: #f1f5f9; border-radius: 4px; padding: 2px 8px; font-weight: 700; color: #6366f1; }

    /* ── Page breaks ────────────────────────────────────────────────── */
    h2, .section-header { page-break-after: avoid; }
    .q-card, .rec-card { page-break-inside: avoid; }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
