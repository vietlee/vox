<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Helvetica Neue', Arial, sans-serif; font-size: 13px; color: #1e293b; line-height: 1.6; padding: 40px 48px; }
    h1 { font-size: 22px; font-weight: 800; color: #1e1b4b; margin-bottom: 4px; }
    .meta { font-size: 11px; color: #94a3b8; margin-bottom: 32px; }
    h2 { font-size: 13px; font-weight: 700; color: #4338ca; background: #eef2ff; padding: 6px 10px; border-radius: 5px; margin: 24px 0 8px; border-left: 3px solid #6366f1; }
    p { font-size: 13px; color: #374151; line-height: 1.7; margin-bottom: 8px; }
    .key-finding { font-size: 11px; color: #64748b; font-style: italic; margin: 6px 0 0 12px; }
    .rec { display: flex; gap: 8px; margin-bottom: 6px; font-size: 12px; }
    .rec-badge { font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 3px; flex-shrink: 0; margin-top: 2px; }
    .high   { background: #fef2f2; color: #dc2626; border: 1px solid #fecaca; }
    .medium { background: #fffbeb; color: #d97706; border: 1px solid #fde68a; }
    .low    { background: #f8fafc; color: #64748b; border: 1px solid #e2e8f0; }
    .conclusion { background: #f8fafc; border-radius: 8px; padding: 16px; margin-top: 8px; }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
