<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Super Admin — Vox</title>
  <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
  <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
  <%= javascript_importmap_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <style>
    /* Critical CSS — prevents FOUC during Turbo navigation / CSS lazy-compile */
    html,body{height:100%;margin:0}
    body{background:#f1f5f9;font-family:Inter,system-ui,sans-serif}
    .flex{display:flex}.flex-col{flex-direction:column}
    .h-full{height:100%}.overflow-hidden{overflow:hidden}
    aside{background:#0F172A;width:200px;min-width:200px;flex-shrink:0;display:flex;flex-direction:column;padding:16px}
    aside a{color:#94a3b8;font-size:13px;text-decoration:none;padding:4px 0;display:block}
    .flex-1{flex:1 1 0}.overflow-auto{overflow:auto}
    header{height:48px;background:#fff;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:flex-end;padding:0 24px;flex-shrink:0}
  </style>
  <link rel="icon" href="/icon.png" type="image/png">
</head>
<body class="h-full font-inter antialiased bg-slate-100">
<div class="flex h-full">
  <aside class="w-[200px] bg-[#0F172A] flex flex-col flex-shrink-0 p-4">
    <div class="flex items-center gap-2 mb-0.5">
      <svg width="24" height="24" viewBox="295 27 90 90" xmlns="http://www.w3.org/2000/svg">
        <rect x="305" y="38" width="70" height="70" rx="18" fill="#1A6BFF"/>
        <polygon points="325,84 318,98 338,84" fill="white"/>
        <rect x="317" y="49" width="46" height="37" rx="9" fill="white"/>
        <rect x="326" y="59" width="7" height="14" rx="2" fill="#1A6BFF"/>
        <rect x="338" y="53" width="7" height="26" rx="2" fill="#1A6BFF"/>
        <rect x="350" y="57" width="7" height="18" rx="2" fill="#1A6BFF"/>
      </svg>
      <span style="font-size:15px;font-weight:800;color:#1A6BFF;letter-spacing:2.5px;line-height:1;">VOX</span>
    </div>
    <div class="text-[10px] text-slate-500 mb-5">Super Admin</div>
    <%= link_to super_admin_root_path, class: "text-[13px] text-slate-400 hover:text-white py-1" do %><%= t("super_admin.nav.dashboard") %><% end %>
    <%= link_to super_admin_workspaces_path, class: "text-[13px] text-slate-400 hover:text-white py-1" do %><%= t("super_admin.nav.workspaces") %><% end %>
    <%= link_to super_admin_subscriptions_path, class: "text-[13px] text-slate-400 hover:text-white py-1" do %><%= t("super_admin.nav.subscriptions") %><% end %>
    <%= link_to super_admin_plan_configs_path, class: "text-[13px] text-slate-400 hover:text-white py-1" do %><%= t("super_admin.nav.plan_configs") %><% end %>
    <%= link_to super_admin_addon_configs_path, class: "text-[13px] text-slate-400 hover:text-white py-1" do %><%= t("super_admin.nav.addon_configs") %><% end %>
    <%= link_to super_admin_broadcasts_path, class: "text-[13px] text-slate-400 hover:text-white py-1" do %>📢 <%= t("super_admin.nav.broadcasts") %><% end %>
    <div class="mt-auto">
      <button type="button" onclick="document.getElementById('logout-modal').classList.remove('hidden')" class="text-[12px] text-slate-600 hover:text-slate-400 bg-transparent border-0 cursor-pointer p-0"><%= t("super_admin.nav.sign_out") %></button>
    </div>
  </aside>
  <div class="flex-1 flex flex-col overflow-hidden">
    <!-- Top bar -->
    <header class="h-12 bg-white border-b border-slate-200 flex items-center justify-end px-6 gap-2 flex-shrink-0">
      <div class="flex gap-0.5 bg-slate-100 border border-slate-200 rounded-lg p-0.5">
        <%= link_to request.path + "?locale=vi", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :vi ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇻🇳 VI<% end %>
        <%= link_to request.path + "?locale=en", class: "px-2.5 py-1 rounded-md text-[11px] font-semibold #{I18n.locale == :en ? 'bg-white text-indigo-600 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" do %>🇬🇧 EN<% end %>
      </div>
    </header>
    <div class="flex-1 overflow-auto p-6">
      <% if notice %><div class="mb-4 p-3 bg-emerald-50 border border-emerald-200 text-emerald-800 rounded-lg text-[13px]"><%= notice %></div><% end %>
      <% if alert %><div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-[13px]"><%= alert %></div><% end %>
      <%= yield %>
    </div>
  </div>
</div>
<!-- Logout confirm modal -->
<div id="logout-modal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 w-full h-full flex items-center justify-center">
    <div class="absolute inset-0 bg-black/40" onclick="document.getElementById('logout-modal').classList.add('hidden')"></div>
    <div class="relative bg-white rounded-2xl shadow-xl p-6 w-[320px] text-center">
      <div class="text-[32px] mb-3">👋</div>
      <h3 class="text-[16px] font-extrabold text-slate-900 mb-1"><%= t("super_admin.logout.title") %></h3>
      <p class="text-[13px] text-slate-500 mb-5"><%= t("super_admin.logout.desc") %></p>
      <div class="flex gap-2">
        <button onclick="document.getElementById('logout-modal').classList.add('hidden')"
          class="flex-1 py-2.5 bg-slate-100 text-slate-700 text-[13px] font-semibold rounded-xl hover:bg-slate-200 border-0 cursor-pointer">
          <%= t("super_admin.logout.cancel") %>
        </button>
        <%= button_to destroy_user_session_path, method: :delete,
              form_class: "flex-1",
              class: "w-full py-2.5 bg-red-500 text-white text-[13px] font-semibold rounded-xl hover:bg-red-600 border-0 cursor-pointer" do %>
          <%= t("super_admin.logout.confirm") %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:before-cache', function() {
    document.querySelectorAll('[id$="-modal"]').forEach(function(el) {
      el.classList.add('hidden');
    });
  });
</script>
</body>
</html>
