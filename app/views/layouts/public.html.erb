<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : (I18n.locale == :vi ? "VOX — Nền tảng Khảo sát & Bình chọn Trực tiếp" : "VOX — Live Survey & Voting Platform") %></title>
  <meta name="description" content="<%= I18n.locale == :vi ? 'VOX giúp bạn tạo khảo sát, bình chọn và thu thập phản hồi theo thời gian thực. Miễn phí để bắt đầu.' : 'VOX helps you create surveys, live votes, and collect feedback in real-time. Free to get started.' %>">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/icon.png" type="image/png">
  <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
  <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
  <style>
    :root,:host{--color-violet-50:#eef3f9;--color-violet-100:#d9e5f1;--color-violet-200:#b3cbe3;--color-violet-300:#7aaac9;--color-violet-400:#4a80a8;--color-violet-500:#2d5f8a;--color-violet-600:#1e3a5f;--color-violet-700:#162c47;--color-violet-800:#0e1e30;--color-violet-900:#070f18;--color-indigo-50:#eef3f9;--color-indigo-100:#d9e5f1;--color-indigo-200:#b3cbe3;--color-indigo-300:#7aaac9;--color-indigo-400:#4a80a8;--color-indigo-500:#2d5f8a;--color-indigo-600:#1e3a5f;--color-indigo-700:#162c47;--color-indigo-800:#0e1e30;--color-indigo-900:#070f18;}
  </style>
  <%= javascript_importmap_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <%= csrf_meta_tags %>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7029957032076351" crossorigin="anonymous"></script>
</head>
<body class="font-inter antialiased bg-white text-slate-900" style="overflow-x:hidden;max-width:100vw">
  <%= yield %>
</body>
</html>
