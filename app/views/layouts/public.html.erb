<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for?(:title) ? yield(:title) : (I18n.locale == :vi ? "VOX — Nền tảng Khảo sát & Bình chọn Trực tiếp" : "VOX — Live Survey & Voting Platform") %></title>
  <meta name="description" content="<%= I18n.locale == :vi ? 'VOX giúp bạn tạo khảo sát, bình chọn và thu thập phản hồi theo thời gian thực. Miễn phí để bắt đầu.' : 'VOX helps you create surveys, live votes, and collect feedback in real-time. Free to get started.' %>">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="icon" href="/icon.png" type="image/png">
  <%= stylesheet_link_tag "tailwind", data: { turbo_track: "reload" } %>
  <%= stylesheet_link_tag "application", data: { turbo_track: "reload" } %>
  <%= javascript_importmap_tags %>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <%= csrf_meta_tags %>
</head>
<body class="font-inter antialiased bg-white text-slate-900" style="overflow-x:hidden;max-width:100vw">
  <%= yield %>
</body>
</html>
