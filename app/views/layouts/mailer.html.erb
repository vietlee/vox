<!DOCTYPE html>
<html lang="vi">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VOX</title>
  <style>
    @media only screen and (max-width: 600px) {
      .email-outer  { padding: 16px 8px !important; }
      .email-card   { border-radius: 12px !important; }
      .email-body   { padding: 24px 20px 28px !important; }
      .email-logo   { font-size: 22px !important; padding-bottom: 16px !important; }
      .email-footer { padding-top: 16px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#eef3f9;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#eef3f9;">
    <tr>
      <td align="center" class="email-outer" style="padding:40px 16px;">
        <table cellpadding="0" cellspacing="0" style="max-width:560px;width:100%;">

          <!-- Logo -->
          <tr>
            <td align="center" class="email-logo" style="padding-bottom:20px;">
              <span style="font-size:26px;font-weight:900;color:#1e3a5f;letter-spacing:-0.5px;">VOX</span>
            </td>
          </tr>

          <!-- Card -->
          <tr>
            <td class="email-card" style="background-color:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 2px 12px rgba(30,58,95,0.10);">
              <div style="height:4px;background:linear-gradient(90deg,#1e3a5f,#2d5f8a);"></div>
              <div class="email-body" style="padding:36px 36px 32px;">
                <%= yield %>
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td align="center" class="email-footer" style="padding-top:20px;">
              <p style="margin:0;font-size:12px;color:#94a3b8;">© <%= Date.current.year %> VOX &middot; Nền tảng học tập thông minh</p>
              <p style="margin:4px 0 0;font-size:12px;color:#cbd5e1;">Email này được gửi tự động, vui lòng không reply.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
